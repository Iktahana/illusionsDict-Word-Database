    "definitions": [
      {
        "index": 1,
        "gloss": "(piece of) writing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "書斎の机には、彼が長年書き溜めてきたと思われる膨大な量の書き物が積み上げられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "江戸時代の書き物を現代語に訳す作業は、当時の暮らしを追体験するような面白さがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この書き物、父が若い頃に書いた小説の草稿かしら。初めて見たわ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "我を厭ふ隣家寒夜に鍋を鳴らす　霜に更ける冬の夜、遅く更けた燈火の下で書き物などしているのだろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川末期の市井の状態の書き物を見ると、斯んな風俗が盛んに行はれた事が解る。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "地名も旅館の名もしばらく秘しておくが、わたしがかつてある温泉旅館に投宿した時、すこし書き物をするのであるから、なるべく静かな座敷を貸してくれというと、二階の奥まった座敷へ案内され、となりへは当分お客を入れないはずであるから、ここは確かに閑静であるという。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚無僧である以上、普化宗本寺の取名印、すなわち竹名を許されたという証印の書き物を所持している筈であるが、彼らは、尺八、天蓋、袈裟などの宗具のほかには、何物も所持していなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに実際は大ちがいで、私は書き物をする時の外、殆ど半日も家の中にいたことがない。",
              "citation": {
                "source": "秋と漫歩",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆やのお駒が私の部屋へ来て、芝生越の樹立ちの中の小亭を指して云う「大川さんが来る前は書き物をするからあすこへ閉じこもると仰るので、ほかのお客を断わってお貸ししてありますのに、赫子さんが来ると何も放り出してあの通り……。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四）○机の上に片肘をついて煙草を吹かしながら、私は書き物に疲れた眼を置時計の針に遊ばせてゐた。",
              "citation": {
                "source": "歌のいろ／＼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日になってみれば頗る貴重な書き物が維新当時にみんな反古にされてしまったからね。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱には錠がおろしてあって、それがもう錆ついているのを叩きこわしてみると、箱の底には一封の書き物と女の黒髪とが秘めてあった。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その書き物の文字はいちいち正確には記憶していないが、大体こんなことが書いてあったのだ。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし梶井の父というのはいわゆる文明開化の人であったから、ただ一笑に付したばかりで、その書き物も黒髪もそこらに燃えている焚火のなかへ投げ込ませようとしたのを、細君は女だけにまず遮った。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹽山でかの女に熱が俄かに出て晝間からとこへ這入つた時、こちらは書き物にいそがしい中を温泉附近の醫者を呼びに行つてやつたり、氷を缺いてやつたり、一と晩中、よく介抱もしたりした。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き物をしていた江藤医学士が庄平を見つける。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護婦「江藤先生、お電話です」江藤「有難う、今直ぐ……」江藤、先刻からの書き物に区切りをつけるために、万年筆を取りあげ、それをしきりに振る。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと書き物すると、脳がのぼせてくらくらしまんねん。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔生は旅費がないので帰ることもできず、菩陀寺という寺へ往って、そこの僧に傭われて書き物をした。",
              "citation": {
                "source": "嬌娜",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三方には本棚があり、書き物机は何の変哲もない窓に向かって置かれ、そこから庭が見渡せた。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくし、いい赤革張りの書き物机を新調しまして、誓って申し上げて、バニスタも請け合いましょうが、ずっと毛羽も汚れもございません。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかしな書き物だったな。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまの場合、この書き物を調べてみるなら、君はそういうひどく込んでいるところが五カ所あることをたやすく眼にとめるだろう。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこれこそあの書き物にある『悪魔の腰掛け』にちがいないと思い、もうあの謎の秘密をすっかり握ったような気がしたよ。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "原稿用紙からワードプロセッサーに転向した者の実感としては、巻紙は書き物の舞台として、悪い選択ではありません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして懐中から一枚の書き物を出して、それを前にひろげて、小石を重りにして置いた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "つやが枕の下をさがすとそこから、手術の前の晩につやが書き取った書き物が出て来た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時この小さな書き物もお前たちの眼の前に現われ出るだろう。",
              "citation": {
                "source": "小さき者へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちがこの書き物を読んで、私の思想の未熟で頑固なのを嗤う間にも、私たちの愛はお前たちを暖め、慰め、励まし、人生の可能性をお前たちの心に味覚させずにおかないと私は思っている。",
              "citation": {
                "source": "小さき者へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこの書き物を私はお前たちにあてて書く。",
              "citation": {
                "source": "小さき者へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しこの書き物を読む時があったら、同時に母上の遺書も読んでみるがいい。",
              "citation": {
                "source": "小さき者へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さる盛りの短かきものなれば、暫時も似よとこの名は負せけん、名づけ親ぞ知らまほしき。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "拂底な蝋燭の、それも細くて、穴が大きく、心は暗し、數でもあればだけれども、祕藏の箱から……出して見た覺えはないけれど、寶石でも取出すやうな大切な、その蝋燭の、時よりも早くぢり／＼と立つて行くのを、氣を萎して、見詰めるばかりで、かきもの所の沙汰ではなかつた。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
