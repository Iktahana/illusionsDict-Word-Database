    "definitions": [
      {
        "index": 1,
        "gloss": "to raise one's head (esp. of a snake)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "危険を感じた蛇は、素早く鎌首をもたげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "獲物を狙う蟷螂が、ゆっくりと鎌首をもたげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「危ない！」と叫びながら、彼は身を守るように鎌首をもたげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "恐竜がぐいと鎌首をもたげると、うなり声をあげて怒り出した。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「織江殿」　といいながら、九十郎は両手を顎の下へかい、蛇が鎌首をもたげるように、顔をもたげて薄ら笑いをした。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ベク助とても悪党の筋が一本通っている点では人後に落ちない曲者だから、みんな見破られているようだと分っていても、よろしい、一そうやってやれという不逞な根性が鎌首をもたげるのである。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十三　幻の塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、怪物のほうでも、その声におどろいて、ピッタリはうのをやめ、グーッとかまくびをもたげるようにして、小林君のほうを見あげました。",
              "citation": {
                "source": "虎の牙",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
