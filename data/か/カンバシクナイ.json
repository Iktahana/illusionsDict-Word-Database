        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それをこのカチカチ山ばかりは、どうも、その仇討の仕方が芳しくない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "義姉は母の躾がよかったのか、村の小学校で、文吉や順平の成績が芳しくないのは可哀相だと面と向って云うのだ。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "義姉は母の躾がよかったのか、村の小学校で、文吉や順平の成績が芳しくないのは可哀相だと面と向って同情顔した。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがざっとあたりを見渡してみるにつけ、ペンの評判はどうも芳しくない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を見る人が少ないために、芳しくないということは無い」とある。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "商業資本家展の出品に対する考へ方に案外ルーズな見方をしてゐるといふ事は芳しくない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼にはほかにも芳しくない話がいくつかある。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟は放蕩をはじめ、マリアのところには何か芳しくないロマンスがある。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京へ戻ってから母に伝えた槙三の報告は恐らく芳しくないにちがいないのを、前から矢代は覚悟していたからだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには一種芳しくない知識がまじつてゐるので、水を注されたやうな反省が起つたのであつた。",
              "citation": {
                "source": "花の前花のあと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私個人の意見をもつてすれば、国民全体の「武人化」などゝいふことは、理想として芳しくないと思ふ。",
              "citation": {
                "source": "一国民としての希望",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ淡々とあまり芳しくない現状を語り、その原因について意見を述べ、最後に、「急ぐからと云つて無理をしちやいかんでな。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手のミネリア国のドン・マルコス大使も細身の褐色肌、目が狡猾で、評判は芳しくない。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間後も芳しくない。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "バイオリズムからするとオーラの放出度は決して芳しくないが、それにもかかわらずグリーンが今日自分と交感することに対して隼人はほとんど確信に近い気持ちを抱いていた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だけど養子なんて、あまり芳しくないな。",
              "citation": {
                "source": "おじさんの話",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、そこで、二網ほど入れたが、成績が芳しくないので、場所を変えることにした。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "モンテーニュに関するあまり芳しくない伝説の半分はここから生れている。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルデラ氏は政府役人でもあり、著名な下院議員だが、評判は芳しくない。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士があまり品行のかんばしくない人であることはすぐにわかった。",
              "citation": {
                "source": "或る探訪記者の話",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "小山内さんの批評はかんばしくないのが常で伊藤はたいがい意気銷沈して帰つてきたようである。",
              "citation": {
                "source": "私の活動写真傍観史",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような娘は折々｜運命の間違いであまりかんばしくない家庭に生まれてくるものである。",
              "citation": {
                "source": "頸飾り",
                "author": "モウパンサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにこの荒れはてた工場については、数箇月前のことであるが、恥の上塗りのようなかんばしくない事件がおこった。",
              "citation": {
                "source": "骸骨館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "余の傷は幸いに軽微であったが、世評は余にかんばしくないようである。",
              "citation": {
                "source": "中庸",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまりかんばしくないことだ――　彼は、南原杉子とすっかり関係をたつべきだと考えていた。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "５．仕事をするに際して、その努力の對象に充分注意が行屆かないとか或はあまり急ぎ過ぎたりするときまつて結果がかんばしくない。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには既製品の数字のゴム印が大小幾種類もあつたので、私は初号型のゴム印で１から０までそろつて箱入りになつてるやつを二三箱ほどためしに買つて、家に戻つてから工夫一番智慧をしぼつてみたが、どうもかんばしくない。",
              "citation": {
                "source": "老残",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ、そんなときにはたいていはあまりかんばしくない結果になるのだった。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルガのかんばしくないさまざまなニュースによって、Ｋは当惑してしまったが、それでも一つだけ埋合せになる点を見つけた。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そのためにバルナバスは、かんばしくないのろのろした使者だっていう悪評を立てられてしまいました。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
