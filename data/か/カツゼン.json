[
  {
    "uuid": "b3623f6f-a783-576a-8680-9b22c0198425",
    "entry": "戛然",
    "reading": {
      "primary": "かつぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞-と",
        "形容詞-たる"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "with a clang",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "審判の笛が戛然と鳴り響き、試合終了を告げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の言葉が戛然として、その場の空気を一変させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い教会の鐘が、戛然と深夜の街に響き渡った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "石鉄｜戛然火花を散らしぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "健在なれ、御身等、今若、牛若、生立てよ、と窃に河野の一門を呪って、主税は袂から戛然と音する松の葉を投げて、足｜疾くその前を通り過ぎた。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の水は澄み切って、鮎の鰭ほどの曇りもないから、差覗くと、浅い底に、その銀の平打の簪が映って、流が糸のようにかかるごとに、小石と相撃って、戛然として響くかと、伸びつ、縮みつする。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手を伸べて、輝くものを戛然と鳴らすよと思う間に、掌より滑る鎖が、やおら畳に落ちんとして、一尺の長さに喰い留められると、余る力を横に抜いて、端につけた柘榴石の飾りと共に、長いものがふらりふらりと二三度揺れる。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻糜を抜くや戛然たる響きが見物席へ伝わった。",
              "citation": {
                "source": "越後の闘牛",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、潮どきを見はからつた小幡氏が、わざと戛然たる靴音を二つ三つ響かせながら、ヴェランダに降りてきた。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの腕輪は再びきらめいて、玉と玉と撃てる音か、戛然と瞬時の響きを起す。",
              "citation": {
                "source": "薤露行",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸吉が三十年の苦心を重ねて錬磨した技術の精妙さ、急角度旋回の秘法は見事に極って、あっと言う間もなく、怨讐二つの飛行具は、戛然として空中に噛み合ったと見るや、絡み合ったまま、幾百千丈の谷底へ――、キリキリと轉落して行ったのです。",
              "citation": {
                "source": "天保の飛行術",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "切なる願納受する神、プォイボス・アポローン、包み掩へる胡※と白銀の弓肩にしてウーリュンポスの高嶺より怒に燃えて駈け降り、　45夜の俄かに寄する如凄く駈け來るアポローン、怒の神の肩の上、矢は戛然と鳴りひびく。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "戰車を落つるパンダロス、其燦爛の戰裝は戛然として鳴りひゞき、足とき駒はをののけり。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "つきまとう木剣の下に、戛然と、槍が折れた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この名刀、この腕の持主が、五百石に足らぬ扶持を取りかね、いつまでも懸り人で朽ちているとは」　そういって、戛然と、抱いていた物干竿の柄を鳴らし、「盲め！",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜叉のごとく荒れまわった忍剣は、突として、いっぽうの捕手をかけくずし、そのわずかなすきに、ふたたび鷲の鎖をねらって、一念力、戛然とうった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白布で、目をふさがれている法師すがたは、その時、顔をあげ、肩をゆすぶッて、なにやら、無念そうに叫ぼうとしたが、「徳川家に仇なすやつ、やがて、あとからいく伊那丸の先駆けをしろッ」　という、半助のののしりに消され、それと同時に、戛然と剣がひらめいた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、棒をとって、立ち向ったのだが、戛然、白刃と棒が相｜搏ッたと思うやいな、どこをどうして打ち込んでいたのか、誰の眼にもとまらなかった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戛然と、戟の柄がつづいて斬られた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼方の水の上を」　一颯の光は戛然と鳴った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼に比して、織部の槍は、細目だったせいか、戛然、けら首のあたりからポキンと折れて、その穂先だけが、あたかも氷片のように遠くへ飛んだ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　戛然と、二度目の剣が、空間に鳴った。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よわが宝剣の威を」　と、戛然、抜き払った一閃の下に、于吉の首を刎ねてしまった。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな、敵の謀略にのって」　と、跳び上がったが、その叫びも終らないうちに、後ろにまわっていた武士の手から、戛然、大剣は鳴って、その首すじへ振り落された。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その首を前へのばすや否や、戛然、剣は彼の頸を断った。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　振り向いた頭上から、戛然、一｜閃の白刃がおりてきた。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞穴の口は高さ五尺、はば二尺にすぎないが、はいってみると、かつぜんと内部は広くなり、二十尺四方の広間となり、地上にはかわいた砂をしきつめてあった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "森をぬけると視野はかつぜんと開けて、砂浜の先に、たけりくるった黒い海が、白いきばをむきたてて、なぎさをかんでいる。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
