    "definitions": [
      {
        "index": 1,
        "gloss": "to write out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "日記帳に、今日の出来事を詳しく書き表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "作家は、作品に込めた思いをエッセイで書き表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "裁判官は、判決の理由を逐一書き表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、複雑な感情を詩に書き表すのが得意だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それから、出来るだけ詩に見えるやうにしようと言ふ工夫と、字を出来るだけ少くして書き表す、見た目はまるで漢詩を見るやうな感じを表さうと言ふやうな事もやつてをります。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の分數を書き表すにはまづ横線を引き、その上に分子を、その下に分母を書く。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは、どうしていちいち解釈を経なければ法が何であるかが解らないような法規を作るのか、もっと平明に法そのものを法規として書き表すことはできないものであろうか。",
              "citation": {
                "source": "法学とは何か",
                "author": "――特に入門者のために",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to publish",
        "register": "standard",
        "nuance": null,
