[
  {
    "uuid": "eb2fb356-13ac-5938-ad6a-e14bdf602901",
    "entry": "空回り",
    "reading": {
      "primary": "からまわり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
