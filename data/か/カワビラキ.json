[
  {
    "uuid": "1f2fe66e-7848-5608-aadb-5c3c602b6de3",
    "entry": "川開き",
    "reading": {
      "primary": "かわびらき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
