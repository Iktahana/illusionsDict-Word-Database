        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "デスクの隅には、いつも数個の紙屑籠が置かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちが描いた絵でいっぱいになった紙屑籠を、母親は嬉しそうに眺めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議室の備品リストに、紙屑籠が追加された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "何の関係もない色々の工場で製造された種々の物品がさまざまの道を通ってある家の紙屑籠で一度集合した後に、また他の家から来た屑と混合して製紙場の槽から流れ出すまでの径路に、どれほどの複雑な世相が纏綿していたか、こう一枚の浅草紙になってしまった今では再びそれをたどって見るようはなかった。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は一度｜紙屑籠へほうり込んであった包み紙やひもや名あて札をもう一ぺん検査して見た。",
              "citation": {
                "source": "球根",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "車の一番上に積まれた紙屑籠につめたランプのホヤがキラキラ光る。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所へ出ると、柱には細長い竹の紙屑籠が掛けてあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七は紙屑籠をおろして、念のために紙屑をつかみ出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "半紙は幾きれにも引き裂いて丸めてあるので、その皺を伸ばして継ぎ合わせてみると、女の筆の走り書きで、書いては消し、消しては書き、どうも思うように書けないので、中途で引き裂いて紙屑籠へ押し込んでしまったらしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして括り紐と包み紙とは一緒くたに丸めて紙屑籠に投り込んだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "本場のフランスでさえ、セザンヌの住んでいた村でセザンヌは理解されていなかったし、ゴッホの忠実な弟がいなかったら、そして理解のある弟の妻がいなかったら、私たちはゴッホを紙屑籠の中へ失ったであろう。",
              "citation": {
                "source": "ディフォーメイションへの疑問",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな紙屑籠、重ねあげられた書類、ひとり女が仕事している。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又夜になったら、あのつづきを書くために、私の紙屑籠が肥らされるのであろう。",
              "citation": {
                "source": "曇天",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つとも引き出しは抜きっぱなしになって、私共がふだん一寸拾ったボタンだの、ピン、小布などの屑同様のものを矢鱈につめこんであるのが、皆な引っぱり出されて、あかあるい日の中に紙屑籠を引っくり返した様になって居る。",
              "citation": {
                "source": "盗難",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "………紙屑籠………唾壺………小型の瓦斯ストーブなぞ……。",
              "citation": {
                "source": "涙のアリバイ",
                "author": "――手先表情映画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり多少芸術的なる青銅製の紙屑籠を思えば好し。",
              "citation": {
                "source": "北京日記抄",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だい、それは」「こっちが紙屑籠、こっちが洋灯の台」「そんなハイカラな形姿をして、大きな紙屑籠なんぞを提げてるから妙なんだよ」「妙でも仕方がない、頼まれものだから」「頼まれて妙になるのは感心だ。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "君に紙屑籠を提げて往来を歩くだけの義侠心があるとは思わなかった」　小野さんは黙って笑ながら御辞儀をした。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その紙屑籠を出せ。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙屑籠を受取ろうと云う謎である。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼鏡の縁から、斜めに宗近君を見ると、相変らず、紙屑籠を揺って、揚々と正面を向いて歩いている。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙屑籠はどこにあるの」　欽吾は答えなかった。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、アッアッアと背延びをしながら紙屑籠へ投げこんだから、どこの紳士だか知らないが、女房子供に気を配つて油断なく書き上げた手紙であらうに、なんにもならなくなつたのである。",
              "citation": {
                "source": "総理大臣が貰つた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとの三分の二は、未亡人が読みながら引き裂いて、紙屑籠のなかへほうり込んでしまつたのである。",
              "citation": {
                "source": "続言葉言葉言葉（その二）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ出版屋のガリマアル君が、そつと紙屑籠から拾ひだしたといふ「日記の破片」を、多くのルナアル党は早く増補として世に出せと注文した。",
              "citation": {
                "source": "続言葉言葉言葉（その二）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「好い子だから向うへ行って一人でお遊び」　彼は子供を推しのけながら、紙を丸めて力任せに紙屑籠の中に抛り込んだ。",
              "citation": {
                "source": "幸福な家庭",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間にも、よく鼻をおかみで、紙屑籠はじきに一杯です。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその原稿によって小酒井さんは創作の材料を得たのでは無く、その原稿は全然紙屑籠の中へ入れるていのものであったそうです。",
              "citation": {
                "source": "小酒井さんのことども",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　木元は、すっかり正気にかえって、ウィスキーの空き罎を紙屑籠の中へ投りこむと、立ちあがった。",
              "citation": {
                "source": "ニュー・ヨーク　『青春の自画像』より",
                "author": "前田河広一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京のやうに紙屑籠を、又は玩具箱を引つくり返したやうな殺風景な土地は、何処へ行つてもあらうと思へない。",
              "citation": {
                "source": "東京の風俗　序",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人の下っ引き葬式彦兵衛は紙屑籠を肩に担いで八百八町を毎日風に吹かれて歩くのが持前の道楽だったのだった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "のの字の刀痕",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ後から、これだけは片時も離さない紙屑籠を担いで葬式彦兵衛が面白くもなさそうに尾いて行った。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "のの字の刀痕",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうせ一日か二日すれば会うんだから……」　こんな事を思ってうす青のライティングペーパアを原稿紙ばっかりのかみくずかごの中に点を打った様にコロッと一つなげ込んだ。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
