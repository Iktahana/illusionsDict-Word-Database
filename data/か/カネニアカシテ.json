  {
    "uuid": "5ebd32bd-d553-56d0-b655-935719086342",
    "entry": "金に飽かして",
    "reading": {
      "primary": "かねにあかして",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
