        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "民漢服及削髮不如式者死。",
              "citation": {
                "source": "支那人辮髮の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "實際頂髮式に背いた爲、又は漢服を着けた爲に、死罪に處せられた者がある（５）。",
              "citation": {
                "source": "支那人辮髮の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "上に引用した『皇明實録』の記事では、元朝の政策の結果の樣にも考へられるが、然し元一代を通じて――未だ十分の調査はせぬが――漢服・蓄髮の禁令は發布されて居らぬ樣である。",
              "citation": {
                "source": "支那人辮髮の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
