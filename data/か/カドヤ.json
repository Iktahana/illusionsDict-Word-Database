      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "house located on a street corner",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "角家は二方向から光が入るため日当たりは抜群だが、通行人の視線が少し気になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "住宅街の角家を改装して、土日だけオープンする小さな古本屋を始めることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「角家なら車庫入れが楽ですよ」という不動産屋の言葉が決め手となって、この家を買った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そのかわり、町の出はずれを国道へついて左へ折曲ろうとする角家の小店の前に、雑貨らしい箱車を置いて休んでいた、半纏着の若い男は、軒の藤を潜りながら、向うから声を掛けた。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしに稚気もあって、女房持ちになってから兎角家にこびりつく、つまり野暮だと言われ度くないために仲間の交際いは出来るだけ勤めたい。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その自動車が、町の角家で見つかりました時、夜目に横町をすかしますと、真向うに石の鳥居が見えるんです。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの竹垣を隔てて、角家がト○の中に（の）を大く（あり）と細筆で書いたのを通へ向けて、掛けてある荒物｜店。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父が脱院したことは勿論で「兎に角家へ戻つたのは幸ひだつたから明日の朝まで監禁を頼む。",
              "citation": {
                "source": "白明",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「病院は妾が断つて来るから、兎も角家へお出で――」そんな虚勢にだまされて堪るものかといふやうに頑として照子は意を翻さなかつた。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、靠れかかったルミを、全身に受けながら、私は、奇妙な触感に一寸ばかり訝かしく思いながらも、兎も角家へ帰って、椅子にかけさせ、「よく、来てくれましたね」　やっと、ほっとしながらいった。",
              "citation": {
                "source": "脳波操縦士",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小ブルヂヨア町なのに、その、くひちがひの一角だけが謙遜な平家建ばかりで、斜向ひの角家は、表側に引窓をもつやうな舊式な長屋だ。",
              "citation": {
                "source": "夏の夜",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "敷居一つまたぐと次の間は妹の家作で、入口の方の家が姉娘の家作、どっちの道、角家の磨きあげた二階家つづきで、お麻さんの芸妓名をついだ妹が主で、大勢の抱妓がいた。",
              "citation": {
                "source": "お墓のすげかえ",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "中井駅という下落合の駅の次でおりて、小学校のつき当りの坂をのぼったすぐの角家です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三四年（昭和九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "六角越前守と云ふ幕府の高家が、野州の幾個村を領して居て、翁もこの六角家領内の名主であつた。",
              "citation": {
                "source": "臨終の田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "この六角家の弊政を改革して、農民の痛苦を救ふと云ふ相談が領内有志の間に盛になり、当時若年の翁はその総代となつて奔走した。",
              "citation": {
                "source": "臨終の田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃ち十年前六角家事件にて貧困せる正義派の疲弊を回復せん為め、勧めて田畑を買入れしめんとす。",
              "citation": {
                "source": "臨終の田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "豪農諸角家のこの屋敷は、そこにいる三人の人間が、小さく見えるほどに広かったが、やはり浅間の爆発や、大旱魃の影響を受け、収入減少したために、手入れをすること出来ないからか、襖は破れ畳は古び、荒涼の体を見せていた。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは、今、折角家の中にゐるんだ。",
              "citation": {
                "source": "運を主義にまかす男",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何より腹が立つのは、その日の牛飲馬食が祟ってそれから二三日食慾が減退し、折角家人の手料理で自分の好きなものを作って貰い、自宅でゆっくり夕餉を楽しもうと思っていたことが、ふいにさせられるのである。",
              "citation": {
                "source": "客ぎらい",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次は兎も角家中の者の持物を調べることにしました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "權八の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "とも角家の中へ入れて、仏様らしくしよう」「ヘエ」　平次は縄の結び目から、死骸の身体まで調べながら八五郎と二人、血潮に汚れるのも構わず、椽側に運び入れました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも住みよさそうではあるが、店賃も高いだろうし、角家で自分たち親子には晴れがましかった。",
              "citation": {
                "source": "枡落し",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正造は前にも漸く二十台の頃、領主六角家の払奸事件に奔走して家産を傾けたばかりでなく、数百両の負債まで残した。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷人追慕已まず、其の碑を郷里に建つ彼の存在は同国の誇りとするところわしが国さで見せたいものは　　　　　昔しや谷風今達模様とは好角家ならぬ人々までもよく知る処である。",
              "citation": {
                "source": "初代谷風梶之助",
                "author": "三木貞一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかもダーハムやサレーの牛が、絵入りロンドン・ニュースに写真を掲げられ、有角家畜共進会において賞金を得たる牛と記入されながら、それを少しも知らないのと同じだった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はもう郷里へ帰りたい」「兎に角家へ帰りましょう」　と僕は自動車を頼んだ。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "春木座の横町で店には紙筆文房具を商っていた角家の二階、さっぱりした六畳の座敷が書斎、氏は全く水道の水で磨き上げた眉目清秀の美青年で、文士というよりはむしろ若旦那然とした風采。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "流浪の将軍家は、和田とか、六角家とかの、大名の家を、転々と身を寄せてあるいた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして人的には美濃の諸侍を誘降し、六角家の旧臣や京極家の一族、また、若狭の武田義統などを加えて、それぞれ適所に用い、ひたすら兵力の増強にあせっていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、鎌倉初期において、佐々木系は二つに分れ、一は江南の六角家、一は江北の京極家となっている。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその十字になった町かどや店の前に女たちが〔〕七八人ぐらゐづつ集って橋の方を見ながら何かひそひそ談してゐるのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその十字になった町かどや店の前に女たちが七八人ぐらいずつ集って橋の方を見ながら何かひそひそ談しているのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその十字になった町かどや店の前に女たちが七、八人ぐらいずつ集まって橋の方を見ながら何かひそひそ談しているのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
