[
  {
    "uuid": "431c192b-4220-5fa1-b367-16a9b8b1a872",
    "entry": "角家",
    "reading": {
      "primary": "かどや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
