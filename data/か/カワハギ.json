    "definitions": [
      {
        "index": 1,
        "gloss": "thread-sail filefish (Stephanolepis cirrhifer)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今日の夕食は、新鮮な皮剥ぎを刺身でいただくことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "皮剥ぎは肝が絶品で、日本酒との相性も抜群だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "釣り上げた皮剥ぎの独特な形に、子供たちが興味津々だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そのうちには皮剥ぎを手伝ってもらった親類の男もいた。",
              "citation": {
                "source": "蛇怨",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも、きツと、皮剥ぎか何かであらう。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "その天井には半ば皮剥ぎたる兎二つ弔り下げたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "かははぎは皮剥ぎの謂で、形の可笑しな魚だが、肉がしまつてゐておいしい。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "むやみに売りに行けば、それから足が付く虞れがあるので、平吉は浅草あたりの皮剥ぎ屋へ牽いて行って、捨て値に売ってしまいました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し義雄はそれには餘り立ち入らず、旅行中に見た槲の皮剥ぎ並びに澁取りの新事業や、アルコール製造場のことや、牧場や未墾地の遊んでゐるのが多いことや、火山灰の利用方法などを話すと、年若い春雄の心は踊つて、「早く獨立して、僕も何かやりたい」と云ふ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも、鼻なしで出歩くなんて、そうじゃありませんか、これが、あのウォスクレセンスキイ橋あたりで皮剥ぎ蜜柑を売っている女商人か何ぞなら、鼻なしで坐っていても構わないでしょうがね。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "数え終ると、皮剥ぎと云う魚を指差して、「これも、えっとやろか」と云った。",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士たちは、前代にもあまり例の少ない生きたものの皮剥ぎを、興味を以て見物しようというのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "また武士たちとても、同じ人間を斬捨てることを商売にしていた時代もあるのだから、たかが生きた犬の皮剥ぎを実地に御覧になるということも、そんなに良心には牴触しないで、かえって残忍性の快楽をそそるくらいのものでありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の世に在っては、鳥さしはおろか、犬殺しや猫の皮剥ぎよりも更に残忍なる徒輩が徘徊するのを見ても、誰一人之を目して不祥の兆となすものがあろう。",
              "citation": {
                "source": "巷の声",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らが社会生存上には必要欠くべからざるものとは云え、人の忌み嫌うところの牢番・斬罪・捕方・掃除、屍体の取片付け、死牛馬の皮剥ぎ、皮革の製造業等の賤職に従事して、それに甘んじておったのも、一つはこんな得分があったからである。",
              "citation": {
                "source": "特殊部落と細民部落・密集部落",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「全国民事慣例類集」に、遠江国敷知郡地方では、「三代皮剥ぎの業をなさざれば、平民となるの例あり。",
              "citation": {
                "source": "遠州地方の足洗",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬殺しもやれば、牛馬の皮剥ぎもやる。",
              "citation": {
                "source": "融和問題に関する歴史的考察",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば露骨にこれをいいますと、大名や武士と、エタや非人との相違は、乱世において先祖が切取強盗をやったか、あるいは犬殺し、皮剥ぎをやったかという相違から、ついには身分上大きな相違が起ったという場合も少くないと言えましょう。",
              "citation": {
                "source": "融和問題に関する歴史的考察",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "担架の後からは盆を捧げた、道服を着た医師めいた男が、盆の上に整然と並べられている、小刀、小槌、小鋸、生皮剥ぎの薄刃物、生き眼刳りの小菱鉾、生爪剥がしの偃月形の錐、幾本かの針といったような物を、大切そうに見守って、厳粛の顔をして従いて来た。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちとそれは……」　と、生皮剥ぎの薄刃物の刃を、掌にあてて験しながら、当惑したように医師は云った。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時生皮剥ぎの薄刃物が、浮藻の額へあてられた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は何時の世にも、大岡裁きを喜ぶものである、子争いに始まって、石地蔵をお白洲に引出す興味、三方一両損の論理、皮剥ぎ獄門のトリックは、何時になっても変らない興味である。",
              "citation": {
                "source": "銭形平次打明け話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）皮剥ぎの手入れが肝要である。",
              "citation": {
                "source": "庭をつくる人",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、狒々婆も白痴の孫を連れて行って見てもらうとその女が云うには、幾十代か前の祖先が馬の皮剥ぎを商売にしていたことがあって、その剥がれた馬の怨霊の仕業なのだから、十円出せば祈り伏せてやるとのことだったそうだけれども、婆にその金の出せよう筈はない。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "サトーリスがじっと観察しているさまは、冷血科学者が動物のなま皮剥ぎを見ているかのようだった。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに途々、斬り死にした将士のからだも同様に、その武器からよろい下着まで、すべてみな“皮剥ぎ”の好餌とならぬものはなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちぬご、かわはぎ、かながしら、色々な魚が宙に浮んで来る。",
              "citation": {
                "source": "田舎がえり",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さかなの肝で特に美味いのは、たい、はも、かわはぎ、ふぐ、あんこう、うなぎ、たら。",
              "citation": {
                "source": "知らずや肝の美味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚の肝の中でのピカ一の優品は、はものそれで、次が、たい、かわはぎというところであろう。",
              "citation": {
                "source": "知らずや肝の美味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわはぎの魚体は、さまで美味いとは言い難いが、しかし、その肝に至っては並々ならぬ特別の美味さを有っている。",
              "citation": {
                "source": "知らずや肝の美味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはかわはぎに似た形の魚で、味噌汁の実にするとなかなか美味いものである。",
              "citation": {
                "source": "雑魚図譜",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
