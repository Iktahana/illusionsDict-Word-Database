        "examples": {
          "standard": [
            {
              "text": "狩猟した動物の皮剥ぎ作業は、熟練の技術を要する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "皮剥ぎの効率を上げるため、新しい道具が導入された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "職人たちは、伝統的な方法で丹念に鹿の皮剥ぎを行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
