        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "箪笥の数え方が「一棹、二棹」であることを、国語の授業で初めて知りました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "フランス語の数字の数え方は、途中から計算式みたいになって頭が混乱する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "イカやタコなど、生きている状態と水揚げされた後で数え方が変わる魚介類も少なくない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "こういう昔ふうな年の数え方は今ではてんで相手にしない人が多い。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十進法というのは言わば単式の数え方であって十干だけを用いると同等である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して干支法は言わば複式の数え方で、十進法と十二進法との特殊な結合である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルンバの早いテンポに合わせて、数え方も早くなって行った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そうして一から十まで数える……支那の数え方で……ええ。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓の上に散らかった釦を百箇ずつ纏めればいいのであるが、のろのろと馴れない指さきで無器用なことを続けていると、来客と応対しながらじろじろ眺めていた順一はとうとう堪りかねたように、「そんな数え方があるか、遊びごとではないぞ」と声をかけた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、かぞえかたが、ちがうだけですもの」　こう言うとカゲロウは、また、空にはねあがって、ダンスをしました。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは、悲しくてたまんない」「おまえは、時のかぞえかたも知らないんだね」と、ポルトガル奥さんは言いました。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう知っているひとは多いだろうが、四つ・八つ・七つはむかしの時のかぞえかたであった。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
