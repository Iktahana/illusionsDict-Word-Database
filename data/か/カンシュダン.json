        "examples": {
          "standard": [
            {
              "text": "プロジェクトの成功には、慣手段に頼るだけでなく、新しいアプローチも必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "問題解決のために、彼はまず慣手段を試したが、うまくいかなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "企業は、慣手段では太刀打ちできない市場の変化に直面している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "警察は、慣手段を用いて容疑者の足取りを追った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "極めて俗なる事を詠むに雅語を用ゐて俗に陥らぬやうにする事｜天明諸家の慣手段なり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            }
          ]
        }
