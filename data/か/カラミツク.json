    "definitions": [
      {
        "index": 1,
        "gloss": "to twine around",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "蔦が古い教会の壁に絡みつき、歴史を感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夏の暑い日差しの中、朝顔がフェンスに絡みついて花を咲かせている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供が母親の足に絡みつき、離れたがらない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ジャングルでは、つる植物があらゆるものに絡みついて成長している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "『いやにじれつたいな、何うにも、恁うにも、恐かないなら、手を地べたに着いて謝罪んねえ、そこへ坐つて、チエツ、意氣地のない青二才だ』「カツ」と痰を吐いたのが、胸の處へベツタリ絡みつく。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして迷ひ込んだが最後逃れやうたつて離れられるもんぢやない、次第に悪因縁は青い蛇のやうに柔らかに絡みつく、どうせ死ぬまでは白い歯形が霊の底までも喰ひ入らねば放すもんぢやない。",
              "citation": {
                "source": "新橋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お今は体を浅井に絡みつくようにして低声で言った。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「腰の骨が砕けて行きそうなの」　お島は傍へ寄って来る小野田の手に、絡みつくようにして、赭く淀み曇んだ目を見据えていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼に何か絡みつくような、ねつい表情があり、ルスタムのやや粗暴になっている感情にうるさい思いをさせる。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらは僕の足に絡みつくようだった。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらは僕の足に絡みつくやうだつた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　快活な癖に妙に絡みつく正直さを持っている久慈を知っている作家の東野は、また始まったぞと思ったらしくにやりとして、「あなたも夕食ですか。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "結んだ帯がいつしか解けて、長く垂れた端が裾に絡みつく。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸び茂るもの、立ち枯れるもの、他物に絡みつくもの、みな自然にそうなっていた。",
              "citation": {
                "source": "山吹の花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "絡みつくやうなしつこさと、狙つてゐる肉慾の目があつた。",
              "citation": {
                "source": "外套と青空",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "野村はその無表情の白々とした女の顔を変に心に絡みつくやうに考へふけるやうになつた。",
              "citation": {
                "source": "戦争と一人の女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ此の人の饒舌には、ただごとでない神経の穂がチクチク揺れて話の前へ滑り出てゐた――聴き手の神経に絡みつくとき、それは堪へ難いものとなつた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "数杯の酒に男は忽ち赤黒くほてつた顔をして、江戸前のいなせな言葉に関西訛りのアクセントが時々絡みつくせつかちな口調で、心安く二人へ話しかけるのを聞いてみると、男は系図屋といふ不思議な商売を営んでゐた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "身心共に疲れ果てた伊豆にとつては是程神経に絡みつく負担はないのであつて、初めは一種の畏怖と親しみであつたものが、逆に嵩じて、茫漠と眼界に拡ごり満ちる痴川の生存そのものを忌み呪ふ気持が伊豆の憔悴した孤独を饒舌なものにした。",
              "citation": {
                "source": "小さな部屋",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「思いもかけない時に、思いもかけない古いことが飛び出してきて、それがしつこく絡みつくんだからね。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇のようによく物に絡みつく、長いしなやかな指、膝の神経痛と関係のある、一種病的な神経質な精緻な触感を持ってる指、そして円く反った細長い爪。",
              "citation": {
                "source": "小説中の女",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "地位が逆に、こちらが初めからお客のような、座敷の空気ばかりでなく、いやそんなものをすっかり蹴散らして、絡みつくようなしなやかな澄代の手の感触が、彼女の自意識を呼びさます。",
              "citation": {
                "source": "操守",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "必死の力でふりほどき、逃れようと焦つてみたが、絡みつく者は更に倍する怪力であつた。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の指は細くしなやかで、朝顔の蔓のようにすぐに物に絡みつくかと思われるほどであった。",
              "citation": {
                "source": "掠奪せられたる男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもときどき舌へ絡みつくものがあるので、「何ですこれは」　と和尚様に訊くと、「藁だよそれは」「エ、藁？",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノアの方舟　スラバヤを出帆してから四日、海洋性の滝のような豪雨がやみまもなく降りつづくのに、赤道特有の絡みつくようなひどい暑気で船艙はさながらの蒸風呂になり、蚕棚へ長く寝てカスカス呼吸をしているという辛い船旅になった。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　立ちなおろうとしたが、もがけばいっそう絡みつくばかり。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の顔色は青大将の熱度の変ずるたびに、それからその絡みつく強さの変ずるたびに、変った。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "伽羅のように絡みつくようなところもなく、白檀のように重くもない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそ他人のふりをしようと早足に歩いてみても、ポチは私の傍を離れず、私の顔を振り仰ぎ振り仰ぎ、あとになり、さきになり、からみつくようにしてついてくるのだから、どうしたって二人は他人のようには見えまい。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い霧の中に立つて振り返ると、白い尻尾でも動くやうに足元から怪しげな影が逃げてゆく、向き直つてそつと歩み出すと重い霧の層までが又ふうわりと後から白くからみつく。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "日常目にする凡てのことに、この疑いが、からみつく。",
              "citation": {
                "source": "セトナ皇子（仮題）",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは花火のようなものに真綿の網のようなものを丸めて打ち上げ、それが空中でぱっとからすうりの花のように開いてふわりと敵機を包みながらプロペラにしっかりとからみつくというようなくふうはできないかとも考えてみる。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツバメの上におおい広げて、野ネズミの部屋からみつくろった花をいくつかそばに添えました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to pester",
