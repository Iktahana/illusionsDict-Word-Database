[
  {
    "uuid": "db9aa56b-e37e-584b-95f9-a53465ce03d9",
    "entry": "辛味",
    "reading": {
      "primary": "からみ",
      "alternatives": [
        "しんみ"
      ],
      "is_heteronym": true
    },
    "grammar": {
