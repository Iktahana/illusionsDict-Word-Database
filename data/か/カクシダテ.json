        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "妹は、友達の誕生日プレゼントのことを私に隠し立てしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このプロジェクトの失敗は、彼らが何かを隠し立てしていたせいだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女はいつも何かを隠し立てしているような、ミステリアスな雰囲気がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "正直に話してほしい。隠し立てせずに、すべてを教えてくれ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "自分に対して何か隠し立てをしていることがあるらしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "……『――折角の葛飾の心遣いを空にするようですけれども、それだからと申しまして、わたくしにしてみればこれ以上隠し立てをするわけにはゆきません……』と美代子は咽び泣きながら役人に打ち明けた。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でくだらない隠し立てなんか致しましょう。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところが、事務のことばかりの手紙で」　芸妓はこの娘が隠し立てしたり、人を逸らかしたりする性分ではないのを信じているらしく、それを訊くと同時に、「やっぱり――」と云って興醒め顔に口を噤んだ。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上人さま、そりゃ本当でござりますか』蓮如『すでに存じておる以上隠し立てもなるまい。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こなた何か、わたしに隠し立てをしていなさるな』（珠数を取出す）源兵衛（おくみの手を払い涙を拭いて）『は、は、は、は、何の隠し立てをしてよいものか。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、皆さん、決して何も隠し立てはしません」　彼は言葉をつづけた。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "『だけど、僕は君に隠し立てしようとは思わない。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから何も君が隠し立てをする必要がない。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしも御用で来たのだから、隠し立てをされちゃあ困る。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまじい隠し立てをして、あとで飛んだ引き合いを食うようなことがあると、却って店の為にもならねえ」「はい、はい、ごもっともでございます」　相手が相手であるから長左衛門も正直に申し立てるよりほかはないと覚悟したらしく、半七に対して一々明確に答えたが、事件の道筋はお粂の報告とおなじことであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、今更となっていつまでも隠し立てをしているのは、よくねえことだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにぶんにも相手が相手であるので、なまじい隠し立てをしてはよくないと早くも観念したらしく、かれは正直に白状した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲のよい友だちであったから頭中将は隠し立てもせずにその話を源氏にするのである。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、たとい少しでも立ち聴きをされたものを、なまじいに隠し立てをするのは却ってよくないと思ったらしく、小声でこんなことを言い出しました。",
              "citation": {
                "source": "蜘蛛の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは万々知っている筈の外記がなぜ卑怯に隠し立てをするのか、それが憎いほどに怨めしかった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村の訪問したというのを聞いて、ひどくなつかしそうな様子で出迎えて、兄でも敬うようにもてなして、やや落ち付いてから隠し立てなく真率に葉子に対する自分の憧憬のほどを打ち明けたので、木村は自分のいおうとする告白を、他人の口からまざまざと聞くような切な情にほだされて、もらい泣きまでしてしまった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして飛び離れて風体の変わった葉子を見ると、なおさら勝手が違って、これがあの葉子なのかというように、驚きの色を隠し立てもせずに顔に現わしながら、じっとその姿を見た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠し立てをしようと決心した以上は、女は男よりもはるかに巧妙で大胆なのを葉子は自分で存分に知り抜いているのだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめえの念もとどいた以上、今さら未練らしく隠し立てをするにも及ぶめえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだこそ大きいが、近在から出て来た田舎者で、見るから正直そうな彼女がとかくに何か隠し立てをするのが、いよいよ相手の注意をひいた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お役目の方が御覧になりましたなら、何もかもお判りでござりましょうから、なまじいに隠し立てはいたしません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを知らずに隠し立てをしていると、おめえも飛んだ係り合いになるぞ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "妖狐伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう一度きくが、たしかになんにも知らねえか」「存じません」「よし、どこまでも隠し立てをするなら仕方がねえ、ここで調べられねえから一緒に来い」　彼はお元の手をつかんで引っ立てて行こうとすると、奥から五十ばかりの女があわてて出て来て半七の袖にすがった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれが斯うして身分を明かしても、おめえは飽くまでも隠し立てをするのか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "辞書は校長を庇ふやうに両肩を怒らして、禿頭を隠し立てをした。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや／＼隠し立てしたつて駄目です。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠し立てのない芳太郎の口から、お袋や親父の噂を聞き出すのも興味があったし、芳太郎の関係した女のことを知るのも面白かった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "期待したような何物をももっていない女の反面、どんな場合にも、そこにいくらかの虚飾と隠し立てとを取り去ることのできぬ女の性格、それに突き当る機会の多くなったのも厭であったが、やはり女をそっと眺めておけないような場合がたびたびあった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうのわたしたち女性はデスデモーナのその恐怖やかくしだてを、全くあわれな、おろかしいルネッサンス婦人の卑屈さとして感じる。",
              "citation": {
                "source": "デスデモーナのハンカチーフ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
