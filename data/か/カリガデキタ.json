        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ピンチの時に助けてくれてありがとう。これで君に一つ借りができたな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プレゼン資料の重大なミスをこっそり修正してくれた同僚に、大きな借りができたと感じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「これで貸し借りなしだ」と言いたかったが、結局また彼に借りができてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お返しなんて気にしないで」と言われたが、心理的にはどうしても借りができたようで落ち着かない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "方々に借りができたのを、自分で形をつけたつて、さう云つてやつたのよ。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "借りができたので、自己紹介と行きましょう」　船長が地上世界のことについて、明快かつ簡単に語る驚きの話に、アストラ人は大いに感心し、歓声を上げた。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はお前に一つ借りができた。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おっ母あ、ご飯を食べたのかい、今夜は」「食べたよ――お民さんのお家から、また一合、拝借してネ」「じゃ、もう何合も借りができたんだな。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でも、ね――片づいたものがまた出て來るのは、どうせいいことではないだらうし、若し義雄さんにでも引ツかかりができたら――」「まさか、そんなことが――」　二人は笑ひに破れてしまつたが、一方はつつましやかに取り澄ました聲であるに反し、一方はまた甲高な神經質に聽こえた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがクラブでは、作品を机の上にセットして電源を入れておけば、やがてすぐに人だかりができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間後、東京流通センターで開かれたマイクロコンピュータショーに出展されたＰＣ―８００１には、黒山の人だかりができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "書くことに、もう一度手がかりができた気がした。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
