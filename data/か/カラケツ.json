        "examples": {
          "standard": [
            {
              "text": "月末になると、いつも財布が空穴になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅行から帰ってきたら、貯金がすっかり空穴になってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいゲーム機が欲しいけれど、今は空穴で買えない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は転職活動中で、今は空穴の状態らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ただ人々の天分に厚薄があり、資質に強弱はあるけれども、既にその心を寄せ、念を繋ぐところを定めた以上は、その深に努めなければ井を掘って水を得るに至らず、いたずらに空穴を造るだけになる。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢきやむからけつとをかぶつて倒れておいで。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判好きの輩判官に賄賂を重ねて両造ともにからけつとなるを「猴に裁判を乞うた」というのだそうな（スキート著『巫来方術篇』一八七頁）。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
