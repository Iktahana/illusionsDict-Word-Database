    },
    "definitions": [
      {
        "index": 1,
        "gloss": "money order",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "遠方に住む祖母へ、誕生日のお祝いとしてかわせを送った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "銀行でかわせの発行手続きをお願いした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い手紙に、当時の為替に関する記述を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "急な出費がかさみ、実家にかわせで送金してもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "○オクツタ」ユイノウタノム」ケツコンシキノシタクセヨ」アスペキンタツ」オオスミチユウタロウ　同時に電報｜為替で百円送られて来たのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところへ、突然、れいの電報と電報為替である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が生れて初めて原稿料というものを貰って自分で自分に驚いたのは「団栗」という小品に対して高浜さんから送られた小為替であった。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "買ひおきし薬つきたる朝に来し友のなさけの為替のかなしさ　これだけ抜いたのは、面白いと思ふ歌がこれだけしか無いといふのではない。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は、カンボジヤ華僑、現在、為替経紀。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はサイゴンとプノンペンを往来する商権の保持と、為替ブローカーをやり、かたわらカンボジヤとシャムの国境に巨大なゴム園を経営していた。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき彼女の父は為替相場の変動のために、彼の商権に致命傷をうけた。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "欠損の主因はファーニッシング・デパートメント仕入の際、英為替二｜志三｜片であったのが送金のとき二志以下となる。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　待っていた為替が家から届いたので、それを金に替えかたがた本郷へ出ることにした。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ家から送ってくれた為替にどうしたことか不備なところがあって、それを送り返し、自分はなおさら不愉快になって、四日ほど待っていたのだった。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日に着いた為替はその二度目の為替であった。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――しかし待っていた為替はとうとう来た。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……大通り四ツ角の郵便局で、東京から組んで寄越した若干金の為替を請取って、三ツ巻に包んで、ト先ず懐中に及ぶ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、為替は直ぐ手取早くは受取れなかった。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、袷に羽織で身は軽し、駒下駄は新しし、為替は取ったし、ままよ、若干金か貸しても可い。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "為替や手形にデュープリケートの写しを添えるよりもいっそう手堅いやり方なのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっさに、うまい嘘も思いつかず、私は隣室の家の者には一言も、何も言わず、二重廻しを羽織って、それから机の引出しを掻きまわし、お金はあまり無かったので、けさ雑誌社から送られて来たばかりの小為替を三枚、その封筒のまま二重廻しのポケットにねじ込み、外に出た。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女は、信州にたった一人の肉親の弟があるとか言って、私の集めて来るお金はたいていその弟のところへ為替で送られるのでした。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を言うにもあの蔵元屋と言うのは博多切っての大金持の為替問屋。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "表向きは立派な為替問屋と質屋になっておりまするが、裏向きは筑前切っての大きな博奕宿で御座います。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "国の財政に赤字が多く、外国為替がとても高価いときに、外国品を好んで買うことなぞはいかがなものでしょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　留守へ言いつけた為替と見える。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "為替してきらめくものを掴ませて、のッつ反ッつの苦患を見せない、上花主のために、商売｜冥利、随一大切な処へ、偶然｜受取って行ったのであろうけれども。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎月｜為替にして郵送するのがすず子の為事の一つであつた。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そう言われて、銀子もその気になり、組んだ為替をそのまま留保し、次ぎの月もずるをきめていたのだったが、母の返辞が来てみると、金の催促もあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "部落といっても、見すぼらしい蒲鉾小舎が、四ツ五ツ固まっているきりであったが、それでも郵便や為替も来るし、越中富山の薬売りも立ち寄る。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、その母親として仕えていたのは、実は子供の時から可愛がられていた情婦に過ぎないのであったが、最近に至って有名な箱師のお玉という、これも変態的な素質を持った毒婦が、模範兵士の新聞記事を見て、大胆にも原籍本名を明記した封筒に、長々しい感激の手紙と、五拾円也の為替を入れて聯隊長宛に送って来た。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこれは実に苦笑ものであるが、私は井伏さんの作品から、その生活のあまりお楽でないように拝察せられたので、まことに少額の為替など封入した。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえって、よだかは、あの美しいかわせみや、鳥の中の宝石のような蜂すずめの兄さんでした。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜂すずめは花の蜜をたべ、かわせみはお魚を食べ、夜だかは羽虫をとってたべるのでした。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "exchange (e.g. foreign)",
        "register": "standard",
