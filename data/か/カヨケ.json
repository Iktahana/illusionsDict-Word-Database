        "examples": {
          "standard": [
            {
              "text": "夏のバーベキューには、蚊よけスプレーが必須アイテムだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ベランダに蚊よけのハーブを置いたら、刺されにくくなった気がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子どもが寝る部屋には、肌に優しい成分の蚊よけパッチを使っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "お日さまが、いつもより金粉をいくらかよけいに撒いていらっしゃるのよ。",
              "citation": {
                "source": "まなづるとダァリヤ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう冬と云う声をきくとすぐこう、ぞっとしてまるで風でも引いた様になりますの、貴方様なんかよけい冬がおきらいでいらっしゃいましょう。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子は、じぶんのことよりも、どんなにかよけいに、お姫さまのことを、おもっているか知れないといいました。",
              "citation": {
                "source": "眠る森のお姫さま",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            },
            {
              "text": "するうち、むすめは、だんだん怪獣のみにくい姿かたちに馴れてきて、それよりかよけい、そのやさしい、よい心を、このましくおもうようになりました。",
              "citation": {
                "source": "ラ・ベルとラ・ベート（美し姫と怪獣）",
                "author": "ヴィルヌーヴ夫人　Madame de Villeneuve",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなも、なにかよけいなものがあったら、くれてやるがいいだ。",
              "citation": {
                "source": "赤いガラスの宮殿",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまじっかよけいな手紙なんか出してるばっかりにかえってそれがカセになって、こんどはこっちが危くなる。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ミンチン先生はベッキイにこういわれて、なぜかよけいに腹を立てました、小使娘の分際で、セエラの肩を持つなんて怪しからん。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはもう外へ出ないから、みんながそう言うのを聞かないし、ここには鏡もないのだからわからない」「きみはほかの人よりかよけい青いとは思えないよ」とわたしは言った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく監視人たちが何かよけいなことをしゃべったかもしれないが、それならそれはただのおしゃべりだ。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルクシズムが、他の社会思想にくらべていくらかよけいに科学「的」であるとは思いますが、科学ではありません。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボーイの手前に対しても、なんだかよけい癪にさわってくる。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃の客にゃ、珍しい」「ふふん……」　と、駕屋は、掌の上の金の色と、女のうしろ姿を見くらべながら、「あんなのなら、ただで乗せてやってもいいと思ったのによ」「さ、戻ろうぜ、金が木の葉に化けるといけねえや」「こう山ン中で見直すと、何だかよけいに美しいな」「これ！",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
