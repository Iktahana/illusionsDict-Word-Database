    "definitions": [
      {
        "index": 1,
        "gloss": "to steer a ship",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "荒れ狂う嵐の中、ベテランの航海士が必死に舵を取る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "初めてヨットに乗った私は、教官の指示通りに慎重に舵を取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "船長が倒れた今、若手の僕がこの巨大な船の舵を取らなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "霧深い海域を進むため、レーダーを確認しながら細心の注意を払って舵を取る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "どこの出先からも万遍なくお座敷がかかって、お馴染のお客とも付かず離れずの呼吸でやらしたいから、後口々々と廻すように舵を取るんです。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫婦ふたりの手で七、八人の子どもをかかえ、僕が棹を取り妻が舵を取るという小さな舟で世渡りをするのだ。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "君たちの船は悪鬼におい迫られたようにおびえながら、懸命に東北へと舵を取る。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "選挙団体、労働団体、職業団体などが、権力を握り、輿論が、指導の舵を取る。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本政府及ぴ日本の父母は表面保守主義な様ですが、事実に於て世界の思潮を見越す事に鋭敏ですから、時には舵を取る為に馬鹿げた干渉もする様ですが、概して温健な推移ならば寛大に見て居る風がありますので、我我は二三十年｜前の日本婦人に比べて雲泥の差と云ふべき思想上の自由を得て居ります。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（＝line）同上の左右について舵を取る紐。",
              "citation": {
                "source": "熟語本位英和中辞典",
                "author": "Y",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろに出ている靴の爪先きにスパイクがついていて、それで舵を取るのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "白い謝肉祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "大海原で、海流に身を任せつつ、尾で舵を取る大鯨。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟には、舵を取る邪魔になるというので、燈火がない。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人はそれを気に留めず、舵を取る以外の何にも注意を払わなかった。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "正三君がまたうまくかじをとる。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to manage",
        "register": "standard",
