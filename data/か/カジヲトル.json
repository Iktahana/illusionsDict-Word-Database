        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は若くして抜擢され、この多国籍企業の舵を取ることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "混乱が続くプロジェクトチームで、彼がリーダーとして舵を取ることで秩序が戻った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "家族の家計を預かる身として、無駄遣いを排してしっかり舵を取る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "映画制作の現場で、監督がどのように舵を取るかが作品の質を左右する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
