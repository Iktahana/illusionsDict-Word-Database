        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "雪深い東北の村では、かつて女性たちが防寒のために大きな角巻を頭から羽織って歩く姿が見られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おばあちゃん、その角巻、すごく厚手で温かそうだね。昔からの手編みなのかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "モノクロ映画のワンシーンで、角巻をまとったヒロインが吹雪の駅舎で恋人の帰りを待つ姿が美しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "（あさ）（買って来た魚のはいっている籠やら、角巻――津軽地方に於ける外出用の毛布――やらを上手の台所のほうに運びながら）ああ、重かったとも何とも、石の地蔵様を背負って歩いてるみたいだったよ。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはヘッドライトの燈に照らされて角巻をした壮い女がいた。",
              "citation": {
                "source": "焦土に残る怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は鼠色の角巻を目深に、すつと敏捷に身をかはしたので、その顔は見えなかつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから椅子に腰をおろし、兎に角巻煙草に火を移すことにした。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、木根ウナラベからの手紙、ムヂリ外套に角巻の五十才ばかりの柄の値段を問合せて来た。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母様の角巻と、大きな夜被とを着てゐます。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親は、二つぐらいの子供を、かくまきで包み背負い、手には、買いものの風呂敷包みを持っていた。",
              "citation": {
                "source": "飢餓地帯を歩く",
                "author": "――東北農村惨状報告書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "北風は、ます／＼ふきつのつて、野原の一面をうづまくやうにあれくるひ、雪けむりをたかくまきあげたり、白かばの枝を笛のやうにうならせるかと思ふと、どつと大声で笑つたりしました。",
              "citation": {
                "source": "そり（童話）",
                "author": "オイゲン・チリコフ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
