        "examples": {
          "standard": [
            {
              "text": "週末に母と一緒に『風と共に去りぬ』のDVDを借りて、スカーレットの波乱万丈な人生に圧倒された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「明日は明日の風が吹く」というフレーズは、『風と共に去りぬ』のラストシーンで非常に印象的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "図書館の古典コーナーで、分厚い上下巻の『風と共に去りぬ』を手に取ってみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は『風と共に去りぬ』のヒロインのような、勝気で情熱的な瞳をしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "放送物語の新劇俳優は例によって分別臭い殊勝な声を、哀れっぽく出してどんな物語もすべて悲しいものにしてしまうし、名人といわれる徳川夢声も、仏の顔も二度三度で「風と共に去りぬ」が宮本武蔵と同じ調子に聴える。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「風と共に去りぬ」のスカーレット・オハラの強烈な性格と生活力にかかわらず、バトラーの抜け目なさにかかわらず、彼らのところで経験されたのは状況と境遇とにすぎなかった。",
              "citation": {
                "source": "心に疼く欲求がある",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一書房からバックをうけて、あの売行を保とうとして出されたミッチェル女史の『風と共に去りぬ』Gone with the Wind。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「風と共に去りぬ」いかがでしたか。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃は古本をみんなが大事にして、すこしましなのは出ないから、『風と共に去りぬ』のような、一時はいやな程溢れていた本が、今ではあんなにあちこちにたのんでさえ、やっと一冊手に入るという次第で心細いものです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説本も、モンテクリストとか、レ・ミゼラブルとか、風と共に去りぬ、というような翻訳本が主であった。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
