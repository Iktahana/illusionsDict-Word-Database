        "examples": {
          "standard": [
            {
              "text": "夜遅く帰宅したら、すでに玄関には鍵がかかっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この引き出しは、重要な書類が入っているので常に鍵がかかっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あっ、鍵がかかってる！どうしよう、スマホ家に忘れちゃった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "扉がぴちんとしまって、中から鍵がかかる。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを区別するのに最もはっきりしている点は、赤見沢博士の昏倒している傍にあった鞄には、ちゃんと鍵がかかるようになっていたのに対し、かのお化け鞄を手にしたことのある人々の話によると、そのお化け鞄には鍵がかからない、つまり錠前がついていない。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下の出入口の一ヶ所に鍵がかかるだけで、個々の病室には鍵がかかっていない。",
              "citation": {
                "source": "精神病覚え書",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで分ったのだが、あの小部屋の扉は、中からも鍵がかかる様になっていて、しかもその合鍵をもう一本、賊が持っていたのだ。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の入口なる半間のひらき戸へ、うち側から輪かぎがかかるやうにして、義雄は毎日、毎夜かの女の看護をした。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の寝室には、かぎがかかるようになっているのに、小林君は、そのかぎさえ、かけないでおきました。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "公衆電話のドアに、かぎがかかるわけはありません。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのドアはしめさえすれば、しぜんにかぎがかかるようになっていたのです。",
              "citation": {
                "source": "虎の牙",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
