    "definitions": [
      {
        "index": 1,
        "gloss": "ridge (in mountain-climbing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あそこの切り立ったカンテが核心部だ。気を引き締めて登るぞ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鋭い岩のカンテを回り込むと、目の前には雲海を貫く雄大な景色が広がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "指先しかかからないような厳しいカンテを攻略し、彼は見事に完登した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわっ、このカンテ、風が強すぎて体が持っていかれそうだ……」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "すべすべしてゐる床の上、金のカンテラ点いてゐる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はあまり遠くない蘆の中で、カンテラを燃して数珠子釣りをやっている。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "坑夫等はもちろん裸体で汗にぬれた膚にカンテラの光を無気味に反映していた。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンテラの光に、兵士たちが蠢めいていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳のあたり、腰から太股のあたりが、カンテラの魔のような仄かな光に揺れて闇の中に浮び上っている。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後には、井村が、薄暗いカンテラの光の中に鑿岩機をはずし、ハッパ袋をあけていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、うしろからは、導火線に点火し終った井村がカンテラをさげ、早足に、しかもゆったりとやって来た。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そのカンテラがチラ／＼見えた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、差し出したカンテラが、彼女にぶつかりそうになって、始めてそれに気がついた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンテラの火がハタ／＼ゆれた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンテラを突き出た岩に引っかけると、いきなり無言で、彼女をたくましい腕×××××。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　カンテラに薄く照し出された女の顔をま近に見ながら彼は考えた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白服の、課長の眼鏡が、カンテラにキラ／＼反射していた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、カンテラと、金の金具のついた縁なしの眼鏡を岩の断面にすりつけた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は、眼鏡とカンテラをなおすりつけて、鉱脈の走り具合をしらべた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンテラが、無愛想に渋り切った井村の顔に暗い陰影を投げた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」脚の悪い老人は、心配げにカンテラをさし上げて広々とした洞窟の天井を見上げた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　老人はなお、ざら／＼に掘り上げられた天井の隅々をさぐるように、カンテラを動かした。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンテラが、洞窟の土の上や、岩の割れ目に点々と散らばって薄暗く燃えていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンテラは闇の晩の漁火のようなものだった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンテラは一瞬に消えてまッ暗になった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……暫らくして、カンテラと、慌てた人声が背後に近づいて来た。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "井村は新しいカンテラでホッとよみがえった気がした。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンテラの光は、そこへ届かなかった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はカンテラを向けながら、ぞッとして立すくんだ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の顔は悲しげにひん曲り、眼だけが、カンテラにきら／＼光っていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の三時ごろまでも表の人通りが絶えず、カンテラの油煙が渦巻いていた。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈もアセチリンもない時代で、カンテラがせいぜいで石油ランプの照明しかなかったがガラスのナンキン玉をつらねた水色のすだれやあかい提燈などを掛けつらねた露店の店飾りはやはり涼しいものであった。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日よ明日よ坑の奥、坑夫はカンテラみつめてる。",
              "citation": {
                "source": "カンテラ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小栗判官、頼光の大江山鬼退治、阿波の鳴戸、三荘太夫の鋸引き、そういったようなものの陰惨にグロテスクな映画がおびえた空想の闇に浮き上がり、しゃがれ声をふりしぼるからくり師の歌がカンテラのすすとともに乱れ合っていたころの話である。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "take-off point (ski-jump)",
        "register": "standard",
