        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "秋の気候が穏やかだったせいか、庭のバラが返り咲きした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "稀な現象だが、桜の木が春の後に再び返り咲くこともあるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わぁ、こんな時期にまた花が咲くなんて、返り咲きかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
