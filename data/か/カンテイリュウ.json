        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歌舞伎の看板には、独特の力強い勘亭流の文字が躍っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "年末年始になると、書道教室で勘亭流の年賀状を書く人が増える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖父は若い頃、勘亭流の書体を熱心に学んでいたらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "壁が崩れ落ちたと思うところに、日章旗を交叉した間に勘亭流で「祝開店、佐渡屋さん」と書いたびらをつるして隠してあるような六畳の部屋だった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山への入口に、ロウソクではなく、電球を入れた大きな提灯がぶらさがっていて、黒ぐろと「地獄一丁目」と勘亭流で書いてある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんで勘亭流なのかは、よくわからない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "のぼりきったところに、また提灯があって、「地獄二丁目」と、これまた勘亭流で書いてあり、その下に順路を示す矢印がある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘亭流の細字で役割を記してあるのがかなり読みにくい上に、古来の習慣として“捨役”なるものが附け加えられている場合が往々ある。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "役割の文字も在来の勘亭流を廃して、すべて活字を用いた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし活字を用いるということは、鳥居風の画面に対してどうも不調和であるという説が多かったので、歌舞伎座の方でも譲歩して、次興行から文字だけはやはり在来の勘亭流を用いるようになった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "深い軒のおくに、下手な勘亭流の文字を書きだした酒屋などが表通りに目立った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の川の澄渡つた空に繁つた木立を聳かしてゐる今戸八幡の前まで来ると、蘿月は間もなく並んだ軒燈の間に常磐津文字豊と勘亭流で書いた妹の家の灯を認めた。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の川の澄渡った空に繁った木立を聳かしている今戸八幡の前まで来ると、蘿月は間もなく並んだ軒燈の間に常磐津文字豊と勘亭流で書いた妹の家の灯を認めた。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はもう昔がたりになったが、あの小さい劇場の有楽座が建ったはじめに、表に勘亭流の字で書かれた有楽座という小さい漆塗りの看板が掛っていたのに、私は奇異の眼をみはった事があった。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこを探しても和臭というものはなかったが、独りこの勘亭流の字だけに従来の芝居の名残をとどめていた。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は暫くその勘亭流の字を眺めていたが、やがて心の中でこう思った。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『講談　　古今亭今松　　　　　明晩夕刻より大広間にて』　道楽者の旦那は寄席の看板にあるようなビラ辰まがいの勘亭流に似た太い字で、スラスラとこう書き流した。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄黄色い灯影を先へ行く師匠の足許のほうへ送りながら、見るともなしに提灯を見ると、勘亭流擬いの太いびら字で「三遊亭」と嬉しく大きく記されてあった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
