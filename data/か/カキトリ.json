    "definitions": [
      {
        "index": 1,
        "gloss": "writing down from other written material",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "小学生の頃、国語の宿題で漢字の書き取りを毎日1ページやるのが本当に苦手だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お気に入りの詩集の一節をノートに書き取りしていると、心がしんと落ち着く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "英語の語彙を増やすために、単語帳の例文をひたすらノートに書き取りした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこでキッコはその鉛筆を出して先生の黒板に書いた問題をごそごその藁紙の運算帳に書き取りました。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は相場の書き取りを叔父に見せる時に、叔父が指で押える株の上り下りを眼顔で知らせた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "文面の書き取りをよろしく。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "自慢ではないが（これはある種お決まりのレトリックではなく、本当に根っから自慢にはならないのだけれど）、ワードプロセッサーはトタン屋根ぼろバラック程度だったオレの漢字書き取り能力を、完膚なきまでに、根こそぎ地上げ風に破壊してくれた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして電子化が奪ったのは、洗い場のカレーの皿にへばりついた黄色い染み程度のオレの漢字書き取り能力だけではなかったのである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月二十一日　　葉子」　つやはこんなぽつりぽつりと短い葉子の言葉を書き取りながら、時々｜怪訝な顔をして葉子を見た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語の書き取りなど一度しか読んでくれないんだから困るよ。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸い当方に於いても、三面の奇景は申すに及ばず、異なりたる風俗なんど、絵に書き取りて、わが君初め、御隠居様にも御目に掛けたいと存じたる折柄。",
              "citation": {
                "source": "壁の眼の怪",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、今度は自分も警部補の眞似をして、一々書き取りながら、十六日老父を送つて行つて來たその晩の時間から段々と問詰めて行つたが、はつきりしてゐるやうでどこにか引かゝりが出來て來る。",
              "citation": {
                "source": "不良兒",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "」彼は小さな手帳を出して、そのままそれを書き取りました。",
              "citation": {
                "source": "リルケ年譜",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは王陽明の弟子が師の詞を書き取りしものなるが、なか／＼おもしろき事｜有之候。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝えらるる口碑を聞き洩らさじと私は書き取りました。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばしば役人があんまり低い声で口授するものですから、書記は坐っていてはそれを全然聞き取ることができないので、そこでいつでも跳び上がっては相手が口授していることを聞き取ろうとし、つぎに急いで坐ってそれを書き取り、今度はまた跳び上がる、というふうにつづくんです。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は中隊長の申し立てを書き取り、すぐそれにつづいて判決を書き取りました。",
              "citation": {
                "source": "流刑地で",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして皆が、一生懸命に書き取りながらも、偶像となってる教師の顔つきや身振りを一々、物珍しげな眼でひそかにうかがってる間に、ジャックリーヌとシモーヌとは小声で尋ね合った。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間も、朝、書き取りの豫習を中途で止めようとした時、母がもう少しおやりなさいと勸めると、「うん」と、合點して、持つてゐる罫紙を指さし「じやあ、もう二タサク‥‥。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼等にその文句をゆっくりいって貰って書き取り、手のいろいろな形を写生した。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語の矢島先生は訳解をおわって、「照常様、一つ書き取りをいたしましょう。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、明日は書き取りはございません」　と照常様は不承知のようだった。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「語学は書き取りにかぎる。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き取りをすると文章の構造をおぼえるから上達する」　と殿様がおっしゃった。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢島先生は殿様がお見えになると必ず書き取りをやってごらんに入れる。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」「こんなものを教科書の中へ入れておいちゃいけないね」「はあ」「もっと本気になって毎日書き取りをやってごらん。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧相な国語書き取り帳があるだけだから。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度、レコードを聴きながら、歌詞の書き取りを教えてね」　そう言いながら、節子は階段を降りて来た。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ヘンゼルは手をぐっと高くのばして、屋根をすこしかきとり、どんな味がするか、食べてみました。",
              "citation": {
                "source": "ヘンゼルとグレーテル",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘンゼルは、屋根がとってもおいしかったので、大きいのをひとつそっくりかきとりました。",
              "citation": {
                "source": "ヘンゼルとグレーテル",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　明智はそういって、テーブルの上の白紙に、筆でつぎのような形に暗号文をかきとりました。",
              "citation": {
                "source": "大金塊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
