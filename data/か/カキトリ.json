        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「リスニング教材の音声、聞き取れたところだけでいいから今から書き取りしてみて。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "会議の議事録を作成するため、録音したデータを何度も止めながら書き取りを進める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "通訳を目指す彼女は、海外ニュース番組の書き取りを毎朝の日課にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
