[
  {
    "uuid": "ef2be781-668f-5ca0-9d81-a3460ba75ad9",
    "entry": "各方面",
    "reading": {
      "primary": "かくほうめん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
