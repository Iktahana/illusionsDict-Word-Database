        "examples": {
          "standard": [
            {
              "text": "スピーチでは話し言葉を使うが、論文では厳密な書き言葉を用いる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "日本の古典文学は、現代の日本人にとって書き言葉の壁がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は話し言葉と書き言葉を状況に応じて使い分けるのが上手だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この叫びは、だが、単なる書き言葉のみでは伝えられない性質を持っており、手紙の主はその音を聞いて母親が完全に失神したと言っている。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
