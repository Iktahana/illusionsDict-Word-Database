    },
    "definitions": [
      {
        "index": 1,
        "gloss": "freight car",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "霧の朝、長い貨車を連結した列車がゆっくりと駅を通過していった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "港では、巨大なクレーンが貨車から次々とコンテナを降ろしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "線路の脇に、錆びついた古い貨車が一つ、忘れられたように置かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "十月廿七日石家荘迄貨車で輸送されて、それから行軍三日、此の辺りの新しき土はほこりっぽくッて困る。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時は、赤い貨車の中でストーブを焚き、一緒に顫えながら夜を明かしたこともあった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポチカレオへ赤い貨車が動く。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貨車の屋根に梯子をかけて這い上った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青き朝日にふかぶかと、　　小馬うなだれ汗すれば、硫黄は歪み鳴りながら、　　か黒き貨車に移さるゝ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人氣のない構内では、貨車が靜かに眠つて居るし、屋根を越えて空の向うに、遠いパノラマの郷愁がひろがつて居る。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火夫の走り、車輪の※り、群鴉の喧號する巷の中で、はや一つの胡弓は荷造され、貨車に積まれ、さうして港の倉庫の方へ、税關の門をくぐつて行つた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりその滝の横に運河を掘ってその滝の上流を堰き止めて、滝壺の水を掻き干して、底の方に溜まっている四百億円の砂金をスコップで貨車へ積み込もうという曠古の大事業だ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "金は取れるかも知れねえけど、貨車の上さ立ったりして乗ってるらしいが、危ねえようだなあ。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　父親の伝平はそう言って、耕平が砂利貨車で稼ぐことは、悦ばなかった。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、耕平は、いつの間にか、父親に隠れるようにして、砂利貨車に働いているのだった。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、籠に水を汲み溜めようとするようなもので、穴だらけな生活の中へ消えて行ってしまうのであったが、父親も母親ももう、耕平が砂利貨車に働くことを止めようとはしなかった。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、そんな風にして一ヵ月ばかりも過ぎたころ、耕平は、進行中の貨車と貨車との間に墜落して、胴体を切断された。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはきのふだか、頬の赤い無邪気な女中が、さういふ風にモウタアを沢山買つて、それを船頭達に貸して、つまり東京での貨車のやうなことをして、それで生活してゐるものが沢山にゐるといふことを話してゐたからであつた。",
              "citation": {
                "source": "モウタアの輪",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄橋の上で転覆した貨車から放り出されたものである。",
              "citation": {
                "source": "原爆回想",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "家屋の彼方では、徹夜して戦場に送るべき弾薬弾丸の箱を汽車の貨車に積み込んでいる。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の下士が貨車の荷物の上に高く立って、しきりにその指揮をしていた。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　死を以て生を　五千の大砲、三万の機関銃、三千の投擲弾、二千の飛行機、五千の機関車、十五万の客貨車、五千の自動車を、連合軍に引渡し、潜水艦の全部、装甲巡洋艦六隻、海防艦十隻、小巡洋艦八隻、新式駆逐艦五十隻の破壊。",
              "citation": {
                "source": "世界の裏",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある寒村に汽車が停つたときま向ひに停つてゐた數臺の貨車の中で動かない數十疋の牛が鼻を縛がれたまま乘せられてゐた。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなくその貨車は動き出した。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い牛の群れが黒い貨車と一緒に夜の底を曳かれてゆく。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "耕作者の手から收納された葉煙草は、貨車で市の專賣局出張所に送られ、ここで再乾燥にかかる。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生の間に噛つた野菜を、一｜纏めに汽車に積み込むとしたら、貨車を三｜哩ばかし繋がねばならぬ事になる。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへだしぬけに貨車がごとごと入つて来た。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると貴方の前に貨車を引込むだのは、以ての外の失礼でした。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　駅長は前よりは一層丁寧にお辞儀をして、小走りに彼方へ往つたと思ふと、暫くすると、貨車はまたごとごとと音を立てて、後退りを始めた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何もやらかしゃしねえよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人の大きな手は、かしゃくなしに、乳鉢を掴みにきた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段の壁に額を掛けた印刷物の前に背の低い肩の怒った男が三人立って大きな声で読んでは何かしゃべっている。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "みなの衆、ようく心を留めて聞かしゃれ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
