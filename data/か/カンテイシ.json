        "examples": {
          "standard": [
            {
              "text": "宝石の鑑定士は、そのダイヤモンドの品質と価値を正確に査定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遺品整理の際、古美術品の鑑定士を呼んで価値を見てもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "不動産の売買には、信頼できる不動産鑑定士の意見が不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "君は花と同じく絵の鑑定士か」　レスブリッジは聞こえない振りをした。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日か二日以内に世界最高の鑑定士に石を渡せば、鑑定ミスはありません」　ハースコートが賛成したようだ。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
