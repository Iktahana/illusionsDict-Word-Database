        "examples": {
          "standard": [
            {
              "text": "パーティーの開始前に、色とりどりのカナッペが並べられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このカナッペ、サーモンとクリームチーズが乗っていて美味しい！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "カナッペは、一口サイズで手軽につまめるのが良いね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "カナッペの代わりに、ミニサンドイッチを用意しましょうか？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ポール翁は私と並んで同じカナッペ（長椅子）に座を占め、マルグリト夫人はわれわれに向つて腰をおろした。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、女の子に手伝わせてカナッペをつくり、その他、お酒や御馳走を注文した。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "確か納豆とジャムを半々にしてカナッペの上にのっけるやつ」「ふうん、でもそれってちょっとまずいんじゃない？",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
