[
  {
    "uuid": "27d4ec98-4852-53a9-bf27-0d3d350ab905",
    "entry": "駆られる",
    "reading": {
      "primary": "かられる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be driven by (a feeling, impulse, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "正義感に駆られて、彼は危険を顧みず犯人に立ち向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "創作意欲に駆られ、一晩中アイデアを練り続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "突然の寂しさに駆られて、昔の友人に電話をかけてみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "飢えに駆られて、冷蔵庫にあったものを片っ端から食べてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "だが一番困ったのは、意識の反対衝動に駆られることだった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそひと思いにと、狂暴な発作に駆られることも、しばしばあった。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいてお涌自身も、子供達と一しょにますます喚き立て度い不思議な衝動にいよいよ駆られるのであった。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが一番困つたのは、意識の反対衝動に駆られることだつた。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に蒐集狂という点から見れば、此｜煙管を飾る人も、盃を寄せる人も、瓢箪を溜める人も、皆同じ興味に駆られるので、同種類のもののうちで、素人に分らない様な微妙な差別を鋭敏に感じ分ける比較力の優秀を愛するに過ぎない。",
              "citation": {
                "source": "余と万年筆",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子という女性は、時によっては非常に執念深く私情に駆られるが、時によってはまるで別人のように公平で淡白な性質も持って居る。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでゐてお涌自身も、子供達と一しよにますます喚き立て度い不思議な衝動にいよ／＼駆られるのであつた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と延子が云ふと、もう純造は何だか解らなくなつて了つて不安な気だけに駆られる。",
              "citation": {
                "source": "坂道の孤独参昧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論運動家はヘツペル先生なのだが、今朝先生は、この四、五年来といふものは永年の修行のためか或ひは年齢の加減か、殆どもうさういふ発作に駆られるやうな場合には出遇はなくなつて、何時も敬虔な気分でヒルゼルやスパイスのお経を繙けるようになつた、「アーメン！",
              "citation": {
                "source": "サロメと体操",
                "author": "ヘツペル先生との挿話",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯五郎の眼つきと凡そ対照的な堪七の眼蓋の運動と、さう云ふ顰め面であるためか、未だ若かつた癖に皺の夥しく多い黄疸色の顔色に接して、その眼蓋の運動のやうに痙攣的な金切声を耳にしてゐると誰でもが、遺恨のあるなしに係はらずその頬つぺたをつねるか、或ひは擽り殺してやりたいやうな衝動に駆られるといふことだつた。",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、さう云ふ類ひの声色や絵画に触れると、それらが稚拙であるなしに関はらず、愚かな無稽事と知れば知るほど、馬鹿馬鹿しい恐怖に駆られるのは誠に損だと思ふので、怪談の類ひには凡て眼を反けるのを慣ひとしてゐた。",
              "citation": {
                "source": "真夏の朝のひとゝき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐怖に駆られるといふよりは、無下に嫌ひに過ぎぬのである。",
              "citation": {
                "source": "真夏の朝のひとゝき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば奴は自分ばかりが、そんなにのろのろと草を喰んだり水を呑んだりしてゐるので、私も謀らぬ酔のために喉の乾きに駆られるので、鞍から降りようとすると、直ぐにその気合ひを悟つて、突然ピーンと後脚で跳ねあがつて、メリゴウラウンドの木馬のやうな波型で飛び出したりするので、私は降りる機会さへも見出せなかつた。",
              "citation": {
                "source": "夜見の巻",
                "author": "「吾が昆虫採集記」の一節",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、この考えは今さらのことでなく、私の年季中から既に芽差していたことで、何かにつけ心掛けてはおりましたが、いよいよ社会の要求に駆られるようになって見ると、事実その写生的に行く方のやり方を実行して見たくなったのであります。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "実物写生ということのはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれを亡き妻に報告したいような気持に駆られる。",
              "citation": {
                "source": "吾亦紅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "――かくして鳥は自分ではどうすることも出来ない衝動に駆られるままに、森から森へと空の高路を縦横に、飛びつつ、叫びつつ、また叫びつつ、飛びつつ、夏中あわただしい旅の生活を送つてゐるのだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに有力な容疑者があげられた時は、一刻も早く、彼を白状せしめたいものだと、人知れず、焦燥の念に駆られるのでした。",
              "citation": {
                "source": "三つの痣",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "安重根は細目に正面下手の扉をあけて廊下の様子を窺ったのち、卓子へ帰り、焦慮に駆られる態にて行李を開けようとし、逡巡する。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、この一個の地理的概念に対して、私は猟犬のような莫然たる動物本能に駆られるのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ある心の琴線に触れると、怒りの激情の炎に駆られるよりは、かえって赦してしまう。",
              "citation": {
                "source": "死生に関するいくつかの断想",
                "author": "BITS OF LIFE AND DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "フーマン自身もそれを知り、何か状態が複雑になりかけると、自分の単純な激情に駆られる性質を恐れるように、冷静な、狡智に長けたバーマンを傍に持とうとする。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、僕は授業をやめてしまひたい衝動に駆られる。",
              "citation": {
                "source": "魔のひととき",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "理由を知らぬ村人は猟師の鉄砲の音と思っているが、私は知っている――あの団長はかような好天気の日には却って身を持ち扱って、無闇に煙草を喫す習慣である、そんな時には彼は非常に神経質な喫煙家になって、一発で点火しないと、わけもない亢奮に腕が震えて不思議な苛立ちに駆られるのであった。",
              "citation": {
                "source": "ゼーロン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、表通を曲って、柳の植わっている見とおしのいい小路へ出ると、忽ち彼等はひた走りに走りだしたいような衝動に駆られる。",
              "citation": {
                "source": "昔の店",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも善意の眼を輝かし、ものに駆られるように動きまわった。",
              "citation": {
                "source": "昔の店",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく僕は真昼の家のうちが薄暗くなると、脅えて藻掻くような気持に駆られるのだったが、時どき僕の父も何かに駆られてもがいているような不思議な顔をしていた。",
              "citation": {
                "source": "雲の裂け目",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし村次郎は、相も変らず黙々としているので、その物静けさには一種不気味な気持に駆られる場合さえあった。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、信者の催眠中、癩に似た感覚を暗示する事で、それがために、白羽の矢を立てられた信者は、身も世もあらぬ恐怖に駆られるが、そこが、教主くらの悪狡いつけ目だった。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、古びた家の寂っそりとした中で、そのような物音を聴いたとすれば、誰しも堪えがたい恐怖の念に駆られるのが当然であろう。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボードレール九歳の子供がありました女の子供でありました世界の空気が、彼女の有であるやうにまたそれは、凭つかかられるもののやうに彼女は頸をかしげるのでした私と話してゐる時に。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
