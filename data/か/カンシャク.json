[
  {
    "uuid": "19368662-0cf9-5778-9243-a0e8f8560cd9",
    "entry": "癇癪",
    "reading": {
      "primary": "かんしゃく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
