    "definitions": [
      {
        "index": 1,
        "gloss": "person from the Kansai region",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
