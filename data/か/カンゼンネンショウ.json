[
  {
    "uuid": "339cba56-96e5-51a5-977a-13a7ebc6c7a5",
    "entry": "完全燃焼",
    "reading": {
      "primary": "かんぜんねんしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
