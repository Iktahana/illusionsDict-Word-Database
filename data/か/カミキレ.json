    "definitions": [
      {
        "index": 1,
        "gloss": "piece of paper",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ポケットからくしゃくしゃになった紙切れが出てきたが、何かのレシートだった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「彼が去り際に手渡してくれた小さな紙切れには、電話番号だけが記されていた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「どんなに立派な契約書でも、破ってしまえばただの紙切れにすぎない。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼が拾った小箱の中からは、ボロに包んだ紙切れが出た。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　吉田は、紙切れに鉛筆で走り書きをして、母に渡した。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ひながら、一枚の紙切れを渡しました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラは、その紙切れが何だったか待ち兼ねたといふやうに急いでのぞきこみました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥お峯が引出したるは唯二｜枚、殘りは十八あるべき筈を、いかにしけん束のまゝ見えずとて底をかへして振へども甲斐なし、怪しきは落散し紙切れにいつ認めしか受取一｜通。",
              "citation": {
                "source": "大つごもり",
                "author": "一葉女史",
                "note": "青空文庫"
              }
            },
            {
              "text": "……………………………………………………　お峯が引出したるは唯二枚、残りは十八あるべき筈を、いかにしけん束のまま見えずとて底をかへして振へども甲斐なし、怪しきは落散し紙切れにいつ認めしか受取一通。",
              "citation": {
                "source": "大つごもり",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……………………………………………………　お峰が引出したるは唯二枚、殘りは十八あるべき筈を、いかにしけん束のまゝ見えずとて底をかへして振へども甲斐なし、怪しきは落散し紙切れにいつ認めしか受取一通。",
              "citation": {
                "source": "大つごもり",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云いながら、一枚の紙切れを渡しました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラは、その紙切れが何だったか待ち兼ねたというように急いでのぞきこみました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻の広場には塵や紙切れが渦巻いていました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人はしばらく棚をさがしてから、「これだけ拾って行けるかね」と言いながら、一枚の紙切れを渡しました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラは、その紙切れが何だったか待ちかねたというように急いでのぞきこみました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラは、その紙切れが何だつたか待ち兼ねたといふやうに急いでのぞきこみました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して子供が遊び捨てた紙切れを庭になげたり、脱ぎ散らした小さな靴を揃へて下駄箱に入れてやつたりした。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると所長は一枚の紙きれを持って扉をあける前から恐い顔つきをして、わたくしの方を見ていましたが、わたくしが前に行って恭しく礼をすると、またじっとわたくしの様子を見てからだまってその紙切れを渡しました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとテねずみは紙切れを出してするするするっと何か書いて捕り手のねずみに渡しました。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下へ置いた笠に何か書いた紙切れが喰っついている。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳の上におろしてやると、もうすぐそこにある紙切れなどにじゃれるのであった。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か紙切れのようなものを下に落としておいて、入り乱れた籐のいろいろのすきまから前足を出してその紙切れを捕えようとする。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれかがその畳まれてある紙切れを受け取った。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ホームズは紙切れを取り上げて、日の光に透かしてみせた。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一週間は描かれなかったのですが、ちょうど昨日の朝、また私は、庭の日時計の上に、この紙切れが置かれているのを見つけました。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから私はホームズさんに手紙を書いて、この紙切れをお送りした次第です。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二三日の間、手帳から例の記号の描かれた紙切れを取り出しては、じっと熱心に見つめるのであった。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ホームズは懐から、踊る人形の紙切れをすべて取り出し、前に並べてしばらく書斎の机に向かった。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ホームズはこう言って、机に椅子を引き寄せ、踊る人形のおふざけを記録した紙切れを、最初から最後まですべてその前に広げた。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が振り返ると、犯人が卓上に投げていった、くちゃくちゃの紙切れが目に入る。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに、ワトソン、その紙切れも、こんな事情であれば劇的なものになるだろう？",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "試行錯誤の末、ついにマイクロコンピューターのイメージをつかみきれぬまま卒業することになった加藤だが、石油ショック後の就職難の中で、第一志望の日本電気に職を得ることができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ学生時代の加藤明は、資料不足に泣かされて一年近くもマイクロコンピューターに取り組みながら、ついにそのイメージをつかみきれないまま卒業するという悲惨な目にあっているのである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
