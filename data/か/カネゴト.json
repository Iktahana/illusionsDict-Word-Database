[
  {
    "uuid": "5c8ecf5e-3b67-5bfe-bb57-c21ae01fa98b",
    "entry": "予言",
    "reading": {
      "primary": "かねごと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
