    },
    "definitions": [
      {
        "index": 1,
        "gloss": "they",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼らはチーム一丸となって、困難なプロジェクトを成功させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昨日の会議で、彼らは新しい提案について熱心に議論していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夕食後、彼らはリビングでテレビを見てくつろいでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "何しろ文学的素質がないのだ、そこでアラを探すにも彼らしくアラを探すことになる。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳壇のいわゆる俳人たちは、彼らの宗匠的主観に偏して、常に俳句を形態上のレトリックでのみ皮相な手法的技巧観で鑑賞するため、句が詩情している本質のポエジイと、その背後にある主観の貫ぬく哲学とを、ややもすれば閑却無視することになるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり彼らは、俳句が抒情詩であることの本義を忘れて、単にこれを形態上のレトリックでのみ、皮相に解釈しているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は芭蕉について、一茶について、こうした抒情詩の本体を知り、その叙景的な俳句を通して、芭蕉や一茶の悩みを感じ、彼らの訴えようとしている人生から、主観の意志する「詩」を掴んでいる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）こうした文学論が如何に浅薄皮相であり、特に詩に関して邪説であるかは、ここで論ずべき限りでないが、とにかくにも子規一派は、この文学的イデオロギーによって蕪村を批判し、かつそれによって鑑賞したため、自然蕪村の本質が、彼らのいわゆる写生主義の規範的俳人と目されたのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは自らインテリゲンチヤと稱しながら、召使に向つては「お前」と呼び捨てにするし、百姓などはまるで動物扱ひにして、ろくすつぽ勉強はせず、本氣に讀書といふ事もしない。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは私たちの「逆廻り」を、うさんくさそうな傍目を使って、あわれむが如き素振りでゆき過ぎた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までとはまるで反対の説を述べて平気でいられるところが彼の彼らしいところを表現していて妙である。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はどこの誰れとも知らない彼らみんなの幸福を心のしん底から祈らずにはいられない気持になった。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってこれらの感官に関する充分な分析的な研究を基礎としてその上に彼らの芸術を最も有効に建設すべきであろうと思う。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに偉人は自覚的成功なし、活動に起り活動に終るは偉人の常なるがごとく、古今東西の偉人多くはしかるを見る、豊公の如き奈翁の如き、彼らは活動を知って満足を知らざるに似たり、偉人の成功は活動にして偉人の満足又活動に存するか。",
              "citation": {
                "source": "絶対的人格",
                "author": "正岡先生論",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸ばたの流し場に手水をすました自分も、鶏に興がる子どもたちの声に引かされて、覚えず彼らの後ろに立った。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はいつものごとくに、おんぼという姉とおんもという妹とをいっしょに背負うて、しばらく彼らを笑わせた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご飯ができたからおんちゃんを呼んでおいでと彼らの母がいうらしかった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの語るところによれば、或る部落の住民は犬神に憑かれており、或る部落の住民は猫神に憑かれている。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その祭の様子は、彼ら以外の普通の人には全く見えない。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは特殊の魔力を有し、所因の解らぬ莫大の財産を隠している。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その疑いない証拠として、現に彼らのオクラ（魔神の正体）を見たという人があると。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "否でも応でも、彼らは自己の迷信的恐怖と実在性とを、私に強制しようとするのであった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからすべての哲学者は、彼らの窮理の最後に来て、いつも詩人の前に兜を脱いでる。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの不注意な失策も、彼らの崩壊と死滅を意味する。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さうして彼らはいま遠く離れてゐるのだ。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは盲ひたやうに手搜りで進みながら、たがひに相手を扉のやうに見出した。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、彼らは怖がつてゐたのではなかつた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らにさからはうとするものは何にもなかつた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼らは、二人でもつて或る新しい血にならうとして、其處にゐたのだから。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは、たがひに相手を澤山の新しい名でもつて呼びあひ、それからまた、耳環でもはづすやうに、そつとそれを引き込めるのだつた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "この界隈の連合委員会の事業振興の決議案にもかかわらず、閑散とした取引市場をとりまいて、日一日と失業者と、彼らの飢えが生産余剰と反比例して街の広場に堆積して行った。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、佐佐木茂索は或る時僕に彼らしい靜かな笑ひを洩らしながら語るのだつた。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、彼らが市街のいずれかへ消えて行って、今夜ひっかえしてくる時には、靴下や化粧品のかわりに、ルーブル紙幣を、衣服の下にかくしている。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
