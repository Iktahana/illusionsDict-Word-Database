        "index": 1,
        "gloss": "pouring hot water on oneself before entering the bathtub",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
