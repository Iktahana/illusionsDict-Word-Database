    "definitions": [
      {
        "index": 1,
        "gloss": "scientific socialism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "マルクスとエンゲルスは、空想的社会主義を批判し、歴史的唯物論に基づいた科学的社会主義を構築した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "19世紀後半のヨーロッパの労働運動は、科学的社会主義の理念に強く影響を受けて組織化された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼の講義では、資本主義の矛盾から必然的に社会主義へと移行するという科学的社会主義の教義が詳しく解説された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "日本に於ける科学的社会主義の思潮の生長以来である。",
              "citation": {
                "source": "日本文化の特殊性",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはユートピア的社会主義に対して自己を科学的社会主義として規定する。",
              "citation": {
                "source": "マルクス主義と唯物論",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォイエルバッハはヘーゲルからエンゲルスの橋渡しとして、ヘーゲルの弁証法を唯物弁証法に媒介した意味で科学的社会主義の先駆ともいえる。",
              "citation": {
                "source": "学生と教養",
                "author": "――教養と倫理学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、これしも空想的社会主義から科学的社会主義にいれるものとして価値を差別せんとするに対しては、我等は見界を異にせざるを得ないであろう。",
              "citation": {
                "source": "純情主義を想う",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂、空想的社会主義と、科学的社会主義との相違は、単に、その手段、方法の問題たるにとどまらず、其処に、性格の相違あり、また、全く人生に対する、前提の同じからざるによるものがある。",
              "citation": {
                "source": "純情主義を想う",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "風俗が多少とも大衆的にヨーロッパ＝ブルジョア化したのはヨーロッパ大戦以後であって、それは実に日本に於ける科学的社会主義の発生と同時だったと云ってもいいだろう。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "――因みに近世に於ける社会理論乃至社会科学の発展は、一方に於て倫理学乃至道徳理論と直接関係が少なくないと共に、本質に於てやはり一種道徳論的乃至倫理的である処のユートピア（非科学的社会主義・前科学的社会科学）との関係を離れては考えられない。",
              "citation": {
                "source": "道徳の観念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に、一般の社会思想（ユートピア共産主義・無政府主義・所謂国家社会主義乃至ファシズム・科学的社会主義等）が、各種の社会科学と歴史的に又理論的に如何に密接な連関を持つかに就いて、説明を必要とはしないだろう。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "一等有望でないのは体系的自由主義で、科学的社会主義にとっては問題が同じ社会主義という身近かにあるので、却って直接に撞着するものを持っているのだ。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファシズムの国際的共通性は、初め資本主義打倒のスローガンをかかげて科学的社会主義に対する反対勢力を結成し、やがて次第にこのスローガンをぼやかし、遂に全く反対な効果を有つスローガンにすりかえることだ。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの関係づけにこそ、今日の日本の科学的社会主義の、何より実践的な課題があるのだ。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学のこの意味に於ける科学性は全く、ソヴェートに於ける科学的社会主義の建設の一環として、哲学が政治的実践的な標尺に沿うて動いていることの結果に外ならない。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこのことは、歴史社会の問題を、科学的社会主義の立場に立って取り上げるということに外ならない。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学的社会主義・共産主義・唯物史観・又歪曲されては経済史観・等々。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルクス主義的社会科学は、サン・シモン C. H. de Saint-Simon・フリエ F. M. C. Fourier・オーエン等のユトーピア社会主義から発達して、科学的社会主義として成長した。",
              "citation": {
                "source": "辞典",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故社会科学は、無産者による社会革命、プロレタリアの独裁的支配という綱領にまで具体化される科学的社会主義・科学的コンミュニズムとなり、又この観念がプロレタリアのイデオロギーとなる。",
              "citation": {
                "source": "辞典",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "デモクラシー・ファシズム・共産主義・無政府主義・科学的社会主義の主張乃至研究は、社会哲学の最も重大な且つ略※共通な内容をなす。",
              "citation": {
                "source": "辞典",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョルジュ・ソレルはサンディカリスト革命のために論じたのであったが、革命のあとに階級のない社会主義の社会が実現されるなどという、いわゆる「科学的社会主義」の公式は断じて信じていない。",
              "citation": {
                "source": "政治学入門",
                "author": "矢部貞治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
