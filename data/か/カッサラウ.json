        "examples": {
          "standard": [
            {
              "text": "すれ違いざまに、ひったくり犯が彼女のバッグをかっ攫って逃走した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一瞬の隙を見て、彼は相手のボールをかっ攫い、ゴールへと突き進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "人気アイドルのチケットは、発売と同時にファンによってかっ攫われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "自分の気に入ったものをちょいちょいとかっさらう。",
              "citation": {
                "source": "川端柳",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この若僧をすてっぺんからおどかして存分に黄金をかっさらうはずだ。",
