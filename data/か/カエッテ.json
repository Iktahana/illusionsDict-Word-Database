[
  {
    "uuid": "04036f05-3a48-5dd8-a1c8-2b04d20421ef",
    "entry": "却って",
    "reading": {
      "primary": "かえって",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
