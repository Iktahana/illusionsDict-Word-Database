        "examples": {
          "standard": [
            {
              "text": "職人たちは、厳冬期に寒晒しで蕎麦粉の灰汁を抜く、伝統的な製法を守り続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "寒晒しにした大根は甘みが増し、昔ながらのたくあん漬けには最適だと言われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬の滝行で寒晒しを行う修行僧たちの姿は、見る者の心に深く刻まれるものがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "むかしは武士のカラ脛、奴の尻の寒晒し。",
              "citation": {
                "source": "洋服論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
