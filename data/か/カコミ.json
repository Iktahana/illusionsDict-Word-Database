        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "数か月に及ぶ城の囲みにより、城内の食糧は底をつき、ついに降伏の時を迎えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「敵の囲みを突破して、本陣に援軍を要請しに行ける者はいないか！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "圧倒的な兵力による囲みに対し、守備側は籠城戦で対抗する構えを見せている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
