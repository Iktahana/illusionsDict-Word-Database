        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "牧草地の周囲には、羊が逃げ出さないように頑丈な木の囲みが作られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "庭の一角に小さな囲みを設けて、家庭菜園でトマトを育て始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "図面上の重要な数値には、見落としがないように赤いペンで囲みを入れておいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "蔦かずらの這う古く懐かしい家の中で、薪の燃えるストーヴの火を囲みながら、老幼男女の一家族が、祖先の画像を映す洋燈の下で、むつまじく語り合うことを言うのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "から鮭も空也の痩も寒の内　雲水に似た旅人芭蕉も、時には一定の住所に庵を構えて、冬の囲炉裏を囲みながら、侘しく暮していたこともある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠を囲みたるは皆軍夫なり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし弱い弾性しか持たぬおしべは虻の努力に押しのけられて、虻の尻がその囲みを破って、少し外方に進出するとそこにちゃんとめしべの柱頭が待ち構えていたかのように控えているのである。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　子供らは棒を棄て手をつなぎ合って大きな環になり須利耶さま親子を囲みました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小さなこどもらはよろこんで、顔を赤くして押しあったりしながらぞろっと淵を囲みました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は端なく東京の父母や弟や親しき友を想ひ起して、今更の如く、今日まで我を囲みし人情の如何に温かであつたかを感じたのである。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十余りの人々長方形の卓を囲みて居並びしがみな眼を二郎の方にのみ注げば、わが入り来たれるに心づきしは少なかりき。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "底は一面の白砂に水紋落ちて綾をなし、両岸は緑野低く春草煙り、森林遠くこれを囲みたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さすがは畜生の悲しさ、もろいもんだ」とみんなは悦び勇んで狐の死骸を囲みました。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤ寝るにも毛布も蒲団も無いので、一同は焚火を取囲み、付元気に詩吟するもあり、ズボンボ歌を唄うもあり。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護婦ちょっとお押え申せ」　いと厳かなる命のもとに五名の看護婦はバラバラと夫人を囲みて、その手と足とを押えんとせり。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一個洋服の扮装にて煙突帽を戴きたる蓄髯の漢前衛して、中に三人の婦人を囲みて、後よりもまた同一様なる漢来れり。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを待受けて囲み撃つという計略であった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　十　均平がヴェランダで籐椅子にかけ、新聞を見ていると、女たちは部屋のなかで円卓子を囲み、取り寄せた林檎を剥いて食べながら、このごろの頭髪の流行などについてひそひそ話していた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」十　均平がヴェランダで籐椅子にかけ、新聞を見ていると、女たちは部屋のなかで円卓子を囲み、取り寄せた林檎を剥いて食べながら、このごろの頭髪の流行などについてひそひそ話していた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち復一の内部から融かすものがあって、おやと思ったときはいつか復一は自分から皮膚感覚の囲みを解いていて、真佐子の雰囲気の圏内へ漂い寄るのを楽しむようになっていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きさは両手の拇指と人差指で大幅に一囲みして形容する白｜牡丹ほどもあろうか。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "都指揮使｜謝貴は七衛の兵、并びに屯田の軍士を率いて王城を囲み、木柵を以て端礼門等の路を断ちぬ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "景隆は」は底本では「」は底本では「」は底本では「、遼東の鎮守呉高、都指揮使楊文と与に兵を率いて永平を囲み、東より北平を動かさんとしたりという。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "景隆は燕王の大寧を攻めたるを聞き、師を帥いて北進し、遂に北平を囲みたり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに細川、山名、一色等は公方管領を送り出して置いて、長陣に退屈させて、桂の遊女を陣中に召さするほどに致し置き、おのれ等ゆるゆると大勢を組揃え、急に起って四方より取囲み、其謀計｜合期したれば、管領は御自害ある。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍で囲み、旗を立て、淡く清く装った得意の人を馬に乗せて市を練って、やがて刑場に送って殺した処で、――殺されるものは平凡に疾病で死するより愉快でしょう。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧都　唯今、仰せ聞けられ承りまする内に、条理は弁えず、僧都にも分らぬことのみではござりますが、ただ、黒潮の抜身で囲みました段は、別に忌わしい事ではござりませんように、老人にも、その合点参りましてござります。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠を囲みたるは皆｜軍夫なり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫟林は、丘の上では果樹園や花畑の背後を囲みながら学校教職員の舎宅のある段と、学園の建物のある段と、その下の多那川べりの灌漑地帯の田畑の平地と、三段になっている地層を抱きかゝえるように多那川の岸にまで立ち続いております。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無常彼に迫りて、無常の実を示し、離苦彼を囲みて、離苦の実を表はし、恋愛その偽装を脱して、恋愛の実を顕はし、痴情その実躰を現じ、大悪その真状を露はし、彼をして棘然として顛倒せしめ、然る後に彼をして始めて己れの存立の実なると天地万有の実なるとを覚知せしめたり。",
              "citation": {
                "source": "心機妙変を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまもなく王ご自身が軍務をおひきつれになって、大前、小前の家をお攻め囲みになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで穴穂王は囲みを解いて、ひきあげて待っておいでになりますと、二人の宿禰は、ちゃんと軽皇子をおひきたて申してまいりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　大長谷皇子はそれから軍勢をひきつれて、目弱王をかくまっている都夫良意富美の邸をおとり囲みになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
