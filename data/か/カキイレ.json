[
  {
    "uuid": "f0aafda5-8c1d-5bc9-b9bd-cb79adb13a3c",
    "entry": "書き入れ",
    "reading": {
      "primary": "かきいれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
