    "definitions": [
      {
        "index": 1,
        "gloss": "entry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今月の収入の書き入れが、例年より多かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "日記帳の今日の書き入れは、ちょっとした発見についてだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この取引は、会計帳簿に新しい書き入れが必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "請求書に、その支払い額を書き入れしてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "當時僕がどんなに深く感動したかは、その時讀んだ本の各頁に、鉛筆で無數の書き入れや朱線がしてあるので、今もその古い本を見る毎に、新しい追憶の感銘が興るほどだ。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四時頃」の三字はあとから行の右側へ書き入れになっている。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "活動から歸つて來ると、「義侠のらつふるず」といふ風にノートへ役割からシナリオから何から何まで書き入れる、――そんな熱心さだつた。",
              "citation": {
                "source": "青空同人印象記（大正十五年六月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に残してあった屋敷と、附近の畑まで、清三の病気のために書き入れなければならなくなった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに毎月の書き入れにしている月浚いさえも休んでいるというのが、何よりの証拠だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから、いつもは、題などはつけないで書きたいことをおしまいまで書いてしまって、なんべんも読み返して手を入れた上で、いよいよ最後に題をきめて冒頭に書き入れることにしているのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから十年の後高等学校在学中に熊本の通町の古本屋で仏語読本に鉛筆ですきまなしにかなの書き入れをしたのを見つけて来て独習をはじめた。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次に行った時に返してもらった句稿には、短評や類句を書き入れたり、添削したりして、その中の二三の句の頭に○や○○が付いていた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に、私は静かに眼を開き安静な気持ちで受験番号や名前も書き入れ、問題の解答を書き進めて行きました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「愛するマルセルへ」書き入れる時彼は墓中の息子を確実にわが息子にした。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋の硯を仮寝の床に、路の記の端に書き入れて、一寸御見に入れたりしを、正綴にした今度の新版、さあさあかわりました双六と、だませば小児衆も合点せず。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三、四、六、七、の日が灸の日で、その日は無量寺の書き入れ日だっせとのことだった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその顔の額へもつていつて彼は「千鳥」と太文字で書き入れた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから右の頬づらへ師匠の宗佐の名を鑑定の印の形に似せて朱で書き入れた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、日記帳は買い求めても、漫画をかいたり、友人の住所などを書き入れるくらいのもので、日々の出来事を記すことはできない。",
              "citation": {
                "source": "作家の像",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その裏に太田正雄さん、文壇での通名木下杢太郎さんがこの本の装釘をして下すったと云うことわりがきがドイツ文で書き入れてあるが、あれも文芸委員会の文句を入れるに極まってから、その紙の裏が白くなるので、それを避けるために、思い立って入れた。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家来も見習いの子弟もみな同様の饗応を受けるのであるから、中間どものなかには最初からそれを書き入れにしているのもあった。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして伯父と自分との類似や相違を其処に書き入れようとしたのである。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は上級学校へ行く希望はない旨、書き入れて置いた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりこの抜き書きのみにとどまらず、自分は教師がよく黒板へ図解して示す絵図なども、そのまま直接教科書に書き入れておいた。",
              "citation": {
                "source": "わが中学時代の勉強法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつものことだ、性格は高慢ちきで自分本位、脳内へ新情報を書き入れるのは迅速にして正確だが、仕入れ先にはたいていお礼の言葉もない。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "川村の事は只今グラスゴウ市の版元から頼まれて編み居るロンドン大学前総長フレデリク・ヴィクトル・ジキンス推奨の『南方熊楠自伝』にも書き入れ居るから外国までの恥｜曝しじゃ。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの変更は注13で書いたように、暗号文の記号と共に、おそらく、ポーがのちの刊行本のための用意にときどき筆を加えておいたいわゆるロリマー・グレアム本の、自筆の書き入れに拠ったものらしく、まだ決定的な、あるいは完全な、訂正ではないので、この訳本ではすべてもとの「四十一度」にしておいた。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来なら赤ペン片手にある種の決意をもって「えいやっ」と直しを書き入れていたものが、キーボードの操作で跡を残さず変えられるとなって、変更に対する精神的な縛りが一挙に弱まった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "テキスト・データに簡単な指定記号を書き入れ、このツールキットに読みこむと、ほぼ瞬時に、タテ組み（ヨコ組みでもいい）、適切な余白つき、ページに分割され、目次や索引をそなえた、いまある活字本にきわめてちかいかたちに変形させることができる。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを要するにアントニウス伝を読んで廓然大悟し、人の人たる道を踏み切ったは、鎌田文相の独断で教科書に書き入れしめて然るべしだ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "官吏はうなずきながら手帳に何か書き入れた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、肩を並べながら、此処が面白くない、この句を斯うしたらいいだろうと、一々ペンでノートに書き入れて行ったのであったが、部屋の中で向き合って見る時よりも遥かに身が入って、私自身にも面白かった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、星の名をかきいれた大空の図をお前にあげよう。",
              "citation": {
                "source": "シロ・クロ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人形を裸にしたときに区別がつかないので、一つの人形の左の乳の上に梅の模様をかきいれました。",
              "citation": {
                "source": "抱茗荷の説",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
