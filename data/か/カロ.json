  {
    "uuid": "2737b0cb-6af9-5f13-aa9b-994d03d551bb",
    "entry": "蝸廬",
    "reading": {
      "primary": "かろ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "little house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「都会の喧騒を離れて、静かな山里の小さな蝸廬で隠遁生活を送るのが憧れだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「彼の書斎は、本に囲まれた、まるで自分だけの蝸廬のようだった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この簡素な家も、私にとってはかけがえのない蝸廬だよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「蝸廬といふ語があるね、僕も書物のなかではよくこの語に接してはゐるが、今日は眼の前にその蝸廬といふものを見て来たよ。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "獨弄詩蝸廬底　　独り詩を弄す蝸廬の底、戰雲滿乾坤時　　戦雲　乾坤に満つるの時。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月六日夏日閑居砲火動坤軸　　砲火坤軸を動かす、蝸廬何所營　　蝸廬何の営む所ぞ。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のやうに一生を蝸廬に過して足一歩も出でぬ者にしては、眼前數尺の自然は殆んど全天地である。",
              "citation": {
                "source": "五葉の松",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "羨やましかろう』という自誇の情が、そうした手紙の言外によく現われてる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校のおつとめからお帰りになって、隣りのお部屋で、私たちの話を立聞きして、ふびんに思い、厳酷の父としては一世一代の狂言したのではなかろうか、と思うことも、ございますが、まさか、そんなこともないでしょうね。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手はフランスがよかろう。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高浜さんには礼を失した点も多かろうと思うが昔に免じて御宥恕を願いたい。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も急く旅でもなしいっそ人力で五十三次も面白かろうと、トウトウそれと極ってからかれこれ一月の果を車の上、両親の膝の上にかわるがわる載せられて面白いやら可笑しいやらの旅をした事がある。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "みな寝しずまったころ、三十歳くらいのヘロインは、ランタアンさげて腐りかけた廊下の板をぱたぱた歩きまわるのであるが、私は、いまに、また、どこか思わざる重い扉が、ばたあん、と一つ、とてつもない大きい音をたてて閉じるのではなかろうかと、ひやひやしながら、読んでいった。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその※のうつくしさふと物音におどろきて午睡の夢をさまされし牡牛のごとも、あどけなくかろやかにまたしとやかにもたげられ、さてうち俯しぬ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞説らく多摩川に沿うた溝には、独歩の「忘れ得ぬ人々」の作にちなんで、独歩の碑が立っているとか、さらば近代における多摩川風景の祖道者として、花袋の碑は、そこに建てらるべきではなかろうか。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しながら「亡び行く生物」の中に、この菜の花が、次第に加わるのではなかろうか、それとも都落ちの仲間に入って、次第に我等の付近から、影を隠してしまうのではあるまいか、場末の旅籠屋などで、食膳の漬け菜の中から、菜の花の蕾が交って出ることがあるが、偶然だけに、どんなにか私を悦ばすことだろう。",
              "citation": {
                "source": "菜の花",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に北斎の『富嶽百景』三巻、『富嶽三十六景』四十六枚が、いかに江戸と、その市民の生活と、富士山とを結びつけているか、いかに世界的版画の名作として、日本をフジヤマの国として、高名ならしめたかは今更説くまでもなかろう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は登山すべく、あまりに老いたとは思っていないが、まだ登るべき多くの山を控えているから、恐らく生涯に二度とここまで来なかろうと思う。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その私たちの登山にしてからが、時間不足のために、絶頂の剣ヶ峰ともいうべき、シャスタ・ピークまでは、達しなかったのだから、一個の予察地形図をスケッチしたぐらいの、軽い気分で読んでいただきたい、何も登山記だからと言って、死に身になってコチコチと緊張しなければならない、というものでもなかろう。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は讃岐の産れで、国には崇徳上皇の御陵のある白峰という阜陵がある、上田秋成の『雨月物語』や、露伴氏の作として、かなり評判のあった『二日物語』は、この白峰に取材がしてあるが、まさか、あの白峰じゃあなかろうと、真面目になって考えこんだものである。",
              "citation": {
                "source": "日本山岳景の特色",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "知ってなきゃそんな無茶苦茶な事が云える筈がなかろうじゃないか。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（腹の具合が良かろう筈がねえじゃないか、医者にもかけねえ、薬も飲まさせねえ、軟かい滋養分も食べさせない、その代りに子供の守をさせてる！",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "街を歩いている時に通り合せた荷車の圧搾ガス容器が破裂してそのために負傷するといったような災厄が四十二歳前後に特別に多かろうと思われる理由は容易には考えられない。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "透して外の物がよく見えるためならもう少し黒い色がよかろう。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海上の日の出がどんなに美しかろうが、海鳥が飛ぼうが、鯨がはねようがそんな事はどうでもよい、一刻も早く目的地に上陸して動かぬ地盤が踏みたいと願う。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相撲は人間の体力の活技で、一方から見れば霊妙な複雑な器械の戦いである、いずれにしても運用する力はいわゆる器械力で、力の作用する目的物は質量を有する物体だから、やはり相撲も力学の広い縄張の中へ入れても好かろうと思う。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず今日の処では炭の棒を使った弧灯の光が一番日の光に近いものだと云うから、呉服屋などではこれを使ったらよかろうと思うのである。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "春は陰影で煮〆たようなキャフェ・マキシムでもなかろう。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "堅苦しいフウケでもなかろう。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思ってかさにかかって翁の娘の神に詰め寄りなじりかかろうとする刹那に神楽の音が起り祭が始ってしまった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもあの娘はその遠く距るものを現実に享け生かそうとするものではなかろうか。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にははるばる西北の山奥でとれたのをまた貰いに貰って来たといって、牟射佐妣という鳥だか、獣だか判らないものをお珍らしかろうと贈りに来た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、神を享けぬ人は低かろう、ただし獣の力を帯ばない人は弱かろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
