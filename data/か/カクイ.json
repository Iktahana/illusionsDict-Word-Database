[
  {
    "uuid": "dacaba15-1de2-5dd2-ae64-feecddb3362e",
    "entry": "各位",
    "reading": {
      "primary": "かくい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
