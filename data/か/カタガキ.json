  {
    "uuid": "a025c0da-26da-5141-a30a-010cb7bfd04c",
    "entry": "方書",
    "reading": {
      "primary": "かたがき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "additional information used to identify an address (e.g. building name, room number)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この手紙、宛名に建物の名前と部屋番号、つまり方書も書いておかないと届かないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "海外への荷物発送なので、住所の他に方書も正確に記入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「〇〇マンション 302号室」というのが方書にあたる部分だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "引越し先の方書を、友達にメールで送るのを忘れないようにしないと。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "素『医心方』は巣元方の『病源候論』を経とし、隋唐の方書百余家を緯として作ったもので、その引用する所にして、支那において佚亡したものが少くない。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "故所著方書以千金名。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宗は自らこれに叙して、「朕尊居億兆之上、常以百姓為心、念五気之或乖、恐一物之失所、不尽生理、朕甚憫焉、所以親閲方書、俾令撰集、溥天之下、各保遐年、同我生民、躋於寿域、今編勒成一百巻、命曰太平聖恵方、仍令彫刻印版、※施華弟、凡爾生霊、宜知朕意」と云つてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩波書店の本は、地方書店には出なかった。",
              "citation": {
                "source": "図書館法を地方の万人の手に",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "又清朝の四庫全書の目録、皆其の時の現存の目録を擧げて、文淵閣に鈔寫して保存した本、即ち著録本と、名目だけ留めた本、即ち存目本と兩方書いてありますが、兩方とも其の當時、本を集める人は全部目を通したもので、これは全く信用の出來るものであります。",
              "citation": {
                "source": "支那の書目に就いて",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方書籍の分け方は、二劉の後も、彼等の最初考へた六略の趣旨を出ない。",
              "citation": {
                "source": "支那目録學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉永五年九月年五十四、御作事方書役出役。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈『北海道先史学十二講』北方書院　昭和24年11月〉",
              "citation": {
                "source": "言語と文化史",
                "author": "――アイヌ文化の探究にあたりて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の錬金術の免許｜取のお仲間で、道場と云う暗い廚に閉じ籠って、際限のない、むずかしい方書どおりに、1040気味の悪い物を煮交ぜたものだ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「有難う、姉ちゃん」「このことやろ」「ふん、これやわ、有難う」「もう綴方書けたのんか」「いかん、―――いかん、―――」悦子は帳面を取り上げると、両手でひしと胸に抱きしめるようにしながら向うの方へ飛んで行った。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎の方では、光子に対して何等疚しい関係はないということ、男子が一たん約束をした以上は、何とか相手の身のふりかたがきまるまでは約束をやぶるわけにはゆかないことを意地になって言い張ったので、とうとう喧嘩別れになったままで彼は出ていったのであった。",
              "citation": {
                "source": "山吹町の殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもどう身のふりかたがきまるか分りません由。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "間取りもいいのでしょうけれど、使いかたがきれいです」　と、恵子が言った。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
