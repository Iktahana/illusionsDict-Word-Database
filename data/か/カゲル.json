    "definitions": [
      {
        "index": 1,
        "gloss": "to become clouded",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "空が急に陰ってきて、雨が降りそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の顔が少し陰った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夕焼けが陰り、夜の帳が降りてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "陰るかと思った空は又うす明るくなって、厩橋の渡しを越えるころには濁った大川の水もひかって来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは盂蘭盆の十三日で、昼の暑さはまだ水売りの声に残っているが、陰るともなしに薄い日影が山の手の古びた屋敷町を灰色に沈ませて、辻番のおやじが手作りの鉢の朝顔も蔓ばかり無暗に伸びて来たのが眼に立った。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日の午後、日の陰る頃、彼は煙草畑へ出て行つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日薄く南窓を射、忽ちまた陰る。",
              "citation": {
                "source": "雲の日記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "散りては更に寄せ来なる　雲の波だつ空の下に照りては陰る牧の原。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かしら忌わしいものが、日が陰るように胸の中をスーッと通りすぎた。",
              "citation": {
                "source": "湖水と彼等",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の夕方、日の陰る頃を見計って朝太郎の吉松殿は、牡丹に丸の定紋のついた、立派な駕籠に乗せられて、城下の方へつれて行かれました。",
              "citation": {
                "source": "三人の百姓",
                "author": "秋田雨雀",
                "note": "青空文庫"
              }
            },
            {
              "text": "より濃密な障害物が陽の光を遮り風景が暫し陰ると、私には描出すること望むべくもない微妙に脅迫的な効果が現れた。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕日の　日｜陰る宮。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽が陰ると、寒うなるぞ」「はい」「来ぬか」「お詣りしてもどります」　時政は、にこと頷き、館の屋根と広い庭を下に見ながら小道を降りて行った。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長門領の山からひろがった白雲が、ちょうど中天の太陽を時折かすめて、陽が陰ると、全島の樹々や篠のそよぎが、暗くなった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "花のにおいがかげるくらいのそばに。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お一方｜御逗留、おさみしそうなその方にも、いまの立山が聞かせたいと、何となくそのお一方が、もっての外気になるようで、妙に眉のあたりを暗くしましたっけ、熟と日のかげる山を視めたが、（ああ。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "光るなし、かげるなし、夕満ち汐、うらもなし、うつつなし、膝、くるぶし。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この寺が大椿寺ぞとはひり来て寂しと出でぬ日暮を二人この寺も古うなりぬと陽の隈に尿しつつ云ふ我も寒むかりさびさびと暮れしづもれば磯寺の障子はかげる寒しとなしに長井二月三日薄暮、三崎より乗合自動車での帰途半で下車、長井で一泊することになつた。",
              "citation": {
                "source": "海阪",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "向つべに日のかげる山、なほ明く温かき山、その空の白き綿雲、ちろちろと禽渡るさへ、なかなかにあはれとも見れ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌この春や水車が立つる水だまの早や大きなり芽柳のもと孟宗と月孟宗と月〔「孟宗と月」の章の長歌「孟宗と月」の末尾に〕反歌物すごき孟宗藪の月あかりかげるかと見れば騒ぐ葉の影秋山の歌〔「秋山の歌」の章に〕水之尾の秋この秋よ、雲は白うて、事もなき世にしあるかな。",
              "citation": {
                "source": "篁",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "巒気か、冷気か、雲が迅いか、日がかげるか、自動車の捲き起す疾風か、私たちの胴ぶるいこそは繁くなると、　ああ、古蒼なさるおがせが椴松の高い枝にかかっている。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼方でとんとん、此方でとんとん、やれやれ、いそがし、日がかげる。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "向つべに日のかげる山、なほ明く温かき山、その空の白き綿雲、ちろちろと渡る禽さへなかなかにあはれとも見れ。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ間に合います――まあ、いずれ首を括られるでしょうが……」　ホームズの顔が不安にかげる。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "髑髏の旗は、海賊が仕事をするときにはいつでも、かかげるものなのだ。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "瘧だごったら、医者さかげる程のごどでもがすめえで、瘧ずもの、うんと仰天させっと、直んぐに癒るもんだどみっしさ。",
              "citation": {
                "source": "芋",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日がかげるころになって葉子も一緒に庭に出てみた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽がかげる頃に彼れは居酒屋を出て反物屋によって華手なモスリンの端切れを買った。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワラは、山崎にかわって、ライトをかかげることになった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにかの参考のために、その当時、かの外国人らが引幕に添えて守田勘弥に送った書面を左にかかげる。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は晴れていながら、どうかして日の光がうっすらとかげると、どこからともなく雪がおちてくるのである。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日がかげるまで我々はさうしてほとんど身動きもしない。",
              "citation": {
                "source": "ジガ蜂",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日日は、頻りに投票ハガキの多いこと、為に中央郵便局の消印機が過熱して使用に堪えぬとか、コンクリートの五階が潰れるとか、センセーショナルな記事をかかげる。",
              "citation": {
                "source": "夏遠き山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
