      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "each (person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "では、各自、持ち場に戻って作業を再開してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この資料は、各自で目を通しておいてくださいね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議の参加者は、各自、意見をまとめておくように。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "お土産は、各自、好きなものを選んでください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "先生は、生徒たちに各自のノートを提出するように指示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ケチなこつたと云つて呉れるな、子供つぽい考へだとも云つては呉れるな、誰でもが各自持つてるおきまり自問自答の二つ三つ、それこそは生きた詩であらうから。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "（とまれ一切物中に於ける、各自我のスペクトルの乱雑が、近時世界の芸術に萎凋を来してゐる。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の暮家路に遠き人ばかり　薄暮は迫り、春の日は花に暮れようとするけれども、行路の人は三々五々、各自に何かのロマンチックな悩みを抱いて、家路に帰ろうともしないのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句から感ずるものは、各自に小さな家に住んで、それぞれの生活を悩んだり楽しんだりしているところの、人間生活への或るいじらしい愛と、何かの或る物床しい、淡い縹渺とした抒情味である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "各自の望みを追うに暇のない世人は、たまに彼の萎びた掌に一片の銅貨を落す人はあっても、おそらくはそれはただ自分の心の中の慈善箱に投げ入れるに過ぎぬであろう。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで多くの場合には各自の意見を参酌し折れ合って大体の価値を決め、そうして皆が十分の責任を負うというだけの自信を得た上で及落を決定する。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは各自の反省すべき点であろう。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すればその詩を味わう読者各自の能知に内在する、その原型の模型にどれだけ照応するかの程度によって各評価者の価値判断が極るのであろう。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに附帯しては、地震の破壊作用の結果として生ずる災害の直接あるいは間接な見聞によって得らるる雑多な非系統的な知識と、それに関する各自の利害の念慮や、社会的あるいは道徳的批判の構成等である。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし現在のように科学というものの中に、互いに連絡のよくとれていない各分科が併立して、各自の窮屈な狭い見地から覗い得る範囲だけについていわゆる専門を称えている間は、一つの現象の概念が科学的にも雑多であり、時としては互いに矛盾する事さえあるのは当然である。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく科学者と称する人々の中でも各自の専門に応じて地震というものの対象がかくのごとく区々である。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "他が為に家庭趣味を説くは陋しい、人の各自に其の家庭趣味を談じて、大いに其の趣味を味うというは、人世の最大なる楽事であるまいか。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の座長の演説の中に物理学者の二つの流派、すなわち実験派と理論派との各自の偏見から来る無用の争いを誡めた一節は、そのまま現代にもあてはまるべきものである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "教育者はそういう点から考えても時々はレビューでも映画でも大衆雑誌でも、およそ現代の少青年の心を捕える限りの民衆教育機関を見学し研究し、そうして、そういうものの如何なる因子が民衆に働きかけるかを分析して、その分析の結果を各自の仕事の上に応用すべきではないかと思われる。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは画家各自の選み出した要素がそれぞれ一種の普遍的な事実あるいは方則のようなものであって、しかも相互の間に何らの矛盾もなければ背違もない。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石井氏の「二科同人群像」には単なる似顔の集成でなく、各メンバーの排置のみならずそのポーズや服装によって各自の個性を表現しようという苦心の痕が覗われる。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのやうに自ら死を持つてゐると云ふことが、各自に獨特な威嚴と平靜な誇りとを與へてゐたのであつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして土着した住民は、その地形的特徴から生ずるあらゆる風土的特徴に適応しながら次第に分化しつつ各自の地方的特性を涵養して来たであろう。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に各自の住み着いた土地への根強い愛着の念を培養して来たものであろう。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろわれわれはこの現象がどうして発生したかを研究し、またその将来がどうなるであろうかということを考察した上で、これに対する各自の態度を決めるのが合理的ではないかと思われるのである。",
              "citation": {
                "source": "俳句の型式とその進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵巻物では、一つの場面から次の場面への推移は観覧者の頭脳の中で各自のファンタジーにしたがって進転して行く。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は一通りの理論から期待される事であるが、実際の場合にどこまでこれが当たるか、各地方の読者の中で気象のほうに興味を持たれるかたがたの各自の研究をおすすめしたいと思うのである。",
              "citation": {
                "source": "海陸風と夕なぎ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "原理の白色光に照らされた時に万象は各自に特有な色彩を現わして柳は緑に花は紅に見える。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそのおかげで学者は心静かに落着いて各自の研究に没頭していられるのかもしれない。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物人の読者はそれを見て各自の中に居る「坊ちゃん」「赤シャツ」エトセトラを共鳴させる。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで順番に各自が宛がわれた章を講ずる、間違って居ると他のものが突込む、論争をする、先生が判断する、間違って居た方は黒玉を帳面に記されるという訳なのです。",
              "citation": {
                "source": "学生時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の世界じゅうの科学者らは毎日各自の研究室に閉じこもり懸命にこれらの化け物と相撲を取りその正体を見破ろうとして努力している。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは高等学校から大学へ来て各自専門の科学の部門の豊富な課程に食傷するほどの教育を受けるのであるが、いまだかつてどこでも科学とかなんとかいう事についての考察の端緒をも授けられないのである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこの学者が自分の題目だけを追究している間は少しの不都合も起こらないのであるが、一度こういう学者たちが寄り合って、互いに科学というものの本質や目的や範囲に関する各自の考えを開陳し合ってみたら、その考えがいかに区々なものであるかを発見して驚くことであろうと思う。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、そりやさうとして、何とかくじがあたらないものかな？",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
