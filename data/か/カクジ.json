  {
    "uuid": "cc340720-2b6b-509b-a0c2-160f9ff0eb0f",
    "entry": "角字",
    "reading": {
      "primary": "かくじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "style of lettering consisting of thick vertical and horizontal lines, often used in seals, crests, etc.",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "老舗の半纏の背中に、力強い角字で屋号が鮮やかに染め抜かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この落款は、角字の配置が絶妙で全体のバランスをぐっと引き締めているね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "江戸切子の伝統的な文様に角字を組み合わせて、モダンなデザインのグラスを特注した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "兎に角字音にも國語にも假名遣に困難はありますけれども、凌ぐべからざる程の困難はないやうに思ひます。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その豆腐屋の一軒置いて隣が仙太郎の宅で、好い家ではございませんが、表には荒い格子が嵌って、台所には腰障子が嵌めてありまして、丸に仙太というのが角字でついて居ります。",
              "citation": {
                "source": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "author": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、そりやさうとして、何とかくじがあたらないものかな？",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそのうち将軍は、だんだんものを食はなくなつてせつかくじぶんで播いたりした、粟も一口たべただけ、水をがぶがぶ呑んでゐた。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「とにかくじっと辛抱していることです。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくじつに、ここへ持って来てくれるひとがあるのよ。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い男の所へ若い女子が度々｜出入したら、そんな事は無うても、人がかれこれ言ひ易い、可えですか、そしたら、間はとにかくじや、赤樫様と云ふ者のある貴方の躯に疵が付く。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せっかくじゃが、ひと足おそうござったな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがの、わしは今日はもう、せっかくじゃが、薬は、いらぬのじゃ。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――とにかく、だまされたと思って、出かけるか」　蟻田博士は、そこに立ちながら医者や看護婦の顔色を用心ぶかくじろりじろりとにらみつつ、一歩一歩玄関の方へあるいていった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せっかくじゃがお断りじゃ」鬼王丸はにべもなく云った。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟻の足なんかくじかせてさ――あの可哀想な小さな足をさ――』　とばつたが云ひますと、氷が答へました。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラスコーリニコフは肩ごしに町人を尻目にかけて、注意ぶかくじっと見つめていたが、ものうげな低い調子で言った。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、いって、つぎの日　さっそく　あんこくじに　つかいを　よこして、「あす　小ぞうの　しゅうけんを　つれて　きんかくじに　きなさい。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしみつ公は　そのころ　あたまを　そって　ぶつもんにはいり、天山と　いいましたが、きんかくじを　たて、そこに　すんで　いたのでした。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょうぐんさまから　まねかれる　ことは　大へんな　めいよですから、おしょうさまは　さっそく　しゅうけんを　つれて　きんかくじに　いきました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上近くなつて鎖の懸崖にかかつたのが三条あり、最初の鎖の手前で登山の行者が皆草鞋を穿き替へることになつて居り、そこいらの岩道は草鞋の腐蝕した堆積によつて黒く柔かくじめじめとなつて居た。",
              "citation": {
                "source": "初旅の残像",
                "author": "安倍能成",
                "note": "青空文庫"
              }
            },
            {
              "text": "志保はわれ知らず縋りつきたいような衝動に駆られた、逞ましい庄三郎の肩、意志の勁そうな眉、豊かな線をもつひき緊った唇つき、なにもかもが親愛な、温かくじかに心に触れてくる感じだ、――こんなにも自分に近いひとだったのか、そういう気持がぐんと志保をひき寄せるように思えた。",
              "citation": {
                "source": "菊屋敷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一センチ、二センチ、三センチ、重い金属のふたは、動いているか動いていないか、わからぬほどの速度で、しかし、かくじつに、ひらいていきます。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "家康は、その通り、信雄に答え、（せっかくじゃが）　と、あっさり断った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
