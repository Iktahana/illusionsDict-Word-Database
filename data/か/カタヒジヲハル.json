        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "高級レストランのディナーは、どうしても肩肘を張ってしまい味がよくわからない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "格式高い茶会に招かれ、終始肩肘を張っていたため肩が凝ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "社長との面談だからといって、過度に肩肘を張る必要はないと上司に言われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
