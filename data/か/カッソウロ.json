[
  {
    "uuid": "e61006da-ce26-540e-bf66-e9ab85ecbd75",
    "entry": "滑走路",
    "reading": {
      "primary": "かっそうろ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
