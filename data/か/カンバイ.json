[
  {
    "uuid": "b5f934c4-5274-5348-b359-259ab404edd4",
    "entry": "完売",
    "reading": {
      "primary": "かんばい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "selling out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "でもたちまち全部完売で、どこへ売ったかも何も教えてくれません。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "二五〇〇ドルの元手でプリント基板を一〇〇枚起こし、完売で五〇〇〇ドルの売り上げを目指していたアップルのビジネス規模は、テレルからの注文で一気に一桁増しとなった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こりゃ、いかんばい」　海賊どもは、船を壊して火を放けたらしい。",
              "citation": {
                "source": "呂宋の壺",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「倅をいつまでも籍なしで、置いといちゃいかんばい。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉井さん、気をつけんといかんばい。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
