    },
    "definitions": [
      {
        "index": 1,
        "gloss": "box and cover",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
