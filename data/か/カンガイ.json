  {
    "uuid": "531d7a72-aefb-548d-b9e6-9ad95b7210f0",
    "entry": "函蓋",
    "reading": {
      "primary": "かんがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
