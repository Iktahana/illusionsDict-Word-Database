[
  {
    "uuid": "6ac2bb22-3ff7-570f-8f40-925435e461ee",
    "entry": "肩にかかる",
    "reading": {
      "primary": "かたにかかる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行"
      ],
