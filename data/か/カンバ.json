    "definitions": [
      {
        "index": 1,
        "gloss": "place to dry seaweed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
