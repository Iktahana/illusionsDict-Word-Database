        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市は、人口増加に対応するため、新しい火葬場の建設を検討しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "亡くなったペットを丁重に火葬するため、専門の火葬場を利用しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「おじいちゃん、安らかに…」遺族は静かに火葬場を後にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "火葬場の予約は、葬儀社を通じて行うのが一般的です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "遺骸は町屋の火葬場で火葬に付して、その翌朝Ｔ老教授とＮ教授と自分と三人で納骨に行った。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きなアカシヤのかげには火葬場が作られていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後の村には燃えさしの家が、ぷすぷす燻り、人を焼く、あの火葬場のような悪臭が、部隊を追っかけるようにどこまでも流れ拡がってついてきた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女がこと切れた時よりも、火葬場での時よりも、変わった土地へ来てするこんな経験の方に「失った」という思いは強く刻まれた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでどこかの火葬場といった感じであった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "火葬場からの帰途、それは薄曇りの日であつたが、白つぽい道の上を歩きながら、死んだ弟の次の弟が、訊かれたでもないのに、フト語り始めるのであつた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物のいない客席は夜の火葬場のようにひっそりとしていた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は泣く泣く米の死体を火葬場に送った。",
              "citation": {
                "source": "妖蛸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その火葬場へは、米の弟の新吉と云うのも来ていたが、それは真箇の弟でなしに、米がまだ歌妓をしていた時からの情夫で、土地の人から達磨の新公と渾名せられている浪爺であった。",
              "citation": {
                "source": "妖蛸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もてあました女房は、町屋の火葬場の前にある地蔵院へ往って、理由を話してそこへ封じこめてもらう事にした。",
              "citation": {
                "source": "偶人物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火葬場の煙突のような大きい煙突が立っていた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "火葬場の煙突のやうな大きい煙突が立つてゐた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕で引き裂いて総歯で噛み砕いて、滓にして吐き出して、それを靴の踵で踏みにじって、それから火葬場の炉の中ですっかり焼き尽してしまいたかった。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "火葬場の女松や枯｜櫟や、通り過ぎると、青い杉や小松の長い長いトンネルになる。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "南湖院｜潮騒ひくし春もやや闌けにつつありて人は果てたり臨終まで我をたのめと沙汰せよと待ちまけし君をひとり死なしぬ死顔の神さぶ見れば灯をつけて揺るるコードの影か隈だつ電気火葬仏は義妹富子の母刀自、落合火葬場にて。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪性の流行｜感冒は日に幾十となくその善良な市民を火葬場に送った。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "人跡稀な山奥の火葬場で人を焼く序に、棺桶を発いて目ぼしいものを奪い取る。",
              "citation": {
                "source": "書けない探偵小説",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が殺した妻君を火葬場へ送る前に、名残を惜しんだ体に見せかけるべく撮影した写真の乾板を、同情した友人と一所に泣きの涙で現像してみると、その死顔の瞼が動いてボヤケていたというストオリイなぞ、思わずゾッとして地団太を踏みたくなる。",
              "citation": {
                "source": "私の好きな読みもの",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "福岡アタリの火葬場にもよくウロウロしおりましたそうで……真夜中でも何でも六神丸の看板を見当てにしてタタキ起しますと、大抵手真似で話が通じましたもので、私は日本語のすこし出来る支那人を引っぱって木賃宿へ帰って来ました。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま、市営の火葬場へ持って行こうとすると、一番前の椅子に腰をかけていた市場の親友二三人が何事かタマリかねたらしく立ち上って馳けよった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、村には火葬場がなかった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝染病患者の死体を遠くの火葬場まで運んでいくわけにもいかなかったので、駐在所巡査と村役場の書記とが立ち会い、墓場の傍の大きな樫の木の下の空地で原始的な火葬を行うのが村の習慣であった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）「ちっとも構やしない、火葬場ですもの。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛はことごとく完全に消毒的手配をして火葬場へ運ぶのである。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その火葬場のすぐ上流は、発電所工事の砂やバラスの採集所になっていた。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "棺は、釣橋を渡ったり、新らしくできた道路を通ったり、そのまだ開通しない個所から急に、山の断崖を河原に下ったり、バラス採集所の掘り残しの狭い高いところを通ったりして、火葬場まで行かねばならなかった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ夫人を鳥辺野の火葬場へ送ることになった。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌二一日、落合火葬場で荼毘にふされる。",
              "citation": {
                "source": "小熊秀雄全集-1",
                "author": "短歌集",
                "note": "青空文庫"
              }
            },
            {
              "text": "――火葬場問題だ、となんて慌てた政治家の遺言の通俗的なことよ。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に遺骸は直ちに自宅へ引取るはずだったが、余り腐爛しているので余儀なく直ちに火葬場へ送棺したと知らせて来た。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
