[
  {
    "uuid": "f0d744e9-68d1-5f24-ab76-e8f202c0f052",
    "entry": "佳月",
    "reading": {
      "primary": "かげつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
