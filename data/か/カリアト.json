        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "収穫を終えた畑には、稲の刈り跡が規則正しく残っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "森林伐採後の山には、痛々しい刈り跡が広がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "牧草地の刈り跡からは、もう新しい草が芽吹き始めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで私たちは燕麦の刈り跡に新聞紙を藉いて、寝ころんだが、雲は白いし、いい機嫌で気焔のあげっこだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "幅の広い刈り跡のような帯が一筋高台の内側から現れて我々が横断してきた経路の二キロメートル弱左にある麓の丘の裂け目へと延びていたが、その帯には一切の建物がなかった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間の心が蒸発して霞になりそうな日だね」と言ったら、一｜間ばかりあとを雪駄を引きずりながら、大儀そうについて来た妻は、エヽと気のない返事をして無理に笑顔をこしらえる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鼠はびっくりして、三歩ばかりあとへさがって、ていねいにおじぎをしてから申しました。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "現にあの色あの形そのものが一種の表情なんだからしかたがない」　原口さんは、この時また二足ばかりあとへさがって、美禰子と絵とを見比べた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "篠原「十日ばかりあとにもどったが。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三の客がきたのは、それから三十分ばかりあとのことであった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにくらべて、エフ氏の足あとは地面にしっかりあとをつけていた。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅吉と二人ばかりあとに残されてみると、急に座敷がテレてしまって、なるほど、あの陽気な人が一人いるといないでは、こうも違うものかと思わせられるくらいです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "よその子はよその子にしてわがおもかげをつたふべきにあらずされば何しに羨やむものぞかく思へどもよその児のよく肥り可愛げなるを見れば畳を掻くごとくくやしきここちすみまかりあとかたもなきわが子のいまはいづこにあらむかと思へばとり返しのつかぬことをせし、泣きもえぬことをせしものかな。",
              "citation": {
                "source": "忘春詩集",
                "author": "忘春詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが十月革命は、それからほんの半年ばかりあとに成就した。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　国際学生会館の人々は、帰りも線のちがう汽車で、伸子と蜂谷良作の二人は、五十分ばかりあとから出発することになった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "返事がすっかりあとからとなりますが、いろいろありがとうね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてクリストフはやはり機械的に、十歩ばかりあとから犬のように二人について行った。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一週間ばかりあとに、クリストフはこしらえたばかりの歌曲をピアノでひいてみた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼が熱くなって、つい口数が多くなるにつれて、かんしゃくまぎれにしゃべってしまったので、昨日としてはもう二つめの失策なのであった……それから後も、この朝はまるでわざとねらったように、不愉快な事ばかりあとからあとから起こった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間ばかりあとには、こぎれいな平屋の戸口に立ち、ジェーン・マーチンを訪問していた。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
