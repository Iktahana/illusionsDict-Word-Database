          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この焼き鳥、足りないと思ったら、やっぱり辛子をちょっとつけると美味しい！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "おでんには、やっぱり和辛子だよな。ピリッとくるのがたまらない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "チューブの辛子じゃなくて、粉から練って作るのが本格的で好きだな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "大風の朝も赤し唐辛子　暴風雨の朝、畠の作物も吹き荒され、万目荒寥として枯れた中に、ひとり唐辛子の実だけが赤々として、昨日に変らず色づいているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村外れの茶店で昼飯を食った時に店先で一人の汚い乞食婆さんが、うどんの上に唐辛子の粉を真赤になるほど振りかけたのを、立ちながらうまそうに食っていた姿が非常に鮮明に記録されている。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか有田の乞食婆の喰っていたあの唐辛子のかかった真赤なうどんと、ポツオリの旗亭のトマトのかかった赤いスパゲッティとの類似のためであろうとも思われない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平然と立ち上つて、狸の火傷にれいの唐辛子をねつたものをこつてりと塗る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸汁の運命から逃れて、やれ嬉しやと思ふ間もなく、ボウボウ山で意味も無い大火傷をして九死に一生を得、這ふやうにしてどうやらわが巣にたどりつき、口をゆがめて呻吟してゐると、こんどはその大火傷に唐辛子をべたべた塗られ、苦痛のあまり失神し、さて、それからいよいよ泥舟に乘せられ、河口湖底に沈むのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "納豆屋の「ナットナットー、ナット、七色唐辛子」という声もこの界隈では近ごろさっぱり聞かれなくなった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七味唐辛子を売り歩く男で、頭には高くとがった円錐形の帽子をかぶり、身にはまっかな唐人服をまとい、そうしてほとんど等身大の唐辛子の形をした張り抜きをひもで肩につるして小わきにかかえ、そうして「トーン、トーオン、トンガシノコ」と四拍子の簡単な旋律を少しぼやけた中空なバリトンで歌い歩くのがいた。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大きなまっかな張り抜きの唐辛子の横腹のふたをあけると中に七味唐辛子の倉庫があったのである。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、廂に唐辛子、軒に橙の皮を干した、……百姓家の片商売。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "忿怒の面相、しかし威あつて猛からず、大閻魔と申すより、口をくわつと、唐辛子の利いた關羽に肖てゐる。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の間ものの、ぼたん、ばらよりして、缺摺鉢、たどんの空箱の割長屋、松葉ぼたん、唐辛子に至るまで聲を出せば節になる。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……恐しい利く唐辛子だ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何、上方筋の唐辛子だ、鬼灯の皮が精々だろう。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "辛子菜の香味、茄子の色彩、胡瓜の快活、糸菜の優美、――しかし私はどちらかといえば、粕漬の濃厚よりも浅漬の淡白を好いている。",
              "citation": {
                "source": "漬物の味〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸汁の運命から逃れて、やれ嬉しやと思ふ間もなく、ボウボウ山で意味も無い大火傷をして九死に一生を得、這ふやうにしてどうやらわが巣にたどりつき、口をゆがめて呻吟してゐると、こんどはその大火傷に唐辛子をべたべた塗られ、苦痛のあまり失神し、さて、それからいよいよ泥舟に乗せられ、河口湖底に沈むのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩と胡椒と辛子を入れる。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の司厨長を呼び寄せて、みな下で作らして居ますのよ」「わざ／＼、まあ、恐れ入りました」「私、最近に下町で瀟洒なレストラントを始めようと思つて、店や料理人を用意してありますのよ」　女主人はレモンの汁を私の皿の手前に絞つて呉れ、程よく食塩と辛子を落して呉れた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其八　明日辰の刻頃までに自身当寺へ来るべし、予て其方工事仰せつけられたきむね願ひたる五重塔の儀につき、上人｜直接に御話示あるべきよしなれば、衣服等失礼なきやう心得て出頭せよと、厳格に口上を演ぶるは弁舌自慢の圓珍とて、唐辛子をむざと嗜み食へる祟り鼻の頭にあらはれたる滑稽納所。",
              "citation": {
                "source": "五重塔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天才」といふ言葉が、唐辛子のやうに私の頭を熱くした。",
              "citation": {
                "source": "いろ／＼の言葉と人",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その腸を二升瓶に貯える、生葱を刻んで捏ね、七色唐辛子を掻交ぜ、掻交ぜ、片襷で練上げた、東海の鯤鯨をも吸寄すべき、恐るべき、どろどろの膏薬の、おはぐろ溝へ、黄袋の唾をしたような異味を、べろりべろり、と嘗めては、ちびりと飲む。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "指で挟んだ唐辛子でも構わない。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "有明の海の泥に匍う小蟹を生けるまゝ臼で搗き潰し、強い塩とたくさんの唐辛子を加えて馴れさす一種の塩辛です。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "野鼠は唐辛子でも食うとよ」「仕方がない、山椒の葉を摘んで来よう」　花田は女の子に烏の叩き肉の番をしておれと命じて、山椒の葉を摘みに出かけました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鶴はんはな、お初つぁんと一緒に夜店へ七味唐辛子を売りに行ったはるねんぜ」「えっ？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰るなら帰ると……」　お鶴の髪の毛は、油気もなくばさばさと乱れて、唐辛子の粉がくっついていた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐辛子の刺戟がぷんと鼻に眼に来て、他吉は眼をうるませた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その良心さへ十分ではない所からして、十分に納得出来る詩が得難いのではあるまいか。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学といふものが、凡そ文字を知つてゐれば、誰にも読むことが出来るといふことからして、余りに文士志望者が容易に生じるといつた現状だが、文学を仕事とするからには、※ルレーヌの言葉を以てすれば、「自分の通り道にあつたものだけを読むだけ」の努力では何にもならぬ。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その危険な兆候が、五十｜歳を越えてからしばしば現われて来た。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからして自分は、時にしばしば彼を「意地惡き皮肉の人」とも考へた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
