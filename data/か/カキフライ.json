        "examples": {
          "standard": [
            {
              "text": "冬になると、無性に牡蠣フライが食べたくなるんだよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はレモンをたっぷり絞って、熱々の牡蠣フライを頬張った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このレストランの牡蠣フライは、衣がサクサクで中の牡蠣がクリーミーだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "○　街頭の柳｜散尽して骨董屋の店先に支那水仙の花開き海鼠は安く鰤鰆に油乗って八百屋の店に蕪大根色白く、牡蠣フライ出来ますの張紙洋食屋の壁に現わる。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "折悪しく誰もいないので、井上君と二人で生れて初めて牡蠣フライを電熱器で拵えたが、古パンでパン粉を作るのが一番厄介だった。",
              "citation": {
                "source": "三浦環のプロフィール",
                "author": "吉本明光",
                "note": "青空文庫"
              }
            },
            {
              "text": "この通りには、ところどころに西洋料理店はあるし、大方は、地下室が、料理場になつてゐて、ほ道とすれ／＼に通風窓があるから、野菜サラダだらうが、かきフライであらうが、鼻が悪くない限りごみ箱を連想し、その所在を気にせずとも、それより遙に新鮮なにほひを感じるのは当然である。",
              "citation": {
                "source": "丸之内点景",
                "author": "‥‥東京の盛り場を巡る‥‥",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
