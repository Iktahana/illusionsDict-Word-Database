[
  {
    "uuid": "a51b17a4-ddbf-5a85-8236-be2b4cccdb18",
    "entry": "化学",
    "reading": {
      "primary": "かがく",
      "alternatives": [
        "ばけがく"
      ],
      "is_heteronym": false
    },
    "grammar": {
