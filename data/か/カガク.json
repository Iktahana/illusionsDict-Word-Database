    },
    "definitions": [
      {
        "index": 1,
        "gloss": "chemistry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "フラスコの中で二つの透明な液体を混ぜ合わせると、激しい化学反応が起きてピンク色に変わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼は大学の化学科に進学し、新しい有機化合物の合成に青春を捧げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "食品のパッケージ裏にびっしりと書かれた化学調味料の名前を見て、そっと棚に戻した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それは鮓の素であるところの、醋の嗅覚や味覚にも関聯しているし、またその醋が、暗所において醗酵する時の、静かな化学的状態とも関聯している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし詩の思念といふものは、詩の言葉の包有してゐる連想や、イメーヂや、韻律やの中にふくまれ、化学的に分析できない有機体となつて生きてるのだから、原詩の文学的構成だけを訳したところで、詩の意味を伝へることは出来やしない。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネルンストの「物理化学」もひやかしに一、二度聴いたことがあったが、西洋人にしては脊の低いずんぐりした体格で、それが高い聴講席をふり仰ぎながら活溌に手を振り身体を動かし頸を曲げてゼスチュアの賑やかな講義をして見せた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その若先生が折々自分の我儘な願いに応じて「化学的手品」の薬品を調合してくれたりした。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無色の液体を二種混合するとたちまち赤や黄に変り、次に第三の液を加えるとまた無色になると云ったようなのを幾種類か用意してもらって、近所の友達を集めては得意になって化学的デモンストラチオンをやって見せたのであった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物理学者や化学者は物質を磨り砕いて原子の内部に運転する電子の系統を探っている。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "化学的の分析と合成は次第に精微をきわめて驚くべき複雑な分子や膠質粒が試験管の中で自由にされている。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに助手の西田君が来て大学の医化学教室が火事だが理学部は無事だという。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、理化学の進歩の結果としてあらゆる交通機関が異常に発達したのはよいが、その発達が空間的時間的に不均整なために、従来は接触し得なかったような甚だしい異質的なものの接触が烈しくなり、異質間の異性質のグレディエントが大きくなった。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずおのおの独立の名称を有っている科学の分派、例えば物理とか化学とかいうものの中にまた色々の部門がおのおの非常な発達をしている。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに世界における物理化学に関する研究論文の文献を集録した『フィジカリッシェ・ベリヒテ』及び『ケミカル・ニュース』の最近のものについて日本人の論文の数を検して見ると約三プロセントくらいのものである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "光がエネルギーを搬ぶと考えると光のあらゆる物理的化学的性質を説明して矛盾するところがない。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "光は熱を生じ化学作用を起しまた圧力を及ぼして機械的の仕事をする。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧洲の大戦が爆発して以来は却って世間一般特に実業者の側で痛切にこの必要を感ずるようになったと見え、公私各種の理化学的研究所が続々設立されるようになった。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に文部省でも特に中等教育における理化学教授に重きをおかれるようになって、単に教科書の講義を授くるのみならず、生徒自身に各種の実験を行わせる事になり、このために若干の補助費を支出する事になった。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツの工業が著しい長足の進歩をしたのは、その基礎となるべき物理学、化学の研究に帰因するという事は識者の認めている所である。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "化学的現象は勿論の事、ブラウン運動等の研究はますます分子原子の実存を証するようになり、真空管や放射性物質の研究はどうしても電子の存在を必然とするようになって来た。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この銭は多くは化学材料を買うために費やされ、ある時は燐で指を焼いた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年ケルヴィン卿が化学会の晩餐演説でこの事を引合に出し、レーリー卿は十二歳のときに燐で指を焼いたそうだが、自分は八十二歳のときに全く同じ火傷をしたと云った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "協会幹事として彼はウィラード・ギブスの酬われざる貢献を認めこれを表彰したいと望んだが、化学方面の評議員が「あれは化学じゃない」と云って承知せず、ケルヴィン卿までも反対した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその結果を『ネーチュアー』誌に載せて化学者の批評と示教を乞うた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてあらゆる方法で、あらゆる可能性を考慮して、周到な測定を繰返した後に、結局空気から得たあらゆる窒素と化学的に得られるあらゆる窒素とが、それぞれ一定のしかも異なる比重をもつという結果に到着した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは所長が知人から頼まれて肝油の分析をしてやった、その分析表が訴訟事件の証拠物件となり、分析業者や化学者の団体から抗議が出てだいぶ面倒な問題になったのである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和五年十二月、岩波講座『物理学及び化学』）",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう考えからすれば、あまり純粋な化学薬品のような知識を少数に授けるよりは、草根木皮や総菜のような調剤と献立を用いることもまた甚だ必要なことと思われて来る。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も火花のすぐそばでは、火花のために化学作用が起るが、そういう作用が、四方へ伝播しないで、そこ限りですんでしまう。",
              "citation": {
                "source": "流言蜚語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、大戦前のドイツのある化学工業会社などでは、常に数十人の学者を養って、それに全く気儘な研究をさせたという話である。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの試験の結果から考えると心臓の鼓動するのは塩のごとき化学的の刺戟物が心臓の神経に作用するためで、この種の刺戟がなければ自ずから鼓動する事は出来ぬだろうという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六かしく云えば機械力なり電気なりまた化学作用なり如何なる方法によるも熱くない光を作る事は出来ぬ。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子猫はおなかがくちくなると、すまし返って前足をかわるがわる動かしながら、喉を鳴らし始めた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
