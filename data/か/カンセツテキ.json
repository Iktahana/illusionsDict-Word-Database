[
  {
    "uuid": "d46ffbfc-8510-58dc-b76f-e497f9f055f9",
    "entry": "間接的",
    "reading": {
      "primary": "かんせつてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
