[
  {
    "uuid": "6c202bee-d2bf-5092-92a7-280d003bb38e",
    "entry": "風に吹かれて",
    "reading": {
      "primary": "かぜにふかれて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
