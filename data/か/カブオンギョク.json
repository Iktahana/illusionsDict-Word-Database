      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "singing, dancing and music",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祝宴では、歌舞音曲が夜遅くまで続き、出席者は皆、大いに楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "寺社の祭りの日には、境内で様々な歌舞音曲が奉納され、多くの見物客で賑わう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は芸事全般に精通しており、特に歌舞音曲のこととなると、その知識は右に出る者がいない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近の若い世代は、伝統的な歌舞音曲よりも、ポップカルチャーに興味があるようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "歌舞音曲も別段客をもてなさうといふ露骨な意圖でもつて行はれるのではない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳴物停止は歌舞音曲のたぐいを禁ずるに過ぎないのであるが、それに伴って多人数の集合すること、遊楽めいたこと等は、すべて遠慮するのが其の時代の習慣であったので、さし当り七月二十六夜の月待ちには高台や海岸に群集する者もなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞音曲も別段客をもてなさうといふ露骨な意図でもつて行はれるのではない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅津家は代々非常な遠祖から歌舞音曲の家柄であったという。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し如何なる種類の歌舞音曲であったかは的確に判明しないが、後に同家の家系の中から梅若九郎右衛門なぞいう名家を分派したところを見ると、相当の繁栄を遂げていた事が推測される。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉興に羅愛愛という娼婦があったが、容貌も美しければ、歌舞音曲の芸能も優れ、詩詞はもっとも得意とするところで、その佳篇麗什は、四方に伝播せられたので、皆から愛し敬われて愛卿と呼ばれていた。",
              "citation": {
                "source": "愛卿伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内板には宴会や歌舞音曲は無期限に延期するという張り紙がある。",
              "citation": {
                "source": "勇子",
                "author": "一つの追憶",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞音曲その他一二を除いて。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "目立たない、こっそり隠れた遊興の面白さが人々に知られると、暫くの間に、廓の家々では、歌舞音曲の響こそしないが、平常のように客は出入するようになってしまったのである。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "固より伝統的な歌舞音曲の保護も結構には違ひないが、その文化的価値に応ずるものでなければならぬ。",
              "citation": {
                "source": "官立演劇映画学校の提唱",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが若し、政府当局の意向を反映したものとし、今日、すべての演劇や映画がいはゆる平時に於ける「歌舞音曲」の取扱ひを受けるのであるとしたら、ここにも亦、国家のため、由々しい事態がひそんでゐると、彼は思つた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも余は依然として歌舞音曲にふけっているから、我が将兵の中には再び安からぬ心をいだく者が起った。",
              "citation": {
                "source": "決戦川中島　上杉謙信の巻",
                "author": "――越後守安吾将軍の奮戦記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "藩主は謹厳な方で、歌舞音曲はお好みになりませんでしたが、謡はなさるとのことでしたから、自然家中の者も嗜んだのでしょう。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女優｜並に遊女の女歌舞伎、また玩童の若衆歌舞伎、いづれにせよそが存在の理由は専ら演技者の肉体的勢力にありて、歌舞音曲はその補助たりしや明かなり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "この言にても知らるるごとく、コックリは児女輩の遊戯同様のものにて、近ごろ当府下にて流行の景況を見るに、書生輩の下宿屋に休日の晩には数名相会し、種々さまざまのことを問いかけて一夕の遊戯となし、市中にては往々、歌舞音曲を交えてコックリとともにおどり戯むる等、実に笑うべきの至りならずや。",
              "citation": {
                "source": "妖怪玄談",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "能狂言に於て古の風流兒在原業平が、歌舞音曲の化神として現はれたのを見る毎に、吾人は數百年を隔てたる此兩時代の間に、案外に深き關係のあることを考へるのを禁ずることが出來ぬ。",
              "citation": {
                "source": "足利時代を論ず",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年目にはもう名君振りの偽装をかなぐり捨てて、歌舞音曲と酒池肉林の生活に沈湎して居りました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "暴君の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに於て、歌舞音曲がいずれの国、いずれの派の宗教にも必然に具在するので、原始時代よりその如く、今にもその原始的生活を持続する野蛮の間にそれが見出される。",
              "citation": {
                "source": "婦人問題解決の急務",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鉄砲の音はいずれから起ったかわからないが、その一発の音が起ると、さしも昼を欺くほどに焚かれていた篝火が、ほとんど一度に掻消され、同時に歌舞音曲の賑いはパッタリとやみ、人が闇中を右往左往にうごめき出す。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかといって、めいめいの話を聞いていれば、やはり歌舞音曲に関することが多いので、この点は七兵衛も、ちょっと測り兼ねているところです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一日の夜、皇太后宮崩御のことがあり、歌舞音曲は停止されて、例年ならば松すぎまでつづく正月気分も、東京の巷から姿を消した。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞音曲の停まること月余、ただ祭祠の鈴音と鳥の啼く音ばかりであった。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
