[
  {
    "uuid": "73045d44-ca31-5b19-9c4e-caaa369db94e",
    "entry": "歌舞音曲",
    "reading": {
      "primary": "かぶおんぎょく",
      "alternatives": [
        "かぶおんきょく"
      ],
      "is_heteronym": false
    },
    "grammar": {
