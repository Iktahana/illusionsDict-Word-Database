          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「お兄ちゃん、僕の引き出しを勝手に見ないでよ！」と、プライバシーを侵害された弟が怒っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "深夜、誰もいないはずのリビングでテレビの電源が勝手に入り、背筋が凍るような思いをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "許可も得ずに他人の敷地内へ勝手に入るのは、法律で厳しく禁じられている行為です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「どうせ勝手に言わせておけばいいさ」と、彼は周囲の根も葉もない噂話を冷たくあしらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "どういふつもりで付けたのかまだ訊ねてみないが、僕が勝手に想像する所では、無口でそつとしておいて貰ひたい男が、誰でもが多かれ少なかれ感じてはゐても余りに底深い、流れだとして殆んど全く触れないで過ぎる態の非情を、人目にも立たず浚渫してゐるといつた風の心得であらうと思ふ。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「議論するなら勝手にしやれ、あとでゲンコの雨が飛ぶ」――茲に、低俗プラグマチックの、象徴がありはしないか。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の先刻捨てに行つた塵芥が、裏庭の風の吹いて来る方寄りであつたことを「誠意がない」と勝手に決めて始めたお説教以来ブツ続けである。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "度々のことで面倒だから、今度から止めにして、先へ勝手に寝ることにしろと何度も言うが、妻は婦道に背くと言い、なかなか承知しないので困っている云々（大意）と。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ご勝手に」「おや、あなたは妙な言葉を体得していますね。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手にしろ、という八つ当りの気持だった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間の昂奮とかいふものはさう永続的でないのだから……」――私はそんな理窟を勝手に捏ね揚げて自分の心を制しようと強めた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さう自分で勝手に大きく考へるから。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分が勝手に前置を作つて、そして他人に自分を強請するのか」と思つた彼も、聊か腹立たしかつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に本来言へば、詩の翻訳に語学上の詮議は無用で、むしろ訳者自身の個人的主観によつて、自由に勝手に翻案化してしまふ方が好いのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勝手に夢の國でぐづぐづして居て、」と神はさへぎつた。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、乙姫はご自分の家へやつて來た珍客を階段まで出迎へて、さうして安心して、あとはあなたのお氣の向くままに勝手に幾日でもここで遊んでいらつしやるやうにと、素知らぬ振りしてああしてご自分のお部屋に引上げて行くといふわけのものぢやないんですかね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、葛原勾當日記の、假名文字活字日誌を土臺にして、それに私の濁創も勝手に加味し、盲人一流藝者の生活を、おぼつかなく展開してみたものでした。",
              "citation": {
                "source": "文盲自嘲",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とでも勝手に理窟をこね※すがいい、おれ達はただ飛べばいいんだつてね……マーシヤ――それにしても意味といふものが――トウゼンバツハ――意味ですつて……いま雪が降つてゐる、それに何の意味があります？",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手に雲が飛び、勝手に油虫どもが這い廻っているようであった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、一つの国家と、その向う側の国家とで勝手に決める問題だ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉庫から、ピークへは、「勝手に下りて貰う」より外に方法が無かった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五呎を、第一番に、死体が「勝手に」飛び下りた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七人の労働者と、二人の士官と、二人の司厨が、ピークに、「勝手に」飛び込んだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも例えば長母音を勝手に二音に数えたり、重母音を自己流に分けたり合したりすると短歌と同じ口調に読めるものが多数にある。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この灯の光の色は管内に入れる瓦斯を巧みに調合すればどんな色でも勝手に出来る。",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "えい、冷たいままで勝手におれ、年がら年中冷たい雪を冠っておるのがいいのさ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、なぜ、昔から男は、食後でも人前でも勝手に足を出し欠伸をし、云い度いことも云えるのに、女にそれが許されないのだろう。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の名前は私が勝手につけたのではありません。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだにらむのか、勝手にしろ。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天上どこぢゃない、どこでも勝手にあるける通行券です。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあの救助係の大きな石を鉄梃で動かすあたりから、あとは勝手に私の空想を書いていこうと思っていたのです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝子のやつめ、かってに注文して強くしてもらっているのじゃないかな」そんなことがふっと思えた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天上どこじゃない、どこでもかってにあるける通行券です。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんもののナイチンゲールは、自分かってにうたいますし、いっぽう、つくりものの鳥は、ワルツしかうたわないのですから。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
