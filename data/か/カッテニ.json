[
  {
    "uuid": "a1c91859-a282-5c79-abb3-69ae46da0d81",
    "entry": "勝手に",
    "reading": {
      "primary": "かってに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
