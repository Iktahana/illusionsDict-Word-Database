    "definitions": [
      {
        "index": 1,
        "gloss": "proletariat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「その小説は、産業革命時代の都市部で苦しい生活を強いられていた下層階級の過酷な労働環境をリアルに描いている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「歴史の授業で、当時の社会構造が上流階級と下層階級に明確に分断されていたことを学んだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "格差社会の拡大により、一度下層階級に転落すると這い上がることが難しいという構造的問題が指摘されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "（五）　クヮ（kwa）グヮ（gwa）は、カ・ガと混同する傾向が古くからあり、江戸初期の京都でも下層階級のものはカ・ガと発音したものがあったが、しかし標準的の音としては永く保たれた。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "都會に於ても同じやうに、かうした神神に供物を捧げる人人は、概ね皆社會の下層階級に屬するところの、無智で貧しい人人である。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誤って下層階級に生い立たせられたところから自恃に相応わしい位置にまで自分を取戻すにはカンで攀じ登れる芸術と称するもの以外には彼等は無いと感じた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰻の寄せものは伊太利移民の貧民街などで辻売している食品で、下層階級の食べものだといった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この俗曲論は日本の民族性の理解を基礎として立てた説であるが、一つは両親が常磐津が好きで、児供の時から聴き馴れていたのと、最一つは下層階級に味方する持前の平民的傾向から自然にこれらの平民的音曲に対する同感が深かったのであろう。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴族や富豪に虐げられる下層階級者に同情していても権力階級の存在は社会組織上止むを得ざるものと見做し、渠らに味方しないまでも呪咀するほどに憎まなかった。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "アグネスの不幸は、環境から性的なものを最も素朴な発動の形で男女の関係の間に知っていて、しかも彼女が人間としてより自由な、より豊富な情操の発展として愛を望むと、その方向には既成社会が、貧困、無智、過労とともに下層階級の女の肩に一際重くなげかけている妻、母としての半奴隷的苦境が見える現実である。",
              "citation": {
                "source": "中国に於ける二人のアメリカ婦人",
                "author": "――アグネス・スメドレーとパァル・バック――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小さい諷刺的な絵は、感覚的な効果をもって日本の下層階級生活の貧困と猥雑さとその日暮しの感じとを、傍観的に、だが強く表現していたのである。",
              "citation": {
                "source": "帝展を観ての感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "野蛮人や下層階級の心理について独断的な傾きのつよい作者の説明に対して極めて自然に、そして正当に後代人である我々の心に起る反撥。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は社会の下層階級の人々の持つ感じ方に注意せられます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "下層階級出身のゴーリキイが、そこに到るまでの道ゆきに於て、顕著な特色の一つが、今私の探求心を刺戟している。",
              "citation": {
                "source": "マクシム・ゴーリキイの発展の特質",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「ギャラップの調査員は大部分が女子で、しかも一定の割当人員のだれを選ぶかは調査員自身の決定にまかしてあるため、労働者や下層階級の人を避ける傾向があり、従って多く民主党支持である下層階級の意見が適当に代表されなかったのは、リテラリ・ダイジェストの場合と同様であろう」と判断されている。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "比較的に下層階級の富有な米国でも、同じく全人口中六割五分だけの者が、全国の富のわずかに五分余りしか所有しておらぬのである。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、これまでの経験から、読者というものが下層階級の人間と知合いになることを余り悦ばないことをよく知っているからだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこの心もちの中に中産下層階級を感じている。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日でも中産下層階級の子弟は何か買いものをするたびにやはり一円持っているものの、一円をすっかり使うことに逡巡してはいないであろうか？",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは、女工が二十人、男工が十五人の小さなセルロイド工場で、鉛のように生気のない女工さんの手から、キュウピーがおどけていたり、夜店物のお垂げ止めや、前芯帯や、様々な下層階級相手の粗製品が、毎日毎日私達の手から洪水の如く市場へ流れてゆくのだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○この街にいろいろな人が集ってくる飢えによる堕落の人々萎縮した顔　病める肉体の渦下層階級のはきだめ天皇陛下は狂っておいでになるそうだ患っているもののみの東京！",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝは、女工が二十人、男工が十五人の小さなセルロイド工場、鉛のように生気のない女工さんの手から、キュウピーがおどけて出たり、夜店物のお垂げ止めや、前帯芯や、様々な下層階級相手の粗製品が、毎日毎日私達の手から洪水の如く流れて行く。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、体裁を繕う為により苦痛を受けなければならぬ中流下層階級の貧困だった。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "豪奢をも、――この豪奢に対する憎悪は中流下層階級の貧困の与える烙印だった。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は中流下層階級の貧困だけの与える烙印だった。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "信輔はこの二脚の椅子に全中流下層階級を感じた。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "下層階級の貧困よりもより虚偽に甘んじなければならぬ中流下層階級の貧困の生んだ人間だった。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "太抵は労働を避けて些細な物質的｜贅沢の中に遊惰な日送りをしようとすることが動機であるから、政府は世の社会改良家、教育者、慈善家と共に、それらの無智な女に勧めて何らかの正しい労働に服させるような方法を講じ、出来るだけ下層階級の女の堕落を防ぐべきである。",
              "citation": {
                "source": "私娼の撲滅について",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、体裁を繕ふ為により苦痛を受けなければならぬ中流下層階級の貧困だつた。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "―或精神的風景画―",
                "note": "青空文庫"
              }
            },
            {
              "text": "豪奢をも、――この豪奢に対する憎悪は中流下層階級の貧困の与へる烙印だつた。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "―或精神的風景画―",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
