[
  {
    "uuid": "a4e3445f-c3a0-515a-82bd-c66619a5ea22",
    "entry": "下層階級",
    "reading": {
      "primary": "かそうかいきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
