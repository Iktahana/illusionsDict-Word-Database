[
  {
    "uuid": "fb996434-c3f1-5e89-8df8-1aad5d970b53",
    "entry": "角煮",
    "reading": {
      "primary": "かくに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
