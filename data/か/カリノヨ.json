[
  {
    "uuid": "949d29b7-2b3c-5727-8402-fce846d88645",
    "entry": "仮の世",
    "reading": {
      "primary": "かりのよ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
