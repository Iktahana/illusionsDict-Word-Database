        "examples": {
          "standard": [
            {
              "text": "昔の汽車には罐焚きが必須の職だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は石炭を運んで釜に投入する罐焚きの仕事をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "罐焚きの作業は重労働だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "中野重治氏の「汽車の罐焚き」「原の欅」と幾多執筆された文学についての評論とは、その相互的関係において眺めて、やはり、今日この種の作家のおかれている条件の主観的客観的のむずかしさが痛感せしめられる。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その特色は、昔「鉄の話」によい価値で現われたし、この「汽車の罐焚き」において作品としてまとめ、読者をひっぱってゆく技術的な力として役立っている。",
              "citation": {
                "source": "鼓舞さるべき仕事",
                "author": "――中野重治「汽車の罐焚き」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような文学に於ける社会的見地の抹殺と客観的な評価の消滅が充ちていたとき、最低限の形ででも民衆の日常の現実を文学の対象として描こうとした努力から中野重治「汽車の罐焚き」や徳永直の「八年制」などが書かれた。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "重治の「汽車の罐焚き」ごろ（二年以上前）からそういう名詞が文学上にあらわれたが、現在の文学作品においては質のすりかえと役立っている。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何かまたきっと悪戯をなされたでしょう」「ほんとうは悪戯したのよ、この方が睡っていらっしゃるから、咽喉の辺をさすったのよ」　若い女はまた笑いだした。",
              "citation": {
                "source": "狼の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
