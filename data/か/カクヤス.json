    "definitions": [
      {
        "index": 1,
        "gloss": "(very) cheap",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「引越しシーズンの合間を縫って、格安で家具を揃えることができた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「近所のスーパーで賞味期限間近の牛肉が格安で売られていたので、今夜はステーキにしよう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「型落ちのパソコンを格安で購入したが、ネットサーフィン程度なら全く問題ないスペックだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あそこの居酒屋は飲み放題付きで三千円と格安だから、週末はいつも学生で賑わっている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "何うした事か、今年は夏帽子が格安だつたから、麥稈だけは新しいのをとゝのへたが、さつと降つたら、さそくにふところへねぢ込まうし、風に取られては事だと……ちよつと意氣にはかぶれない。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トーキー時代以前に人気のあった役者たちを世界中から格安な給料でかりあつめました。",
              "citation": {
                "source": "十年後の映画界",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭旅宿の留学生臭い生活を離れて格安ホテルに暫らく自由を味ってみたり、エッフェル塔の影が屋根に落ちる静かなアパルトマンに、女中を一人使った手堅い世帯持ちの真似をしてみたり、新吉は巴里を横からも縦からも噛みはじめた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "格安でモダーンで、そして洒脱でなければいけない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに家賃も格安だつたし、一先づ此處にきめておかうと、その青年父子に――青年のお父さんといふは年老いた醫師であつた――厚く禮を述べ、一晩ゆつくりして行つたらいゝだらうと勸めらるゝのをも斷つて、その日の汽車で私は東京へ歸つた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "木槿の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと年会費六千円で使い放題と格安の上に、容量がかなり制限されるとはいえ、今度は自分の情報が発信できます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、熱海まで行こうと云う方があるのですが、その方と合乗して下さったら、如何でしょう、それならば大変格安になるのです。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜具は上等、お泊り貸は格安、いかがでござります。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、熱海まで行かうと云ふ方があるのですが、その方と合乗して下さつたら、如何でせう、それならば大変格安になるのです。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには自分に受負はせて呉れたら格安に勉強するとでも吐くだらうと言つたが、松山に居る独逸の俘虜で、日本の紋の研究を始めて、材料をどつさり集めてゐるのがあるさうだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "買ひ集めるとなると、大枚の金が要る事だし、寧そ贋物で辛抱したら、格安に出来上るだらうと、懸額から、軸物、屏風、床の置物まで悉皆贋物で取揃へて、書斎の名まで贋物堂と名づけて納まつてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛肉の肉汁が滋養になるのはよく判つてゐるが、少し値段が張り過ぎるからといつて、格安な代用品を発明した男がある。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩に背負つた風呂敷包には、二宮金次郎の道徳のやうな、格安で、加之に「お為めのいい」石鹸や白粉がごたごた包まれてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "新吉がどこからか格安に買って来た手箪笥や鼠入らずがツヤツヤ光って、着物もまず一と通り揃った。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろどこそこに、こういう金時計の出物があるから買わないかとか、格安な莨入れの渋い奴があるから取っておけとか、よくそういう話を新吉に持ち込んでくる。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それなら私もちやうど引越さうと思つてゐるのやさかえ、田中村の奥の方に、一軒格安な家がありますが何うです。",
              "citation": {
                "source": "閾",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが一番格安でもあり、便利だと、迂闊に日本風に考えていたのだが、出帆の日も迫ったのであちこち聞き合わしてみると、日本と違ってそこらの町角や露路に棟梁の家があるわけではなし、さんざ困った揚句、それではと言うので箱から荷作りまですっかり運送屋に一任することにした。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは独逸の方から新荷が着いたばかりだという種々な玩具と一緒に、あの丸善の二｜階に並べてあったもので、異国の子供の風俗ながらに愛らしく、格安で、しかも丈夫に出来ていた。",
              "citation": {
                "source": "伸び支度",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日分の宿泊料も相当格安に予約されてゐた。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショーの会場では、モステクノロジーという新しい半導体メーカーが、６５０２と名付けたマイクロコンピューターを二五ドルという格安の値段で売っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "費用回収のめどが立たず、紙では本にできないものも、格安の電子本でなら作れる。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "箪笥の底に納いこんであった双子の袷も質流れを格安に手にいれたもので、三十何年の間つれ添うて内儀さんに奢ってやった目ぼしいものといえばまあこの袷ぐらいなもの。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか爆薬密売買の手筋を呑み込んでしまって、独力で格安な品物を仕入れては仲間に売る。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "下町の物価の高い事、風俗の派手になつた事、三軒が三軒見て来た芝居の木戸留であつた事、秩父縞の月賦売が却つて格安の事や何かを話して聞かせる。",
              "citation": {
                "source": "茗荷畠",
                "author": "眞山青果",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体今の処では日本料理よりも西洋料理が格安になっています。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "うれしくあたゝかくやすらけく寝たり起きたり、我がまゝをさせていたゞく。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
