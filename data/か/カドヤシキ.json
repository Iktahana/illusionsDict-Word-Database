    "definitions": [
      {
        "index": 1,
        "gloss": "corner house (Edo period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "江戸の古地図を開くと、堀割に面した一等地に大名家の立派な角屋敷が記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "時代劇のロケセットで、刺客が身を隠して標的を待つのは決まってこの角屋敷の陰だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "広大な敷地を持つ角屋敷は、火災が頻発した江戸の街で延焼を食い止める壁の役割も果たした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "鳥打に手をかけて、「つかんことを聞くがね、お前さんは何じゃないかい、この、其処の角屋敷の内の人じゃないかい。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処は深川法乗院門前で俗に三角屋敷と云う処であった。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一軒の角屋敷の前には、焚火して、泅袴に扣鈕一つ掛けし中單着たる男二人、對ひ居て骨牌を弄べり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川の邸は水道橋外で、今白山から來る電車が、お茶の水を降りて來る電車と行き逢ふ邊の角屋敷になつてゐた。",
              "citation": {
                "source": "ぢいさんばあさん",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜も晝も拙者の道場に竹刀の音の絶え間なく、なにぶんにも手狹でござるに因つて、近いうちに町内の角屋敷を買ひ取り、道場を唯今の三倍ぐらゐに取擴げようと存じて居ります。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪の東町奉行所は城の京橋口の外、京橋｜通と谷町との角屋敷で、天満橋の南詰東側にあつた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川の邸は水道橋外で、今｜白山から来る電車が、お茶の水を降りて来る電車と行き逢う辺の角屋敷になっていた。",
              "citation": {
                "source": "じいさんばあさん",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "年月日は覚えないが何でも朝のことゝ思う、豊前中津下小路の西南の角屋敷、大阪屋｜五郎兵衛の家に行て主人五郎兵衛は留守で、弟の源七に金を渡したと云うことまで覚えて居ます。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは暗い軒通いに、小川通りを下って来ると、ふと辻を一つ曲った所に、大きい角屋敷のあるのを見つけました。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅悦住家及び、此を受けてゐる三角屋敷の場などは、南北らしい惨虐と幻怪味と不道徳とが、腐つたはらわたの様に、纏綿してゐるのだが、これすら完全に二つ連続して上演した事を、覚えてゐない。",
              "citation": {
                "source": "お岩と与茂七",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の手の高台もやがて尽きようというだらだら坂をちょうど登りきった角屋敷の黒門の中に生まれた私は、幼き日の自分をその黒門と切り離して想い起すことは出来ない。",
              "citation": {
                "source": "山の手の子",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時はすでに父も母も死んで、ヘンリ通の家には伯母の家族が住まっていたが、シェイクスピアは町の目抜の通、礼拝堂通から礼拝堂小路へかけての角屋敷で、以前にサー・ヒュー・クロプトンといってロンドン市長を勤めたことのある人の屋敷を六十ポンドで買い取っていた。",
              "citation": {
                "source": "シェイクスピアの郷里",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、急ぐでもなく歩いていたが、ふと、行く手に、黒い塀をめぐらした角屋敷を見つけると、　――おッ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "むく犬の吉、ペロリと舌を出して、　――だから、いわねえこっちゃあねえ――松枝町の角屋敷、なかなか七面倒な場所なんだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを真直ぐゆけば、三斎の角屋敷の横に出るのだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この知識が偶然の功を奏して、当時富士見町の角屋敷に官職を辞していた老父のところへ、洋行がえりの同県人と称して来て五十円騙った男を追跡し、それをとりかえしたという逸話さえある。",
              "citation": {
                "source": "中條精一郎の「家信抄」まえがきおよび註",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて明治座の役者たちと共に、電車通の心行寺に鶴屋南北の墓を掃ったことや、そこから程遠からぬ油堀の下流に、三角屋敷の址を尋ね歩いたことも、思えば十余年のむかしとなった。",
              "citation": {
                "source": "深川の散歩",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三角屋敷は邸宅の址ではない。",
              "citation": {
                "source": "深川の散歩",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "毅堂の新に居を卜した竹町四番地の家は旧｜寄合生駒大内蔵の邸内に祀られた金毘羅神社とその練塀を連ねた角屋敷で、旧幕府｜作事方の役人が住んでいた屋敷であったということである。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀留の横町からもちの木坂へ差し掛る角屋敷は、西丸御書院番、二千石の知行をとるお旗本、大迫玄蕃の住居である。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "これではならぬと鼻子は、「実は私はつい御近所で――あの向う横丁の角屋敷なんですが」「あの大きな西洋館の倉のあるうちですか、道理であすこには金田と云う標札が出ていますな」と主人はようやく金田の西洋館と、金田の倉を認識したようだが金田夫人に対する尊敬の度合は前と同様である。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "角屋敷の金田とは、どんな構えか見た事は無論ない。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "虱つぶしにして行ったら、二刻足らずで追いつめることが出来よう」　両国二丁目の角屋敷。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "両国の大鯨",
                "note": "青空文庫"
              }
            },
            {
              "text": "軈て十分間も歩いたと思うと、ある角屋敷の立派な門構の家へ入って行きました。",
              "citation": {
                "source": "耳香水",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "方十二三間もある角屋敷で、形の如く店構へも尋常、暖簾も下がつては居りますが、兩替と質よりは、先祖代々の蓄積と信用と、それから金利で太つた家で、奧の方に土藏が二た棟、脅威的な物々しさで往來を覗いて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "五つの壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "早い話が、近所｜界隈を御覧、銀座の角屋敷は何処も一代で潰れるという評判だけれど、何も角屋敷に限った話じゃない。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの腕木門か」「いや、その隣の角屋敷」「ふム……宏壮なものだな」「出世したものさ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お、ここの角屋敷でござる。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "正木作左衛門の角屋敷の黒塀へ、貼りついたような人影が、身動きもせずに佇んでいた。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
