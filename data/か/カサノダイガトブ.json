        "examples": {
          "standard": [
            {
              "text": "何度も納期に遅れた後、彼は「笠の台が飛ぶ」ことを恐れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "マネージャーは、パフォーマンスが改善されなければ「笠の台が飛ぶ」可能性が現実的だと彼に警告した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "予算削減のため、数名の従業員がまもなく「笠の台が飛ぶ」かもしれないという噂がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「やばい、これをしくじったら、間違いなく「笠の台が飛ぶ」ぞ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「昔なら十両からは笠の台が飛ぶんだ。",
              "citation": {
                "source": "助五郎余罪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "見込まれた近江屋と因業久兵衛の弱り目はさることながら、狂気の真似をし通したお高の根気、役者も下座も粒の揃った納涼狂言、十両からは笠の台が飛ぶと言われたその当時、九カ月あまりに五百両は、もし最終まで漕ぎつけえたら、瘠浪人の書き下し、なにはさて措き、近ごろ見物の大舞台であった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "お茶漬音頭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの狷之介の野郎に捉まって、駒形の大村屋敷に引立てられ、危なく笠の台が飛ぶところでしたよ」　浅五郎は自分の首を平手でピシャリピシャリと叩きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "大村兵庫の眼玉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
