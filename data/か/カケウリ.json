        "examples": {
          "standard": [
            {
              "text": "あの店は常連客にだけ掛け売りをしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "小さな商店では、地域住民への掛け売りが慣習として残っている場合がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "掛け売りで商売が成り立つのは、信頼関係があるからこそだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "行商というといかにも原始的にきこえるけれども、見方によると、町の商店の営業と同じことで、御用聞きにまわって品物をおさめて掛け売りしているのと同じことだ。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "全国的に御用聞きにまわって掛け売りして、年に何回か代金を回収していると思えばよろしい。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「肉屋も掛け売りをことわって、もう肉をよこそうとしません。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
