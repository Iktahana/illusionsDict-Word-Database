[
  {
    "uuid": "b0d84c1a-023e-57ac-9ed6-b088a4dc08cd",
    "entry": "金儲け",
    "reading": {
      "primary": "かねもうけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
