          "standard": [
            {
              "text": "このホテルには、予約すればいつでも利用できる貸切風呂がいくつかある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "旅行の疲れを癒すために、夕食後に家族で貸切風呂を予約した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供連れだったので、周囲を気にせず入れる貸切風呂は本当に助かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "百合子は行く先々の地に着くと自炊などゝいふ考へは毛頭もなく、急に金持の婦人のやうに取り済して、貸切風呂がなくては居られないわ――そんな調子に変つた。",
              "citation": {
                "source": "好色夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
