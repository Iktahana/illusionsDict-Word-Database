    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to distinguish in writing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "報告書では、事実と意見を明確に書き分けることが重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は論文で複雑な概念を分かりやすく書き分けるのが得意だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "異なる読者層に向けて、文章のトーンを書き分けるスキルが求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そうしてその区別は普通の仮名（平仮名や片仮名）では書き分けることが出来ないのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば「こ」に当るものなら、「古」の類も「許」の類もどちらも「こ」にあたるので、両類の区別は普通の仮名で書き分けることが出来ないものであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、今の普通の仮名で書き分けることの出来ない十三の仮名がおのおの二類に分れているということは、奈良朝のものについて見ますと、前に述べたように多少例外があるのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "区別がなくなれば書き分ける必要もなく、一つでよい訳であります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場合に、一々の文字について、これはどの類に属するかを覚え、また語についてもこの語はどの類の字で書くべきかを一々記憶して、それで間違わないで書き分けるということは、それは殆ど不可能だと思われます。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから、その当時の人から見ると、こういう風に二類の仮名で「キ」を書き分けるということは、今の人が「カ」という音と「キ」という音を書き分けるのと同じことで、むしろ書き違える方が不思議であります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから問題になるのは、前にしばしば述べました、普通の仮名で書き分けることの出来ない音のことであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれにしても、もし今後私が少々人物を書き分けることができるとすれば、それは此の執拗を以て、辛いながらも人に接し、小胆なくせに無遠慮でもあるからなのです。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか筆が先へ滑ってごたごたしたが、実際私はこれから先をはっきりと書き分けるのに困難を感ずる。",
              "citation": {
                "source": "或る男の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　多年私は小説と童話を書いたが、いま頭の中で二つを書き分ける苦しさを感じて来ました。",
              "citation": {
                "source": "今後を童話作家に",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人びとの中に混って、一人の異様な紳士が――満身にすばらしい香水の匂いをプンプンさした紳士が、右手をスプリング・コートのポケットへ入れたまま、なにかひどく腑に落ちかねたような顔つきで、鼻をヒクヒクさせながら、人混みをかきわけるようにして、出口のほうへ歩いて行った。",
              "citation": {
                "source": "香水紳士",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「合点でござんす」　虎松は暗闇の中をかきわけるようにして韋駄天ばしりに駆けだした。",
              "citation": {
                "source": "くろがね天狗",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "肇は、今日始めて会った人の事について考え、　篤は自分のわきにぴったり座って居る肇の事を思い、電車は闇をかきわける様にしてつき進んだ。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とてもひどい人でね――あのひとをかきわけるだけでもいい加減くたびれるわ。",
              "citation": {
                "source": "鏡餅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かきわける藪のなかにおのずから出来る踏わけ路であった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は人だかりをかきわけるようにして出てきた。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚八とても目にアリアリと残っている情景、気色のいい時間ではないらしく、目をとじて、顔をふせたが、フシギや甚八の面色は土色に改まり、額に汗がうき、彼は握りしめた手をひらいて、急いで胸をかきわけるようにしたと思うと、前へのめって、畳をむしり、「ウッ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そういうぐあいに、丼や蓋物を持った面々が四列つなぎになって並んでいるのを、かきわけるようにして前へ泳ぎだし、番衆に押しもどされてすごすご後列へもどって行くが、すぐまた出てきて逆上したように、お氷を、お氷をとあえぐ、四十二三の浪人ていの男。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "氷献上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤマネ　なのでその三人の姉妹は、かきわける練習をしていました。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリス　かきわけるって何を？",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸でどうシロップをかきわけるの？",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子屋　プールでなら水をかきわける、シロップの井戸ならシロップをかきわける――当たり前だ、馬鹿者。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤマネ　もちろんせまい、だからそこそこに――三人は「お」で始まるものをかきわけるのです。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なのでその３人の姉妹は――かきわける練習をしていました、ほら……」「かきわけるって何を？",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「プールでなら水をかきわける。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「シロップの井戸ならシロップをかきわける――当たり前だ、バカ者。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「３人はかきわけるおけいこ中、」と続けるヤマネはあくびをして目をこすっていてね、どんどんねむくなっていたんだ、「いろんなものをかきわけます――『お』で始まるあらゆるものをかきわけるのです……」「どうして『お』なの？",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて若君は、肩のあたりに懸かる髪を、小さい手で前へかきわけると、静かに西に向って、手を合わせ念仏を称えて、首をさし伸べた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十二巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
