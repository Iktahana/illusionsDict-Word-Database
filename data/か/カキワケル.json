[
  {
    "uuid": "74d15d71-82c3-5583-8732-cfb0f6070a0c",
    "entry": "書き分ける",
    "reading": {
      "primary": "かきわける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
