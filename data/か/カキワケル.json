        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はキャラクターの表情を、喜びや悲しみなど細かく書き分けることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この画家は、人物の個性を巧みに書き分けることで有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鉛筆一本で様々な質感や陰影を書き分けるのは、熟練の技だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
