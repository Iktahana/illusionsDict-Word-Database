        "examples": {
          "standard": [
            {
              "text": "細胞がアポトーシスを起こす際、核崩壊のプロセスを経て断片化していく様子が観察された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "物理学の実験で、放射性同位体が核崩壊して別の元素に変わる時間を計測する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "顕微鏡で見ると、ダメージを受けた細胞の核が崩壊しているのがはっきりと分かるね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "核崩壊によって放出されるエネルギーを計算し、遮蔽材の厚さを決定する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "原子の蔵する勢力は殆んど全部原子核の中にあって、最近の物理学は原子核崩壊の研究にその主流が向いている。",
              "citation": {
                "source": "弓と鉄砲",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し笑話になるが、我が国でも今度の大戦中、或る方面で原子核崩壊の研究委員会が出来ていた。",
              "citation": {
                "source": "原子爆弾雑話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
