        "examples": {
          "standard": [
            {
              "text": "試合の前に、彼はライバルを睨みつけ、肩をいからせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「僕がやったんじゃない！」と叫びながら、少年は精一杯肩をいからせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "悪役は登場するなり、観客を威圧するように肩をいからせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "いずれ、手痛い目を見せてやる所存でいたが、そなたが、そう言うなら今晩、これからでも、乗り込んで、素ッ首を叩き斬ってやる」　と、肩をいからせると、お初が嘲笑って、「それだから、厭さ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、抜け出ることが出来ないといふよりも、反対に、もつともつと癩小説を書くぞ、とひそかに肩をいからせるのだ。",
              "citation": {
                "source": "柊の垣のうちから",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――変なばばあが、なにか、ぶつぶついってるぜ」　お杉婆は、いよいよ怒って、「今、笑うたのは、いったい誰じゃ」「みんなだよ」「なんじゃと」　ばばが肩をいからせる程、職人たちは笑っていた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
