        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は業界で顔が広く、多くの人とつながりがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "顔の広い人脈を持つことは、ビジネスで有利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は社交的で、イベントに行けば必ず顔の広い誰かに会う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "顔の広い先輩に相談したら、すぐに解決策が見つかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "会社で浅井のそんなに顔の広いことを、お増はお今などの前にも矜らしく思った。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "指環なども、顔の広い彼女は、何処かの宝玉屋から取って来て、見なれない品を不断にはめていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「深夜の市長」とは、そうした風に顔の広いため奉られた単純なる綽名なのであろうか、それとも何かもっと大きな実力を持っていて深夜のＴ市に於て、何か陰謀でもめぐらしている怪人物なのであろうか。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、台助に声をかけたのは、通りかかった芝居道に通じている、芸人の間を歩き廻る顔の広い男だった。",
              "citation": {
                "source": "市川九女八",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬徳坊の如き顔の広い親分の開堂する時は、外省の游民が船車でやって来て馬師を拝しその乾児実に万人余に及んだそうである。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれか顔の広い人物があったら、教示にあずかりたい」　　　　仇人　　　　　　一　吉田屋のお民が、お駒を、お目見得泥棒とののしって、席をけたてるようにしてかえっていったあとだ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしお武家さま、江戸で、顔の広いお方と申しましても、どういうお方でございましょうか。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭焼の倅の猪之松を上州から呼んで、資本を出して炭屋の店を持たせたり、顔の広いお秀が、いろいろ口をきいて御得意をふやしてやったり、ずいぶん恩になっていますよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "青い帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは好奇心から、ベリルという噂好きの顔の広い男に、ハッカー・ハーコート大佐の娘たちがどうなったか聞いてみたら、一人はボンド通りの婦人帽店、たしかマダム・マルメゾンのお店にいるという。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
