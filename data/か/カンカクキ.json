[
  {
    "uuid": "a7f4802d-cbac-5c4c-96e3-e7c0cb269c57",
    "entry": "感覚器",
    "reading": {
      "primary": "かんかくき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
