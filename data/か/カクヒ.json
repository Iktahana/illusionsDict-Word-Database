          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ネイルケアの基本は、まずお湯で角皮を柔らかくしてから丁寧に処理することだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "空気が乾燥する冬は、指先の角皮が硬くなったり、ささくれたりしやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "爪の根元にある薄い角皮を無理に剥がすと、そこから細菌が入って炎症を起こすことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "とにかくひどく坂になった。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなにどんどん行っちまわないでせっかくひとへ物を訊いたらしばらく返事を待っていたらいいじゃないか。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、おや、これは全体人だらうか象だらうかとにかくひどく肥ったもんだ。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくひとつとなりの方へ、弟子をお供に出しませう。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（９）　失業している夫　妻の身の自分が内職でもして家計を立てようとする努力とともに、失業状態にある夫の心は、とかくひがみ易くなっていますから、妻は平常より寧ろ夫を敬愛する態度に出でよ。",
              "citation": {
                "source": "良人教育十四種",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくひたざまに自由教育を善からずとするこの圧迫は如何。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い学者が研究論文を書くと、とかくひとり合点で説明を省略し過ぎて、人がよむとわかりにくいものにしてしまう場合が多い。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしたとえ古くさくとも、僕にとって新しいことが細かくひとつふたつはあるものなのだが、しかしあのおぼこ当人からは得るところがある。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、毒があっても、ほおずりしておいても、とにかくひきがえるが花になったのは、むすめのあたまやひたいや胸の上にのったおかげでした。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "野郎ども、だんなのおっしゃるとおり、手を引きな」　だんだら団兵衛とは名のるにもおこがましいような名まえだが、とにかくひざの下のやつも一人まえの親分とみえて、しかりつけたところを、得意の伝六がかたっぱしから数珠つなぎ――。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、もしも君子が、少からず無理な考え方だが、とにかくひとまず母親の房枝を殺したことにする。",
              "citation": {
                "source": "銀座幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくひどく神経が疲れてゐるし、魂はまだ号泣を続けてゐた。",
              "citation": {
                "source": "かげろふ断章",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだをうごかしているときには奥ふかくひそんでいて、ときどき蠢めくだけであったが、一度横になると襟首や袖口にぞろぞろと這い出してくるのだった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに長いあいだの問題が、とにかくひとまず解決を告げたので、いくらか頭も軽くなっていたから、息もつかずずんずん筆を着けて行くことが出来た。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとも金をもたない婦人民主クラブが、ともかくひとつの週刊紙を借金の上から送りだしつづけてゆくことは、楽なやりくりでありようなかった。",
              "citation": {
                "source": "その人の四年間",
                "author": "――婦人民主クラブの生い立ちと櫛田ふきさん――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに仕様のない奴だ」　彼はほんとに怒つたのか、ただしは藤枝の詰問を一時でものがれるために怒つたふりをしたのだか、ともかくひろ子に烈しく云つたのであつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからともかくひろ子だけでも危険から離しておくつもりだつたのだ」　彼はこう云つてちよつとだまつて私を妙な目つきでながめた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の世の中はとかくひかったものがちやほやされるだよ。",
              "citation": {
                "source": "どんづまり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋のなかできいてゐると、街の建物が石や煉瓦で建つてゐるせゐか、人聲や俥のベルの音がかんだかくひゞいてきこえた。",
              "citation": {
                "source": "秋果",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物が済むと、岩の中の食堂で、ひらめ学校の生徒は沢山御馳走になって、夕方ぢかくひらめ村へみんなで戻って来ました。",
              "citation": {
                "source": "ひらめの学校",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "信号旗がさっと旗艦の檣たかくひるがえった。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アア、そんなじゃないけどとにかくひまじゃないんだ」　男はたるんだ声で云ったのがふくれきって居た女の心をひやっこくスーッとなぜて行った。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "豪華船クイーン・メリー号も、ついに、このアトランタニアンのため、海底ふかくひきずりこまれたのであろう。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくだつてな、あのときは一升ぢかくひろつたぞ。",
              "citation": {
                "source": "栗ひろひ週間",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大フーフーで落語ではないが「えー人間、一心というほどおそろしいものはございません」　四時半頃ともかくひっくりかえして、自分もひっくりかえりそうにへばった。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「困った男だ」　かくひとりごちて、武男はまた千々岩の名刺を打ちながめぬ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういうわけで火星人がこんなところへはいり込んでいるのか、そのわけはわからないが、とにかくひとつ、あたってくだけろである。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
