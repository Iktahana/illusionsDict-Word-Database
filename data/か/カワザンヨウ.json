    "definitions": [
      {
        "index": 1,
        "gloss": "over-optimistic calculation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しいビジネスを始める前に、収益性の皮算用ばかりしてはいけない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はまだ契約も取れていないのに、売上目標達成後の皮算用で頭がいっぱいだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "企画が通るかどうかも不明な段階で、成功した後の皮算用をするのは時期尚早だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "成程皮を忘れてはならない、捕らぬ狸でも皮算用をする世の中に、飼つた狸の皮算用を忘れてはならない。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "原子兵器を全人類にとっての癌たらしめまいと奮闘する仕事を中傷するものがあるとすれば、それは、自分も死ぬことを知らないで、ほくそえみながら厖大な棺の注文を皮算用している棺桶屋ばかりである。",
              "citation": {
                "source": "私の信条",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "百圓も貯めて一生涯に一度位は父母を驚かしたいものだと、常次はとらぬ狸の皮算用ばかりしてゐる。",
              "citation": {
                "source": "玄關の手帖",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、周囲をたしかめてから、密談のような声で、「取らぬ狸の、皮算用かもしれんがね。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、おっ母さんや、まあたんと皮算用をしたけりゃしなさいだがね。",
              "citation": {
                "source": "真珠の首飾り",
                "author": "ZHEMCHUZHNOE OZHERELJE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、会社で皮算用している作品が、はずれたならばそのままでは済まなかったろうと思う。",
              "citation": {
                "source": "映画界・小言幸兵衛",
                "author": "―泥棒しても儲ければよいは困る※―",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃御府内にチヨイチヨイ贋金が現はれるんで、その犯人を擧げた者には、大層な御褒美を下さるといふ御觸れぢやありませんか」「なんだその事か、――そいつは取らぬ狸の皮算用だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "二枚の小判",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ御府内にチョイチョイ贋金が現れるんで、その犯人を挙げた者には、たいそうな御褒美を下さるという御触れじゃありませんか」「なんだその事か、――そいつは取らぬ狸の皮算用だ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二枚の小判",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前にも飛んだ苦勞をさせたから、松吉と世帶を持つ足しに三十兩やらう」「あれ親分さん、そんな事を」「あとの三十兩で八の野郎に女房を持たせると」「まア」「まだ四十兩殘るが、これはお靜と俺が湯治に行つて、溜めた店賃を拂つて、殘つたら大福餅の暴れ喰ひでもするか」「まア」「が、それも捕らぬ狸の皮算用だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "濡れた千兩箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち筆にも吹革にも向かず、いわゆる皮算用のできぬしろものである。",
              "citation": {
                "source": "狸とムジナ",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが又、当局が皮算用している程に痛快な大動揺も、なさそうだという噂さである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "順調な滑り出しに健一は気をよくして、このまま金が集まれば、いつごろ目標金額に達するか、早くも皮算用をはじめる有り様だった。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "とらぬ狸の皮算用ということはことに昨今全く論外ですから、一つ出れば、はァ出たかというようなものね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはまず三席はまちがいないと思う」「有難いが、低い声でたのむ」と、幹太郎は赤くなり、「取らぬなんとかの皮算用はよそう」と云った。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎も「捕らぬ狸の皮算用はよそう」といいながら、むろんそれを期待していた。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に捕らぬ狸の皮算用で見積りも設計も出来て居りますから、追って御覧に入れます。",
              "citation": {
                "source": "母校復興",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれから生れる馬を当てにするのは捕らぬ狸の皮算用に近い。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ取りもせぬ天下の皮算用などは止めにしよう。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
