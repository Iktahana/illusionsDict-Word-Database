        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "駅前でよく発生していた置き引きは、同じ犯人による掻っ払いだったと判明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜店の賑やかさに紛れて、財布の掻っ払いが横行しているという噂だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの店の万引きは、最近増えている小規模な掻っ払いの一種だと言えるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "掻っ払いじゃありませんよ。",
              "citation": {
                "source": "街底の熔鉱炉",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来で白昼掻っ払いを働く奴を東京では「昼とんび」と云った。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "カニは、木の葉吹き払い掻っ払い食えばあまりうまくなくもなえ申すと言い返した。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "この節のように、掻っ払いや小泥棒ばかり追っ掛け廻していた日にゃア腕が鈍って仕様がねえ」　ガラッ八の八五郎は、そんな事を言いながら、例の癖で自分の鼻ばかり気にしておりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "一枚の文銭",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃すっかり暇で、ろくな掻っ払いもないせいもあったでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五人男だ」　と、八百屋の御用聞きでまた掻っ払いの名人、チビの鼬は、英雄じみた昂奮でいった。",
              "citation": {
                "source": "雲霧閻魔帳",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそのなかに悲劇があるのだ、いいかい、アレクセイ、おれは卑しい堕落した煩悩をいだいた卑劣な人間かもしれないが、しかしドミトリイ・カラマゾフは泥棒や、掏摸や、掻っ払いには、断じてなり下がるはずがないだろう。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、今こそ聞いてくれ、おれは泥棒なんだ、掏摸なんだ、掻っ払いなんだ！",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃あの界隈を荒していた掻っ払いに我輩の人相が似ていたんだ」「ハッハヽヽ」「警察でも此奴に相違ないと言う。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "掻っ払いと間違えられたんだから、行くところまで行ったんだね。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つこうと思ったが、考え直したんだ」「斯ういうのが掻っ払いをやるんだろう」　と安達君は、用意していた丈けに隙がなかった。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、決して嫌ではないけれど、お光さんの手を突っ放すようにして、掻っ払いのように、あわてて、人混みの中へ駈けこんでしまった。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば捨て身になって、こっちから死に近づいて、死の油断を見すまして、かっぱらいのように生の一片をひったくって逃げて来なければならないのだ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、屑拾い小僧であり、板片のかっぱらいであった小さいゴーリキイを、かっぱらいの徒党のうちへつなぎきりにしなかった彼の天質の健全な力が、この場合にも一つの新しい疑問の形をとってその働きを現わした。",
              "citation": {
                "source": "マクシム・ゴーリキイの発展の特質",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本官は大分まえから、どうも彼奴は飲んだくれで、窃盗もやりかねない奴だとにらんでいましたが、つい一昨日のこと、ある店からボタンを一揃いかっぱらいましてね。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つの監房に二十何人かの男が詰っているがそれらはスリ、かっぱらい、無銭飲食、詐欺、ゆすりなどが主なのだ。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食べものなら、狩りをしたり、かっぱらいをすればいいんだからね。",
              "citation": {
                "source": "少年たち",
                "author": "МАЛЬЧИКИ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間自分のにせものが大阪にあらわれて宿やでかっぱらいして逃げたのですって。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "かっぱらいする女が自分のにせで通る、そこに何とも云えぬ皮肉を感じないのね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり彼はスリ、かっぱらい、其他類似の小悪事によって暮しを立てていたのである。",
              "citation": {
                "source": "江川蘭子",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "明智探偵はそれらの少年に、すりやかっぱらいをはたらかぬようによく教えて、「ありの町」という労働者の会の会長をやっている友だちにたのんで、そこに住みこませ、くずひろいなどをやらせてあるのです。",
              "citation": {
                "source": "魔法人形",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
