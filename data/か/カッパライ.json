        "examples": {
          "standard": [
            {
              "text": "あのスーパーで捕まった掻っ払いは、近所でも有名な常習犯だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お祭りの人混みの中では、巧みな手口の掻っ払いに注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "防犯カメラの映像から、カバンを盗んだ掻っ払いの顔が特定された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
