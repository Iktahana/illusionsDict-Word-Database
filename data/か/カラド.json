    "definitions": [
      {
        "index": 1,
        "gloss": "hinged door",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古い寺の山門には、重厚な唐戸が使われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの料亭の入り口の唐戸は、細やかな彫刻が施されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史的建造物の修理で、唐戸の蝶番（ちょうつがい）が新しくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "不意の驚きに気息を引いた子供が懸命になつて火のつくやうに「マヽ……マヽ……パヽ……もうしません……もうしないよう……」と泣き出した時には、彼はもう寝室の唐戸を足で蹴明けて廊下に出てゐた。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、右の其の盲人は、例の魔ものは、其の婦の影を、嘗めう、吸はう、捉へよう、蹂躙らう、取啖はうとつけ※す――此の儀を汝から託けて、氣を注けるやう言ひなさい、と申したのを、よくも聞かずに、黒雲を捲いて、飛んで行き、電のやうに、鐵の門、石の唐戸にも、遮らせず、眞赤な胸の炎で包んで、弱い婦に逢ひました。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下関へ着いたのは九時だつた、唐戸市場を見物する、どうしても行乞気分になれない、あちこち歩きまはるだけ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時、唐戸から船で大里へ、大里から荒生田まで電車、公園の入口でひよつこり星城子君にでくわす、よかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹塗の柱、花狭間、梁の波の紺青も、金色の竜も色さみしく、昼の月、茅を漏りて、唐戸に蝶の影さす光景、古き土佐絵の画面に似て、しかも名工の筆意に合い、眩ゆからぬが奥床しゅう、そぞろに尊く懐しい。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐格子、唐戸、桁、梁、※すものの此処彼処、巡拝の札の貼りつけてないのは殆どない。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はた迷える人は、緑の甍、朱の玉垣、金銀の柱、朱欄干、瑪瑙の階、花唐戸。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし、それとても朧気ながら、彼処なる本堂と、向って右の方に唐戸一枚隔てたる夫人堂の大なる御廚子の裡に、綾の几帳の蔭なりし、跪ける幼きものには、すらすらと丈高う、御髪の艶に星一ツ晃々と輝くや、ふと差覗くかとして、拝まれたまいぬ。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "正午、下関に渡り、映画見物はやめにして、唐戸から電車で長府の楽園地へ、一浴して一睡。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐戸で十銭の朝飯を詰め込み、ゆつくりとしかもがつしりと歩き出した。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋間の窓並びに唐戸の枠は蝦夷松、額ぶちはヌカセン、その天井板二十五種、腰羽目板二十二種は、以上に擧げた種類の外に、シナ、ナラ、シウリ、ヱンジユ、櫻、槲、朴の木、ドロ、山モミヂ、オヒヨウ楡、ハンの木、アサダ、サンチン、カタ杉、檜の木などだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄關のがらす唐戸を這入つた十疊敷きの室の横にある帳場の格子前で、義雄は渠と對坐して對談した。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲團蹴立てて起きあがり、それでも細帶を締め直してから、唐戸を排して氷峰の部屋へ行かうとすると、階段の手すりのところで、敷島の青い顏に出くわした。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐戸のような大きな障子が、すうーっとあいて、有明の行燈の中が、にわかにまたたきをはじめました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "比較的間口の広いその玄関の入口はことごとく細い格子で仕切られているだけで、唐戸だの扉だのの装飾はどこにも見られなかった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうした、吉田の法師は」「は」　何げなく主膳はさかいの唐戸を開けた。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "大儀だった主膳」　主膳は始終おもてを上げず、またそうっと、片手でさかいの唐戸を閉めた。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこからどこまで「青春」とか「若さ」とかいふ叙情的の印象がみなぎつてゐる。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の硬派の首領株の一人はその後｜人力車夫になったと聞いたが、それからどうなったか一度も巡り合わずそれきり消息を知ることが出来ない。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、ふだんからどうもこの雀を可愛がりすぎます。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論子音の排列分布もかなり大切ではあるが、日本語の特質の上からどうしても子音の役割は母音ほど重大とは考えられない。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八時頃からどこでもみんな戸を閉めて通りを一人も歩かない。",
              "citation": {
                "source": "うろこ雲",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋の天井にのぼった人たちは、器械の上の方からどんどん乾いた玉蜀黍をほうり込みました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの勇士達はこれからどこの国のどこの道の果てまで行くのであろうか。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにある室で何番目の窓からどの方向を見ると景色がいいという事を教えたのがあった。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたがお出でになったら、お話し申すつもりで、今日はお出でか明日はお出でかと、実は家中がお待ち申したのですからどうぞ……」　そう言われては僕も帰る訣にゆかず、母もそう言ったのに気がついて座敷へ上った。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一七―一八年の冬頃からどうも脚が冷えて困ると云ってこぼしていた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういう事が問題になっているのか、肝心の事は分らなかったが、何でも議長が何かをどうかして、それからどうとかすべきはずなのを、そうしなかったのが不都合だと云って攻撃しているようであった。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口もないのに、どこからどうして這入つて來るのか。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴吉、慌てて、　「まッお半さん、そんな訳だからどうか石松を怒らねえでやって呉れ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
