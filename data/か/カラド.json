[
  {
    "uuid": "f756cefc-ab71-58b5-9002-0d4d564d1265",
    "entry": "唐戸",
    "reading": {
      "primary": "からど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
