        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この木は、長い年月をかけて完全に化石化（ペトリフィケーション）しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "土砂に埋もれて、偶然にも化石（ペトリフィケーション）のプロセスが始まった例があります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "植物の化石（ペトリフィケーション）は、当時の植生を知る手がかりになります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
