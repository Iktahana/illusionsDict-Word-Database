[
  {
    "uuid": "43235d36-6d7e-5fb6-8992-96c85c9e3e12",
    "entry": "数知れない",
    "reading": {
      "primary": "かずしれない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
