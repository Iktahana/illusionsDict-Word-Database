        "examples": {
          "standard": [
            {
              "text": "電気分解の実験で、カソード側に金属が析出していく様子を観察した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「カソードとアノードを逆に繋ぐと、回路が壊れる可能性があるから注意して」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "真空管の中をカソードからアノードに向かって、目に見えない電子が飛び交っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "蓄電池の放電時には、カソード側で還元反応が起きている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それは「電気の実験研究」の第七篇になっているが、まずファラデーは電池の電極を、単に電流の入り口と出口に過ぎないからとて、アノード（昇り道）およびカソード（降り道）という名称をつけ、また液体内で分解している物に、アニオン（昇り行く物）およびカチオン（降り行く物）という名前をつけた。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
