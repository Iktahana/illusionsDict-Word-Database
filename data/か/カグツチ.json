        "examples": {
          "standard": [
            {
              "text": "日本神話によれば、軻遇突智は火の神として知られています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "イザナギが、火の神軻遇突智を生んだ際に、その熱さで亡くなったとされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "軻遇突智の誕生は、多くの神話で重要な転換点となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「軻遇突智の物語は、炎の力強さと恐ろしさを同時に描いているね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古代の祭祀では、軻遇突智の鎮火を願う儀式が行われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "かぐつちは目黒の寺に祟りして　　　長五郎坊主江戸を焼きけり　瀧泉寺には比翼塚以外に有名の墓があるが、これは比較的に知られていない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かぐつちは目黒の寺に祟りして長五郎坊主江戸を焼きけり　　　　　◇　滝泉寺には比翼塚以外に有名の墓があるが、これは比較的に知られていない。",
              "citation": {
                "source": "目黒の寺",
