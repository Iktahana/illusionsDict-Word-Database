        "examples": {
          "standard": [
            {
              "text": "木材の表面を紙やすりで丁寧に研磨したら、すべすべの手触りになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古くなったテーブルのニスを剥がすため、粗目の紙やすりで地道に削り始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "DIYで棚を作る際、切り口がささくれないように紙やすりで角を丸くする作業は欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "塗装の下準備として、細かい紙やすりで全体を軽くこすると、塗料の乗りが格段に良くなるんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一度男の荒い掌が｜そこにさわってなでると、彼女は丁度荒い男の掌という適度な紙やすりでこすられた象牙細工のように、濃やかに、滑らかに、デリカになる。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女にする男　その紙やすりである男の荒い掌になでられすぎた女を御覧、　こすりすぎた象牙の表面同様につやがぬけ、筋立ち、かさかさして居る。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは学校教師であり、家庭教師であり、測量士であり、植木職であり、農夫であり、ペンキ屋であり、大工であり、左官であり、日雇い人夫であり、鉛筆製造人であり、紙やすり製造人であり、文筆家であり、時にはへぼ詩人であります。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "訳者の言葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙やすりで、胸のどこかをさかさに撫でられたようで。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お櫃は箍をみがき、すしはんぼは紙やすりをかけた。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
