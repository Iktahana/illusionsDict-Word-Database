        "examples": {
          "standard": [
            {
              "text": "あの家具屋さんの主人は、腕の良い家具師らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、自分でデザインした家具を販売する家具師を目指している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "家具師に頼んで、オーダーメイドの棚を作ってもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "老舗の家具師が作る家具は、品質が保証されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "二十歳の時は一人前の家具師で、その仕事場が祖父の家とならんでいる。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家具師が持って来た寝台を、その天井のところから入れました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
