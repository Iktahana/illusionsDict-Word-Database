        "examples": {
          "standard": [
            {
              "text": "地域のお祭りで、下流社会の人々も楽しめるような企画を考えたんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "経済的な困難を抱える下流社会の人々への支援策が、もっと必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、下流社会のリアルな生活を描いた小説で賞をとった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「下流社会」という言葉は、聞く人によっては不快に感じるかもしれないから、使い方には気をつけよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ところが西洋の社会を見ると、日本とは反対に上流社会即ち紳士なる者は皆立派なる人たちであるが、下流社会即ち一般の人民は皆腐敗して居る。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "故をもって、下流社会はいうに及ばず、中等以上の人々まで大いに疑懼の念を抱き、百方これを避けんとするものがるるに道なく、ついに迷信の淵に沈むに至る。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "下流社会ではまた狐を信心することが盛で、狐を養った人が幸運によって金満家になったというような話が多い。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
