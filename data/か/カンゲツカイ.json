        "examples": {
          "standard": [
            {
              "text": "「あいにくの曇り空だけど、観月会のお弁当が豪華だから満足だわ」と参加者の女性たちが賑やかに笑っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "会社の親睦行事として、屋形船を貸し切って隅田川の川面から月を眺める観月会を開催することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "兼六園の観月会では、ライトアップされた木々と満月が池の面に映り込み、現実とは思えないほど幻想的な風景が広がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "観月会、――其中有楽。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に今宵は明月の下、皆の集った観月会ぞ。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規墓参それより月の俳句会わが墓参済むを静かに待てる人九月二十六日　観月会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
