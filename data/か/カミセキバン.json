        "examples": {
          "standard": [
            {
              "text": "祖父の遺品整理をしていたら、昔の学生が練習用に使っていたという古い紙石盤が出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "石盤の代わりとして普及した紙石盤は、当時の教育現場における工夫の跡を感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "博物館の展示室で、薄く黒塗りにされた紙石盤の表面に刻まれた、かつての子供たちの筆跡を眺める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "何本を買はねばならぬかとか、石盤は石石盤が可いか紙石盤が可いかとか、塗板も有たせねばならぬかとか、父兄は一人々々同じ様な事を繰返して訊く。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "何本を買はねばならぬかとか、石盤は石石盤が可いか紙石盤が可いかとか、塗板ももたせねばならぬかとか、父兄は一人々々同じ樣な事を繰返して訊く。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "米はあきらめて黙って紙石盤を出して来ると腹這いになって画をかき始めた。",
              "citation": {
                "source": "火",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外に〕　○宮、紙石盤にすっかり、負債の数字をかきその他準備して出て来ている。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            }
          ]
        }
