        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昨日から熱があって、顔色が悪いって周りから心配されてる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "徹夜明けの彼女は、化粧で隠しきれないほど顔色が悪い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「どうしたの？顔色悪いよ。大丈夫？」と声をかけられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "急な体調不良で、鏡を見たら自分の顔色の悪さに驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "お清はお源を見て「お源さん大変顔色が悪いね、どうか仕たの」「昨日から少し風邪を引たもんですから……」「用心なさいよ、それは不可い」　お徳は「お早う」と口早に挨拶したきり何も言わない、そしてお源が炭俵の並べてないのに気が着き顔色を変えて眼をぎょろぎょろさしているのを見て、にやり笑った。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴下は太くその顔色が悪いですね。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいへん顔色が悪いよ」と言いながら棚から薬の箱をおろしました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいへんお前の顔色が悪いよ。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那はどうかなさいましたか、顔色が悪いじゃありませんか」　丹治も今あんな目にあったから己の顔色が悪いだろうと思ったが、何か飲まないとゆっくりそれを話すことができなかった。",
              "citation": {
                "source": "怪人の眼",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんでもないの」「顔色が悪い」「なんでもないのよ」　紀久子はそう言って、すぐ起き上がった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、ばかに顔色が悪い。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉はどうしたの、どうして顔色が悪いの、と訊ねてきましたが、私はホテルで宝石泥棒があったからあわててるんだ、と答えました。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、顔色が悪いぞ、病気じゃないか」　彼は朝起きる時に苦しかったことを思いだした。",
              "citation": {
                "source": "雀が森の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとよ、お前どうかしたのかい、たいへん顔色が悪い」「ええどうもしやしません」「そうかい、そんならえいけど」　母は入れた茶を夫のと娘のと自分のと三つの茶碗についで配り、座についてその話を聞こうとしている。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分の顔色が悪いので、熊蔵も手持無沙汰で黙っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「少しは何か調べたか」「なんだか顔色が悪いぜ！",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "『君は大変顔色が悪いぢやないか。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "大変顔色が悪いなんて言はれる時でも、私は反つて気分の好いことが有るよ。",
              "citation": {
                "source": "燈火",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、お前何だか顔色が悪いようじゃないか。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "大そう顔色が悪いようですね。",
              "citation": {
                "source": "夢占",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一妙に顔色が悪い。",
              "citation": {
                "source": "おしの",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、よく来たね」「大へん御無沙汰いたしました」　岸本はすゝめられた座蒲団を敷きながら、「何だかお顔色が悪いじゃありませんか」「うん、君のいつか話した聖書泥棒だね。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あっ、主任、ひどく顔色が悪いじゃありませんか」「うん」　主任は眉をひそめながら答えた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔色が悪いぞ」「そうか、どうも心持ちがわるい」「そうだろう。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか顔色が悪いようだね。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は一層顔色が悪い。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大変顔色が悪い」「なに大丈夫。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうした大変顔色が悪いが」　と、姉小路卿は不思議そうに云った。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "親鸞　ほんに少し顔色が悪いね。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「顔色が悪いぢやないか。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
