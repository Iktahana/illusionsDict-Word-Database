        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "戦時中は、物資が不足し、多くの人々が粥腹で耐え忍ばなければならなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "節約のために、しばらくは豪華な食事を控え、粥腹で生活を立て直すことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "貧しかった時代、子供たちは「また粥腹か…」とため息をついたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "お粥腹のお姫様を饂飩で口説いて、八頭を見て泣いたって、まるでお精霊様の濡場のようだね。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、さすがに病床の粥腹では、日頃、日本のあらゆる現代作家を冷笑している高慢無礼の驕児も、その特異の才能の片鱗を、ちらと見せただけで、思案してまとめて置いたプランの三分の一も言い現わす事が出来ず、へたばってしまった。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "・人がゐてしぐれる柿をもいでゐた・庵のぐるりの曼珠沙華すつかり枯れた・つゆくさ実をもち落ちつかうとする夜はまた粥を煮て食べた、私には粥がふさはしいらしい、その粥腹で、たまつた仕事をだいぶ片付けた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お粥腹では力が出んなあ」　いつの間にか私の側には、大阪の罹災親爺が立つてゐるのだつた。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう枝元老人から手紙が来て（企画用紙送り来る）「この用紙を届けに行くべきながら、お粥腹で歩けないので、郵便にします」と断りの文句があった。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お粥腹を懐炉で助けつつ寒中を登山した記念としてここに掲げておく。",
              "citation": {
                "source": "周防石城山神籠石探検記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆　私あ、こんな年寄でいくらも食べやしないけど、此の食ひ盛りの子が、二日も三日も水の様なお粥腹でシヨビタレてゐるのを、私が黙つて見てゐられると思ふのかい？",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸い大した怪我もなかったのはめでたいが、大切な米をこぼして、槍を越す頃は二食にも足らぬ粥腹だった。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ持って来て皆天井の映るような粥腹でしょう。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼春の給仕のみで、すぐ粥腹に鎧を着込む。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "粥腹に温もった五体をよろいにつつむと、かえって、彼本来の面目とおちつきを持ち、そして、頼春や寺中の家士がそれぞれの腹拵えや身仕度をすますあいだ、独りあぐらをくんでゆったりと庭の朝霜に対していた。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
