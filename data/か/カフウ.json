        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "潮の香りが混じった家風が吹くと、決まって海辺の生家を思い出すんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "窓を開けると心地よい家風が入り込み、一人暮らしの寂しさを一瞬だけ忘れさせてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この家風が届く場所に、僕の帰るべき場所がある」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
