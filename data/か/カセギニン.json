    "definitions": [
      {
        "index": 1,
        "gloss": "breadwinner",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "村でも評判の稼ぎ人だった彼は、若くして自分の店を持つまでになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あそこの家のご主人は本当に稼ぎ人だねえ」と近所の人たちが噂している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "稼ぎ人として毎日朝から晩まで働き詰めだった父の背中を、今でも覚えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「妹はまだ子供ですし、稼ぎ人にいなくなられちゃあ、どうにもしようがないんです」「そりゃあ気の毒だね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから高岡へ還ってみると、その日から稼ぎ人というものがないのだ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも大事にして置かないと、院長は家中の稼ぎ人で、すっかり経済を引受けてるんだわ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は逗留客としての一面を生活し、同時に、出稼ぎ人としての滞在をしているのであった。",
              "citation": {
                "source": "機関車",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに勘定日の時間の速度などというものは、それは、受取ったためしのある稼ぎ人でなければ、分らない話である。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い時からずいぶん人を泣かせているから、年を取ってこうなるのは当り前だなんぞと言う人もありますけれど、なにしろ自分はよいよいになって、稼ぎ人のむすめに死なれたのですから、まったく気の毒ですよ。",
              "citation": {
                "source": "蜘蛛の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年になって、こんなからだになって、大事の稼ぎ人を殺されてしまって、あしたから生きて行くことが出来ねえ。",
              "citation": {
                "source": "蜘蛛の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "サックまで付けて今夜は只の十五銭……折れるの曲がるのという御心配のないメリケンスチールの精製品……ハイ只今――」　これだけの口上を聞けば、浅草に来る人々にバラック住居の稼ぎ人が多勢居ることがわかるであろう。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災後、東京市中到る処に軒並べて（法螺ではない）出来た安飲食店や弁当屋、カフェー等は彼等の唯一の慰安所でなければならぬが、そんな処でビールの満を引いたりしているのは大抵稼ぎ人風の男である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "稼ぎ人に逃げられたお幸は、桜井の屋敷から内々の扶助をうけていたとか云います。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、大事の稼ぎ人を殺したんですから、抱え主は気違いのようになって騒ぐ。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてもう小ひと月を送っているうちに、彼もだんだんに仕事に馴れて来て、朝に家を出て暮れ方に戻れば、きっと幾らかの銭を持って来るので、年をとった叔父や叔母はよい稼ぎ人の戻ったのを、むしろ喜んでいるくらいであった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さういつたやうな稼ぎ人や無頼漢どもが、道の出合ひがしらにこの頭でつかちを見て、小生意気にもいきなり飛びついてみたり、また細つこい毛臑でもつて力一杯蹴飛ばしてみたりするが、相手は平気なもので、身動き一つしようとしない。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房は世間並に一人あるが、醜婦で稼ぎ人で、加之に子供を生む事を知らないので、金は溜る一方であつたが、夫婦とも揃ひも揃つた吝嗇坊で、寄附事といつたら鐚銭一つでも出し惜みをした。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "学士は「ウン、高瀬君か」という顔付で、店頭の土間に居る稼ぎ人らしい内儀さんの側へ行った。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼んでおいた若い稼ぎ人が来て、道太の陣取っている離れの方から手をつけはじめて、午後には下の部屋へ及んできた。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "会葬したものは又一人も残らず若死したお民を惜しんだり、大事の稼ぎ人を失つた広次やお住を憐んだりした。",
              "citation": {
                "source": "一塊の土",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他出稼ぎ人である大工、職人、人夫の数は千名を突破している。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに立派な稼ぎ人もいた。",
              "citation": {
                "source": "三甚内",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそれから五年経った今日この頃はどうかというに、目星い稼ぎ人は影さえもない」　などと不平を云ったりした。",
              "citation": {
                "source": "三甚内",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の長家は稼ぎ人が多いゆえ、昼間の疲れで何処も彼もぐっすり寝入り、一際寂といたしました。",
              "citation": {
                "source": "西洋人情話英国孝子ジョージスミス之伝",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると其の隣りに明き樽買いの岩田屋久八と申し、此の人は年三十九歳になる独身もので稼ぎ人でございます。",
              "citation": {
                "source": "鹽原多助一代記",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "多助も稼ぎ人なれば互に睦まじく、毎日休む処が極って居ります。",
              "citation": {
                "source": "鹽原多助一代記",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "文ちゃんは稼ぎ人で、苦しい中から追々｜工面をよくし、古家ながら大きな家を建てゝ、其家から阿爺の葬式も出しました。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道の「鮭ずし」は元来新潟のもので（北海道は新潟人の出稼ぎ人が最も多く土着した）似たような「鮎ずし」もあり、海の魚も川の魚も美味だが、土地の魚は多くはとれないので一般用はよその魚かも知れない。",
              "citation": {
                "source": "諦めている子供たち",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼と同じ稼ぎ人が、彼と同じ目的のもとに、忍び込んでいるものと推量した。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お聞き及びでもござろうが、我ら北国の稼ぎ人には、『北国盗賊組合』と申す一つの組合がござるのじゃ。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「これは隙のないお尋ね、さすがは稼ぎ人の人丸殿じゃ。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
