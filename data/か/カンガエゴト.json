        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は窓の外を眺めながら、静かに考え事に耽っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "突然、彼が「そうだ！」と叫んだので、どんな考え事をしていたのか気になったよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、まるで迷路に入り込んだかのように、深い考え事をしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
