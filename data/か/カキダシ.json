        "examples": {
          "standard": [
            {
              "text": "遺産の分配について、相続人全員の同意を得て書き出しを作成した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "契約書には、両者の義務が明確に書き出しされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "紛争解決のため、お互いの主張を書き出しにして提出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
