    "definitions": [
      {
        "index": 1,
        "gloss": "beginning (of writing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "小説の書き出しで読者の心をつかむのは、至難の業だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "レポートの書き出しが決まらず、手が止まってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "詩の書き出しの一行が、全体の雰囲気を決めることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それで、手紙が書きたくなるたびに、沢山書くことがあるやうな気持なのですが、さて書き出してみると、何もないのです。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といふのがその書き出しである。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚子が小説を書き出した頃は、自分はもう一般に小説というものを読まなくなっていたので、随ってその作品も遺憾ながらほとんど読んでいない。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めの書き出しにはロマンチツクなしかも現実に即した人生行路の処々に置かれてある、眼に見ましく手にとらまほしき一篇の詩のやうには書き出しはしましたが…………。",
              "citation": {
                "source": "恋愛といふもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一字書き、一行進めては氣に入らなくなり、不滿になり、厭やになつたりして、私は幾度か原稿紙を引き裂き、幾度か書き出しの稿を改めずにはゐられなかつた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして書き出しの四五枚を漸くまとめ得たかと思ふ内に、いつか十月にはひつたが、努力の疲れとともに私の恐れてゐたものが體に迫つて來た。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は古の談話製造家が面白く書き出したもので、尤も多少の事実はあつたにした処が正確なことは解つて居らぬ。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして書き出してみると、先生の思い出はあとからあとから数限りもなく出て来るのであるが、この機会にはやはりこれくらいにして筆をおいたほうが適当であろうと思う。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」女は書き出しにかう書いてゐる。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "きちんと履物をそろえて書斎の中に端坐し、さて机の上の塵を払ってから、書き出したような作品に、もはや何の魅力があろう。",
              "citation": {
                "source": "土足のままの文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "題を決めるのに一日、構想を考えるのに一日、たのまれてから書き出すまでに二日しか費さなかったぐらいだから、安易な態度ではじめたのだが、八九回書き出してから、文化部長から、通俗小説に持って行こうとする調子が見えるのはいかん、調子を下すなと言われたので、決然として、この作品に全精力を打ちこむ覚悟をきめた。",
              "citation": {
                "source": "文学的饒舌",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "四「先斗町と書いてポント町と読むことは京都の人なら誰でも知っていようが、しかしなぜ先斗町――四条大橋の西の袂を北へ入った路地を、ポント町というのか、知っている人はすくないだろう……」　小田策之助はちぎり家の別館で、「それでも私は行く」の第一回目の書き出しを書いていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、あわて者を主人公にした小説を書き出した。",
              "citation": {
                "source": "経験派",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな、書き出しが、うまい。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き出しの巧いというのは、その作者の「親切」であります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎外自身の小説だって、みんな書き出しが巧いですものね。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つ、三つ、この第十六巻から、巧い書き出しを拾ってみましょう。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十余篇、全部の書き出しを、いま、ここに並べてみたいほどです。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上、でたらめに本をひらいて、行きあたりばったり、その書き出しの一行だけを、順序不同に並べてみましたが、どうです。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "物語を創るなら、せめて、これくらいの書き出しから説き起してみたいものですね。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「女の決闘」という小説の書き出しはどんなであったでしょうか。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふところ手をして、おめえに知らせてあげようか、とでもいうようなたいへん思いあがった書き出しでありました。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、あくる日女中が、灰をかきだしますと、兵隊はちいさなすずのハート形になっていました。",
              "citation": {
                "source": "しっかり者のすずの兵隊",
                "author": "DEN STANDHAFTIGE TINSOLDAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご免をこうむってちょっと一休みいたしましょう」　こう言って長十郎は起って居間にはいったが、すぐに部屋の真ん中に転がって、鼾をかきだした。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎は、よし子が絵のつづきをかきだしてから、問答がたいへん楽になった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今かきだしたばかりだのに」「なぜよけいな事をおっしゃる」と女は正面に帰った。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里へ出てからは十九歳の裁縫女として十二時間労働をし、そのひどい生活からやがて眼を悪くして後、彼女は自家で生計のための仕立ものをしながらその屋根裏の小部屋の抽斗の中にかくして、「ただ自分一人のために」小説をかきだした。",
              "citation": {
                "source": "知性の開眼",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼾までもかきだした不行儀な女もあった。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり酔ひ潰れた哥薩克はゆきあたりばつたりにところきらはず身を横たへて、キエフ全市に轟ろき渡るやうな大鼾きをかきだした始末である。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "大時計の仕掛はこうなっている……」　と、怪囚人は、鉄の壁へ、釘の折れで、大時計の図をかきだした。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
