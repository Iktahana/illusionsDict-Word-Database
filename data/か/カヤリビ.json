    "definitions": [
      {
        "index": 1,
        "gloss": "smoky fire to repel mosquitoes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夕食後、庭で蚊遣り火を焚き、家族で団欒を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "蚊遣り火の煙が、ゆらゆらと夜空に立ち昇っていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「蚊遣り火の匂いって、夏って感じがするね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "風のない穏やかな夜は、蚊遣り火の煙が原地にとどまりやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "目の先に見える屋根の間からは、炊煙だか、蚊遣り火だかがうっすらと水のように澄みわたった空に消えて行く。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊はもう夕暮れには軒に音を立てるほど集まって来て、夜は蚊遣り火の煙が家々からなびいた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "団扇使いは御寝の妨げと差控え、その代り名香をふんだんに、蚊遣り火の如く焚くのは怠らなかった。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "――成信はいつもの癖で、蚊遣り火を焚きながら、燈火をひき寄せて夜半すぎまで本を読んだ。",
              "citation": {
                "source": "泥棒と若殿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
