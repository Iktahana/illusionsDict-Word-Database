        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「よし、このレア武器さえ装備すれば、次のギルド戦は確実に勝つるぞ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "劣勢だった試合でエースが逆転ホームランを放ち、ベンチ裏で「これで勝つる…！」と確信した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "試験の予想問題が的中しているのを見て、心の中で「これは勝つる」とガッツポーズをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いつのまにかつるが負けてはち切れてしまったが、つるのからんだ痕跡だけは、いつまでもちゃんと消えずに残っている。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その提燈は何人かつるしてある釘から除ったように、燈の点いたなりにふわふわと下へ落ちて来た。",
              "citation": {
                "source": "岐阜提燈",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんなもご存じでしょうが、ふとん蒸し、水責め、さかつるし、罪人どうしの間で刃物を使わねえ人殺しは、これまでもちょくちょくねえわけじゃねえんです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝六のいうとおり、平牢の、それもおおぜい投げ込み牢の中では、牢つきあいの悪い者、牢名主にさからった者なぞは、深夜、さかつるし、水責め、あるいはまたふとん蒸しなぞの牢成敗に出会って、囚人が囚人に殺される例はままあることでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると此時迄隅の方に三人かたまつて、何かつる／＼、ちゆ／＼食つてた連中が、ひとしくおれの方を見た。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとこの時まで隅の方に三人かたまって、何かつるつる、ちゅうちゅう食ってた連中が、ひとしくおれの方を見た。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドライバーは、何遍かつるりと滑った。",
              "citation": {
                "source": "もくねじ",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "棒から、いつのまにかつるは、からたちの木に登っていました。",
              "citation": {
                "source": "へちまの水",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇野の名も言つてゐたから、芥川と宇野がなにかつる助に冗談を言つてゐたことがあるのだらう。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
