        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "台所で料理をする時は、袖が汚れないように割烹着を着ることにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "母が着ていた花柄の割烹着姿が、今でも懐かしく思い出される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "給食のおばさんは、いつも清潔な白い割烹着を着ていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "美術の授業で絵を描く時、服が汚れないように割烹着を持参した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "やがて最初に目に入つた玉屋に這入ると、部屋は明るくガランとしてゐて、温室のやうだつた、客の腰掛場になつてゐる、畳二枚を縦に並べた場所の、その中程に置かれた火鉢には其処の主人が如何にも睡げによつかゝつてをり、お主婦さんも割烹着を着たまゝ火鉢で手をぬくめてゐた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "割烹着の胃に当る辺りが濡れてゐるところを見ると、今の今まで茶碗でも洗つてゐたという風だ。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、妻は割烹着のポケットのなかに、いろんな書きつけなどと一緒に入れてゐたのだが、何処へやったのかもう憶ひ出せなかった。",
              "citation": {
                "source": "棉の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理方の人達はいずれも白い割烹着に手を通して威勢よく働き始めた。",
              "citation": {
                "source": "食堂",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "釜の向うでワンタンを鉢にうつしていた白い割烹着にレースの布を捲いた娘がチラリと一瞥を送って「いらっしゃい」と声をかけた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それに銀三さんのことだから、御飯ごしらえから子供の守りまで、ひとりで立ちまわってさ、割烹着なんかきて市場へ買い出しに行ったりしてさ。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スカートと柔かいジャケツの上から割烹着をつけ、そこに膝ついているひろ子の体や、あっち向で何かしているタミノの無頓着な後つきをじろり、じろり眺めて、ねばって行った。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地に馴れない者らしく、そして不知案内な顔つきで一寸佇んでいたひろ子は、ふっと思いついたという調子で、そこに草箒をつかっている割烹着のお神さんに声をかけた。",
              "citation": {
                "source": "日々の映り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――若いもんはいいねえ」　薄赤い、むっちりした手が水の滴をたらしながら襦袢をしぼり上げるところを見ていたが、引込んだと思うと、「ちょいと、すまないけど、これもついでにザブザブとやっといて下さいな」　焼杉の水穿きをつっかけて、自分の水色格子の、割烹着をもって来た。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九にしては大ぶりな体つきのおしもは、ぼってりと盛りあがった乳房が割烹着の上からあらわな形をみせて、それが、俯向いて息忙しく雑巾がけなどをするたびに、ブリブリとゆれてみえる。",
              "citation": {
                "source": "女心拾遺",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "割烹着の細かな花模様の赤と黄と青とが、ちかちかと眼を刺激した。",
              "citation": {
                "source": "変る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "若々しいきゃしゃな身体つき、ういういしい尖った※、捉え難い黒目、それらがぼやっとぼやけて、割烹着の花模様の青と黄と赤とがちらちらした。",
              "citation": {
                "source": "変る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "背の高い中国人の給仕が、うす汚れの割烹着をつけて、流暢な日本語をしゃべった。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "待つほどに、ガチャン／＼と奥の方からいくつも錠をあけたてする音が近づいてきて、やがて、和服の上に割烹着のやうな白いものをつけ、左の手にバイブルをぶらさげた看護人を先登にして疑惑の中の怪人物が現れてきた。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "和服の上に割烹着のやうな白いものをつけ左の手にバイブルをぶらさげた御人はまさしく木菟の先生であつた。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原の端にある高い築堤の上で、白い割烹着を着た女が、口に手をあてて何か叫んでゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きりつとした割烹着の姿は彼女の伸びやかな身体の特長をよく現はしてゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、それどころではない、今そこに立つてゐる盛子、白い割烹着に包まれ、すらりとした伸びやかな身体までが、その微笑してゐる切れの長い眼つき、悪戯つぽさと羞みとのまざり合つてゐる様子だの、そのすべてが、何かしら微妙な、手で触れにくい、不思議な物として見えたのだつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに対して、笠間由子は、物々しく割烹着を着こんで、飛び跳ねる世津子を、後から抱きかかへるやうに引き寄せ、立つたまま、「お帰りなさいませ」　と、誰よりもはつきり云つた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（割烹着を家政婦に渡し、机の前に坐る）あと、ハンケチだけでせう。",
              "citation": {
                "source": "驟雨（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "お徳の白い割烹着も、見慣れるうちにそうおかしくなくなった。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて割烹着の女や通りがかりの人がばたばた馳け出す。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ僕もあと三十年もしたら浴衣がけで芸談一席と洒落る気になるかも知れないが、今のところはこの不細工な割烹着を脱ぐつもりはない。",
              "citation": {
                "source": "飜訳のむずかしさ",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしは、テンピの中と調理台の上を手早く掃除すると、少年に白い割烹着を着せ、ハンカチでコックさんの帽子をつくって冠せてやりました。",
              "citation": {
                "source": "キャラコさん",
                "author": "月光曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の割烹着が生れるまでに我々はまだ色々の試みをして居る。",
              "citation": {
                "source": "服裝語彙分類案",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まア、まア、お嬢様」　そう言って迎えてくれた中年の夫人は、昨年猫間ヶ淵で死んだ潜水夫の配偶で、お高さんという――、白い割烹着に、引詰めた束髪といった、思いの外東京風の女です。",
              "citation": {
                "source": "水中の宮殿",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　和服の上に割烹着をひっかけた朝倉夫人が廊下の窓から顔をのぞかせ、不審そうにそう言ったが、「ご飯はこちらでいただきましょうね。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "むつかしい顔の和服の進の父や、親戚や、似合わない新品の割烹着をつけたばあやなどが、佐藤と話していた。",
              "citation": {
                "source": "演技の果て",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い割烹着のばあやが、棺の置かれている部屋の廊下に立ち、口をあけてそれを眺めていた。",
              "citation": {
                "source": "演技の果て",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
