        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「おっ、カネヒラが釣れた！この時期の婚姻色は、淡水魚とは思えないほど鮮やかだな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「水槽の中でカネヒラが二枚貝に卵を産み付ける様子を、じっと観察している。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「カネヒラはタナゴの仲間でも大型になる種類だから、見応えがあって飼育も楽しいよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "小さい太郎は、いちばんはじめに、いちばん近くの、くわ畑の中の金平ちゃんの家へいきました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "金平ちゃんの家には、しちめんちょうを二わかっていて、どうかすると、庭に出してあることがありました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい太郎はそれがこわいので、庭まではいっていかないで、いけがきのこちらから中をのぞきながら、「金平ちゃん、金平ちゃん。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "金平ちゃんにだけ聞こえればよかったからです。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなか金平ちゃんに聞こえないので、小さい太郎は、なんどもくりかえしてよばねばなりませんでした。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、とうとう、うちの中から、「金平はのォ。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "金平ちゃんのおとうさんのねむそうな声でした。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「金平は、よんべから腹がいとうてのォ、ねておるのだで、きょうはいっしょに遊べんぜェ。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、またあしたになって、金平ちゃんのおなかがなおれば、いっしょに遊べるからいいと思いました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林金平の妾おきぬが璃鶴と私通し、遂に金平を毒殺するに至りしより、おきぬは死罪、璃鶴は連坐の刑に問われしなり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい太郎は、いちばんはじめに、いちばん近くの、桑畑の中の金平ちやんの家へ行きました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "金平ちやんの家には七面鳥を二羽飼つてゐて、どうかすると、庭に出してあることがありました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい太郎はそれがこはいので、庭まではいつていかないで、いけがきのこちらからなかをのぞきながら、「金平ちやん、金平ちやん。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "金平ちやんにだけ聞えればよかつたからです。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなか金平ちやんに聞えないので、小さい太郎は、なんどもくりかへして呼ばねばなりませんでした。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、とうとううちの中から、「金平はのオ。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "金平ちやんのお父さんの眠さうな声でした。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「金平はよんべから腹が痛うてのオ、寝てをるだで、今日はいつしよに遊べんぜェ。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、またあしたになつて、金平ちやんのお腹がなほれば、いつしよに遊べるからいいと思ひました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、あなたのお弁当のおかずは卵焼きと金平牛蒡で、私の持って来たお弁当のおかずは、筋子の粕漬と、玉葱の煮たのでした。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、私の粕漬の筋子を食べたいと言って、私に卵焼きと金平牛蒡をよこして、そうして私の筋子と玉葱の煮たのを、あなたが食べてしまいました。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もあなたの卵焼きと金平牛蒡を食べて、なんだかもうこれで、私たち二人の血がかよい合ったような気が致しました。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい太郎は、いちばんはじめに、いちばん近くの、桑畑の中の金平ちゃんの家へゆきました。",
              "citation": {
                "source": "小さい太郎の悲しみ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "金平ちゃんの家には七面鳥を二｜羽かっていて、どうかすると、庭に出してあることがありました。",
              "citation": {
                "source": "小さい太郎の悲しみ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい太郎はそれがこわいので、庭まではいってゆかないで、いけがきのこちらからなかをのぞきながら、「金平ちゃん、金平ちゃん」と小さい声でよびました。",
              "citation": {
                "source": "小さい太郎の悲しみ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
