        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その新製品が持つ革新的な機能には、業界全体が刮眼して今後の動向を見守っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の短期間での目覚ましい成長ぶりには、かつての厳しい指導官も刮眼せざるを得なかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "今回の判決が今後の司法制度に与える影響について、憲法学者たちは刮眼して注視している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "秀吉、家康の上に出ずるところに刮眼することを祈る。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんど手取り足取りにかつがんばかり……。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
