[
  {
    "uuid": "36afe581-f85b-549c-9ce4-9ba362c6ae02",
    "entry": "活眼",
    "reading": {
      "primary": "かつがん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
