    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cold, strong, dry wind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "冬の北風は、まさに身を切るような空っ風だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "群馬県では、冬になると赤城おろしと呼ばれる強い空っ風が吹く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "空っ風が吹き荒れる中、洗濯物はあっという間に乾いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「何をしに自分は来たのだ」　街へ出ると吹き通る空っ風がもう人足を疎らにしていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべから吹きつづく空っ風に鼻先を赤くしながら、あの金兵衛がまた駈け込んで来た。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二、三年はまことに忌な年だったと言い暮らしているうち、暦はことしと改まって、元日から空っ風の吹く寒い日がつづいた。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たい空っ風が吹いて、外套も着ていない私には寒さがしみじみと身にしみました。",
              "citation": {
                "source": "悪魔の聖壇",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "積もるほども降りませんが、なにしろ名物の空っ風で……。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は日曜日で、空っ風の吹く寒い日であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京要塞海野十三-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）空っ風｜：ルビの付く文字列の始まりを特定する記号（例）築地｜夜話であった。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "：入力者注　主に外字の説明や、傍点の位置の指定（例）ふのりは使わず、-------------------------------------------------------　　　非常警戒　凍りつくような空っ風が、鋪道の上をひゅーんというような唸り声をあげて滑ってゆく。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは天気も好し、あんまり空っ風も吹かねえから、十万坪の方まで附き合わねえか」「十万坪……」と庄太は妙な顔をした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　あくる二十八日の朝は空っ風が吹いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三河万歳",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝からの空っ風が白い砂けむりを吹き巻いている広徳寺前をうろついて、ようように香具師の富蔵の家を探しあてた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三河万歳",
                "note": "青空文庫"
              }
            },
            {
              "text": "名物の空っ風が、ぴゅうっ、ぴゅうっ、ねえ、朝起きてみると、白いものが地面に下りて、霜だ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二八年一月十二日木曜日の朝のことで、雪を孕んだ空っ風が米国ミシガン州マウント・モウリスの町を吹き捲り、地面には薄氷が張っていた。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "空っ風がひどくその町を吹きまくった。",
              "citation": {
                "source": "朝の風",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "空っ風に、鼻を赤くして、のりの悪い白粉を厚くつけた女が、町中を走り歩いた。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "折柄、上州名物の空っ風が吹きすさんで、火は八方にひろがった。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "空っ風が強くて、黄色な砂塵が揚っていた。",
              "citation": {
                "source": "越後の冬",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「桂文楽」一枚看板の灯はとうに消されていたが、ひどい空っ風に吹き曝されて夜目にも仄白く見えるその行燈は、カタカタ寂しい音立てて揺れていた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あの空っ風の晩の「桂文楽」と筆太にしたためた宮志多亭の招き行燈が、目にアリアリと蘇ってきた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの晩、空っ風に吹かれたまま、いつまでもいつまでも去りやらず睨んでいた招き行燈の中へ、今こそ「三遊亭圓朝」の五文字を筆に書き入れさせるときがきた、そうしてあかあかとその字を灯の中へ浮きださせてやるときが――。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "粘土だ、水だ、空っ風だ、野菜もなけりゃ果物もねえ。",
              "citation": {
                "source": "追放されて",
                "author": "В　ССЫЛКЕ",
                "note": "青空文庫"
              }
            },
            {
              "text": "着のみ着のままの私は上州の空っ風の中の下宿に、ひと月ほど滞在した。",
              "citation": {
                "source": "わが愛する詩人の伝記（三）",
                "author": "――萩原朔太郎――",
                "note": "青空文庫"
              }
            },
            {
              "text": "永いようで短い冬は、事の起りそうで事の起らない自分の前に、時雨、霜解、空っ風……と既定の日程を平凡に繰り返して、かように去ったのである。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところは常陸の国、空っ風でお馴染みの筑波の山は天狗党の一揆が大変じゃ大変じゃ！",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葱の青さ、抜き捨てた大根の白さなど、ところどころに色彩の変化はありますが、だいたいは霜解と空っ風に荒された畑地で、歩くと不気味な足跡が一つ一つ印されるような土地です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "凧の糸目",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来の人も殆んど絶えて、僅に終電車の音が遠く唸るばかり、夜と共に起った空っ風が、巷の埃を濛々と吹き起して、車の外は面を向けられそうもありません。",
              "citation": {
                "source": "青い眼鏡",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから何時間経ったでしょう、水の黒さが身にしむばかり、人足も大分途絶えて、名物の空っ風、花を散らした名残りを吹いて、サッと橋の上の砂塵を吹きあげる頃でした。",
              "citation": {
                "source": "悪人の娘",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう戌刻（八時）過ぎ、夕方から吹き始めた名物の空っ風に、頬も鼻も、千切れて飛びそうな寒さですが、平次の探求心はかえって火のごとく燃えさかります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "兵糧丸秘聞",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
