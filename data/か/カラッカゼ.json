[
  {
    "uuid": "d58758ef-ece6-5fd9-8b67-cd897876c7a6",
    "entry": "空っ風",
    "reading": {
      "primary": "からっかぜ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
