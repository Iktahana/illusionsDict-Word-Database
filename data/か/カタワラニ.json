[
  {
    "uuid": "e05f1bb1-de45-5510-8308-0227148027f6",
    "entry": "傍らに",
    "reading": {
      "primary": "かたわらに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
