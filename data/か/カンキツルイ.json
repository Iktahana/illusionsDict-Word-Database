        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ビタミンCたっぷりだから、風邪予防には柑橘類を積極的に摂りたいわ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この時期は、不知火（デコポン）とか、甘夏とか、美味しい柑橘類がたくさん出回るから嬉しい！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "サラダにオレンジやグレープフルーツを加えると、彩りも味も豊かになるんだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あー、この酸っぱさがたまらない！やっぱり柑橘類って最高！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "私の登った北米のフッド火山は、大なる氷河が幾筋となく山頂から流れているにもかかわらず、麓の高原は乾き切って、砂埃とゴロタ石の間に栽培した柑橘類の樹木が、疎らに立っているばかり。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "細かく風にそよぐ竹藪、蒼々とした杉木立、柑橘類、大島椿。",
              "citation": {
                "source": "湯ヶ島の数日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柑橘類でも熱い土地の産は肉も袋も総て柔かでかつ甘味が多い。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにその中間の地（たとへば東海道南海道など）で出来るものは柑橘類でも比較的堅くしまつて居るところがあつて、液が多量にあり、しかもその液には酸味が多い。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭には柑橘類が黄いろく実り、軒下には大根の干してある百姓家を写生したのが一枚、鉢に入れた林檎の静物が一枚、自画像が一枚、これがその時私の描いたもので、後にも先にも私の描いた油絵といへば、一生のうち此の三枚があるだけである。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り、マンゴーや柑橘類が季節的であるのに反して、パパイヤだけは一年中常に結実する。",
              "citation": {
                "source": "台湾の姿態",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの庭園には、大粒な黄いろい果實を簇がらせた柑橘類や紅い花をつけた山茶花などが植つてゐたが、それらが曇つた空と、草いろの鎧扉と、不思議によく調和してゐて、言ひやうもなく美しいのだ。",
              "citation": {
                "source": "旅の繪",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺碧の空、軟い錆金色の草山、色づいたまま散らない蔓類の葉、細い竹やぶ、杉、柑橘類、大島椿の白い幹。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒国である私の故郷は、柑橘類に恵まれていなかった。",
              "citation": {
                "source": "姫柚子の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "たわわに柑橘類のみのった山裾をいい香りをかいで歩きながら、ああこれも古墳のあとかなと考え出すのは、どうもね。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの庭園には、大粒な黄いろい果実を簇がらせた柑橘類や紅い花をつけた山茶花などが植わっていたが、それらが曇った空と、草いろの鎧扉と、不思議によく調和していて、言いようもなく美しいのだ。",
              "citation": {
                "source": "旅の絵",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "柑橘類の咲きみのる南方の山国であつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "柑橘類のみのる下を葬列が通る。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、私の経験によると、林檎のようなもの、レモンのような柑橘類の少し熟したものを食べると、声のよく出ることがある。",
              "citation": {
                "source": "声と食物",
                "author": "宮城道雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻さしあげた「民族と歴史」の中にも書いてあります通り、枳殻や、柚子や、橙や、いろいろの柑橘類が、みな温州蜜柑の接木によって、ことごとく温州蜜柑になってしまっているのです。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレンジとそれに類似のもの、すなわち柑橘類は沢山あるが、日本の蜜柑のようなものはあまり見当らない。",
              "citation": {
                "source": "果物の天国",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "低い山畑に揉みついたように熟れている柑橘類の烈しい芳醇な匂いに沁みた新しい空気や、そこを馳け廻る少女の姿などを描いて見たりした。",
              "citation": {
                "source": "或る少女の死まで",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "島へ降りれば一面のレモン畑、ということはなく、適当に見当をつけて歩きはじめると、様々の柑橘類の低木が現れるのだが、彼にはそれらの区別がつかない。",
              "citation": {
                "source": "鉄道模型の夜",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の蹄鉄でも、馬車の軸でも、柑橘類の剪取に使うハサミでも、清七は、馬鹿叮嚀に念を入れるので、よその鍛冶屋のよりは、数等堅牢で永持ちがした。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンドの研究は、しばしば柑橘類が壊血病の治療や予防への有効性を示したこととして記載されている。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "柑橘類のジュースはその酸性によって治療効果を持っているので、硫酸（使用前に薄める！",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンドは、皮膚にある汗の穴は海の空気によって詰まるので毒は外に出ることができなくなって貯まると考え、柑橘類の果物は“石鹸のように希薄化し分解する作用”（洗剤作用）を持っているので穴の通りを良くすると信じていた。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "オーストラリアの研究では、15g/dの柑橘類ペクチン（いわゆる“水溶性繊維”）は緩下剤の作用は無いが血漿コレステロールを13%低下させたが、セルロースは緩下剤の効果しか無かった（160）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "柑橘類の香りが蝋のなかに加えてある。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
