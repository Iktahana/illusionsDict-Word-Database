        "examples": {
          "standard": [
            {
              "text": "秋も深まり、山には枯れ尾花が揺れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "寂れた田舎道に、枯れ尾花が寂しげに立っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの山の斜面、枯れ尾花が風に揺れて、なんとも言えない切ない光景だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "アハハハ……幽霊の正体見たり枯れ尾花とはまさにこのこと、これなる扇子と懐紙入れがあの一カ所から離れなかったのも、かしこの水がうずというほどのうずでないうずを巻いているため、水もろとも穴の底に引きつけられて、ぐるぐるあのまわりを漂っていたに相違ござりませぬ」「いかさまのう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときようやく正体が分かったが、分かってみれば、枯れ尾花にあらずして普通の人間である。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "諺に「幽霊の正体見たり枯れ尾花」とあるごとく、つまらぬものを見てただちに天狗なりと思うものである。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、俗に雪隠の化け物、舟幽霊、雪女等の怪談あれども、これらはみな幻視、妄覚より起こりたるものにして、諺に「幽霊の正体見たり枯れ尾花」の類なれば、説明するに及ばぬ。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　枯れ尾花のように、毛の光る狐だった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ出ると、所々の人家のきれめに、枯れ尾花のくぼ地や、草鞋を売る店や、駄賃馬の往来などが頻繁なので、あたりは急にひなびて見える。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯れ尾花に、風がつよい。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
