    "definitions": [
      {
        "index": 1,
        "gloss": "steering (a boat)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "嵐の中、船長は必死に舵取りを続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初心者でも簡単にできるように、このボートは自動舵取り機能を搭載している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ヨットの舵取りは風を読む技術が重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "此方が手遊びに拵える、五位鷺の船頭は、翼で舵取り、嘴で漕いで、水の中で火を吐くとな………』『天守の上から御覧なされ、太夫ほんの前芸にござります、ヘツヘツヘツ』とチヨンと頭を下げて揉手を為て言ふ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "販売政策の舵取りによって、普及の足どりは多少変わるにしても、今後、参考図書の電子化は確実に進みます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳敷きにはできない形ではあるが、それをその面積に換えれば六畳ぐらいは敷けるだろうと思われる「おもて」には、上下二段にベッドを作りつけて、水夫長、大工、舵取りを除いた、水夫五人と、おもてのコックが一人と、ストキとが寝るようにできていて、その中央に、テーブルと、ベンチとが作りつけてあった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "この漕ぎ手に白羽の矢が立ったのは、鰹船で鍛え上げた三上と、舵取りの小倉とであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "西沢と波田とは、ブリッジに上がって、小倉の舵取りを見学していた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ボーイ長はどうしよう、という相談が水夫らと、四人の舵取りの間に行なわれた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "金は五人の水夫と、四人の舵取りと、一人の大工とで二円ずつ出せば、二十円あるから、それで、もし必要ならば入院させて、「とも」で入費を持たないというようなことであったら、おもてで持とう。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それはいいだろう」で、本部は三畳敷きに足りない舵取りの室を第一の候補地にした。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまで緊密なパートナーシップを保って日本市場の開拓に協力してきた電子デバイス事業グループとの関係に、日本電気の新しいグループの参入が間違いなく影響を与える以上、今後の舵取りにあたって考慮すべき点は出てくるだろう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっぽう、忠義者のヨハネスは舵取りのところにのこっていて、船を陸からはなすようにいいつけました。",
              "citation": {
                "source": "忠義者のヨハネス",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく海棲だと思われるのに翼構造が存在するとは謎めいているが、水中での舵取り機構か。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから先はしっかりせい国の舵取りゃあぶないぞやめたらどうぞい。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご不興の風でも吹かれては困るし、やれ舵取りはなかなか難しいわい。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも可能なら賢い舵取りは船を嵐には曝さないで嵐を避けた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓や舵取りを完全にするのは実践である。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚槽付小型船や亀獲り船で、寝ずに舵取りの番をするような時など、たまに歌を唄っていた。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "天を信じてイタリアの岸に漕ぎ寄することあたわずば、舵取りよ、唯わが加護を信じて漕ぎゆけ。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "波や風や舵取りが思いのままに西に東にひきまわす哀れな舟よ！",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "舵取りは慈悲深く全能なのであるから、我々は彼の舵のとり方に全然口ばしをいれる必要はないのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "お月さまの明るい晩、かじとりだけが、かじのところに立っていました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは、かじとりだけが、かじのところに立っているばかりです。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
