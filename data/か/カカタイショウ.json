    "definitions": [
      {
        "index": 1,
        "gloss": "laughing a ringing laugh",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼のジョークはあまりにも滑稽で、皆は呵々大笑した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あまりの面白さに、友人は腹を抱えて呵々大笑していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "コントのオチで、観客がどっと呵々大笑し始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「いやー、これは参った！参った！」と彼は呵々大笑しながら言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "主膳尚も、Ｔ「何しろ貴様は天下のお尋ね者」　源兵衛「そんなに大声で」　主膳呵々大笑する。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "男も女も同じだ、何故なら男だけではと思い付き、真理は平凡なりと呵々大笑した。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛島の梵雲庵に病んでいよいよ最後の息を引取ろうとするや、呵々大笑して口吟んで曰く、「今まではさまざまの事して見たが、死んで見るのはこれが初めて」と。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっはっはっ」　ドレゴはそういい切って呵々大笑した。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い文壇的気流の匂いだの、ゴシップだの、競争だの、いりくんだ利害関係だのから、作家同士或は作家、編輯者との間からは、世が世智辛くなるにつれ、率直さや朗らかさや、呵々大笑的気分は消失して来ているであろう。",
              "citation": {
                "source": "文学の大衆化論について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏有閑、呵々大笑！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "呵々大笑はおもしろいが時代が許さないだらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "呵々大笑するふとった酒神、習慣的に一刻も早く給料袋をからにしなければ安心出来ない船員たちのむれ！",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂へはいつて一切を洗ひ落して戻ると、樹明さんと武波さんとがにや／＼して待つてゐられた、悪行露見、罪業深重、いさぎよく白状して呵々大笑したことである、さうする外ないではないか！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにＭ男爵閣下には小生のかような窮状を見て呵々大笑されました。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "真の外交手段と云う事は出来ないであろう」　と云われまして再び呵々大笑されました。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "構内監倉の入口にて、枯川は、送れる人々を見返りて、「こゝからは本人だけしか入れないよ」と呵々大笑して、フロツク着たる影は、ツカ／＼と小暗き廊下に没し去れり、皆相顧みて語なし、彼の手には、「エンサイクロペヂヤ、ヲブ、ソシアルレフオーム」伝習録其他数巻を携へたりき。",
              "citation": {
                "source": "筆のしづく",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして、某君は呵々大笑するのだが、可笑しいのは夫子一人だけで、誰にも何のことやら分らない、筆者だけには分るが……。",
              "citation": {
                "source": "「沈黙」の話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪魔呵々大笑していわく、「愚なり、巴。",
              "citation": {
                "source": "るしへる",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚栄心や利己心や性的本能が、あるときは私を呵々大笑させ、あるときは私を沈黙と憂鬱とに導きつつ私の生活を落着のない、流るるような自由と快活とを失ったものにしていたのは事実であるが、他方においては傲慢な心から発した弁解する心と神を試みる心との二つの心が私の生活を激越な、安静のないものとした。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨のことをおしめりとしか言わず、鼻のわきの黒子に一本長い毛が生えていて、その毛を浹々と洗湯の湯に浮かべて、出入りの誰かれと呵々大笑する。",
              "citation": {
                "source": "舞馬",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒に赤らんだ周の顔が、殆んど微笑することはなく、突然に呵々大笑する。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "では失敬」　金博士は、送受話器のスイッチをぴちんと切ると、髭をふるわせて呵々大笑した。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、ここのお頭さんを典獄と申されます』と駄じやれて呵々大笑しました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達はお通夜をしりめに杯の数をあげながら、つまり今夜俺達は例のファウストの科白に復讐してゐるやうなものだなと言ひあつて呵々大笑したものである。",
              "citation": {
                "source": "牧野さんの死",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も私を覚えていて、呵々大笑した。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川夢声君のごときも先年私が大阪から笑福亭松鶴君を招いて独演会を企画した時、その「しゃっくり政談」を客席からじつに愉しそうに呵々大笑して聴いていられたことを、あえて特筆しておきたい。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、よ、あれは君、若造が馬鹿造だから、破産したんだぜ……」　呵々大笑して、「お蔭で、この山間の村々でも、約三百軒の貧農、中農が、まき添えを喰って倒産する。",
              "citation": {
                "source": "荒蕪地",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこの手紙をうけ取って、一読おもわず呵々大笑しましたね。",
              "citation": {
                "source": "真珠の首飾り",
                "author": "ZHEMCHUZHNOE OZHERELJE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は前山さんを評するわけではありませんが、もし直評を許されるならば、前山さんの今の製陶認識では失礼ながら古を偲ぶに足る、それは決して出来るものではありませんでしょう」　鈍翁は呵々大笑して……。",
              "citation": {
                "source": "素人製陶本窯を築くべからず",
                "author": "――製陶上についてかつて前山久吉さんを激怒せしめた私のあやまち――",
                "note": "青空文庫"
              }
            },
            {
              "text": "金箱だという説は誰しもいい加減に思いつく空想だが、切支丹てえのは、しかるべき達人のニラミがないと見破れない」　虎之介はこれをきいて呵々大笑。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッハッハア」　と虎之介は大きな両腕でヘコ帯の前を抑え、肩をゆすって呵々大笑した。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十三　幻の塔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
