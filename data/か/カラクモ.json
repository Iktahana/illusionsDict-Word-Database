[
  {
    "uuid": "a1b4353f-f0bf-5c03-966f-5997508eb090",
    "entry": "辛くも",
    "reading": {
      "primary": "からくも",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
