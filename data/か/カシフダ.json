    "definitions": [
      {
        "index": 1,
        "gloss": "card (oft. featuring illustrations of sweets) used to represent money when gambling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "時代劇で、博打の場に菓子札が積み上げられているシーンを見たことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「昔の賭場では、現金の代わりにこの菓子札をやり取りしていたんだって。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お菓子を模した絵が描かれている菓子札なんて、なんだか粋だよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "資料館で展示されていた菓子札を見て、昔の遊びに思いを馳せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしふだんは重苦しい眠が、――それ自身悪夢のような眠が、間もなく彼女の心の上へ、昏々と下って来るのだった。",
              "citation": {
                "source": "奇怪な再会",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしふだんの時でも不足勝ちであったものが、その借金を返すことは容易でなく、ついには不処理の結果、店を退去しなくてはならぬようなことにもなる。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしふだんのとおりおちついて話した。",
              "citation": {
                "source": "とけない問題",
                "author": "THE INSOLUBLE PROBLEM",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
