[
  {
    "uuid": "9c6d601e-7a08-5dc4-88ab-7669af87adf4",
    "entry": "寒風",
    "reading": {
      "primary": "かんぷう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cold wind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜中にかうした澤を吹下ろす寒風の影響であらうか。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは南から来る暖かい風がこの境界線から地面を離れて中層へあがりその下へ北から来る寒風がもぐり込んでいるのだという事は、当時各地で飛揚した測風気球の観測からも確かめられている。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "半病人の家の者が、白いガーゼのマスクを掛けて、下の男の子を背負い、寒風に吹きさらされて、お米の配給の列の中に立っていたのだ。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぞへに下りて石垣へ立つと、私の丈ぐらゐな下に、船の小べりが横づけになつて、中流の方に二艘、谷崎さんはその眞中に寒風に吹かれながら颯爽として立つてゐた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒風に吹き晒されて、両手に胼を切らせて、紙鳶に日を暮した二十年｜前の小児は、随分乱暴であったかも知れないが、襟巻をして、帽子を被って、マントに包まって懐手をして、無意味にうろうろしている今の小児は、春が来ても何だか寂しそうに見えてならない。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "良寛さんの心には、寒風の吹きすさぶ越後の冬の海のはげしさが、ひそんでゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬は寒風が辛くあたる。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、この本一冊のために、身の置きどころを失い、たえず自尊心を傷けられて世のなかの寒風に吹きまくられ、そうして、うろうろ歩きまわっていた。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると其軍の大将が武力を用いれば何とでも随意に出来るけれど、好い大将である、仁義の人であると思われようとする場合には、寒風雨雪の夜でも押切って宿舎する訳には行かない。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "見世物小屋から飛び出して、寒風に吹きまくられ、よろめきながら湯村の村はずれの郵便局にたどりつく。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし堂島は遂に姿を見せないで、路上には漸く一月の本性の寒風が吹き募って来た。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒風の中を一散に堤防目がけて走った。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "馴れぬ風土の寒風はひとしおさすらいの身に沁み渡り、うたた脾肉の歎に耐えないのであったが、これも身から出た錆と思えば、落魄の身の誰を怨まん者もなく、南京虫と虱に悩まされ、濁酒と唐辛子を舐めずりながら、温突から温突へと放浪した。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十一月、寒風の吹き荒むとともに、懐胎したカウの大群集は成長した幼獣、処女獣と南方に向って去り、半成牡も去り、そうして、かの絶倫なる諸王、ブル中の英雄たちも、不眠と絶食と間断なき性交とに、疲労困憊の極は、へとへとによろよろになってようやくに後から後から蹤いて去るのだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉颪の寒風に徒らに顫え乍ら、寛永十四年は暮れて行った。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　凍てついた道を寒風が吹き渡っていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉樹が寒風に嘯き早春の欅の梢が緑の薄絹に掩われるのも、それは皆すべて植物の生理的必然の作用に他ならない。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松の中には布子を引つ掛けた漁夫が二三人寒風に吹き曝されながら懷手のまゝぼんやりと際涯もない沖を見つめて居る。",
              "citation": {
                "source": "濱の冬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の日電柱に寒風がうなり、吹雪の朝、電柱の片面に、雪が吹きつけられて凍っているのがちょうどその面に日でも当たっているように見える。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、その磨き澄ました日本刀のような寒風が揺するのだった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道の寒風がりんごの皮を緻密にし、その皮膚を赤く染めたように人足らも、その着物を厚くし、その頬を酒飲みの鼻の頭のようにしている。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同様に北海道の寒風は、労働者たちから、その体温をどんどん奪ってしまう。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一陣の寒風が颯つと吹き抜けた概で、あたりは水底のやうに静まり返つた。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は慾深爺の顔つきで、今更、斯んな世にも滑稽な事件のために血道をあげてゐるものゝ、私にとつては金塊引上事業や鉱脈発見の苦心者と実にも同然なありのまゝの惨胆さに相違なく、どうやら旋風の絶え間もなく、このまゝこんな村で銑太郎の出現を待ち呆けたならば寒風に吹き殺されて了ひさうだつた。",
              "citation": {
                "source": "冬物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『そこで親分、街の酒場で鱈腹酒をのんでから、さあ俺は馬賊だ斬るなり殺すなり勝手にしろ、と大あぐらを組んだところが、すこぶるかん単でさ、冷たいものがすうと首筋を撫でたと思つたら、首と胴とが泣き別れで獄門の上で寒風に晒されるといふわけですからな。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一朝その徒と山中におり寒風堪ゆべからなんだ時、氷雪を集めて息を吹き掛けるとたちまち火となったと詠んだ詩人もある。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月怒って羊は三月末より四月初めへ掛けて子を生む大切の時節と気が付かぬかと言い放ち、自分の終り三日と、四月より借り入れた三日と、六日の間寒風大雨を起して、すべての羊もちょうど生まれた羊児も鏖しにしたと。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々捜して燈を点しよく視ると、昼間鶏が二階のこの室に走り込んで突き破って逃げ飛んだ硝子窓の破処から、吹き込む雪｜雑りの寒風がカーテンに当って上り下りしおりその風の運動が件の両人の立ち廻りと現われ、消え失せた後もなお無形の何かが楕円軌道を循環すると見えた。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "水中の森は、甚兵衞が舟をつなぎて、雪にうづもれ、寒風にさらされて、宗吾の歸り來たるを待ちし處也。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
