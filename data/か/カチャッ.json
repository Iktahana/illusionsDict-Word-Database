        "examples": {
          "standard": [
            {
              "text": "ドアの鍵がカチャッと音を立てて開いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "車のシートベルトがカチャッと締まる音がした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はライターの蓋をカチャッと閉めてポケットにしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スイッチをカチャッと押すと、部屋の電気がついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「公休たい、月に一度の公休たい」　………哀れなるかな少年車掌――と、おしまいの方は唄のように云って弁当箱をカチャッとおいてちょッとも哀れそうでない笑い声をたてた。",
              "citation": {
                "source": "冬枯れ",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "タラタラタラと酒が黒っぽい高座着を濡らし、カチャッと地べたで茶碗の割れる音がした。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
