[
  {
    "uuid": "63c45aea-28af-5f9c-acf4-4da48b1f2e7b",
    "entry": "係り合い",
    "reading": {
      "primary": "かかりあい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
