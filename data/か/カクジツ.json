[
  {
    "uuid": "fa493be3-28b6-5036-9dd5-c4d49551adbb",
    "entry": "確実",
    "reading": {
      "primary": "かくじつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
