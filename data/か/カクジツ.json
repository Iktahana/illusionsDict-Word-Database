      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "certain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「会議の資料を明日までに届けると約束した以上、確実に午前中に着くように手配してくれ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "気象庁の予報で雨の確率が90％を超えており、明日の運動会の中止はほぼ確実だと言わざるを得ない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地道な基礎練習を毎日積み重ねることこそが、試合で勝利を掴むための最も確実な近道である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしながら Real といふ言葉は外国語の意味に於いては、単なる「現実」を指すのでなく、もつと深奥な哲学的の意味、即ち或る「真実のもの」「確実なもの」、架空の幻影や仮象でなくして、正に「実在するもの」といふやうな意味を持つてゐる。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけは確実である。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠っているような植物の細胞の内部に、ひそかにしかし確実に進行している春の準備を考えるとなんだか恐ろしいような気もする。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの知識を確実に把握するためには支那、満洲、シベリアは勿論のこと、北太平洋全面からオホツク海にわたる海面にかけて広く多数に分布された観測点における海面から高層までの気象観測を系統的定時的に少なくも数十年継続することが望ましいのであるが、これは現時においては到底期待し難い大事業である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音は、外部に発しないで、一種の確実さをもって、彼の足部から彼の黒い熱塊のような苦痛に満ちた頭部へ衝き上った。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故彼の日本の恋人が、彼を裏切って他の恋人に走ったということが確実に判った朝、彼は、彼の恋人のその宣言のような手紙を受取って読んだ瞬間つと立ち出でて、伯林の仲秋の街路へ出たのか彼にもはっきり判らなかった。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆゑに、恋愛に於いて当事者の意識する処は大部分ロマンチツクな詩的な精神的部分でありながら、実は人類の根本義に深く根ざし最も確実な現実性を有する最も現実的人生行路のところどころに置かれたる詩篇なのであります。",
              "citation": {
                "source": "恋愛といふもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴磨きにアパートにおける殺人の嫌疑をかけるためには殺されるダンサーのアパートにその靴磨きをなんとかしておびき入れ、そうしてアパートにおける彼等の姿を確実に目撃した証人をこしらえておく必要がある。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり確実な事は云われないが、西洋の電車ではこんな心持のした事はなかったように思う。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、一番始末のいい場合は、学問の本山であるところの西洋の第一流の大家達の統括の下に開拓され発達させられた一つの明確な区劃内に限られた部門の中で、かの地の誰やかれが既にかなりまでつつき廻した問題の一方面に若干の確実な貢献をしたというような種類の仕事が学位論文として提出された場合である。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に「今後五十年内に日本南海岸のうち一部分に強震あるべし」という事がよほど確実なりと仮定せよ。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこれらの影響は地球全体に比べて小さい事も確実である。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういう場合でも、一方では音の方向知覚というものの本来不確実なために、また一方では劇場の複雑な反響のために、なおその上に、視像の暗示にだまされる錯覚のために、実際はたいした不都合は感じないかもしれない。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "論理的に確実なある物を捕える喜びは、もうこの頃から彼のうら若い頭に滲み渡っていた。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうすれば、言葉と白墨の線とによって、大きさや角度や三角函数などの概念を注ぎ込むよりも遥かに早く確実に、おまけに面白くこれらの数学的関係を呑み込ませる事が出来る。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来の盲探しの手数のかかる方法に代わるに簡単で確実な合理的方法を考案してこれを実地に応用し良好の成績を収めた。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが石川君の歌を見ると、航行の目的と要求とが明瞭して居つて、それに対する、碇も羅針盤も確実に所有し、自分の行きたい所へ行き、自分の留りたい所へ留つてるのである。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良朝以前の万葉仮名の資料は甚だ少ない故に、確実に実証することは困難であるが、そう見れば見得る例はないでもないのである。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも東京市民が慌てて遁げ出すか、あるいはあの大正十二年の関東震災の場合と同様に、火事は消防隊が消してくれるものと思って、手をつかねて見物していたとしたら、全市は数時間で完全に灰になることは確実である。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし前任者が果して瓦斯中毒で死んだかどうかも確実には分からないようである。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもその町内の親爺株の人の例えば三割でもが、そんな精密な地震予知の不可能だという現在の事実を確実に知っていたなら、そのような流言の卵は孵化らないで腐ってしまうだろう。",
              "citation": {
                "source": "流言蜚語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、このような明白な事実を確実に知っている人が如何に少数であるかという事を示す証拠と見られても仕方がない。",
              "citation": {
                "source": "流言蜚語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも晩年の作品の中に現われている色々のものの胚子がこの短い詩形の中に多分に含まれている事だけは確実である。",
              "citation": {
                "source": "夏目先生の俳句と漢詩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの所長のパシュフォード博士が近頃報告したところに拠れば、癌の療法と称するものは色々あるが、いずれもあまり確実な効験はない。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし時間の計算から、それが私の家の近所であること、徒歩で半時間位しか離れていないいつもの私の散歩区域、もしくはそのすぐ近い範囲にあることだけは、確実に疑いなく解っていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは多分、もっと確実な推測として、切支丹宗徒の隠れた集合的部落であったのだろう。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての感覚が解放され、物の微細な色、匂い、音、味、意味までが、すっかり確実に知覚された。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論三つの生命は確実に三つの据りを保つてゐなければならぬ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、十年前の甲某が今日の甲某と同一人だということについては確実な証人が無数にある。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地震だなと思うと、すぐにその初期微動の長さの秒数を数えたり、主要動が始まればその方向や週期や振幅を出来るだけ確実に認識しようとする努力が先に立つ。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
