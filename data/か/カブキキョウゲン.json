        "examples": {
          "standard": [
            {
              "text": "俳優たちは、今夜の公演のために「歌舞伎狂言」を熱心に研究しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "本格的な「歌舞伎狂言」を現代語に翻訳するのは、大きな挑戦です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その作家は、新しい「歌舞伎狂言」のセリフを練り上げるのに何年も費やしました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
