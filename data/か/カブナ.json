        "examples": {
          "standard": [
            {
              "text": "採れたての蕪菜を浅漬けにして、夕食に出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬の畑で、雪をかぶった蕪菜が甘みを増している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "蕪菜の葉は栄養満点なので、味噌汁の具にするのが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "大根、桜島、蕪菜、朝鮮芋（さつま芋）、荒苧（里芋）、豌豆、唐豆（そら豆）、あずき、ささげ、大豆、なた豆、何でもあった。",
              "citation": {
                "source": "私の父",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汁は「すまし」にて椎茸と蕪菜の上に卵を一つ落しあり。",
              "citation": {
                "source": "明治卅三年十月十五日記事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の心は山のように蕪菜を積み重ねた流し許の方へ行った。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "青々と洗われた新しい蕪菜が見えて来た。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪菜を煮る、やはらくてまことに年寄向。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "余念も無く蕪菜を洗ふ女の群の中に、手拭に日を避け、白い手をあらはし、甲斐々々しく働く襷掛けの一人――声を掛けて見ると、それがお妻で、丑松は斯の幼馴染の様子の変つたのに驚いて了つた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "島根縣の邑智郡などでいふクキタチも、必ずしも薹に立つた菜だけでは無く、三月頃麻じりの畠に殘つて居る蕪菜を拔いて漬けて置くものゝことであり、もとは田植の頃の食物となつて居た。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "島根県の邑智郡などでいうクキタチも、必ずしも薹に立った菜だけではなく、三月頃麻じりの畠に残っている蕪菜を抜いて漬けておくもののことであり、もとは田植の頃の食物となっていた。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるじがもてなしとて、芋と蕪菜を味噌汁にしたるなかにいぶかしきものあり、案内がさし心えていふやう、そは秋山の名物の豆腐也といふ。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹藤に越ゆる尾根の上に、　　なまこの雲ぞうかぶなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日夜一鳥の飛ぶなく、一帆の浮かぶなく、満目ただ渺茫たり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも具体的な作品が浮かぶなら、それを青空の本に仕立ててみませんか？",
              "citation": {
                "source": "青空文庫の提案",
                "author": "青空文庫編",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
