    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bright and clear (weather, sky, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あら、空がからっと晴れたわね！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "今日の東京は、からっとした青空が広がっていて気持ちがいい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昨日の雨が嘘みたいに、朝から空はからっとしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "これなら遠足も安心だ。空がからっと晴れ渡っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "空がからっと一たん明るくなった。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日たって民さんはなぜ近頃は来ないのか知らんと思った位であったけれど、民子の方では、それからというものは様子がからっと変ってしもうた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "空はからっと晴れていて、百舌鳥の声がきんきん、ひびいていました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は朝からからっと晴れた好天気で、気候も初夏らしく温い日だったので、人びとはお祭り騒ぎで替え乾をはじめた。",
              "citation": {
                "source": "赤い牛",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼がさめてみると、からっと晴れているのは、うれしいからな。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎夜、毎夜、万朶の花のごとく、ひらひら私の眉間のあたりで舞い狂う、あの無量無数の言葉の洪水が、今宵は、また、なんとしたことか、雪のまったく降りやんでしまった空のように、ただ、からっとしていて、私ひとりのこされ、いっそ石になりたいくらいの羞恥の念でいたずらに輾転している。",
              "citation": {
                "source": "めくら草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢部の前で、十一、二の子供でも叱りつけるような小言を言ったことなどもからっと忘れてしまっているようだった。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝のうちだけからっと破ったように晴れ渡っていた空は、午後から曇り始めて、まっ白な雲が太陽の面をなでて通るたびごとに暑気は薄れて、空いちめんが灰色にかき曇るころには、膚寒く思うほどに初秋の気候は激変していた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "重い冷たい潮霧が野火の煙のように濛々と南に走って、それが秋らしい狭霧となって、船体を包むかと思うと、たちまちからっと晴れた青空を船に残して消えて行ったりした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさまでは雨雲に閉じられていた空も見違えるようにからっと晴れ渡って、紺青の色の日の光のために奥深く輝いていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "からっと晴れた朝の天気に引きかえて、朝日がしばらく東向きの窓にさす間もなく、空は薄曇りに曇って西風がゴウゴウと杉森にあたって物すごい音を立て始めた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉地はこれをきっかけにからっと快活になって、今までの事は忘れたように、古藤にも微笑を与えながら「それはおもしろかろう」といいつつあとに続いた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は毎朝五時には起床いたしまして、すぐ身を浄め、画室の障子をからっと明け放します。",
              "citation": {
                "source": "あゝ二十年",
                "author": "――やっと御下命画を完成した私のよろこび――",
                "note": "青空文庫"
              }
            },
            {
              "text": "降り続いた雨も上って空はからっと晴れて、少し冷たさを覚える朝、みんなに送られて、みんなの祝福の言葉を浴びて、祖母と一緒に私は旅に立った。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして雨も、その前々夜にはからっと上がり、町にはすでに火薬の匂いもありません。",
              "citation": {
                "source": "一週一夜物語",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと、森だった小柳津氏の前は、今もうからっとした石燈籠屋になって居る。",
              "citation": {
                "source": "日記",
                "author": "一九二〇年（大正九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで、からっと晴れりゃ、いいお正月がくるんだ。",
              "citation": {
                "source": "寺坂吉右衛門の逃亡",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが（これさえ済めば、からっと、晴れ上るんだ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜びと期待に満ちて寝台に入り、ぐっすり寝込んで五時に目をさまして見ると空はあつらえ向きに、からっと晴れ渡っている。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の国じゃ、もう今頃からは、からっと晴れた空なんぞはめったに見られません。",
              "citation": {
                "source": "北国の人",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを抜けるとからっとした広い傾斜面でどこも秣畑になっている。",
              "citation": {
                "source": "石ころ路",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は、からっとよく晴れていました。",
              "citation": {
                "source": "道の上で見た話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェマイマは　こころもち　もたもたと　おりたつと、　そのあとは　うむのに　ちょうどいい　からっとしたところを　さがして　あたりを　よちよち。",
              "citation": {
                "source": "みずかきジェマイマのはなし",
                "author": "THE TALE OF JEMIMA PUDDLE-DUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "じぶんは　まいごなのでは　なく、　たまごを　かえすに　ちょうどいい　からっとしたところを　さがしに　きているのだと、　わけを　はなしました。",
              "citation": {
                "source": "みずかきジェマイマのはなし",
                "author": "THE TALE OF JEMIMA PUDDLE-DUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "息苦しいのどがからっとして、息がすうすうできるようになった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸しゃれたところで、ベーコンの皮をからっと揚げたものか、南瓜の種の塩煎りというところである。",
              "citation": {
                "source": "パーティ物語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤアこんでるんだなアというような、からっとしたところなくてね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か、つき交ぜた顔で、三人ばかり招ばないか、飲み直して、からっと笑って帰ろう」「……でも、今、お迎えに見えていますよ」「え。",
              "citation": {
                "source": "春の雁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや官吏の奥さんめいた気取りがちッともなく、からっとした陽気な婦人なのである。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "nicely dry (laundry, air, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
