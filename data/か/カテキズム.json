        "examples": {
          "standard": [
            {
              "text": "彼は幼い頃から教会のカテキズムを学び、信仰心を深めていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "宗教教育の場では、子供たちにカテキズムを用いて基本的な教えを伝える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い修道院の図書館には、手書きの貴重なカテキズムの書物が保管されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "最も原始的なカテキズム、幼稚な奇蹟｜反駁論、最も子供｜欺しの拙劣な例を以て証明されねばならない無神論。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道徳的なカテキズム（教義問答書）や倫理的カズイスティクが、スコラ論理学のような意味で可能になる。",
              "citation": {
                "source": "道徳の観念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カテキズム」ですから話にのぼった作品の箇所へでもゆけば誰のかいたどういうものかと思うような字句であったろうと思います。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "風景でも人情でも恋でも述懐でも、常にこのとおりの課題があり、常にその答案の予期せられていたことは、天台の論議や旧教のカテキズムも同様であった。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
