        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "高級料理を貪り喰い歓楽街に狂呼し、札束を切り大酔して意気高々とした状は、豪快といえば豪快に似ているが、実は刑務所から釈放された前科人が餓えきって娑婆の風に遇ったようなもので、十二分に歓を尽くせば歓を尽くすだけ、その状はむしろ哀れで悲しく、見窄らしげで、重々しいところは更に無いのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その惨めな姿がこの歓楽街から小暗い横丁の方へ消えていくと、あとを見送った弥次馬たちはワッと手を叩いて囃したてた。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぜひそこへ案内してくれたまえ」　僕とタクマ少年は、動く道路を利用し、第十八｜歓楽街のクラゲ座へ行った。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦後に出来た歓楽街としては東京でおそらく一番の地帯の、ややはずれに近いあたり、幅のせまい路地が複雑に交錯する奥に、その店はあった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "歓楽街にある酒と食事の店の、ありとあらゆる種類や形態のぎっちりと詰まった、屋根裏まで含めると三階建ての、大きな木造の建物の隙間のような部分に、そのバーはあった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "歓楽街となっている地区のまんなかを横切って、ふたりは駅に向けて歩いた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳しくは自宅へ帰ってから」　夜のこの時間の歓楽街には人の数がもっとも多かった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大通りを越えると、そこから先が歓楽街の広がりだ。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん東側の通りから、矢野はその歓楽街に入っていった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年前にはしばしば目にした光景が、歓楽街としてよりいっそう増幅されたかたちで、いまもいたるところにそのままあった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンパルサは初めてだったし、その歓楽街に入るのも、ほとんど初めてだと言ってよかった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンパルサが東の端にあったあの歓楽街がそもそも、彼が自ら足を向ける場所ではなかった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも古くからある商店街は、いまはパチンコ店や酒の店が軒を接してならぶ歓楽街となっていた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の場所は、下谷の広徳寺前で、ここは歓楽街の吉原裏に近いのに、なぜか窮民の混雑は、ほかよりひどい。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
