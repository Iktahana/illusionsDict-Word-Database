    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(shopping) cart",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「スーパーで一番大きいカートを選んで、週末の買い出しを始めた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「子供がカートに乗って、店内を駆け回ろうとするから危ないよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「レジの前にカートを置いて、さあ、商品を並べよう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「お米やお水は重いから、カートがあると本当に助かる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "褄は花の如く開かねば趣ないといふ廃頽的の江戸趣味も困るが、この理由をもつて、だからこそ和服も行灯式のスカートにせよといふ改良論者はまた行き過ぎる。",
              "citation": {
                "source": "風と裾",
                "author": "――何人か良案はないか？――",
                "note": "青空文庫"
              }
            },
            {
              "text": "咏嘆的な音楽が奏でられ、スカートの長いフランス女とアバッシュなマルセーユ男でワルツを始めました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "深刻な表情をして酒盃を傾けている黄をマリは見つけると、つか／＼と彼のかたわら迄彼女は行くと、少しばかりスカートを捲いてマリは薬品の為にオリーブ色になった唾液を床に吐いた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では男が女のようにスカートをはく時代なのだ。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　貨幣の豪奢で化粧されたスカートに廻転窓のある女だ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "太田ミサコの黒いスカートが冷たい路上で地下の電光に白く煌いた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の界わいを、極度に断截された近代娘たちが、短いスカートと男のような乳房と新しい恋愛教科書によった独立の精神をもった彼女たちが、キャバレットとバーと夜の百貨店へくりだした。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "金貨遊戯室の、立縞の短いスカートの女が毛皮の襟に顔をうずめて、夜会バッグにしまった三角形の××を彼女の墓誌銘にして、梅田方面に立ち去った。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "スカートの短い女のまえで自殺する男にたいするご意見は？",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフタヌーンのスカートは短くイブニングのスカートは長い。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "スリップにつけたレースがまんかいしてスカートから臑のあたりに××××るのはあまり感心しないがどうしたものか。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台から跳ねあがる音がして、黒いスカートのもとから素足のままで、フランのワイシャツに汚れたネクタイを締めながらスマ子女史は英介氏の部屋にやってきて、ストーブのまえでうずくまりながら、――お仕事できたらしいわねえ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイ・ヒルの靴を支那女の腹部に背をみせると、機械色のスカートのなかで小きざみに足並をそろえて彼女があるきだした。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いが、もとは相当にものが良かったらしい外套の下から、白く洗い晒された彼女のスカートがちらちら見えていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "スカートが短かすぎるように思われました。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青木さんも無言で、キヌ子のスカートなど直してやる。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年前に見た時はまだ女学校へ通っていたのに、今はすっかり娘めいて、スカートの裾から覗いているむっちりした膝頭を気にしているのを見て、思わずはっと赧くなったのだろうか。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……敗戦になってから、急に酒を飲みだしたんです」　おまけに煙草は日に八十本、病院もやめてしまい、毎日ぶらぶらして、水すましのように空虚な無為徒食の生活をはじめた――と道子はスカートの端をひっぱりながら言った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜十時お伺いします」　そう言ったかと思うと、信吉の返辞も待たず、スカートの後ろを気にしながら、階段を降りて行った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ればはだしで、短いスカートも、小さいシュミーズの袖もきれていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い髪の毛のまわりに銅のボタンをつけて、あい色のスカートをはいた女たちが、重い荷をつんだ牡牛を追っています。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり、この娘さんも、紙で作られてはいましたが、でもスカートなどは、それはそれはきれいなリンネルを使って、こしらえてありました。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、だれにも見られないように、みんな、あたしの前に立っていておくれ」　そこで、侍女たちは、お姫さまの前に立ちならんで、スカートのはしをつまんで、ひろげました。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "オーレ・ルゲイエは、おばあさんの黒いスカートをつけて、坊さんのかわりに、式を行いました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅やに、スカートのほころびを縫わせて、縫いあがったら、さっさと帰って行った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、ダンスをおわったお千代さんが、うすももいろのスカートをひらひらさせて、舞台うらへひきさがってきました。",
              "citation": {
                "source": "正坊とクロ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は女学校時代のつぎはぎだらけのスカートに、それからやはり昔スキーの時に着た黄色いジャケツ。",
              "citation": {
                "source": "恥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺のスカートは、つぎはぎだらけだ。",
              "citation": {
                "source": "恥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "kart",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「週末は、近所のサーキットでカートレースに参加するのが趣味なんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「初めてのカート体験、最初は怖かったけど、すぐにスピードに乗って楽しめたよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このカートは加速が良いから、コーナーで差をつけやすいね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「子供の誕生日プレゼントに、本格的なゴーカートを買ってあげた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
    ],
