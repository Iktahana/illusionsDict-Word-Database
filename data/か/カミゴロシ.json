        "examples": {
          "standard": [
            {
              "text": "古代の神話には、英雄が神殺しの大業を成し遂げる物語が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの伝説の剣は、かつて神殺しに使われたと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "神殺しとは、世界の秩序を根底から揺るがす禁忌の行為だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
