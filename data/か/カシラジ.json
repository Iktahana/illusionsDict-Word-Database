        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "各行の頭字を繋げて読むと、一つの短いメッセージになるという言葉遊びだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "名簿は全員の名字の頭字をもとに、あいうえお順で整理されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "検索システムで単語の頭字を入力すると、候補のリストが一覧で表示される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "古いヨーロッパの写本は、各章の頭字が金箔や絵の具で美しく装飾されていることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「さあ、何か存じません、待合さんかも、それは分りませんが、てんで私の方で伺う気はござりませなんで、頭字も覚えませぬよ、はい。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは逸作の腕に支えられながら、弟の医者にちょっと脈を検められ、「生きの身の」と、歌の頭字の五文字を胸に思い泛べただけで急いで帰宅の俥に乗り込んだだけを記して、早くこの苦渋で憂鬱な場面の記述を切上げよう。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑いろの革で四角に出来てゐて、縁と蝶番の処とは勿論、四隅に附いてゐる鱗形の装飾も、表の真中に附いてゐる名の頭字の A の字も、皆銀である。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "柔肌に食い入るばかり、金｜金具で留めた天鵝絨の腕守、内証で神月の頭字一字、神というのが彫ってある。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故というのに、秋貞というのはその店に折々見える、紺の前掛をした、痩せこけた爺さんの屋号と名前の頭字とに過ぎないのである。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の姓名の頭字を組合せて入れてくれたものだと思えば、それでいいのであるが、それでは何となく物足りなかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのＳを倭文子の頭字にしたかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "倭文子が、自分に対する贈物に、彼女の名の頭字と、自分の姓の頭字とを、組合せたものと考えたかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを訪れる若い人達は、みんなその水車の柔い、だん／＼朽ちてゆく木に、自分の名前の頭字を彫りつけて行つた。",
              "citation": {
                "source": "水車のある教會",
                "author": "オウ・ヘンリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "また魚とならば、御子の頭字象りもし、驢馬ともなりては、主を乗せまつりし昔思ひ、はた、わが肉より禳ひ給ひし豕を見いづ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "また魚とならば、御子の頭字象りもし、驢馬ともなりては、主を乘せまつりし昔思ひ、はた、わが肉より穰ひ給ひし豕を見いづ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "え、ロミオと萬迭香とは、頭字が同じかいな？",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の句の頭字を五十音順に列べた其｜配列法が、最初少からず富江の怨嗟を買つた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の句の頭字を五十音順に列べた其配列法が、最初少からず富江の怨みを買つた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして雨の中を展覧会へ行くまで二人の間に交された話ぶりを記しているのであるが、このＭというのが、今日の映画の「恋人の日記」のパン種となったモウパッサンの頭字だろうか。",
              "citation": {
                "source": "マリア・バシュキルツェフの日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただレーニンとローザ・ルクセンブルグとカール・リープクネヒトとの頭字のＬを三ツあわせた記念日としてだけ思えないところがある。",
              "citation": {
                "source": "三つの愛のしるし",
                "author": "――自由・平等・独立の火をともす――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十世紀の人類生活の前進のため、このＬという字を頭字にもった三人の人たちの生涯は、革命暦の上にあらまし印刷されている業績より、もっともっとふかい階級的な人間としての意味を語っている。",
              "citation": {
                "source": "三つの愛のしるし",
                "author": "――自由・平等・独立の火をともす――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちＬという頭字をもった三人の人たちは個人的な権勢の欲望に害されることのなかった無私な人たちだった。",
              "citation": {
                "source": "三つの愛のしるし",
                "author": "――自由・平等・独立の火をともす――",
                "note": "青空文庫"
              }
            },
            {
              "text": "源吉というのがこの若者の名で、それを山家の習慣では頭字ばかり呼んで、源で通る。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェルテルスキーは、故国にいる間絶えず種々な頭字を肩書に持つ友人に煩らわされた。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "社の方で差支へがあれば頭字にでも直すようにしませう。",
              "citation": {
                "source": "書簡　大杉栄宛",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "sacred fish――古代の基督教信者が其の記標として用ひたるもの、蓋し希臘語の魚に當る語は英語のJesus Christ, Son of God, Savior に相當する希臘語の頭字を集めたるものと同一なるより起りたるものなり、即ち其語はΙΧΘΥΣ也。",
              "citation": {
                "source": "アーサー王物語",
                "author": "KING ARTHUR'S ROUND TABLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "指の骨に結婚指輪をはめていて、その内側に頭字が彫ってあった。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フランシス某夫人」――この第一頭字のＦを取って、二つの名に「Ｆ・フランシス夫人――Ｆ・デェヴィス夫人」と突嗟に思い付いて書いたものと考えることは果して遠いであろうか。",
              "citation": {
                "source": "土から手が",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋という頭字をひろつてゆくと、秋川という姓はたつた一つしかない。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "プリューシキンの認ためた書附は綴りの短かいことが特徴で、どうかすると、名前と父称の頭字だけを書いて、あとには点が二つ打ってあるきりであった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしなべて汽車のうちさへしめやかになりゆくものか渓見えそめぬたけながく引きてしらじら降る雨の峡の片山に汽車はかかれりいづかたへ流るる瀬々かしらじらと見えゐてとほき峡の細渓　秋の、よく晴れた日であつた。",
              "citation": {
                "source": "渓をおもふ",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は何時の間にかしらじらと明けて蒼白い光が花壇の花をぼんやり、照らして居るのでした。",
              "citation": {
                "source": "西班牙の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不満とも鬱憤ともつかない、また期待の念ともつかない、何かしらじりじりした、自から動き出そうとするものだった。",
              "citation": {
                "source": "電車停留場",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "小鳥が鳴いてる、花が咲いている、鮒が浮いてる、杉の芽が綺麗だ、ほんとにいい天気だ、などとそんなことを短い言葉で独語のように云いながら、それでも心の底には、何かしらじっとしていられないものが渦巻いてるといった風に、出来るならば宙を飛んだり地面に転がったりしたいような素振だった。",
              "citation": {
                "source": "或る男の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
