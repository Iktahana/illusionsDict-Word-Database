        "examples": {
          "standard": [
            {
              "text": "何度説明しても、彼は自分のやり方に片意地を張って譲らない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供が「嫌だ！」と片意地を張って、全く言うことを聞かない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔気質の職人さんは、伝統的な技術に片意地を張って、新しいやり方をなかなか取り入れようとしない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は間違いを認めず、片意地を張って議論を続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "お初の奴が、片意地を張るにまかせて置きゃあ、あべこべにおめえが、どんなことになるかわかったものじゃあねえから、思い切って荒っぽく出てやったのよ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            }
          ]
        }
