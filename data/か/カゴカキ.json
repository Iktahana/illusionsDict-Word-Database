[
  {
    "uuid": "ad12b48b-ad26-539b-a7b6-56f9709206b1",
    "entry": "駕籠かき",
    "reading": {
      "primary": "かごかき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
