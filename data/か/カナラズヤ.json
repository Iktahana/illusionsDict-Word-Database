[
  {
    "uuid": "e197ac2b-7028-5346-b5d7-bc866c882e0e",
    "entry": "必ずや",
    "reading": {
      "primary": "かならずや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
