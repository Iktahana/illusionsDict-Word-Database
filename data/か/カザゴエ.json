    "definitions": [
      {
        "index": 1,
        "gloss": "hoarse voice (caused by a cold)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「もしもし……あ、ごめん、酷い風邪声で誰だか聞き取れなかったかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "喉の炎症が酷いらしく、彼女は鼻にかかったような掠れた風邪声で応対した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おや、随分な風邪声だね。今日のプレゼンは交代するから早く帰りなさい」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ハスキーな風邪声のせいで、電話越しだと自分の子供と間違えられてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "風邪声にしちゃ、少々野太いと思った。",
              "citation": {
                "source": "凡人凡語",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべ帰りがおそかった美佐子は、旅の疲れで睡そうにしていた高夏と二三十分しゃべったばかりで、土産の犬はまだ見ていないのだが、あのひいひいと風邪声のようなかすれた声で啼いている方がピオニーであろう。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
