    "definitions": [
      {
        "index": 1,
        "gloss": "binding hand and foot",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "捕らえられたスパイは手足を縛られ、身動きが取れない金縛りの状態だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "強盗は被害者の身体をテープで金縛りにして、貴重品を奪って逃走した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の物語では、悪人が主人公を金縛りにして地下牢に閉じ込める場面がよくあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "出て来ぬと金縛りに合わせるぞ。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "出さぬと金縛りだぞ……そうだそうだ……」　こう云いつつその舌に顔をさし寄せて、ジッと睨んでいた不動様は、不意にパクリとその舌を頬張ると、ズルリズルリとシャブリ初めた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "下宿屋の娘と言い、またこの「同志」と言い、どうしたって毎日、顔を合せなければならぬ具合になっていますので、これまでの、さまざまの女のひとのように、うまく避けられず、つい、ずるずるに、れいの不安の心から、この二人のご機嫌をただ懸命に取り結び、もはや自分は、金縛り同様の形になっていました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、直ちに木遁の術……が、しかし何故か思うに任せず、金縛りにかかったようになりながら、ただ阿呆の一つ覚えのように、「名を名乗れ！",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし又、万一、それでも満月が自分を嫌うならば、銀之丞様に加勢して、満月を金縛りにして銀之丞様に差出しても惜しい事はない。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きんとするものは、既成の主張を以て自己を金縛りにしてはなるまい。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ばか者めッ」　そのまま、退屈男の前へ金縛りにあったように立ちすくんでしまいました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "令子を見ると、金縛りにあったように、ただ画面を見つめている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「云わないと金縛りにするぞ」「祈り殺すぞ」　と、云うようなことを云うと白状した。",
              "citation": {
                "source": "村の怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ、淑女らしさという金縛りを身にうけてはいても、その時代の先進国であったイギリス生れの知識婦人であったフロレンス・ナイチンゲールが、社会衛生、道徳改善の事業にその規模の大きい現実的な精力の対象を見出したということは、決して不思議ではなかったのであった。",
              "citation": {
                "source": "フロレンス・ナイチンゲールの生涯",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の事あねえ不動様の金縛りを喰った山狼みてえな恰好で、みんな指を啣えて、唾液を呑み呑みソンナ女たちを眺めているばかりでした。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは自分でも「正直のところあまりびっくりしてどうにも足が動かなかった」と告白しているとおり、この一種形容できない白昼の驚怖感が、刹那彼の神経を萎縮させて、とっさの判断、敏速｜機宜の行動等をいっさい剥奪し、呆然として彼をいわゆる不動｜金縛りの状態に、一時｜佇立せしめたのだと省察することができる。",
              "citation": {
                "source": "女肉を料理する男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "不動の金縛りにでも逢ったように、動くことも声を立てることも出来なかった。",
              "citation": {
                "source": "赤格子九郎右衛門",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不動金縛りとはこれであろう。",
              "citation": {
                "source": "牛",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "別して天草商事には恨みをむすんでいる様子であるから、その一念、天草の三羽烏を金縛りにするかも知れない。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼には、紙帳の彼方に、刀を構え、斬り込もう斬り込もうとしながらも、こっちの無言の気合いに圧せられ、金縛りのようになっている、頼母の姿が、心眼に映じていた。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "切って棄てるは易いけれど、刀を抜くのも面倒じゃ、一つ金縛りにしてくれようと。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "刀も抜かずにそれほどの敵を、金縛りにしてしまうとは」　若衆を思う彼女の恋は、今夜の働きを知ると共に、益※強くなるのであった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その畏怖の情に包まれて、さすがの放胆泰軒居士も、ついぞなく、いま身うごきがとれずにいる不動金縛り。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "源三郎、金縛りにあったようにそのままの姿勢です。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "額ごしの左眼は、不動金縛りの力で、強く門之丞を牽制しながら、左膳、口をひらいた。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　つぶやいた文次、安を促してあとずさりしようにも、これが不動金縛りというのか、足がくぎづけになって身動きが取れない。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは火渡りのごとき、あるいは不動金縛りのごとき、ずいぶん不思議に見ゆれども、火渡りは物理の研究によるもできる道理にて、足の皮膚およびその面にある水気が、ある度までは熱力に耐え、かつ熱を防ぐことを得るゆえ、そのできるとできざるとは、つまり熱の程度に関する問題である。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎに不動金縛りは、現今にては催眠術にてたやすくできることなれば、不思議とは申し難い。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに、他人より「われは汝に不動金縛りを掛ける」と命令されれば、たちまち身体、手足が動かぬようになる。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "「動けば斬る」　このものすごい武士の唱えた呪文で、お松は金縛りにされてしまった。",
              "citation": {
                "source": "大菩薩峠",
                "author": "壬生と島原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーラは人か物かに金縛りになった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "一歩進もうとすると突然体が金縛りになり、頭の中に金属音が鳴り響く。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――小作人はどうかした拍子に「かなしばり」がとけた時のような身軽さを感じた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "この生活のこころよい均斉な調子は、早くもかれをかなしばりにしてしまったし、こういう暮らしかたのやわらかな輝やかしい静穏は、たちまちかれをうっとりとさせてしまった。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "sleep paralysis",
        "register": "standard",
        "nuance": null,
