    "definitions": [
      {
        "index": 1,
        "gloss": "to borrow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "明日のプレゼンで使うための予備のプロジェクターを、隣の部署から一台借りてこなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ！消しゴム忘れた。ごめん、ちょっとだけ借りていい？すぐに返すから」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "図書館で借りた古い歴史小説に夢中になって読み耽っていたら、いつの間にか外が明るくなっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼はズツと離れた郊外にゐたし、彼の友人や知人はみんな市内やまた他の方面の郊外にゐたので、彼は電車賃がないとなれば、誰かが遊びに来るのを待つてゐて、遊びに来た者から借りるか、それとも本を売るかしなければならないのだつた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "正しく風に動力を借りるオランダ低地の風車は美でもあり、経済的でもあったろうが、レムブラントの名手に油絵、またはエッチングに取り入れられたあの風車の風景も、近来は電気工業に取って代られ、引き合わないために、風車はだんだん取り毀たれ、オランダ風物の代表は、全く失われんとしているとも聞いた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャスタへ行くには、私たちの居住地、桑港から、オレゴンへと北向する南太平洋鉄道の便を借りるのである。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも優れた科学者が方則を発見したりする場合には直感の力を借りる事は甚だ多い。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この半七ならば祕密を明かしても差支へはあるまい、いつそ何も彼も打明けて彼の智慧を借りることにしようかと思つた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階をちよいと借りるぜ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "奎吉がふと思ひついたのはその莊之助の金を借りることだつた。",
              "citation": {
                "source": "奎吉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奎吉自身としてもそんな貯金から借りるのはどうしてもいやであつた。",
              "citation": {
                "source": "奎吉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今宵は泊るのが小菅ひとりであるし、わざわざ隣りの病室を借りるにも及ぶまいと、みんなで相談して、小菅もおなじ病室に寢ることにきめた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客様に御飯を上げる仕度も為なければならんし」と急に起上がって「紙と筆を借りるよ。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし講義の内容が抜け目なく系統的に正確な知識を与えさえすればいいとならば、何も器械の助けを借りるまでもなくその教師の書いた原稿のプリントなり筆記なりを生徒に与えて読ませれば済む場合もあるわけである。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは呪術師として祈らずに、娘を愛する母として、日頃使い馴れた呪術の力を借りるとしよう。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいらこれから石滝へ行くから、お前あとから取りに来ねえ、夕立はちょいと借りるぜって、そのまま乗出したもんだからね、そこいら中騒いでた徒に相済みませんを百万だら並べたんで。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お隣のを借りる）を掛けると六丁目里見氏宅で、はあ、とうけて、婀娜な返事が――幹事で支度がありますから、時間を早く、一足お先へ――と言ふのであつた。",
              "citation": {
                "source": "九九九會小記",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……借りるつもりか、さては近頃工面がいゝナなぞとおせきなさるまじく。",
              "citation": {
                "source": "鳥影",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　十九「それからその少え方は、（どうだろう、その黒門の空家というのを、一室借りるわけには行くまいか、自炊を遣って、しばらく旅の草臥を休めたい、）と相談｜打ったが。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房さん、済まないがちょいと借りるぜ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも型ばかりの硯箱を違い棚に置いてある家はいいが、その都度に女中に頼んで硯箱を借りるような家もある。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに滞在客は無し、女ばかりでは寂しいというのでわざわざ僕の隣を選んで六畳と四畳半の二間を借りることになったのだ。",
              "citation": {
                "source": "河鹿",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしも何だか気味がわるくなって、忽々に逃げて帰りました」「おめえはお鎌と心安くしているのか」「別に心安いというわけでもありませんが、あの婆さんは小金を持っているので、時々ちっとぐれえの小遣いを借りることもあるのです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗に「鰯の頭も信心から」といいますが、あんまり他人の頭ばかり借りてものを考えたり、喋ったり、書いたりしておりますと、しまいには鰯の頭まで借りるようになってしまいます。",
              "citation": {
                "source": "猫と杓子について",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "人類はじまって以来、多くの天才は僕らが借りるべき多くの着物を残してくれました。",
              "citation": {
                "source": "猫と杓子について",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、まず順序として、親戚で借りることを考えてみる。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "心斎橋筋の雑閙のなかでひともあろうに許嫁に小銭を借りるなんて、これが私の夫になる人のすることなのか、と地団駄踏みながら家に帰り、破約するのは今だと家の人にそのことを話したが、父は、へえ？",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はなんだか自分までが馬鹿にされたような気になり、ああ、いやだ、いやだ、昼行燈みたいにぼうっとして、頼りない人だと思っていたら、道の真中で私に金を借りるような心臓の強いところがあったり、ほんとうに私は不幸だわ、と白い歯をむきだして不貞くされていた。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊部は二十五歳で医学博士になったくらいの秀才で、酒も煙草も飲まぬ、いわゆる品行方正の男だったし、勤務先の阪大病院でもまず相当な給料を貰っていたから、高利貸に金を借りるような生活はまるで想像も出来なかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこの両者が共同し、その上に機械的の計算や統計を担当する助手の数人の力をかりることができれば、仕事はかなりおもしろく進行しそうに思われる。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうちんだけかりるのも、へんなので、常念坊は、「おい、おばあさん。",
              "citation": {
                "source": "のら犬",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、うめのきごけが、樹皮の乾燥している老幹に宿をかりるという、科学的な、又は自然的な関係からばかりでなく、自然の美的情緒を深めるためにも、梅の老樹を灰白色に、或いは茶褐色にぬりつぶしているような気がします。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、たまらなささうに、この子はどうしたといふんだらう、とふと口の中に独言を云ひながら、どうにも仕方がない程可愛いといふやうな様子で、『坊や、』と強く云ったけれども、笑が顔からあふれて了って、彼女は助をかりるやうに男の顔を見た。",
              "citation": {
                "source": "晩餐",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to rent",
        "register": "standard",
        "nuance": null,
