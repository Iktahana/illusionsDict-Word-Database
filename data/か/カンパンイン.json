        "examples": {
          "standard": [
            {
              "text": "彼は若い頃、貨物船の甲板員として世界中の海を渡り歩いた経験がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "荒波の中、甲板員たちが船体を固定する作業に追われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "甲板員は、船の運航や荷役作業の補助など、多岐にわたる業務を担当する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "陽に焼けた、ごま塩頭の甲板員が、ぼくがいこうとしている島はどれなのか教えてくれた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじごま塩頭の甲板員がいた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと思いついたぼくは、昨日オートバイを乗せたかどうか、甲板員にきいてみた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
