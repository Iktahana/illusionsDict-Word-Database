    "definitions": [
      {
        "index": 1,
        "gloss": "complexion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は徹夜明けにもかかわらず、顔色一つ変えずに仕事をこなした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "体調が悪いのか、彼の顔色がいつもと違うように見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "緊張していたが、なんとか顔色を悟られないように努めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夏の日差しで、健康的な顔色に焼けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "つまり、人の顔色を見るやうな能力はみるみる発達する一方、瞑想だの理念だのは、さなきだに濃厚ではないのが、発展の余地を持たなくなり、益々衰へてゆくのである。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "話が佳境に入って来ると、ヘルンは恐ろしそうに顔色を変え、『その話、怖いです、怖いです』といっておののきふるえた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母が顔色を変へて走つて来ました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母が顔色を変えて走って来ました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頻繁なる対人圏にあつて、各人が各人で朗らかであり得ぬ程度に比例して人々は互の「顔色を覗ふ」こと盛となる、即ち相対的となる、即ち創作的気心より遠ざかるわけである。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の顔色が急に変るかと思ふと彼は自分のマントと帽子を左手に持つて、右手で私の頬をポカツと擲りつけた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワールブルヒは腎臓でもわるいかと思われるように顔色が悪く肥大していて一向に元気がなかったが、ゴールトシュタインは高年にかかわらず顔色も若々しく明るい上品な感じのする人であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "柵の外より頻りに汽車の方を覗く美髯公のいずれ御前らしきが顔色の著しく白き西洋人めくなど土地柄なるべし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで庄屋殿が例えば「狸」と仰せられると加八は一同の顔色を注意深く観察して誰が「狸」であるかを観破するために云わば読心術の練習のようなことをする。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで麻酔なしでこの出血のはなはだしし手術を遂行したが、おしまいまでいっこうに平気で苦痛の顔色を示さなかった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "重兵衛さんの細君は喘息やみでいつも顔色の悪い、小さな弱々しいおばさんであったが、これはいつも傍で酌をしたり蚊を追ったりしながら、この人にはおそらく可笑しくも何ともない話を子供と一緒に聴きながら一緒に笑っているのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍に坐った妻の顔が小さく遠い処に居るようで、その顔色が妙に蒼く濁って見える。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ思いが、仲間の顔色に読まれる、飯を炊くのに、未だ時間がある、思い切って天幕から一、二間歩き出した、岩を二ツ三ツ飛び越えて、次第に爪先が上る、無辺無限の単調の線が、どこへ繋がって、どこへ懸っているのか、解らない……やはりあの空線の一つを辿っている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある時は「あなた、かくしているでしょう、きっとそうだ、あなたそうでしょう」とうるさく聞きながら、余の顔色を読もうとする、その祈るような気づかわしげな目づかいを見るのが苦しいから「ばかな、そんな事はないと言ったらない」と邪慳な返事で打ち消してやる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔色はたいして悪くもない。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、よだかでないただのたかならば、こんな生はんかのちいさい鳥は、もう名前を聞いただけでも、ぶるぶるふるえて、顔色を変えて、からだをちぢめて、木の葉のかげにでもかくれたでしょう。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなも顔色を変えて叫んだのです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔色の悪い事や、眼鼻の形状配置といったようなものは別としても、顔全体としての表情が十中八、九までともかくも不愉快なものである。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お松は自分が何と云うかと思うらしく自分の顔色を見てる。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にも元気のない風で夜のせいか顔色も青白く見えた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お民さんの様な温和しい人を、お母さんの様にあアいって叱っては、あんまり可哀相ですわ」　お増が共泣きをして言訣をいうたので、もとより民子は憎くない母だから、俄に顔色を直して、「なるほどお増がそういえば、私も少し勘違いをしていました。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は民子は顔色がよく、はっきりと話も致しました。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代ちやんひどく不快でもなつたのかい福や薬を飲まして呉れないか何うした大変顔色がわろくなつて来たおばさん鳥渡と良之助が声に驚かされて次の間に祈念をこらせし母も水初穂取りに流し元へ立ちしお福も狼狽敷枕元にあつまればお千代閉ぢたる目を開らき。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人の出し得る極度の大きな声を出しているという事は、その顔色が紫がかる程に赤く光沢を帯びて、眼球が飛び出しそうな程に眼を見開いている事からもおおよそ察せられた。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都の駅前でバンザイを叫んだ人と××の街頭でバンザイを叫ぶ人と顔色が違う。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "源兵衛は白ばくれて居るが、お静の顔色で、　石松、可怪いぞと思った。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次「ハハン」と五郎蔵の顔色読んだ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、かおいろをかえたじゃないか」　怪物の首領は、にくいほど、はっきりした口調で、三郎たちに話しかけてくるのであった。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶんおしずはもう打ちあけてもよい時機が来た、夫婦が夫婦でないことがわかったら姉も一往はふこころえをさとすであろうがいまとなってはとうわくしながらも妹たちのなさけにほだされてしまうであろうと看てとりまして何かのおりにかおいろをうかがいながら話をそこへ持って行ったのではござりますまいか。",
              "citation": {
                "source": "蘆刈",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "林さんはふたりのかおいろをみて、手ばやくひょうのかわをきせてくれるのでした。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
