        "examples": {
          "standard": [
            {
              "text": "リーダーは部下の顔色をうかがいながら、慎重に指示を出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "失敗をしてしまい、上司の顔色をうかがうのが怖かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の顔色から、かなりの不満を抱いていることが見て取れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
