    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one side",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「このチラシ、片面印刷でいいですよね？」とアルバイトの店員が確認してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "食パンの片面だけにバターをたっぷりと塗り、こんがりとトーストする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "片面しか見えない月のように、彼女も決して本心を明かそうとはしなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "レコードの片面を聴き終えたので、一度プレーヤーを止めて裏返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "嘆願隊やがて四時ともなりなんを、　　当主いまだに放たれず、外の面は冬のむらがらす、　　　山の片面のかゞやける。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローマを取巻く丘のように程のよい高さで盛り上る肉付きのまん中に一円銀貨の片面が少し曇って濡れていた。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地の総銀一面に浮彫の波の中に、うつくしい竜宮を色で象嵌に透かして、片面へ、兎を走らす。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローマを取巻く丘のやうに程のよい高さで盛り上る肉付きのまん中に一円銀貨の片面が少し曇つて濡れてゐた。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "金と銀と、両面の楯であって、おまえは、楯の片面の金色を、どんなに強く主張してもいいわけだ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と膝に手を置き、片面を、怪しきものの走るがごとく颯と暗くなった海に向けて、蝕ある凄き日の光に、水底のその悪竜の影に憧るる面色した時、隼の力の容貌は、かえって哲学者のごときものであった。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "子が愛づる薄葉鉄の太鼓、その紅き片面剥げしに、土盛りて、せめて植ゑむと、福寿草霜に抜き来ぬ、二株三株。",
              "citation": {
                "source": "風隠集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "読み難い仮名を本字に、本字を仮名に、天爾遠波の落ちたのを直し補った程度のものに過ぎない）　　　　片面鬼三郎自伝　われ生まれて神仏を信ぜず。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "門地高き家の三男にて綽名を片面鬼三郎となん呼ばれたる者也。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ胸を轟かしつゝ、今宵の婿がね、此の片面鬼三郎なりし事、兼ねてより御承知なりしやと尋ねしに、奈美殿、涙ながらに頭を打振り給ひて、否とよ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "われこそは生肝取りの片面鬼三郎よ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "御身の悪念は此の片面鬼三郎が受継ぎたり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "片面鬼三郎にて通りし人也。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にも吾こそは片面鬼三郎と呼ばるゝ日本一の無調法者に候。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "片面鬼三郎生年二十四歳、此処に生命を終るかと観念の眼を閉ぢむとする折しもあれ、和尚の背後、方丈に通ふ明障子の半開きたる間より紫色の美しき物影チラ／＼と動けり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――小松原の肩のあたりから片面の耳朶かけて、天井の暗さが倒に襲ったのを、熟と見ながら、これがある婦人と心中しようとした男だと頷いた。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の日電柱に寒風がうなり、吹雪の朝、電柱の片面に、雪が吹きつけられて凍っているのがちょうどその面に日でも当たっているように見える。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくみはそこに膝を突いた儘、お向ひのお家の二階屋根の片面に、黄ろい色に狭まつた夕日の影を見るとしもなく見入つてゐた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄僕等は眼隠しされた馬みたいに、もの事の片面、片面しか見て来なかったんだ。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランクリン号は二階建の寄宿舎のやうな細長い船で、屋根に覆はれて、片面に四十七の窓を持つてゐる。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
