    },
    "definitions": [
      {
        "index": 1,
        "gloss": "flurry of snow in a clear sky",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "晴れているのに風花が舞う、不思議な天気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「あっ、風花！もうそんな季節か。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "窓の外を見ると、陽の光を浴びてきらきらと輝く風花が飛んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "乾いたアスファルトの上に、はかなく消えていく風花を眺めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "風花や天城の杉を、うらら日を、何とはなくて吹きちらふその影にかも、心は寄する。",
              "citation": {
                "source": "黒檜",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌うら歎く父母の子は風花の消ぬかに散らふ和ぎにかも行くおもしろの雪祭やおもしろの雪祭や。",
              "citation": {
                "source": "黒檜",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "風花の空に顕ちて、日和うららよとの。",
              "citation": {
                "source": "黒檜",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "中江正樹氏――『風花』美しい感覚の持ち主である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "明くれば、風花に送られて湯本を發す。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "風花とは、奧山に積れる雪を風の吹送り來たる也。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちら／＼と風花が降る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風花を混じえて、頬に当たれば腐肉も割れやせん。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは霰であって土地の人は風花と呼んでいる。",
              "citation": {
                "source": "山と村",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりの寒さが、風花落ちかかる夜更けの街から街を慄えていく寒念仏の辛い境涯が、そのまましきりにいま自分の上にあてはめて考えられてきた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "）舟車跋渉幾山河、回首天涯遊跡多、濠野三千程白霧、竺洋百万頃蒼波、風花雪月望中転、春夏秋冬夢裏過、看尽吟情猶未飽、更探奇勝入南阿。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "豪州の野の三千里の白い霧、竺洋百万畝の青い波、風花雪月の景色はみるみるうちにかわり、春夏秋冬の季節は夢のようにすぎた。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十一年十二月）同心草拾遺つみ草風花日将老佳期猶渺渺不結同心人空結同心草しづこころなく散る花に長息ぞながきわがたもとなさけをつくす君をなみ摘むやうれひのつくづくし。",
              "citation": {
                "source": "我が一九二二年",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十二年日ねもすの風花淋しからざるや一月二日　武蔵野探勝会新潟行。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風花　時は、真冬だった。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そこまでを見とどけたのは、先駆の物見隊だけで、尊氏の本隊は、なお地蔵堂のあたりにとどまり、吹きすさぶ風花まじりの山颪の下にその晩は夜営していた。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょうひょうとこの日は風があって白い風花が旗や剣槍を吹きかすめた。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "風花はひる頃からほんとの雪に変り出していた。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "風花にちら／＼帰る屋島寺　夜はたちまち十時過ぎる。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "winter wind which brings scattered snowflakes or raindrops",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "北国から吹く風花が、頬に冷たく当たった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "風花が吹き始めると、漁師たちは急いで港へ船を戻した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "夕暮れ時、遠くの山から風花が里へと下りてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "skin eruptions cause by a cold or fever",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "高熱が続いた後、背中に赤い風花ができてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "医者は子供の腕を見て、「これは風邪による風花でしょう」と診断した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この薬を塗れば、風花は数日で綺麗に引きますよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      }
