    "definitions": [
      {
        "index": 1,
        "gloss": "finished product",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "工房で丹精込めて作られた木彫りの熊は、見事な完成品として展示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このソフトウェアの最新バージョンは、バグ修正と機能追加を経て、ついに待望の完成品となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女がデザインしたドレスは、細部までこだわり抜かれた、まさに芸術的な完成品だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "職人の技が光るこの包丁は、使いやすさと切れ味を両立させた完成品です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そんな時期に彼は、完成品としては日本初の、日本電気から発売されたＣＯＭＰＯ―ＢＳ／80に出合った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に日本語ワープロと呼ばれることになるこのマシンの試作機開発をスタートさせた一九七七年秋、横綱は当時一部のマニアが騒ぎ始めていたマイコン・キットを完成品に仕上げて個人用のコンピューターとして売り出す第二のプロジェクトも立ち上げていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は未完成でも（それがよろしいけれど）、制作はそれ／″＼完成品であるべし。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "わづか十年しか此世の風に曝されてゐない咲子は、或る意味で既に一つの完成品に凝まりかけてゐるやうに思へたが、年と共に其のなかにあるものが成長して行くことを考へると、何をされるか解らないやうな不安を感じて、半分厭気が差して来た。",
              "citation": {
                "source": "チビの魂",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩年の未完成品『自然科学の形而上学的原理から物理学への推移』を除くならば、之はカントの自然哲学上の注目すべき作品の殆んど最後に位いするものである。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り、私は一二のもっと小さい完成品をまず書くことにした。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビジコン社は、それまでの常識からすれば半完成品のＬＳＩ、つまりは完全に印刷が終わっておらず、白い頁の残ったままのＬＳＩを利用することを考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに対し、半完成品でそこにソフトウエアを追加してはじめて機能するＬＳＩを大量に作っておく。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この半完成品ＬＳＩ、いわばできそこないＬＳＩに、付け加えたい機能を実現するソフトウエアを加えてやれば、それ用のＬＳＩに化ける。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムカデのように足を出した完成品の集積回路――。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分で組み立ててもらえばよりいっそう分かりやすいだろうと、完成品ではなく組み立てキットとした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに完成品のコンポＢＳとなると、これまでのように「カタログに毛のはえたようなもの」といういい方は通用しなくなるだろう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "通信販売で電卓キットをさばくのにＭＩＴＳが一台あたり三九ドルを要したにもかかわらず、スーパーマーケットには二九ドルの完成品の電卓が並びはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＩＴＳのエド・ロバーツは、かねてからコンピューター技術の大衆的な普及を目指して活動を続けてきたピープルズ・コンピューター・カンパニーに、唯一存在していた完成品のアルテアを貸し出していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "完成品のパーソナルコンピューターがアメリカで続々と誕生しはじめたのは、その矢先だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アップル※やＰＥＴ、ＴＲＳ―80などの完成品は、電源を入れると同時に自動的にベーシックが起動されて命令を受け付ける状態となり、キーボードを叩くと画面上に文字を表示できるように作られていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンポＢＳは、組み立て済みの完成品として販売された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしたゲーム用ＬＳＩを使っては、完成品のゲーム機も作られた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルテアの価格がキットで四三九ドル、完成品で六二一ドルだったことを記憶する物覚えの素晴らしくよい読者は、キットとも完成品とも異なる「五〇〇ドル」に引っかかるかもしれない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし一九七五年一月号の『ポピュラーエレクトロニクス』では、アルテアのキット価格は三九七ドル、完成品は確かに四九八ドルとされていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにジョブズはマーケティングのセンスを発揮して、もしも組み立て済みの完成品の状態ならこのマシンをいくらで買ってくれるかを、集まったメンバーたちにたずねた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーマには完成品を買えば当時数十万円はしていた、電圧、電流、抵抗を測ることのできるデジタル式のマルチメーターを選んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★ＭＩＴＳのアルテアは、日本では輸入代理店となったＩＥＥコーポレーションから二八万五〇〇〇円で売り出されており、完成品には三九万円の値段がついていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてさらには、システム自体は完成品を買ってきてこれを拡張しようとする、第三世代が誕生しつつある。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "完成品のパーソナルコンピューターはベーシックのインタープリターをＲＯＭに収め、もっぱらこの言語だけを使うよう仕立てられている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷めかけた心は、完成品のパーソナルコンピューターを支える技術の出自をたどることで、いっそう熱を失っていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡＳＩＣはいわば、半完成品の状態でいったん製造され、注文に応じて最終的な加工をほどこして仕上げる〈イージーオーダー〉のＬＳＩだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あえて美術の場合のみに限ったことではないが、苦心の跡がむき出しに見え、労作の痕跡がありありと窺われているのでは、それを真の完成品と称することは未だしである。",
              "citation": {
                "source": "画室の言葉",
                "author": "藤島武二",
                "note": "青空文庫"
              }
            },
            {
              "text": "真の完成品とは即ち画面にいささかの作為も見られず、すこしの渋滞を止めないに至って初めて言い得ることであって、これこそ即ち天衣無縫の境地であるに外ならない。",
              "citation": {
                "source": "画室の言葉",
                "author": "藤島武二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
