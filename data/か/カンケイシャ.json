[
  {
    "uuid": "5178d08a-683d-50c2-b1bc-62bb34d68eeb",
    "entry": "関係者",
    "reading": {
      "primary": "かんけいしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
