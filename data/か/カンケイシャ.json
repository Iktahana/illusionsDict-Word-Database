    "definitions": [
      {
        "index": 1,
        "gloss": "person concerned",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しいプロジェクトの立ち上げにあたり、関係者全員を集めて最初の顔合わせを行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "事件の真相を究明するため、警察は多数の関係者から事情聴取をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "商品の展示会には、製造元の担当者や販売店の関係者、メディア関係者など多くの人が訪れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（昭和十六年二月校訂の時しるす）本書は昭和十二年五月内務省主催第二回神職講習会における講義を速記したものであって、昨年三月｜神祇院で印刷に附して関係者に頒布せられたが、今回｜書肆の請により同院の許しを得て新たに刊行したものである。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私が今こんな事を書かなければ、私のこの過失は関係者の外には伝わらないで済むかもしれない。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに普通の社会記事となって現われた、たとえば人殺しやけんかの表現が、ひとたび関係者の心理に触れる段になると、それらはもう決してわれわれ人間の心理でなくて全く違った「存在」の心理になってしまっている。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "会ふ人も会ふ人も、男から見ればみんな自己本位からの利害の関係者である。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍聴席は人の山を成して、被告および関係者水島友は弁護士、押丁らとともに差し控えて、判官の着席を待てり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "文楽は小屋が焼け人形衣裳が焼け、松竹会長の白井さんの邸宅や紋下の古靱太夫の邸宅にあった文献一切も失われてしまったので、もう文楽は亡びてしまうものと危まれていたが、白井さんや古靱太夫はじめ文楽関係者は罹炎に屈せず、直ちにこの国宝芸術の復活に乗りだしたのである。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "お能の関係者がよく泊る――といえば、うなずかれるのだが、いかにも鼓の音でも聴えて来そうな旅館である。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ署の玄関の石段を、固い姿勢で豹吉は登って行った――と、作者は書いたが、たしかに警察署の玄関へはいって行くことは、署員か御用商人か、新聞記者か、それとも警察の関係者以外にとっては、何か薄気味悪いものである。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから、奈落（と芝居関係者は言っている、つまり舞台の底だ）を通って楽屋へ行けるのだった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この風呂敷の問屋は、芸者に関係者はなかったが、商談などの座敷に呼ばれ、お神が出入りの芝居者から押しつけられる大量の切符を、よく捌いてくれた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを知って居た男は関係者自身で去年の秋死んでしまった。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての関係者はいかむ。",
              "citation": {
                "source": "愛と婚姻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそれ愛によりて起る処の婚姻ならむか、舅姑なにかある、小姑何かある、凡ての関係者何かある、そも／＼社会は何かある。",
              "citation": {
                "source": "愛と婚姻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに、社会に対する義務の為に止むを得ずして結婚をなす、舅姑は依然として舅姑たり、関係者、皆依然として渠を窮せしむ。",
              "citation": {
                "source": "愛と婚姻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その筋じゃ、直きその関係者にも当りがついて、早瀬も確か一二度警察へ呼ばれた筈だ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "◎此隠謀は、野口君の北海道時代の唯一の波瀾であり、且つは予の同君に関する思出の最も重要な部分であるのだが、何分事が余り新らしく、関係者が皆東京小樽札幌の間に現存してゐるので、遺憾ながら詳しく書く事が出来ない。",
              "citation": {
                "source": "悲しき思出",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "左隣の船は運送会社のマークの付いた高提灯を立て、紅白の幕で飾った会社の社員や関係者の家族の乗込んだ伝馬船で、シャツの上衣の良人が舷からガーゼの簡単着を着たこどもにおしっこをさせていますと、その妻は「酔ってるから、あなた、坊や落っことしちゃいけませんよ」と後から危がっています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "客をそうして狂わせて置き乍ら、その狂う形骸に向って心からの親切、愛嬌、敬意を払って居るマネージャー始め食堂関係者等の慇懃な態度――彼等のその態度にはまったく皮肉も狡さも無い。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが為に若し今後の芸術上の作品に真に信実な感情の光と曾て見なかつた新らしい思想の芽生とを齎らす事が出来たら、小生は全く此度の関係者達にまたとない美くしい感謝の涙を献げねばなりません。",
              "citation": {
                "source": "わが敬愛する人々に",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで関係者の戸籍調べをして置く必要がある。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが町奉行所の耳にはいって、関係者一同は厳重に取調べられた。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の関係者は追放に処せられた。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "深見氏は養子で、その実家が広島県のＫの町にあることは世間でも知っているのであるから、関係者一同が知らない筈はない。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　お筆がここから出て行く姿を、お銀がたしかに見届けたとすれば、お筆もこの事件の関係者には相違ないが、果たして男ふたりを毒殺するほどの怖るべき兇行を敢てしたかどうかは疑問であった。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こないだから持っていた考えだが、――吉弥の関係者は幾人あるか分らないのだから、僕は旅の者だけに、最も多くの恨みを買いやすいのである。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他関係者諸氏の目に見えない犠牲を加算したならば、翁の遺徳の世道人心に入る事の如何に深く且つ大きいかは到底想像も及ばない位であろう。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、能楽関係者も一般にそんな風に考えて、唯｜無暗に習った手法をその通りに固守して、それを教えて飯を喰うのを本分と心得ている向きが多いらしい。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
