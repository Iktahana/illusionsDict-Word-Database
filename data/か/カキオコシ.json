        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長時間の会議の音声を、後で確認できるように書き起こしした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "インタビューの内容を正確に記録するため、会話の書き起こしを作成した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この動画の書き起こしがあれば、内容を把握しやすくなるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「とりあえず、音声認識で書き起こしをして、後で手直ししよう」とプロデューサーは言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
