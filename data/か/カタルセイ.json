        "examples": {
          "standard": [
            {
              "text": "「うーん、風邪を引いたかな。喉がカタル性に腫れている感じがする」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "カタル性の胃炎と診断され、しばらくは消化の良いものを食べるように言われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "冬の乾燥した空気のせいで、カタル性の炎症が悪化してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それは五年前、エルフルトでカタル性の熱病に、あの高熱の胸の病にかかって以来、一度も声をひそめぬ警告である。",
              "citation": {
                "source": "悩みのひととき",
                "author": "SCHWERE STUNDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワイズの訳書を研究したヘーザーはカタル性黄疸（＊＝ウイルス性肝炎）、淋病、たぶん結核の証拠を見つけ出している。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これこれの顔色をしているから自分は何かカタル性炎症を起すのではないか。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは悲観と衰弱とが、よわよわしいカタル性の徳を我々に刻みつけているだけのことである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
