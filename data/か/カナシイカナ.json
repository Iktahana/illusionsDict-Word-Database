[
  {
    "uuid": "d6a6ca9d-2420-5ce2-be15-9179f4df7389",
    "entry": "悲しいかな",
    "reading": {
      "primary": "かなしいかな",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
      "inflections": null
