    "definitions": [
      {
        "index": 1,
        "gloss": "sad to say",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "悲しいかな、努力したにもかかわらず、プロジェクトは失敗に終わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "悲しいかな、彼は自分の過ちを認めることができなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "悲しいかな、約束の時間に誰も現れることはなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "悲しいかな、その美しい伝統工芸も後継者不足に悩んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかもその自由は、悲しいかな彼自身の教養に屬しなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽は好きかと聞くと勿論きらいではないが悲しいかな音楽の事は少しも知らぬ。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、悲しいかな、私の方が蟻より大きかつたものだから、蟻の足は岩に届かないで、私の臍の近くでつゝぱつてゐるだけだつた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しいかな惚れている。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども悲しいかな私たちは、その宇宙生命のほんの一部しか覗けません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二流であることも自覚せず、何だか一流の真似をしているつもりだが、悲しいかな天才じゃない。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、悲しいかな、この男もまた著述をなして居るとすれば、その外面の上品さのみを見て、油断することは出来ません。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しいかな今のわれらは刻々に押し流されて、瞬時も一所に※徊して、われらが歩んで来た道を顧みる暇を有たない。",
              "citation": {
                "source": "マードック先生の『日本歴史』",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しいかな、我も亦た浮萍を追ひ迷雲を尋ねて、この夕｜徒らに往事を追懐するの身となれり。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれども、悲しいかな、中途にして発露し、儂が本意を達する能わず。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しいかな美術家の特殊性といふものはその作り上げるものゝ特殊性である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しいかな、香峰は才子多病の喩へに洩れずして、其の後間もなく病みて逝きぬ。",
              "citation": {
                "source": "月の隅田川",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも探訪記者に向かって、一たん口外した話を、新聞に出してくれるななんて頼むのは、飢えた狼に向かって命乞いをするよりももっと無駄なことなのだが、素人には悲しいかな、そんなことはわからないのだ。",
              "citation": {
                "source": "或る探訪記者の話",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "非業の最期を遂げた井上金八妻女の傷は小柄だな、と眼をつけたその眼の的否をたしかめようとするらしく、一本一本と鞘から抜いてはためつ、すかしつ、見改めていましたが、悲しいかな急所のその眼が狂ったらしい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれども、悲しいかな、どなたの手に渡っているやら、むだぼねおりでござりましたところへ、こん日ここへあのかたがたがそろいのしごきでお花見にお越しとかぎつけましたゆえ、これ屈強と網を張っていたのがこんな騒ぎになりましたもと、それもこれも秘密のその文、見つけたいばっかりの一心でござりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれども悲しいかな国は今、その小判に欠けておる。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "囚人には涙もある、血もある、又よく物の味も解つて居る、實に立派な戰士だ、たゞ悲しいかな、一つも武器といふものを持つて居ない。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "囚人には涙もある血もある、又よく物の味も解つて居る、実に立派な戦士だ、たゞ悲しいかな、一つも武器といふものを持つて居ない。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しいかな、身心相食む。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ならなければ之を捨てゝ了はなければならないが、そこが悲しいかな、矢張り味噌汁や何かへぶち込んで蕎麥掻のやうにして喫べる。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "山のめききは凄いほど当ったが、訓練にも工夫をつんだが、悲しいかな老爺さんの発明は、丁度お直参の株をかったのと同じようにいつも世界の年代からおくれている。",
              "citation": {
                "source": "木魚の顔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど我は悲しいかな。",
              "citation": {
                "source": "三つのなぜ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しいかな、われわれは花を不断の友としながらも、いまだ禽獣の域を脱することあまり遠くないという事実をおおうことはできぬ。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に弔辞を書いてしまえば、何も苦しい仕事の合い間に「悲しいかな」を考えずとも好い。",
              "citation": {
                "source": "文章",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は夢を現実に見ているのですがただ悲しいかなそれは私だけにしか見ることが出来ないのでした。",
              "citation": {
                "source": "歪んだ夢",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう思うものの悲しいかなかの女はそれを探偵すべき手がかりがないのであった、父にいえばどんなに叱られるかしれない、十六にもなれば人の目につく年ごろだからめったなことをして奉公人共に後ろ指をさされることになると、あの子の名誉にもかかわる、さりとてうちすておくこともできない。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しいかな、喇嘛仏の男根や。",
              "citation": {
                "source": "北京日記抄",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、悲しいかな、まだ機械が悪いために、敵が五百米まで下りて来ないと、発射出来ないのである。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その勇士たちは、悲しいかな、みなフーラー毒ガスでねむらされているのだ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらは高麗丸の右舷、中甲板の欄干に総出で、かなしいかな、人間人間人間なんだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
