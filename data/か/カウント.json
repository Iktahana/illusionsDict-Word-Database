        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ガイガーカウンターは、放射線のカウントが異常に高いことを示していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このエリアでは、バックグラウンドの自然放射線カウントが低いので安心だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "研究室では、微量な放射性物質のカウントを測定する精密な機器が使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
