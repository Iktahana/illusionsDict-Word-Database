    "definitions": [
      {
        "index": 1,
        "gloss": "count",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今日訪れた観光客の総数をカウントしてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プレゼンテーションの残り時間を、タイマーでカウントダウンしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供が寝る前に羊をカウントする習慣がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "カウントの取り方、僕教えるよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで来れば、安売り電気店やディスカウント・ショップでバカスカ売れる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "柾生がカウント・インで歌いはじめる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "何回かやれば、うまくいくかも」「よし、じゃ、〈アイル・ゲチュー〉、テイク・ワン」　広岡が右足でカウントして、頭のベースラインを弾く。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "次ぎの番なのでカウントしたが、知らない人ばかりなので、遠慮してミスを見逃がすと、安子が、「モア、シリヤスリイ」　と言った。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "安子が私のミスを厳しくカウントするので、　プレイしながら「ベリイ、シイリヤス」と叫んだら、彼女は笑いながら、「エキスキュース、ミイ」　と言った。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　カウントを忘れたのは、須貝さんが始めよ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "須貝　僕は始めから、カウントなんか、問題にしとらんがね。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと、インターフェアがおこる、あるいはそれをカウントして、こういう日どりかもしれず、大したことはない、そうじゃあない、やめさせて五月へ入ってあとにするべきだ。",
              "citation": {
                "source": "日記",
                "author": "一九五〇年（昭和二十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡単にやってください」「水上氏が三万カウントのサマルスキー石を持って、アメリカへ帰って来た。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "カウントしてくださいね。",
              "citation": {
                "source": "復活祭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "レフト、バック、などと呟きつつ、一人でカウントをとり、ぼくはそうして六大学のリーグ戦を挙行したのだ。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論辞表を叩きつける決心だったが、鳧の奴、方寸に納めてノウ・カウントにすると保証するじゃないか？",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時からでも一回のカウントに入るんですからね」　と堀尾君は度々来たいのだが、度々と思われたくない。",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日待たせて置いて、カウントが何だのって打算的なことをなさる人は嫌いよ」　と道子さんは昨日の仇討の積りだった。",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のは見つからなかったから、ノーカウントだ」　と寛一君は又下りて行く。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに僕は三男坊だから冷飯だ」「それもカウントに入るよ。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、ひょっとして、あなたが申上げるといけないと思って態※上って参りましたのよ」「それなら然うと、早く仰有って下されば宜かったんです」「だってお話途中だったじゃございませんか」「今までカウントに入れなかったが、此奴は大敵だ」「本当よ」「彼奴はやるとなれば、何んなことでもし兼ねません。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "機体のあらゆる部分を純白に塗った、双発のヴァイカウントが、建物からそれほど遠くないところに停まっていた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗客が数人、そのヴァイカウントにむかって歩いていた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨大な背中、思いきって太い胴、そしてやはり巨大なと言わざるを得ないお尻の白人女性が、私はこんなふうにしか歩けないと、一歩ごとに宣言しているような足どりで、ヴァイカウントにむかっていた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽に読みとれるスピードで、その数字は０から９、８、７、６、５、４、３、２とカウント・ダウンされ、最後に数秒間、１の数字が残った。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきほどとおなじように、リーダー・フィルムの透明さがまずスクリーンに投射され、数字がカウント・ダウンされていって２で止まった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車で都心へ出て、スポーツ用品のディスカウント・ストアへいった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりもさらにブラックなものとして、デューク・エリントンやカウント・ベイシー。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
