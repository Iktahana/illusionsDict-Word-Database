    "definitions": [
      {
        "index": 1,
        "gloss": "to be profoundly compatible",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
