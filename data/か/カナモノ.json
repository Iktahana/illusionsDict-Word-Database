    "definitions": [
      {
        "index": 1,
        "gloss": "metal utensil",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "日曜大工に必要なネジや特殊なボルトを買いに、駅前の古い金物屋へ向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "キッチンの引き出しには、栓抜きや缶切り、お玉といった金物がぎっしり詰まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "外に置きっぱなしにしていた金物が錆びついてしまい、ネジがびくとも動かない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いい金物は手入れさえすれば一生もんだ」と、大工の父は道具を大切に扱っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "街路は冬のやうに白つちやけて、昔ながらの大道店が、ガマの油や、オツトセイや、古着類や、縞蛇や、得體のわからぬ壞れた金物類などを賣つてる。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木綿をきり売りの手拭を下谷の天神で売出した男の話は神宮外苑のパン、サイダー売りを想わせ、『諸国咄』の終りにある、江戸中の町を歩いて落ちた金や金物を拾い集めた男の話は、近年隅田川口の泥ざらえで儲けた人の話を想い出させて面白い。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉の裏側には、「ネクタイピン、カフスボタン、眼鏡、財布、その他金物類、　ことに尖ったものは、みんなここに置いてください」と書いてありました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の雑貨商店や金物店の息子たち、夏やすみで帰ったあちこちの中等学校の生徒、それからひるやすみの製板の人たちなどが、或は裸になって二人三人づつそのまっ白な岩に座ったり、また網シャツやゆるい青の半ずぼんをはいたり、青白い大きな麦稈帽をかぶったりして歩いてゐるのを見て行くのは、ほんたうにいゝ気持でした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉の裏側には、「ネクタイピン、カフスボタン、眼鏡、財布、その他金物類、　ことに尖つたものは、みんなこゝに置いてください」と書いてありました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを携えた刑事や警官が、町中の、ありとあらゆる金物店について調査を進めた結果、ちょうど七月十五日の氏神祭の日のこと、写真にソックリの学生風の青年が、乗馬｜倶楽部の者だと云って新しい藁切庖丁を一｜梃買って行った。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは駅前の金物屋から四、五年前に二円で買って来たものだ。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "間口三間くらゐの小ぢんまりした金物屋である。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五十くらゐのひとで、金物屋の越野ですが。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、失礼ですが、越野たけ、あの、金物屋の越野さんは、こちらぢやございませんか。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで何かに憑かれたみたいに、たけはゐませんか、金物屋のたけはゐませんか、と尋ね歩いて、運動場を二度もまはつたが、わからなかつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ帰ることにきめて、バスの発着所のベンチに腰をおろし、十分くらゐ休んでまた立ち上り、ぶらぶらその辺を歩いて、それぢやあ、もういちど、たけの留守宅の前まで行つて、ひと知れず今生のいとま乞ひでもして来ようと苦笑しながら、金物屋の前まで行き、ふと見ると、入口の南京錠がはづれてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佳い締り金物と見えて音も少く、しかもぴったりと厳重に鎖されたようだった。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……話の中に、田舎から十四で上京した時は、鍛冶町辺の金物屋へ小僧で子守に使われた。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "机は蚊母樹か何かで岩乗に出来てゐて、引出には真鍮の金物が打つてある。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対の方の隅には、沢のある赤いやうな木で拵へた、大分大きい箱があつて、其上に銀の小さい箱に、金で菊の紋を附けたのと、緑いろの革に銀金物を取り附けた金入らしいものとが、並べて載せてある。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今度は金物屋に行って鉛の半円鋳を六百斤ほど買集め、そっくりそのまま町外れのシロカネ屋（金属細工屋）に持って行って、これは蓬莢島から来た船の註文ゆえ、特別念入りの大急ぎで遣ってもらいたい。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　本石町の金物店へはいった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに続いて、がちゃんと何か重い金物でも堕ちたような音がしました。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日までに、君は仏・中英金物株式会社の営業部長になっていることだろう。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『けれどぼくは金物だなんてさっぱりです。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は、仏・中英金物株式会社の営業部長として、最低賃金五〇〇ポンドにて職務遂行することに、まったく同意するものである。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつを持ち帰っていただいて、金物商全員を住所とともに抜き出していただきたい。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らも金物を売るので。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに君も賛成してくれるだろうが、アーサー・ハリー・ピナー氏と仏・中英金物株式会社の仮事務所で相まみえることは、僕ら両名にしてもそれなりに興味深い経験となろう。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "上着とベストが床に落ち、扉の後ろの鈎金から、首まわりに吊り帯を巻き付け、仏・中英金物株式会社社長はぶら下がっていた。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "重さうな沓には大きい銀の金物が付いてゐる。",
              "citation": {
                "source": "十三時",
                "author": "THE DEVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "沓の金物も市民のより太い。",
              "citation": {
                "source": "十三時",
                "author": "THE DEVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙管も、沓の金物も、目玉も誰のよりも大きい。",
              "citation": {
                "source": "十三時",
                "author": "THE DEVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん銭ばかりでは全体が黒ずんでしまって、兜の色の取り合わせが悪いので、前立てや吹き返しには金銀の金物をまぜてありました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
