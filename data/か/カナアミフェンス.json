        "examples": {
          "standard": [
            {
              "text": "公園の周囲は緑色の金網フェンスで囲まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "グラウンドと校舎の間には、子供たちの安全のために金網フェンスが設けられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "隣家との境界に、目隠し効果のある金網フェンスを設置した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い金網フェンスが錆びて、ところどころ破れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "敷地の南側は十メートルほどの高台になっていて、低い金網フェンスの外から下の道まで、石を積んだ壁になっていた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
