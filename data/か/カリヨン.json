        "examples": {
          "standard": [
            {
              "text": "正午のチャイム代わりに、広場の時計塔からカリヨンの澄んだ鐘の音色が街中に響き渡る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ベルギーの古い石畳を歩いていると、どこからかカリヨンの練習をする音が風に乗って聞こえてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "披露宴の最後に鳴り響いたカリヨンの音が、新しい門出を迎えた二人を祝福しているかのようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この谷に今では長崎の教会のカリヨンが海をわたってきこえてくるが、彼はこの風光やカリヨンの幻聴などが問題ではない充実した動物だったろう。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "長崎チャンポン――九州の巻――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
