    "definitions": [
      {
        "index": 1,
        "gloss": "kagura hall (at a shrine)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古びた神楽堂の舞台裏では、出番を待つ子供たちが緊張した面持ちで控えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "境内の奥にある神楽堂が、秋の例大祭に合わせて鮮やかな朱色に塗り替えられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あそこの神楽堂、昔は近所の寄り合い所としても使われていたんだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "母屋に近い藤棚のついた二間打ち抜きの部屋と一番｜端れの神楽堂のような建て前の棟はもう借手がついていた。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "決めて帰りがけに葉子達は神楽堂の方の借主をどんな人達かと聞いて見た。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの名物という塩竈や貝多羅葉樹や、泉の三郎の鉄燈籠や、いずれも昔から同じもので、再遊のわたしには格別の興味を与えなかったが、本社を拝して横手の広場に出ると、大きな神楽堂には笛と太鼓の音が乱れてきこえた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも何か神社が残っているであろうが、かなり広い池をもった社で神楽堂が池の中にあった。",
              "citation": {
                "source": "テンコツさん一家",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、いい加減に、お神楽堂の上の莫迦のような身ぶりだとか、手つきだとかを、繰返しているのにすぎない。",
              "citation": {
                "source": "ひょっとこ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "小角力は傘もさゝずに濡れて行き蔦雄男親｜纏のやうに遊ばせる同神楽堂飴屋の傘へ釣を垂れ同　第三句、分つてもらへるだらうか。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "泊る宿もなし金もないから暗闇の神楽堂へ上ってちょっと寝た。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――斜に白くつめたくのびた石だゝみのうえをそのまゝ広い境内へ入ると、欅だの、銀杏だの、枯れた梢のたか／″＼と空にそゝる間でみたらしの手拭がそよりとも動かず、神楽堂もむなしく戸を下ろしていれば、見晴しの、むかしながらの崖のうえに並んだ茶店もたゞその心細い骸をさらしているばかりだった。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お神楽堂へ出て来るような、緋の袴の少女が四人、灯明と供物を持って入って来ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "不死の霊薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何が大変なんだ、少し落着いて物を言え、お神楽堂から飛出した潮吹みたいな風じゃないか」　平次は静かに煙草盆を引寄せました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "十七の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が仮面をつけて、故郷の讃甘神社の神楽堂で、舞ったりしたことなども、思い出された。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅軒は坐るとすぐ、「……先ほど、神楽堂の前で、武蔵が連れの子供に洩らした言葉に依れば、明日は、奥の院へ登るつもりらしい。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓芸人でも白足袋の嗜みはありますが、鎮守様のお神楽堂とは、少々勝手がちがうので、燭の明りが映えかがやく長廊下を、いかにもオズオズ、畏る畏る。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの野郎、妙な所で笛を吹いていやがるが、何しにこんな所へ舞い込んで来たのだろうか」　釘勘と金吾の二人は、腕をこまねいて社家の窓から彼の挙動を注視しておりましたが、神楽堂の上の伊兵衛自身は、笛に熱しきッていて、今は、笛以外何ものも知らない顔つきでした。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……したが、あいつと絶えずつるんで歩いていた馬春堂の姿が見えないのはどうしたものでしょう……」などと釘勘は、その手出しを思い止まっても、まだ目明し気質な気ばたらきはやまないと見えて、じっと、眼も放たずに見ておりますと、突然、群衆と神楽堂の空間を、針のような白い光が、一本の筋を描いて飛びました。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、伊兵衛が笛を持ったまま仰向けに仆れた、神楽堂の上の騒ぎよりも、その堂の下に人浪を押している群衆に目をつけて、小柄を投げた人間をじいっと物色しておるらしい眼ざしです。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその男が、神楽堂の騒ぎや周囲の狼狽を冷ややかに見やって、何処かぜ吹くかというように、人浪の中をふところ手で抜けてゆく姿が、飴屋の傘にかくれました。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ、自分たちが、秩父の神楽堂の下から双子の高原まで追いつめて行って、遂に迫ることのできなかった日本左衛門ではないか。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
