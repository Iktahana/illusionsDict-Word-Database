        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "白いキャンバスを前に、彼は迷うことなく絵を描き始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "授業が始まると、子供たちは各自のスケッチブックに絵を書き始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "どんなデザインにするか悩んだが、とりあえず大まかな線を書き始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
