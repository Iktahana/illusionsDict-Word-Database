    "definitions": [
      {
        "index": 1,
        "gloss": "to begin to write",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "卒業論文の締め切りが近いので、そろそろ真剣に書き始めないとまずい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "先生の合図で、生徒たちは一斉に答案を書き始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "久しぶりに手紙を書き始めたら、昔の友人の顔が次々と浮かんできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（書き始める）女　まあ奇麗な字を書くわねえ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（男、手帖に何か書き始める。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く手廻しをすればよいのに、元日になってから慌てて書き始める、そうして肩を痛くし胃を悪くして溜息をしているのが、傍から見ると全く変った道楽としか思われないのであった。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯のペンを用い出した余は、印気の切れる度毎に墨壺のなかへ筆を浸して新たに書き始める煩わしさに堪えなかった。",
              "citation": {
                "source": "余と万年筆",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はこの本を書き始める前、書物の歴史を勉強しておこうと図書館に出かけました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "とここまで書いてきて海よりも深く反省したのだが、ほらみろ、構成を決めずに書き始めると、アラン・ケイの目に映った東芝のダイナブックをテーマとしたはずの原稿が、もう東京ドームにおけるビガロの突然死になってしまうでしょう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き始めるには、どうしても神話を別にしなくてはならないのだ。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、いまそれに就いて書き始めるといかにも附けたりの樣に聞える虞がある。",
              "citation": {
                "source": "樹木とその葉",
                "author": "自然の息自然の聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私たち一族の不幸は母の自殺から始まる、……と、私は自叙伝を書き始めるだらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯を済ませて、さっき手紙を書き始めるとき、灰皿の上に置いた葉巻の呑みさしに火を附けて、北表の縁に出た。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし年をとると共に、嘲魔のみが力を加へれば、私も亦メリメエのやうに、「私の友人のなにがしがかう云ふ話をして聞かせた」なぞと、書き始める事にも倦みさうである。",
              "citation": {
                "source": "点心",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、頻に筆を走らせていた小野寺十内が、何かと思った気色で、ちょいと顔をあげたが、すぐまた眼を紙へ落して、せっせとあとを書き始める。",
              "citation": {
                "source": "或日の大石内蔵助",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、長いものを書き始めると、この鏡は邪魔になって、いつも寝床の上へほうり投げてしまう。",
              "citation": {
                "source": "生活",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番、自分が知っているから一時はゆきばがなくなるけれども、机の前に坐り、また、こつこつ何か書き始める。",
              "citation": {
                "source": "生活",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃から小説を書いてみたいと思い始めましたが、長い間雑文にまみれていましたので、私の筆は荒んでいて、二、三枚も書き始めると、自分に絶望して来るのです。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家中が寝静まった、深い夜の沈黙の中に、此の日記の第一頁を書き始める。",
              "citation": {
                "source": "日記",
                "author": "一九二〇年（大正九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月二十五日（月曜）「我に叛く」を書き始める。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日、一九〇三年三月二十日、いよいよジャン・クリストフを書き始める、」と私がしるしたときには、私は麦の穂束をこしらえるのに、穂をよりわけ締めつけるだけでよかったのである。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲野さんはここから書き始める。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯蒼鷺幽鬼雄の第二作「血染の昇降機」を書き始める。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私はごろりと寝がえりをうち、腹ばいになって、鉛筆を手にとり、昨夜書きかけて電灯が消え、そのままになっている草稿の文章の下へ次の字を書き始めるのである。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば列国間の外交文書に平和のためと書くのは、あたかも英語の手紙では、仇のごとくに思うている人に対しても Dear Sir と書き始めるのと同じことで、日本語に直せば拝啓とか一筆啓上とかいう何の意味もない定式の文句に過ぎぬ。",
              "citation": {
                "source": "戦争と平和",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二三年面倒を見てやったら、きっと、あッと驚くような大物を、書き始めるに相違なかろう。",
              "citation": {
                "source": "曲亭馬琴",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで旅行から歸つて、稍※心持の靜かになつた今日になつて、君に宛てた公開状を書き始めるのである。",
              "citation": {
                "source": "三太郎の日記　第二",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神さんはサラサラ何か書き始める。",
              "citation": {
                "source": "倫敦消息",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "論文を書き始める時には、まず予め思いついた論議要素を羅列する。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　手帳　以前からファラデーは種々の本を読んだときに、面白いと思うた事を手帳に書き抜いておったが、この頃からは自分の心に浮んだ考をも書き始めることにした。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして、只今この二枚目を書き始める時、スエコ口走って曰「細く書くのが道楽になっちゃった」と。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その紅い花が雨にぬれているのを眺めながら、今日もその続稿をかきはじめると、むかしの大久保があり／＼と眼のまえに浮んでくる。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二部をかきはじめるころ、『新日本文学』にのせたいという話が出て、『展望』も新日本文学へならば異存をいうすじもないという考えだったし、わたしももとより異議なかった。",
              "citation": {
                "source": "「道標」を書き終えて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
