[
  {
    "uuid": "6bc5e73b-c5df-53bc-8679-a9606751c8fe",
    "entry": "間作",
    "reading": {
      "primary": "かんさく",
      "alternatives": [
        "あいさく"
      ],
      "is_heteronym": true
    },
    "grammar": {
