      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "catch crop",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "麦の列の間に大豆を植える間作を行うことで、土地を休ませることなく効率的に活用できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うちの畑では、害虫を避けるためにトマトの株元にバジルを間作しているんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "間作は雑草の抑制にも効果があるから、農薬の使用量を減らすことができるよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "けれども一線一画の瞬間作用で、優に始末をつけられべき特長を、とっさに弁ずる手際がないために、やむをえず省略の捷径を棄てて、几帳面な塗抹主義を根気に実行したとすれば、拙の一字はどうしても免れがたい。",
              "citation": {
                "source": "子規の画",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は相当うぬぼれの強い人間であるが五年間作品を出さずにつないで行く自信はない。",
              "citation": {
                "source": "映画界手近の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども一線一畫の瞬間作用で、優に始末をつけられべき特長を、咄嗟に辨ずる手際がない爲めに、已を得ず省略の捷徑を棄てゝ、几帳面な塗抹主義を根氣に實行したとすれば、拙の一字は何うしても免れ難い。",
              "citation": {
                "source": "子規の畫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために、こんにちの文学の現象はいっそう混乱して、商業ジャーナリズムの大半を占め、紙数をより多く占めて発言している中間作家、風俗作家の文学論が、さながら文学論であるかのようにあらわれている。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "加野君が、薪炭林の中間作業に就いての詳細をよこしてゐましたが、御覧になりましたか。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十余年の長い間作者に接近した私としては、禅の即今に通じ、道元禅師の今日一日の行持に通じ、耶蘇の空飛ぶ鳥の教へに通ずる永遠の現在らしいものを生れながらにして身に著けてゐた人だと思ふ外はない。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "真鍮の金具、五重の櫓、狭間作りの鉄砲｜檣！",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔唐の賈島は、年の終に、一年間作つた詩を自ら祭つたといふ事が傳へられて、一つの文壇の佳話となつてゐるが、祭書といふことを始めたのは黄丕烈からで、これも文壇の佳話に相違ない。",
              "citation": {
                "source": "藏書家の話",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "此供養間作法、別有性海比丘一巻記。",
              "citation": {
                "source": "濫僧考補遺",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "××山のてっぺんに、上水道の貯水池が造られ、×××谷の清流に発電所が出来、二作に、間作まで稔る××の田圃が開拓されて、電車が通い始めたということなど……「兄さん、私は車掌の試験を受けて合格しました。",
              "citation": {
                "source": "あまり者",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間も、群馬県の製糸所の所長さんが見えて、いろいろ話をしたが、その人の前任者までは、朝の七時から晩の五時まで十二時間作業であって、しかも時計の針を二十分、三十分おくらして、それだけ余計の仕事をさせた。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大昔かつて我々のいうカヌカまたはコウゲであった処は、十数世紀間の地変と人間作為を経ても、まるまるその面貌を改めてはおるまい。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハートが見つけた所によると、アマサ・フィールドの区画にある通路からかなり離れた所に大掛かりな穴が掘ってあり、一味は発見前に相当長時間作業をしていたに相違ない。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　鮭の字の考　新撰字鏡といふ字書は、本朝の僧昌住といひし人、今より九百四十年あまりのむかし寛平昌泰の年間作りたる文字の吟味をしたる書也。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "この数年の間作家として一点の愧なきと申しましたが、一つ誤りをあげるなら、それは仕事のあるもの――婦人のためのものです――が当時のジャーナリズムに影響されなかったとは云えないことです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その申し出はメック夫人の素姓を隠して、逢っても挨拶をしないというチャイコフスキーの身勝手な条件まで入れて成立し、チャイコフスキーは音楽学校の教職を退いて、閑静な地に三年間作曲生活を続けることが出来た。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い間作りに作っていた里見重之の音調をやめて、持って生れた大牟田敏清の声を聞かせてやったのだ。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
