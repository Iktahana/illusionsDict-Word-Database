    "definitions": [
      {
        "index": 1,
        "gloss": "well-known face (esp. in a particular area or among a specific group)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの料亭の女将は政界にも顔利きなので、予約を取るなら彼女に頼むと良いだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回の映画祭には、国内外の映画界の顔利きが大勢集まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は地元のイベント主催者としては顔利きで、彼の尽力なしでは成功しなかっただろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの政治家は、メディア界の顔利きたちと頻繁に会食しているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "間違ヘやうもない、新聞の婦人欄でよく見覚えのある関西婦人――協会の幹事で、こちらの婦人界では顔利きの一人でした。",
              "citation": {
                "source": "黒猫",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お袋の口ではこの界隈で顔利きの親父が、帳場にでも坐っていてくれなければ、一日もこんな商売がして行かれないということであった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お島を懲しておかなければならぬような報告が、この数日のあいだに養家から交渉に来た二三の顔利きの口から、父親の耳へも入っていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "この秘書はまた顔利きであったのか楽屋へはいって見ましょうと言うので、それをみせてもらうことになった。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まだもしどこかはっきりしない点があるようでしたら、どうかおききになって下さい。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かおききんなったら、皆私がわるいんだと仰云って、ね。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだほかに、なにかおききになりたいことがありますか？",
              "citation": {
                "source": "歌う白骨",
                "author": "THE ECHO OF A MUTINY",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうブーブーを、あなたはごくたまにしかおききにならないのですから、まあおきき下さい。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
