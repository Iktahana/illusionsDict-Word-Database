  {
    "uuid": "94cfdb9f-e335-5cd4-bafd-f7e30fbe7ca4",
    "entry": "カゼ",
    "reading": {
      "primary": "カゼ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "casein",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "牛乳から抽出されたカゼは、プラスチックの代用素材としても注目を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この絵具は、カゼを固形分として配合しており、独特の質感と耐久性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "食品添加物としてのカゼの含有量を厳密に管理し、アレルギー表示を徹底する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ニハカニ　クラク　ナリマシタカゼガ　ゴウゴウ　フイテキテアメモ　ザアザア　フリマシタ　春の夕立ちは、珍しい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "サテ　コノ　テフテフモ　オハネガ　ジヨウブニ　ナルト　カゼニ　ノツテ　ウマヤノ　ヤネヲ　コエタリ、ヲガハノ　ウエニ　イツテ　ミタリ　シマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "タニガワノ　オトガ　ダンダン　チカク　ナツテ　キタ　トコロデ、トツゼン　カゴカラ　トビダシ、カゼノヤウニ　ハヤク　グングン　ニゲマシタ。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「カゼハ　フイテ　ヰナイノ？",
              "citation": {
                "source": "デンデンムシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカヤ　アヲヤ　キイロヤ　ムラサキヤ、イロイロナ　フウセンダマハ　ホホヲ　スリヨセナガラ　カゼノ　フク　ハウヘ　ナビイテ　ヰマシタ。",
              "citation": {
                "source": "ツイテ　イツタ　テフテフ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "カゼサンヤンドクレパパノオフネアブナイヨ　汽車が停った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘達が乗馬服に着換へる間に竹下と滝本と八重の父親が、街道に出て、何時ものやうに知り合ひの水車小屋から「ワカクサ」、蜜柑山の倉庫番から「アサカゼ」「ミドリ」、そして酒造家の厩から「ドリヤン」などゝいふ馬を借り出して来た。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹下はギターとランチ・バスケツトを携へてアサカゼに、ローラは捕虫網を翻してリリイに、百合子は海水着の袋を鞍につけてワカクサに、八重はローラの採集箱を肩にかけてミドリに、そして滝本は空身でドリヤンにまたがつた――蝉がかまびすしく鳴き立つてゐる森を抜けて河堤に出た。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "めったにカゼなどひいたことはなかったのに、この頃ではすぐとカゼをひいてねたりするのはまったく酒を飲まないからだと考えている。",
              "citation": {
                "source": "変なあたま",
                "author": "――最近の心境を語る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ホイッポ……カゼ……ネツ……モリミョウ。",
              "citation": {
                "source": "一太と母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノミ、シラミ、アメ、カゼに責められて、なか／＼寝つかれなかつた、落ちついて澄んでゆく自分を見詰めつゞけた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "チリリン　チリリン　チン　チリリンカゼハ　ナクトモ　スズシイナ。",
              "citation": {
                "source": "未刊童謡",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女はアメリカ人で、レーデー・カゼラインとよんだ。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで白米に不足せる成分を加へたならばよからうと考へて、カゼインや豚脂、燐、鐵、石灰などを種々の割合に加へて試驗したが、意外にも動物は、白米のみの場合と殆んど同じ樣に衰弱して死んでしまつた。",
              "citation": {
                "source": "ヴィタミン研究の回顧",
                "author": "鈴木梅太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わがカゼルラよ、我のこの羈旅にあるは再びこゝに歸らんためなり、されど汝何によりてかく多く時を失へるや。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　その日、中華料理店をでゝ、家へ戻ると、先生はカゼをひいて、ねついてしまった。",
              "citation": {
                "source": "遺恨",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生は安パンパンを買って、カゼをひいたんだぜ。",
              "citation": {
                "source": "遺恨",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "カゼをひかせちゃ、こまるから、コタツをいれようと云うと、ダメなんだ、弟の奴、子供の時から寝相がわるく、なんでも蹴とばすから、火事になる、と兄貴が仰有る。",
              "citation": {
                "source": "無毛談",
                "author": "――横山泰三にさゝぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "アル日、アヒルサンガカゼヲヒイテ学校ヲヤスンデヰルト、オネコサンガキテイヒマシタ。",
              "citation": {
                "source": "アヒルサン　ト　オネコサン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オネコサン、私ハカゼヲヒイテ、真白ナキモノヲキテネテヰマス。",
              "citation": {
                "source": "アヒルサン　ト　オネコサン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風ガヒドクテ三匹ハ　カゼヲヒキマシタ。",
              "citation": {
                "source": "三匹ノ　コグマサント　キシヤ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ウニはカゼといえる貝の卵巣なり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "カゼニ　フカレテ、ゴミハ　ウエキノ　トコロマデ　トンデキマス。",
              "citation": {
                "source": "オホサウヂ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の日記を見ると、やはり十何日か頃、神経衰弱的になって閉口して居る、今年はカゼが長いのでわるし。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分は数日来の鼻カゼがなおらぬ。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月三日　水　カゼ工合わるし　急に思い立ってコーズへ来る。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "カゼがなおっていないから。",
              "citation": {
                "source": "日記",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "月曜日までにカゼをなおすと云っている。",
              "citation": {
                "source": "日記",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
