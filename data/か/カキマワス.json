    "definitions": [
      {
        "index": 1,
        "gloss": "to stir",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このポタージュスープは、火にかけている間、底が焦げ付かないように絶えずかき回してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "朝食のシリアルに牛乳を注ぎ、スプーンで軽くかき回すのが僕の日課だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "熱いお湯にインスタントコーヒーを溶かすとき、ダマにならないようによくかき回すのがコツだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "煮る団茶、かき回す粉茶、淹す葉茶はそれぞれ、唐、宋、明の気分を明らかに示している。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "カチっと鋭い音を立てて蓋が閉まると、落とし戸の向こう、頭上の尖塔の永劫の暗黒から、かき回すような柔らかい音が聞こえたようだった。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つ一つの物音に、返答するような一種の音が頭上からやってきたのだ――なんとなくかき回すような感じで、木と木をこすりつけるような音が混じっていた。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのも、真の芸術家だけが戦慄というものの本当の解剖学や恐怖の生理学――正確にどんな線どんな比率が、潜み棲む本能や遺伝性の記憶と結びついていくのか、またいつもは眠っている不思議さを感じ取る感覚をかき回すのにふさわしい色彩のコントラストや照明効果がどんなものか――を知っているからね。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、家鴨の子のように、盥の中をかき回す時のためにも、音楽をもっていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリーの芝居の頭立った人々は、汚辱と感情とをこね合わせること、美徳に悪徳の匂いを与えること、悪徳に美徳の匂いを与えること、年齢や性や家族や愛情の諸関係をかき回すこと、などに秀でていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち何物をも信じない不安定な性質と、何物にも耳を傾けずにただ人生をかき回す理屈癖の理性と。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間業の過去をくだらなく引つかき回すのは、人間自身の冒とくでもある。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、見ませんでした……」とラスコーリニコフは記憶をかき回すように、ゆるゆる答えた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "様々な想念が繰り返し湧き起こっては頭の中をかき回すが、もはや何も考える気力のない疲労しきった脱力感がその問いかけに答えることを拒絶し、拒絶してもなお執拗に反芻される内的葛藤が隼人を苛んだ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　マリユスは火箸かまたは何か鉄器で炭をかき回す音を聞いた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "明智はしきりと例の頭の毛をかき回す癖を始めていた。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、また、机の引き出しを、くしゃくしゃかきまわす。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頽廃の土曜の夜よりも、彼等の心を乱れに乱れさせた日曜の夜の底を、泥ンまみれにかきまわす雨であった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして葉子にとっては長い時間が過ぎ去ったと思われるころ、突然頭の中を引っかきまわすような激しい音を立てて、汽車は六郷川の鉄橋を渡り始めた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに探偵的推理に熱中する時、明智が「もじゃもじゃした頭」をしきりにかきまわす癖なども、意識的か、無意識的かの模倣と言えよう。",
              "citation": {
                "source": "日本の近代的探偵小説",
                "author": "――特に江戸川乱歩氏に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お目に懸れるのは、骸骨に、腐った鉄材、それに深海魚ぐらいのところだろうよ」「いや、必ず持って来てやるよ、はははは」　談笑が、煙草の煙とアルコールの強い匂いで飽和したサロンの空気をかきまわす。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなおに――しとやかに――さりながらやたら無精にかきまわす事の出来ない厳かさを持って居る。",
              "citation": {
                "source": "繊細な美の観賞と云う事について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから暫くひっそりとなって、やがてそこらをかきまわす音が続いた。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "折々「チー」や「ポン」の懸声があちこちに起り、またガチャガチャと牌をかきまわす異国情調的な音が聴えて来ました。",
              "citation": {
                "source": "赤耀館事件の真相",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "机のヒキダシも、押入れの中のものも放りだしてひッかきまわす始末であった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで腸をかきまわすようなその怪しい音は、まさしく怪塔ロケットがこっちへ飛びもどってきたらしいのです。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウロウロ悄然としてまだどこかにお金でもあるが如くに懐をかきまわす時に至って、かねてお金持の文士の方がチッとも騒がずオモムロに懐中からズッシリふくらんだ財布をとりだすということになる。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "刻み昆布の入った擂鉢の中へ前述の醤油加減しただしを、最初少しばかり入れて、それを杉箸五本くらいを片手に持って、かきまわすのである。",
              "citation": {
                "source": "昆布とろ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "金時に料理をつくらせると、鍋に熱湯をたぎらせて調味料をぶちこみ、飯でも野菜でもなんでもかまわず投げこんで、シャモジでかきまわすだけである。",
              "citation": {
                "source": "水鳥亭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋をかきまわすことよりも、肥ダメをかきまわすことを好んだ。",
              "citation": {
                "source": "水鳥亭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "チュースと叫びつつ俺達の糸のもつれを直す『黒子』ではなくて俺達の糸を滅茶苦茶にかきまわす『白子』が舞台一杯に押し塞がったのだ。",
              "citation": {
                "source": "犬にされたカスペルの話しかけ",
                "author": "佐藤武夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（テーブルの上の書類を引っかきまわす）間。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "にんじん――かきまわすこともいらないし……。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいそう　びくついた　ごようすの　ダッチェス、　パイのなかを　かきまわすばかり。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to rummage around",
