    "definitions": [
      {
        "index": 1,
        "gloss": "in spite of",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "激しい吹雪であったにも関わらず、彼は約束の時間を一分違わず現れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "医師の強い忠告があったにも関わらず、彼女は退院したその日から仕事を再開してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "周囲からの猛烈な反対に関わらず、若手社員の斬新なアイデアを新規事業として採用した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "××府の女、六朝の血を衝けた彼女達の北方軍閥に対する憎悪は、南方の組織に関わらずその力によって北方軍閥の倒壊をまって自己を擁力しようとする陰謀、シイ・ファン・ユウも目的をそこにもっていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "楚歌一身に聚りて集合せる腕力の次第に迫るにも関わらず眉宇一点の懸念なく、いと晴々しき面色にて、渠は春昼｜寂たる時、無聊に堪えざるもののごとく、片膝を片膝にその片膝を、また片膝に、交る交る投懸けては、その都度靴音を立つるのみ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも関わらず掘出し物根性の者が多く、蚤取り眼、熊鷹目で、内心大掘出しをしたがっている。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ合衆国政府・南部社会上流階級の努力に関わらず、数年間盛んなりしも、一八六九年この結社は突如瓦解に至る。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが当夜は真暗な嵐のこととて、通行人数人の協力にも関わらず救うを得ず、警笛にて水上警察に援助を乞い、果たして遺体を得たり。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にもあれ人無き処にて、他に見せまじき所業を為せばその事の善悪に関わらず、自から良心の咎むるものなり。",
              "citation": {
                "source": "黒壁",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『銀河ヒッチハイカーズ・ガイド』の冒頭で彼は『銀河百科大事典』にも触れていて、遺漏やかなりいい加減な記述があるにも関わらず、『ガイド』が『事典』をしのぐ人気を集め始めた理由を挙げています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "中味は同じであるにも関わらず、器を変えるたびに一から値段を付け直すというやり方は、平凡社の専売特許ではありません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月にはほぼ決定稿が仕上がっていたにも関わらず、本来の目標であるエキスパンドブックでの出版は、二つの要素が重なって翌年に持ち越しました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "辞書そのものは、ずいぶん遠くのコンピューターに置かれているにも関わらず、綴りを入れると一瞬に解説が出てきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の酒量には些過ぎる程であるにも関わらず、之を飲み尽してしまうのは、福を惜しまないのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人と共に之を飲めばただ僅かに口に麹香（酒の香）を留めるだけにも関わらず、自分だけで之を飲むには堪えなくて他人と共に之を飲むというのは福を分かつのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に言った通り気が散る原因が有るのにも関わらず、強いて眼前の事を続けるから気が散る訳なのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも関わらず、平凡な才能を抱き、浅小の器量の者が、その学問は密でなく深くなく、その知識は精でなく遠くなく、その思惟考察し得るところは分かり切ったものでしか無いのに、敢然として自ら問題を解こうとする。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも関わらず、今時の人の気の鋭さは、方程式をよく理解せず、論理にも暗い薄弱劣小の頭脳で以て、大昔の英傑も説明できなかったほどの大問題に、解釈を下すようなことを敢えてする者がいる。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一部の人士は今の文人を危険視しているが、日本の文人の多くは、ニヒリスト然たる壁訴訟をしているに関わらず、意外なる楽天家である。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "故二葉亭に関する坪内君の厚情は実に言舌を以て尽しがたいほどで、私如きは二葉亭とは最も親密に交際して精神上には非常に誘掖されてるにも関わらず、二葉亭に対していまだかつて何も酬うておらぬ。",
              "citation": {
                "source": "明治の文学の開拓者",
                "author": "――坪内逍遥――",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜怒哀楽が材料となるにも関わらず拘泥するに足らぬ以上は小説の筋、芝居の筋のようなものも、また拘泥するに足らん訳だ。",
              "citation": {
                "source": "写生文",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学者を目指す大学生のフランケンシュタインは、神をも恐れぬ行為となるにも関わらず生命の謎を解き明そうと研究し、ついに人造人間を作り出した。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした場所にも関わらず、停車場前に戻り、そこに一夜を送って、サン・テチエンヌ寺の塔を宿屋の窓の外に望みながら朝霧の中に鶏の声を聞いた時は、実に彼は胸一ぱいに好い空気を呼吸することの出来る静かな田舎に身を置き得た心地がした。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一それでは、風間が吾が子を殺さねばならなかった心理が説明されていない」「それから王妃の衣川暁子には、二つの花の名を云ったにも拘らず、折れた｜雪の下を渡した……」　検事の抗議にも関わらず、法水はずけずけと云い続けた。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、口にする事が、内容の如何に関わらず、如何にも急しなく、かつ切なそうに、代助の耳に響いた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何となく陰気に薄暗くじめじめして、妙に気味の悪い厭な感じがしたので、夫人が直覚的に反対したにもかかわらず、ヘルンは一見して大いに気に入り、『面白いの家』『面白いの家』と、子供のように嬉しがって、是非それを買おうと言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、何となく心を牽かれる俳句であり、和歌の恋愛歌に似た音楽と、蕪村らしい純情のしおらしさを、可憐になつかしく感じさせる作である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気を付けていたにもかかわらず一度も柱を登る姿を見た事がない。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワールブルヒは腎臓でもわるいかと思われるように顔色が悪く肥大していて一向に元気がなかったが、ゴールトシュタインは高年にかかわらず顔色も若々しく明るい上品な感じのする人であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらずこういう口碑は人の心を三韓征伐の昔に誘う。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらずそれを見る人の心は遠い昔に起こったある何かしらかなり深刻な事件のかすかな反響のようなものを感ずる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな心持であったから、多少の病苦はあったにもかかわらず、心は不思議なくらい愉快であった。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の登った北米のフッド火山は、大なる氷河が幾筋となく山頂から流れているにもかかわらず、麓の高原は乾き切って、砂埃とゴロタ石の間に栽培した柑橘類の樹木が、疎らに立っているばかり。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
