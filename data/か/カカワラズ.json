        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "当社では国籍や年齢に関わらず、独自のスキルを持ったエンジニアを広く募集しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "過去の失敗経験に関わらず、何度でも新しい企画に挑戦できるのがこの部署の強みだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "昼夜に関わらず絶え間なく鳴り響く工事の騒音に、近隣住民は頭を悩ませている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      }
