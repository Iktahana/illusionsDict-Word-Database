    "definitions": [
      {
        "index": 1,
        "gloss": "tutelary deities of the hearth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "年の瀬になると、煤払いのついでに竈神の御札を新しいものに取り替える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うちの田舎では、竈神を怒らせると家が火事になると言い伝えられてるんよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "台所の棚の上に安置された竈神の仮面が、家族の食事を静かに見守っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "當時の上帝が後の元始天尊に進化したのか、門神が神荼欝壘（これは又蓋し雷の表象である）となつたか、井が井君となり、竈が竈神となつたか、それは別に考證を待つて定めらるべきだが、いづれにせよ早くからいろ／＼のものが祭られた。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてそれより塩竈神社にもうでて、もうこの碑、壺の碑前を過ぎ、芭蕉の辻につき、青葉の名城は日暮れたれば明日の見物となすべきつもりにて、知る人の許に行きける。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩竈神社の神楽　わたしが塩竈の町へ入り込んだのは、松島経営記念大会の第一日であった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その混雑の中をくぐって、塩竈神社の石段を登った。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩竈神社の神楽を観た時と同じような感じを以って、ただ一種の古雅なるものとして耳を傾けたに過ぎなかった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは陸前の登米、本吉、気仙の諸郡から、陸中の東磐井、江刺（以上旧仙台領）、その他これらの地方に近接した地方にわたって行なわれている竈神とて粘土や木刻の円眼船口形の怪奇な面を家々の竈前の柱に掛けておく風習があることである。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを竈神とも竈地蔵とも、また名まえそのままヒョウトクとも呼んでいる（１）。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、先生の海南小記のなか（３）には、竈神の起原に関した話として、かの炭焼き長者に縁因あることを明かされている。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "（２）（３）柳田國男著『海南小記』「蘆刈と竈神」というに詳しい。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　竈神の話はこうみてくるといずれも福神の由来談になっている。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩竈神社というのは、実に景気のよい神社であった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊勢の神様をはじめとして、たいがいの神様が甚しく景気がわるいというのに、塩竈神社は景気がすごいや。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩竈へきて塩竈神社にお詣りしないという手はないて」　神様とともに共存共栄しているから、強硬に私の方向をネジ変えてしまったネ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩竈神社もはやるし、サフラン湯も昼酒に酔っぱらッていられるわけさ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の行った十日ほど前に塩竈神社の祭礼があった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙台から塩竈、石の巻、塩竈神社の例の石段でも、石の巻の民家の勝手口のドブ石でも、みんな牡鹿半島から切りだした石なんだね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに塩竈神社というところの石段を二百段ほど登ったときにも、「もう山登りはコンリンザイやらんよ」　と、かたく念を押したのである。",
              "citation": {
                "source": "フシギな女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点に重きを置けば、唱門師はまた下級の神主・修験者・または竈神の札を配って歩き行いた舞太夫などと類を同じくするとも見られる。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩竈神祠駅ノ南一里バカリニアリ俗呼ンデ一ノ宮トイフ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの参考は越後｜蒲原などの昔話に、家の火の神すなわち荒神とか竈神とかいうものを、ホド神と謂い、また北信や岩手県下に、ホドを深く掘ると貧乏神が出るとか、一つ眼という怪物が出るという口碑があることで、ジロに関しては今はまだそういった話を聴かない。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて『大和物語』の蘆刈話の元の形かと考えてみた、近江由良の里の竈神の由来譚なども、袋中の大徳は是を事新らしく書き伝えたけれども、ちゃんとその前から沖縄の島々にも行われていたものが、もっと写実でありまた原産地の香が濃い。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "竈神之由来　昔々爺と婆があった。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "江刺地方で童話になっている竈神のヒオトコの木の面が、通例掛けて置かれる場所である。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
