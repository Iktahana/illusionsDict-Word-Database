    "definitions": [
      {
        "index": 1,
        "gloss": "ripples on a river",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夕暮れの静かな川面には、穏やかな川波が寄せていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "風が吹くと、川波がキラキラと輝き始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ボートから眺める川波は、心地よい揺れをもたらす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "……夜の蓮華の白いのの、いま真青な、麓の川波を綾に渡って、鼓の緒を捌くように響いて。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の川波は蕭条たるいろだ。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　日が陰つたり照つたりして河原道と川波の筋を金色にしたりした。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲むも飲まぬも読むも読まぬも、人※の勝手で、刀根の川波いつもさらつく同様、紙に鉛筆のあたり傍題。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "………ザヾツ、ぐわうと鳴つて、川波、山颪とともに吹いて來ると、ぐる／＼と※る車輪の如き濃く黒ずんだ雪の渦に、くる／＼と舞ひながら、ふは／＼と濟まアして内へ歸つた――夢ではない。",
              "citation": {
                "source": "雪靈記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、隅田の川波、渺々たるに、網の大きく水脚を引いたような、斜向うの岸に、月村のそれらしい、青簾のかかった、中二階――隣に桟橋を張出した料理店か待合の庭の植込が深いから、西日を除けて日蔭の早い、その窓下の石垣を蔽うて、もう夕顔がほの白い……　……時であった。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ザザッ、ごうと鳴って、川波、山颪とともに吹いて来ると、ぐるぐると廻る車輪のごとき濃く黒ずんだ雪の渦に、くるくると舞いながら、ふわふわと済まアして内へ帰った――夢ではない。",
              "citation": {
                "source": "雪霊記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "風も静に川波の声も聞えず、更け行くにつれて、三押に一度、七押に一度、ともすれば響く艪の音かな。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾万｜条ともなき、青い炎、黒い蛇が、旧暦五月、白い日の、川波に倒に映って、鞍も人も呑もうとする。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あざけるように橋の下で、びちゃびちゃと川波が鳴りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面に月をうけて立った舞妓たちの簪のびらびらが、せせらぐ川波の中で揺れていてまだ宵らしくつづいた川向うの灯が、橋を渡る夥しい人の足を浮きあがらせて賑かだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、間もなく、渦巻く彼らの団塊は、細長く山の側面に川波のように流れていった。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、そう云う内にも水嵩は益高くなって、今ではとうとう両脛さえも、川波の下に没してしまった。",
              "citation": {
                "source": "尾生の信",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝焼けの揺らめいた川波には坊主頭の死骸が一人、磯臭い水草や五味のからんだ乱杭の間に漂っていた。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が文藝倶樂部に川波と題する小説を掲戴したのに、譽め言葉をくれたのは飛上る程悦しかつた。",
              "citation": {
                "source": "永井荷風といふ男",
                "author": "生田葵山",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄干につかまつて半身乘出して見ると、目の下の川波にゆられながら、大きな泥龜が悠々と泳ぎ廻つてゐた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その月光は川波に碎け、娘の額から肩のあたりを、蒼白く照らした。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は川波に少し搖れる舷に肱をついて、つかれた肚の底から欠伸の出て來るのを噛み殺した。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "横ともなく縦ともなく、川波は随意に泡だっていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸にはぴちゃぴちゃと川波が騒いでいた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "舳の提灯が濁った水の色をぼんやり浮きだし、川波がちりちりと揺れてくだけていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴちゃぴちゃと川波の音が耳についた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "舷側にぴたぴたと川波がくだけていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝焼けの揺らめいた川波には坊主頭の死骸が一人、磯臭い水草や五味のからんだ乱杭の間に漂つてゐた。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "―或精神的風景画―",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、「千鳥」の珍しさや、娘形本領を一挙に揚棄した「玉手御前」の成功、新開拓などの出来ぬと思はれてゐたのに、「お種」――堀川波の鼓――を而も内面的に描破した実力、瓢箪棚のお園で満悦させ、色々の赤姫で、品格や器量以上に、芸で開く領域を認めさせた。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "街路が舗装で固められ、建物が直角の肩を並べ、交通機関が速力を増してくる、その中にあって、商家のお上さんや番頭などをのせ、川波にゆられながらのろのろと走る小蒸汽は、都市の煉瓦や石やコンクリートの中に穿たれてる一種の通風孔みたいに思われるのだ。",
              "citation": {
                "source": "道化役",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くまで吾々で送ってきたというよりも、遠くへまで片づけにやってきたという方が、どうも適切のような気もするね……」　この辺一帯に襲われているという毒蛾を捕える大｜篝火が、対岸の河原に焚かれて、焔が紅く川波に映っていた。",
              "citation": {
                "source": "父の葬式",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "依志子　いいえ水の上には銀色に濡れた月の煙が静かによどんで、ずっと下のあたりまできらきら輝いた川波は、寝入ったような深い夜の息をついておりました。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "弦月落ちて宵暗の星影凄し廣瀬川恨むか咽ぶ音寒く川波たちて小夜更けて秋も流れむ水遠く。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "大変に遅いじゃないか」　眉を顰めて、吐きだすように云ったのは、赭ら顔の、でっぷり肥った川波船二大尉だった。",
              "citation": {
                "source": "恐しき通夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
