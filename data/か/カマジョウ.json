        "examples": {
          "standard": [
            {
              "text": "夜空には、美しい鎌状の月が浮かんでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その鳥のくちばしは、餌を捕らえるのに適した鎌状をしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は鎌状の道具を使って、丁寧に雑草を刈り取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新種の昆虫は、鎌状の触覚を持つことで知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこへヘルメス神が鎌状の鋭刀をくれに来た。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞けば、関牧場は西の方ニオトマムの辺から起って、斗満の谷を川と東へ下り、別谷を東のトマリとして南に折れ、三川合して名をあらためて利別川の谷を下って上利別原野の一部に及び、云わば一大鎌状をなして、東西四里、南北一里余、三千余町歩、別市街も其内にある。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌首をもたげ、鎌状の毒牙がムーアの震える手に忍び寄った。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            }
          ]
        }
