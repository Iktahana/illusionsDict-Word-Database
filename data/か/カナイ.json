    "definitions": [
      {
        "index": 1,
        "gloss": "(my) wife",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「わが家内が作った料理ですので、お口に合うかどうかわかりませんが」と彼は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "出張先から家内に電話し、子供たちの様子を尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人の紹介で、家内と初めて出会った時のことを覚えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "家内は花を育てるのが趣味で、リビングはいつも華やかだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし東京へ移ってから、子供が大ぜい生れたりして、家内が狭くなった上に、貯財も少し出来て来たので、夫人のすすめで売家を一軒買うことにした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "家内のちょっとした物音や話声にも、感興を破られたといって苦情を言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさは上天気ゆえ、家内と妹を連れて、武田神社へ、桜を見に行く。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十二日は、信玄が生れた日だとか、死んだ日だとか、家内も妹も仔細らしく説明して呉れるのだが、私には、それが怪しく思われる。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あたし、桜を見ていると、蛙の卵の、あのかたまりを思い出して、――」家内は、無風流である。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程私は此の頃では、私の言ふことは可なり家内中で重くみられてゐた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "よもすがら音なき雨や種俵うぐひすや家内｜揃ふて飯時分　春の日の遅い朝飯。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日通り掛りに店の様も見れば、また阪の方に開いた裏口の竹垣から家内の模様もいつとなく知られる。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主婦や娘は台所で立働いているのを裏口の方から見かける事があるが、一体に何処となく陰気なこの家内のさまは、日を経るに従うて自分の眼に映る。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹はかよわい身一つで病人の看護もせねばならず世話のやける姪をかかえて家内の用もせねばならず、見兼ねるような窮境を郷里に報じてやっても近親の者等は案外冷淡で、手紙ではいろいろ体の好い事を云って来ても誰一人上京して世話をするものはない。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻と下女とで静かに暮していた処へ急に二人も増したのみならず、姪はいたずら盛りの年頃ではあり、家内は始終ゴタゴタするばかりでほとんど何事も手につかぬような有様であった。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹婿は日曜などにはよく家内連れで方々へ遊びに出た。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝まであんなに騒々しかった家内はしんとしてあまりに静かである。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日南洋から手紙が來て「東京の家にはお前の唯一人の叔母たる小生の母と、小生の妹と家内と三人で侘しく留守をしてゐるから一度訪ねて行きなさい」とそれに書かれてありましたが、私はそれに返事して「僕にはとても行けない。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさは上天氣ゆゑ、家内と妹を連れて、武田神社へ、櫻を見に行く。",
              "citation": {
                "source": "春晝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十二日は、信玄が生れた日だとか、死んだ日だとか、家内も妹も仔細らしく説明して呉れるのだが、私には、それが怪しく思はれる。",
              "citation": {
                "source": "春晝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あたし、櫻を見てゐると、蛙の卵の、あのかたまりを思ひ出して、――」家内は、無風流である。",
              "citation": {
                "source": "春晝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は、多少口調を改めて、そんなことを家内に教へた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "當選などは、思ひも寄らぬことで、家内にも、また家内の實家の人たちにも、「こんど、國民新聞で短篇小説のコンクールがあつて、私も書くのだが、まあ、おしまひから二、三番のところ、と思つてゐて下さい。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と何かの機會に、さう言つて、笑つたことがあるけれども、そのとき、家内の母は、ひとり笑はず、正直に淋しさうな顔をして見せて、私はそれに氣がつき、おそろしく、しよげてしまつたことがある。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と臺所の家内を呼んで、そのハガキを見せた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」家内も、一瞬、へんな顏をした。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家内の實家の母に、だい一ばんに、その新聞を見せたかつた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、實の生みの母もあるのだが、いろいろの事情から、いまは音信不通になつてゐて、親孝行したくても、なかなか、それの許されない立場に在るのであるから、せめて、この家内の母にだけでも子としての務めを、ほんのわづかでも、無力の私にできる小さい範圍内でも、何かしたいと念じてゐるのだ。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家内にも、見せたかつたのである。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家内は、その新聞を讀んで、「でも、よかつたわねえ。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は、家内をほめたく思つた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私も家内も笑つてゐるので、母も、自然に笑ひ出して、「なんだらう。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "實家の妹が、家内に袷を一枚、持つて來て、「これ、お母さんが、ねえさんにあげなさいつて。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分自身であるといふことは、嘘をつかないことであり、自分自身であることは意志的であることである。",
              "citation": {
                "source": "詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "inside the home",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
