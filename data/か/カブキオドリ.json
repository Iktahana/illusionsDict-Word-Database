        "examples": {
          "standard": [
            {
              "text": "「歌舞伎」の起源は、賑やかな踊りの「歌舞伎踊り」に遡ります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "初期歴史家たちは、「歌舞伎踊り」をより即興的でエネルギッシュな形態だったと描写しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「歌舞伎踊り」を理解することは、「歌舞伎」の進化を評価するのに役立ちます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "瀬左衛門は、真面目くさって、堺町の歌舞伎踊りを踊るのだった。",
              "citation": {
                "source": "べんがら炬燵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その陰へ、助右衛門と勘六の二人が隠れて、隆達節を真似て吹くと、大石瀬左衛門は、真面目くさった顔をして、堺町の歌舞伎踊りを踊ってみせた。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
