[
  {
    "uuid": "cda92516-4792-5778-920f-9bc63d33dd6e",
    "entry": "片帆",
    "reading": {
      "primary": "かたほ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
