    },
    "definitions": [
      {
        "index": 1,
        "gloss": "close-haul",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "嵐の中、船は片帆を上げて波を乗り切った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "強い向かい風に、ヨットは片帆で進むしかなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "片帆でも着実に進む船のように、諦めずに目標を目指した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "みるとしもなく、ま帆片帆沖ゆく舟にみとれたる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "中禅寺の湖をながめて天雲のいはひもとほる湖の上に眞白片帆の舟歸る見ゆ歌袋歌滿ちあふるなめ革のかはり袋のありこせぬかも歌袋の歌は文して格堂にからかいやりしなり。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見崎のあたり真帆片帆白し。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "片帆の力を借りながら、テンポの正規的な汽鑵の音を響かせて、木下の乗る三千｜噸の船はこの何とも知れない広大な一鉢の水の上を、無窮に浮き進んで行く。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより、「爺や茶屋」「箱根」「原口の瀧」「南瓜軒」「下櫻山」を經て、倒富士田越橋の袂を行けば、直にボートを見、眞帆片帆を望む。",
              "citation": {
                "source": "逗子だより",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "却って佃島の（鰯こ）に心を澄まし、初冬の朝の鰹にも我が朝の意気の壮なるを知って、窓の入口に河岸へ着いた帆柱の影を見ながら、この蒼空の雲を真帆、片帆、電燈の月も明石ヶ浦、どんなもんだ唐人、と太平楽で煩っていたのも、密に柳屋のお夏を健在、と思っての事であった。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "都鳥と片帆の玩具を苞に挿した形だ、とうっとり見上げる足許に、蝦蟇が喰附きそうな仙人掌の兀突とした鉢植に驚くあとから、続いて棕櫚の軒下に聳えたのは、毛の中から猿が覗きそうでいながら、却ってさまようものをしばらく彳ませ、憩わせる蔭を見せた。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士はその方をジロリと見ただけで、またすぐ沖合の灰色のジャンク船の片帆に視線はかえった。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "権徳輿の晩渡揚子江の詩に云ふ、遠岫有無中、片帆烟水上と。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「朝鮮とオ――　内地ざかいのアノ日本海イ――　揚げたア――片帆がア――アノよけれエ――ど――もオ――。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの馬山通いの背後から一艘、二艘……そのアトから追付いて来る足の速いのも……アノ三艘の片帆の中で、どれでもええから捕まえて、船頭と話して御覧なさい。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれ等を読んだ為に「都に近き山の形」を、「欝金畠の秋の風」を、「沖の時雨の真帆片帆」を、「闇のかた行く五位の声」を、――本所の町々の教えなかった自然の美しさをも発見した。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が止んだので狭い甲板に上つて眺めた私の心には、唐人の「支頤見千里、煙景非一状、遠岫有無中、片帆風水上」と云ふ詩が浮ぶのであつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれ等を読んだ為に「都に近き山の形」を、「鬱金畠の秋の風」を、「沖の時雨の真帆片帆」を、「闇のかた行く五位の声」を、――本所の町々の教へなかつた自然の美しさをも発見した。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "―或精神的風景画―",
                "note": "青空文庫"
              }
            },
            {
              "text": "』夫の伊佐奈うちほほゑめば、妻の止利はいと誇らしげ、『金色の如來阿彌陀の御經をも誦んずるわが身、『さればまた弛くはあれど、夫が淨土、海としいへば夜がたりの片帆、片羽のふしぶしもつばらに知りぬ。",
              "citation": {
                "source": "春鳥集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「梅雨に咲く花や彼岸の真帆片帆。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "梅雨に咲く花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）弟　桐城　張祖翼　逖先未定艸風雨共帰舟、言従海外遊、鐙明孤塔遠、風圧片帆遒、海水平如砥、客心間似鴎、他年応相済、莫漫説欧洲。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "山やくや舟の片帆の片あかり　　　　水颯　湖か、川か、あるいは海に近い山を焼く場合であるか、とにかく春になって山焼をする。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "その火の明りが水にうつり、またそこを行く舟の片帆にうつる、という西洋画にでもありそうな景色である。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "片帆に片明りするの遥に印象的なるに如かぬ。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたほうの足も、ずいぶん高くあげていました。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとうさんは、かたほうの足を、からだの下に高く上げていました。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ブタ飼いが、ちょうど八十六回めのキスをもらったときに、かたほうのスリッパで、ふたりの頭を打ちました。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃ、死んでからリンゴとスモモをつめて、ミイラにしてもらえるのよ」　こう言うと、ポルトガル奥さんは、日なたに寝ころんで、かたほうの目をパチパチやりました。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、あまりあわてたので靴をかたほう落としてきてしまいました。",
              "citation": {
                "source": "子どものすきな神さま",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といって、おじいさんはもう、かたほうのくつをつくりあげてしまいました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから仕事台にこしをおろして、つぎのかたほうをほりはじめました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、兵太郎君は、十日ほどまえから、かたほうの耳が耳だれで、いやなにおいのする緑色のうみをだらりとたらしていたので、みんなが、例の音楽の道具をかそうとしなかったため、くやしがっていたからである。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姫様は森のかたほとりで若者に出遇ひました――といふやうな、ト書の個所を先生が読むと、一年生でも、若者ならば若者らしい音声で、若者の科白をそらんじてゐました。",
              "citation": {
                "source": "舞踏学校見物",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちかいあったふたりが、きょうかいへむかったとき、上の姉はみぎがわにいて、下の姉はひだりがわにいましたが、まん中にいたハトに、ふたりとも、かたほうの目をたべられてしまいました。",
              "citation": {
                "source": "アッシェンプッテル",
                "author": "ASCHENPUTTEL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
