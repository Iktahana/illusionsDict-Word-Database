[
  {
    "uuid": "d5225668-5c2f-5a3f-b323-b6ba2337b7d9",
    "entry": "考えなし",
    "reading": {
      "primary": "かんがえなし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
