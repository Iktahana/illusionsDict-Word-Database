    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unthinking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あんな考えなしな発言を人前でするなんて、後で後悔しても知らないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いつも考えなしに行動するから、そうやってトラブルに巻き込まれるんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "全財産をよく分からない投資につぎ込むなんて、考えなしにもほどがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の考えなしな振る舞いのせいで、プロジェクト全体に大きな穴が空いてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「うらが始めからやらん云うのに、お前が何んにも考えなしにやりかけるせに、こんなことになるんじゃ。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、わたしたちは、ごうまんな気持から、考えなしにまきちらしたものを見て、おどろきます。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、前川の世話だと致しましたら、あの人も考えなしですわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひょいと考えなしに荷物船に乗っかって、三年余り突っ走っちゃったもんでね、おいらぐっすり休みてえんでさあ。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お上では、乱心者としてもっと寛大な処置を取ろうとなさいましたが、内匠頭は、乱心でない、上野は後の人のために生かしておけんなどと、いろいろ理屈をいったそうで、とうとう切腹に……」「あの意地張りの気短め、どこまで考えなしか分かりゃしない。",
              "citation": {
                "source": "吉良上野の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "記者は別に深い考えなしに、只一寸した好奇心に駆られて、その四十恰好の番頭にきいて見た。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも今時の人は、ヤレ流行ソレ流行と、着物の柄から髪形から、何も彼も流行となると我れ勝ちに追ッかけて、それが自分に適ろうがうつるまいが、そんなことは一切合財考えなしで随分｜可笑しな不調和な扮装をしている人が沢山あるようです。",
              "citation": {
                "source": "好きな髷のことなど",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もじつは前後の考えなしにここへ飛びこんだものの、明朝になればさっそく払いに困らねばならぬ。",
              "citation": {
                "source": "世間師",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、何にも欲しがりゃしないんだから――温室だって僕考えなしでこしらえて貰ったけど、本当はこしらえない方が正しかったのかもしれないんだし」　順二郎が余り真面目にそう云ったので、瑛子の警戒心が目醒めた。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "求めるのはいいが、Ｘ大使のいった、ちょっとした交換条件とは、一体どんなことであろうか）　私は、交換条件のことが、たいへん気になったけれど、ここで敵艦に捉えられるよりはずっとましであると思ったし、死ぬのも残念なので、遂に、前後の考えなしに、Ｘ大使の救援を求める気になった。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "其那有様で、今は西洋洗濯でまあどうやら行って居るのだけれ共、主人が考えなしにポンポンと借りて来る金を返すにいつも追われる様なので、子供の時分から貧困に頑なにさせられたお関の病的な気持は又もう一度巡って来た変転期にすっかりかたく強められて仕舞ったのである。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、料理人のつくったものなら、なんでも結構なお料理だなぞと、軽卒に考えるのも大変な考えなしであることを、私は特に言い添えておきたい。",
              "citation": {
                "source": "家庭料理の話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "その順序をもしも無茶苦茶に考えなしにした日には、どこまでも手間どれて、そうして幾枚縫っても手のあがるものではありません。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日、真吉は、東京へ着くと、すぐにお店に帰って、昨日からのことを正直に主人に話しますと、主人は、真吉の孝心の深いのに感歎しましたが、感情に委せて、考えなしのことをしてはならぬと、この後のことを戒めました。",
              "citation": {
                "source": "真吉とお母さん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいていの子供たちなら、考えなしに、いたずらをして、無理にも引きはなしてしまうのを、『ああ、雪で裂けたのだな、こんながけの上で、岩にしがみついて、一｜日として平穏に暮らしたことのない木を、かわいそうに……。",
              "citation": {
                "source": "海の踊り",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、吉雄さんは、もし自分が番をしなかったら、だれか、考えなしに、この家の前で、大きな声を出して、正ちゃんの目をさまさないものでもないと考えたから、大急ぎで、自分の家へ帰って、半紙に、「コノ家ノ、小サイ正チャンガ、ビョウキデスカラ、シズカニ前ヲトオッテクダサイ。",
              "citation": {
                "source": "幼き日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も考えなしに行っている業こそは、自然と理合に適ってくるのである。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあ、トーマス、アイピング村のばか者どもが、考えなしの大さわぎをおっぱじめやがったおかげで、おれの姿が透明で着物を身につけさえしなければ、だれにも姿をみられなくなるってことを、みんなに知られてしまったんだ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　それに、この快遊船の中で、じぶんだけがたった一人の日本人なので、いきおい、注目されたり、批評されたりしなくてはならない立場に置かれているのだと思うと、考えなしな行動はとりにくいのである。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えなしには古書を信従する事はできぬ。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラムがいなければ、あなたは過去を忘れようとはしなかったでしょうし、きっとそんなに考えなしに身体をいじめつけて仕事をしなかったでしょうし、また商売をこんなに栄えさせはしなかったでしょう。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」考えなしに聞いた。",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくも素早く空中に浮かんだのは、未熟な故、十分な考えなしに自分を非物質化してしまったからだ。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく僕は考えなしに言ったんです……。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが表向きに現われる時は、打首か追放か、我が身はおろか、一家中にまで……こんなところへ弾薬を隠しに来るほどの考えなしでも、その罪科の容易ならぬことは弁えているものと見えます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "三輪の神杉の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えなしの至りだが、あの我儘なお嬢様なるものの仕事だから、何をやり出すか知れたものではない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "もういけないとは思うが、性急に閑子を引きとるというのも、二晩の休暇を一晩で帰ってゆく閑子の気持を思うと、考えなしには出来ないし、出来たとしてもそうなったら、閑子はどうするだろう。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "「厭ですよ」彼はこうはっきりと云った、「断わって下さい」「大四郎さん」母親がまずびっくりした、「あなた、考えなしにそんなことを云って……」「考えるまでもないんです、私は婿にゆかなくともよくなったんですから。",
              "citation": {
                "source": "ひやめし物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えなしとはいわぬが、ちと功利心に燃えすぎる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
