          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔ながらの駄菓子屋のレジ代わりには、使い込まれて塗装の剥げた、年季の入った鉄製の金箱が置かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ここに今日のバザーの売り上げをしまっておいて」と、会計係の彼女からずっしりと重い金箱を渡された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "フリーマーケットの売上金を一時的に保管するため、ダイヤル錠のついたコンパクトな手提げ金箱を準備した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」「そりや大事な金箱を痛めて困るね。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "）黙って金箱から、ずらりと掴出して渡すのが、掌が大きく、慈愛が余るから、……痩ぎすで華奢なお桂ちゃんの片手では受切れない、両の掌に積んで、銀貨の小粒なのは指からざらざらと溢れたと言う。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "善吉は唯おめ／＼と身を竦ませてゐると、彼等は帳場の金箱を引つかゝへてばた／＼と逃げ出した。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は一旦その近所の太宗寺内へ逃げ込んで、金箱のなかをあらためると、銀と銭とを併せて二両ほどしか無かつた。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "金箱は本堂の縁の下へ抛り込んで立去つた。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はもうなんの分別も無しに、手近の金箱から二百両と百八十両を二度ぬすみ出して、お節の指図通りに山谷の実家へとどけたのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の父は婿の去つた時家の金箱を失つたといつて嘆息した。",
              "citation": {
                "source": "商機",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも娘がいい旦那をつかまえているので、まあ楽隠居のような訳だったのですが、その金箱が不意にこんなことになってしまっては、お父さんもさぞ力を落しているでしょうよ。",
              "citation": {
                "source": "蜘蛛の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに或る夜、その金蔵を破って金箱をかかえ出した者がある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "郡蔵は自分の不心得を深く詫びて、どうぞ内分にしてくれと頻りに頼むので、兵太夫も承知して、そんならその金箱を元のところへ戻して置けと、二人が金蔵の方へ引っ返そうとする時、郡蔵は不意に兵太夫を斬り倒して、金箱をかかえて逃げてしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又あたりを見まわして、まだ誰も来ない事がわかりますと、今度は傍にあった果物の籠を抱えて、その中にいろいろの果物を拾い込んで外套の下に隠して、傍に在る金箱に手をかけようとしました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、店のカウンターの前には、良く見ると白系露人運動の寄附金箱が、軽そうにぶら下って傾いている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上さんが毎晩五銭ずつを貯金箱に入れる事にきめて居るのだが、せめてそれを十銭ずつにしてやりたいよ。",
              "citation": {
                "source": "熊手と提灯",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっせと金箱を重くしても、娘っ子に攫われちゃあ始らないからな」　仕立屋のカールは、ルイザの方へやって来た。",
              "citation": {
                "source": "顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも自分で自分を励まして、金部屋へ引き返して、何より先に金箱の錠前を改めた。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はけばけばした外見が嫌いで、著ている燕尾服も痩せた連中のほど上手な仕立ではないが、その代り金箱の中にはお宝が唸っているのだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母がすっかりすましてきても、金箱の鍵があかないで、祖父は盗人におどしつけられていた。",
              "citation": {
                "source": "西川小りん",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪医者が玄関を広大にして盛んに流行し、売薬師が看板を金にして大いに売り弘め、山師の帳場に空虚なる金箱を据え、学者の書斎に読めぬ原書を飾り、人力車中に新聞紙を読みて宅に帰りて午睡を催す者あり、日曜日の午後に礼拝堂に泣きて月曜日の朝に夫婦喧嘩する者あり。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文子さん、どうにかならないか」　毎日人のご馳走になってすましているわけにゆかない、文子は母に貰った小遣い銭を残らずだした、二、三日すぎてかの女は貯金箱に手をつけた、それからつぎに本を買うつもりで母をだました。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これが俺んとこの金箱さ」　と、石に腰をかけ、煙管をくわえながら、矢張り池の水を見ていた植甚は、会心の笑いという、あの笑いかたをしたが、「この水のために、俺んとこの植木は精がよくなるのさ」「まるで珠でも融かしたようですねえ。",
              "citation": {
                "source": "甲州鎮撫隊",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "親方にとっては金箱だし源公から見れば恋女だ。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人は押入から金箱を取出しました。",
              "citation": {
                "source": "悪魔の宝",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙ金のなる機という可笑しな、然し面白い貯金箱を見つけて買う。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "土蔵の内部に捨てられていましたが、盗まれた金箱の位置から離れた片隅に放りだしてあったせいです。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん犯人はそのカゴで何回か土蔵から出入して、盗んだ金箱を一時的にうめておく場所との間を往復したと思いますが、盗む金箱がなくなった後にも知らずにノコノコやってきて、カゴをすてて手ブラで帰るでしょうか。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗むべき金箱がまだ有ることを知らなければ土蔵へ戻りやしないでしょう。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが一ツのカゴを置き忘れた以上は、それが不要であったことは確実ですが、金箱一ツでも小脇に抱えて持ち去るよりは背負いカゴに入れて逃げる方が楽でしょう。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも金箱を盗む時にカゴを持ってでた定助が、殺された日に家をでたときは手ブラでしたし、古墳の中に彼が残した品々にも何物かを運ぶための道具はありませんでした。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "出てゆかねばこうだぞ」　と懐中からピストルを取り出して、無茶先生につき付けました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽躁と心附かねばこそ、身を軽躁に持崩しながら、それを憂しとも思わぬ様子※｜醜穢と認めねばこそ、身を不潔な境に処きながら、それを何とも思わぬ顔色。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
