      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Garuda (man-bird deity and 'vahana' of Hindu-Buddhist myth)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "仏教美術において、迦楼羅は鳥の姿をした神として描かれることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "インド神話の迦楼羅は、ヴィシュヌ神の乗り物とされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お寺の天井画に、炎を背負った迦楼羅の姿がダイナミックに描かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "天竜・夜叉・乾闥婆より、阿脩羅・迦楼羅・緊那羅・摩※羅伽・人・非人に至るまで等しく憫れみを垂れさせたもうわが師父には、このたび、爾、悟浄が苦悩をみそなわして、特にここに降って得度したもうのじゃ。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金翅鳥は竜を常食とする大鳥で、これまた卵胎湿化の四生あり、迦楼羅鳥王とて、観音の伴衆中に、烏天狗様に画かれた者だ。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに『唐土訓蒙図彙』に示せる羽民国の人のごとき、また『仏像図彙』に見るところの迦楼羅王の形のごときは、全くわが国の天狗に類するものなれば、これらの想像のよって起こるところなかるべからず。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来年々大きな霰の降るというのは八部衆の悪神すなわち天、龍、夜叉、乾達婆、阿修羅、迦楼羅、緊那羅、摩伽羅迦等〔八部衆の悪神〕が人民を害することを大いによろこんで霰や雹を降らして、そうして収穫を滅却してしまうのである。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、おまえを好いてはいないんだ」　少し、ポチにもわかるらしいのである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中の変遷を見守って来た人、達識者は、幾多の経験の末、どうしてもこの力に結論せざるを得ないものにぶつかるらしいのです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、小木までには、またバスで、三時間ちかくかかるらしい。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さん、昼顔を読んだことが無いはずなのに、それでも勘で、わかるらしいのだ。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（これで俺も助かるらしいぞ、猿に助けられるとは不思議なことじゃ）　大塚の身体は刻々に上へ上へあげられた。",
              "citation": {
                "source": "忘恩",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小謡篁に遊ぶ童は素肌にて、さびしかるらむ、一人にて、前ゆすり、後ゆすり、竹の葉洩れの暑き陽をちりやちりちり、ちりやちりちり、見て楽しめり。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌饑ゑ饑ゑて雀がふふむ米つぶはしら玉のごとかはかなかるらむ三ましら玉、しら玉あはれ、しら玉の米、玉の米、米の玉あはれ。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "後の籠地にしひきずる、重かるらしも。",
              "citation": {
                "source": "篁",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙なくては情もなかるらむ。",
              "citation": {
                "source": "山庵雑記",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙なくては誠もなかるらむ。",
              "citation": {
                "source": "山庵雑記",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも歐羅巴に來た時に非常にてきぱき物のわかるらしい人、まごつかない人、さう云ふ人が存外後に大きくならない。",
              "citation": {
                "source": "混沌",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父母もかなしかるらむ。",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "問はぬをもなどかと問はで程ふるにいかばかりかは思ひ乱るる苦しかるらん君よりもわれぞ益田のいける甲斐なきという歌が思われます。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「月のすむ川の遠なる里なれば桂の影はのどけかるらん　うらやましいことだ」　これが蔵人弁であるお使いが源氏に伝えたお言葉である。",
              "citation": {
                "source": "源氏物語",
                "author": "松風",
                "note": "青空文庫"
              }
            },
            {
              "text": "うめの花はつはつ咲けるきさらぎはものぞおちゐぬわれのこころに梅の花さかり久しみ下｜褪せつ雪降りつまばかなしかるらむ梅の花褪するいたみて白雪の降れよと待つに雨降りにけりうめの花あせつつさきて如月はゆめのごとくになか過ぎにけり　これらはその次の集『朝の歌』に出てゐる。",
              "citation": {
                "source": "樹木とその葉",
                "author": "野蒜の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "親父の話だと、五、六〇万はかかるらしい」　三年後、一期生が五年になったときを目指して、交換留学の話がもちあがっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "曙の美しからば、その昼は晴れわたるべく、心だに優しくあらば、身の夜も楽しかるらむ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "曙の美しからば、その晝は晴れわたるべく、心だに優しくあらば、身の夜も樂しかるらむ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺社方の許可を得て、かれは何かの活動に取りかかるらしく、役宅から帰ると更に子分の松吉と亀八を呼びよせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "狐と僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ほんの眼近かにあつた答の噴水が、競争者の行手から移動風景のやうに遠ざかるらしかつた。",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどうかするとむずかるらしく、剪刀を投げられたりするから、あれは直さなければと葉子は笑いながら庸三に話すのであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "大穴の周囲に岩があって、それへ水がぶつかるらしい。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれもだれも楽しんでいる中で、宮だけは「いかなれば近江の海ぞかかるてふ人をみるめの絶えてなければ」という歌の気持ちを覚えておいでになって、遠方人の心（七夕のあまのと渡るこよひさへ遠方人のつれなかるらん）はどうであろうとお思いになり、ただ一人｜茫然としておいでになるのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々鍬を休めてボンヤリとそこいらを見まわしては又、思い出したように仕事にかかるらしい気振が見えて来た。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀しみは遠き窓より我に来ぬ夜を催す黒雲の如　恋人と世界を歩む旅に居てなどわれ一人さびしかるらん　わが脊子よ君も物憂し斯かること言放つまで狂ほしきかな　宿の近くにババリヤ公園があつて、其処にバイエルン国の精神を表示した女神像が立つて居るが、徒に巨大な許で少しも崇高な感の起らない物である。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐもうその先きは鳥居峠にさしかかるらしい、その宿はづれには、一本の大きな梨の木が立つてゐた。",
              "citation": {
                "source": "爐邊",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
