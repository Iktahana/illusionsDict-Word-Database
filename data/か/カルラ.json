[
  {
    "uuid": "6dd5c19e-7218-555e-b42e-a0a60884cbd9",
    "entry": "迦楼羅",
    "reading": {
      "primary": "かるら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
