        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "二人は代わりばんこに歩道橋を渡った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このゲームでは、プレイヤーが代わりばんこに戦略を立てる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "朝晩、代わりばんこに霧吹きで植物に水をやる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "金太郎はみんなの頭を代わりばんこになでてやって、「みんな仲よく遊んでおくれ。",
              "citation": {
                "source": "金太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "白犬のすることをじっと見つめていた二ひきの犬は、すぐに立ち上がって、おたがいに前足を取り合って、交際社会（社交界）の人たちがするように厳かに六歩前へ進み、また三足あとへもどつて、代わりばんこにご臨席の貴賓諸君に向かっておじぎをした。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわいそうに、ドルスは」　わたしたちは代わりばんこにこんなことばをつぶやいた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでアルキシーとバンジャメンが代わりばんこに、寝台のそばにつききりについていてくれた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはあなたがたみなさんに、一人ひとり代わりばんこに会って、ほうぼうの便りを持って行きましょう。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "代わりばんこに重い背嚢をしょうよりも、てんでんが軽い背嚢をしじゅうしょっているほうが楽であった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたちは代わりばんこにカピをつかまえては、かれがいやになるまでよく洗ってやった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、宵になると、小さい兄妹達がみなして代わりばんこに、梯子段を盗み足に登って行っては、宴会の灯とお嫁さんを覗きに行った。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちはこのやっかいな乳母車をかわりばんこに押していったのである。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はかわりばんこに、泉のふちの、しだやぜんまいの上に両手をつき、腹ばいになり、つめたい水の匂いをかぎながら、鹿のように水をのみました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、ぼくたちは学校へいくとき、かわりばんこに先生のポケットに手を入れていくんだ。",
              "citation": {
                "source": "うた時計",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずり落ちそうになる眠気と、倭文子の上に京子がどんな魔手を弄しているだろうとの不安とが、かわりばんこに、彼を襲って来た。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お房とお菊はかわりばんこに腰掛けた。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん、お父さん家にいるよ、お婆ちゃんも、小母ちゃんも銀座の方にこの頃通って、とても夜おそいの、だから僕だの父ちゃんが、かわりばんこに駅へむかいに行くんだよ……」　お君さんはおこったように沈黙って海の方を見ていた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二本の足をかわりばんこに動かして、まるで、目の前に希望がぶらさがっているような、あくせくした行進だ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はかわりばんこに手つだいあうことを約束しました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランプがついている下で、大きい瀬戸物のスープ入れの壺のまわりへ親子がかたまり、かわりばんこに木匙をつっこんでキャベジスープをたべた。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の前には少し黒味のかかった十銭丸二つと其よりも一寸大きい二十銭一つがかわりばんこにおどりをおどって居る。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆用事があるし、かわりばんこに出て、自分ひる間すみ子さん一人っきりにしておけず入棺がすむまで（午後六時頃）居た。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなかわりばんこにごちそうするの、あたしも、たびたびごちそうになったわ。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、三人でかわりばんこに一ツずつ話そうじゃ有りませんか」と直樹が言出した。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "お房とお菊とは、かわりばんこに腰掛けた。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてＴ君と私とをかわりばんこに見ながら、Ｓ温泉の説明をしてくれた。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は繻子のクッションの上に寝て、最近にサーカスを見物したとき眼をつけた軽業師の真似をしているらしく、片脚をかわりばんこに上へ蹴り上げていた。",
              "citation": {
                "source": "小波瀾",
                "author": "ЖИТЕЙСКАЯ　МЕЛОЧЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "両足をかわりばんこにあげているのは、かにさされないためでもありますが、便所にいきたいのをがまんしているためでもありました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新しくとりましょうよ、かわりばんこに……」　ばつがわるそうにそう言って伸子はちらりと亢奮した笑顔をした。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏草のもうすがれはじめた庭の軒さきで、かわりばんこに撮った下手な素人写真を添えて書類を出した。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい焔がゆれているような顔をしてトラヴィアタの中にあるメロディーを口笛で吹き、そうかと思うと、ブジョンヌイの歌を鼻うたでうたって、部屋じゅう歩きまわったあげく膝をまげた脚をピンピン左右かわりばんこに蹴出すコーカサス踊の真似などをした。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫く横になっていた方がいいよ」　着たまま毛布の下へ入り、湯たんぽを足の先、胃のうしろと、かわりばんこに動かして伸子は体を暖めようとした。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は「戦旗」をかりて来た日から、折にふれてはその二冊をかわりばんこにくりひろげて、読んで見るのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
