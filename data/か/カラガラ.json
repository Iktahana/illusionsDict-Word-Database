    "definitions": [
      {
        "index": 1,
        "gloss": "barely",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "最終電車に、閉まりかけたドアの間から辛辛飛び乗った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "激しい雨の中、道に迷いながらも、辛辛目的地にたどり着いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "予算不足だったが、やりくりを重ねて辛辛イベントを開催することができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「助かった、命からがら逃げてきたよ」と、彼は肩で息をしながら言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ＫＳ倶楽部の土間は、命からがら、身をもって逃がれて来た人々で埋まっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六、さすがのフウケーボー大博士も命からがらにげだした。",
              "citation": {
                "source": "ペンネンノルデはいまはいないよ　太陽にできた黒い棘をとりに行ったよ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃこそ出たぞ、と驚き慌て、得右衛門も待ち合えず、命からがら遁帰りぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの貴下が命からがらで御遁げ遊ばす処が一番｜愉快い。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "およしなさいっていうのもきかないで、お友達の狐が、或る家の家鴨を盗もうとしたので、お百姓に見つかって、さんざ追いまくられて、命からがら逃げたことでした。",
              "citation": {
                "source": "手袋を買いに",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お爺さん、これお爺さん、何をそんなに魘されてるのだよ」　すると老人の声で、「ああ怕かった、乃公が街を歩いてると、何をかんちがいしやがったのか、二人の仕事師が、だしぬけに鳶口を持って追っかけて来たのだから、命からがら逃げて来たのだよ」　と云った。",
              "citation": {
                "source": "遁げて往く人魂",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさしく、命からがらであった。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』ヴェル氏、仰天して、ころげるようにして廊下へ飛び出し、命からがら逃げかえったそうで、僕は、どうも、人のざんげを聞くことが得手じゃないのです。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨魚タマカイに追われて生命からがら独木舟に逃げ上ることもある。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　村を出はずれて峠道にさしかかるといつものように背後からがらがらと音がして町へ通ってゆく馬車が駈て来た。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "家財はもちろん型なしで、塵一っ葉残りませんけれど、それでも家の者五人は命からがら逃げまわって、まあみんな無事でした。",
              "citation": {
                "source": "指輪一つ",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは命からがら船へ帰りました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "避難列車で命からがら逃げて来たと聞いて、両親は、えらい苦労したなとしきりに同情した。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその中にまじつて、こはれ掛つた椅子にもたれて、アスピリンで微熱を下げながら、自分の運命のやうに窮地に陥ちた王将が、命からがら逃げ出すのを、しよんぼり悲しんでゐたのだつた。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼過からがらりと晴上って、蛇の目の傘を乾かすような月夜になったが、昨夜から今朝へかけて暴風雨があったので、大川は八｜分の出水、当深川の川筋は、縦横曲折至る処、潮、満々と湛えている、そして早船乗の頬冠をした船頭は、かかる夜のひっそりした水に声を立てて艪をぎいーぎい。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に砕けていて、ちっともみずからがらない女だけれど、どこか恐しく品があって、私なんざ時々我ながら頭の下がることがありますもの。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "葱十本を一両に売って、しかも買い手が命からがら逃げてゆくなどということは、ここらでも前代未聞の椿事と噂された。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが去年の春からがらりと変った。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　日本のあと、フィリピンにまわった四人は、大統領の招待を断わったとかで、空港で群衆に投石され、命からがら脱出するはめになった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "行って見たら危うくなぐられそうになって、命からがら……。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の有様などを詳さに述べたところで、結局私達が奴等に手とり脚どりされて、ぐるぐる回る水車の川下に放り込まれてしまつたゞけのことで、そんな自分の姿を偉がりやの私としては思ふだに自尊心に関はりますので止めますが、私達は命からがら向方岸へ泳ぎついたのでした。",
              "citation": {
                "source": "船の中の鼠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "格子のあく音がきこえると同時に、南向きの窓が内からがらりと明いた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしらも傍杖の怪我せぬうちと、命からがら逃げて来たのじゃ。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "久作が椿事に遭って生命からがら帰って来たのを感ちがいした喜助は、初一念を貫いて、あれから直ぐ後で、鉄路の露となって消えてしまった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "山卯の若い衆が大宅太郎を気どって出かけると、蝦蟆の妖術よりも恐ろしいのに出逢って、命からがら逃げて帰るという始末。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "格子のあく音がきこえると同時に、南向きの窓が内からがらりとあいた。",
              "citation": {
                "source": "ゆず湯",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "出しには出しても、出した荷は山と積まれたまま焼けてしまうのですから、誰も彼も生命からがら、ただ身一つになって、風呂敷包み一つも持たず逃げ出したもの……実に悲惨なことでありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "浅草の大火のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗男は、命からがら、この殺人境からのがれ出た。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、馬は置き捨てにして、命からがら池の端の辺まで逃げました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
