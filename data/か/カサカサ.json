        "examples": {
          "standard": [
            {
              "text": "夜道で、風に揺れる木の葉がカサカサと音を立てる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "袋からお菓子を取り出すとき、ビニールがカサカサと鳴った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "書類をめくる音がカサカサと静かなオフィスに響いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
