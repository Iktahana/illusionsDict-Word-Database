[
  {
    "uuid": "7b6aa2dc-af46-5412-b393-1bdb47e28045",
    "entry": "観覧席",
    "reading": {
      "primary": "かんらんせき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
