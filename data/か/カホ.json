    "definitions": [
      {
        "index": 1,
        "gloss": "flower garden",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "手入れの行き届いた花圃には、色とりどりのチューリップが咲き誇っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は毎朝、裏庭にある小さな花圃でハーブを摘むのが日課だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、見て！あの花圃、まるで絵画みたいな美しさじゃない？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この公園の花圃は、地元のボランティア団体によって守られています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "三宅花圃女史もここの門弟であった。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この祠の祭の行わるるときは、御花圃とよぶところにて口々に歌など唱いながら、知る知らぬ男女ども、こなた行き、かなた行きして、会いつ別れつしつつ相戯れて遊びくらすを習いとすとかや。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、明治二十何年という時代、三宅花圃、田沢稲舟などという婦人が、短篇小説を当時の文芸倶楽部にのせた時、出版書店は御礼として半衿一かけずつを呈上したということである。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれを沢山の花圃や植木に漑がなければならなかった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十一　お島が楽みにして世話をしていた植木畠や花圃の床に、霜が段々｜滋くなって、吹曝しの一軒家の軒や羽目板に、或時は寒い山颪が、凄じく木葉を吹きつける冬が町を見舞う頃になると、商売の方がすっかり閑になって来た壮太郎は、また市の方へ出て行って、遊人仲間の群へ入って、勝負事に頭を浸している日が多かった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "持って行った植木の或者は、土が適わぬところから、お島が如何に丹精しても、買手のつかぬうちに、立枯になるようなものが多かったが、草花の方も美事に見込がはずれて、種子が思ったほどに捌けぬばかりでなく、花圃に蒔かれたものも発芽や発育が充分でなかった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十一　お島が楽みにして世話をしていた植木畠や花圃の床に、霜が段々滋くなって、吹曝しの一軒家の軒や羽目板に、或時は寒い山颪が、凄じく木葉を吹きつける冬が町を見舞う頃になると、商売の方がすっかり閑になって来た壮太郎は、また市の方へ出て行って、遊人仲間の群へ入って、勝負事に頭を浸している日が多かった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治二十年代に三宅花圃が「藪の鶯」という小説を書いた。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花圃の小説中最も愛らしく聰明な婦人と思われている女主人公は、日本の富国強兵の伴侶として、その内助者としての女性の生活を最も名誉あるものと結論しているのである。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年花圃の良人三宅雪嶺とその婿である中野正剛等が日本の文化における反動的な一つの元老として存在したことと考え併せると、極めて興味がある。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八八年、田辺龍子（三宅花圃）が発表した「藪の鶯」が、婦人によって生まれたやや文学らしい文学の第一歩をしめした。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、花圃とおない年であった北村透谷が激しい青年の心に当時の社会矛盾を苦しんで、「当世書生気質」の半封建的な人生態度の卑屈さと無思想性に強く反撥しながら、人間の精神の高貴さを求めていた思想の動きに対しても、花圃の環境が全く無感覚に生きられていたということにも関心をひかれる。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの婦人文学者たちの教養は、花圃の内面世界よりも数歩前進してヨーロッパ文学の影響のもとにあったであろう。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三宅恒方博士の死後彼女にとってせまくるしかった家庭生活から解放されたやす子は、花圃を長老とする三宅家の監視を反撥して「未亡人論」を書いた。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと、ほんの少しずつ短いものが公表されるようになったとき、偶然三宅花圃の思い出話をよんで、そこに語られている樋口一葉と花圃との対照的な姿につよく印象づけられた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の三宅花圃が田辺龍子嬢として明治二十一年に二十一歳のとき、書かれたものである。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花圃の「思い出の人々」という昔がたりの中で、この作品が出来た前後の事情が話されている。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "作中人物の心持が惻々として迫って来るというところに筆が到るには、花圃の人生は、未だ浅くあった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、今日の公平な読者の目には、これらの識見が、決して二十歳そこそこであった花圃自身の自発性によって見出され身につけられたものばかりでないことは明瞭に写って来る。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上流の開化、欧風教育そのものでさえ、どんなに矛盾し、錯雑したものであったかということは花圃の追懐談にもその情景を溢れさせている。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花圃などは、当時の進歩的な大官の令嬢としてベッドで寝起きし、洋書を学び、洋装をして舞踏会にも出席し、家庭での男女交際ものびのびと行われていたらしい。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花圃が「藪の鶯」を出した翌る年のことだから、その刺戟で書かれたものであったろう。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し根が風癲（フーチヤン）だから、何かほかのことが頭を占めてる時は、金なんて忘れてるといつた塩梅だな」。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠音に渡るかほととぎすの。",
              "citation": {
                "source": "絶句四章",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猪が仔猪をつれて来て相撲って遊ぶところです」　赤土は何度か猪の蹄に蹴鋤かれたらしく、綿のように柔かに、ほかほか暖そうであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹄で蹴鋤いた赤土はほかほかしている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "否な当事者はまして読者諸氏にいかほどか優つた二人の激越が徐々にそのクライマックスに近づきつつあるのを感得しつつ、久々の対面の機を待ちかまへて居たか知れませんでした。",
              "citation": {
                "source": "恋愛といふもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらのなかほどへ来て、よだかはまるで鷲が熊を襲うときするように、ぶるっとからだをゆすって毛をさかだてました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」カムパネルラは、なにかほんたうに決心してゐるやうに見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "苹果だってお菓子〔〕だってかすが少しもありませんからみんなそのひとそのひとによってちがったわづかのいゝかほりになって毛あなからちらけてしまふのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
