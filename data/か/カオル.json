    "definitions": [
      {
        "index": 1,
        "gloss": "to smell sweet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "春の訪れとともに、庭のジンチョウゲが甘く優しく香るようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女が身にまとう香水は、決してきつくなく、ふわりと上品に香るのが魅力的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "焼きたてのパンの香ばしい香りが、早朝のキッチン中に心地よく香る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わあ、この花の香り、すごく癒されるね！」「本当だ、風に乗ってどこまでも香るみたいで、散歩が楽しくなるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "水の色、香る泡沫、眉引のをさな月夜をああ、誰か、影にうかがふ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　大地は黒く汝のために香る。",
              "citation": {
                "source": "杉よ！　眼の男よ！",
                "author": "富岡誠",
                "note": "青空文庫"
              }
            },
            {
              "text": "――双頬、この時愈々ほのぼのと美しく紅を散らして、匂やかな風情の四肢五体、凛然として今や香気を放ち、紫紺絖小姓袴に大振袖の香るあたり、厳寒真冬の霜の朝に咲き匂う白梅のりりしさも、遠くこれには及ばない程のすばらしさでした。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリス　（廟の前へ進みて）なつかしい花の我妹子、花を此新床の上に撒いて……あゝ、天蓋は石や土塊……其撒いた草花に夜毎に香る水を注がう。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そびゆる山は英傑の跡を弔ふ墓標、音なき河は千載に香る名をこそ流すらむ。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "松太郎は、何がなしに生甲斐がある様な気がして、深く深く、杉の樹脂の香る空気を吸つた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "松太郎は何がなしに生き甲斐がある樣な氣がして、深く深く、杉の樹脂の香る空氣を吸つた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道あたりの、アカシヤの香る並樹道を一人できままに歩いてみたいものなり。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道あたりの、アカシアのプンプン香る並樹舗を、一人できまゝに歩いてみたい。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "内日さす都めぐりの里つづき咲く梅しろき朝ぼらけかな梅が香をそよ吹き入れて衣架のころもに香る春の朝風明治二十三年の春。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は薔薇と睡蓮のふくいくと香る花束。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔無題〕薔薇よ、如何なれば休むひま無く香るや。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとひ香ることは身一つに過ぎずとも、世界は先づ我よりぞ浄まる。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花は仄かに猶｜呼吸づきぬ、あはれ、こは、臨終の女詩人の如く、香る、美くしき言葉も断続に……〔無題〕わが運命の贈りもの、恋と歌とに足る身には薔薇を並べた日が続く、真珠を並べた日が続く。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "×霜ふらぬ間に園の薔薇、乏しけれども秋の薔薇、純情の薔薇、夢の薔薇、これを摘まずば寂しかろ、べにと薄黄に香る薔薇。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自らを恋に置くなりしら玉よ香る手箱にあれと云ひつつ　今や自分は恋愛三昧の人である。",
              "citation": {
                "source": "註釈與謝野寛全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅花のあぶらが、なつかしく香るのが、雪之丞には却って胸苦しい。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お客人をおともした」　と平馬は、いかめしく言って、「客間に灯を入れろ」　その客間というのが、まだ壁の匂いがツンツン香る、床に掛物もかけてない、がらんとした、寒む寒むしい十二畳だった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏は白い山百合が香る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方は月見草が庭一ぱいに咲いて香る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海浜随処に※瑰の花が紫に咲き乱れて汐風に香る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる理由のもとに、今後のプロは古人の心の高く香るお茶なるものにはすこぶる縁遠いところに立つの他はない。",
              "citation": {
                "source": "茶美生活",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "らんの花の香る南の支那の町を、歩きまわって、日本へ渡ってきたのは、十二、三のころでした。",
              "citation": {
                "source": "春風の吹く町",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "――山の裳裾の広い原に麦は青々とのび菜の花は香る、その原なかの一すじ道　　塔の見える当麻の寺へ。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして聞こえてくる遠くのぱたぱたという足音、なみだをぬぐって近づくものに目をやると、そう、あの白ウサギがまたもどってきたんだ、おめかしして、白ヤギの手ぶくろを片手に、香る花束をもう片手に持っていてね。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃いかすみに水ぬるみ、多くの花が香る。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "海濱隨處に※瑰の花が紫に咲き亂れて汐風に香る。",
              "citation": {
                "source": "熊の足跡",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "浄海　（傍白）「青く柔らかい棘持つ薔薇、その奥ゆかしさの香る女に違いあるまい。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "朽ちた古い柴の葉と、萌え出づる新しい栗や、樫や、蝋燭のような松の芽が、醋く、苦く、ぷん／＼かおる。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おや、かおるねえさんまだねてるねえ、ぼくおこしてやろう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
