[
  {
    "uuid": "c10fe13b-4f9b-5d42-b278-a0d2655b1d1b",
    "entry": "鏑矢",
    "reading": {
      "primary": "かぶらや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
