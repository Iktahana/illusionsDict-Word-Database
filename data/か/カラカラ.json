    "definitions": [
      {
        "index": 1,
        "gloss": "parched",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "喉がからからで、冷たい麦茶を一気に飲み干した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長い日照りで、田んぼの土がからからに乾き、ひび割れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "砂漠の熱風にさらされ、唇がからからになってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "植木鉢の土がからからだ。早く水をやらないと枯れてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "五人女にも、於七が吉三のところへ夜決心してしのんで行って、突如、からからと鈴の音、たちまち小僧に、あれ、おじょうさんは、よいことを、と叫ばれ、ひたと両手合せて小僧にたのみいる、ところがあったと覚えているが、あの思わざる鈴の音には読むものすべて、はっと魂消したにちがいない。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは思はず窓からからだを半分出してそっちを見あげました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は急いで佐野の楽屋に這入ってみると、彼は武士姿に扮して、鏡の前で人形のように白粉を真白に塗っていたのが、妾を認めると、不意にからからと空虚な笑声をたてて妾に近寄ってくるのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すつかり葉をふるひ落した裸のポプラ並木、からからに凍りついた歩道、明りを消し、二重窓を降して冷たい沈默を包んでゐる煉瓦や石造りの暗い家並、毎日毎夜の不安な空氣に脅かされてゐる町は、朝から曇つたままに暮れ落ちた暗澹たる夜空の下に、わけても眞夜中過ぎのその夜は、人通さへ稀に無氣味な程に鎭まり返つてゐた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時、彼等は、帰りに、丘を下りながら、ひょいと立止まって、顔を見合わせ、からから笑った。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは思わず窓からからだを半分出してそっちを見あげました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからからだ中からつめたい汗が湧きました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　とからからと笑った、慎み深そうな打見よりは気の軽い。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（異なことをいうようだが何かね、世の中の女が出来ねえと相場がきまって、すっぺら坊主になってやっぱり生命は欲しいのかね、不思議じゃあねえか、争われねえもんだ、姉さん見ねえ、あれでまだ未練のある内がいいじゃあねえか、）といって顔を見合せて二人でからからと笑った。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は機を逸せず、からからと高笑いした。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "檻の底に車輪の脚がついてゐるらしくからからと音たてて舞臺へ滑り出たのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "檻の底に車輪の脚がついているらしくからからと音たてて舞台へ滑り出たのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木ぎれでひいた横の線、ここからからから　　かけてつた。",
              "citation": {
                "source": "輪まはし",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは思わず窓からからだを半分出して、そっちを見あげました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつきさんおつきさん　まんまるまるるるん　おほしさんおほしさん　ぴかりぴりるるん　かしわはかんかの　　　かんからからららん　ふくろはのろづき　　　おっほほほほほほん。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右から二ばん目の鹿が、俄かにとびあがって、それからからだを波のようにうねらせながら、みんなの間を縫ってはせまわり、たびたび太陽の方にあたまをさげました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジヨバンニは思はず窓からからだを半分出して、そつちを見あげました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「図星をさされたね」　渡瀬はまたからからと笑って、酒に火照ってきた顔から、五分刈が八分ほどに延びた頭にかけて、むちゃくちゃに撫でまわした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤に、黄に、紫に、からからに乾いて蝕まれた野葡萄の葉と、枯｜蓬とが虫の音も絶えはてた地面の上に干からびて縦横に折り重なっていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "敲き大工の息子ですから、几帳面に長く坐っていると立てなくなりますよ」　渡瀬さんはそういって、片眼をかがやかしながら、からからと笑って膝を崩した。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "からからといっても、渡瀬さんの笑いには声は出なかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云ってからからと笑いました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お咲はすぐ傍に室子の母親のいるのに気付き、普段に戻って、からからと笑った。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄ぼけた様な雲のなかに、ちらちらと饒に残光を保つ明け方の星空の元に、山刀や弁当の包を太縄で結わえ付けた幾つもの男達の空車の歯が、からからと音を立てて、やがて次の村落の方へ消えて行くと、跡は森閑として、家内の者はにわかに睡眠不足の眼をしばだたき出すのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "も一度からからと響くと思うと、若菜家の格子のカタンと開く音。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お正月は何処まで、　からから山の下まで、　土産は何じゃ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつきさんおつきさん　まんまるまるゝゝん　おほしさんおほしさん　ぴかりぴりるゝん　かしははかんかの　　　かんからからゝゝん　ふくろはのろづき　　　おつほゝゝゝゝゝん。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山男が嬉しがって泣いてぐるぐるはねまわって、それからからだが天に飛んでしまうくらいいいものをやりたいなあ」　おじいさんは消えたランプを取りあげて、「うん、そういういいものあればなあ。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
