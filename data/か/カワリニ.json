        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「この宿題を手伝ってくれる？ 代わりに、今日のランチを奢るから」「よし、交渉成立だ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "秘密を教える代わりに、君が持っているあの限定フィギュアを僕に譲ってほしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "家賃を少し安くしてもらう代わりに、アパートの共用部分の清掃を週に一度引き受けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「私が夕飯を作る代わりに、明日のゴミ出しと風呂掃除をお願いね」「わかった、任せて」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
