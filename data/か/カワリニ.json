    "definitions": [
      {
        "index": 1,
        "gloss": "instead of",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「急用で出られなくなった彼の代わりに、私が本日の司会を務めさせていただきます」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "キャンプで飯盒を忘れてしまったので、代わりに厚手の鍋を使って米を炊いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「外が雨だから、散歩に行く代わりに家でボードゲームでもしない？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "コーヒーを飲みすぎるのをやめて、代わりに白湯を飲む習慣を始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "王が代わりに自分の弓を与えたのを引き絞ってみて「弱い弱い、大王の弓にはあまり弱い」と言って弓を投げ捨て、剣と盾とを取って勇ましく戦った。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで手足の指などは自分のからだの一部とは思われないように冷え凍えてこちこちしている代わりに頭の中などはいいかげんにあたたかいものがよい程度に充実しているような気がしている。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから生まれる効果は一プラス一が二になる代わりに三になり四になり十になるようである。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでｇｒの代わりにｆｒを取ってみると英国の激怒 fury, Ｌの furia, furere に対する。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ｇｒの代わりにｇｄを取ってみると、アラビアの動詞 ghadiba（怒り）の中に見いだされる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "音が聞こえてから、目でその音源を追究する代わりに、カメラを回してそれを追究する。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地震の現象でも大小の地震が不断になしくずしに起こっている代わりにたとえば中部アジアなどで起こるような非常に大規模な地震はむしろまれであるように思われる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の神秘とその威力を知ることが深ければ深いほど人間は自然に対して従順になり、自然に逆らう代わりに自然を師として学び、自然自身の太古以来の経験をわが物として自然の環境に適応するように務めるであろう。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも述べたように自然の恵みが乏しい代わりに自然の暴威のゆるやかな国では自然を制御しようとする欲望が起こりやすいということも考えられる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人は西洋人のように自然と人間とを別々に切り離して対立させるという言わば物質科学的の態度をとる代わりに、人間と自然とをいっしょにしてそれを一つの全機的な有機体と見ようとする傾向を多分にもっているように見える。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかといって太平のシャンゼリゼーの大通りやボアの小道を散歩するのに、まさか弓矢や人殺し用の棍棒や台所用のパン棒を携えるわけにも行かないから、その代わりに何かしら手ごろな棒きれを持つことになったのではないかとも想像される。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実在の三次元の空間の一次元を割愛してただ二次元の断面に限定する代わりに、第四次元たる時間を一次元空間に投射することによって時間の経過をわれわれの任意に支配するという考えは両者に共通のものと考えられる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやもうから意気地がござりません代わりにゃ、けっして後ろ暗いことはいたしません。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さなブーメラング形の翼の胚芽の代わりにもう日本語で羽根と名のつけられる程度のものが発生している。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれは時の代わりに或る何かのエネルギーあるいは「作用」のごとき量を基本的のものとしてこれを空間と対立させる事によって、新しき力学的系統を立て直す事は不可能であろうか。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "活火山だけだと m = 2 なる代わりに N = 14 となるので R = 10.3 でやはりほぼ同値となる。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の酷寒には水滴の代わりに美しい羽毛状の氷の結晶模様ができる。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "原子の場合にわれわれは個々の原子の状態を確定する代わりに、ただその確率を知ると同様に、たとえば割れ目の場合でも精密な形を記載することはできなくても、その統計的特徴を把握することができるであろうと想像するのは、必ずしも不倫ではあるまいと思われる。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ理学士｜藤野米吉君が、液の代わりに製菓用のさらし餡を水で練ったものの層に熱対流を起こさせる実験を進めた結果、よほどまで、上記自然現象の機巧の説明に関する具体的な資料を得たようである。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上のものとは少し違った部類のものであるが、氷柱や鐘乳石が簡単な円錐形または紡錘形となる代わりに、どうかすると、表面に週期的の皺を生じ、その縦断面の輪郭が波形となることがある。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは雪の代わりに他の可溶塩類を使った実験ができる見込みである。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この天成の妙機を捨てる代わりに、これを活用してその長所を発揮するような、そういう「科学の分派」を設立することは不可能であろうか。",
              "citation": {
                "source": "感覚と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人より先に人のまだ行かない所へ行き着くこともできる代わりに、途中の道ばたあるいはちょっとしたわき道にある肝心なものを見落とす恐れがある。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の言葉の音波列を分析して、その組成分の中からその基音ならびに低いほうの倍音を除去して、その代わりに、もとよりはずっと振動数の大きい任意の音をいろいろと置き換えてみる。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう地方のそばに、割合に冷たい空気におおわれた地方がありますと、前に言った地方の、暖かい空気が上がって行くあとへ、入り代わりにまわりの冷たい空気が下から吹き込んで来て、大きな渦ができます。",
              "citation": {
                "source": "茶わんの湯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともその符徴はたいていだれでも知っていたので、秘密の暗号でもなんでもなくただ数字の代わりにかたかなを使ったというだけのものであった。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで冬が来るとからだは全くいじけてしまって活動の力が減退する代わりに頭のほうはかえってさえて来て、心がとかくに内側へ向きたがる、そのせいかもしれない。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして家が丈夫になると大地震でこわれる代わりに家全体が土台の上で横すべりをする。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度影を隠した銀座の柳は、去年の夏ごろからまた街頭にたおやかな緑の糸をたれたが、昔の夢の鉄道馬車の代わりにことしは地下鉄道が開通して、銀座はますます立体的に生長することであろう。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを予防する人柱の代わりに、今のうちに京橋と新橋との橋のたもとに一つずつ碑石を建てて、その表面に掘り埋めた銅版に「ちょっと待て、大地震の用意はいいか」という意味のエピグラムを刻しておくといいかと思うが、その前を通る人が皆円タクに乗っているのではこれもやはりなんの役にも立ちそうもない。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
