        "examples": {
          "standard": [
            {
              "text": "お土産にもらった加賀友禅には、美しい加賀紋があしらわれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の家の家紋は珍しい加賀紋の一つだと聞いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "加賀紋のデザインは、伝統的な美意識が感じられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "下には鼠縮緬の引かえしを着、上には黒｜羽二重の両面芥子人形の加賀紋の羽織を打ちかけ、宗伝唐茶の畳帯をしめていた。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "下には、鼡縮緬の引かえしを着、上には黒羽二重の両面芥子人形の加賀紋の羽織を打ちかけ、宗伝唇茶の畳帯をしめている。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒ちりめんに加賀紋の羽織を着て、風呂敷ほどの絹半巾を鼻からまいて、車からおりると、「おッしょさん――」て鼻声を出して、踊るように袖をバタバタさせて、「おお寒む寒む、はよう温かいものでもおくれ。",
              "citation": {
                "source": "明治座今昔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼やかな軟風にさざなみを立てている不忍池畔の池添い道を、鉄色無地の羽二重の着流し姿に、橘の加賀紋をつけた黒い短か羽織茶色の帯に、蝋塗細身の大小の落し差し、編笠にかくれた面立は解りませぬが、年のころは三十あまりと思われるのが、只一人、供もつれず、物思いがちにブラリブラリと逍遙っておりました。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
