        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "皆様方々、本日はお忙しい中、お集まりいただきありがとうございます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "資料の配布は、出席されている方々にお配りください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "先生方々のご指導のおかげで、無事卒業することができました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ご参加いただいた方々には、ささやかですが記念品をご用意しております。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この度のイベントには、全国から多くの方々にご来場いただきました。本当に嬉しいです！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
