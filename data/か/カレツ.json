      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "severe",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "わずかなミスも許されない苛烈な出世競争に身を置き続けるうちに、彼は次第に心身ともに疲弊していった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あんな苛烈な取り調べを何時間も受けたら、無実の人だって精神的に追い詰められてしまうよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "冬の峠を越えようとした一行の行く手を、視界を完全に奪うほどの苛烈な吹雪が容赦なく阻んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "芸術の尊厳、自我への忠誠、そのような言葉の苛烈が、少しずつ、少しずつ思い出されて、これは一体、どうしたことか。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、戦争がもっと苛烈になって来て、にぎりめし一つを奪い合いしなければ生きてゆけないようになったら、おれはもう、生きるのをやめるよ。",
              "citation": {
                "source": "たずねびと",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日、一日、僕には、いまのこの世の中の苛烈が、身にしみる。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か、こう苛烈なことを。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄洋社と愛国社に向って現今の共産党以上の苛烈な圧迫を加えたものであったが、これに対して愛国社が言論に、玄洋社が腕力に堂々と相並んで如何に眼醒しい反抗を試みたかは天下周知の事実だからここには喋々しない事にする。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十四回日本美術院出品の「仔馬」はその抒情性に於いて隠されてゐる作者の人間的な優しさを露はしたものである、しかし奥村氏の人柄の優しさは、その人との対座に於いては感ずることができるが、作品の上ではそれとは反対の極限を画風の上で示す、土牛氏の芸術観は厳格であり、苛烈なものがそれである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "その教授振りが、私は、自分でも吃驚りした程、厳格で、彼等は稍々ともすれば苛烈な面罵を享け続けてゐたのである。",
              "citation": {
                "source": "ラガド大学参観記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い間のここでの生活と、彼がつきおとされた運命の苛烈さのゆゑに、すこしは頭もみだれかけて來たものであらうか。",
              "citation": {
                "source": "盲目",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その芸術必然の人間的真情が歴史と文学との深刻苛烈な葛藤にいかに処しつつあるかが、日本とはかぎらず世界を一貫して現代文学の課題なのであると思う。",
              "citation": {
                "source": "歴史と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会情勢の波瀾が内外の圧力で純文学末期の無力な自我から最後の足がかりを引攫おうとしたとき、そのような苛烈な現実を歴史的な動きの中に把握してゆく精神を既に喪っていた自我がそれぞれのとりいそいだ転身の術によって自ら歴史の中に立つ気力を失った自我を託すべき地盤をさがし求めた。",
              "citation": {
                "source": "文学精神と批判精神",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、作者は自身の気構えのつよさに現実の苛烈さを錯覚しているところもある。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つの世界大戦を経て、地球上には、より新しい民主勢力が拡大し、人類の理性は、ますます苛烈な実践をもとめられ試煉を経つつあります。",
              "citation": {
                "source": "若き僚友に",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリティシズムを創作活動の衰えのように見るのは、クリティシズムを創作活動と全く共通性のない本質から発するものと見るからであり、従って之を創作活動の最も卑屈な奴隷と見るか、又は逆に最も苛烈な刑執行人と見るか、する、からである。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう社会生活の上に生じた笑いの欲望につづいて、五年間ソヴェト同盟が耐えて来たナチとの闘争は、七百万人の命を犠牲とする苛烈なものであった。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会生活におけるそのことの必然を認めることさえ罪悪とした軍部の圧力は、若い精神に、この苛烈な運命に面して自分としてのすべてに拘泥することをいさぎよしとせず、それをみにくいことと思わせるほどに成功していた。",
              "citation": {
                "source": "生きつつある自意識",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者にそれを自省する力がないならば、せめて読むものとしてわたしたちは、このように非人間で苛烈な生のたたかいが女性の上や子供の上に強いられる戦争そのものこそ絶滅されなければならないと抗議せずにいられない。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、人民生活と文学との苛烈さは、「朝鮮ヤキ」のすぐれた作品を最後として譲原昌子を結核にたおした。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "官製の報道員という風な立場における作家が、窮極においては悲惨な大衆である兵士や、その家族の苛烈な運命とは遊離した存在であり、欺瞞の装飾にすぎないことが漠然とながら迫ってきたからであろう。",
              "citation": {
                "source": "歌声よ、おこれ",
                "author": "――新日本文学会の由来――",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争の年々は、私たちすべてに、苛烈な教訓を与えた。",
              "citation": {
                "source": "ある回想から",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど戦局は苛烈であり、空襲は激化の一路にあります。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "リアリズムの批評的精神は、單に空虚放慢なる幻影を拂拭して、苦澁にして苛烈なる物質的現實を暴露することに止まるべきであつたらうか。",
              "citation": {
                "source": "生みの力",
                "author": "片上伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "戰爭が段々苛烈になつて來ると、この村でも早朝から女の集りをして竹槍のけいこをするやうになり、蝶子もびつこをひいて國民學校の庭に出掛けて行つた。",
              "citation": {
                "source": "うき草",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとむき出しに時代の運命の荒っぽさを見て、その苛烈な人間の運命への母性的なものとして妻を考えると思う」　順助の顔の上には、あのとき海岸で犬と遊んでいたときのような、それをもっと濃くしたような寥しさと熱情のいり混った表情が拡った。",
              "citation": {
                "source": "夜の若葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そうしているうちに、ふと余の瞳に映じたものがあって、その衝動の苛烈さには、思わず双眼鏡を取り落したほどだった。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺、全部焼け野原で、あたりに人影も稀だったが、苛烈な空襲下、日本服の着流しの人は如何にも珍しく、謂わば時勢を知らない流行外れなのである。",
              "citation": {
                "source": "楊先生",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る生活の中に生じる波瀾かっとうは非常に苛烈であって、異常であるが、それに対する理解が驚くべき見とおしによって貫かれていて、当事者がそれを悲劇以上の把握で捉えて生きぬく場合、それは文学に描かれて悲劇の程度に止っているであろうか。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三四年（昭和九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "同乗の西田君に露西亜のカバレエへ案内されたが、踊子の露西亜娘は総べて頬が痩せ落ちて、さながら怪異図中のものであり、一杯のウオツカは苛烈にして、予等は唯だ其れを前にするのみであつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふい討ちであり苛烈であった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "風に吹かれつ、わが来し方に茫然としぬ、……涙しぬ。",
              "citation": {
                "source": "夏と私",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、おそらくさつぱり駄目だらう、といふ予想を裏切つて校長も農民の誇りを傷つけるやうなことはなく、抜きつ抜かれつ、水をこぼすまいとして走る、組合長と村長の後を続いた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
