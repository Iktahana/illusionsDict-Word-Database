[
  {
    "uuid": "cbe440ae-e016-5431-9f80-b09f3d40a3c9",
    "entry": "苛烈",
    "reading": {
      "primary": "かれつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
