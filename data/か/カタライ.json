        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼らは互いに変わらぬ語らいを誓い、結婚式を挙げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国王は臣下からの語らいを受け入れ、忠誠を約束した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古代の部族では、血の誓いによって語らいが結ばれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
