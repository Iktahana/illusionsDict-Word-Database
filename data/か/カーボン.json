        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ロードバイクのフレームをカーボンに変えたら、驚くほど軽くなって坂道が楽になったよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あちゃー、釣竿のカーボンが折れちゃった。修理に出すと高くつくかな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最新のテニスラケットは、高い剛性を実現するために特殊なカーボン素材を採用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "エンジンルームにカーボンパーツを多用して、少しでも車両重量を減らしたいんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "紙にはさんで筆圧で複写をとるカーボン紙の特許は、すでにイギリスで一八〇六年に成立しています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに一部には、現在のカーボン用紙に相当する、松脂を利用したコピー紙を工夫して、生産性を上げようとする試みも生まれます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "最つと馬鹿な奴はカーボンやプラチナ板に撮した自分の写真を恭やしく送つて来る奴もある。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "半紙四ツ切型のうすいペラペラしたその紙には、一包毎に等級と量目とが、カーボンで複寫してあつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い壁について煌々あたりを輝やかしているいくつもの電燈のカーボン線を震わすような女の声が、マイクロフォンをとおして金属的に反響している。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏になると虫が沢山とんで来て、朝になると、カーボンが歩道の上に落ちていた。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに濛々と渦巻く熱気と、石炭の粉の中に、臨時に吊した二百｜燭光の電球のカーボンだけが、赤い糸か何ぞのようにチラチラとしか見えていない。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "接伴委員長のカーボン卿は、金博士が、あまりにも空爆下に無神経でありすぎるのに愕き、周章てて持薬のジキタリスの丸薬をおのが口中に放りこむと、金博士を桟橋の上に積んだ偽装火薬樽のかげに引張りこんだ。",
              "citation": {
                "source": "独本土上陸作戦",
                "author": "――金博士シリーズ・３――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああカーボン卿、ドイツ空軍のために、こんなに行き亘って爆撃されたのでは、借間が高くなって、さぞかし市民はたいへんであろう」「おお金博士。",
              "citation": {
                "source": "独本土上陸作戦",
                "author": "――金博士シリーズ・３――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで瘠躯鶴の如きカーボン卿は、樽のかげから外に出て、一応頭上を見上げたうえで、樽のかげの金博士の手を取って、引張り出したのであった。",
              "citation": {
                "source": "独本土上陸作戦",
                "author": "――金博士シリーズ・３――",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォスゲン、ピクリンサン、ジフェニルクロルアルシン、イペリット、カーボンモノキサイド、どれが欲しいかね」　下は人工灯の海、上は星月夜、そして屋上は真暗だった。",
              "citation": {
                "source": "毒瓦斯発明官",
                "author": "――金博士シリーズ・５――",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーボン紙のインクがにじめば主任に叱られるので、ペン先きを機械のように動かしている。",
              "citation": {
                "source": "悲しい誤解",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　鉛筆は、下へカーボン紙を入れて、コツピーを取る必要のある時に用ひることにしてゐる。",
              "citation": {
                "source": "文房具漫談",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して、いく枚かのカーボン紙を、手早く次のそれぞれの頁の間へ挟み込む動作までを、守屋為助は見届けたのである。",
              "citation": {
                "source": "計算は計算",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "訳注(*1) telephonic tube、ちょうどカーボンマイクロホンを使った実用的な電話機が発明された頃なので微妙ですが、内容からこう訳しました。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生にも初めはカーボン筆写のものの内良く書けたのをと思いましたが僕の文字はへたくそなのでどうしてもへんな文字のものになり読みにくくなります。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーボンは、ミーヨの島から帰ってきて、徹底的に落とした。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "入浴し、カーボンにペンを走らしてる大西・穂積を残して、二時に就床。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
