[
  {
    "uuid": "0d29b47c-6e84-530d-8130-768a075c1800",
    "entry": "柏手",
    "reading": {
      "primary": "かしわで",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "clapping one's hands in prayer (at a shrine)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お賽銭を投げ入れ、手を合わせて柏手を打った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "神聖な場所では、柏手を打って神様に感謝の気持ちを伝える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初詣の際、多くの人が本殿の前で柏手を打つ音が響いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さいわい、戦災にも遭わず、二人の子供は丸々と太り、老母と妻との折合いもよろしく、彼は日の出と共に起きて、井戸端で顔を洗い、その気分のすがすがしさ、思わずパンパンと太陽に向って柏手を打って礼拝するのである。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛邦、近年神道を興すとて瑣末な柏手の打ち様や歩き振りを神職養成と称して教えこみ、実は所得税を多く取らんために神職を増加し、その俸給を増さしめ、売れ行きの悪い公債証書を売りつけんために無理早速に神社基本金を積ましむる算段と思わる。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "上座に坐ると勿体らしく神社の方を向いて柏手を打って黙拝をしてから、居合わせてる者らには半分も解らないような事をしたり顔にいい聞かした。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが拝殿の前でやむと、母はまず鈴を鳴らしておいて、すぐにしゃがんで柏手を打つ。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝欠かしたことも無いように軽く柏手を打って、信心深い眼付で祈願を籠めるそのすがたを、捨吉は久し振で見た。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "按ずるに伊沢氏には蘭軒手沢本と榛柏手沢本との二種の内経が遺つてゐた筈である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は、手を洗ひ口を嗽いでから、お賽錢を上げ柏手をうつて拜んだ。",
              "citation": {
                "source": "滑川畔にて",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の中に御車を曳出して参りまするを見ますると、皆京都の人は柏手を打ちながら涙を飜して居りました。",
              "citation": {
                "source": "牛車",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ではこれから、秘伝伝授の儀に移ろう」　一松斎はそういって、額ずく雪之丞を見下ろすと、祭壇に向って、柏手を打ち、深く、跪拝して、いつも神霊の前に供えてある、黒木の箱の蓋をはねると、中から、一巻の巻物を取り出した。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポンポンと二つ柏手を打った。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白木の宮に禰宜の鳴らす柏手が、森閑と立つ杉の梢に響いた時、見上げる空から、ぽつりと何やら額に落ちた。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬師様のお堂へまいり、柏手を打って頻りに母の眼病平癒を祈り、帰ろうといたしますと、地内に宮松という茶屋があります。",
              "citation": {
                "source": "西洋人情話英国孝子ジョージスミス之伝",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬作は珠数を首に掛け、馬「そんなら婆さん屹度頼んだぜ、さア此奴が有りゃア大威張だ、時に兼ちゃん何うです大変な賑いですねえ、今日のお賽銭は何のくらい上りましょう、羨しいね私もお祖師様に成りてえ、もしあんな別嬪なぞに拝まれてね」兼「馬鹿アお云いな勿体ない」馬「さア来た／＼」　と本堂に上り柏手をポン／＼。",
              "citation": {
                "source": "松の操美人の生埋",
                "author": "侠骨今に馨く賊胆猶お腥し",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、小さい時から、私達子供は神様のおかげで生きているとされ、毎朝毎夕、柏手をうっていた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は高尾山上の薬王院へ参詣しようというのでもなく、山頂に鎮座するこの山の守護神、飯綱権現の社前へ一気に上って来ると、社の前に例の箱入りの名刀を供えて、二人とも跪まって柏手を打ち、恭しく敬礼しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて質素な式がはじまり、神酒、白米、野菜などが型のように故人の霊前に供えられると、禰宜の鳴らす柏手の音は何がなしに半蔵の心をそそった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "父忠寛は未だその榊の蔭に居て、子の遠い旅立を送るかのようにも見える、実は柏手を打って、先祖の霊に別離を告げた。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日見に参候折｜参詣人の柏手拍つ音小鳥の声｜木立を隔てゝかすかに聞え候趣｜大に気に入り申候。",
              "citation": {
                "source": "雨瀟瀟",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それはとにかく、幹様の後生、ちょっと拝んで置こうかしら」ポンポンと柏手を打ったとたん、「太夫、おッそろしく神妙だねえ！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神前に詣りて柏手を打ち立て、身出世を祈りたり長命富貴を祈りたりするはみな大間違いなり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここ深川、富ヶ岡八幡の社前に、おごそかに柏手を打ってしきりに何ごとか念じているのは、恋慕流しの宗七の妻、お多喜なので。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に、調子よく柏手を打ったお多喜が、くるりと踵をめぐらして社前を立ち去ろうとすると、「ほほほほほ――。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "忍びの柏手一　子として、父の死を悼まぬものが、どこにあろう。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまんでは拝んで、二度香をくべた源三郎、ふたつ続けて、音のない柏手をうちました。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、忍びの柏手といって、神式のとむらいにおける礼悼の正式作法で……まず、よほどの心得。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "柏手を打って鈴を鳴らして御賽銭をなげ込んだ後姿が、見ている間にこっちへ逆戻をする。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は、さらに水哉、冬村二君も来庵、かしわでうんと飲んだ、酔ふた酔ふた、みんなが去つてゆくのが癪に障るほど酔ふた（私は時々、親しい人々に対しては駄々児気分を発散するらしい）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "待つてゐる――敬坊来、間もなく樹明来、かしわで飲む、何といふうまさ、友情そのものの味はひだ！",
              "citation": {
                "source": "行乞記",
                "author": "室積行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛肉ですか、かしわですか。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本浴衣のねまきに着換えた多計代は、煖炉棚の上においてある錦のつつみものに向って、よく響くかしわでを二つうちならした。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
