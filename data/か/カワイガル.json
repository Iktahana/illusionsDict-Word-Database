[
  {
    "uuid": "7aa1088d-e5d5-5fed-85cc-89e063f2e50d",
    "entry": "可愛がる",
    "reading": {
      "primary": "かわいがる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
