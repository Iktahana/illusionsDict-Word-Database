[
  {
    "uuid": "7ebc7371-dd41-5182-a5ab-dbf0f5c94d8c",
    "entry": "嗅ぎつける",
    "reading": {
      "primary": "かぎつける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to sniff out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "わずかなガスの匂いを嗅ぎつけ、すぐに窓を開けて換気した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "記者は長年の勘で、大物政治家のスキャンダルを嗅ぎつけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は、新しいビジネスチャンスの匂いを誰よりも早く嗅ぎつける才能がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "獲物の気配を嗅ぎつけた猟犬が、森の奥へと駆け出していく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "犬も猫も春を嗅ぎつけるのは早い。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は年も六十に近く、すでに四十年の余もこの社会の女の髪を手がけ、気質や性格まで呑み込み、顔色で裡にあるものを嗅ぎつけるのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし流石にその智慧だけでは、ニイチェを嗅ぎつけることが出来ないのである。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとの秘密を嗅ぎつけるのが早いのだ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりのものかげから冷え冷えと流れて来る山気をかき乱すともないつつましやかさを背に感じながら、落葉の径をそことしもなく辿っていると、ふとだしぬけに生きた山の匂をまざまざと鼻さきに嗅ぎつけることがよくある。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを嗅ぎつけると、私はほくそ笑みながら、すぐに自分の手で荷物の縄目を解きにかかつた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ふと彼は、お柳がどこからか覗いているのを嗅ぎつけると、また首をひっ込めた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　甲谷は山口の豪傑笑いの中から、参木に対するいくらかの友情を嗅ぎつけると喜び勇んで乗り出した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私はヨーロッパの知性という完備に完備を重ねた精緻な構成物が、恰も全く別の自然物のように、人間の脳中で張りわたり、これ以上の知性の網は論理を崩す以外に方法はあるまいと嗅ぎつけるようになって来てからは、一層私の眼にはスフィンクスの怪貌が鮮やかに浮き上って来るようになった。",
              "citation": {
                "source": "スフィンクス（覚書）",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は頭をかかへてそのときの草の匂ひを嗅ぎつけるやうに雜草の中へ倒れ込んだ。",
              "citation": {
                "source": "草の中",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この十年間の都會生活の間に我が身につけたものを次々にかなぐり棄てて行く、どこへ出て誰に見られても、誰も自分にはそんな過去を嗅ぎつけることが出來ないほどになる。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の時々の心持は鋭敏に嗅ぎつけることも出来た。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのにほひは、丁度、自分が穢い方面に這入りながら、目をつぶつて、心の内容を披瀝する氣持ちの樣に思はれ、それによつて、義雄は自分自身の現在の立ち場をよく嗅ぎつけることが出來た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "その言葉は若い女が情夫に対して云ふやうな意味合のもので、どんなことがあつても、自分たちから離れないでくれ、しかし、息子さんは探偵を使つて私たちのところにあなたがゐることを嗅ぎつけることができるかも知れぬ、それが私は心配だ、と云つたのである。",
              "citation": {
                "source": "日本三文オペラ",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋭敏な鼻で、数十露里も離れたところに定期市が立って、いろんな集まりや舞踏会のあることを嗅ぎつけると瞬く暇に彼はもう其処へ駈けつけて、骨牌台の前で早くも議論をおっ始めたり、大騒動を演じたりしているのだった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父つあんの留守をすぐに嗅ぎつけるんだもの。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　美しい松脂色のゴム絹の袋から、きざみ煙草をダンヒルのパイプに詰め詰め云う由吉の話を矢代は、自分と別れてからの、千鶴子の生活の匂いを嗅ぎつける思いで聞くのだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "また実際仲間の若者たちも彼の秘密を嗅ぎつけるには、余りに平生の素戔嗚が、恋愛とは遥に縁の遠い、野蛮な生活を送り過ぎていた。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、ブリストルの人々も、我々の目指している港のことを――というのは宝のことだが――嗅ぎつけるや否や、だれも彼も非常によく働いてくれたと言ってもよいでしょう。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもはその不器用な容貌の蔭に眠つてゐる不敵さ、だが何か圧迫を加へられると忽ち跳ね起きて来る反撥する房一の気質は、同時に圧迫しようとかゝるものを嗅ぎつける点でも敏感であつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "理性といふよりはむしろ動物的なこの嗅ぎつける力のお蔭で、今房一はたゞ鼠のやうな眼をした小柄な男を見ただけであつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴らの仕業は腕ききの名探偵や刑事でも嗅ぎつけるには骨の折れるものなのだ。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか嗅ぎつけてきたわけじゃアないでしょうね」「嗅ぎつけるはずはないが、しかし妙な暗合だな。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのむごい有様が、どうぞしてお役人衆の耳にとどくか、お役人衆が嗅ぎつけるかしてくれればいいがと、みんな心の中で思ってはいたものの、第一そのお役人衆が、てんで口ばしを入れる気がないのですから、なんにもなりはしません。",
              "citation": {
                "source": "かもじの美術家",
                "author": "TUPEJNYJ HUDOZHNIK",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の匂を嗅ぎつけると、たちまち飛んで来て、私をくわえると、尻尾を振りながら、ドン／＼、主人のところへ駈けつけて行って、そっと、私を地面に置きました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、鷲はよく臭を嗅ぎつける鳥ですから、たとえ獲物が上手に隠れていても、すぐ見つけ出すので、私が箱の中にいることも、ちゃんともう知っているにちがいありません。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はセルゲイの居場所を嗅ぎつけると、鉄の扉ごしに男とことばをかわし、すぐその足で鍵をさがしにかかった。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の所謂嗅ぎつける力の一つのささやかな例として見ても、この話は私には一種の懐かしさをもっているのである。",
              "citation": {
                "source": "実験室の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真理をかぎつける事の天才はファラデーであった。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人が一流でないという点を、あるいは滑稽に、あるいは不愉快にかぎつけるのだ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
