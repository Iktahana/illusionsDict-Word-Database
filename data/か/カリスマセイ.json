        "examples": {
          "standard": [
            {
              "text": "新任の監督は、そのカリスマ性で選手たちの信頼を瞬く間に勝ち取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女のカリスマ性は、プレゼンテーションを成功に導く大きな要因となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "特定のカリスマ性を持つ政治家が、混迷する国民の支持を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あのロックシンガーは、圧倒的なカリスマ性で多くのファンを魅了し続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "売上高に対する経常利益率が、成長を重ねながらなお二〇パーセント台を維持し続けるという高収益体質と、社員の滅私奉公的な献身、その核となる稲盛和夫のカリスマ性において、京都セラミツクは際だっていた★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
