[
  {
    "uuid": "bb31997d-c5c1-5c4e-9e02-a7654adf751f",
    "entry": "神さび",
    "reading": {
      "primary": "かみさび",
      "alternatives": [
        "かむさび",
        "かんさび"
      ],
      "is_heteronym": false
    },
    "grammar": {
