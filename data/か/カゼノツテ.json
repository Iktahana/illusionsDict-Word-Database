        "examples": {
          "standard": [
            {
              "text": "あの名店がひっそりと暖簾を下ろしたということを、風のつてに聞きました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "高校卒業以来会っていない彼女が地元でカフェを開いたと、風のつてで知った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "風のつてで聞いた話だから確証はないんだけど、隣の部署の部長、来月左遷されるらしいよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "お手紙は、心から春待つ園はわが宿の紅葉を風のつてにだに見よ　というのであった。",
              "citation": {
                "source": "源氏物語",
