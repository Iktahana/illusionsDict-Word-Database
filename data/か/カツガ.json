[
  {
    "uuid": "971ddd1a-d44e-5cca-aac1-b73a151fc259",
    "entry": "活画",
    "reading": {
      "primary": "かつが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
