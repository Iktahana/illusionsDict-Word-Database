    "definitions": [
      {
        "index": 1,
        "gloss": "lifelike painting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その屏風に描かれた虎は、今にもこちらに飛びかかってきそうなほど見事な活画であった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "巨匠が最期に遺した肖像画は、モデルの静かな息遣いまで伝わるような活画として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "筆の一振り一振りに迷いがなく、まさに活画と呼ぶにふさわしい躍動感に満ちた作品だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "実に今より百年ばかり前のことをわれわれの目の前に活きている画のように、ソウして立派な画人が書いてもアノようには書けぬというように、フランス革命のパノラマ（活画）を示してくれたものはこの本であります。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の眼瞼から感激の涙が一滴溢れるや最後、其処にも此処にも声を挙げて泣く者、上気して顔が火と燃え、声も得出さで革命の神の石像の様に突立つ者、さながら之れ一幅生命反乱の活画図が現はれる。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "空のいろを映して黒い川の水と、低い古い建物を背景に、それは幻怪きわまる言語と服装と女子供と海産物とが、じつに縦横に無秩序に交錯する「北海の活画」である。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿と娘、――これは日々見る活画題だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯涼しい活画を見て居る彼の眼前に、何時とはなしにランプの明るい客間があらわれた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは直ちに画の上の肥料となって、死画を活画に更新さす秘術でもあるからだ。",
              "citation": {
                "source": "陶磁印六顆を紹介する",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても「上り」うたの中の、第六節「登る箱根のお関所で……」の件りなどは、情景躍動見るべし、浮世絵にもこの活画面は好個の題材なるに拘らずちよつと見かけない。",
              "citation": {
                "source": "東京の風俗",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然はこれ一幅の大活画なりと。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "足を運びつつ、魅力的な古都に残る数多の過去の名残を紡ぎ合わせ、一世紀を遡る一枚の活画に仕立てようと努めた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう、不思議の物語というのは人間が抱くある種の気分の活画でしかあり得ません。",
              "citation": {
                "source": "怪奇小説の執筆についての覚書",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして父の従兄から出る僅かの金で父はかつがつ軍医学校まで卒へた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなに、さわったらころびそうな連中を引っぱり出して鉄砲をかつがせるって法があるかい！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "専売局の方々にでも聞いてみたら分るかもしれないが、事によると、これは自分がちょっとかつがれたのかもしれない。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は、墓地へかつがれて行く夫の屍体のあとにつづいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妊娠の婦人は、その腹よりも、もっとふくらんだ二ツ折の柳行李を、支那人のボーイに、一箇は肩にかつがし、一箇は片手に提げさして、肩で息を切らし乍らやって来た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「銃を持った日にや、薪は皆目かつがれやしねえからな。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、まんまと、かつがれたわけであるが、けれども私には、この友人の無邪気な冗談を心から笑う事は出来なかった。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつがなきゃおまんまが食べられませんからね。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かつがれちやつたのかとも思ひましたが、電話がまじめなお話ですし、そんなわるさをなさる方でないし………。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにこんな赤い太鼓をかつがせられて、いい見せ物にされて、――」「まあ、そう言うな。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんは、まあ、自業自得で仕方がないとしても、あたしにまで、こんな赤い太鼓の片棒かつがせて、チンドン屋みたいな事をさせてさ、お母さんはきっと、お父さんをうらんで、化けて出るわよ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんのお祭り野郎を見抜いて、こらしめのため、こんな真赤なお祭りの太鼓をかつがせて、改心させようと思っていらっしゃるのに違いない。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、あのような重い太鼓をかつがせ、その上、男どもは、だいぶ女連にやられていたようで、気の毒に思っている。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝次は足を折つて皆に運ばれ、遂に遠くの病院へかつがれて行つた。",
              "citation": {
                "source": "椋の實の思出",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄の服の唐子、唐子よ、かつがれて、籠にゆられて。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし名を問われ、年を問われた時に、かつがつ返事をしたばかりで、そのほかの事を問われても、「いっこうに存じませぬ」、「恐れ入りました」と言うよりほか、何一つ申し立てない。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと、かつがれたのではないか、と思いながら、受け取った。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝指のうえに何所かにぼんやりしたところがあったから、よく人にかつがれた。",
              "citation": {
                "source": "阿宝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は不断からぐっすりと安眠する男で、よくうちで、私はかつがれたって目をさまさないだろうなんて、冗談を云ってるくらいです。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はベルセネフの肩にかつがれていた。",
              "citation": {
                "source": "警察署長",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
