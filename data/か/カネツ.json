[
  {
    "uuid": "757ac3de-3e1d-5f0c-9241-1b9fd7c9828c",
    "entry": "加熱",
    "reading": {
      "primary": "かねつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
