[
  {
    "uuid": "ee142290-58d9-50d6-b336-2db731770a21",
    "entry": "瘡蓋",
    "reading": {
      "primary": "かさぶた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
