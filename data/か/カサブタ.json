    "definitions": [
      {
        "index": 1,
        "gloss": "scab",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "転んでできた膝の傷に、ようやく瘡蓋ができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "痒いからといって、瘡蓋を無理に剥がしてはいけない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "瘡蓋が取れたら、新しい皮膚ができていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その傷は瘡蓋になりかけていて、治り始めているのが分かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "水泳などに行って友だちや先輩の背中に妙な斑紋が規則正しく並んでいて、どうかするとその内の一つ二つの瘡蓋がはがれて大きな穴が明き、中から血膿が顔を出しているのを見て気味の悪い思いをした記憶がある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱のために目に力が入りすぎ、両頬には消耗性紅潮が見られ、唇は変色した瘡蓋が。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "良心を、余りに淫逸に耽溺させ、アルコールに麻痺させた資本家共の瘡蓋だらけの良心には、「人類の理想」や「地上に於ける民衆の結合」や、「神の意志の体現」などは、到底分りつこはないのである。",
              "citation": {
                "source": "工場の窓より",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "比良に雪が降つたといふ記事を新聞で見て、慌てて汽車で駈けつけてみると、山には瘡蓋のやうな雪がちよつぴり残つてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると青緑色の靄が立罩めた薄暗い光線の中に、瘡蓋だらけの醜い背中が露出された。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたはん、そや、キビスをこする石やつたのに、まア、どうしようかいの」　見るも無惨な凸凹の瘡蓋になつた私の顔に姉は膏薬を塗つてくれながらへんな苦が笑ひをした。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "肘の辺から指先まで、ベッタリ瘡蓋が飛び散っていた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中指の附け根の瘡蓋の上に、モジャモジャと一房の毛があった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母家へさへ行かなければ、學校の淺間しい後姿も、厭やらしい背中の瘡蓋も、見ないで濟むと考へた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず額に一本の針金が渡されていて、情けない毛髪がそれから生じているのです、その絶頂には小さな丸髷が一つ乗っているのでした、その髪の下は完全な禿頭で、その禿頭にはくろんぼがベタベタと瘡蓋の如く一面に塗られていて、到底じっとは見ていられない穢さでありました。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "背中に立てられた蝋燭がゆらめくたびにぽたぽたと蝋涙を垂らして、それが醜い瘡蓋のように肌にこびりついていた。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "水面は、みるも厭らしいくらい黄色をした、鉱物質の滓が瘡蓋のように覆い、じつは睡蓮はおろか一草だにもなく、おそらくこの泥では櫂も利くまいと思われる。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに大之丞の次の弟、彦之助が京に上ってから胎毒を発し、頭が瘡蓋だらけでお釈迦様のようになり、膿が流れ、その介抱に皆力を尽していた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "坐つた奴等肉瘤で黒くて痘瘡あり、緑い指環を嵌めたよなその眼、すくむだ指は腰骨のあたりにしよむぼりちぢかむで、古壁に、漲る瘡蓋模様のやうに、前頭部には、ぼんやりとした、気六ヶ敷さを貼り付けて。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "手足は※のように膨れ、背中は曲り、頭はぞっとするような吹出物と瘡蓋に蔽われ、指の股には壁蝨が食いこみ、腹のあたりにわずかに纒いついている衣服の名残には、虱と南京虫が布目も見えぬほどに這いまわっていた。",
              "citation": {
                "source": "カストリ侯実録",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の方の小部屋のいくつかと通廊には古代の瘡蓋のように砂埃がある程度だった一方、時々新たに拭われたように奇妙に汚れのない感じの区域もあった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は身体ぢゆうのふきでものを痒がつて夜も昼もおちおち眠らないもので糠袋へ小豆を包んで母と伯母とがかはるがはる瘡蓋のうへをたたいてくれると小鼻をひこつかせてさも気もちよささうにしたといふ。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてトランプの相手ならまだしも、「水戸ちゃん」と二人で悦子の手だの足だのを掴まえて、瘡蓋を剥がしては面白がっていた。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢ちゃん、まあ見て御覧、こんな工合に何ぼでも剥がれますねんと云いながら、瘡蓋の端を摘まんで引き剥がすと、ずるずると皮が何処迄でも捲れて行く。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瘡蓋を拾い集めて手の中へ入れて、母屋の台所へ戻って来て、ほら、お嬢ちゃんの体からこんなに皮が剥けるねんと、それを下働きの女中達に見せびらかして気味悪がらすのであったが、しまいには皆が馴れて恐がらないようになった。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "かさぶたさへとれて、ただ赤白い斑點になつてゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、これまで書いている作家が、そのことでかしこくされないとともに、これから書こうとしているかくれた新鮮なエネルギーの上にかかるかさぶたになってしまうだろう。",
              "citation": {
                "source": "両輪",
                "author": "――創造と評論活動の問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも両腕は肱の辺までべた一面痣やかさぶたで、掻くなと云われても、掻かずにはいられないのであった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとにまあ可哀そうに、頭の地一杯に何だか、かさぶたの様なものがついて居る。",
              "citation": {
                "source": "一日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "首筋から、胸へかけて、ぶつぶつとあせものかさぶたではどうにもなりません。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆき子を傷つけた加野は、ゆき子に詫びてゐたと聞いたが、富岡は、考へてみると、自分の卑怯さには、一種のかさぶたが出来てゐるやうなものだと感じた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "村役場の事件、「かさぶた」と云う村から提起した訴訟事件、それにともなう村の事件が大変面白いと思われた。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "若木は艶やかだが、古い幹となると、かさかさで節くれだち、垢が鱗のようにつもってるとも言えるし、皮膚病のかさぶただらけとも言えるし、見られたざまではない。",
              "citation": {
                "source": "小さき花にも",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○モスク※の冬のオレンジ、かさぶたのようにそばガラをつけた皮。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まるで傷の上のかさぶたをはがれるようだ。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
