[
  {
    "uuid": "f4ca4237-3d67-5b85-84f3-e77bb0224602",
    "entry": "匿う",
    "reading": {
      "primary": "かくまう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to shelter (e.g. a fugitive)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "追っ手から逃れてきた若者を、村人たちは密かに寺の床下に匿い、夜が明けるのを待って山へ逃がした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おい、まさか指名手配されている友人を、内緒で自分のアパートに匿っているんじゃないだろうな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "嵐の激しい夜、怪我をして動けなくなっていた子狐を納屋に匿って、翌朝まで介抱してやった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "亭主もし二の足ふまば我が職掌をいうべきなれど、蔵匿うことを承知したればそれにも及ばず都合｜可し。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "衆生済度を旨と致すわれら仏弟子が、救いを求めてすがり寄る罪びとを大慈大悲の衣の袖に匿うたとて何の不思議がござる。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなる替え難い浄財を尊き霊地に於てスリ取った不埒者匿うことが、何の慈悲じゃッ。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「物見に行った仲間達で」「何故俺達の敵の子を神聖な社殿などへ隠匿うのだ？",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠匿ってくだされ」「はて隠匿うとおっしゃいますのは？",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（陣十郎とかいうお侍さん、随分怖そうなお侍さんだが、あんな人の眼をこっそり盗んで、鴫澤主水とかいうお侍さんを、こんな所へ隠匿うなんて……血腥さい事件でも起こらなけりゃアいいが）　これを思うと弁三爺さんは、不安で恐ろしくてならなかった。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その姫の手で隠匿うからには、いよいよ俺の持ち物にはならぬ。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな人間でも匿う穴や、小道の多い東京へまた戻る決心をした。",
              "citation": {
                "source": "日は輝けり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは一軒の家をも、おのれの思い出を匿うべき一隅の場所をも、もってはいない。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それを匿う尊公の量見が分らぬ。",
              "citation": {
                "source": "夕顔の門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ありがたくお縄をいただいて、御一しょに参る」「いや、老台を連れてゆくまえに、隣家の空家に匿うてある女賊に縄を打ちますが、お覚悟でござろうな」「女賊とは」「五人組のひとり、お燕という女」「知らん……。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "匿うたら断罪に処するぞ。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "匿うたなどと疑われてみさっしゃれ、それこそ……」「いや、不愍じゃ。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへまた、誰が告げたか、伊豆山走り湯の僧兵が一群れ、また一群れと何十人も馳せつけて来て、「われわれが北条殿のむすめを匿うているなどとは、聞き捨てにならぬ沙汰だ。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　最初から目のかたきに頼朝を狙うていた大庭景親は、二十五日の夕方、一斉に、布令を発し、（頼朝を匿う者、木戸の警備を怠った者、等しく断罪に処するであろう）　と辻々に高札を立て、およそ諸国へ通じる宿駅は元より、山伝いの小道から、浜辺の一帯に亙るまで眼を光らせて、詮議はいよいよ峻烈を極めているとある。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは玄蕃めを匿うた京極の策を同じようにし返してやるのじゃ。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――十二年の久しきあいだ、織田家を悩ませた本願寺の黒幕の謀将を、おゆるしも仰がず、匿うなどという行為は、明らかなる叛意と申されても仕方がないではございませぬか。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、世間で臆測しているように、上野介の身を、米沢へ移してしまうとか、麻布の上屋敷へ匿うとか、或は、逆襲的に赤穂方の領袖たちの三、四名を暗殺してしまうとか。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……左近」「はっ」「そして、正季は、妹夫婦を、あくまで匿う所存なのか、どうなのだ」「さ、そこを、どうしたものか、伺うてくれとの御意でございました。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくまうて下され、隱まうてくだされ。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　倭文子は愛人をかくまう映画の女主人公のように、かいがいしく出て行った。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして天野に、「わたしの親身の叔母のようにしている方でございますの」と、とりかくまうように言った。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとどうでしょう薩摩藩の情勢が、吉之助様たちのご努力にかかわらず、佐幕論に傾きまして、ご上人様を薩摩藩でかくまうことを、体よく拒絶ったばかりでなく、国境いにおいて斬殺する目的のもとに「東目送り」という陰険きわまる法を、あえて行なうことになりました。",
              "citation": {
                "source": "犬神娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はまさかあの男をかくまうような馬鹿げたことはしないだろうね？",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "小夜子サンを東京へ連れて戻ったトオサンは、ウチへ当分かくまうことにしました。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "小夜子サンをかくまうには元貴族が安全だとは、ふざけているではありませんか。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の場合、かくまうとは隠すことです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや、わざわざ元貴族のニセモノをつくって、そこにかくまうとはナンセンスにすぎません。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "元貴族のニセモノを仕立てて小夜子サンをかくまうなぞとはトオサンをだましてていよく小夜子サンを誘拐する手段にすぎないということは、日野の奴むろん承知の上で云ってるのです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただニヤニヤと笑いながら、しかも酒に酔っぱらって、法本がニセの貴族を仕立てて小夜子サンをかくまう計画をもっているよともらしただけでは一応誰を裏切ることにもならないばかりでなく、むしろ双方から味方と思われる可能性の方が多いことも計算に入れているのです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
