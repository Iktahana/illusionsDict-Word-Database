        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "日本の建国神話は、天皇が即位する以前の、神秘に満ちた神代から語り継がれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古事記や日本書紀には、神代の神々の系譜や伝説が詳細に記されており、興味深い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "神代の時代、まだ人と神の境界が曖昧だった頃の出来事を想像すると、とてもロマンを感じるね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、日本の神代史を専門に研究する第一人者として、その分野では非常に有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
