        "examples": {
          "standard": [
            {
              "text": "酸と塩基が完全に中和する点を見つけるために、化学当量を用いる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この反応における各成分の化学当量を計算することで、必要な試薬の量を決定できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "滴定実験では、終点と化学当量点が一致するように慎重に進めることが求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ファラデーの書いた中には、「電極に現われて来る割合を表わす数を、電気化学当量と呼ぶことにする。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "その電気化学当量はほとんど一、八、三六、一二五、一〇四、五八である。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
