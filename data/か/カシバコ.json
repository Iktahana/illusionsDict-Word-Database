          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お土産に、伝統的な和菓子が詰められた立派な菓子箱をいただいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の誕生日パーティーのために、カラフルなフルーツゼリーが入った菓子箱を用意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あら、この美しい菓子箱、開けるのがもったいないくらいね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "五　八十三で亡くなった母の葬儀も済んで後に母の居間の押入を片付けていたら、古いボールの菓子箱がいくつか積み重ねてあるのに気がついた。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小さな菓子箱のふたを通してのぞいた珍しい世界がどんなに美しくなつかしいものであったか、ずっと晩年にほんとうの西洋へ行って見ても、この「夢の西洋」はどこにもなかった。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この菓子箱のふたは自分の幼時の「緑の扉」であったのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ坊ちゃんが来てお菓子箱の蓋を取ってみるとビックリして、「お母さん。",
              "citation": {
                "source": "キャラメルと飴玉",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると綾さんは風呂敷包にした菓子箱を抱込むで毎日のやうに駄菓子を賣りに來た。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鶴原様はこちらで……私は九段の高林のうちのものですが……老先生からこれを……」　と菓子箱を風呂敷ごとさし出した。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから間もなく件の白骨は、キレイに洗い浄められて、古綿を詰めたボールの菓子箱に納まって、文作の家の仏壇に、女房の位牌と並べて飾られた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、海蔵さんは、じぶんも駄菓子箱から油菓子を一｜本つまみだしながらききました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "店にはいって来た海蔵さんは、いつものように、駄菓子箱のならんだ台のうしろに仰向けに寝ころがってうっかり油菓子をひとつ摘んでしまいました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "人力曳きたちは、お客を待っているあいだ、することがないので、つい、駄菓子箱のふたをあけて、油菓子や、げんこつや、ぺこしゃんという飴や、やきするめや餡つぼなどをつまむのが癖になっていました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄菓子箱の方は土間で向うの壁際に爐があつて鍋や何かゞ自在鍵に掛つて居る。",
              "citation": {
                "source": "竹の里人〔三〕",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "振返ると、生徒の一人――顏は確かに知つてゐるが、名前が咄嗟には浮かんで來ない――が私の前に來て、何かよく聞きとれないことを言ひながら、五寸角位の・蓋の無い・菓子箱｜樣のものを差出した。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の生命がけの仕事を邪魔するなよ」　大寺教授の自宅に「退院御礼」と書いた菓子箱を置いて博多駅前のポストに学部長宛の辞表を投込んだ私は、間もなく着いた上りの急行列車に風呂敷包を一つ提げて乗込んだ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒と赤とのインキを瓶のひっくり反らない用心に、菓子箱のあいたのに、並べて入れたのに、ペンを添えて、机の向うの方に置いた。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合においても彼は、ソーッと、自分の棚から、状袋を出して、その中に五十銭玉が一つ光っていることを見ると、非常な誘惑を菓子箱に感じた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、神様を便所から見つけたが、菓子箱には貧乏神がいるとこぼしていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、正月になれば、それも何とかなるだろうさ、くよくよしたもんでもないや」　彼は自分に言い訳をしながら、沖売ろうのねえさんの所有に属する、菓子箱へと近づいた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、それでも一緒になって、キャッキャッとはしゃぎながら、自分の商売の菓子箱のくつがえるのも忘れて、抵抗したりふざけたりするのだった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、見習いさんでねえか、びっくりしただがよ」彼女は菓子箱を持って来て、ボーイ長の前へひろげて見せた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありますわ、お菓子箱でいいかしら。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "倭文子は、新世帯の炊事をでもしているように、菓子箱の空箱を両手に抱えきれぬほど持って入って来た。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "菓子箱を壊しては、炉の中へ投げ込んだ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、妻の産見舞として、到来したたくさんの菓子箱や果物籠などを、棚の上に積み重ねてあったことです。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎さんは思わず大きな声で、「ハイ」　と言って飛び起きて駈け出しますと、それは四角い油紙で、何だかお菓子箱のようです。",
              "citation": {
                "source": "お菓子の大舞踏会",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の荒川公園なぞはその男が図を引いたのであるが、その男が、浅草公園の第六区の道路を広めないと衛生上悪いというので、今は無くなった十二階下真正面に通ずる道路の両側、活動館や見世物が行列しているところを実地に調査して帰って見ると、彼の下宿に黄白を詰めた菓子箱が山積みしていた。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "流石の彼もその早いのに仰天したが、ここぞ一生の思い出というので、その菓子箱を悉くたたき帰して先ず溜飲を下げた。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは白い紙で包まれた長方形の箱で紅い紐でゆわえてあったから、どう見ても一ポンド入の菓子箱としか思われなかった。",
              "citation": {
                "source": "恐ろしき贈物",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "名刺が中に入れてあるに違いないから」　ウォーカーは友だちのいうままに、好奇の念に駈られながら、紅い紐を解き、白い紙を開くと、果して菓子箱が出たので、やがてその蓋を開いた。",
              "citation": {
                "source": "恐ろしき贈物",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは菓子箱か、葉巻煙草の箱かと思われる位の大さで、白い紙で包まれ紅い紐がかけてあったから、彼は何気なしにそれを開いて見ようと思って、取りあげたが、意外に重かったので、これはと思って下に置くと同時に、先日来の脅迫状のことを聯想したのである。",
              "citation": {
                "source": "恐ろしき贈物",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "このエガンという探偵は今まで爆発物を度々取り扱って来たが、一度も怪我をしたことがなかったので、いかにも自信ありげに、その小包を手に取って、先ずその紐を解き包紙を除くと、中から菓子箱が出て来た。",
              "citation": {
                "source": "恐ろしき贈物",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
