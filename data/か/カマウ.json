    "definitions": [
      {
        "index": 1,
        "gloss": "to mind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「雨だけど、傘なくても構わない？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あの子が何と言おうと、私は構わない」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「もう遅いけど、時間なら全然構わないよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「私のことは構わないで、先に行ってくれ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「多少の無理は構わないから、最後までやり遂げよう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「構うもんか、入ろう、入ろう。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謂ってみりゃ支那人の片割ではあるけれど、婦人だから、ねえ、おい、構うめえと思って焚火であっためてやると活返った李花てえ女で、此奴がエテよ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば先生のところから帰って来て後は直ぐ遊ぶことが出来るのですから、家の人達のまだ寝ているのも何も構うことは無しに、聞えよがしに復読しました。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも私の母様は御病身でございました故、子供には余り構うて呉れなかったのでございます。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンタの首なら構うまいが、私の首となるとチットばかり惜しいわい」「アハハハ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことを構うもんか、こっちはそのせいで藁草履を穿いて歩いてる位じゃもの。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "構うこたあねえ、可けなけりゃ皆で死のう。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "淫売屋などへ泊れるものか、堅いという花月へ行こう」「荷物はどうする」「荷物なんか構うものか。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "……こう云うと軽薄らしいが、まったくの処……一生懸命で、土間でも床でも構う気じゃなかった。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰助は一人残りて、死人の呼吸を吹返さんとする間際には、秘密を唸り出す事もやあらんと待構うれば、医師の見込みは過たず、ややありて死骸は少しずつの呼吸を始め、やがて幽に眼を開き、糸よりもなお声細く、「ああ、これが現世の見納かなあ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何がお前様、翌が日のことを構うていられるようなこちとらではござらぬじゃて。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「構うもんか、内の夫人も御隣のも呑込んでお在なさるるから可い、そこで帯をお解きといったんだ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "敢て言を構うるのではないが、塔婆の閨の議には与らない。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "晃　流が細ったって構うものか。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小児二　構うもんか、何だって。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺たちが構う事は少しもない。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "村越　お互の中にさえ何事もなければ、円髷も島田も構うものか。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……決して私に構うなと言った処で、人情としてそうは行くまい、顔の前に埃が立つ。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三「――旦那さん、その虫は構うた事には叶いませんわ。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「若いもの、その人に構うまい。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何んの、私はちっとも構うことないのですえ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御亭主は留守だが、明放しよ、……構うものか。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものを言う清い、張のある目を上から見込んで、構うものか、行きがけだ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "構うもんか、勝手にしろ、似たものを引つけて、とそう覚悟して按摩さん、背中へ掴ってもらったんだ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御者は書巻を腹掛けの衣兜に収め、革紐を附けたる竹根の鞭を執りて、徐かに手綱を捌きつつ身構うるとき、一｜輛の人力車ありて南より来たり、疾風のごとく馬車のかたわらを掠めて、瞬く間に一点の黒影となり畢んぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "構うものかね、遠慮も何も要るものじゃない。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さんほんとにお召しなさいよ」「構うことはない。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな、そんな児を構うものか。",
              "citation": {
                "source": "女客",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死んでも構うものか」　お葉は覚悟を極めた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って雇人に呉れてやり、お前行けと言うと、われわれの行くところでないと辞退したので、折角七円も出したものを近所の子供の玩具にするのはもったいない、赤玉のクリスマスいうてもまさか逆立ちで歩けと言わんやろ、なに構うもんかと、当日髭をあたり大島の仕立下ろしを着るなど、少しはめかしこんで、自身出向いた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to be an issue",
