[
  {
    "uuid": "08c077e0-3209-5d12-a015-d62e93873dda",
    "entry": "観ずる",
    "reading": {
      "primary": "かんずる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
