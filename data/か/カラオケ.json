  {
    "uuid": "6c5056ed-9a02-5437-a9f6-9a5fe8bc2ae1",
    "entry": "空桶",
    "reading": {
      "primary": "からおけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "empty bucket",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "水を汲みに行ったが、桶が空桶のままでがっかりした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "宴会の準備中、間違えて空桶ばかり運んでしまい、先輩に笑われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大工さんが作業場に置いていた空桶に、道具を入れて持ち運んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庭の水やりをしようとしたら、雨水が溜まっているはずの桶が空桶だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "向うから空桶を担いで来る女がある。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃあ、皆さん、ごきげんよう」　酒売りの男は、愛想をいうと、空桶担って、もと来た坂道の方へ、すたすたと、足早に立去ってしまった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一日たった次の日だ、やくざの仲間が誘いにきて、行かねえかッてんで、ふところは淋しいが、村のばくち場を覗きにいき、夜になったら、取られたやつと二人で、ぼんやり帰ってくると、村の三ツ叉道を、妙な野郎が、二つの空桶を担いで素っ飛んできやがった」「なるほど」「連れの男が、オヤ今のは白日鼠の白勝らしい。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（このすこし手前まで書いたら開成山からおけさ婆さんの婿が来ました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "廻り縁からおけいが顔を覗かせた。",
              "citation": {
                "source": "扇野",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつるとの仲がそんなふうでなければ、栄三郎は初めからおけいに彼女と逢ったことを話したであろう。",
              "citation": {
                "source": "扇野",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
