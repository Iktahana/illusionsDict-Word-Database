        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "禅僧は悟りの境地に至り、真理を喝破した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "偉大な思想家は、時代を超えて普遍的な真実を喝破する力を持っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は自らの経験を通して、人生の深い意味を喝破したと語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その芸術家は、作品を通して社会の隠れた一面を喝破しようとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
