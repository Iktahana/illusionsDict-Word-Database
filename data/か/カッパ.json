    "definitions": [
      {
        "index": 1,
        "gloss": "kappa",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔話に出てくる河童は、きゅうりが大好物だとされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "真夏の暑い日、子どもたちは「河童が出てくるかも」と川で水遊びに夢中だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域の川には、河童伝説にまつわる古い言い伝えが残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イラストレーターが描いた、愛嬌のある河童のキャラクターが人気を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「河童」が雜誌に載つた時、僕の推賞に對して、芥川君は「君に讀んでもらひたかつたのだよ」と言つた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへばあの憂鬱でニヒリズムの影が濃い「河童」や、特に最近の悲痛な名作「齒車」やに於て。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「河童」が「西方の人」が「齒車」が、それから最近の多くの作物がさうであり、轉期への黎明的な豫想を見せてる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は氏の晩年の小説（歯車、西方の人、河童等）を日本文学中で第一位の高級作品と認めてゐるが、その俳句に至つては、彼の他の文学であるアフオリズム（侏儒の言葉）と共に、友情の割引を以てしても讃辞できない。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えんこう」（河童）を釣る話とかいう種類のものが多かった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなボウボウ山なんて屁の河童さ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "河童の肉は、うまいさうで、何とかして、そのうち食べてみようと思つてゐるんだがね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　温泉宿から梓川に沿いて、河童橋を渡り、徳本の小舎まで来た、飛騨から牛を牽いて、信州へ山越しにゆく牧場稼ぎの人たちが、行き暮れて泊まるところだ。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "文中に前穂高とあるは、御幣岳の北部より下れる一支峰にして、梓川に臨み、上高地温泉または河童橋より、最も近く望見し得らるる、三角測量標を有せる低山をいう。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な河童橋は河風が寒く、穂高の山塊はすつかり雨雲に隠されて姿を見せない。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な河童橋は河風が寒く、穂高の山塊はすっかり雨雲に隠されて姿を見せない。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おら河童捕りしたもや。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はかつて、彼のさうした文學的素質の一を新作「河童」の中に發見した。",
              "citation": {
                "source": "芥川龍之介の追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河童にかえ」「河童や河獺じゃあねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門が微笑んで、Ｔ「河童の川流れか」Ｔ「へッ」　と伝六。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川龍之介は人間が河童の世界へ行く小説を書いたが、河鹿の世界というものは案外手近にあるものだ。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その河鹿は瀬の石と石との間に出来た小さい流れの前へ立って、あの奇怪な顔つきでじっと水の流れるのを見ていたのであるが、その姿が南画の河童とも漁師ともつかぬ点景人物そっくりになって来た、と思う間に彼の前の小さい流れがサーッと広びろとした江に変じてしまった。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天狗」や「河童」の類となると物理学や気象学の範囲からはだいぶ遠ざかるようである。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天狗和尚とジュースの神の鷲との親族関係は前に述べたが、河童や海亀の親類である事は善庵随筆に載っている「写生図」と記事、また※庭雑録にある絵や記載を見ても明らかである。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "河童の写生図は明らかに亀の主要な特徴を具備しており、その記載には現に「亀のごとく」という文句が四か所もある。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだとするとこれらの河童捕獲の記事はある年のある月にある沿岸で海亀がとれた記録になり、場合によっては海洋学上の貴重な参考資料にならないとは限らない。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、サタンがそんな可愛らしい河童みたいなものだとは、どうしても考えられない。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "割合｜肥沃な：入力者注　主に外字の説明や、傍点の位置の指定（例）河童取りあんすた。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋形船が化けて出て河童が住居う風情がある。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」河童御殿十八「ははあ、葛木ですかね、姓じゃね、苗字であるですね。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこの一石橋の夜の御領主、名代の河童が、雨夜の影を潜めたのも、やっと五六年以来であるから。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手を縋って、肩を細く乗出しながら、「河童や、悪戯をおしでないよ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十を越えた禿げ頭の男からおかっぱの女の子までまじっている。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "──かっぱらうこと。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "掏摸が一度、豪勢な身なりをしている男の懐中物をくすねて鼻をあかしてやると、その快味が忘れられず、何回もそれを繰りかえし、かっぱらう。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
