    "definitions": [
      {
        "index": 1,
        "gloss": "dead card (comp. karuta)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
