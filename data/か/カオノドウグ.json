        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は顔の道具が一つ一つ大きく、華やかだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若い頃は顔の道具を気にしていたが、今は気にならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その漫画家は、登場人物の顔の道具をデフォルメして描くのがうまい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼女はばらばらになった顔の道具をたちまちまとめて、愛嬌したたるような媚びの笑顔に造り直した。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人種の差から免れ難い顔の道具の形や居ずまいだけがこのような差別の原因であろうか、何かもっとちがったところに主要な原因があるのではあるまいかと考えてみた。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "エイゼンシュテインは特に写楽のポートレートを抽出して、強調された顔の道具の相剋的モンタージュを論じているが、われわれは広重でも北斎でも歌麿でもそれぞれに特有な取り合わせの手法を認めることができるであろう。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽部は体の小柄な割に、顔の道具立てが一つ／＼大きく、眉毛が太く、眼は近眼鏡のうしろにギョロリと突出し、鼻の肉は分厚く鉤鼻であった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔の道具立は如何にも調和を失して居る、奇怪である、余程混雑して居る。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼も鼻も口も、すべての顔の道具立てが極端に大きくてしかも平べったく、人間のものとは思われないような感じを与えるのである。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈の高いのと、面長な顔の道具の大きいのとで、押出しが立派であったが、色沢がわるく淋しかった。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸見た場合、完全な顔の道具だてを持っている者よりは、大きな痣でも頬にある者の方が人目を欹てしめる。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔の道具立は、さて何と言いますか、さしずめ鼻は団子鼻というのではない。",
              "citation": {
                "source": "三味線の胴",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "その風姿は必ずしもきまってはいないが、ともかくも顔の道具をすべて持たない妖怪であるが、これらも一種の奇形感、病気感、を持っている。",
              "citation": {
                "source": "ばけものばなし",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ一つの顔の道具が美しいのではなくて、式部卿の宮によく似て、全体に艶なところのある顔を、構わないままにしてあっては、はなやかな、若々しいというような点はこの人に全然見られない。",
              "citation": {
                "source": "源氏物語",
                "author": "真木柱",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな場合、風景の中を撰択の為めに走り廻る事が面倒臭いからと云って、いい加減の所へいい加減の木を附け足して見たり、でたらめの人物を描き添えて見たりする人もあるが、これはよほど熟達した人でない限りは大変危険である、人間の顔の道具を勝手に置きかえて化物とする様なものである。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の顔の道具を勝手に置きかえて化物とするようなものである。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨汁だの帳簿だのの、のっかっていたテーブルの向う側に、黒い背広を着、顔の道具だてがみんな真中に向ってすり詰ったような表情の警視庁の特高が腰かけている。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌は白く、髪は多く、顔の道具も充分｜調い、上流の商家の娘のようだ。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　円い鼻、円い眼、おでこの額、よく喋舌る薄唇、顔の道具は綺麗ではないが、腹が綺麗で追従気がなく、それで熊太郎に愛されている男、それが清三郎という男であったが、そう云って熊太郎の顔を覗いた。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに人間の持っている顔の道具はそろっていた。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔の道具も大きく、がっしりしていて、頼もし気に見えます。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の胸に描く飛騨の翁とは、いかにも山人らしい風貌をそなえ、杉の葉の長くたれ下がったような白い粗い髯をたくわえ、その広い額や円味のある肉厚な鼻から光った目まで、言って見れば顔の道具の大きい異相の人物であるが、それでいて口もとはやさしい。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "にもかかわらず顔の道具は、いかめしいまでに調っていた。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓬々とした太い眉毛、魚の形をした夢見るような眼、決して険しくない高い鼻、軽く開いても強く結んでも、愛嬌のあふれる小型の口、これが顔の道具であった。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔の道具は無論｜極っている、大さも大概は似たり寄ったりである。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "お人形のように顔の道具が揃って、御殿女中のようにしとやかで、少し淋しくはあるが、大したものですね。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "腰抜け彌八",
                "note": "青空文庫"
              }
            },
            {
              "text": "引締った三十女、古典的な眼鼻立、お園のような不均整な顔の道具から来る魅力はありませんが、いかにも自尊心に充ちた人柄です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "夕立の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊麗で、媚を含んでいて、そのくせ上品にさえ見えるのは、顔の道具のよく整っているせいでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "一と目千両",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議な美しさを持った娘――お侠で柔順で、賢くて無知で、顔の道具の揃わないのが、反って一種の魅力になって居た矛盾だらけの江戸娘は、自分を害めた者の名も言わずに、一刻一刻、いや一瞬一瞬、命を燃やし尽して、母親の後を追うのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鬼の面",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
