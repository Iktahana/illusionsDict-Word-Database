        "examples": {
          "standard": [
            {
              "text": "川原の土手に、可憐な河原撫子が群生していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "河原撫子の花びらは、繊細で淡いピンク色をしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の笑顔は、野に咲く河原撫子のように、見る人の心を和ませる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "岬の中腹を低く高く導いて行く小道に、一つ二つ河原撫子のいたいけなのが叢の中に咲いてゐた。",
              "citation": {
                "source": "夜の浪",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "土手から摘んできた河原撫子を机上の壺に活ける、この花は見すぼらしいが、日本固有のよさがある、私の好きな花の一つだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早く散歩する、河原撫子を採つて来て活ける、素朴な可憐な花である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "憂愁を歌つた世界最初の詩人、シヤトオブリヤンの墓から汀つゞきに、「エメラルドの浜」と呼ばれるブルタアニユの北海岸、そこは河原撫子の乱れ咲くラ・ギモレエの岬なのです。",
              "citation": {
                "source": "海の誘惑",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原撫子、女郎花、鵯花、何やら升麻、車百合などの花が露重たげに頸垂れている。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪をさげ下地にして、細模様の縫入墨絵で河原撫子を描いた白絽の単衣に綿の帯を胸高に締め、腕のあたりでひきあわせた両袖は、霞かとも雲かとも。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "かごやの客",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
