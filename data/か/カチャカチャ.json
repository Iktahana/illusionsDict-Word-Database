        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食器がカチャカチャと音を立てていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は指輪と鍵をカチャカチャといじっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は苛立ちながら、机の上のペンをカチャカチャと鳴らしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "隣の部屋から、何かがぶつかり合うカチャカチャという音が聞こえてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ヒラメの家では食事はいつもその小僧がつくり、二階のやっかい者の食事だけは別にお膳に載せて小僧が三度々々二階に持ち運んで来てくれて、ヒラメと小僧は、階段の下のじめじめした四畳半で何やら、カチャカチャ皿小鉢の触れ合う音をさせながら、いそがしげに食事しているのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中はカチカチやっていたが、その皿がお膳から反りかえりそうになっても、コチコチで、そのうちカチャカチャ、くるりと皿ごと廻ってしまった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "勤めがなくて、ぽっぽにたんまりおこづけえがあって、べっぴん片手に船遊山、チャカホイ、チャカホイ、チャカチャカチャ――と、いけませんかね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　盃と銚子がやかましく、カチャカチャと触れ合った。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとには看護婦が残って、手術器械をカチャカチャと片づけているばかりだった。",
              "citation": {
                "source": "幸運の黒子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――うれしがって箸で机をたたいたり、茶碗をカチャカチャ鳴らしたりするものがあった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆箱のカチャカチャと鳴る音がいつまでも耳に残り、こんなことがあってから寿女は、途上で女の子を見付けると周章てて道をそらしたりした。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「千世ちゃんお前のハンカチーフが二枚ほか入って居ないから、名の縫いつけてあるのを五六枚出して御出」と云われて銀の錠をカチャカチャ云わせて納戸の西洋箪笥の二番目の引き出しをあけた。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうすこしだ――」　軈て、カチャカチャと、軽い音がした。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく中を開けて調べて見ろ」　カチャカチャと音をさせて、スウィッチの硝子蓋を開いてみたが、それは普通のスウィッチが、明らかに開かれた状態になっていて、外にインチキな接続は発見せられなかった。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "土塀の外にもカチャカチャ鍋を洗う音などがした。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "教師の話がすむと、あるものは起ち上り、あるものは隣りへ悪戯をしかけ、筆筒をカチャカチャいはせ、「先生！",
              "citation": {
                "source": "ママ先生とその夫",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「心得たりと武田左典廐信繁、これを受け止めた、また馬を乗り下げた謙信が馬勢を付けて進みきたりヤッ、ヤッ、ヤーッ」　カチャカチャ、カチャーン。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「リリーや、リリーや」とつづけさまに呼びながら、皿と罎とをカチャカチャ打ちつけてみたりしたけれども、リリーはてんで聞えないふりをして、まだ窓ガラスにしがみ着いているのであった。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの高い塔や記念碑についていえば、かつてこの町にシナまで穴を掘ることをくわだてた気狂いがいたが、そのいうところによると彼はシナの鍋や釜がカチャカチャ鳴るのが聞こえるとこまで往ったそうである。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラウンがこんなことを考えている間に、劔戟の音がせわしくせまってカチャカチャという急調に早変りを始めた。",
              "citation": {
                "source": "サレーダイン公爵の罪業",
                "author": "THE SINS OF PRINCE SARADINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その時、盆の上に最後に一つ残った茶わんが、小きざみにカチャカチャカチャと鳴る。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も下りて見ましょう、おやこれからお昼らしい、カチャカチャ茶わんの音がする。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人に云わせると長唄の三味線は余程の名人が弾かない限り、撥が皮に打つかる音ばかりカチャカチャ響いて、かんじんの絃の音色が消されてしまう。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　賊はあきらめたようにいいすてて、部屋のすみの大きな机の前へ行き、机の足をくりぬいたかくし引きだしから、六個の宝石をとりだすと、てのひらにのせて、カチャカチャいわせながらもどってきました。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お杉隠居のように痩せこけているかまきりという秋の虫が、鎌に似た細い脛をカチャカチャ鳴らして、人間へ斬ってかかる態を嘲っていうことばなのである。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩を送れ」　再びカチャカチャ掛け金の音がして、暗闇に隠れていた二人は、リッチフォードが入室してきて、我が家のように振る舞うのを見ても、全然驚かなかった。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械のような音だな」　確かに遠くの部屋からカチャカチャ、ゴウゴウ、ブンブンという音が聞こえ、まるで小さなモータを近くで回しているかのようだ。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "オイお常、そろそろ寝酒の御用意、おれはここを片づけ初めるから、奥へ支度をしてくんな」　と、しゃがれ声で女房へ怒鳴って、鞴のまわりや土間いッぱいの仕事道具を、カチャカチャ片づけ初めました。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
