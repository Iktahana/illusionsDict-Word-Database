[
  {
    "uuid": "fa01a82b-e36e-587f-a1fc-b88ee6a5915c",
    "entry": "片眼鏡",
    "reading": {
      "primary": "かためがね",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
