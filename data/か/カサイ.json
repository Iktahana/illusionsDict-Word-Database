  {
    "uuid": "a9e07b6e-a9b7-5410-badf-07f1d44c8d7c",
    "entry": "家裁",
    "reading": {
      "primary": "かさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
