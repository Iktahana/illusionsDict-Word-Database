        "examples": {
          "standard": [
            {
              "text": "朝刊の隅にある囲み記事で、地元出身の若手ピアニストが国際コンクールで優勝したことを知った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この雑誌の囲み記事には、専門家によるちょっとした豆知識が掲載されていて読み応えがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "編集会議で、新製品の紹介を広告ではなく編集側の囲み記事として扱うことが決まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "六月から半年の予定で「マイコンの世界」と題した囲み記事を週に一度連載しているのだという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、破損された部分に次のような小さな囲み記事があったことを見いだした：北共同墓地で夜の墓堀騒ぎ　本朝北共同墓地最古の区画において同墓地夜警ロバート・ハートはトラックに乗車した数人の男よりなる賊を発見し、なんであれ目的を達する前に一味を追い払った。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "別の囲み記事には、行方不明の子供ラディスラス・ワレイコの手がかりは発見されなかったと述べられていた。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日という日、というタイトルの囲み記事が、朝刊に連載されています。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
