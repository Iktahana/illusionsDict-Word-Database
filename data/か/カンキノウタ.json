    "definitions": [
      {
        "index": 1,
        "gloss": "Ode to Joy (choral fourth movement of Beethoven's Symphony No. 9)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
