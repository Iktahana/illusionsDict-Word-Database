        "examples": {
          "standard": [
            {
              "text": "高速道路を走行中、ドアミラーの隙間から発生する風切り音が耳に障る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あれ、マイクに風切り音が入っちゃってるな。スポンジのカバーを付け直そう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新型特急の先頭形状は、不快な風切り音を極限まで抑えるために設計されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ビルの谷間を吹き抜ける冬の突風が、ヒューヒューと不気味な風切り音を立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、風圧と風切り音、エンジンの音、そして車体から全身に伝わる振動は、すさまじい。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
