[
  {
    "uuid": "aa24f632-cfde-5060-9338-9a684e8d9ef0",
    "entry": "空になる",
    "reading": {
      "primary": "からになる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
