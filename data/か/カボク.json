[
  {
    "uuid": "38796393-2f7f-52b9-86c1-f58e399aa2af",
    "entry": "佳木",
    "reading": {
      "primary": "かぼく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "beautiful trees",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭園には、手入れの行き届いた佳木が並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遠くの山々には、雪化粧した佳木が連なっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この公園は、四季折々の佳木が楽しめることで有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それにまた雑木のもつ健康さが――雑木は多くの場合佳木よりも健康だ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろへ腰掛けてこぼこぼはっていく温い水へ足を入れていてついとろっとしたらなんだかぼくが稲になったような気がした。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだかぼくがつまずくようになるよ。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、彼がそんなにぼくに親切にしてくれるのは何故であるかぼくには分らなかったが、ぼくは唯、彼がぼくの機嫌をとる態度をみて、嫉妬される者の優越感を味い、少し己惚れ気味に良い気持になっていた。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "君よ　なぜ早く籠をひらいて鷄肉の　腸詰の　砂糖煮の　乾酪のご馳走をくれないのかぼくは飢ゑぼくの情慾は身をもだえる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の妹を殺した女が無罪に決定したって、何が嬉しいのかぼくには分からないなあ」「おれにとって嬉しいこたあ、いまとなってみればきみにとっちゃ悲しいことさ」「何を言っているんだ！",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "親から月々学資を送ってもらう身分でいながら、一度に二十円の三十円のと、人に用立てるなんて、いかにも無分別だとあるんですがね――なんだかぼくに責任があるように書いてあるから困る。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一標題がわからんです」「ハイドリオタフヒア」「なんのことですか」「なんのことかぼくにもわからない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかぼくのはらった犠牲を無駄にしないように考えてくれたまえ」　私には先生のこの暴挙を非難する余裕などなかった。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉さん、今日は何だかぼく、あの笛の音が淋しくて仕方が無いよ、そう思わない？",
              "citation": {
                "source": "おさなき燈台守",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、なにかぼくの蔭口ではないかと、焦々している耳に、内田さんの声が、「熊本さん、この頃、とても、しょげているのよ。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に悄気てしまったぼくが片隅でひとりダンスを拝見していると、いつの間にかぼくの横に、油もつけていないバサバサの長髪を無造作に掻きあげた、血色の悪い小男の青年がやって来て立っていました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四　ハワイをでると、あとはもう横浜まで海ばかりだという気持が、なにかぼくを気抜けさせるものがあって、船室に引籠って啄木歌集を読んだり、日向に出ては海を眺めたり、そんな時を過していました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもしかぼくが幸坊だつたら、すつかり開けて出ておいでね、とうと。",
              "citation": {
                "source": "幸坊の猫と鶏",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいか諸君、久保井先生がなければ学校がほろびるんだぞ、ぼくらはなんのために漢文や修身や歴史で古今の偉人の事歴を学んでるのだ、『士はおのれを知るもののために死す』だ、いいかぼくらは久保井先生のため浦和中学のため、死をもってあたらなきゃならん」「それでなければ男じゃないぞ」と叫んだものがある。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "長平はそれをそらして、「君は何かぼくに言いたいことがあるのじゃないか。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがどういふ機會に書かれたものかぼくは知らないが、かなり激越な、ほとんど喧嘩腰の文章である。",
              "citation": {
                "source": "三島由紀夫",
                "author": "ナルシシスムの運命",
                "note": "青空文庫"
              }
            },
            {
              "text": "透明人間は、口におしこんだシーツをとりのぞき、「ねえ、きみ、どうかぼくの言うことを信じてくれたまえ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあどうかぼくを捨てないでくれたまえ。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくの近所で聴いていた人たちは、まさかぼくを愛ちゃんの兄とは知らないから、――日本にもこんなに若くて、こんなにうまいピアニストがいたのかなア、多勢の外国人も来ているようだが、こんな芸術家を発見しただけでも、われわれの肩身が広い――と言っていたよ」「まア」　愛子は少しきまり悪そうでした。",
              "citation": {
                "source": "九つの鍵",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだお逢いしたことはありませんが――」「そりゃ、世間の評判さ、左近先生だって、まさかぼくのフィアンセを何うしようとはなさるまい」「でも」　三室銀子は自分の肩を犇と抱いて、処女らしい恐怖に身をふるわせるのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "結婚ラプソディ",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中でへたれこむ自分が可笑しくなり、笑うと、その笑いすら半分ほどで消えて、いつのまにかぼくは目を据えたまま短い吐息をくりかえしているのだ。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、いつのまにかぼくは興奮し、例によって夢中でたしかに生物は生物を食ってしか生きては行けないこと、強いものが勝つということ以外に、絶対的ななんの法則も生物界にはないと思う、という彼のその言葉への同感を、熱心にしゃべっていた。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺してやるという言葉がどこから降ってきたのかぼくは知らない。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢様、どうかぼくたちも協賛会員、いや一般会員として、いやむしろ設立会員として参加させてください。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
