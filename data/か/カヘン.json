[
  {
    "uuid": "8bd3ef88-0abd-58dd-8570-f959ddac098d",
    "entry": "可変",
    "reading": {
      "primary": "かへん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞-の形容詞",
