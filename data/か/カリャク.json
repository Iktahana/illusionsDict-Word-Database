        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歴史の教科書をめくると、嘉暦年間に起こった鎌倉幕府の内部抗争が詳しく記されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「嘉暦三年の銘があるこの五輪塔は、この地方で最も古いものの一つです」とガイドが説明する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古文書の端に『嘉暦』と記された日付を見つけ、調査チームは歓喜に沸いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "改元が行われた嘉暦の春、京の街では疫病が収まりつつあるという噂が広がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "正中元年その御計画は、北條氏の探知するところとなり、資朝、俊基の公卿を始め、土岐頼兼、多治見国長などの犠牲者を出したが、天皇は隠忍してその時機を待たせられて居たが、嘉暦元年北條氏の皇位継承に対する干渉露骨となるや、天皇の御決心いよ／＼深く、北條氏討伐の御計画は、正に一触即発の域に達した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "このナギヌルの訓は従来からそうであるが、嘉暦本にはイマゾユキヌルと訓んでいる。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（嘉暦二）　　　　　　　　　　　　　　　　　　（四条）　三月廿一日　　　　　　　　　　　　　　　　　左中将隆資奉進上　　　　　　　　　　　　　　　　　東寺長者僧正殿　とある。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝦夷は此時代を終るまで集團をなして陸奧に居住し、安東家の差圖によつて屡※叛亂を企て、それが爲め東北地方に兼ねてより關係のあつた關東の豪族即ち工藤右衞門祐貞、宇都宮五郎高貞、山田尾張權守高知等が、嘉暦年間に相踵いで出征を命ぜられたことが、北條九代記に出て居る。",
              "citation": {
                "source": "日本史上の奧州",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "為相はその後正二位権中納言に昇り、嘉暦三年六十六で薨じた。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "為世は自分の子や孫が勅撰集の撰者となるのを眼のあたりに見たし、嘉暦三年には為相が六十六で薨去した。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉改組と、わずか二日ちがいで、朝廷でも、改元ノ儀が行われ、この年を、　嘉暦元年　とするの令が、天下に布かれた。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇の第三皇子で、嘉暦二年以来、叡山に入っておられる前ノ天台の座主、尊雲法親王（大塔ノ宮）と、日野俊基であることをも明記していた。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに、嘉暦（六年前）のころ。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
