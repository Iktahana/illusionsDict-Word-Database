    "definitions": [
      {
        "index": 1,
        "gloss": "Karyaku era (1326.4.26-1329.8.29)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
