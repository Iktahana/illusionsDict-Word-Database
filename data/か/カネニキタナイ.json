        "examples": {
          "standard": [
            {
              "text": "彼は金に汚いから、割り勘でも1円単位まで計算して請求してくるんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの政治家は金に汚いことで有名で、小さな寄付金まで不正に流用していたらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "金に汚い人に限って、他人のことにはやたらと口を出すものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社の経費を私的に使い込むなんて、本当に金に汚い奴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "中国人は金に汚いというが、日本人は汚くないでしょうか。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "金銭について、金に汚い男というものは論外である。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
