        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "テーブルの上には、読みかけの本の重ねがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "庭の隅に、剪定した枝の大きな重ねが積まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちが作った、砂の重ねはまるで小さな山だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」　私は名誉の家の所以を語り、重ねてまた大隅君の無感動の態度を非難した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が、真率にして齢を重ねる時、「習慣」の存在に対して次第に寛容になることは、自然なことである。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "真率にして富永は齢を重ねていつた。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしおなかが空いたの――」　兄が傍を通る時に、畳の座板がひわるのが、良子の重ね合せて坐つてゐる足に感じられた、彼女は悲しい気持になつてゐた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その石段の両側には、土産物の寄木細工を売る店や、かういふ町に適当な小綺麗の小間物屋や、舶来煙草を飾つた店や、中庭に廻廊のある二層三層の温泉旅館が、軒と軒とを重ね合せて、ごてごてと不規則に並んで居る。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を切りそうな五円札を一重ねに折りかえして銅貨と一緒に財布へ押しこんだのを懐に入れて、神保町から小川町をしばらくあちこち歩いていた。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅員の不機嫌顔甚だしきも官線はやはり官線だけの権力とか云うものあるべしと、かしこみて願い奉りようよう切符を頂戴して立ちいずれば吹き上ぐる朝嵐に藁帽飛んでぬかるみを走る事｜数間、ようやく追い付きて取止めたれど泥にまみれてあまり立派ならぬ帽の更に見ばえを落したる重ね／＼の失敗なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく十二時となりて、プラットフォームに出でんとすればこの次のなりとてつきかえされし、重ね／＼の失敗なりける。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ何がはかないと云っても、浮世の人の胸の奥底に潜んだまま長い長い年月を重ねて終にその人の冷たい亡骸と共に葬られてしまって、かつて光にふれずに消えてしまう希望程はかないものがあろうか。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとひ眞珠を十萬粒二十萬粒積み重ねたつて、あれくらゐの高い山にはなるまい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを約百萬山くらゐ積み重ねると、まづざつとあれくらゐの峯が出來る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島は、重ね重ね、龜から無用の嘲弄を受けてゐるやうな氣がして、いまいましくてならぬ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "重ねて、Ｎさんには、おわびを言ひます。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに、重ね重ねの御無禮を御海容下さらば幸甚に存じます。",
              "citation": {
                "source": "文盲自嘲",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四合目となると、室も今までのように木造でなく、石を積み重ねた堡塁式の石室となる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は、眼を上げて、世界の出来事を見ると、地獄と極楽との絵を重ねて見るような、混沌さを覚えた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば時代や、季節や、人間の階級や、死因や、そういう標識に従って類別すれば現われ得べき曲線上の隆起が、各類によって位置を異にしたりするために、すべてを重ね合すことによって消失するのではあるまいか。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "反對側の、山の方へ向いた廊下へ出て見ると、此の山腹一面に築き上げ築き重ねた温泉旅館ばかりの集落は世にも不思議な標本的の光景である。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "数年前よりドイツのコルン氏が研究を重ねた末今年に至ってほぼ成効した、いわゆるコルン式写真電送機の事は既に我邦の諸新聞雑誌に掲載せられた事があるので事新しく述べる必要もないが、簡単に云ってみれば先ず次のような仕掛けである。",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぞれちがった色硝子の障子で天然の色を三通りに濾し分け、別々に撮った三つの写真版を赤黄青の三色で重ね刷りにするという趣向であって、絵具の調合などが巧みにゆけば相応に天然に近い色が出来る。",
              "citation": {
                "source": "天然色写真新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他電力の経済も、他灯に優るとも劣らぬと発明者は云っているが、この点はなお試験を重ねた後でなくては判然せぬものと見ねばならぬ。",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣類を失つた人々が秋が更けても白地の單衣の重ね着の袖を雨にしめらせながら街を歩いてゐた。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の三歳、五歳の祝ひ着は今の芝居のうちかけで見るやうな花蝶総縫ひのちりめんに下着を赤のゑぼしちりめんといふので重ねてありました。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "重ね重ねの母胎の苦労である。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅な松明の灯に照し出される岩肌は、穴の屈曲に従って　拗けた瘤をつけ　波打つ襞を重ねる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は香りを消さぬように薬味の青｜海苔を撒らずに椀を重ねた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに不思議なことはこの東海道には、京へ上るという目的意識が今もって旅人に働き、泊り重ねて大津へ着くまでは緊張していて常にうれしいものである。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『桜陰比事』の「四つ五器かさねての御意」などもそうした例であると同時に、西鶴の実証主義を暗示するものと見られる。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大島のかさねを黒いコートでつつんで、リスの毛皮を左乳に垂らした、頬紅をささない蒼白な厚化粧の女が、いつも一点をみつめ前後の気配を感ずる都会の女の乗った車が、中央九番街のクロス・ワード模様の東洋銀行のまえで停止すると、彼女のフェルトの草履が石畳を踏んで衣服の黒い裾裏が地上を流れる風にはねかえった。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "杳かな創世の日から勞働爭議の今日に至るまで、積みかさね積みかさねられたものがそこにある。",
              "citation": {
                "source": "太郎と街",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
