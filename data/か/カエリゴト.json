        "examples": {
          "standard": [
            {
              "text": "お世話になった先生に、感謝の印としてささやかな返り言を贈った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "結婚式の招待客には、記念品として返り言を用意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「遠方から来てくれてありがとう。」と言い、彼は友人たちに返り言を渡した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
