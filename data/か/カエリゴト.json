        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供は、母親の質問に素直な返り言をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "質問に対する彼の返り言は、的を射ていて分かりやすかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「どうして遅刻したの？」と聞かれ、彼はしどろもどろな返り言しかできなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
