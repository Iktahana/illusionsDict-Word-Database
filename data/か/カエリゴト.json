    "definitions": [
      {
        "index": 1,
        "gloss": "message that a messenger brings back home",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "王様は、使者が持ってきた返り言に満足しなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "城壁の上で、兵士は遠くから来る使者の返り言を待っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この間送った手紙への返り言はまだか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "『あの使のものが待つてをりますが――お返り言がございますのでございませうかツて？",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "心せはしき三度五度、答なきほど迷ひは愈々深み、氣は愈々狂ひ、十度、二十度、哀れ六尺の丈夫が二つなき魂をこめし千束なす文は、底なき谷に投げたらん礫の如く、只の一度の返り言もなく、天の戸渡る梶の葉に思ふこと書く頃も過ぎ、何時しか秋風の哀れを送る夕まぐれ、露を命の蟲の音の葉末にすだく聲悲し。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "世捨人に情も義理も要らばこそ、花も實もある重景殿に只々一言の色善き返り言をし給へや。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "心せはしき三度五度、答なきほど迷ひは愈狂ひ、十度、二十度、哀れ六尺の丈夫が二つなき魂をこめし千束なす文は、底なき谷に投げたらん礫の如く、只の一度の返り言もなく、天の戸渡る梶の葉に思ふこと書く頃も過ぎ、何時しか秋風の哀れを送る夕まぐれ、露を命の蟲の音の葉末にすだく聲悲し。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "世捨人に情も義理も要らばこそ、花も實もある重景殿に只※一言の色善き返り言をし給へや。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仰せのとほり昔ながらの宮廷の生活が懐しく思はれます」との返り言であつたと言ふ。",
              "citation": {
                "source": "日本文学における一つの象徴",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
