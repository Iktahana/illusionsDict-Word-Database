[
  {
    "uuid": "fe61463b-430f-5d24-af7a-89d263c76b3f",
    "entry": "仮寝",
    "reading": {
      "primary": "かりね",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
