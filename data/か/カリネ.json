    "definitions": [
      {
        "index": 1,
        "gloss": "nap",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "電車の中でつい仮寝をしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は昼休みにデスクで仮寝をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "疲れたので、少しの間仮寝しよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "仮寝のつもりが、つい熟睡してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "森は、忍の森、仮寝の森、立聞の森。",
              "citation": {
                "source": "古典竜頭蛇尾",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋の硯を仮寝の床に、路の記の端に書き入れて、一寸御見に入れたりしを、正綴にした今度の新版、さあさあかわりました双六と、だませば小児衆も合点せず。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の疲もあり、蒸々する晩でもあり、不寝番の控室てはとろとろと仮寝の鼾も出ようと云ふ真夜中に、けたゝましいもの音、やにはに飛出した囚人。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "この空小屋のうちに仮寝せし渠の懐には、欣弥が半年の学資を蔵めたるなり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっぱつまり、旅の仮寝の枕元の一輪を、日本浪曼派と名づけてみた。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に取って見れども信ぜずば、見ざるもひとしき仮寝の夢。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "所詮、私は、東京のあばらやで仮寝して、生家のなつかしい夢を見て慕ひ、あちこちうろつき、さうして死ぬのかも知れない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜更け、燈火の灯影に鈴懸炬燵にあたって、仮寝している。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の悔恨は殺された娘の上へ乗り移り、洋菓子やチョコレエトを買わず、駄菓子の飴を買うて、それでわびしい安宿の仮寝の床の寂しさをまぎらしていたところに、その娘の悲しい郷愁が感じられるような気がし、ふと私は子守歌を聴く想いだった。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして甘酸ゆい燐光の息するたびに、あをあをと眼に沁みる螢籠に美しい仮寝の夢を時たまに閃めかしながら、水のまにまに夜をこめて流れ下るのを習慣とするのである。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の親愛な友人は私を大きな寝台に寝かしてくれて、自分は談話室のソファを仮寝台にこさえさして寝た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は葦間に仮寝の夢を結び、朝になれば、また、果知らぬ水底の砂原を北へ向かって歩み続けた。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は店のテーブルの上に俯向いて仮寝をしてゐるところを、お菊さんに起されたところであつた。",
              "citation": {
                "source": "蛾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れ流れて仮寝の宿に転がる姿を書く時だけが、私の文章の生き生きする瞬間であり、体系や思想を持たぬ自分の感受性を、唯一所に沈潜することによって傷つくことから守ろうとする走馬燈のような時の場所のめまぐるしい変化だけが、阿呆の一つ覚えの覘いであった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "五更（午前三時―五時）に至るまで寂然として物音もきこえないので、守る者も油断して仮寝をしていると、たちまち何物かはいって来たらしいので驚いて眼をさますと、将軍の妻はすでに行くえ不明であった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　わたしは宿屋の仮寝に飽きると佗しさに身をもてあまして、その夜中過ぎまでも酒を飲ませる店に渋々ながらも出かけるのが常だつた。",
              "citation": {
                "source": "書斎を棄てゝ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵は大宮に仮寝の夢を結ばんとおもえるに、路程はなお近からず、天は雨降らんとし、足は疲れたれば、すすむるを幸に金沢橋の袂より車に乗る。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "深く酔った家従たちは皆夏の夜を板敷で仮寝してしまったのであるが、源氏は眠れない、一人｜臥をしていると思うと目がさめがちであった。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『新著聞集』酬恩篇に、相馬家中の富田作兵衛二階に仮寝した夢に、美女来って只今我殺さるるを助けたまわば、末々御守りとも成らんという。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜半に燈下に坐して、倦んで仮寝をしていると、恍惚のうちに白衣の女があらわれて、鍼でそのひたいを刺すと見て、おどろき醒めた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "池北偶談",
                "note": "青空文庫"
              }
            },
            {
              "text": "言うことを聞かぬとか、物をよく食うとか、仮寝をするとか、なんぞと言っては、どやしつけられるのがつらさに、ある時などは、村の路に通りかかった旅商人らしい男に縋って、どこへでもいい、どんな難儀をしてもいいからいっしょに連れていってくれと頼んだ。",
              "citation": {
                "source": "ネギ一束",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もういいかな」「ああ」「風邪だんべい」「寒い思いをしてはいけないいけないッて言っても、仮寝なぞしているもんだから……風邪を引いちゃったんさ……」「お母、いい気だからなア」「ほんとうに困るよ」「でも、お種坊はかせぎものだから、お母、楽ができらアな」　娘は黙って笑った。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、夜中眠られない癖がついてしまったので、昼間よく仮寝をする。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "小樽で下車して、姉の家で朝飯を喫め、三時間許りも仮寝をしてからまた車中の人となつた。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、壁一面に貼りつけた満洲の地図と大きな地球儀を備へた離れの居間にうづくまつて、酒がまはると脇息に凭れて仮寝をするだけだつた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、奥様は私共の夜のようじゃ無い、一寸した仮寝にも直ぐ夢を御覧なさる位ですから、それは夢の多い睡眠に長い冬の夜を御明しなさるので、朝になっても又た克くそれを忘れないで御話しなさるのです。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗衣かわかしたゝむ君しあればかりねの宿とわがおもはなくに廿三日小山の停車塲にて長塚と袂を分つ。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「じゃ……私を、」　と擦寄って、「不埒と言わないばッかりね。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ヨハンネスは、コップに二はいのむと、もうすっかりねむくなって、目をあけていることができなくなり、そのままぐっすり寝込んでしまいました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもこの小さなもみの木は、ただもう大きくなりたいと、そればっかりねがっていました。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "stopping at an inn",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
