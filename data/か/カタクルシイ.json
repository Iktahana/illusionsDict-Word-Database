[
  {
    "uuid": "475be890-690a-55dc-8584-1d2251844e9c",
    "entry": "堅苦しい",
    "reading": {
      "primary": "かたくるしい",
      "alternatives": [
        "かたぐるしい"
      ],
      "is_heteronym": false
    },
    "grammar": {
