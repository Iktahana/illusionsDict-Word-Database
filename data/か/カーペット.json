        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しく敷いたカーペットの色が部屋の雰囲気にぴったり合っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "猫がカーペットの上で爪とぎをしてしまうので、困っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このカーペットは肌触りが良くて、冬でも床からの冷えを感じにくい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、膝にのせた手のさきから、燃え尽した巻煙草の灰がほとりと落ちて、緑のカーペットに砕ける。",
              "citation": {
                "source": "秋の歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその離れ家の入口の側にある芝生の上には、カーペットとかその他そんなものがおいてありました。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼の云うままに二階に上っていってみますと、彼の指さすカーペットの上に、ありありと人の足跡が三つ四つしるされているのでした。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして小さな少年の給仕が出て来て案内してくれたので、私たちは直ちに、美しいカーペットの敷いてある階段を昇って二階に行こうとした。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが倭文子はなぜか妙に、しょげてしまって、そこにあった安楽椅子に腰を降ろしてぼんやり青いカーペットに目を落していた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "村川は、椅子から立ち上って、チラリと京子の方を見ると、すぐ眸を、カーペットの上に落していた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　村川のカーペットに置いている両足はガクガクとふるえた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　村川は、狂気のように叫んだかと思うと、腰かけていた椅子からずり落ちて、カーペットの上に、ひざまずいた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はあやまってあなたを……」　村川は、カーペットに頭をすりつけた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "床にはカーペットが敷いてありました。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーペットの上は埃でよごれて、電気スタンドの不必要に長いコードがうずを巻いており、その上や周囲には、紙屑や蜜柑の皮などが一面に散乱して、前の晩に眠るときに読んだものと見えて、二三枚の夕刊が散らばっていました。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛け布団は近頃新調した、新しい錦紗の布団でしたが、その下から毛布がはみ出して、だらりとカーペットの上へ垂れ下がっていました。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "床は綺麗なカーペットになっていたので、それを痛めるのは気の毒だと思いまして、下に落さぬようにして手でもみ消したそうでございました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の上には色の凝ったカーペット二つ三つ。",
              "citation": {
                "source": "書斎を中心にした家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの日には書斎のカーペットがすり切れているほど机のぐるりを歩き廻って、朝九時から夜中まで仕事しているカールも、日曜日ばかりはイエニーと子供たちとの完全なとりこになった。",
              "citation": {
                "source": "カール・マルクスとその夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「又始まった、いやなら行かなけりゃいいさ、いつでもあれだ我ままものだネエ」　母親はひったくる様に斯う云ってＨと源さんに賛成をもとめる様に目をやったけれ共、二人ともよそを見てたもんでしまつのわるくなった目を籐椅子の編目をくぐらせてカーペットの花模様の上におっことした。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "用具はいずれもマホガニー製で、床は矢筈組樫木張で、その上に高価なカーペットが、ずっと敷きつめてありました。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ピリニアークの家、窓のカーテンにまでも、厚いカーペットをつり下げてあるところ、彼の生活力と、腕力を示して特徴あり。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○カーペット沢山、135 ゾロチ　25 ゾロチ　95 ゾロチ　一寸よいのがある。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さいカーペットがその横の手摺にかけてある。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーペットをめくってガラン堂になった西洋間、手伝の男に床をふかせ、長椅子をおく。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーペットにお住まいのアリスの右足さまへアリスから愛をこめてまったく！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで彼は老女と小さな毛皮野郎がカーペット敷きの床の上を近づいてくるのを見た。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーペットの上では大変見分けづらかったのだが、カーペットの縁と幅木の間に床が剥き出しになった部分があった。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこが応接室につかわれていて、もう数人の先客が、いくらか褪せた淡紅色のカーペットの上に自由にばらばらおかれている肱かけ椅子の上にかけていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十歳と五十歳との間ぐらいに見えるそのがっしりした肩幅の婦人は、瀬川や伸子たちが厚いカーペットの上を音なく歩いて、そのデスクから五六歩のところへ来るまで、手にもっている書類から視線をあげなかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤堂駿平の一行で占められているサヴォイ・ホテルの奥まった一画から、おもての方へ深紅色のカーペットの上を歩いて行きながら、伸子は、モスクの住宅難からある邸の温室を住宅がわりにして、そのガラス張りの天井の下へ、ありとあらゆるものをカーテン代りに吊って、うっすり醤油のにおいをさせながら暮しているのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はすっと瀟洒に身をかがめて伸子が落して知らずにいたハンカチーフを赤いカーペットの上からひろいあげると、「ヴォアラ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
