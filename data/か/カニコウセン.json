        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "小説「蟹工船」は、これらの船での労働者の過酷な生活を描いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "カニ缶詰船は20世紀初頭の漁業にとって不可欠だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "蟹工船での労働は、極限の条件で知られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "この蟹工船博光丸のすぐ手前に、ペンキの剥げた帆船が、へさきの牛の鼻穴のようなところから、錨の鎖を下していた、甲板を、マドロス・パイプをくわえた外人が二人同じところを何度も機械人形のように、行ったり来たりしているのが見えた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに日本の「蟹工船」に対する監視船だった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "（函館の労働組合は蟹工船、カムサツカ行の漁夫のなかに組織者を入れることに死物狂いになっていた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「分ってるものもあるだろうが、云うまでもなくこの蟹工船の事業は、ただ単にだ、一会社の儲仕事と見るべきではなくて、国際上の一大問題なのだ。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に函館を出帆した他の蟹工船は、何時の間にか離れ離れになってしまっていた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹工船には川崎船を八隻のせていた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――蟹工船はどれもボロ船だった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへもってきて、船一艘でマンマと何拾万円が手に入る蟹工船、――彼等の夢中になるのは無理がない。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹工船は「工船」（工場船）であって、「航船」ではない。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それに、蟹工船は純然たる「工場」だった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この蟹工船だって、今はこれで良くなったそうだよ。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――蟹工船にはそういう、自分の土地を「他人」に追い立てられて来たものが沢山いた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "積取人夫は蟹工船の漁夫と似ていた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹工船では、船長の発声で、「万歳」を叫んだ。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでさ、駆逐艦が蟹工船の警備に出動すると云ったところで、どうしてどうして、そればかりの目的でなくて、この辺の海、北樺太、千島の附近まで詳細に測量したり気候を調べたりするのが、かえって大目的で、万一のアレに手ぬかりなくする訳だな。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、蟹工船の「仕事」は、今では丁度逆に、それ等の労働者を団結――組織させようとしていた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｈ・Ｓ会社」はカムサツカに五千八百万罐、蟹工船に七百八十万罐、千島、北海道、樺太に九百八十万罐移出していた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりか、今年ロシアが蟹工船の漁夫供給問題の復仇として、更にカムチャツカの、優良漁区に侵出してくることは分りきっていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一九二八・三・一五」「蟹工船」「不在地主」等の比較的まとまった作品を発表して、プロレタリア身辺小説を掲棄した小林多喜二はこの方面における第一の功労者といって差し支えなかろう。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がプロレタリア文学の作品がなんら新しい形式を獲得していないと批難したのは批難する方が無理であると思わせたが、「蟹工船」の批評には適切な意見が含まれていた。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて、有名な「蟹工船」が書かれ、「不在地主」「工場細胞」「オルグ」「独房」「転形期の人々」「沼尻村」と精力的に作品が送り出されたが、我々が特別注目し又感歎するのは、同志小林多喜二が一つの作品から一つの作品へと常に前進しつづけたプロレタリア作家としての努力、覚悟についてである。",
              "citation": {
                "source": "同志小林多喜二の業績",
                "author": "――作品を中心として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "同志小林は「蟹工船」において、日本資本主義の植民地的搾取の真相と、日本海軍がどのように人民収奪を援助する任務をもっているかということを、生産面においてくまなく描こうとした。",
              "citation": {
                "source": "同志小林の業績の評価に寄せて",
                "author": "――誤れる評価との闘争を通じて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく、発展の本質に対する誤った認識の上に立って、同志小林の創作活動は「蟹工船」を頂点とする見解がある。",
              "citation": {
                "source": "同志小林の業績の評価に寄せて",
                "author": "――誤れる評価との闘争を通じて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "作品の具象化の点で部分的難点はあるが、同志小林によって最近執筆されたこの二篇の小説は、「蟹工船」時代の自然主義的手法の晦渋さ、その反撥として以後の諸作を貫いていたやや浮き上った平易さへの努力の跡を揚棄している。",
              "citation": {
                "source": "同志小林の業績の評価に寄せて",
                "author": "――誤れる評価との闘争を通じて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "同志貴司山治が『時事』に書いた文芸時評中にも、この作品を形象化の欠如という点からだけ批判し、「蟹工船」以後の発展、特に去年四月以後同志小林が行った本質的飛躍については触れていない。",
              "citation": {
                "source": "同志小林の業績の評価によせて",
                "author": "――四月の二三の作品――",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説として「蟹工船」「太陽のない街」「三・一五」「鉄の話」「キャラメル工場から」「施療室にて」などが生れ、プロレタリア文学の理論は、当時国際的な革命的文学運動の課題となっていた唯物弁証法的創作方法の問題、世界観の問題、前衛の文学の問題などをとりあげた。",
              "citation": {
                "source": "作家の経験",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "未熟であり、よしやある誤りを含んでいたとしても、新しい社会生活の感情がそのような芸術理論をも生んだのであって、小林多喜二の「蟹工船」「不在地主」徳永直の「太陽のない街」村山知義の「暴力団記」「東洋車輌工場」その他多くの新しい文学作品が現れた。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二九年には小林多喜二の「蟹工船」がかかれ、中野重治の「鉄の話」、黒島伝治の特色ある反戦的短篇があらわれたのもこの時代である。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして恐ろしい戦争の時代を通過して、小林多喜二が生きて闘ったものはどれほど残酷なものであり、どういう意味において小林がそれと闘われたものであるか、「蟹工船」なんかのようにどういう風にして労働する人の生活が武力によって監視されているかということを書いてある、それを何と思って読んだでしょう。",
              "citation": {
                "source": "婦人の創造力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば葉山嘉樹の「海に生くる人々」、小林多喜二の「蟹工船」、徳永直の「太陽のない街」などを全部引用しなければならないだろう。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
