        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "漢方薬の原料として、葛根は古くから重宝されてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "葛根を煮出して作ったお茶は、体に良いとされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬の寒い日には、葛根を使った料理が体を温めてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "葛根田川の河原におりて行く。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで脈を一つ採ったことの無い、自分の風邪をひいたのには葛根湯を飲んで、それで治る医者なんだ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "風薬の葛根湯ぐらいならいいが、疵薬でも買やあしねえか」「ようがす。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "友の一人が少し風気で携行した葛根湯か何か煎じてゐたが、山上の寒さの身にしむ宵とて皆に分けて飲ませる光景、外の山には雪が積つてゐてその上を弦月が照らしてるといふわけである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは皆山伏の末えいで、旅館になり、農になり或は葛根をほってたつきとしている。",
              "citation": {
                "source": "英彦山に登る",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃の風邪の薬は例の葛根湯で、少し熱が強ければ、セキコウを加える。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この外多少蘭方を知っているものは、葛根でなくて茅根を用いて茅根湯といっていた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天ゆく月を綱にさし」も、月の蓋の外に、巫女の月ごもりなるものを、此新室の葛根もてする如く徴して、おのが者として、かづき臥し給ふといふので、床入り際の歌である。",
              "citation": {
                "source": "小栗判官論の計画",
                "author": "「餓鬼阿弥蘇生譚」終篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱は心の鎮り、梁は心の栄し、椽は心の整り、蘆※は心の平ぎ、葛根は命の堅め、葺き芽は富みの過剰を示すと言ふ風の文句の後が、今用ゐて居る酒の来歴を述べる讃歌風のもので、酒ほかひの変形である。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の八十蔭（天の御蔭・日の御蔭）葛根など言ふのは、皆屋の棟から結び垂れた葛の縄である。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "築き立つ　稚室葛根築き立つる柱は、此｜家長の御心の鎮りなり。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此神の子として、若室｜葛根神（記）の名を伝へて居るのは、寧、御饌神即厨の神とする説の方がよい。",
              "citation": {
                "source": "小栗外伝（餓鬼阿弥蘇生譚の二）",
                "author": "魂と姿との関係",
                "note": "青空文庫"
              }
            },
            {
              "text": "この薬たしかに効能あるやうに覚えければその後は風邪心地の折とてもアンチフェブリンよりは葛根湯妙振出しなぞあがなひて煎じる事となしぬ。",
              "citation": {
                "source": "矢はずぐさ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから養子が死んでそのまた養子が跡を続いだら葛根湯がアンチピリンに化けるかも知れない。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩飯も拔きまして、葛根湯を二杯も呑んで、一寢入りとすると、曉方御店から小僧が飛んで來ました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "凧の詭計",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の小言を葛根湯と間違えてやがる」「でもね、親分。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なアに、三輪の親分の顔が見てえという話で――」「止さねえか、馬鹿野郎」「へッ、これで葛根湯が四服目だ」　手の付けようがありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥取縣の東伯郡などには、蕨のカネといふ語があり、鹿兒島縣でも特にクヅノカネと明示して居るから、少なくとも長門の豐浦郡のやうに、之をカヅネとはつきりと發音し、葛根の語音の如く考へるのは誤りであらう。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥取県の東伯郡などには、蕨のカネという語があり、鹿児島県でも特にクズノカネと明示しているから、少なくとも長門の豊浦郡のように、これをカズネとはっきりと発音し、葛根の語音のごとく考えるのは誤りであろう。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "順序を立てて話して見るがいゝ」「昨夜お勢は戌刻（八時）過ぎまで無事だつたさうですよ」「誰が見たんだ」「お秀は客の歸る一寸前、少しばかりの隙を見付けて、お萬に葛根湯を煎じさせて、四疊半へ持つて來させて飮ませたさうです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青い帶",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お勢は葛根湯を飮まなかつたらしいよ、吐月峰の中は藥で一杯だ」「へエ――？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青い帶",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何んだね、親分」「昨夜、お勢が葛根湯を飮むところを見たのか」　平次の問ひは不思議でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青い帶",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐しくこんがらかつてゐるから――ところで、昨夜お勢が葛根湯を飮むところを見なかつたのかい」　平次はまだ葛根湯に取憑かれてをります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青い帶",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛根湯を飮ませると言つて、藥を吐月峰に捨て、その後で殺されたやうに見せるために、いろ／＼の細工をした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青い帶",
                "note": "青空文庫"
              }
            },
            {
              "text": "順序を立てて話してみるがいい」「ゆうべお勢は戌刻（八時）過ぎまで無事だったそうですよ」「誰が見たんだ」「お秀は客の帰るちょっと前、少しばかりの隙を見付けて、お万に葛根湯を煎じさせて、四畳半へ持って来させて飲ませたそうです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "青い帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お勢は葛根湯を飲まなかったらしいよ、吐月峰の中は薬で一杯だ」「ヘエ――？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "青い帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだね、親分」「ゆうべ、お勢が葛根湯を飲むところを見たのか」　平次の問いは不思議でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "青い帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしくこんがらかっているから――ところで、ゆうべお勢が葛根湯を飲むところを見なかったのかい」　平次はまだ葛根湯に取憑かれております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "青い帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一つむこうのテーブルでは給仕達が夢中になってラグビーの話をしながら飯をかっこんでいる。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "-------------------------------------------------------　　　　　　　　一　炉ばたのゴザのこっち側で、たけをが箱膳を膝の前に据え、古漬けの香のもので麦七分の飯をかっこんでいる。",
              "citation": {
                "source": "だるまや百貨店",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
