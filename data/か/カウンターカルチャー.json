        "examples": {
          "standard": [
            {
              "text": "1960年代には、若者を中心にカウンターカルチャーが世界中に広がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の作品は、当時のメインストリームとは異なるカウンターカルチャーの影響を強く受けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい世代は、既存の価値観に疑問を投げかけるカウンターカルチャーを生み出すことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その後離婚と退職をきっかけにサンフランシスコに移り住んだアルブレヒトは、大気中にカウンターカルチャーのにおいの充満したカリフォルニアで、コンピューターの布教活動を続けたいと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六〇年代後半、世界をおおった学生反乱の源流を生み、カウンターカルチャーの巨大なゆりかごとして機能した西海岸のはみ出し者たちの中には、コンピューターを管理と支配の象徴としてとらえる意識が根を張っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
