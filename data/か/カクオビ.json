    },
    "definitions": [
      {
        "index": 1,
        "gloss": "man's stiff sash",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は粋な着物姿で、博多織の角帯を締めて祭りに出かけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "祖父から譲り受けたこの角帯は、手織りの温かみがあって気に入っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "浴衣を着るとき、角帯をきりっと結ぶと全体の印象が引き締まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "さまざまの背広服のほかに、学生服を着たり、菜葉服を着たり、あるときには角帯に白足袋という恰好で私を狼狽させ赤面させた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」有本や霧積は何か眩しく光る絵巻か角帯らしいものをひろげて引っぱってしゃべってゐた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（尖へ玉のついた長杖を突き、草色、石持の衣類、小倉の帯を胸高で、身の丈六｜尺あまりもあらうかと云ふ、大な盲人）――と云ふのであるが、角帯を胸高で草色の布子と来ては、六｜尺あまりの大な盲人とは何うも見えぬ。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころの給仕人は和服に角帯姿であったが、震災後向かい側に引っ越してからそれがタキシードか何かに変わると同時にどういうものか自分にはここの敷居が高くなってしまった、一方ではまたＳとかＦとかＫとかいうわれわれ向きの喫茶店ができたので自然にそっちへ足が向いた。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺絣に角帯というのもまた珍妙な風俗ですね。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "縞の着物に角帯をしめて歩いたものである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "袷の紺飛白に一本｜独鈷の博多の角帯を締め、羽織の紐代りに紙繕を結んでいる青年音楽家は、袖をつめた洋装を着た師の妹娘を後に従えて、箱根旧街道へと足を向けた。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その儒者風な顔に引較べて、よれよれの角帯に前垂れを掛け、坐った着物の裾から浅黄色の股引を覗かしている。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "方角をかえて河岸通へ、しかものそのそと着流しのぐなりとした、角帯のずれた結目をしゃくって行く。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽織を捌いた胸さがりの角帯に結び添え、希くは道中師の、上は三尺ともいうべき処を、薄汚れた紺めりんすの風呂敷づつみを、それでも緊と結んだと見えて、手まさぐると……「解いてあげましょうか。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、甘谷という横肥り、でぶでぶと脊の低い、ばらりと髪を長くした、太鼓腹に角帯を巻いて、前掛の真田をちょきんと結んだ、これも医学の落第生。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺の腹掛、唐桟の単衣に角帯、麻裏草履、そのような服装をしていながら、白線の制帽をかぶって、まちを歩いたのは、一たい、どういう美学が教えた業でしょう。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐桟、角帯、紺の腹掛、白線の制帽、白手袋、もはや収拾つかないごたごたの満艦飾です。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関で靴を脱いでいたら、角帯をきちんとしめた番頭さんのような若い人が出て来て、どうぞと小声で言ってスリッパを直してくれた。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんという俳優か名前はわからなかったが角帯をしめた四十歳前後の相当の幹部らしいひとが二人、部屋の隅の籐椅子に腰かけていた。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "最上等の麻の着物と、縫紋の羽織と夏袴と、角帯、長襦袢、白足袋、全部そろえて下さいと願ったのだが、中畑さんも当惑の様子であった。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝起きた時から、よごれの無い、縞目のあざやかな着物を着て、きっちり角帯をしめている。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんという布地か、私にはわかりませんけれど、濃い青色の厚い布地の袷に、黒地に白い縞が一本はいっている角帯をしめていました。",
              "citation": {
                "source": "恥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、角帯に、夏羽織を着てゐた。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、二十一歳の冬に角帯しめて銀座へ遊びにいって、その晩、女が私の部屋までついて来て、あなたの名まえなんていうの？",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "※頭角帯、緋緑の衣を着た判官が数人入ってきて何か言いはじめた。",
              "citation": {
                "source": "富貴発跡司志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして間もなく彼は訪れなくなつたので、花屋の帰りに安否を伺ひに尋ねると、冬の頃折々途上で顔を見知つてゐた夜番の人が現はれて、正平の父であると云ひ、倅は卒業も待てずに奉公に出し、今日は第一の休日で角帯を絞めて帰つて来たがと述べた。",
              "citation": {
                "source": "魚籃坂にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に戻つて見ると、袂のついた縞の着物に角帯を絞めた正ちやんが、僕の机の上のスタンド・ランプの傍らで僕の子と共に絵本を開いてゐた。",
              "citation": {
                "source": "魚籃坂にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そんな声で私は目を開くと、ひとりの無帽の、角帯に黒つぽいよれよれの素袷を着流した男が、私の眼上に枯木のやうに突ツ立つたまゝ眼ばたきもせずに私の顔を見降してゐた。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も自分のそれらの知人は、遠国から遥々都へ遊学に出た青年で、学校の制服を嫌つてピカ／＼光る着物を着たり角帯をしめたり、そしてさうしない者を返つて田舎者だと云つて軽蔑する程の・以下の田吾作青年ばかりだつた。",
              "citation": {
                "source": "松竹座を見て（延若のこと）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四の夏が秋に移ろうとしたころ、葉子はふと思い立って、美しい四寸幅ほどの角帯のようなものを絹糸で編みはじめた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車が新橋に着くと葉子はしとやかに車を出たが、ちょうどそこに、唐桟に角帯を締めた、箱丁とでもいえばいえそうな、気のきいた若い者が電報を片手に持って、目ざとく葉子に近づいた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地理的にいえば、大塚と行徳と荒芽との三地点から縄を引っ張った三角帯が『八犬伝』の本舞台であって、この本舞台に登場しない犬江（親兵衛は行徳に顔を出すがマダ子役であって一人前になっていない）・犬村・犬阪の三犬士は役割からはむしろスケ役である。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "美妙は鯔の背のように光ったベラベラ着物に角帯をキチンと締め、イツでも頭髪を奇麗に分けて安香水の匂いをさしていたが、紅葉は燻んだ光らない着物に絞りの兵児帯をグルグル巻いて、五分刈頭の紺足袋で八幡黒の鼻緒の下駄が好きであった。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は白足袋に角帯で単衣の下から鼠色の羽二重を掛けた襦袢の襟を出していた。",
              "citation": {
                "source": "手紙",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
