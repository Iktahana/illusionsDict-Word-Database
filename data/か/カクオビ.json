[
  {
    "uuid": "32d2b6ef-b8cf-5c32-9c5a-6059f2242da0",
    "entry": "角帯",
    "reading": {
      "primary": "かくおび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
