[
  {
    "uuid": "44744203-9c35-5cb7-b791-c4767d03cac9",
    "entry": "カツカツ",
    "reading": {
      "primary": "カツカツ",
      "alternatives": [
        "かつかつ"
      ],
      "is_heteronym": false
    },
    "grammar": {
