        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "文化祭で、有名な絵画を再現する活人画の出し物が一番人気だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "活人画の役者は、長い時間じっと動かずにポーズを保つ練習をしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "美術館のイベントで、来場者が名画の活人画に挑戦する企画があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "実に美しい活人画がそれからそれと現われて来る。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれらの一つ一つのシーンは多くの場合に静的であり活人画でありポーズである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○七月十五日より歌舞伎座にて、歴史活人画を興行。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうひとりは、ほかの子供たちの着物をみんな自分のからだに巻きつけて、椅子の上に立ちあがり、ぼくは活人画だぞ、みんなであててみろ、と言いました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてその山は安宅先生が一期の演出として死の果よ、美の戯れよと呼びながら湖水の霧がくれに、行きすがら、うす紅色の裸体活人画を見せて私たちから遁れ失せた山であります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "微妙な震度に応じて彼の姿体は、様々な姿制を活人画として人々に感知させた。",
              "citation": {
                "source": "素書",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎はこの活人画から受ける安慰の念を失った。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "入木亭の店先には熱海の早咲の梅花が生けられ、女学生の活人画が催された。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、私が時々画を頼んだことのある日清戦争中の人気者であつた「勇敢なるラツパ卒の討死」の光景を、活人画にして私の眼前に髣髴させた。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その活人画は黙殺して、天上の悪魔を打ち倒した時の「豆の木のジヤツク」の心を心として、悠々と、剣を鞘に収める真似をして、彼が息を引き取るのを見降しながら、「他愛もなく片附けてしまつた。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎は此活人画から受ける安慰の念を失つた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "不規則なる春の雑樹を左右に、桜の枝を上に、温む水に根を抽でて這い上がる蓮の浮葉を下に、――二人の活人画は包まれて立つ。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗近君の眼から活人画が消える。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙んまりと云ふことは主としておほまかな動き、活人画的、活人画といふのは一寸説明がしにくいですが、本当の人間がある瞬間、画の様な或は彫刻の様な効果を与へることであります。",
              "citation": {
                "source": "日本演劇の特質",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この美術祭には岩村先生が大いに力を入れて二三日間も続き、飾物も出来る運動会もやる仮装行列もやるという風で、僕らは裸体になって活人画をやった。",
              "citation": {
                "source": "美術学校時代",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある時は、平生｜活人画以上の面白味は解せないくせに、歴代の名作のある画廊を経営していた。",
              "citation": {
                "source": "世界漫遊",
                "author": "ダウィット　Jacob Julius David",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとすると、これはあたしのために催している厳粛な活人画なのかもしれないと思うと、馬鹿らしくなって見てやる気もなくなった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時これはうつくしい活人画だと思った。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞の振りや楽の旋律を無視して論ずるのは無謀であるが、ただこの舞曲の構造から考えると、恐らく活人画を去ること遠くないものであったろう。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千々子さまは、この世にあきらめということのあるのを忘れ、半礼装の一帳羅を着こみ、活人画中の人物のようにしゃちこばって、毎日、根気よくシュラー氏を待っている。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "拳を振上げたものは拳を振上げたまま、幸田の襟首を掴まえたものはその襟に手を掛けたまま、無惨にも地面へ鼻面を摩りつけられた幸田節三さえもアングリと口を開けたまま、活人画の人形のように動かなくなってしまった。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "活人画中の一人になぞらえるにしても、柚子なら、もっと立派にやり終わすだろう、美しさも優しさも段ちがいだと、池田の胸にムラムラと口惜しさがこみあげてきた。",
              "citation": {
                "source": "春雪",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "濠端の久太夫と赤木屋の手代は、活人画中の人物のように、ものの四半刻ばかり、そこで凝り固まっていたが、そのうちにどちらの顔にも疲労の色が濃くなり、斬るか斬らせるか、一挙に埓をあけなければ、このうえは、ひと時も保合えぬようなところにまで迫ってきた。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓を開けて、この神秘的な活人画に見入って居る宗三郎の心が、妖しくも乱れて行くのを何うすることも出来なくなりました。",
              "citation": {
                "source": "猟色の果",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピオニェールの活人画みたいな劇、移動劇団がやって来て大道具をつくって芝居する。",
              "citation": {
                "source": "正月とソヴェト勤労婦人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "令嬢はたちまち舞踏会やピクニックの女王になってしまい、どうかした保母たちの救済だと言って、活人画の催しまであった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄貴と二人で、大急ぎで降りて行って見ると、一枚開いた雨戸の隙間から、活人画の様に、明い庭の一部が見え、そこに、親父が非常に不自然な恰好をしてうずくまっていた。",
              "citation": {
                "source": "疑惑",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが懐中電燈の円光の中に、胸から上を大写しにして、私は人形ですという顔をして活人画の様にまたたきさえしないでいるのだ。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆息をのんだ体で、部屋全体が一場の陰惨な活人画だった。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
