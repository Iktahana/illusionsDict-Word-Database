[
  {
    "uuid": "c54c4c08-09d0-5b9a-8c05-c5f38f544e6c",
    "entry": "活人画",
    "reading": {
      "primary": "かつじんが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
