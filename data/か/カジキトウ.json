[
  {
    "uuid": "2154df2b-851a-5e10-9eb0-c9214419067d",
    "entry": "加持祈祷",
    "reading": {
      "primary": "かじきとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
