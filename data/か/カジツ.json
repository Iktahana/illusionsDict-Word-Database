    },
    "definitions": [
      {
        "index": 1,
        "gloss": "auspicious day",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "結婚式を挙げるなら、やはり六輝の良い佳日を選びたいものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい事業の開始に際し、社長は佳日を選んで神事を執り行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "本日は大安吉日、まさに佳日にふさわしい門出だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この佳日に、皆様の幸せを心よりお祈り申し上げます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これ以上の佳日は無い筈である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天長節の佳日に際し　　子爵　　伊東海軍大將　　　　　　肝付海軍少將　　伯爵　　吉井海軍少佐　　子爵　　小笠原海軍少佐　　　　　　上村海軍少佐各位の清福を賀※、つたなき本書のために、題字及び序文を賜はりし高意にむかつて、誠實なる感謝の意を表す。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "――支那大陸紀元八十万一年重陽の佳日、中国軍政府最高主席委員長チャンスカヤ・カイモヴィッチ・シャノフ恐惶謹言頓首々々恭々しく曰す。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、偶、ホテルの人が枕頭に持つて来てくれた改造のなかにあつたのが彼の「佳日」といふ短篇であつた。",
              "citation": {
                "source": "稀有の文才",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は病余のつれづれに、いつまでも枕頭にあつた「佳日」を日課のやうに毎日読んだ。",
              "citation": {
                "source": "稀有の文才",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "外には新聞より読むものがないのだから新聞を拾ひ読みした後では必ず「佳日」を愛読したものである。",
              "citation": {
                "source": "稀有の文才",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三七年九月二十七日、誕辰の佳日に当って、一筆件の如し。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の古い政治経済学教授の座は疾うの昔に後任者によって適切にも占められていた――経済学の教授法は我が佳日から大いに変わっていたが。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "佳日に来合わせたものかなと秘かに祝福して、開演中も舞台よりはその方に気を取られ勝でいると、そのうち僕の席から少し離れたところにいるその一団の連中の中で、互いに囁き合いながらこちらを顧みるのがいるんだ。",
              "citation": {
                "source": "メフィスト",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が洒落に鶴賀をかじつて、坊主、出來るから、時々慰みに稽古に行くと思ひねえ。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所の女だの、年上の従姉妹だのに、母が絵解をするのを何時か聞きかじつて、草双紙の中にある人物の来歴が分つたものだから、鳥山秋作照忠、大伴の若菜姫なんといふのが殊の外｜贔屓なんです。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、すぐ、何故かじつとした。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋風のものではフランス料理を二つ三つ聞きかじつて知つている。",
              "citation": {
                "source": "わが妻の記",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尼寺の応接所に二人が据わつて、干菓子をかじつたり、ソルベツトを啜つたりしながら、尼達の饒舌るのを聞いて、偸目をして尼達の胸の薄衣の開き掛かつてゐる所をのぞいてゐたことは幾度であらう。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それは男を先づそとに見えない心臟や肺のあたりからがつ／＼とかじつて、つひにはその全身をかの女の病熱と衰弱との喰ひ物にしてしまふのではなからうか？",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても私たちが聞きかじつてゐる明治以前の文明は、みんな、唐や明を通してきてゐるものだけに、私たちにはわからないから、ただ、ボヤツと驚いた。",
              "citation": {
                "source": "日本橋あたり",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かじつくりと考へようとすると、すぐ反射的にこみいつたつまらないことがごたごたと浮んで來る。",
              "citation": {
                "source": "雨",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋が深くなつて、朝など山の方から獵銃の音がきこえ出すと、老犬のジャックはなんだかじつとしてゐられないやうに走りまはり、不意と見えなくなる。",
              "citation": {
                "source": "ふるさとびと",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上まだ鼻垂れが五人もあつて朝から晩まで学校へも行かず家の中できやつきやつと騒いで、何処かの畑で盗んで来た大根を生でがりがりかじつたり奪ひ合つたりしてゐるので、その浅ましさは乞食の子供の集合地以上である。",
              "citation": {
                "source": "白痴",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、前線を親しく見廻つて、私は痛切に感じたことだが、戦闘部隊は時としてまつたく給養の道を絶たれ、やむを得ず大根や生薯をかじつて饑を凌いでゐるのである。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "承徳の総攻撃が目下準備されつゝあること、娘子関方面の敵がなかなか頑強であることなど聞きかじつてゐたので、差支ない限り詳しい情報を得たいと思つたが、話はわきへ外れた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ白秋君は幾晩も徹夜することが出來、握飯をかじつては詩作し、作歌したもので、私などは驚き入つてゐた。",
              "citation": {
                "source": "北原白秋君を弔ふ",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕、さつき、お猫さんのおぢさんの鼻の先をかじつたの。",
              "citation": {
                "source": "お鼻をかじられたお猫さん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "信子は手にしていた林檎を皮ごと一口かじつた。",
              "citation": {
                "source": "恋をしに行く（「女体」につゞく）",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "信子は二口かじつて、やめた。",
              "citation": {
                "source": "恋をしに行く（「女体」につゞく）",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシヤ語をすこしばかりかじつてますもんですから……。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の花は十月、十一月に咲くのだが、そのとき茶の樹に眼を注いでみると往々正しく整形せられた聚繖花序に逢着することはなにも珍らしいことではないが、なぜ世の多くの学者が今までこれに気がつかずに見逃がしていたかじつに不思議千万である。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "年々歳々、これだけは家康の渡海免許の御朱印状を持つてゐて、貿易のために渡來する和蘭船のほかに、當時のさだめとして、日本の土地のどこに漂着しても、必ず一度は長崎におくられてきた、毛色眼色のちがつた異國人たちに接してゐれば、あれこれと海外の珍らしい出來事も聞きかじつたと察することが出來る。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊んで暮してゆける身分でもないので、ロシヤ語を少々かじつてゐたのをたよりに、小石川にある或る東洋学関係の図書館に、なかば自宅勤務の形でつとめることになつた。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「瀧口入道」は平家物語の一節を焼き直して文章までも剽窃したもの、「釈迦」も同じくお経の文句をそのまゝ仮名交り文に引き伸ばしたやうなもの、「美的生活」はニイチエを読みかじつてニイチエの深みもなく、浅薄な議論をしたもの、その他、何一つとして独創性の認められるものはないではないか。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
