  {
    "uuid": "b1c27ce6-09be-50d4-8549-fdc1f0cda059",
    "entry": "果実",
    "reading": {
      "primary": "かじつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fruit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝食には新鮮な果実をたくさん食べるようにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この季節、市場には色とりどりの果実が並び、目を楽しませてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はデザートに甘い果実を好んで食べる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "樹から落ちた果実を拾い集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その時その林檎と、果実商組合とは何の関係もない。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "年じゅう同じように貯蔵した馬鈴薯や玉ねぎをかじり、干物塩物や、季節にかまわず豚や牛ばかり食っている西洋人やシナ人、あるいはほとんど年じゅう同じような果実を食っている熱帯の住民と、「はしり」を喜び「しゅん」を貴ぶ日本人とはこうした点でもかなりちがった日常生活の内容をもっている。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひたすら、酒か、菓子か、果実か、煙草を要求した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹の枝はみな生物のように垂れてその美しい果実を王子たちに奉った。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何度も何度もその果実を鼻に持っていっては嗅いでみた。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十中八九は実際おそらくなんらの目立った果実を結ぶことなく歴史の闇に葬られるかもしれない。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと近年になってこの現象が電気動力線の瞬時的高圧の測定に利用されそうだというので若干のエンジニアーによって応用の方面の見地から取り扱われはしたが、それも本質的に物理的な意味ではなんらの果実を結ぶこともなしに終わっているように見える。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "植物の果実のことだけを詳しく取り扱ったいわゆるカルポロジーの本を読んだときに、乾燥すると子房がはじけて種子をはじき飛ばすものの特例の一つとして Impatiens noli-tangere というものが引き合いに出ていた。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘、わが身に快く、充分に美しく、たのしく、しずかに差し出された美事のデッシュ、果実山盛り、だまって受けとり、たのしみ給え。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い広い桃畑があるが、木はもうみんな葉をふるってしまって、果実を包んだ紙の取り残されたのが雨にたたけてくっついている。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらは田園の風と光の中からつやゝかな果実や、青い蔬菜を一緒にこれらの心象スケツチを世間に提供するものである。",
              "citation": {
                "source": "『注文の多い料理店』広告文",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらは田園の風と光の中からつややかな果実や、青い蔬菜といっしょにこれらの心象スケッチを世間に提供するものである。",
              "citation": {
                "source": "『注文の多い料理店』新刊案内",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "米も出来ず、果実も実らず、万事｜尽く生色を失う事となる。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともとこの話は松村と同窓の友人である白川奨の口から始つたので、白川は此資金が産む果実をとつて、自己の担任せる訴訟事件示談金の財源にしようと企てた。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "バナナン大将｜手籠を持ちてその下を潜りしきりに果実を収む。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベースピラミッド　カンデラブルまたパルメット　エーベンタールことにも二つの　コルドンと棚の仕立に　　　いたりしにひかりのごとく　降り来し天の果実を　　　いかにせん。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　新刊書を買うて帰るときの感じ、恋人の足音を聞きながら、その姿を待つときの感じ、新鮮な果実に鋭利なナイフをあてたときの感じ。",
              "citation": {
                "source": "夜長ノート",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "林檎の果実が手毬くらいに大きく珊瑚くらいに赤く、桐の実みたいに鈴成りに成ったのである。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こころみにそのひとつをちぎりとり歯にあてると、果実の肉がはち切れるほど水気を持っていることとて歯をあてたとたんにぽんと音高く割れ冷い水がほとばしり出て鼻から頬までびしょ濡れにしてしまうほどであった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の男のことなぞ」　と嘲って呆れるのであるが、なおその想いは果実の切口から滲み出す漿液のように、激しくなくとも、直ぐには止まらないものであった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ実の入らない果実、塩｜煎餅、浅草｜海苔、牛乳の含まぬキヤンデイ、――食品目は偏つて行つた。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もぎたての果実のやうに新鮮な軽い味である。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "禁断の智慧の果実と斉しく、今も神の試みで、棄てて手に取らぬ者は神の児となるし、取って繋ぐものは悪魔の眷属となり、畜生の浅猿しさとなる。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "抑も波羅葦増の国と申すは、四時花咲き、鳥歌ひ、果実｜季なく実り、生あれども死なく、明あれども暗なく、悔なく、迷なく、苦なく、禍なく、白象鰐魚も人に戯れ、河水甘露の味を宿して、白檀蘆薈のかをり園に満ちたり。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腐れゆく襤褸のにほひ、酢と石油……にじむ素足に落ちちれる果実の皮、赤くうすく、あるは汚なく……片手には噛りのこせし林檎をばかたく握りぬ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "視よ、すでに美果実あからみて田にはまた足穂垂れ、風のまに山鳩のこゑきこゆ、角を吹け。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もろもろの美果実籠に盛りて、汝が鴿ら畑に下り、しらしらと帰るらし夕づつのかげを見よ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒蕪地つづき、廃れ立つ礎燃えて烈々と煉瓦の火気に爛れたる果実のにほひそことなく漂湿る。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い霖雨の間に果実の樹は孕み女のやうに重くしなだれ、ものの卵はねばねばと瀦水のむじな藻にからみつき、蛇は木にのぼり、真菰は繁りに繁る。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴿の面をもてる者に蛇の心あり、美はしき果実に怖ろしき毒を含めることあり、洞に近けば※蛇蟄し、林に入れば猛獣遊ぶ。",
              "citation": {
                "source": "哀詞序",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "fruits",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
