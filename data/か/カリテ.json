    "definitions": [
      {
        "index": 1,
        "gloss": "mower",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "雨が降る前に収穫を手伝ってもらうため、農家は追加の刈り手を雇った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "芝生があまりにも伸びすぎていたため、専門の刈り手が必要だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "刈り手の音が、田舎で夏が始まった合図だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "刈り手の個性と刈り時の遅速とが芝生の上に不規則なまだらを描いていた。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣から三人、家のものが五人、都合八人だが、兄は稲を揚げる方へ回るから刈り手は七人、一人で五百｜把ずつ刈れば三千五百刈れるはずだけれど、省作とおはまはまだ一人前は刈れない。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の虫はまたむらさきうまごやしの若草を草刈り手が何んにも刈るものを見当らない程すつかり食べてしまふ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、彼は手でぐるりと一つ、大きく荒々しく輪を描きながら、夢中になって叫んだ……「収穫は熟して刈り手を待っている……現代の厚顔無恥はあらゆる堤防を破った……しかし僕はいうのだ……」「おい。",
              "citation": {
                "source": "神の剣",
                "author": "GLADIUS DEI",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔雪とひのきの坂上に〕宮沢賢治雪とひのきの坂上に粗き板もてゴシックを辛く畳みて写真師の聖のねぐらを営みぬぼたと名づくる雪ふりていましめさけぶ橇のこらよきデュイエットうちふるひひかりて暮るゝガラス屋根",
              "citation": {
                "source": "〔雪とひのきの坂上に〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日の力をかりてわたしはおまへに許しを乞ひに來た。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第百九十三段「くらき人の、人をはかりて、その智を知れりと思はん、更にあたるべからず、云々」の条など現代の諸専門学者の坐右銘になる。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、大多数の科学者は結局どこかで誰か他人の助けをかりて生活すると同時に研究する外はない。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二三歩｜行きかかりて戻る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗保は、薪を積みに行くという真実味をよそうため、途中で猫車をかりて、引っぱって山へ行く坂の道を登りだした。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀州が小橋をかなたに渡りてより間もなく広辻に来かかりてあたりを見廻すものあり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "村道朝日かゞやく水仙を、　　　　　になひてくるは詮之助、あたまひかりて過ぎ行くは、　　枝を杖つく村老ヤコブ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔けむりは時に丘丘の〕けむりは時に丘丘の、　　栗の赤葉に立ちまどひ、あるとき黄なるやどり木は、　　ひかりて窓をよぎりけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と呟きざま、躍りかかりてハタと打ちし、拳はいたずらに土によごれぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とあとよりいいたるはわが家につかいたる下男の声に似たるに、あわや出でむとせしが、恐しきもののさはたばかりて、おびき出すにやあらむと恐しさは一しお増しぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤けたる行燈の横長きが一つ上にかかりて、ほととぎすの画と句など書いたり、灯をともしたるに、水はよく澄みて、青き苔むしたる石鉢の底もあきらかなり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近く寄れ、喰さきなむと思うのみ、歯がみして睨まえたる、眼の色こそ怪しくなりたれ、逆つりたる眦は憑きもののわざよとて、寄りたかりて口々にののしるぞ無念なりける。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "端厳微妙のおんかおばせ、雲の袖、霞の袴ちらちらと瓔珞をかけたまいたる、玉なす胸に繊手を添えて、ひたと、おさなごを抱きたまえるが、仰ぐ仰ぐ瞳うごきて、ほほえみたまうと、見たる時、やさしき手のさき肩にかかりて、姉上は念じたまえり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　同時に軍夫の一団はばらばらと立かかりて、李花の手足を圧伏せぬ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち卿の一八九五年のある手紙の一節に「このごろ、マンロー訳の助けをかりてルクレチウスを読んでいた。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方私はルクレチウスをかりて自分の年来培養して来た科学観のあるものを読者に押し売りしつつあるのではないかと反省してみなければならない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私が今本誌の貴重な紙面をかりてここにこれらの問題を提出することによって、万一にも、好学な読者のだれかがこの中の一つでもを取り上げて、たとえわずかな一歩をでも進めてくれるという機縁を作ることができたら、その結果は単に私の喜びだけにはとどまらないであろうと思うのである。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくそういうこともあるくらいだから、だれか生理光学に興味をもつ生理学者のうちにこの問題を取り上げてまじめに研究してみようという人があったらたいへんにありがたいと思うので、それでわざわざ本紙のこの欄をかりてこのような夢のような愚見を述べてみた次第である。",
              "citation": {
                "source": "人魂の一つの場合",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時にたとえばラジオによって全国に火事注意の警報を発し、各村役場がそれを受け取った上でそれを山林地帯の住民に伝え、青年団や小学生の力をかりて一般の警戒を促すような方法でもとれば、それだけでもおそらく森林火災の損害を半減するくらいのことはできそうに思われる。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそうだとすれば、科学の力をかりて災難の防止を企て、このせっかくの教育の効果をいくぶんでも減殺しようとするのは考えものであるかもしれないが、幸か不幸か今のところまずその心配はなさそうである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は読者の中で国家百年の将来を思う人々があらば、どうかこういう国家的にも世界的にも意義の深い仕事に有形無形の援助を惜しまれないようにこの機会をかりて切望する次第である。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といって、うしかいの火をかりて、じぶんのちょうちんにうつすだろう。",
              "citation": {
                "source": "ひとつの火",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ宵ながら月は高く澄んで、さえた光を野にも山にもみなぎらし、野末には靄かかりて夢のごとく、林は煙をこめて浮かぶがごとく、背の低い川やなぎの葉末に置く露は玉のように輝いている。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "入り江の奥より望めば舷燈高くかかりて星かとばかり、燈影低く映りて金蛇のごとく。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜までは、わが洋行も事業の名をかりて自ら欺く逃走なりき。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
