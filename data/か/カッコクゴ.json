        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "空港の案内板には、日本語のほかに各国語の翻訳がデジタル表示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "オリンピックの開会式では、選手団が各国語で歓迎の挨拶を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "そのベストセラー小説は、またたく間に各国語に翻訳され、世界中で愛読された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しからば「いき」という語は各国語のうちに見出されるという普遍性を備えたものであろうか。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにいちばん簡単な場合を考えて、各子音がそれぞれ各国語に出現する頻度あるいは確率が一様で、皆νに等しいとすると、ν = 1/n で均一になる。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、ホメロスに対する弾劾論を強調する目的で各国語の凡ゆる形容詞を八部の著書に取り纏め七冊の修辞々典を著はし、五冊の書に厭世哲学を述べて、遠くシヨウペンハウエルに迄影響の翼を垂れた。",
              "citation": {
                "source": "ゾイラス",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では世界中で亜細亜や阿弗利加を除いては到る処にエスペラント協会が出来てゐて、其教科書は各国語に飜訳されてある。",
              "citation": {
                "source": "エスペラントの話",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日私たちの住む地球の上は毎秒三〇万粁の速度で、昼夜を分たず世界各国語による交通が電波によって飛び交っているのであるが、最も興味あるべきこの世界ニュースの聴取が日本では極めて狭い範囲に止められているのはどういう理由からであろう。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェッコの男は支那の靴を常用し、もうひとりいる独逸人はゴルフ洋袴に身を固め、支那人Ｔ博士は各国語をあやつり一車中の代弁をつとめる。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま重大な布告があるぞオ」　車上の男は、各国語で、同じことをペラペラと叫んだ。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どん底」を書いたのは四十年近く前であり、その頃から各国語に翻訳されて読まれるという意味ではゴーリキイは若い時から世界的な作家であった。",
              "citation": {
                "source": "マクシム・ゴーリキイの発展の特質",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どん底」を書いたのは四十年近く前であり、その頃から各国語に翻訳されて読まれるという意味ではゴーリキイは若い時から世界的作家であった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィツジェラルドの翻訳はいろいろの体裁で翻刻され、各国語に訳された。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりアンナ風な各国語に通じた正直な人間を高価い金でレコード用に雇っておいて、極めて重要なメッセージを送る場合に使うんだ。",
              "citation": {
                "source": "人間レコード",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日記は仏、独、英、日、の各国語に訳された。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベンサムの博学宏才をもって心を法典編纂に委ぬること五十有余年、当時彼の著書は既に各国語に翻訳せられ、彼の学説は既に一世を風靡し、雷名｜轟々、天下何人といえども彼の名を知らぬ者はなかったのである。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "英独仏伊西の各国語に通じ、少しくビルマ語をも解す。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、日常生活を通じて日本人が触れる可能性のある外国語を、――これは新しい方法に依らなければならないと思ふが――例へば、各国語の簡単な発音だとか、同じ意味の言葉がそれぞれ国に依つてどう異るかとか、さう言ふやうなことを中等学校で教へるのも一つの方法ではなからうか。",
              "citation": {
                "source": "外国語教育",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで白状するが、私は、各国語の構造にも、各国の政府の法典にも、またいろいろな国家の政治にも、興味をもたなかった。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それのみならず、この著はほとんど世界各国語にも翻訳された。",
              "citation": {
                "source": "十五年",
                "author": "山本実彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多年易の八卦より算数の新法を研究し、又各国語発音聞取り書の法を案出し、此の二術を伝播せむがため来朝せしなりといふ。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい宇宙論の提唱者かつ解説者として彼の名は、英国でベスト・セラーになり、世界各国語に翻訳されて、広く読まれている。",
              "citation": {
                "source": "エスキモーの国から",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに一個人にして各国語に通ずるということはなかなか望み得られないことである。",
              "citation": {
                "source": "東西両文明の調和を論じて帝国の将来に及ぶ",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はパリ、セーヌ河岸の古本屋で各国語対訳聖書をちょろまかしたのが露見して二年間の禁錮に服さねばならなかった。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "またヨーロッパの各国語に通じ、ことに珍しいことには、あらゆる階級の言葉に通じ、それを常に話していた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、大陸の各国語のうちにあって、一種の強力、一種の神秘な主権を持ってる言葉がある。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ最前列の升席に座ると、ちょうど幕が上がり、劇場は各国語が飛び交い、毎晩満席だ。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
