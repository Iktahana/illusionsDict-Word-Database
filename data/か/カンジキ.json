        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "深い雪山を歩くために、昔の人は自分で橇を作っていたんだって。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬の狩猟では、足が雪に沈まないように橇を履いて獲物を追う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域では、雪が積もると移動手段として橇を使う家庭が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "博物館には、北国の民族が使っていた様々な種類の橇が展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "〔雪とひのきの坂上に〕宮沢賢治雪とひのきの坂上に粗き板もてゴシックを辛く畳みて写真師の聖のねぐらを営みぬぼたと名づくる雪ふりていましめさけぶ橇のこらよきデュイエットうちふるひひかりて暮るゝガラス屋根",
              "citation": {
                "source": "〔雪とひのきの坂上に〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーテンを上げて覗いてみると、人気のない深夜の裏通りを一台の雪橇が辷って行く、と思う間もなく、もう町のカーヴを曲って見えなくなってしまった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分にナショナルリーダーを教わったときに生れてはじめて雪橇というものの名を聞き覚え、その絵を見て、限りなき好奇心と異国の冬への憧憬を喚び起こされたのであったが、その実物をこの眼に見、その鈴の音を耳にしたのは実にこの夜が初めてでありそうしてまたおそらく最後でもあった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この雪夜の橇の幻の追憶はまた妙な聯想を呼出す。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの山々から瞰下されて、乾き切っている桔梗ヶ原一帯は、黒水晶の葡萄がみのる野というよりも、橇でも挽かせて、砂と埃と灰の上を、駈けずって見たくなった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "天は愈よ明るい、氷の海は一層の白を加うると共に、一分の硬味を減じて来た雪になったのである、玉屑累々ともいうべき空に懸れる雪の大路を無形の手で、橇を縦横に掻き廻しはじめたと見え、捏ね返した痕跡が割れ目を生じたころは、雪は一方に堆く盛り上られ、一方では掬われたようにげっそりと凹む。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして行き交う厚い外套と雪靴の街、子供達の雪合戦の街、橇の其処にも此処にも散ばる街――その街はクリスマスの仕度の賑わう街なのです。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "河は凍って、その上を駄馬に引かれた橇が通っていた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬に曳かれた橇が、遠くから河の上を軽く辷って来る。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　麓の方で、なお、辻待の橇を呼ぶロシア語が繰りかえされた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒場のある向うの丘からこちらの丘へ燈火をつけない橇が凍った雪に滑桁をきし／＼鳴らせ、線路に添うて走せてきた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　馭者のチョッ／＼という舌打ちがして、橇は速力をゆるめた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "橇がひっくりかえりそうに、一瞬に五六間もさきへ宙を辷った。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ兵は橇の上から懐中電燈でうしろを照した。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、橇の上から轟然たるピストルのひゞきが起った。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "橇は滑桁の軋音を残して闇にまぎれこんだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩に乗り上げた舟のように傾いた橇の底では兵士が、でこぼこのはげしい道に動揺するたび、傷を抑えて歯を喰いしばった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五六台の橇が院庭へ近づいてきた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "橇は、逆に馬をうしろへ引きずって丘を辷り落ちそうに見えた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "衛兵にまもられた橇が黒龍江を横切って静かに対岸の林へ辷って行く。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "橇は、向うの林の方へ、二三枚の木葉舟のように小さく、遠くなって行った。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう激しい感情を林へ引いて行かれる橇を見て自ら慰めるよりほか、彼等には道がなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」橇の上からピストルを放したメリケン兵のロシア語は、まだ栗本の耳にまざまざと残っていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　　　　　　七　鈴をつけた二十台ばかりの馬橇が、院庭に横づけに並んでいた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "負傷者の携帯品は病室から橇へ運ばれた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "橇には、五人ずつ、或は六人ずつ塒にかたまる鶏のように防寒服の毛で寒い隙間を埋めて乗りこんだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　栗本は橇の上から呼びかけた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田口は看護長の返事を待ちながら、傷病者がうまく橇に身を合わそうとがた／＼やっているのを見ていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が二人の間には、膝から下を切断し、おまけに腹膜炎で海豚のように腹がふくれている患者が担架で運んで来られ、看護卒がそれを橇へ移すのに声を喧嘩腰にしていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗本は田口がやって来そうにないのを見て、橇からおりて雪の中の馬の頭のさきを廻って行った。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
