        "examples": {
          "standard": [
            {
              "text": "植物の細胞壁の主成分であるセルロースには、多数のカルボキシル基が存在する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この高分子は、そのカルボキシル基を利用して金属イオンを吸着する性質を持つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "特定の酵素は、基質のカルボキシル基に特異的に作用し、反応を促進する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "カルボキシル基の水素原子はイオン化によって水のものとすぐに交換する。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "興味深い例外はカルボキシル基に近い炭素原子に結合した水素である。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            }
          ]
        }
