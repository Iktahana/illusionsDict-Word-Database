        "examples": {
          "standard": [
            {
              "text": "このアプリでは、各ユーザーIDと購入履歴の関連付けを自動で行っています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "記憶術の基本は、新しい情報を既知のイメージと関連付けすることだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ファイル形式と実行プログラムの関連付けが解除されてしまい、開けなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "心理学の実験で、特定の音と報酬の関連付けを被験者に学習させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これらの一般的な解釈をシェーンハイマーは1937年のハーヴィー・レクチュアおよび1941年のダナム・レクチュアで総括した……　シェーンハイマーのもっとも優れた性質の１つは知識の高度に多様な分野からの適切な事実を関連付け当面している問題に結びつけることであった。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "再生過程を排泄物の生成と関連付けようとするのは興味深いことである。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想は、実践を反映する意識であるから、やがて大衆の社会的実践、ひいては政治的問題にまで関連付けられる。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "症状、症候群、病気は種々の臓器と密接に関連付けられている。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェシは漠然とこの妙な出来事を、アストリア王とされる不幸な人物に関連付けた。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
