[
  {
    "uuid": "3114cf3b-9076-5b43-bc15-2b3273fa8dc7",
    "entry": "考え様",
    "reading": {
      "primary": "かんがえよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
