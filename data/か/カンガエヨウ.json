      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "way of thinking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "まあ、それも一つの考え様だね。一概に間違いとは言えないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "あんなにポジティブになれるなんて、考え様によっては幸せな性格だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "同じ失敗でも、考え様一つで次のチャンスに繋げることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「結局は自分の気の持ちようか…」「そうそう、考え様だよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ひとの大いそがしの有様を、お役人の案内で「視察」するなどは、考え様に依っては、失礼な事とも思われます。",
              "citation": {
                "source": "三月三十日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばばさまのへそくりを拝借したとしても、それは一家の内の事で、また、地中に埋もれた財宝を、掘り出して世に活用せしめたのは考え様に依っては立派な行為とも言えると思うのです。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那に自国統治の実力さえあったなら、こんどの戦争も起らなくてすんだであろうに、これではまるで支那の独立保全のために日本に戦争してもらっているようにも見えて、考え様に依っては、支那にとってはまことに不面目な戦争ではあるまいか。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、考え様によっては、心臓にこそ、人生のあらゆる神秘が蔵せられて居るといってよいかも知れない。",
              "citation": {
                "source": "恋愛曲線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふとその建物を見て斉明天皇の朝倉の行宮の木の丸殿もこんなのではなかったかと思えて考え様によっては存外に風情があって、風変りなだけに雅致のあるものであるかも知れないとも思われた。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "今位頭が熟していれば、まだ考え様があったのだが、惜しい事に若かったものだから、余りに自然を軽蔑し過ぎた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためにお久美さんにやる手紙の中に、まるで祈祷を凝す様な気持で、私共はまだ生れなかった先から今日斯うあるべき運命が神様から授けられて育ったのだと思うより外考え様がないと思います。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしクスノキ科のアブラチャンにもズサならびにヂシャの名があるから考え様によってはこの植物ではなかろうかとも想像の出来ん事はない。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、幸福の解釈は、各人の考え様如何にあるのであって、その人が、生活の上に、また哲学を有するか否かに原因するものであります。",
              "citation": {
                "source": "文化線の低下",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "考え様によっては物は古いよりも新しいのがよい。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "がしかしそれは考え様であります。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら八十年という月日は考え様に依ればまた相当に長いものともいえる。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "考え様に依れば人生は陰鬱なもの悲惨なものとも見る事が出来る。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もお主が未熟だから追出そうとは言っておらぬぞ」「斧だけ持って出て行けと云われるからにゃア、ほかに考え様がありますまい」「さ。",
              "citation": {
                "source": "夜長姫と耳男",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも欧米視察とでもいうのなら又考え様もあるが、高の知れた日本国内を保養がてらの友達と一緒に見物して歩くとあっては、僕もお父さんの心底を疑わずにはいられない。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが矢張り、考え様によっては、その筋でも、おれの家のものを疑っていて、様子を探りに来るのかも知れないのだ」「だが、君は少し神経が鋭敏になり過ぎてやしないのかい」「神経だけの問題なら、おれはこんなに悩まされやしない。",
              "citation": {
                "source": "疑惑",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがね、縁側の靴ぬぎ石の上へ、はだしでおりたかと思うと、どういう訳だか、そこへピッタリ立止って了ったんだ、考え様によっては、親父の死骸を見て、余りの事にためらったのかとも思われるが、しかし、それにしては、なぜ、手に持っていた兵児帯を、沓脱石の上へ落したのだ。",
              "citation": {
                "source": "疑惑",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「刑事先生、一生かかったって、知れっこない指紋の持主を、今頃はさぞ探し廻っていることだろう」　思わぬ大金の入った私は、その事については、それ以上考え様ともしないで、早速車を命じて、いつもの遊び場所へ出かけたことです。",
              "citation": {
                "source": "双生児",
                "author": "――ある死刑囚が教誨師にうちあけた話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「若しこの想像が当っているとすると（実際この外に考え様がないのだが）すてておく訳には行かぬ。",
              "citation": {
                "source": "百面相役者",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その会場の大広間は、人の出入自由なあるビルヂィングの中にあったのだが、考え様によっては、偶然聴衆の中に辻堂と似た人物がいて、それが平田氏の探した時には、もう立去ったあとだったかも知れない。",
              "citation": {
                "source": "幽霊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "私としたことが信心深いお母さんを前にして、ふだんの自分のものの考え様をそのままあらわしてしまうなんて。",
              "citation": {
                "source": "聖アンデルセン",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "外に考え様がありますか。",
              "citation": {
                "source": "陰獣",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イヤ、必ずしもそうではありませんが、……木島さん、あなたは湯本譲次が四つの殺人事件の真犯人だと信じていらっしゃるのですか」「無論その外に考え様がないではありませんか」　木島は態と強く言い切って見せた。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人のない他殺とより、他に考え様はないのじゃないでしょうか」　アア、犯人のない他殺。",
              "citation": {
                "source": "火繩銃",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「想像は想像だけれど、外に考え様がないのだ。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその外に考え様がない様に思った。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも外に考え様がないじゃありませんか」　と紋三は明智に本音は吐かせないでは置かぬ意気込みだった。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "死骸は溶けてしまったか、あるいは蒸発してしまったとしか考え様がないのだ。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴のあの不可解な消失は、妖術とでも考える外考え様がないではありませんか。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕にしたって、その外に考え様がありません」　恒川氏は一応は感服して見せたが、しかし、その次の瞬間には、やっぱりどこやら腑に落ぬ面持になる。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
