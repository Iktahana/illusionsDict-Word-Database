    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Themeda triandra var. japonica (variety of kangaroo grass)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "秋の野山を歩くと、穂を赤らめたメガルカヤが風に揺れる姿が目を楽しませてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "万葉集の時代から、刈萱は秋の訪れを告げる代表的な草花として親しまれてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この辺りに群生しているのは刈萱かな？夕日に照らされてとても綺麗だね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一時、芸者の数が有余ったため、隣家の平屋を出城にして、桔梗、刈萱、女郎花、垣の結目も玉章で、乱杙逆茂木取廻し、本城の欄の青簾は、枝葉の繁る二階を見せたが、近頃いわれあって世帯を詰めて、稲荷様向うの一軒につづめたので、隣家はあたかも空屋である。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "松に舫った釣舟は、主人の情で、別荘の庭に草を植え、薄、刈萱、女郎花、桔梗の露に燈籠を点して、一つ、二見の名所である。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月　宵々の稻妻は、火の雲の薄れ行く餘波にや、初汐の渡るなる、海の音は、夏の車の歸る波の、鼓の冴に秋は來て、松蟲鈴蟲の容も影も、刈萱に萩に歌を描く。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "桔梗、刈萱、女郎花、我亦紅、瑠璃に咲ける朝顏も、弱竹のまゝ漕惱めば、紫と、黄と、薄藍と、浮きまどひ、沈み靡く。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月　藍あさき宵の空、薄月の夜に入りて、雲は胡粉を流し、一むら雨廂を斜に、野路の刈萱に靡きつゝ、背戸の女郎花は露まさる色に出で、茂れる萩は月影を抱けり。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――添へて刈萱の濡れたのは、蓑にも織らず、折からの雨の姿である。",
              "citation": {
                "source": "玉川の草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に、千鳥と名のあるのは、蕭々たる夜半の風に、野山の水に、虫の声と相触れて、チリチリ鳴りさうに思はれる……その千鳥刈萱。",
              "citation": {
                "source": "玉川の草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "西市へはかなり遠かつた、萩、女郎花、刈萱、白い花、赤い花が咲きみだれた道で、私の好きな道であつた。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中、刈萱を摘んで帰庵したのは五時近かつた。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "上代純朴なる時代に男女の詠めりし秋草に寄する心を聞けば　　　　　日置長枝娘子　　秋づけば尾花が上に置く露の消ぬべくもわが念ほゆるかも　　　　　大伴家持　　吾が屋戸の一枝萩を念ふ児に見せずほと／＼散らしつるかも　萩、桔梗、女郎花は私に山を想はせ、刈萱は河原を、そして撫子と藤袴は野原を想はせる。",
              "citation": {
                "source": "秋の七草に添へて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼い頃、多摩川原近くの武蔵野に住んでゐた私は、刈萱に人一倍の愛着を感ずる。",
              "citation": {
                "source": "秋の七草に添へて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "野原一面に叢生する刈萱は雑草の中に一頭地を抜いて蟠簇してゐる。",
              "citation": {
                "source": "秋の七草に添へて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "据傲な刈萱を見れば、いつしか敵意を感じて、穂といふ穂を打つて見たくなる。",
              "citation": {
                "source": "秋の七草に添へて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなつかしい気持ちの底には強くて鋭いものに対する稚純な敵意よりもなほさら私のこゝろにふかく沁みついてゐる刈萱の穂の銀灰色の虚無的な寂しい風趣なのである。",
              "citation": {
                "source": "秋の七草に添へて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳よりもお優しい、すらすらと雨の刈萱を、お被け遊ばしたようにござります。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月　向日葵、向日葵、百日紅の昨日も今日も、暑さは蟻の數を算へて、麻野、萱原、青薄、刈萱の芽に秋の近きにも、草いきれ尚ほ曇るまで、立蔽ふ旱雲恐しく、一里塚に鬼はあらずや、並木の小笠如何ならむ。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "然も刈萱の蓑いつしかに露繁く、芭蕉に灌ぐ夜半の雨、やがて晴れて雲白く、芙蓉に晝の蛬鳴く時、散るとしもあらず柳の葉、斜に簾を驚かせば、夏痩せに尚ほ美しきが、轉寢の夢より覺めて、裳を曳く濡縁に、瑠璃の空か、二三輪、朝顏の小く淡く、其の色白き人の脇明を覗きて、帶に新涼の藍を描く。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "床几に休ひ打眺むれば、客幾組、高帽の天窓、羽織の肩、紫の袖、紅の裙、薄に見え、萩に隱れ、刈萱に搦み、葛に絡ひ、芙蓉にそよぎ、靡き亂れ、花を出づる人、花に入る人、花をめぐる人、皆此花より生れ出でて、立去りあへず、舞ひありく、人の蝶とも謂ひつべう。",
              "citation": {
                "source": "彌次行",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と声を限り、これや串戯をしては可けないぜと、思わず独言を言いながら、露草を踏しだき、薄を掻分け、刈萱を押遣って、章駄天のように追駈けまする、姿は草の中に見え隠れて、あたかもこれ月夜に兎の踊るよう。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそこの高原には、桔梗、われもこう、刈萱、松虫草などがさながら毛氈を布いたやうに美しく乱れ開いた。",
              "citation": {
                "source": "女の温泉",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の桔梗　山の見事な草花が一番先きに私の頭に上つて来た松虫草、女郎花、われもかう、刈萱、ことに桔梗の濃い紫は何とも言はれなかつた。",
              "citation": {
                "source": "夏",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "刈萱もまた見るにつれてあたたかみの感ぜらるゝ花である。",
              "citation": {
                "source": "秋草と虫の音",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人同道して長野見物――まづ西光寺（刈萱親子地蔵尊）へ詣でる、父寂照坊母千里御前、そのまんなかに道念坊の墓がある、それから美篶橋上に立つ、白根山四阿山のすがたもよろしい。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "刈萱を摘んで戻つた、これも私の好きな草である、まだ穂が出てゐないから、刈萱の風情は十分に味へないが。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつと小さい刈萱を見つけて活ける。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の散歩、足はおのづから野へ川へ、刈萱はよいな、四句拾つた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄汚い祭文語りは炉端へ呼び入れられて、鈴木｜主水や刈萱道心のようなものを語った。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "野を歩いて持つて帰つたのは、撫子と女郎花と刈萱。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "刈萱を活けた、何といふ刈萱のよろしさ！",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "かるかやを活ける、よいかなかるかや。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "Cymbopogon tortilis var. goeringii (variety of grass closely related to lemongrass)",
        "register": "standard",
