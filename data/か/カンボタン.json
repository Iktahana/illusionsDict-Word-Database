        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "雪が降る寒い日にもかかわらず、庭の寒牡丹が凛と咲き誇っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "盆栽展で、見事に手入れされた紅色の寒牡丹が訪れる人々の目を引いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬の日本庭園を散策すると、防寒用の藁囲いの中に寒牡丹のつぼみを見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "……先生は、讀賣新聞に、寒牡丹を執筆中であつた。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "△紅葉秋濤著「寒牡丹」読みかけてやめる。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "九日――「寒牡丹」読みて夜にはいって読了す。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "（五月六日）三○東京の牡丹は多く上方から苗が来るので、寒牡丹だけは東京から上方の方へ輸出するのぢやさうな。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の方は其角嵐雪の句でも白雄一派の句でも仮令いくらかの美しい処はあるにしても、多少の渋味を加へて居る処はどうしても寒牡丹にでも比較せねばなるまい。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い寒い静かな明方に、誰れも気づかぬとき、床の間の寒牡丹が崩れ散ったような彼女の死の瞬間が想像され、死顔を見るに堪えなくなって暇を告げた。",
              "citation": {
                "source": "松井須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "とり分き日本では寒念仏の、臘八坐禅の、夜業の、寒稽古の、砧の、香の、茶の湯の季節、紫の二枚｜襲に唐織の帯の落着く季節、梅もどきの、寒菊の、茶の花の、寒牡丹の季節、寺寺の鐘の冴える季節、おお厳粛な一面の裏面に、心憎きまで、物の哀れさを知りぬいた冬よ、楽んで溺れぬ季節、感性と理性との調和した季節。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔無題〕正月元日、鏡餅の傍に寒牡丹一つ開き、子供等みな健やかに、良人の留守｜護る我家は清し。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の四隅の小暗くて、中に一もと寒牡丹われと並びて咲くと見る友の姿のあてやかさ。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガランとして人気もない中に、雪持寒牡丹の模様の着つけに、紫帽子の女形が、たった一人、坐った姿は、異様で且妖しかった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪之丞は好みの、雪投げの寒牡丹の衣裳に、女よりもなよやかな身をつつんで、つつましく坐ったまま、不敵な微笑を、美しい紅い口元にうかべた。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の間の南画の山水の前に寒牡丹が活けられ、厳かに大小の刀が刀掛けに掛けられていた。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "今松は床の間の寒牡丹の花の姿に、まだ見ぬ未亡人の妖艶な姿を思って、ひそかに心濡れるものをおぼえていた。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "人形の前に崩れぬ寒牡丹何事の頼みなけれど春を待つ一月二十四日　玉藻俳句会。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "苞割れば笑みこぼれたり寒牡丹寒燈にいつまで人の佇みぬ一月十三日　笹鳴会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "惨として驕らざるこの寒牡丹十二月二十五日　松本長七年忌。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあたりほのとぬくしや寒牡丹一月十九日　玉藻吟行。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、夜が明けるだろう」　と、霜除けをかぶった寒牡丹のように、ぶるぶると、歯の根を噛んでいるのは、今夜の見張をいいつけられた加山、波越の二同心だった。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぜひなく、両使とも、そこに佇んでいたが、だいぶ手間どれるので、何故待たせるのかと疑いながら、広縁へ出て、折ふし冬ざれの寺の庭面に、霜除けをかぶって、仄かな紅を見せている寒牡丹など眺めていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
