        "examples": {
          "standard": [
            {
              "text": "「本工事が始まるまで、掘り返した道路の溝をアスファルトで仮埋めして歩行者の安全を確保する。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "水道管の修理が終わったけど、明日の検査までは土を完全に戻さず砂利で仮埋めしておこう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "電線を地中に通す際、最終的な舗装をする前に砂で仮埋めして、車両が通行できるようにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "遺跡の保存のために、発掘した穴を一時的に土で仮埋めして風化を防ぐ処置をとったんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "東沃沮の俗新死者を仮埋めにし、皮肉尽くるを以て骨を取って木槨中に置くと魏志にある。",
              "citation": {
                "source": "火葬と大蔵",
                "author": "焼屍・洗骨・散骨の風俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで訪問客のあるときにはうっかりうめくことができない。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて門野支配人は、黄金塔を床下の深い穴の中に、すっかりうめこんでしまいました。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
