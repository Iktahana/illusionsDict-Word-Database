[
  {
    "uuid": "7cf5ec48-8663-5814-b9d9-b48014cbc702",
    "entry": "辛め",
    "reading": {
      "primary": "からめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
