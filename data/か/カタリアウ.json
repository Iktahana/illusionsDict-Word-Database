[
  {
    "uuid": "829e8944-3068-536c-9d40-ac9010c1986a",
    "entry": "語り合う",
    "reading": {
      "primary": "かたりあう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
