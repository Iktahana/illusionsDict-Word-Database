        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "リビングの壁に大きな掛け時計があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの掛け時計は、昔のおばあちゃんの家から持ってきたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「そろそろ時間だよ」と、壁の掛け時計を指差して彼は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最新のスマート掛け時計は、天気予報も表示してくれるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その時宿直室の掛け時計が遠くのほうで一時を打った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室の掛け時計は十時を打つてゐる。",
              "citation": {
                "source": "春の夜は",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛け時計は今度は十一時を打つた。",
              "citation": {
                "source": "春の夜は",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともっと手のこんだ仕掛け時計はざらにありますよ」　と川田が虎之介をたしなめた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十八　踊る時計",
                "note": "青空文庫"
              }
            },
            {
              "text": "電信機、機関車、救命船、掛け時計、農作機械、度量衡、地図、海図、その他当時の日本には珍奇な贈り物を残して置いて、この国を去った。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "分銅のついた安ものの小さな掛け時計が、急調子でかっきり十二時を報じた。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まことに美しい掛け時計、美しい絨緞、美しい召し使いの服装である。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "銅版画をはめ込んだ鼈甲色の縁飾りの付いた掛け時計。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしの行灯だとか、煙草盆だとか、いろいろな形の掛け時計、置き時計、むかしのやぐら時計、花びんや置きもの、本棚もあれば、洋酒のびんをならべる飾り棚もあります。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
