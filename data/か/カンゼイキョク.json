        "examples": {
          "standard": [
            {
              "text": "海外からの荷物が届かないので、関税局に問い合わせてみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "関税局の職員が、手荷物検査を実施している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "輸入手続きのために、関税局への書類提出が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は以前、関税局で働いていた経験がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その過程で彼は、カーウィンはニューポート関税局の間諜であることが判明し、これに対しプロヴィデンスの船長、商人、および農民は皆、公然ないしは隠然と拳を振り上げていると説明した。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
