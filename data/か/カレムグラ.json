    "definitions": [
      {
        "index": 1,
        "gloss": "creeping plant withered in the winter cold",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
