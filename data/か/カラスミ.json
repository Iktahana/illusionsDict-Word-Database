      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dried mullet roe",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "料亭で、お酒の肴に最高だと勧められた鰡子（ボラのこのわた）を注文した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "年末年始の贈答品として、塩漬けにした鰡子を毎年送っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "薄く切って炙った鰡子は、濃厚な旨味と独特の風味がたまらない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「これは高級品だよ」と、父が大切に取っておいた鰡子を出してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "東京へ出るようになってからは時々この丸善の二階に上がって棚の書物をすみからすみへと見て行くのが楽しみの一つであった。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、時にはすべての階をすみからすみまで歩かせられる事もある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそれらの話の中に含まれている事実と方則とがいつとなく自然自然と骨肉の間にしみ込んでしまって、もはやもとの形は少しも残らなくなっているが、しかし実際はそれらのものの認識がわれわれのからだのすみからすみまで行き渡ってわれわれの知恵の重要な成分をなしているのである。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その殺人現場における事件の推移はもちろん、その動機から犯行までの道行きをたとえ簡単にでも正確につきとめるためには、実は多数の警察官や司法官の長日月の精査を要し、しかもそれでもなかなか容易にはすみからすみまで明白にしにくいのが通例である。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「俳諧」の中に含まれた「さび」や「しおり」を白日の明るみに引きずり出してすみからすみまで注釈し敷衍することは曲斎的なるドイツ人の仕事であったのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生のノートや原稿を見るときれいな細字で紙面のすみからすみまでぎっしり詰まっていて、「余白」というものがほとんどなかったようである。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、今までにデンマークを、すみからすみまで旅してまわりました。",
              "citation": {
                "source": "人形つかい",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、兵隊たちは、すみからすみまで、さがしまわりました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎兵衛はおのれのからだをすみからすみまで殴ってみて、眉間と水落ちが一番いたいという事実を知らされた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか、井伏さんが釣竿をかついで、南伊豆の或る旅館に行き、そこの女将から、「お部屋は一つしか空いて居りませんが、それは、きょう、東京から井伏先生という方がおいでになるから、よろしく頼むと或る人からお電話でしたからすみませんけど。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新一郎君は、まさかうそとは思わなかったので、ついていって、まだぬれている牛市場の草をふみわけふみわけ、すみからすみまでさがしたが、牛のふんしか落ちてなかったそうである。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が例のように常夜燈の下をすみからすみまでさがしまわっていると、いつのまにきたのか林太郎が常夜燈の石段にもたれてとうもろこしをたべていた。",
              "citation": {
                "source": "花をうめる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "りっぱな宝物や、金貨や銀貨をつめこんだ大きな袋が、すみからすみまで、ぎっしりとつみ重ねてありました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラシャ切れを丸めた石盤ふきですみからすみまで一度ふいてそろそろ丁寧に説明してくれる。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の内部の世界のすみからすみまでを照らし尽くすような気がしても、外の世界とちょっとでも接触する所には、もう無際限な永遠の闇が始まる、という事がおぼろげながらも彼の頭に芽を出しかけていた。",
              "citation": {
                "source": "球根",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてずっと並んだ五つの部屋を一つ一つ見て回って、掛け軸、花びん、団扇さし、小屏風、机というようなものを、自分の好みに任せてあてがわれた部屋のとすっかり取りかえて、すみからすみまできれいに掃除をさせた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉妹三人のいる二階の、すみからすみまできちんと小ぎれいに片付いているのに引きかえて、叔母一家の住まう下座敷は変に油ぎってよごれていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子の心のすみからすみまでを、溜飲の下がるような小気味よさが小おどりしつつ走せめぐった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから葉子は家の中をすみからすみまで見て回った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すみからすみまで片づいていて、倉地のあの強烈な膚の香いもさらに残ってはいなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたさまはいま八丁堀でお名うての知恵巧者、むっつり右門が乗りこんだからには、ただでは済みませぬぞ、と、このように少しく色をつけて、すみからすみまでずいと触れ歩きまするでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして両手でもって、水のそこをすみからすみまでのこらずかきさがしました。",
              "citation": {
                "source": "ぶくぶく長々火の目小僧",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小笠原豊前守お城下で名物の高価なからすみ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "田子からすみれ丸に乗つて沼津へ。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の女の生活が一瞬にすぎた考へまでが真面目な最も率直な筆で隅からすみまで描き出されてゐます。",
              "citation": {
                "source": "私信",
                "author": "――野上彌生様へ",
                "note": "青空文庫"
              }
            },
            {
              "text": "からすみを食はず、況や烏賊の黒作り（これは僕も四五日｜前に始めて食ひしものなれども）を食はず。",
              "citation": {
                "source": "田端人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとき誤解はわれわれのうちからすみやかに消え去ってゆく。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "からすみも好きだけれども、これも高い。",
              "citation": {
                "source": "生活",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「阪井をなぐれなぐれ」　声はすみからすみへと流れた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「サクラ号の少年たちがぶじ帰国したぞッ」　この声がニュージーランドのすみからすみにつたわった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
