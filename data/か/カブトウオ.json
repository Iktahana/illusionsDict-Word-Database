        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "深海調査の映像に、ゴツゴツした頭部が特徴的なカブトウオが映り込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「へえ、カブトウオってこんなに頭がでかいんだ。深海魚は面白いなあ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "図鑑でカブトウオの姿を見て、そのエイリアンのような造形に子供たちが驚いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "armored fish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
