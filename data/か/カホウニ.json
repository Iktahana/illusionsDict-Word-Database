[
  {
    "uuid": "c3bb1557-6e7e-5069-a45f-875895cb5576",
    "entry": "下方に",
    "reading": {
      "primary": "かほうに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
