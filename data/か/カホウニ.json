    },
    "definitions": [
      {
        "index": 1,
        "gloss": "below",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "崖の淵から恐る恐る下方に目を向けると、荒波が岩に砕ける様子が見えて足がすくんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "天気予報の等圧線が下方に膨らんでいる領域は、これから天気が崩れる可能性が高い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このネジを締める時は、力を下方にかけながら回さないと溝をなめてしまうよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "また全くそうでしょう、袖に赤十字の着いたものを、戦闘員と同一取扱をしようとは、自分はじめ、恐らく貴下方にしても思懸はしないでしょう。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ貴下方に、他を尋問する権利があるので？",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、少し見ているうちに、まず一番に目についたのは、画面の中央の下方にある一枚の長方形の飛び石であった。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが下方に行って再び開いて裾の線を作っている。",
              "citation": {
                "source": "浮世絵の曲線",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人、日本橋に褄を取って、表看板の諸芸｜一通恥かしからず心得た中にも、下方に妙を得て、就中、笛は名誉の名取であるから。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "數日以來の風は、隨分悽まじいものであつたが、颶風の常として、吾が輕氣球は幾度も同じ空に吹き廻されて居つた樣だから、左迄遠方へ飛ぶ氣遣はない、私の考では、下方に見ゆるのは矢張印度洋の波で、事によつたらマダカツスル島の西方か、アデン灣の沖か、兎に角歐羅巴邊の沿岸には、左程遠い所ではあるまいと思はれた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓から見える塀の金鎖草の蔓の一むらの茂みが初夏の夕暮の空に蓬髪のように乱れ、その暗い陰の隙から、さっき茶を呑んだ隣のベッシェール夫人の庭の黄ろい草が下方に小さく覗かれる。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また全く左様でしやう、袖に赤十字の着いたものを、戦闘員と同一取扱をしやうとは、自分はじめ、恐らく貴下方にしても思懸はしないでせう。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぢやあ貴下方に、他を尋問する権利があるので？",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中下方の農村　日高の中下方には、僕の子供の時に聽かされた記憶を呼び起す淡路團體の農村がある。",
              "citation": {
                "source": "日高十勝の記憶",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "中下方にあるのはそれだが、第二囘の五十戸は、今、同じ染退川添ひの碧蘂村にある。",
              "citation": {
                "source": "日高十勝の記憶",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "『この脚下の清流が箒川、これが囘顧橋、この下方に大瀑あり。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎょっと驚いて今さらのように大きく目を見張った君の前には平地から突然下方に折れ曲がった崖の縁が、地球の傷口のように底深い口をあけている。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……もうあのクーペ、いま頃は関所止めになって、箱根口でうろうろしているだろう」　遙かに左手の下方にあたって、闇の中に火の粉のような一群の遠火が見える。",
              "citation": {
                "source": "白妖",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダイの方は、手前に出ているハンドルを、キューッと矢の方に引張ると、クランクの巧みなる運動によって、蝦のように曲った管の先についているダイの受け器が、クルリと廻って、適当なる下方に伸びて、ダイを受ける。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十三図　遊星Ｐが、Ｐの下方にある或る中心点のまわりに回転する流星の流れから生成されんとしているさまを示す様式図である。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "するうちに、一羽の鷹がどよめきの裡でも特に鋭い鷹匠の懸声をききつけたのか、さっと翼を張って下方に向った。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アアル河の屈曲が作りいだす島の如き地形の上から、河流を遙か下方に眺めた、古城趾を思はせるやうな都市である。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌朝、雨を冐して馬上、新冠の御料牧場を見に行く途中で、染退川荒廢の跡を調べ、中下方に於ける淡路團體の農村を見た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが中下方にあるが、第二囘の五十戸は、今、同じ川添ひの碧蘂村にある。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠藤も、この中下方に這入つてからは、道すがら馬をとどめて、あたりを頻りにながめてゐたが、後れて進む義雄を返り見て、「どうです、この邊の田園的風致は！",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお下方に詳記するであろう。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地位の事に關しては、下方にて雅俗折衷之助が軍配に對する我が反撃の條にしるすところを參看せよ。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "永らく編集方面のことを貴下方にばかり御任せして放棄しておき何とも申訳なく存じております。",
              "citation": {
                "source": "平野義太郎宛書簡",
                "author": "一九三二年五月二十三日",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには山麓といふものがなく、下部も、上部と同じく嶮峻な峰であり、その上方にも下方にも高く空が展がつてゐる。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "（イ）文字の右下方に位する小黒點は句讀點であるが、要らないと思ふところにあつたり、一個で十分であるのに二個打つたりしてある。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、響で跡を消すといかんから、下の方の板をそっと切り破ろうじゃないか」　やがて、扉の下方に空けられた四角の穴から潜り込むと、法水は懐中電燈を点じた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、最初に焦点が、その交叉点よりやや下方に落ちて、まず弦よりやや短い一本が切断される。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど縁から幾分下方に当る所に、疑うべくもない拇指痕が、レヴェズの咽喉に印されたのと同一の形で現われた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、反対側の蝋も、ホンの僅かな間だけ燃える芯の下方に当る部分のみが熔けて、上端の部分はそのままの形で残るか、少なくとも蝋膜ぐらいは存在していなければならない。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
