        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "船長は静かに舵柄を握り、荒波の中を進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は小型ヨットの舵柄を操作し、風上に向かって進路を取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "経験豊富な漁師が舵柄を巧みに操り、定置網へ向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "……王の射手エーナール・タンバルスケルヴェはエリック伯をねらって矢を送ると、伯の頭上をかすめて舵柄にぐざと立つ。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "艇尾には色淺黒く、虎髯を海風に吹かせたる雄風堂々たる海軍大尉あり、舵柄を握れる身を延して、『やゝ、貴下等も日本人ではないか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "艫の舵柄の傍では、年老った船頭が一杯機嫌で胡座をかき、大きな煙管で煙草を喫みながら舵柄を見て、二人の壮い舵手に冗談口を利いていた。",
              "citation": {
                "source": "幽霊の自筆",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにその雲霧のようなものの影は、ふわふわと舵柄の傍へ降りて来た。",
              "citation": {
                "source": "幽霊の自筆",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「船幽霊が来やがった」　二人の舵手は舵柄にすがったなりで起きあがれなかった。",
              "citation": {
                "source": "幽霊の自筆",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "舵柄がばたんばたんと動く度にそれについている真鍮がぴかぴか光るのまでが見えた。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから私は舵柄を括りつけて、下へ降り、自分の衣類箱のところへ行って、母に貰った柔かい絹のハンケチを取って来た。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に、私は掴んでいた舵柄を放すと、それが風下の方へ烈しく跳ねた。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "という訳は、その舵柄がハンズの胸にあたって、彼はしばらくの間ぴたりと止ったからである。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "上に出てみると、小矢柱が突き転がされて舵場の上に倒れ、帆はズタズタに切られ、舵柄はもぎとられ、船を動かす道具という道具は残りなく壊してあるという目もあてられない狼藉ぶりであった。",
              "citation": {
                "source": "呂宋の壺",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "舵柄は取り除いてある。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
