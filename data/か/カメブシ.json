        "examples": {
          "standard": [
            {
              "text": "築地の乾物屋で、小ぶりながらも旨味が凝縮された亀節を一節買い求めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今日のお吸い物は亀節で出汁を取ったから、いつもより香りが上品でしょ？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鰹を三枚におろして作る亀節は、家庭でも使い切りやすいサイズなのが嬉しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "と不足らしい顔つきして女を見送りしが、何が眼につきしや急にショゲて黙然になって抽斗を開け、小刀と鰹節とを取り出したる男は、鰹節の亀節という小きものなるを見て、「ケチびんなものを買っときあがる。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "本節と亀節ならば、亀節がよい。",
              "citation": {
                "source": "だしの取り方",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "見たところ、堂々としていても、本節は大味で、値も亀節の方が安く手に入る。",
              "citation": {
                "source": "だしの取り方",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
