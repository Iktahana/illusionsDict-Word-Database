        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔ながらの洗濯は、この大きな金ダライに水を張って行っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "庭の手入れで、土や肥料を混ぜるのに金ダライを使った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "金ダライが古くなって錆びてきたな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祭りの準備で、提灯を洗うために金ダライが必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "兄は『あの金ダライは元私のもので、高は勝手に彼の名をペンキで書いて、自分のものだと云い張るんです。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところどころに娘をみつけた父母が跼んでなにかを飲ませてい、枕もとの金ダライに梅干をうかべたうすい粥が、蠅のたまり場となっている。",
              "citation": {
                "source": "原爆詩集",
                "author": "峠三吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "やかましく云って下すって、金ダライのありかがわかって、というようでもあったわねえ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "金ダライでもたたいて、さわぎましょうか？",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どろぼうに見舞われたときにも、やはり一般市民を真似て、どろぼう、どろぼうと絶叫して、ふんどしひとつで外へ飛び出し、かなだらいたたいて近所近辺を駈けまわり、町内の大騒ぎにしたほうが、いいのか。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "箪笥の前にはブリッキの小さなかなだらいの中に。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　武男は、筆をつかったあとで、かなだらいに、水をいれて洗うと、もくもくと、ちょうど汽車の煙のように、まっ黒い墨を、筆からはき出します。",
              "citation": {
                "source": "山に雪光る",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
