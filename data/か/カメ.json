[
  {
    "uuid": "9d0818b2-ca09-57a4-a92c-bdf7f2fe0abb",
    "entry": "亀",
    "reading": {
      "primary": "かめ",
      "alternatives": [
        "カメ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
