        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大学進学を機に、初めて一人暮らしを借り住まいから始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "家族が増えたので、手狭になった借り住まいから広い家へ引っ越すことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の借り住まいを訪ねたら、きれいに整理整頓されていて驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
