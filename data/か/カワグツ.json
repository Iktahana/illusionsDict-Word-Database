        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「痛っ、新しい革靴で靴擦れしちゃったみたい」とベンチに座り込んで顔をしかめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大事な商談の前には、ホテルのロビーで革靴を丁寧に磨くようにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雨の日に革靴を履いた後は、型崩れしないようシューキーパーを入れて陰干しする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "弟は初めての給料で、少し背伸びをして憧れのブランドの革靴を新調した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "丈の高い男の嚴丈さうな腕に、もたれるやうに腰を抱きかかへられながら、女は踵の高い赤革靴の運び輕げに踊つてゐる。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤革靴に霜降の流行型の背廣を着た方は金縁眼鏡を掛け、和服の方は羽織を脱いだ着流し姿になつて、毛もくぢやらの足を腰掛下に突き出してゐる。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、海水パンツいっちょうに革靴の男がなぎなたの試合会場を飛び回って審判でもやってれば、そりゃタケシ軍団の世界だろうよ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんともったか」　制服用の黒い革靴に、コットンパンツはまずい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりとも、車のなかで私服に着替え、高志は制服を車においてきたが、慶一は、制服の上下と黒い革靴をバッグに突っこんでもっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の目に嫌でも入ってくる、君の革靴、左内側、ちょうど火灯りに照らされたあたりの、ほぼ平行な六つの傷が。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリフォン　（真剣に）革靴をまだらに磨くからよ。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリス　革靴をまだらに磨く？",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリフォン　そうよ、革靴を磨いたらどうなる？",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリフォン　海んなかじゃ革靴を磨きゃあ、まだらになるんよ。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリス　その、海の革靴ってどうなってて？",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は僕と並んで壁にもたれたまま、じっと自分の塗革靴をにらんでいたが、不意に気を失ってぶったおれてしまった。",
              "citation": {
                "source": "幸福への意志",
                "author": "DER WILLE ZUM GLUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕尾服は申し分なく、シャツはまぶしいほど白く、細い、形の好い足には、塗革靴を穿いている。",
              "citation": {
                "source": "小フリイデマン氏",
                "author": "DER KLEINE HERR FRIEDEMANN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでぼくはみんなの穿いている木靴を羨ましいとは思ったが、革靴のように売ってもいず、手に入れる工夫も知らず、始終、水びたしの足に、ただの破れ靴か草鞋しか穿いていなかったのである。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "同氏も熱病にかかり、回復したときは革靴と、なけなしの金しか持ってなかった。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、皆が革靴を履けたらなあ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京にいるお父さんから送ってきたお正月の革靴である。",
              "citation": {
                "source": "大根の葉",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、スライトは、メイフィールドのズボンが雨のしずくを反射し、革靴が泥で汚れているのを見逃さなかった。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "革靴が泥で汚れていました。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "革靴が泥で汚れておりました。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は淡黄褐色の長い上着に、シルクハットの伊達男、粋な仕立てズボンと、エナメル革靴をはき、一人ぼっちじゃなく、見事なショールを掛けた女を連れている。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "革靴を脱いで書斎へそっと来てください。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "革靴を脱ぎ捨て、ウェブリー拳銃を見つけ、弾倉にすべて充填し、階段を猫のように忍び降りて、書斎を覗き込んだ。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "また革靴をはいて、取り掛かった。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっこい女のような足に、エナメル革靴を履いとった。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かに、二人の男が不法侵入し、間諜し、同じ小足、同じエナメル革靴を履くなんて、ありえない。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "折れ頭巾をかぶり、白髯は膝にたれ、道服に似たものを着、柔かそうな革靴をはいている。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのいでたちを見るに、緋房のついた鉢兜、鋳物綴りの鍍金の甲、下には古物ながら蜀江の袖をちらつかせ、半月形の革靴をはいた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、彼もまた、その日は瀟洒であった赤革靴のきびすを回すと、やや低いスロープを作っている芝生の窪みに、お光さんがいた。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
