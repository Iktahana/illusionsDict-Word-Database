    "definitions": [
      {
        "index": 1,
        "gloss": "to be square",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は、骨格がしっかりしていて、少し角張った顔立ちをしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "昔の自動車は、今の流線形のデザインと比べて、全体的に角張っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼の書く文字は、まるで定規で引いたように角張っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "で、折角張る氣を以て事に處し物に接して居ても、反對の弛む氣が頓て生じて來る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角張る氣で有つても、流れて逸る氣となつて終ふ。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、折角張る気を以って物事に接していても反対の弛む気がやがて生じて来る。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角張る気であっても流れて逸る気となってしまう。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "気取るな、威張るな、角張るな、逆上せるな。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "この久兵衛とお艶とどういう関係にあるのか、などと改めて四角張るのは野暮の骨頂で、片方が気違いのことだ、順序も系統もあったものではない。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "お茶漬音頭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お白洲じゃないから、四角張るには及ばない。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "三千両異変",
                "note": "青空文庫"
              }
            },
            {
              "text": "同級生もお客となると四角張る。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to be formal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "重役たちが揃った会議室は、角張った雰囲気で、誰もが緊張していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "普段は冗談ばかり言う彼も、その場では妙に角張った話し方をしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "そんなに角張った言い方をしなくても、あなたの気持ちは十分に伝わりますよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      }
