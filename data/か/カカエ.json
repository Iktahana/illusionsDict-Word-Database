        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は社長お抱えの運転手として、長年その一家に仕えてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "その料亭は、数人のお抱え芸者を抱えており、毎夜華やかな宴が開かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "有名な建築家は、信頼するお抱えの職人たちだけでプロジェクトチームを構成した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      }
