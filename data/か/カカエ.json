    "definitions": [
      {
        "index": 1,
        "gloss": "armful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は一抱えもある大きなスイカを、大事そうに持って帰ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "誕生日プレゼントに、自分の背丈ほどもある一抱えのぬいぐるみを貰って彼女は喜んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "古書店で、一抱えの古書を買い込み、彼は満足げな表情を浮かべた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "冬の寒夜に火桶を抱えて、人生の寂寥と貧困とを悲しんでいた蕪村。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四丁目で電車を下りると皿の包を脇の下へ抱えてみたが工合が悪い。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その跡へは大きな革鞄を抱えた爺と美術学校の生徒が乗ってその前へは満員の客が立ち塞がってしまう。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんど腐朽に瀕した肉体を抱えてあれだけの戦闘と事業を遂行した巨人のヴァイタルフォースの竈から迸る火花の一片二片として、こういう些細な事柄もいくらかの意味があるのではないかと思われるのである。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は、頭を抱えながら呶鳴った。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "セコンドメイトは、私が頭を抱えて濡れた海苔見たいに、橋板にへばりついているのを見て、「いくらか心配になって」覗き込みに来るだろう。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は頭を抱えながら、滅茶苦茶に沢山な考えを、掻き廻していた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林は、秋山を放り出して、頭の鉢を抱えた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い婦人で小学校の先生らしいのが両腕でものを抱えるような恰好をして拍子をとっている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は女を抱え、女は男を捉えて走りに走った。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはそのままでわしが貰おう」　翁は、瓜わらべを抱えて戸外へ出た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は螺の腹にえび蔓の背をした形で、瓜わらべを抱え、いつの間にか、いつぞや、息子の岳神に教えられた山ふところの猪の相撲場に来ていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、手頃に傷けてまだ息を残さしてある雄鹿を小脇に抱えていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "連れにはみち子と老妓の家の抱えでない柚木の見知らぬ若い芸妓が二人いた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして船の中へ移るとき、わざとよろけて柚木の背を抱えるようにして掴った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔漢が一升徳利を抱えて暴れているのもいい。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことから考えてみると、我国固有の国民思想を保存し涵養させるのでも、いつまでも源平時代の鎧兜を着た日本魂や、滋籐の弓を提げた忠君愛国ばかりを学校で教えるよりも、時にはやはり背広を着て折鞄でも抱えた日本魂をも教える方がよくはないかという気がしたのである。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次急に横っ腹を抱えて「痛え痛え」と苦しみ出す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝長屋の夜　棚倉一味の門弟がお絹を引抱えて無理に駕籠に押し込めて担ぎ去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次と児分お光を抱えて呆然。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉、仲蔵を抱えて身構え乍らジリ退る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "中の一人が驚いて床の間の文箱を抱えて走り去る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その都会の猛威に対する自分のはらはらしたなつかしさは肉体さえも抱え竦められるようである。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋は大理石像の一群に囲まれて、ロダンさんは秘書のマハセル・チレル公爵夫人と、何かお仕事をしていらっしゃいましたが、その公爵夫人が部屋からお去りになるとロダンさんは壮年のような若々しさを以て、妾の小さい肉体を、あの頑健な腕で抱えて、喜悦をお伝えになったのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾が薄気味悪がって逃げ出そうとすると、急に妾を抱えて嫌がるのもきかないで妾に接吻しました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからの妾は孤独な花子の首を抱えて巴里の隅々を妾の魂を求めて逍遙ったのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "レムブルグを抱えた米良が舞踊場に機械が造り出した人間の造花の美と、同志の終りに近づいた純潔を撒き散らした。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供達は、そこから、琺瑯引きの洗面器を抱えて毎日やって来た。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに何だかおかしい女が来たんだよ」　怪しい女に鯉を抱え出された一件を女房の口から聴かされて、藤吉はいよいよ顔の色を変えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場はときたま、てかてか黒く光るヴァイオリンケエスを左腕にかかえて持って歩いていることがあるけれども、ケエスの中にはつねに一物もはいっていないのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
