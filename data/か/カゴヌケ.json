  {
    "uuid": "950aff5c-019c-5b02-b179-7b0642514344",
    "entry": "籠抜け",
    "reading": {
      "primary": "かごぬけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
