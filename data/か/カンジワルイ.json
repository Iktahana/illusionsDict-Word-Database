        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの店員、客に対してすごく感じ悪い態度だったな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "初めて会ったのに、彼からは威圧的で感じ悪い印象を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "悪天候で気分まで感じ悪くなってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "元来食物の味というものはこれは他の感覚と同じく対象よりはその感官自身の精粗によるものでありまして、精粗というよりは善悪によるものでありまして、よい感官はよいものを感じ悪い感官はいいものも悪く感ずるのであります。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "感じ悪いよ」　夢がこわれたのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "円山公園感じ悪いよ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだよ、おまえら、感じ悪いな！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "概して平和主義のデンには感じ悪い。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "北野の重役室へ寺本支配人を訪れる、感じ悪い奴だが今日は頗る機嫌よく、色々話す、ロッパ映画が内務省あたりで評判よき話をきゝ嬉しい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「名古屋毎日」の記事出た、感じ悪い。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二十六日（月曜）　今朝迄、又麻雀したが、一向面白くない雀だった、嵯峨善兵てのが感じ悪いのと、島村竜三が、いぢけてゝあたぢけないせいであらう。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーラス・コロンビアの若いの大ぜい、挨拶一つせず、感じ悪い。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
