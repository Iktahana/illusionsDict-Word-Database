[
  {
    "uuid": "672d60e5-3b81-5107-9487-23d791937d70",
    "entry": "枯れる",
    "reading": {
      "primary": "かれる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to wither (of a plant)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "花瓶に生けたチューリップが、水切れでだんだん枯れてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "秋になると、公園の木々の葉が黄色く枯れて、地面に舞い落ちる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "猛暑が続き、庭の芝生がすっかり茶色く枯れてしまって残念だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "よく秋の末に草が枯れる時分になりますと、山火事がありましてね。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯れるかと思ったら存外枯れもしないで、今年の春の日光を受けるとまた正直に若芽を吹き出して来た。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一生のつとめを終ってしまった樹木が、だん／＼に、どこからともなく枯れかけて、如何なる手段を施しても、枯れるものを甦らすことは出来ないように死んでしまった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "捨てりゃ、ネギでも、しおれて枯れる、ってさ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸ではね、僕たちが波のしぶきを運んで行くとすぐ枯れるやつも枯れないやつもあるよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "苹果や梨やまるめろや胡瓜はだめだ、すぐ枯れる、稲や薄荷やだいこんなどはなかなか強い、牧草なども強いねえ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええと、陸稲が枯れるんですか。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっぱり稲枯れるもの。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、我々の肉体は衰え、感覚は枯れる。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "人人はげつそりとし、ものうくなり、空虚なさびしい心を感じて、磯草の枯れる砂山の上にくづれてしまふ。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯れるな、枯れるな、根を、おろせ。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木之助の家では八十八歳まで生きた木之助の父親が、冬中ねていたが、恰度旧の正月の朝、朝日がうらうらとお宮の森の一番高い檜の梢を照し出すころ、恰度天から与えられた生命を終って枯れる木のように、静かに死んでいった。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ黄色い下葉や裏葉、あれも程なく枯れるであらう。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、お種の洗濯している谷川の流れは、日浦坂の上にある、ほど落ちと云う池から来ているもので、流れは小さいが如何なる炎天にも枯れることがないと云われていた。",
              "citation": {
                "source": "蟹の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ樹木の枯れるように手足が不叶いになられただけで、健康には申分なく、そのまま枯れ果てて三年後の夏の何日であったかに、眠るが如く世を去られたまでの事であった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "花は咲いたが、どうもこの木、枯れるらしい。",
              "citation": {
                "source": "たべものの木",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "観音様に見えますと云って、凝と優しい姑の顔を見ながら、莟の枯れる口を開けた、お母さんのおもいも、察するが可いよ。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "草の霜枯れるように死を待つイナゴは寂しいものである。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "老木の朽ち枯れるそばで、若木は茂り栄えて行く。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右の畑は紫色の花が満開で吾々は喉の枯れるほど歌ひながら風を切つて進んだ。",
              "citation": {
                "source": "サフランの花",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし又その松の樹が次第に老い、次第に衰へ、一部分が枯れ、終に全く枯れるとすれば、明日の松の樹もまた今日の松の樹と異なり、明年の松の樹もまた今年の松の樹と異なるのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "松樹は或る時に花を飛ばし或る時に葉を替え、そうして次第に成長し、次第に老い、次第に枯れるのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹に花が咲くと枯れるといふことを私は昔から聞いて知つてゐるので、これは駄目だなと思つた。",
              "citation": {
                "source": "中秋の頃",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "……木部にわびようか……木部は居所さえ知らそうとはしないのだもの……」　葉子はやせた肩を痛ましく震わして、倉地から絶縁されてしまったもののように、さびしく哀しく涙の枯れるかと思うまで泣くのだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕燕の母さん洒落母さんそろひの簪買つてやろ牛乳屋の表に遊んでた母さん燕は洒落母さん　トマト畑雨降り雲はなぜ来ないトマト畑がみな枯れるトマト畑に太陽はじりりじりりと照らしてる雨降り雲はなぜ来ないトマト畑がみな枯れるトマト畑の百姓は赤いトマトを眺めてる。",
              "citation": {
                "source": "十五夜お月さん",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕燕の母さん洒落母さんそろひの簪買つてやろ牛乳屋の表に遊んでた母さん燕は洒落母さんトマト畑雨降り雲はなぜ来ないトマト畑がみな枯れるトマト畑に太陽はじりりじりりと照らしてる雨降り雲はなぜ来ないトマト畑がみな枯れるトマト畑の百姓は赤いトマトを眺めてる。",
              "citation": {
                "source": "十五夜お月さん",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、文学志望で文学が書けぬといへば、尠くも近頃は「困つた」と思ふが、「いいものを書いてゐるが認められぬ」といふことは、「まあまあそのうちなんとかなるよ」と、それも甚だ好い気な調子で肩叩かれる。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護衣のまゝで抱かれるのは少しいやでもあつたけれど、心底可愛さうに抱いてるのにそんなことも云へなかつた……」と、母の話はマストの次には岡宮さんである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが寔に此の一言を免かれる人一人の不幸といふものはないのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の部門を出て故人に逢ひぬ秋の暮　秋風｜落寞、門を出れば我れもまた落葉の如く、風に吹かれる人生の漂泊者に過ぎない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to mature (of one's personality, abilities, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長年舞台に立ち続けた彼の演技もようやく枯れてきて、名脇役としての風格が漂い始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お前もずいぶん枯れたもんだな」と、昔の尖っていた頃を知る友人にしみじみと言われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "円熟味が増し、余計な虚飾が削ぎ落とされた枯れた味わいの文章は、大人の読者にこそ響く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「若い頃のようなギラつきはなくなったけど、今の枯れた雰囲気のほうが僕は好きだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
