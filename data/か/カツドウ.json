[
  {
    "uuid": "4c847ccd-240b-5a9e-98a6-2de3d163d5f1",
    "entry": "活動",
    "reading": {
      "primary": "かつどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
