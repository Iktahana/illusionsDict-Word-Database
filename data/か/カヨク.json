    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unselfishness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は常に寡欲で、名誉や財産には一切興味を示さない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "都会の喧騒を離れ、寡欲な生活を送ることに心の平安を見出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地位や権力に固執せず、寡欲な姿勢を貫く彼の生き方は、多くの人に尊敬されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "病気の時ほど、人は寡欲になることはない。",
              "citation": {
                "source": "病床生活からの一発見",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気は、丁度さういふ寡欲さで、人をエピクロス的の快楽主義者にする。",
              "citation": {
                "source": "病床生活からの一発見",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃、口腹が寡欲になった為、以前の様に濫費しません。",
              "citation": {
                "source": "岡本一平論",
                "author": "――親の前で祈祷",
                "note": "青空文庫"
              }
            },
            {
              "text": "三毛が食物に対してきわめて寡欲で上品で貴族的であるに対して、たまは紛れもないプレビアンでボルシェビキでからだ不相応にはげしい食欲をもっていた。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二百七十八　わたくしは榛軒の資性を語つて、既に其寡欲と多く文事に意を用ゐざることとを挙げた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "（※）清廉寡欲　『三國志』の諸葛亮傳に、初亮自表後主（劉禪）曰。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "生来の寡欲と商法の手違いとから、この多吉が古い暖簾も畳まねばならなくなった時、かみさんはまた、草鞋ばき尻端折りになって「おすみ団子」というものを売り出したこともあり、一家をあげて江戸に移り住むようになってからは、夫を助けてこの都会に運命を開拓しようとしているような健気な婦人だ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寡欲と、正直と、おまけに客を愛するかみさんの侠気とから、半蔵のような旅の者でもこの家を離れる気にならない。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしさような宝を手頼にいたすは尋常で、寡欲のお徳はそれに増すお身の備でございます。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここには幡随院の長兵衛が生きており、式亭三馬や十返舎一九も生存し、鼠小僧次郎吉も、弁天小僧菊之助も、生きていたに違いない、人間は寡欲で恬淡で、時には途方もない物堅い人間が生存していたに違いない、随分苦しい生活であったが、猫の蚤を捕えても暮しが立ち、耳の穴を掃除しても三度の飯にありついたのである。",
              "citation": {
                "source": "銭形平次打明け話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "寡欲清廉な人ではあつたが、政治的識見才能に乏しく、たとい小国でも、一国の政治を任される人ではなかつたので、孔子は彼が魯のような大国の大夫であることに、大きな疑問を抱いていたのであろう。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "民政ノ要ハ、寡欲公平ニアリ。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "カクテ、昨日ノ寡欲ナル武門ハ、驕奢ニ変ジ、驕奢ノ門ハ賄賂ヲヨロコビ、賄賂ハマタ、苛斂ト誅求ヲ諸地方ニ生ム。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから私は何を云つたかよくは覚えてゐないが、兎も角新しき男に皮肉めいたことを喋舌つたことを覚えてゐる。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかよく、僕の詩を鑑賞してみて呉れたまへ。",
              "citation": {
                "source": "河上に呈する詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かよく解らなかったけれど、今夜是非お松を頼みたいと云うような事を、勝手にしゃべって出て行った。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "パピプペポと発音したのはいつであったかよく判りませぬが、奈良朝ではもうファフィフフェフォになっていたのではないかと思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこがいいのかよくは分らない。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を塞いで聞き入りながら、私は何時の間にかよく寢込んでしまふのだつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはどういうわけであったかよくわからない。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何物が持ち去ったかよくは分らない。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、その秘密を行なうのはいつでも夜なかときまっていて、どこの誰が秘密の祈りをして貰ったということが他人に知れると、その験がないというので、秘密の祈りを頼むものは世間がみんな寝静まった頃に、顔を隠したり、姿を変えたりして、そっと裏口から出入りをしているので、誰だかよく判らないということです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにかよくはわからないが、とにかくこれは非常に艶めかしい所作であることは事実である。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煉瓦やアスファルトの所はすべらないのに、適当に泥の皮膜をかぶった人造石だとなかなかよくすべる。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の話によるとなかなかよく日本人の特性をうがっていて、むしろ日本人の美点を表現しているそうですが、タケラモに恐れてまだ見ません。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこれをニュース映画で見ると、儀式のプログラムの全体としての構成次第などはよくわからず、演説したり挨拶したりする人がだれだかよくわからなかったりすることもある。",
              "citation": {
                "source": "ニュース映画と新聞記事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "留守にたずねて来た訪問客がだれだかよくわからない場合に、取り次いだ女中に「鬚があったか、なかったか」と聞いてみると、大概の場合に、はっきりした記憶がない。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろな点でなかなかよくできているおもしろい映画であると思われた。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "波の音もなかなかよく撮れていて、いつまでも耳に残るような気がした。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルクナー主演の「女の心」（原名アリアーネ）の一場面で食卓の上にすみれの花を満載した容器が置いてある、それをアリアーネが鼻をおっつけて香をかいだりいじり回したりするのであるが、はじめは自分にはそれがなんだかよくわからなくて、葡萄でも盛ったくだもの鉢かと思っていた。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
