[
  {
    "uuid": "e116de44-bb2f-5df5-8d69-fc46464650dc",
    "entry": "寡欲",
    "reading": {
      "primary": "かよく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
