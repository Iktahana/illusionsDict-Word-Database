        "examples": {
          "standard": [
            {
              "text": "会議のすべての関与者に事前に資料が配布された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このプロジェクトには、多様な分野の関与者が集まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "事件の関与者として、彼は警察から事情聴取を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "紛争の和平プロセスには、多くの国際機関の関与者が含まれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしその人々は僕の内的、外的な仕事の全的な証人ではありえないし、また僕のまことの関与者ではありえない。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            }
          ]
