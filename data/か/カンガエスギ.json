    "definitions": [
      {
        "index": 1,
        "gloss": "overthinking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "心配しすぎだよ、それはただの考えすぎだって。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は何でも考えすぎる癖があるから、あまり深く詮索しない方がいい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「大丈夫だよ、きっとうまくいくさ。」と友人は励ましてくれたが、私はまだ考えすぎていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "これはまた園があまり真剣に考えすぎたなと思うと、人見には即座に返事をするのが躊躇された。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが落語のことを真剣に考えすぎたために鬱病のどつぼにはまった彼は、「一時は時うどんも繰られへんぐらいになり」、自殺寸前にまで追い込まれてから今の芸風に大化けして立ち直った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり考えすぎるから、事がむずかしくなるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり物事を簡単に考えすぎるやり方だと思います。",
              "citation": {
                "source": "これでは囚人扱い",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕なんか、飯も食える方だし、夜もよく眠りますよ」「少し考えすぎるんでしょうね」彼は続けて言った。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はほんの常識的な答えを期待しての問いだったんだろうが、私は深く考えすぎたのだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりゃ余りに考えすぎていませんかな。",
              "citation": {
                "source": "麻雀殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、君は佐田やす子を独立して考えすぎている。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと冬になったら、もとの巣がこいしくなって帰ってくるよ、そのときぼくらはあたたかい心をもってむかえてやればいい」「そうだ、ぼくはあまりに考えすぎていた」「ハハハ、これでどうやら過敏症も全快らしいね、おめでとう」　とゴルドンがほがらかに笑った。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして白人をえらく考えすぎているのじゃないかしら？",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "御敬ちゃんは、「貴方、あんまり何か考えすぎたんだ、キット、だけどもうすんで仕舞った事だから……」　こんな事を云って私の頭を押えて居て呉れた。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものごとを物的に考えすぎるな。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            },
            {
              "text": "余りに考えすぎたからだったろうか。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし考えすぎとりゃせんかナ」「それは先刻から何度も云っていますとおり、私の自信から来ているのです。",
              "citation": {
                "source": "蠅",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局妾は疑心暗鬼から、たいへん入り組んだことまで考えたが、これは考えすぎてたいへん莫迦をみたようなものであった。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "尼さんになった日から何にも思わず好い事だらけだと思うのはあんまりよく考えすぎてますよ、ほんとに。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはちとお考えすぎではないでしょうか。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二人が同じ仲間とは、ちと考えすぎではあるまいか」「でも、そうとしか考えられませんもの」　一彦少年は、いつに似ず、たいへんがんばっています。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が考えすぎるにはワケがあった。",
              "citation": {
                "source": "握った手",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えすぎるのはいけないことだ、とむろん彼も心得ていた。",
              "citation": {
                "source": "握った手",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもまた土地柄でそれだけ独特の土地風があって一概に甲乙はつけがたいが、日向の人々が自分たちの古墳群を過大に考えすぎるのにくらべて、群馬の人々が全然古墳なぞ念頭におかないのはおもしろい対照である。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察の旦那というものは、考えすぎるよ。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、現在の警察の取締りぶりには、酔っ払いの自業自得を認めるの余り、山賊の商法の方を合理的に考えすぎる傾きがあるようだ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何でも僕は先へ先へと考えすぎたようだね。",
              "citation": {
                "source": "恩人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「物事を余り真面目に考えすぎるからいけないんだ。",
              "citation": {
                "source": "球突場の一隅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたは余り何でも大袈裟にお考えすぎなさるからいけませんですよ。",
              "citation": {
                "source": "運命のままに",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「余りいろんなことを考えすぎなさるからいけないんですわ。",
              "citation": {
                "source": "二つの途",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り考えすぎるからいけないんだとは知っていますけれど、隆ちゃんが始終暗い影を背負ってるように思われて仕方ありません。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　私の考えでは、従来の法律家は――否、普通一般の人々も――法律の領分を不当にひろく考えすぎているように思います。",
              "citation": {
                "source": "役人の頭",
                "author": "末弘厳太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――けれども、現代の人びとはあまりに肉体を大切に考えすぎているので、まず神のことばを聞け、と話してみたって、耳をふさぐか、背を向けて逃げるか、歯をむいて跳びかかってくる。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
