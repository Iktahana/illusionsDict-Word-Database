[
  {
    "uuid": "1e8d2337-75fe-56da-ac66-f21f46c32905",
    "entry": "隔壁",
    "reading": {
      "primary": "かくへき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
