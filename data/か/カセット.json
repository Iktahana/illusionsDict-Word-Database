    "definitions": [
      {
        "index": 1,
        "gloss": "cassette (tape)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "実家の納戸から、中学時代に深夜ラジオを録音したカセットが段ボール一箱分も出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "カセット特有のわずかなヒスノイズが、かえって当時の部屋の空気を思い出させてくれて心地いい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鉛筆をリールの穴に差し込んで、たるんでしまったカセットの磁気テープを慎重に巻き戻す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これによって、レコードからカセットに音楽を落とし、ウォークマン型の機器で聞くことは、問題ないとされてきた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カセットテープなら、リールをセットしなくていいのにな」と、高志。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "国産のテープが発売されるので、高志はカセット・テープレコーダーを買うといっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オープン・リールとカセットの、ふたつのテレコもセットされている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "カセットのほうはマイクで録るんだから、みんな入っちゃうよ」　全員に注意をあたえ、ワラは二台のレコーダーをまわした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "カセットテープができたときだって、いやな予感がしたんだよね。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、カセットハーフが死んでてさ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにＰＥＴには、外部記憶装置としてカセットデッキまで組み込まれていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに、作ったプログラムをカセットテープに記録しておき、必要に応じて読み出してきてまた使うなど、ＰＥＴ一台で、一つのまとまったコンピューターとして充分使うことができる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "カセットデッキとのインターフェイス回路を組んで、カセットを外部記憶装置として使う。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キットを組み立てたいのではなく、でき上がったコンピューターを使いたいのだ」とのユーザーの声に応じて送り出された新製品は、組み立て済みのＴＫ―80とＴＫ―80ＢＳを組み合わせ、電源と外部記憶装置としてカセットデッキを組み込んでケースに収めたものだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに電源を付けたりカセットとのインターフェイスを付ければ八万円から九万円にはなる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにはカセットデッキの有無で二種類があり、付いている方で定価が二三万八〇〇〇円、付いていない方で一九万八〇〇〇円だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが新製品発表ののち、コンポＢＳはカセットなしのタイプで一五万円まで値引きされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時点では、八Ｋバイト版の単体価格は五〇〇ドルで、本体、八Ｋバイトの増設メモリー、シリアルＩ／ＯもしくはオーディオカセットＩ／Ｏとのセット価格は七五ドル。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本体、一二Ｋバイトの増設メモリー、シリアルＩ／ＯもしくはオーディオカセットＩ／Ｏとのセット価格は一五〇ドルと設定されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディスプレイに加えてデータやプログラムの記憶装置としてカセットデッキまで組み込み、スイッチ一つでベーシックの立ち上がるＰＥＴは、趣味の世界を超えて実用の機械を目指しているように見えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この新製品には、外部記憶装置としてカセットデッキを本体に組み込んだタイプも用意されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三に、これまで補助記憶装置として使われてきたカセットテープレコーダーも、接続できるようにする。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "キーボードはビジネス用を意識して、大きめのタッチのよい本格的なものが用意されており、従来のマシンで一般的だったカセットテープレコーダーもつながるようになっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ―８００１は、標準でカセットテープレコーダーをつなぐインターフェイスを備えていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "カセットテープに収めたプログラムと解説書とをセットにした『ＰＣ―８００１ ＢＡＳＩＣ ゲームブック』は、一九七九（昭和五十四）年十二月に書店に並ぶと売れに売れた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＨＣ―20の本体には、液晶のディスプレイに加えて、補助記憶として使うマイクロカセットレコーダーと小さなプリンターまで組み込まれており、西はこのマシンにもマイクロソフトのベーシックを売り込んでいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他にＢＩＯＳ、通信関係、検査、ベーシックを収めるＲＯＭやカセットテープの製作要員、さらに追いかけの作業となるＯＳの移植スタッフなどが必要となり、社内の担当者と、日本電気では協力会社と呼んでいる外注のスタッフあわせて、つごう二五名程度を専従として張り付ける必要があるだろうという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五に、これも八ビット機で外部記憶装置として使われ、アプリケーション供給のベースとなってきたカセットテープレコーダーを接続できるようにすること。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "オフィスコンピューターの製品計画に携わってきた小澤は、従来機からの継承性を重視するという方針は承知していたものの、まがりなりにもコンピューターに家庭用テレビやカセットテープレコーダーへのインターフェイスを用意せよという注文には違和感を禁じえなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "カセットテープレコーダーがパーソナルコンピューターの外部記憶装置として今後どれほど使われるかには大いに疑問があった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭用テレビやカセットテープレコーダーといったアナログの機器をつなぐのには当初戸惑いがあったが、着手してみればこれも間もなく解決できた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "加えてＰＣ―８００１に用いられたＮ―ＢＡＳＩＣと互換のＮ―ＢＡＳＩＣ（86）が、カセットテープによって供給されることとなった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
