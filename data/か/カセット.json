        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "接触が悪くなったゲームのカセットの端子に息を吹きかけるのは、当時の子供たちの共通の儀式だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "名作だと噂のカセットを中古ショップで見つけたが、プレミア価格がついていて手が出なかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「これ貸すから、代わりにそっちのソフト貸してよ」と、放課後の教室でカセットの交換交渉が始まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
