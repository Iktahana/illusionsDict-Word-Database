    "definitions": [
      {
        "index": 1,
        "gloss": "to put in order",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ちょっと、ハサミ使ったら元の場所に片付けておいてよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「明日家庭訪問があるから、リビングを完璧に片付けなきゃいけないんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「散らかったデスクを片付けると、仕事の効率が全然違うよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よし、この段ボール箱の中身を全部棚に片付けちゃおう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "食事がすんでそこらを片付けるうち風呂がわいたから父上から順々にいってからだを清める。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "繪具箱を片付ける頃には夕日が傾いて廢墟の汀の花薄は黄金の色に染められた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私はそう答えながら、ものごとを片付けるなら一番あとにして下さいと頼む。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれもこれもことごとく偶然の現象だとして片付ける前にともかくも何かしら合理的な方法のふるいにかけて吟味しなければならない。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の手術で「速度の相対性」を片付けると、必然の成行きとして「重力と加速度の問題」が起って来た。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後日彼は、あるアメリカの農夫が『百科全書』を買ってＡからＺまで通読しているという噂をして「私の波動論をどう片付けるか見ものだ」と云った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれを取片付けるのが当然だということも認めていらっしゃるのでしょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこで、くどいことは云わねえ、手短かに話を片付けるが、おまえさんは死んだ若い師匠とどうかしていたんだろうね」　弥三郎の顔色は変った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵の具箱を片付けるころには夕日が傾いて廃墟のみぎわの花すすきは黄金の色に染められた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚の上なぞを片付ける時には、まだ見た事もないものや、忘れ果てゝ居たものなどが、ひよつこり出て来るので、お末と力三とは塵だらけになつて隅々を尋ね廻つた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを反射運動とか、本能とかの言葉で片付けるなら、その反射運動こそ、またその本能も理想的のものだとして置きましょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼覚めたらすぐ起きるのが私の癖だ、起きたのは四時頃か、そこらを片付ける、さつぱりする、気持がいゝな。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ぐいと落着拂ツて、平筆を洗ツて、片付けるものを片付けにかかる。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "放り出した夜具類を、もとの通りに片付けると今度は隣り側の襖を開いて内部一面に切り組んである衣裳棚を引き出し初めた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから大急ぎで蚊帳と寝床を丸めて押入に投込んで、机の上に散らばっていた高等文官試験準備用の参考書や、問題集を二三冊、手早く重ねて片付けると今一度、駐在所の表口へ顔を出した。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は「彼岸過迄」を片付けるや否や前約を踏んで「土」の校正刷を読み出した。",
              "citation": {
                "source": "『土』に就て",
                "author": "――長塚節著『土』序――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し今其源因を一つに片付けるのは愚の至として、又事実の許す如く、しばらく両方の因数が相合して此需要を引き起したとして、余はとくに余の見地から見て、後者の方に重きを置きたいのである。",
              "citation": {
                "source": "余と万年筆",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの声音を無心とか無我とかいうものへ片付けるには、あまりに物凄い酸蝕性を持っている。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体は磊落な男なので、軍服なぞも脱ぎ散らかして置いて、細君が勝手に片付けるのであつたが、或時ふいと感じたことがあつて、今では寝ても傍を離さないことにしてゐる。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の尻を他人に拭いてもらう奴を小児といい、自分の垂れ物を自分で片付ける奴を大人という。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "能楽では、何万という登場者があるべき舞台面を僅かに二人か三人で片付ける事が珍らしくない。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は「彼岸過迄」を片付けるや否や前約を踏んで「土」の校正刷を讀み出した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば耕す時は、深く鋤き、細かに砕き、畦を正しくし、土を平らにして、作業は親切を極め、朝から暮れまで働き、終われば鋤鍬を丁寧に洗って片付ける。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに、こんな小さな家だから、なんにも片付けるほどの家財もない。",
              "citation": {
                "source": "火薬庫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝晩は急に冬らしくなりました」「もう店を片付けるのじゃあねえか」「いえ、まだでございます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おあさとおつぎは仕立物を早々に片付ける。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（お妙は仕立物を片付ける。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日、道具を片付ける時になると母はまた押入の前で地球儀の箱を邪魔にし始めた。",
              "citation": {
                "source": "地球儀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々では慌てて雨戸をしめる、干物を片付ける。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう涼しいからね」　ジョバンニは立って窓をしめ、お皿やパンの袋をかたづけると勢いよく靴をはいて、「では一時間｜半で帰ってくるよ」と言いながら暗い戸口を出ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to settle (a matter)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「例のクレームの件、なんとか穏便に片付けることができました。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この問題、誰が責任を持って片付けるんだ？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「過去のしがらみを全部片付けて、新しい土地でやり直すつもりです。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「借金をきれいに片付けてからじゃないと、結婚なんて考えられないよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "to finish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「こんな山盛りのチャーハン、1人で片付けられるかなぁ……。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「残ってる仕事、チャチャっと片付けて飲みに行こうぜ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「冷蔵庫の残り物、全部片付けちゃっていい？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よし、この書類の山を午前中のうちに片付けるぞ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 4,
        "gloss": "to marry off (one's daughter)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「大事な一人娘をどこの馬の骨ともわからん奴に片付けるなんて、俺は許さんぞ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「親としては、早く息子を片付けて安心したいところなんだけどね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あいつもようやく嫁に行って片付いたかと思ったら、一週間で戻ってきやがった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 5,
        "gloss": "to do away with (someone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あんな生意気な新人、一ひねりで片付けてやるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「裏切者は、組織のルールに従って速やかに片付けられた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このパズルゲーム、敵をまとめて片付ける爽快感がたまらないんだよね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
