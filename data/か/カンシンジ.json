    "definitions": [
      {
        "index": 1,
        "gloss": "matter of concern",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供の教育は、親にとって最大の関心事だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "世界経済の動向は、多くのビジネスマンの関心事である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の最近の関心事は、再生可能エネルギーについてだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "日本でも外来語の整理が全国民の関心事となるのは欧米との戦争というような犠牲を払った後でなければ期しがたいのであろうか。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にしても作家たちの関心事は洋服屋の関心事と同じである。",
              "citation": {
                "source": "童話における物語性の喪失",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも芸術家の人知れない苦心などゝいふものは商人にとつては関心事ではない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "化石なんか採ってるアヴェックを、だれが本気にしますか」　なにか一撃くらわせようと、芝は高志をにらんだが、ここにいては、じぶんのほうの関心事も進展する可能性がないことに思いあたったのか、渋い顔でシャーベットを受けとった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にとっては、今日はレインコートを持って出ようかどうしようかを考えるのが最大の私の関心事になって来た。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この質問はどこでも受けたが、してみると、何より日本の国の男子の関心事は、女の事だったのかと、今さら憮然とせざるを得なかった。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが私の人間研究の最大関心事であったのだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし僅々三十年後にはなお、社会の最大関心事が依然として経済であり、主義が戦争の最大原因となるとは考えられない。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和三年度のためには、前年の講義録を再修正する前に、私の年来最大の関心事であるナポレオンの対英戦争の大陸封鎖の項に当面し、全力を挙げて資料を整理し、昭和二年から三年への年末年始は、これを携えて伊豆の日蓮聖人の聖蹟に至り、構想を整頓して正月中頃から起草を始めようとしたとき、流感にかかり中止。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究は大急ぎで素材を整理したくらいのところで、まだまだ消化したものではなく、殊に私の最も関心事であったナポレオンの対英戦争は、その最重要点の研究がまとまらずにいるのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の論敵たる勢力が「民衆を隷従、蒙昧、無智の状態に引止めて置こうとしている」現代の「非真実」な社会現象との闘いが、今日すべての人間らしき人間の関心事である。",
              "citation": {
                "source": "ジイドとそのソヴェト旅行記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の文化の問題から見れば、イタリーの一般知識人の中にあるハケ口のない脱出の欲求が、外から却って彼等を脱出せしめざる方向へ振り替えられていることが、関心事であろうと思う。",
              "citation": {
                "source": "イタリー芸術に在る一つの問題",
                "author": "――所謂「脱出」への疑問――",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に、「ルポルタージュなるものは『物が人をうごかす』という唯物論的文学観によるのであり、今日この形式の文学が文壇の関心事となったこともそこに根拠があるのである」と、結ばれているが、既に現代の文学観は、「物が人を動かす」面にだけ立脚したプレハーノフの理論の時代から辛苦の結果、数歩をすすめて来ている。",
              "citation": {
                "source": "明日の言葉",
                "author": "――ルポルタージュの問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリア作家夫婦にとっての関心事は、それから先に在ると私は思う。",
              "citation": {
                "source": "夫婦が作家である場合",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も興味あり関心事であるべきそれらの点を、作者は機械主義で片づけている。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "同志須井の「幼き合唱」の右翼的逸脱がわれわれの関心事であるのは、特に彼が「綿」の作者だからこそなのである。",
              "citation": {
                "source": "前進のために",
                "author": "――決議によせて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五〇年における日本のまじめな人民の関心事は、全面講和によって世界平和に協力することです。",
              "citation": {
                "source": "宋慶齢への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが母はまた母の関心事があって、いつもそういう私の元禄袖の後姿だけは見て、座敷を出ればもう忘れて立ち働いたりそれなり外出したりしたのだろうと想像される。",
              "citation": {
                "source": "行方不明の処女作",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "早い話が、集団農場組織の問題が、あらゆるソヴェト市民の関心事となったのはいつからだ？",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "耕作用トラクターからはじまって、飛行機は勿論、どこかに成長しつつある同志、チュダコフの強力な発明の可能性に至るまで、一九三〇年代の自覚ある全プロレタリアートの関心事であることに間違いない。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日の関心事、その心持がまた違う。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリア文学における新幹部の養成は、技師、熟練工の養成と同様、重大な関心事となっている。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人の問題ではなく、文学の置かれている非道な境遇として、中野や私は、なんとかそれを全般の関心事としたかった。",
              "citation": {
                "source": "ある回想から",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒飲みは悪い酒を飲み、茶好きはよい茶を好む、前者では量、後者では質が第一の関心事らしい。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの最大の美しい関心事は、人間活動の中の最も高い部分に位置する道徳と理智とを見脱して、どこにも美しさを求めることが出来ぬ。",
              "citation": {
                "source": "純粋小説論",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅の明瞭な記憶は、旅行中当面の関心事たるその人事にはなくて、看過しがちだったその自然の景色にある。",
              "citation": {
                "source": "性格批判の問題",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一番の関心事は、一人の老優人が死ぬることの影響である。",
              "citation": {
                "source": "実川延若讃",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年学生はいずれ関心事たる恋愛につき、いろいろな説を参考するもよかろう。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこゝ数年、かういふ心の影にふれない生活を送り、関心事は肉体の問題に限られてゐた。",
              "citation": {
                "source": "分裂的な感想",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
