        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「かっこう、かっこう」という閑古鳥の鳴き声が、霧に包まれた山あいの村に響いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "閑古鳥が鳴くのを聞くと、都会の喧騒を忘れてどこか寂しげで穏やかな気持ちになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歳時記によれば、閑古鳥はカッコウの別名で、初夏を象徴する鳥として親しまれてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔の人は、鳴き声の主である閑古鳥の姿を求めて、深い森へと分け入ったのだろうか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "林の中では閑古鳥が鳴いてゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑古鳥の声を良寛さんはきいた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "憂きわれをさびしがらせよ閑古鳥「日本浪曼派」十一月号所載、北村謙次郎の創作、「終日。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "津々浦々の渡鳥、稲負せ鳥、閑古鳥。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（二）　落人ごゝろ　このたびの我が旅故郷の閑古鳥｜聴かんがためとも人に云ひぬ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、夢に閑古鳥を聞けり。",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑古鳥を忘れざりしが　かなしくあるかな。",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふるさとを出でて五年、　病をえて、かの閑古鳥を夢にきけるかな。",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑古鳥――　渋民村の山荘をめぐる林の　あかつきなつかし。",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふるさとの寺の畔の　ひばの木のいただきに来て啼きし閑古鳥！",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日々の高原の空にはほととぎす、やぶうぐいす、閑古鳥などの唄がひびいていた。",
              "citation": {
                "source": "夏秋表",
                "author": "立原道造",
                "note": "青空文庫"
              }
            },
            {
              "text": "芋※の靡く様子から、枝豆の実る処、ちと稗蒔染みた考えで、深山大沢でない処は卑怯だけれど、鯨より小鮒です、白鷺、鶉、鷭、鶺鴒、皆な我々と知己のようで、閑古鳥よりは可懐い。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何、正体を見れば、閑古鳥にしろ、直そこいらの樹の枝か葉隠れに、翼を掻込んだのが、けろりとした目で、閑に任かして、退屈まぎれに独言を言っているのであろうけれども、心あって聞く者が、その境に臨むと、山から谷、穴の中の蟻までが耳を澄ます、微妙な天楽であるごとく、喨々として調べ奏でる。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑古鳥や山鳩が、遠くで緩い伴奏を続けてゐた。",
              "citation": {
                "source": "芭蕉と歯朶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "うき我をさびしがらせよ閑古鳥　芭蕉の閑古鳥はたしかに郭公鳥の事であらねばならぬ。",
              "citation": {
                "source": "樹木とその葉",
                "author": "若葉の頃と旅",
                "note": "青空文庫"
              }
            },
            {
              "text": "空一杯、胸一杯に太鼓の音が鳴り響いて、天狗が、牛頭が、象が、｜山彦の精が、馬が、河童が、｜風の神が、｜人形使ひが、｜蝶々の精が、ダイアナがおかめと手を携へて往き、閑古鳥をさゝげた｜白鳥の精が笛を鳴らし、榊やオリーブの枝をさんさんと打ち振りながら続いて続いて止め度がない……。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅｜遠近南すべく北すべく閑古鳥寺見ゆ麦林寺とやいふ山人は人なり閑古鳥は鳥なりけり更衣母なん藤原氏なりけり　最も奇なるはをちこちをちこちと打つ砧かなの句の字は十六にして調子は五七五調に吟じ得べきがごとき。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "定石”　　　　　　　　　　　　たくあん破れて縫うてあるもの閑古鳥よ啼け古雑誌を読みつゝ水声山色老人――“得何和”“一人を楽しむ”旅していると、一期一会をしみ／″＼感じる、山を歩いてゐると和敬清寂を考へる。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは日本橋油町の鉾出車にあったもので、神田田町の「猿」、京橋の「閑古鳥」と並んで、有名な日本橋の「竜神」とは違うが維新の時国外へ流れ出てしまった、この有名な蘭陵王の面は、アメリカにあるとかいった。",
              "citation": {
                "source": "大丸呉服店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "――皆淋しいお山の閑古鳥だ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　皆淋しいお山の閑古鳥。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう、それは大層よいことであつたかも知れないのだ……　クツクウ、クツクウ……向うの林で閑古鳥が啼き出した。",
              "citation": {
                "source": "生者と死者",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてときをり思ひ出したやうに閑古鳥の啼いてゐる林の方へ最後の一瞥を與へながら、思はず溜息をしながら、いまの少女が自轉車を走らせていつた道を村の方へゆつくりと下りて行つた。",
              "citation": {
                "source": "生者と死者",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてその栗の木に手をかけたままで、しばらくじつとしてゐると、その埃りのまだ消え去らぬ間に、また何處か遠くの方で閑古鳥の啼くのが聞えてきた。",
              "citation": {
                "source": "生者と死者",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "山茶花など山茶花の莟こぼるる寒さかな　　龍之介　私はこの夏田舍で「閑古鳥」といふ小さな物語を書いたが、これはその續きといつても好いやうな、もう一つのささやかな人生と、もう一つの墓地との物語である。",
              "citation": {
                "source": "生者と死者",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "時鳥だとか、閑古鳥だとか、それからまだいろいろあります。",
              "citation": {
                "source": "北国の人",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅｜遠近南すべく北すべく閑古鳥寺見ゆ麦林寺とやいふ山人は人なり閑古鳥は鳥なりけり更衣母なん藤原｜氏なりけり　最も奇なるはをちこちをちこちと打つ砧かなの句の字は十六にして調子は五七五調に吟じ得べきが如き。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "中わろき隣合せやかんこどり　　　　一夫「さびしさに堪へたる人の又もあれな」というような山里ででもあるか、閑古鳥が啼くといえば、自ら幽寂な境地を想像せしめる。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
