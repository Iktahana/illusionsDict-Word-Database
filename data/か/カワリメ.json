        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "二つのモデルの、わずかな変わり目を見つけるのが難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この絵画は、他の作品との変わり目が、作者の個性を際立たせている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その二人の性格の変わり目は、彼らがどうして親友になったのかを物語っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
