        "examples": {
          "standard": [
            {
              "text": "「あの科学史家が指摘するように、ニュートンの錬金術への傾倒は単なる道楽ではなかった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "科学史家の講演を聞いて、ガリレオの裁判が当時の政治状況にどれほど左右されていたかを知った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は一介の物理学者としてキャリアを始めたが、晩年は科学史家として多くの著作を残した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ギリシア哲学がバビロン・エジプトの技術学とどんなに密接な史的関係があるかは、科学史家や技術史家の想定する常識となっている。",
              "citation": {
                "source": "技術的精神とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学と技術との連関を分析する必要を最も手近かに感じて来たのは、一群の科学史家であった。",
              "citation": {
                "source": "生産を目標とする科学",
                "author": "――再三「科学と技術」とについて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、この解答を予想しながらかの設問を提起した側の科学史家が、最も誘惑を感じるのは、何となく科学を技術の手段のように見ようという態度である。",
              "citation": {
                "source": "生産を目標とする科学",
                "author": "――再三「科学と技術」とについて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里に万国科学史委員会なるものがあり、伊太利の科学史家ミーリ氏が主になってやって居るのであるが、私はさきに誤ってこの委員会の通信会員に選挙された。",
              "citation": {
                "source": "数学史の研究に就きて",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
