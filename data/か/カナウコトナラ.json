        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "叶うことなら、もう一度学生時代に戻って思いっきり遊びたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "叶うことなら、宇宙の果てまで行ってみたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「叶うことなら、今すぐあの人に会いたい」と彼女はつぶやいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "叶うことなら、世界中の美味しいものを食べ歩きたいな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "折入ってお願いは、相叶うことならば、お台所の隅、お玄関の端になりとも、一七日、二七日、お差置きを願いたい。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子結婚の後は自から其家事に忙しく、殊に子供など産れたる上は外出は自然｜乙甲なれども、父母を親しみ慕うは人間の情にして又決して悪しき事にあらざれば、家事の都合次第、叶うことならば忘れぬように毎々里の家を尋ねて両親の機嫌を伺い、共に飲食などして共に楽しむ可し。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天理人情にさえ叶うことならば、一命をも抛ちて争うべきなり。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何なりと――身に叶うことなら」　何でもなげに広海屋は答える。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくアンナ・セルゲーヴナに会って話がしたい、叶うことならゆっくりどこかで会ってみたい、と思ったのである。",
              "citation": {
                "source": "犬を連れた奥さん",
                "author": "DAMA S SOBACHKOI",
                "note": "青空文庫"
              }
            },
            {
              "text": "叶うことならあっしは、聖なる神の祭壇の前で、あんたの良人になりたいんだ。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "常務取締ともなれば、下級社員の一人や二人何うにでも融通がつくから、叶うことなら、先輩の恩顧に一遍コッキリ酬いたいものと宗像さんは考えていた。",
              "citation": {
                "source": "秀才養子鑑",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "叶うことなら御機嫌を解きたい。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その何かを、かなうことなら自分で見つけたい気持ちもあったのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私の力にかなうことなら悦んでお力になります」　が、そう云い終ると同時に、彼の艶のない白っぽい眉毛の生えた額際を我にもあらず薄赧くした。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方は男らしくはなやかで、ああきれいだと思う第一印象がだれよりもすぐれておいでになりますよ」　などと女房たちは言って、「かなうことなら宮様の殿様におなりになって始終おいでくださることになればいい」　こんなことまでも思ったに違いない。",
              "citation": {
                "source": "源氏物語",
                "author": "柏木",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば、何なりと私の力にかなうことなら、あなたのお望みに応じまして、それは、家屋なり別荘なり、至当のお礼は別にきっといたすとしましょう。",
              "citation": {
                "source": "書記官",
                "author": "川上眉山",
                "note": "青空文庫"
              }
            },
            {
              "text": "と辰弥は重ねて笑み作りて、うむ、あなたの力にかなうことなら、私の望みに応じてとは、三好さん、きっとですぜ。",
              "citation": {
                "source": "書記官",
                "author": "川上眉山",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしでかなうことなら、どんな願いでも、きっと聞いてあげようから。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそれがかなうことなら、尋ねるまでもなく長老のほうから説明してくれるはずであった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなうことなら押しかえしてやりたい。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――身にかなうことならば、ほかならぬ六条どのの頼み。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
