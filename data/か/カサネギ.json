    "definitions": [
      {
        "index": 1,
        "gloss": "layering (clothing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "冬のキャンプでは、「重ね着」を工夫することが大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "温度変化に対応できるように、「重ね着」で調整するのが良いだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「重ね着」しすぎて、ちょっと暑くなっちゃった！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "衣類を失つた人々が秋が更けても白地の單衣の重ね着の袖を雨にしめらせながら街を歩いてゐた。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬服にメリヤスを重ね着した地上からの訪問者には、地下増温率によって規定された坑内深所の温度はあまりに高過ぎた。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ラクダの毛の重いコートを、心に四、五枚重ね着させたような」重苦しい気分に押しつぶされて、ベッドでうずくまっていることしかできません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドなど、人が多く衣を重ね着ぬ熱地では、かかる事を学び知る便宜が遥かに他より多かるべく、したがってそっちの研究はよほど進みいただろう。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "地をつぶしてさしこをした厚衣を二枚重ね着して、どっしりと落ち付いた君のすわり形は、私より五寸も高く見えた。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は外套の上にまた大外套を重ね着していながら、風に向いた皮膚にしみとおる風の寒さを感じました。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがまた、きょうはどうしたことか、黒羽二重五つ紋の重ね着を着用に及んで、熨斗目の上下こそつけね、すべての服装が第一公式のお武家ふうでしたものでしたから、うるさいことにまた伝六が、血のめぐりのよろしくないところを遺憾なく発揮いたしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私の部屋には着換への着物もなかつたのでシヤツばかりを幾つも私が雑巾のやうにほうり出すと音無は、夢中でそれを重ね着して、「未だ寒さうだから、一層あれを着て行かうか――」　と、柄にもなく赤い顔をして部屋の隅の鎧櫃を指差した。",
              "citation": {
                "source": "鬼の門",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして決して受取らうとしないのであるが、私だつて出したものを引つこめるわけにもゆかないので、不図、もう羽織も欲しい季節だといふのに浴衣の重ね着をして控えてゐた傍らの雛妓を見たので、慌ててその子に渡すと、その養母と二人が非常に丁寧に頭をさげて、「若旦那様、どうも有り難う――」　とお辞儀をした。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに来て以来彼は、午後の二時頃寝床を逼ひ出て、それから夜おそくまで斯うして、この部屋に丸くなつてゐた、ドテラを二枚も重ね着して。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる借物の重ね着が君等といふ人間を造つてゐる。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "単衣の重ね着で、どろどろに汚れているメリンスの羽織と云うていたらくでは、尋常な勤め口もありよう筈がない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫と私との変化はちょっと相反している如く見えるが、猫の丸くなるのはもって冬への用心であり、私は寒気を覚えて、何か重ね着をして丸くなろうと考えるわけである。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もあてにはしないぞ）　と、思うと、甚左の重ね着に、批評を加えたのも、いけないように思えた。",
              "citation": {
                "source": "寛永武道鑑",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝と、夕と、秋風の立っている山の中は、もう、単衣の重ね着でさえ、冷たかったし、薬湯を煎じている炉の火が、うれしかった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "独り者の年増婦人の室によくあるように、正枝の室にも、裾を引いた美しい衣裳を重ね着してる大きな童女の人形が、硝子箱に納まって、床の片隅に置いてあった。",
              "citation": {
                "source": "椿の花の赤",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "小紋錦紗のすらりとした姿で、重ね着の淡色の襟を二枚、白縮緬の半襟の上にのぞかせ、臙脂矢羽根の帯締に小さな銀鍵をさげている。",
              "citation": {
                "source": "変る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "絹の重ね着をして、年よりずっとはでな羽織を着、籐表ての駒下駄を絹足袋の□にひっかけて居る。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "身體がぶよぶよ膨れてゐるのは、頻りに麥酒を飮むためだが、その圖體が一段と大きいのは外套の重ね着をしてゐるからで、その中に埋つてゐる恰好はコーリフラワのやう、一番上の外套の裾は踵まで屆いてゐる。",
              "citation": {
                "source": "驛傳馬車",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや……ナニ、ちょっと……それにしても寒い――信州の秋の夜の寒いことは……そこで重ね着しようとして……」　もずもずと口の中で云いながら、テレて、失望して、断念して、主水は又も夜具の中へ入った。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は手荷物を預けてしまって上野ステーションの駅前の便所に這入った時、余の服装が紺飛白の単衣と白地の単衣との重ね着であった事をどういうものだか今だに記憶して居る。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて仙台駅に下車して見ると、それは広い停車場ではあったが、何処となくガランとしていて、まだ九月の初めであるというのに秋風らしい風が単衣の重ね着の肌に入みた。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常に混んでいて、縞目もわからない程汚れ切った着物を重ね着した女だの、犬の皮をはおった土工ふうの人たちだのが、ストーブの上に押しかぶさっていた。",
              "citation": {
                "source": "荒野の冬",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその襟のはだけた下にフランネルと浴衣の重ね着をしている所を見ると、先生はまだ寝間着のまゝなので、そのぼろ隠しにこんな上ッ張りを纒ったのであろうか。",
              "citation": {
                "source": "蘿洞先生",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を釣りあげた上の姉の常子が、毛布地仕立の大外套の重ね着をして、鼻の下までマフラをひきあげた山川に蝙蝠傘をさしかけながら、なになには、どうとかしなくてはとか、ネオ・レバーを飲むことを忘れないでとか、子供にでもいうようにクドクドと注意していた。",
              "citation": {
                "source": "蝶の絵",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜も一色道庵をわざ／＼此處まで伴れ出した上、後ろから一刀に斬り捨てたのは、その爲で御座いました」「フーム」「あの手際は見事で御座います」「餘程の腕利きであらうな、八丈の重ね着を一枚の雁皮のやうに斬つてある」「ところが、それほどの腕利きも、お當家裏門前で斬つたのは手ぬかりで御座いました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "兵粮丸祕聞",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜も一色道庵をわざわざここまで伴れ出した上、後ろから一刀に斬り捨てたのは、そのためでございました」「フーム」「あの手際は見事でございます」「余程の腕利きであろうな、八丈の重ね着を一枚の雁皮のように斬ってある」「ところが、それほどの腕利きも、御当家裏門前で斬ったのは手ぬかりでございました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "兵糧丸秘聞",
                "note": "青空文庫"
              }
            },
            {
              "text": "重ね着をした人間を、たつた一と太刀で、これだけ斬り下げるのは、据物斬の名人でなければなりません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "辻斬",
                "note": "青空文庫"
              }
            },
            {
              "text": "重ね着をした人間を、たった一と太刀で、これだけ斬り下げるのは、据物斬の名人でなければなりません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "辻斬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
