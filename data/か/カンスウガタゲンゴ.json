        "examples": {
          "standard": [
            {
              "text": "副作用を最小限に抑えるため、プロジェクトの一部に関数型言語のHaskellを導入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "手続き型言語に慣れた身には、関数型言語特有の再帰や高階関数の考え方が新鮮だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「へえ、関数型言語なら並列処理もスッキリ記述できるんだね」とエンジニアが感心した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "不変性を重視する関数型言語の設計思想は、バグの混入を防ぐ強力な武器になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
