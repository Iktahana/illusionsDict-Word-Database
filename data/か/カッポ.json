    "definitions": [
      {
        "index": 1,
        "gloss": "striding",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "プレゼンが大成功した後、彼は自信に満ちた表情で廊下を闊歩していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大都会の真ん中を、最新のファッションに身を包んだ人々が闊歩している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "優勝トロフィーを抱え、選手たちは凱旋パレードで胸を張って闊歩した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "早朝の公園を、ジョギングをする人が気持ちよさそうに闊歩している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "憎まれ児世に蔓ると云う諺の裏を云えば、身体が丈夫で、智恵があって、金があって、世間を闊歩するために生れたような人は、友情の籠った林檎をかじって笑いながら泣くような事のあるのを知らずにしまうかも知れない。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の、コムパスは酔眼朦朧たるものであり、彼女の足は蹌々踉々として、天下の大道を横行闊歩したのだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして二人とも美しい顔をゆがめてチューインガムをニチャニチャ噛みながら白昼の都大路を闊歩しているのであった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は得意になつて大道を闊歩した。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた県土木技師の設計監督によるモダーン県道を徳川時代の人々が闊歩したり、ナマコ板を張った塀の前で真剣試合が行なわれたりするのも考えものであるが、これはやむを得ないことかもしれない。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "闊歩横行、登攀、跋渉、そんな事はお茶の子で。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はほくほく者で、幾度も同じ通りを胸をそらして闊歩した。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛のごとく吼ゆるもの、　図体の憎々しく大きく、群獣をぬいて高く怒号するもの、　うそぶき、笑い、闊歩するもの、　孱弱く疲れていざり寄るもの、　ごろりと仰向きに臥ている牡、右の前｜鰭で、はたりはたりと煽いでいるもの、（暑いんだな、あいつ鰭を団扇にしているんだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「太陽と大地と生物とを愛し、富を軽蔑し、乞う者には与え、白人文明を以て一の大なる偏見と見做し、教育なき・力溢るる人々と共に闊歩し、明るい風と光との中で、労働に汗ばんだ皮膚の下に血液の循環を快く感じ、人に嗤われまいとの懸念を忘れて、真に思う事のみを言い、真に欲する事のみを行う。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都の市中は、今や勤皇の志士は全く屏息して、所司代の役人や、会津桑名の藩士、さては新選組の浪士たちが、肩で風をきつて、闊歩してゐる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪の中でコヨーテが忍び、空ではコンドルが旋回し、暗い谷には獰猛なグリズリーが岩間に餌を求めて闊歩している。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうにもモリアーティ教授のごとき御仁がロンドンの街をのうのうと闊歩しているとあってはね。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋が来ると、若いトルコ帽の男や、髪の毛の長い男などが、大道を闊歩するのが目立つ。",
              "citation": {
                "source": "秋は淋しい",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は一日大道を闊歩しつつ、突然として思い浮んだ。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "別段に比べるわけではないが、尾崎君や田畑君の質実味には誰れも劣らぬ闊歩があると期待してゐるのだ。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして私の国はこの美しい私が羽根を拡げて闊歩するにふさはしい程素晴しく立派であることを連想して下さい。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば今日もビナレスの寺院にハヌマン猴を夥しく供養し、また諸市のバザーに入って人と対等で闊歩し、手当り次第｜掴み歩く。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからコケットリー、これは昔は男女ともに言ったが、今は専ら女のめかし歩くを指し、もと雄鶏が雌鶏にほれられたさに威張って闊歩するに基づく。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　何十年といふ間、四季夫々の初めに催される祭りの度毎に天狗になつて闊歩して来た年寄だが、今はもう世の一切の物音から遠ざかつてゐる。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに闊歩のかたちだ。",
              "citation": {
                "source": "足袋のこと",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――万太郎氏は、腕を延して、軽く握つた二つの拳を打ち振りながら、こまかく、大きく闊歩してゐた。",
              "citation": {
                "source": "足袋のこと",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は病院の廊下を揚々と闊歩している。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、山野や桑田や岡本や杉野は作家として立派に登録を済まして「×××」同人として文壇を闊歩している。",
              "citation": {
                "source": "無名作家の日記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、復活した東京の新文化の華然として、大道を闊歩している所謂職業婦人というのはそんなのではない。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "モンスーンが去ったのと歯の痛みが去ったのと、あしたはインドへ着くという楽しみとで、私は何か大きい声で歌いたいような心持で、甲板をしばらく横行闊歩していると、偶然に右の奥の上歯が揺らぐように感じた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、こんな身体で、どうして博士は往来を闊歩されたか。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　思はず僕は、そんなに声を出して呟きながら、得意気に胸を張り、肩をそびやかして闊歩した。",
              "citation": {
                "source": "センチメンタル・ドライヴ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかに世界の公敵が大手をふって闊歩するのを見おとしてはならない。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しい品々かっぽじって来られい。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、かっぽれは如何なる理由からか、ひどく声をひそめて尋ねる。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
