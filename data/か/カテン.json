    "definitions": [
      {
        "index": 1,
        "gloss": "adding points",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「今のプレゼン、資料の見せ方がすごく上手だったから加点しておいたよ」と部長に褒められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自由英作文で難しい構文を正しく使えれば、かなりの加点が期待できるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "コンクールでは技術点だけでなく、表現力による加点が勝敗を分けることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おっ、自炊してるんだ。女子力加点だね！」なんて冗談を言いながら、彼女は僕の作った肉じゃがを頬張った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」これは畢竟枯荻落雁の画趣を取って俗謡に移し入れたもので、寺門静軒が『江頭百詠』の中に漁舟丿して影西東白葦黄茅画軸中　　　　白葦黄茅　画軸の中忽地何人加点筆　　忽地として何人か点筆を加え一縄寒雁下秋空　　一縄の寒雁　秋空を下る〕と言った絶句と同工異曲というべきである。",
              "citation": {
                "source": "向嶋",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "野心があるから、孤獨なんて事を氣に病むので、他の世界の事なんかてんで問題にしてなかつたら、百年千年ひとりでゐたつて樂なものです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども元大先生からして自己流ですから弟子も皆な自己流で、ただむやみと吹くばかり、そのうち手が慣れて来れば、やれ誰が巧いとか拙いとかてんでに評判をし合って皆なで天狗になったのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "野心があるから、孤独なんて事を気に病むので、他の世界の事なんかてんで問題にしてなかつたら、百年千年ひとりでゐたつて楽なものです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは下の方の観客席なんかてんで見やしません。",
              "citation": {
                "source": "或る精神異常者",
                "author": "モーリス・ルヴェル",
                "note": "青空文庫"
              }
            },
            {
              "text": "実のところ、僕は骨牌なんかてんで好きじゃありませんからね。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直なところ、役所へなんかてんで行きたくはないのだ。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢ちゃんがいなくなって私独りぼっち小父さんのところにいるのが怖いんだから……」　だが、大人には大人の理由があって、子供のそうした感情なんかてんでわからないかのように母は冷酷に私の願いを却けた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "上京して苦学している間、瀬川のことなんかてんで思い出してもみなかったのに、今またこうして会って見ると、やっぱり何か、瀬川にひかれるものがあった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三田はすつかり恐縮して、さかんに斬合つてゐる舞臺の活劇も目に入らず、芝居の筋なんかてんでわからなかつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな餓鬼にお前、眼鏡なんてしゃら臭くて掛けられっかてんだ。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山の直り祝いに弁天様のお祭りか」と池田が笑うと、「なんで鉱石なんかてんで出やしねえんでやんすよ。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャンガラ星人の死骸なんかてんで見えないです」「き、き、きみはへんなことをいう。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五ひく三の十二分で神田先生が殺せるかてんだ。",
              "citation": {
                "source": "正午の殺人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は何をしていたかてんだ――どうだい」「十二分ぐらいは何をしても過ぎちまわア」「坂の下にパチンコ屋も喫茶店もなくてもかい。",
              "citation": {
                "source": "正午の殺人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころかてんで見当がつかないから、いつそ一思ひにあの人の前に跪いて許しを乞ひたくて仕方がないのかも知れないのです。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでその犬がどうしたのさ」「その犬の仔を買わないかてんですが、親の性能を見なくちゃ何ともいえませんや。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の恋文はまたこの果し状と同じでんで、あるときはキザなこと話にならず、また或時は熱に浮かされて何がなんだかてんで分らず、また或時は深謀遠慮を逞うして恋の手管をつくして居り、思ひ出してもはづかしくて顔が赧らむ状態だから、メリメとはだいぶん違ふ。",
              "citation": {
                "source": "手紙雑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまなかてんぷらなぞ遠く及ばない。",
              "citation": {
                "source": "夏日小味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車を待たせといて、人殺しができるかてんだ。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はただもう囚人隊の出発の日を待ちこがれ、そうなれば可愛いセリョーシカに再会する折もあろうかと思うばかりで、子どものことなんかてんで念頭になかったのだ。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだその上に、ここのところ圓生を宗家とする三遊派というものが、なぜかてんでその道での人気が目に見えてなくなってきていた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "……人の言うことなんかてんで聴こうともしないんだ……循環させるつもりがありゃ、いっそ初めから齷齪しない、って連中なんだ。",
              "citation": {
                "source": "マリ・デル",
                "author": "MARI D'ELLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "用事を思いだした」　あたしのいうことなんかてんで問題にしない顔でママがいった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ママ薯はぬうっと反り身になると、あたしのいったことなんかてんで聞えなかった顔で、「人間というものは、戦争とか、美とか、そういう苛酷なものに生甲斐を感じると、シュメリングがいっていますが」　あたしが訂正してやった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちらの人気はどうですか」　緬羊にはあたしのいうことなんかてんで通じない。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "このひとはあたしのことなんかてんでかんがえていなかったんだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "――日比魚と三字でひらめと読むか読まないかてんで、大変な騒ぎですよ」「フーン」　平次は一向気の乗らない様子です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "北冥の魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんな馬鹿な話じゃねエ、あの繃帯の足に、セメントの粉が付いて居たのを見たかてんだ。",
              "citation": {
                "source": "悪人の娘",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「両国の活人形に一枚差し加えて下さるまいかてんでさ、恐ろしく丁寧な口をききますが、お貰いのような野郎ですぜ、免倒臭かったら断ってしまいましょうか」　お先っ走りの八、――木戸番と使い走りをやって居る塩辛声の八は、親分の渋い顔を見ると、縁側からこんな呑み込んだ事を言います。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第六夜　人形の獄門",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
