        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "風でずり落ちたワンピースの肩を、彼女はそっと肩を入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "踊っているうちに、衣装の肩がはだけてしまったので、素早く肩を入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "寒い中、マフラーがずれて肩が出たのを、彼は手で肩を入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
