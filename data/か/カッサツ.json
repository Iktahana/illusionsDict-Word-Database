[
  {
    "uuid": "5db373a2-bc9d-57d6-829d-170814977231",
    "entry": "活殺",
    "reading": {
      "primary": "かっさつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
