[
  {
    "uuid": "9943b9de-cc33-5c41-88cc-ed4c37bc2ead",
    "entry": "掛け持ち",
    "reading": {
      "primary": "かけもち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
