    "definitions": [
      {
        "index": 1,
        "gloss": "Nandikesvara (Ganesh in the Buddhist pantheon)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
