        "examples": {
          "standard": [
            {
              "text": "「火山の麓にあるこの浜辺は、火山砂の影響で砂が真っ黒なんだね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「強い風が吹くたびに、細かい火山砂が舞い上がって目に入りそうになるよ、痛いなあ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "火山砂が混じった土壌は水はけが良すぎて、稲作よりも果樹栽培のほうが適しているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おっと、靴の中に火山砂が入り込んでジャリジャリするな、ちょっと待って。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "村には全く人氣が絶え、火山砂の村道ばかりが白じらと光つてゐた。",
              "citation": {
                "source": "生者と死者",
                "author": "堀辰雄",
