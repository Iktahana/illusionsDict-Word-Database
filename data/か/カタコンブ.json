        "examples": {
          "standard": [
            {
              "text": "ツアー客たちは、ランタンの灯りだけを頼りにカタコンブの迷宮を歩いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "古い地図には、街の地下に広がるカタコンブの隠し通路が描かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "カタコンブ特有のひんやりとした空気が、肌を粟立たせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "埃及のカタコンブから掘出した死蝋であるのか、西蔵の洞窟から運び出した乾酪の屍体であるのか、永くいのちの息吹きを絶った一つの物質である。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里の街の下に見し、カタコンブなる鈍色の、人骨などはよそのこと、あの絵に描いた白い人。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
