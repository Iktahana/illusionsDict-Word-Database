    "definitions": [
      {
        "index": 1,
        "gloss": "to tie up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長く垂れ下がったコードを壁に沿って絡げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古くなった雑誌を紐でしっかりと絡げてゴミに出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "髪が邪魔だったので、一つに絡げて作業を続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カーテンが床についていたので、クリップで絡げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "自分は行李を絡げる努力で、顔やら背中やらから汗がたくさん出た。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "行李一つ絡げるにさえ、彼は細紐をどう渡すべきものやら分らなかった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうすこし不明瞭なのでは「かえるやら山陰伝う四十から」の次に「むねをからげる」があり、「だだくさ」の次に「いただく」があり、「いさぎよき」の次に「よき社」がありするのも同様である。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫たちは、一本のロープを持って、ボートの下へ仰向けにもぐり込んだり、ボートの外側――そこはデッキ板一枚の幅しかなくて、海面まで一直線にサイドなのだ――に、今縛りつける、そのボートにつかまって綱をからげるために、サイドへ足を踏んばって、海の方へからだを傾けたりした。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな場合にも袴をとつた事のない氏は、その度に袴の裾をからげるのがうるさいからといつて、終にはその袴に態と綻びを拵へてその儘にしてゐたといふ事を聞いた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいつからとなく、尻からげする癖を持つやうになつた、尻をからげることはよろしい、尻をまくることはよろしくないが。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、ガルール等の仕事は、綱や鎖で一生懸命にその荷物を引からげることで、その合間には船員達の作業に手伝をさせられた。",
              "citation": {
                "source": "ラ・ベル・フィユ号の奇妙な航海",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　俊助は手ばしこく編上の紐をからげると外套を腕にかけたまま、無造作に角帽を片手に掴んで、初子の後からくぐり門の戸をくぐった。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に、小褄をからげるでもなく、そのまま奥庭のくらがりの、植込みの蔭につとより添って、母家の方をじっとみつめる。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「脛にあげて」も、裾をまくり上げて、上肢の陰し処に近くからげるのだ。",
              "citation": {
                "source": "小栗判官論の計画",
                "author": "「餓鬼阿弥蘇生譚」終篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな茶のべんけいの浴衣を着て、黒繻子の帯を平つたく四角に締め、すそを片方だけ高くからげるから白の蹴出しが出て、それが素足にかゝる。",
              "citation": {
                "source": "浴衣",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いる」「いますか……では、与の公が待っていますから、わたしはすぐ引っ返して――」　と手早く片裾からげるお藤へ、源十郎はにやりと笑いかけて、「左膳はこの若造を死身になってさがしているのだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにかからげるものはないかとあたりを見廻す。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分、神田まで一と飛びだ」　振りきって尻をからげる八五郎、この男は親分平次の女房のお静を、御神体のように崇拝して、その危難に赴くためには、何時でも自分の身体くらいは張り兼ねない気組を持っているのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "お先へ」　お銀は小褄をキリリとからげると、片手に行燈を提げたまま、器用に梯子を踏んで穴の底へ降りて行きます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よしツ、丁度眞晝だらう」　平次は尻をからげると、水のよく干いた田の中へ入つて行きました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "富士見の塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜へと見えてぢん／＼端折かな　　　　一茶「ぢん／＼端折」というのは裾の後の中央を取って、帯のところにからげるのをいうのである。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、支度をしろ」　裾をからげると、脛には脚絆が当っていた。",
              "citation": {
                "source": "銀河まつり",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリョーシャは法衣の裾をからげると、町のはだし小僧のような身軽さで、ひょいと籬を飛び越した。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "大竹をからげて青しもゝの花　　　　桐之　太い竹を縄か何かでからげる、その竹が真青な色をしている。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、法衣のすそを高くからげると、毛のふかい脛が剥き出されたので、子どもたちは、父のそうした姿をよろこんで、「お父さまが、お百姓になった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to tuck up (clothes, etc.)",
