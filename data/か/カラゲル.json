        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "水仕事をするため、着物の裾をたくし上げるように絡げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "農作業に入る前に、ズボンの裾が汚れないようにしっかりと絡げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "川遊びをする子供たちは、皆、服の裾を絡げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "雨の中を歩くので、泥跳ねを防ぐためにスカートの裾を絡げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
