        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「家主さんがうるさくてね。借り間の生活もなかなか気を使うよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は学生時代、神田の古いアパートの一室を借り間にして司法試験の勉強に励んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お邪魔します！ここが君の借り間かい？意外と片付いているじゃないか」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "幕が開くと、「ああ好いですわねえ」とその一人が云つた、「先代萩の序幕……あの舟はしつかり出来てますわねえ、かかりますでせうねえ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、あれには十年たっぷりかかりまして、と殊勝らしく伏眼でいったら、諸兄は、どんな顔をするだろう。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大隅さんのお嫁さんが見つかりました。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、どうやら無事に言い納めた時に、三十歳を少し越えたくらいの美しい人があらわれ、しとやかに一礼して、「はじめてお目にかかります。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのふは佐藤先生へ、「ハネ起きて、先生わかりました！",
              "citation": {
                "source": "先生三人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍宮といふのは昔から、歌に詠まれ、また神仙譚として傳へられてゐますが、あれはこの世には無いもの、ね、わかりますか？",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな奇妙な風流は、私のやうな田舍者にはわかりませんねえ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にもよくわかりませんが、その貝の中に何かはひつてゐるのぢやないんですか？",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "取組を、四、五番見ましたが、あまり、わかりませんでした。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいことか、惡いことか、私には、わかりません。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、やはり、はつきりは、わかりません。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "トラックの上にかたまって乗っている労働者達が異国人の私達に笑いかけながら手を振って通り過ぎる情景などに幾度接したかわかりませんでした。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と私は主人の居る方へ敷島でも採りに行こうかと立ちかかりました。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜花が、しっきりなしにそれらの上へ散りかかります。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "キラキラツと黄金のぶちがひかりました。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうよだかは落ちているのか、のぼっているのか、さかさになっているのか、上を向いているのかも、わかりませんでした。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いま誰もゐないでわかりません。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもたしかに流れてゐたことは、二人の手首の、水にひたったとこが、少し水銀いろに浮いたやうに見え、その手首にぶっつかってできた波は、うつくしい燐光をあげて、ちらちらと燃えるやうに見えたのでもわかりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だかわかりません。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何だかわかりません。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてきまりが悪いのでカムパネルラと二人、また窓の外をながめてゐましたが、その鳥捕りの時々大したもんだといふやうにちらちらこっちを見てゐるのがぼんやりわかりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもう四粒ばかりぽろぽろっところがって来たと思うとあとは器械ばかりまるで今までとちがった楽なような音をたてながらまわりつづけました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこの崖で見てもわかります。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "elongatedpot-hole〔ここがどうしてこう掘れるかわかりますか。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、九月の末のある日曜でしたが、朝早く私が慶次郎をさそっていつものように野原の入口にかかりましたら、一本の白い立札がみちばたの栗の木の前に出ていました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつものようにたくさん見附かりましたから私はいつか長官のことも忘れてしきりにとっておりました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあちこちの川の岸や崖の脚には、きっとこの泥岩が顔を出しているのでもわかりましたし、また所々で掘り抜き井戸を穿ったりしますと、じきこの泥岩｜層にぶっつかるのでもしれました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
