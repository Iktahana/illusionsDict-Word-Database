[
  {
    "uuid": "2aa13cac-2436-5a44-8981-635b55801b8d",
    "entry": "乾酪",
    "reading": {
      "primary": "かんらく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
