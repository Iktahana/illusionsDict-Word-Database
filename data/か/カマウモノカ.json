        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「そんなに雨が降っているのに傘も持たずに行くの？」「構うものか、走ればすぐさ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "周囲が何を言おうと構うものか。俺は自分の信じる道を突き進むだけだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今からじゃ終電に間に合わないよ」「構うものか。歩いて帰るまでだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一世一代の勝負だ。全財産を失ったところで構うものか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "淫売屋などへ泊れるものか、堅いという花月へ行こう」「荷物はどうする」「荷物なんか構うものか。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "晃　流が細ったって構うものか。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "村越　お互の中にさえ何事もなければ、円髷も島田も構うものか。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "御亭主は留守だが、明放しよ、……構うものか。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものを言う清い、張のある目を上から見込んで、構うものか、行きがけだ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "構うものかね、遠慮も何も要るものじゃない。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな、そんな児を構うものか。",
              "citation": {
                "source": "女客",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死んでも構うものか」　お葉は覚悟を極めた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きてる中はどうかこうか食わずにゃあいねえものだ、構うものかイ。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、何の、死んだって、売られたって、観世物になったって、どうしたって構うものかね。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょいとでもお前さんに甘えさしてもらいさえすりゃ、あとはどうなったって、構うものか。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "構うものかね、なに構やあしない。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そりやア」と、落ち付いて、「お前がまだ世間に對する浮氣ごころがあるからで――世間のものが何て云つたツて構うものか、ね。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘を汚すことになるのを受け入れるくらいなら、人生そのものを投げ出したとて構うものかと。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「その象結構だ、構うものか。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人でも何でも構うものか。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「構うものか」そう思いながら葉子は事務長の目使いにも無頓着に、快活な足どりでいそいそと田川夫妻のほうに近づいて行った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "えゝ、いい構うものか、どうせ鼻をあかさせるならのっけからあかさせてやろう、そう思って葉子はそのままの姿で古藤を待ち構えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村……木村からもしぼり上げろ、構うものかい。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、どう思われたって構うものか。",
              "citation": {
                "source": "無名作家の日記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「湖の水はいくら濁ったって構うものか。",
              "citation": {
                "source": "ルルとミミ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なあに構うものか。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "）だれに聞えたって構うものか。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」構うものかと思い返えした。",
              "citation": {
                "source": "奥さんの家出",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "性が良くっても悪くっても構うものか」　半七は笑いながら一朱銀を受け取って、今更のように手の上で眺めた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、構うものか、こんな稲荷……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三河万歳",
                "note": "青空文庫"
              }
            },
            {
              "text": "構うものかと薩摩下駄を引掛けて全速力で四谷坂町まで馳けつける。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑稽だって構うものか。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "母に自分を生ませた男が、最も卑劣な侵略者なら構うものか、そうあらせろ、自分が、母と自分の血を浄めて見せるぞ。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かまうものかとも思った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
