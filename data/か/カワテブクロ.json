        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "冬のツーリングには、防寒性の高い革手袋が欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この革手袋、使い込むほど手に馴染んできて、すごく快適なんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わあ、その革手袋、おしゃれだね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "庭仕事用に、丈夫な革手袋を探している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それから古い革手袋や、昔はやつたお高祖づきんの布つ片にしつかりくゝつて。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな太郎の為に…………太郎の美くしいお嫁さんに着物を買ふため麻のハンカチ古い革手袋、昔はやつたお高祖づきんの布つ片へ、そつと貯めて置かうとするお金なんです。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人のボオイが部屋を去ると、私はふと同室の寝台に乱雑に投げ出された女物の革手袋と粋な持物の下の花模様の部屋靴が私の目にとまるのであった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は紺色の長いマントをひつかけ、純白の革手袋をはめてゐた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は紺色の長いマントをひっかけ、純白の革手袋をはめていた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが昨日この部屋に入ったとき、つまり呼び出されたときでございますが、初めに目に入ってきたのが椅子に置かれたギルクリストさまの革手袋で。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは、また、皆、鎮西八郎為朝が、はめていただろうと思われるような、弓の手袋に似た革手袋の中で、その手を泳がせている。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "のっぽな露西亜種の向日葵が、野球用の革手袋を思わせるような大きな盤の上に、高々と大粒な実を盛り上げて、秋風に吹かれているのは哀れが深い。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るとその中には、小指の太さに束ねた長さ八｜寸ばかりの髢が一房と、よごれた女の革手袋がかたしと、セルロイドの櫛が一枚あった。",
              "citation": {
                "source": "謎の咬傷",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、そこには背のスラリと高い立派な毛皮の外套を着た素晴らしい美少女が立っていて、青白い顔の下半分を、革手袋を嵌めた手で隠しながら、オズオズとした眼つきで僕の方を見つめているのだった。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」「……燐寸をお使い遊ばせな」　と、彼女は鶯みたいな声を出してそういうと、つと右手をのばして、革手袋の中の四角な燐寸箱を僕の前に見せた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あーら……」と彼女は口のところへ、革手袋を嵌めた手を持っていったが、急に気づいて、僕の身体を押しのけた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　博士は、革手袋をはめた手で、下を指さした。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞を読みながら地下鉄へ降りてゆくのは、押出しは立派だが、とんと見当のつきかねる人物だ、革手袋、かうもり、歩度緩、さて何が何だか。",
              "citation": {
                "source": "銀座街頭",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "良子は男物の革手袋に手をのばした。",
              "citation": {
                "source": "一人ぼっちのプレゼント",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、その革手袋のしなやかな手ざわりが、精悍な男性の冷たく残酷な魅力を、彼女に空想させていたのだった。",
              "citation": {
                "source": "一人ぼっちのプレゼント",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い革手袋をはめた手を、丸万は自分であんまでもするみたいに揉んでいた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "めいっぱい　めかしこんでて、　かたてには　しろの　かわてぶくろ　ひとくみ、　もう　かたてには　ちいさな　おうぎ。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
