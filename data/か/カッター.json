        "examples": {
          "standard": [
            {
              "text": "大きな段ボール箱を開けるのに、このカッターが一番使いやすいんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ゴミに出す前に、カッターで紐をいくつか切っておこう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "工作で厚紙をきれいに切りたいときは、カッターナイフの出番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
