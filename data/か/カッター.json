    "definitions": [
      {
        "index": 1,
        "gloss": "cutter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "段ボール箱を開けるのに、切れ味のいいカッターを使った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "建設現場では、鉄筋を切断するために大型のカッターが使われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "漁師が海で使うカッターは、小型で機動力がある船だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ここン所坂野医院大繁昌だね」　坂野はにやりと木崎の顔を見ながら、ケースの中からヒロポンのアンプルを取り出し、アンプル・カッターを当てて廻すと、まるで千切り取るように二つに割った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り大騒ぎになりそうなので、怖くなった政府では、最近、突如囚人達をカッターに乗せてトケラウス島へ移して了った。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "徹夜の切り貼りのようなことはしょっちゅうで、果てはカッターを握ってフィルムの修正までやりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "写植文字をハサミやカッターで切りはなし、一つ一つの文字のボリューム（大きさや太さ）に合わせて、字間距離をこまめに詰めたり拡げたりして貼りなおす。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、伝馬にはデッキ、カッターにはエンジンということに振り当てられた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "カッターはそのあとでおろされた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伝馬は」といって、チーフメーツはカッターの上へ立って方々をながめたが、それは見えなかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "カッターは引き上げられた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが高速度鋼のカッターは、鋳物を、ナイフで大根でも削るように削る。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "この寒い冬の最中に上着も無く、カッター・シャツを着ただけであり、足には地下足袋を履いている僕を見ては誰だってそう思うだろう。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右の舷側に吊した四隻のカッター端舟はセイゼイ廿人も乗れる位のもので在ったろうか。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後になると、船団のラガーが貝床を離れて全部環礁の沖へ集まって来、二隻のカッターを出して綿密にワラ族の入江を偵察しはじめた。",
              "citation": {
                "source": "三界万霊塔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ズボンに、カッターシャツの上に、スェーターを着た若い男で、ざん切り風にバラリと刈りこんだ頭髮の下に、噛みつくような眼をしている。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って竹針といえども一本一回主義を厳守して、一回ごとに鋭利なカッターで切るべきである。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カッターを使うのよ」　と、おばさんはこたえた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カッターですか」「そうよ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「見せてください」　カウンターのむこうの端まで歩いていった彼女は、ベイグル・カッターを持ってぼくのまえまで戻って来た。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、カッターをかかげて見せてくれた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ナイフがいつもシャープでないといけないのよ」　もとの場所にベイグル・カッターを持っていきながら、彼女は言った。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "パドルも」「カッター・ナイフ」　トモが言った。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「トモ」「なあに」「ナナエによろしく」「伝えます」「ナナエが望んでいたとおりだから」「そうね」「はい、カッター・ナイフ」「そうだ、それが必要なんだ」　ハチミが差し出すカッター・ナイフを、トモは受け取った。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カッター・ナイフをトモはシートの下に置いた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "シートの下に手をのばし、カッター・ナイフをさぐり当てた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カッター・ナイフを逆手に持ったトモは、刃を左手首の内側に当てた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "トモはカッター・ナイフから手を離した。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カッター・ナイフは水に沈んですぐに見えなくなり、左腕を肘まで彼女は水につけた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
