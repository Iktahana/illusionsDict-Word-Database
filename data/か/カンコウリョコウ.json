        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "来月、イタリアへ観光旅行に行く計画を立てています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "添乗員付きの観光旅行なら、言葉の心配もなく安心して楽しめますね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "学生時代にバックパッカーとして、多くの国を観光旅行した経験がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わあ、この景色！写真で見たまんまだ！最高！」って、友達と観光旅行中に叫んじゃった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "役所勤めか単なる観光旅行ならいざ知らず、短期間の研究といふ任務を帯びた小生の日常は、繁雑な神経の浪費からなるべく解放されてゐなくてはならないのです。",
              "citation": {
                "source": "ある夫婦の歴史",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本への観光旅行のコマーシャルだ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本へいって旅館の布団で寝るという観光旅行のコマーシャルを聞いていて、ぼくは、もう何年もまえに読んだ一冊の本のことを思い出した。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の観光旅行なんだけど、ひとりで町を歩いてると、路線バスがとおるの。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
