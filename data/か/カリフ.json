        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "イスラム帝国の最盛期には、カリフは政治的・宗教的最高権威だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "中世の歴史書には、カリフの即位に関する記述が多く見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アッバース朝のカリフは、学術と文化の発展を積極的に支援した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カリフ制度の変遷は、イスラム世界の歴史を理解する上で重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "当時の土佐と熊本とでは、心理的には今の日本とカリフォルニアくらいのへだたりがあったのである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それの産地だといふカリフオルニヤが想像に上つて來る。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それの産地だというカリフォルニヤが想像に上って来る。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "せん子を小布施のところへ遣つてから、手廻りは何事も不如意で、代つてして呉れる内弟子のカリフオルニヤ生れの桑子はビジネスライクに過ぎて、気持にそぐはないところが多い。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "邦人移民排斥の法律を枉げてまでそうしたのは、カリフォルニヤを開拓した日本人の忍耐と努力を知っていたからであろうか。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから三年の後、スティヴンスンは、其の時カリフォルニアに帰っていたファニイの後を追うて、大西洋を渡った。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分カリフォルニアの或る町で――実際に私の経験したことだが…………ハッと気がつく。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファニイの後を追うてカリフォルニア迄渡って来、極度の貧困と極度の衰弱との中に、友人や肉親との交通も一切断たれたまま・桑港の貧民窟の下宿に呻吟していた時のことだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その頃まで北海道の砂金といったらカリフォルニヤの向う張る勢いで、しかも夕張川の上流の各支流の源泉附近は到る処、砂金ならざるなしという評判で、全国の成金病患者がワンワンと押しかけていたものだ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてすぐに、カリフさまの御殿へ行って、手紙と、セレンジブ王からいただいたみやげ物とを、さし上げました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こんなふうに、カリフさまは、手紙と、みやげ物を持って、大よろこびなさいました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ある日、友達を呼びあつめて、ごちそうをしています時、召使の一人が入って来て、「ただ今、カリフさまのお使がお見えになって、だんなさまにお目にかかりたい、とおっしゃいますが。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとお使は、「カリフさまが、お召しでございます。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "カリフさまのお使の船は、バクダッドを出立しました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、カリフさまのお手紙と、見事なおくり物とを、さし上げました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "バクダッドにつくと、私はすぐその足で、カリフさまの御殿へまいりました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "カリフさまは、私を見て、大へんおよろこびになりました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "カリフさまは、びっくりなさいました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、私の七へんめの航海の話を、すっかり、金の字で書きしるして、カリフさまのお宝物として、だいじにしまっておくようにと、家来にお言いつけになりました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから僕は波斯を通りメッカを見物し、それからちょっとではあったが、カァールトウムのカリファに、興味ある訪問をした。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃ちょうどカリフォルニアでは黄金熱が盛んで、この選民の街がちょうど通過点に当たっていたのだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "カリフォルニアの開拓者だったから、面白い話には事欠かなかった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "金銭の外を知らずと嘲らるる米国人すら、カリフォルニアの巨柏など抜群の注意して保存しおり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に戻ったわけではなく、カリフォルニアからかけてくれていると言います。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビル・トッテン、一九四一年カリフォルニア州ロングビーチ生まれ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "カリフォルニア州立大学卒業後、ロックウェル社でアポロ計画に携わった彼は、一九六七年、大型コンピューター用ソフトの受託開発を行なっていたＳＤＣ社に入社。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "たくさんの方言の生まれたＵＮＩＸの中で、本家のＡＴ＆ＴのシステムＶとカリフォルニア大学バークレー校で育ったＢＳＤは二大勢力となっていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてカリフォルニア大学バークレー校でＵＮＩＸのお守りに携わっていたビル・ジョイに頼み、このマシンにＵＮＩＸをのせる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
