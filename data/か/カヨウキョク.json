    "definitions": [
      {
        "index": 1,
        "gloss": "kayōkyoku",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔の歌謡曲には、心に染みるメロディーが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祖母は、昭和の歌謡曲をよく口ずさんでいた。「♪この歌、懐かしいわねぇ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "喫茶店から流れる歌謡曲が、懐かしい雰囲気を醸し出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "わたしの秘密というのはこの間｜歿くなった古典歌謡曲の名手のお艶との間の事情である。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは当時、世に行われ出した蓄音器を表現舞台とする流行歌謡曲に眼をつけた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、エレクトロラの蓋を払って、コンチタ・スペルビアのスペイン歌謡曲をかけると、自分も小声で共に和しながら、酒場の中を、一、二度行きつもどりつした。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "柾生のすがたからして、歌謡曲ファンではない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォークソングとか」　これは予想外の答だったが、すくなくとも歌謡曲ではない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、歌謡曲ファンではないらしいので、慶一は安心した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ステレオからは、ＡＭ放送の歌謡曲が聴こえてくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この曲なら、いまチャートインしている「南北戦争時代の歌謡曲」が、たばになっても、片手でなぎ倒せる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで、ロックンロール・ファンのリスナーが、この曲をナンバーワンに押しあげるのに全精力を使い果たし、歌謡曲派の躍進を許してしまったように見える。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一は、歌謡曲みたいだからとかって、かけたがらないしよ」　と、高志が慶一を見あげる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かの歌謡曲を澄んだ丸味のある声で唱っていたりして、腹痛の柔らいでいる時には、何か思い出している様子も見せた。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "のち、歌謡曲の作詞を手がけ、やがてレコード会社の専属作詞家になり、800余りの歌謡曲の歌詞を作った。",
              "citation": {
                "source": "風狂私語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、この一篇で、私は独逸歌謡曲特有の、あの親しみ深い低音に触れ得たことと思う。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其間に古来のと今様のと、民謡に唐楽風の節をつけた、当時の歌謡曲の様なものが謡はれた。",
              "citation": {
                "source": "神楽記",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、西洋楽器を使つて、現在の歌謡曲みたいなものもやれないことになる。",
              "citation": {
                "source": "“現代風俗”に就いて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌謡曲なども同様で、今日は略々画一的な歌謡曲が出来て居ります。",
              "citation": {
                "source": "観光事業と文化問題",
                "author": "――日本観光連盟第六回総会に於ける講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕が下りると、幕をかきわけて、天地陰陽とりまぜての歌謡曲。",
              "citation": {
                "source": "退歩主義者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の行った日は、桜まつり歌謡曲の日。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちじゃ一生懸命｜粒よりのオペレッタや、夢幻劇や、すばらしい歌謡曲の名人を出してやるんだが、それが果してあの手合いの求めるものでしょうか？",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "その踊りは、歌謡曲に取材したもので、すなわち、君去りぬ。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めて抒情的なアメリカの歌謡曲である。",
              "citation": {
                "source": "老残",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛行するいわゆる歌謡曲は、現在の芸術的価値は低くとも常に大衆とともに進むから、無数の実験を重ねるうちに、この歌曲の形式問題に相当役立つかも知れない。",
              "citation": {
                "source": "歌詞とその曲",
                "author": "信時潔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ロバート・フランツ歌謡曲集」はエルンスト・ヴォルフ（バリトン）の独唱で彼の代表作十六曲をまとめたもの、フランツの唯一のレコードと言ってよい（コロムビアＪ八六六〇―二）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌ではビクターの「フランス歌謡曲集」にベルナックが一つ二つ歌っている。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」この年に「はるかな恋びとに」捧げる An die ferne Geliebte 六つの歌謡曲（作品第九十八）が作られたが、これらの歌は実に感動的なまた実に深みのある性格を持っている。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはちょっと変わってて、日本の戦後十年間にヒットした歌謡曲から、いい曲を選んで十二曲。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
