        "examples": {
          "standard": [
            {
              "text": "今度のアルバムは、海外の歌謡曲（ポップス）をカバーした楽曲も収録されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ラジオから流れてきたのは、耳馴染みのある洋楽の歌謡曲だった。「あ、この曲知ってる！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、様々な国の歌謡曲を研究している音楽家だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
