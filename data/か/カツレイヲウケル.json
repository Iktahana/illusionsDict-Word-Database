        "examples": {
          "standard": [
            {
              "text": "彼は一族の伝統的な教えに従い、決まった年齢に達した際に厳かな雰囲気の中で割礼を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "移住先のコミュニティに馴染むため、自らの意思で割礼を受けることを選択した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古代エジプトの壁画には、若者たちが儀式として割礼を受ける様子が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これに対し、否、割礼を受けることは必要な条件ではない。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち割礼を受けることによって、ユダヤ人たる身分を取得するものとせられました。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって外国人がユダヤ教徒となるため、すなわちユダヤ教に改宗してシナゴグに属する者となるためには、やはり割礼を受けることが必要とせられたのです。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
