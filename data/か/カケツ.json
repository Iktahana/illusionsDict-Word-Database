[
  {
    "uuid": "1d0fc869-ebc5-587e-86e5-86779570b2b7",
    "entry": "仮決",
    "reading": {
      "primary": "かけつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
