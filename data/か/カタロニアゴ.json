        "examples": {
          "standard": [
            {
              "text": "バルセロナでは、スペイン語だけでなくカタロニア語も広く話されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は留学中にカタロニア語を習得し、現地の人々と交流を深めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カタロニア語の響きは、スペイン語とはまた違った魅力がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "第四番と第百四十番のカンタータは、全曲近いものがビクターに入っているが、それは残念なことに演奏があまり上手でなく、その上カタロニア語で歌われていることや、吹込みの甚だしく古いことが、甚だしい物足りなさを感じさせるだろう。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビクターには先に書いたカタロニア語のカンタータのほかに、シューマン‐ハインクの「わが心は歌い喜ぶ」（第六八番）（七三八八）、ラシャンスカの「甘き死よ来れ」（七〇八五）などがある。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
