        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は、長年のトレーニングで引き締まった体つきをしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その女優は、しなやかな体つきが魅力的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の成長とともに、体つきもがっしりしてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "身体つき容貌まで何やら山の姿、峯の俤に似通って見えた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「豚群」とか「二銭銅貨」などがその身体つきによく似合って居る。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "堯はなにか露悪的な気持にじりじり迫られるのを感じながら、嫌悪に堪えたその犬の身体つきを終わるまで見ていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると遠くでわからなかったその人の身体つきや表情が見えて、その人がいまどんなことを考えているかどんな感情に支配されているかというようなことまでが眼鏡のなかへは入って来るでしょう。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "強く引くのかと思うと、身体つきだけ強そうにして軽く引っ張る。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その故か、見ていると不思議なくらい信子の身体つきが髣髴とした。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先方では私が叔母の家の者であり、学校の先生ということで遇うたびに礼をして行き過ぎるのでございます、田舎の娘に似わない色の白い、眼のはっきりとした女で、身体つきよくおさよに似てすらりとしていました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の事は云われないが、連の男も、身体つきから様子、言語、肩の瘠せた処、色沢の悪いのなど、第一、屋財、家財、身上ありたけを詰込んだ、と自ら称える古革鞄の、象を胴切りにしたような格外の大さで、しかもぼやけた工合が、どう見ても神経衰弱というのに違いない。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の身体つきは少女のようにきゃしゃで、首筋は垢でよごれているが、垢の下の皮膚は少女のように白く、何か哀れな脆さが痛々しかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そう云われてみれば成る程ひどく剽悍そうな体つきをしている、その見知らぬ男の顔をまじまじと眺めたのであった。",
              "citation": {
                "source": "薔薇の女",
                "author": "渡邊温",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は小柄の精悍な体つきで太い金鎖など帯に絡ませ、色の黒い顔に、陰険そうな目が光っており、銀子は桂庵の家で初めて見た時から、受けた印象はよくなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も半円祠堂のまんなかの腰掛には崖邸の夫人｜真佐子が豊かな身体つきを聳かして、日光を胸で受止めていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は三十前なのに大分老い晒した人のような身体つきや動作になっていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女はまるで相手に関はぬ態度で、しかし、身体つきをちよつとかしげた顔に生れつき自然に持つ媚態とでもいつた和みを示し、ふくよかに答へた。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婢の身体つきは、だいぶ老齢の女になつて、横顔の顎の辺に二三本、褐色の竪筋が目立つて来た。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村は少し凹まされたかども有るが、この人は、「肉の多きや刃その骨に及ばず」という身体つきの徳を持っている、これもなかなかの功を経ているものなので、若崎の言葉の中心にはかまわずに、やはり先輩ぶりの態度を崩さず、「それで家へ帰って不機嫌だったというのなら、君はまだ若過ぎるよ。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と甘えるような身体つき、座蒲団にぐったりして、横合から覗いて云う。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体つきにも顔つきにも、情が滴ると言った状じゃ。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち、一人の女の眼が、孔雀石の粉を薄くつけた顔が、ほっそりした身体つきが、彼に馴染のしぐさと共に懐かしい体臭まで伴って眼前に現れて来た。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱々しそうな身体つきと顔立をした少女が、やさしい表情をしながら、変な日本語を使うのが、彼に妙な気持をさせた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふっさりとした銀杏返が耳許へばらりと乱れて、道具は少し大きゅうがすが、背がすらりとしているから、その眉毛の濃いのも、よく釣合って、抜けるほど色が白い、ちと大柄ではありますが、いかにも体つきの嫋娜な婦で、（今晩は。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変らず男の力は四角い両肩に集り、それから下は一本花の茎のように憔けた棒立ちの身体つきでいますが、そのまゝ成育して頑張りの利く青年に見えて来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄ちゃんは須田町の近くの魚屋の伜で十九歳、浅黒い顔に角刈りが似合い、痩せぎすの体つきもどこかいなせであった。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいっの体つきは娘じゃねえ」　と言って、この時ばかりは女房に負けぬ男だった。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "体つき、身のこなしなど、いやらしく男の心をそそるようで眼つきも据っていて、気が進まなかったが、レッテル（顔）が良いので雇い入れた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女のような体つきで、顔も色白くこぢんまり整っていたから、女教師たちがいきなり抱きしめに来た。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔つきや体つきから見れば、まだ三十そこそこの女性だというのに、頭には早くも白いものがまじり、憔悴が顔から見てとれる。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "年を重ねるにつれて、ルーシィの背は伸び、体つきもしっかりしてきた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "お篠さんが紋附の長い裾をひきずって、そのお料理のお膳を捧げて部屋へはいって来て、（すらりとしたからだつきで、細面の古風な美人型のひとであった。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このインド娘は、なにかしら空気のように軽やかでしたが、それでいて、ぴちぴちとした、ゆたかなからだつきをしていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
