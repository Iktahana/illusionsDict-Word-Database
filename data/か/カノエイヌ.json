        "examples": {
          "standard": [
            {
              "text": "彼の生まれた年は庚戌の年で、粘り強さと誠実さが特徴だそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "次の庚戌の年は2030年だから、その頃には社会が大きく変わっているかもしれないね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庚戌の年に建てられたこの建物は、歴史的建造物として保存されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "四十三年（庚戌）　一九一〇○四月、中村吉蔵監督のもとに、東京座にて新社会劇団第一回公演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日、庚戌、将軍家御疱瘡、頗る心神を悩ましめ給ふ、之に依つて近国の御家人等群参す。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "予（蒲松齢）は庚戌の歳、南に遊んで泝州に往き、雨にへだてられて旅舎に休んでいたが、そこに劉生子敬という者がある。",
              "citation": {
                "source": "蓮香",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉永｜庚戌、七月、山村菱秋書という落款で、半七先生に贈ると書いてあるのも何だかおかしいようにも思われた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "庚戌、正月、なお……このなおというのはだれの名だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ところで君は在京の耳鼻咽喉科の医者連中がやっている庚戌会って言うのを知っているかね。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十三年の庚戌の年に出来た会……ウン。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから庚戌会へも行けないかも知れない。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって毎月三日が庚戌会の期日じゃございません」「あ……そうだっけなあ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は庚戌会へお出でになりませんの」「ウン。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも午前十時頃しかいらっしゃいませんって申しましたら、きょうは風邪を引いて寝ちゃったから、庚戌会へは失敬するかも知れないって仰言るんですね。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこちらでも非常に恐縮して、折よく故郷から送って来た鶏卵素麺に「今度の庚戌会へは是非とも出席します」と言う意味の手紙を添えて、下六番町の白鷹先生宛に送り出したが、それは何処へ届いたやら、あるいは横浜の臼杵病院を一歩も出なかったかも知れないと思う。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間のお手紙に、今度の庚戌会で是非会うって、お約束なすったでしょう」「ウン。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の庚戌会は大会なんでしょう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の庚戌会は、ちょうど明治節だから久し振りの大会にするから東京市外の病院の方々も参加を申し込んで頂きたいって書いてありましたわ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして会えるんだい」「今夜の庚戌会は何処であるんでしょう」「やはり丸の内倶楽部さ」「今からそこへお出でになったらキット白鷹先生が来ていらっしゃると思うのよ」「馬鹿な。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "白鷹の奥さんの卒倒騒ぎを……」「信じているともさ……だからお見舞に行くんじゃないか」「お見舞に行くのを止して頂戴……そうして知らん顔して庚戌会へ出席して御覧なさいって言うのよ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかしいわ……」「そりゃあ庚戌会がその頃にあるからさ」「でも……やっぱりおかしいわ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "倶楽部の玄関で給仕に聞いてみると、「庚戌会は今晩でございます。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "庚戌会と言えば謹厳な学術の報告会、兼、茶話会みたようなものと思ったが、なかなかどうしてエライ景気だわい。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから私が裏切り的に庚戌会に出席した事を、電話か何かで探り知った彼女は、狼狽の余り、おなじ日に、おなじ種類の患者を二度も私にブツケルようなヘマな手段でもって、私と白鷹氏の会見を邪魔しようと試みたものであろう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の庚戌会に出席して斯界のチャキチャキの連中と交際し、連絡を付けるのは地方開業医の名誉であり、且、大きな得策でもあり得るのだから、その意味に於て優越な立場にいる白鷹氏は、キット俺が出席するのを見越して、アンナ風に性格をカムフラージしていろいろな悪戯をしておられるのかも知れない。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "庚戌会へお出でになりまして……？",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三世瑞仙直温の書した過去帖に、「釈寿慶信女、同（瑞仙）後妻、寛政二庚戌十月廿四日」と云つてあるのが是である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」庚戌の此遊は夏の初で、途上四月八日に某寺を訪うた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」五首の題は「嘉永三庚戌日光道中口占」である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」是に由つて観れば、榛軒庚戌の遊は正弘に随行したものと見える。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二百五十八　わたくしは此年庚戌の正宗院八十の賀に、清川安策の五古があつたと云つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは其生日を知らぬが、全安の伊沢氏を冒してゐた期間より推すに、庚戌三月よりは遅れなかつただらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
