        "examples": {
          "standard": [
            {
              "text": "彼女の描く絵はいつもカラフルで、見ているだけで元気になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "商店街にはカラフルな提灯が飾られ、祭りの雰囲気を盛り上げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちはカラフルなブロックを使って、思い思いの家を作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "食卓にはカラフルな野菜が並び、食欲をそそる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あのデザイナーの作品は、いつもカラフルで斬新だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ブース全体もカラフルに飾り付けられている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンドの背後には巨大なパネルスクリーンが備え付けられ、白黒の昔の恐怖映画にカラフルなオリジナルのアニメーションがちぐはぐに編集されているという実験映画じみたアバンギャルドなフィルムが上映されている。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
