        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "船のカーゴスペースに大量の救援物資が次々と積み込まれていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "急ぎの部品だったので、航空貨物便を利用して緊急のカーゴを海外へ送った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重いカーゴを運搬するため、トラックは積載量が増えるように特別に補強されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "……もう久しく……正月の初め頃から、この病院の特等室に寝起きしている、黒木繁という患者で、元来欧洲航路のカーゴボートの一等運転手であったのが肺尖を患った揚句、この病院の新聞広告を見て静養しに来たものだそうである。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちの一台は、二輪のカーゴ・カートを牽引していた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーゴ・スペースをのぞきこみ、「すこし荷物が積んであるわね」　と、安心したように言った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
