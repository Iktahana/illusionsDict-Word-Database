    "definitions": [
      {
        "index": 1,
        "gloss": "fortune-telling based on the physiognomy of a house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「新築を建てる前に、念のため家相見に間取りを見てもらったんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あそこの家相見、当たるって評判だけど、鑑定料が結構高いんだよね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「古くからの家相見の教えに従って、鬼門にあたる北東には窓を作らないことにした。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「家相見の先生に『この土地は水はけが悪い』と指摘されて、契約を白紙に戻したよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "試みに見よ、世間の愚民、人の言を信じ、人の書を信じ、小説を信じ、風聞を信じ、神仏を信じ、卜筮を信じ、父母の大病に按摩の説を信じて草根木皮を用い、娘の縁談に家相見の指図を信じて良夫を失い、熱病に医師を招かずして念仏を申すは阿弥陀如来を信ずるがためなり。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "太閤様、権現様、信玄公、謙信公と同格の家柄だというはらがあるから、この城の家相を見てからが――以前にもちょっと出たことがあるが、これが七兵衛は一種の家相見であります――全く立派な貫禄で、どこへ出してもヒケは取らねえ、奥州の青葉城、うしろに青葉山を控えて、前は広瀬川がこの通り天然の塹壕をなしている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
