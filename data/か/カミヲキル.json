        "examples": {
          "standard": [
            {
              "text": "「お母さん、もうちょっと短く髪を切るね。動いちゃダメだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は手際よく顧客の髪を切る間、ずっと軽快なトークを続けていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔は父親がバリカンを持って、兄弟全員の髪を切るのが我が家の恒例行事だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "美容師見習いの彼女は、初めてウィッグ以外の髪を切るチャンスに手が震えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
