[
  {
    "uuid": "b4817f40-0b7e-5f4a-a382-4a7d19dd250b",
    "entry": "会話",
    "reading": {
      "primary": "かいわ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "conversation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼との会話はいつも楽しくて、時間が経つのを忘れてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初対面の人とでも、天気の話から自然に会話が弾むことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女と久しぶりに会って、積もる話で一時間以上会話した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "喫茶店では、隣の席から楽しそうな会話が聞こえてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そうした夫婦の会話は女中や下僕にはもちろんのこと、子供たちにさえもよく解らなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『内のパパとママとは、だれにも解らない不思議な言葉でだれにも解らない神秘のことを話している』と、学校へ行ってる男の子が、自慢らしく仲間の子供に語ったほど、それは奇妙な別世界の会話であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（子供と会話する時には、ヘルンは多く英語を用いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　元来人間の会話というものは、動物に比して甚だ不完全なものである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬や小鳥やの動物は、単に鼻を嗅ぎ合うとか、尾を振り合うとか、目をちょっと見合すとかいうだけで、相互の意志が完全に疎通するのに、人間は廻りくどく長たらしい会話をして、しかもなお容易に意志を通じ得ない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に眼を見合すだけで、一切の意味が了解される恋人同士の間には、普通の意味での言葉や会話は、全く必要がないのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてヘルン夫妻の奇妙な会話が、おそらくそういう種類のものであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての恋する人々は、自分等以外に全く人影のない離れ小島の無人島で、心行くまで二人だけの生活をし、二人だけの会話をしたいと願うのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の愛人同士は、周囲に多くの人々が住んでる環境に居て、しかも無人島に居る二人だけの会話を会話し、二人だけの生活を自由に享楽していたのであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "会話が、少しもわからず、さりとて、あの画面の隅にちょいちょい出没する文章を一々読みとる事も至難である。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "叙述でもなし、会話でもなし、描写でもなし、どうも不思議な、それでいてちゃんと独立している無気味な文体。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おめえは会話の語尾に、ねえ、とか、よ、とかをつけなければものを言えないのか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて我等の意味もない会話が生まれる。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも表面はさりげなく、普通に会話して居なければならないのである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の夜の露店の会話と、建築家の良心はもうない。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばまた「のろい週期」などという言葉も平気で使うが「長い週期」というよりも日常会話にはこの方が実感があるから自然にそんな用例が出来るのであろうと思われる。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新喜楽のまえの女将の生きていた時分に、この女将と彼女と、もう一人新橋のひさごあたりが一つ席に落合って、雑談でも始めると、この社会人の耳には典型的と思われる、機知と飛躍に富んだ会話が展開された。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園で子を遊ばしている子守達の会話がふと耳に入る。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の会話の断片を基にしたジャーナリストの評論や、またそれの下手な受売りにどれだけの信用が措けるかは疑問である。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人はなおしきりに金魚をながめて年相当な会話をやってるらしい。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、どうした拍子であったか、とにかくＮ君とのある日の会話の経過で、いつか一度議会傍聴に案内してもらうという約束が出来上がってしまった、その約束がいよいよ履行される日が思ったよりも実はあまりに早く来たのであった。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの話や会話は、耳の聴覚で聞くよりは、何かの或る柔らかい触覚で、手触りに意味を探るというような趣きだった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、アメリカ兵は、将校より、もっと達者なロシア語を使って、娘と家族の会話を彼の方から横取りした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "有声映画に取り入れられる音声も、単に話の筋道をはこぶための会話の使用にはたいてい先が見えている。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一晩睡らないで、頭のしんしん痛む豚に、又もや厭な会話を聞かせたのだ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この径ではそういった矮小な自然がなんとなく親しく――彼らが陰湿な会話をはじめるお伽噺のなかでのように、眺められた。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれらの会話をきくともなしに聞いていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもなんだか意味がよくわからぬが、秋の会話を盗み聞きして、そのまま書きとめて置いたものらしい。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり私が、気取って口を引きしめて、きょろきょろしていると異様のもので、老人たちにも、多少気づまりの思いを懐かせていたらしく、私がいなくなると、みんなその窮屈から解放されて、ほっとした様子で、会話がなだらかに進行している。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、娘、何とかいわんかい」　と催促されてもうそ寒そうに袖の中に手を入れ合して立っているだけだった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
