        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "未舗装の道路が、大雨の影響で部分的に陥没していたため、迂回を余儀なくされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地震のニュース映像で、地面が大きく陥没する様子に息をのんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い建物の基礎が脆くなり、一部の床が陥没し始めているのが見つかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "工事現場の近くで、アスファルトの路面が突然陥没して、通行止めになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あるいは一歩さかのぼって、裾野がいまだ生成しないうち、富士と、愛鷹と、箱根が、陥没地帯の大海原に、火山島のように煙を吐いて、浮かんでいたところを想像すれば、今日の豆南諸島の大島、利島、三宅島などが、鋪石のように大洋に置かれているのと似て、更に大規模なる山海の布置を構成するであろう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸壁が海の方へせり出して、その内側が陥没したので、そこに建て連ねた大倉庫の片側の柱が脚元を払われて傾いてしまっている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本書紀第十六巻に記録された、太子が鮪という男に与えた歌にも「ない」が現われており、またその二十九巻には天武天皇のみ代における土佐国大地震とそれに伴なう土地陥没の記録がある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルワンガル島は、今から八十年ばかり前の或日、突然、住民｜諸共海底に陥没して了った。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するにわが国は、こういうふうに外側地震帯及び日本海を走っている内側地震帯の幹線に地方的な小地震帯がたくさんの支線を結びつけているうえに、火山脈が網の目のようになっているから、その爆発に因る地震も非常に多く、従って土地の隆起陥没もまた多い。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天武天皇の時大地震があって、一夜にして近江の地が陥没して琵琶湖が出来ると共に、駿河に富士山が湧出したという伝説も、その間の消息を語るものである。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天武天皇十二年、俗に白鳳の地震と言っている地震に、土佐の田苑五十万｜頃が陥没して海となったという伝説のあるなども、それを裏書してあまりあるように思われる。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがいわゆる白鳳の地震で、土佐では黒田郡の一郡が陥没したと言い伝えられている。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また遠江の地が陥没して浜名湖が海と通じた。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめの地震は、豊後、薩摩の二箇国がひどく、豊後の府内の土地が陥没して海嘯が起った。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『列車は過って軌道を滑り出した後、数百ヤードの間｜軌道に沿うて流れておるランカシアー運河の中へ陥没してしまったものだろう』と。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "城の東門前にある石の亀に注意して、もしその眼が赤くなったときは、この城の陥没する時だと思いなさい」　老人の姿はどこへか失せてしまった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に、城は突然に陥没して一面の湖となった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、記者は『陥没して了ふ人』といふ題をつけて、そしてそれを雑誌に載せた。",
              "citation": {
                "source": "脱却の工夫",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の表面にあらはれてゐたあらゆるものが、一つ一つその前に陥没して了ふ。",
              "citation": {
                "source": "現代と旋廻軸",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある人は、『考へると、進歩なんて言へないかも知れないけれど、しかし一歩、一歩、ごくわづかだけれど、丁度陸地が目に見えないほど長い年月の間に陥没したり隆起したりするのと同じやうに矢張進歩して行つてゐるらしい。",
              "citation": {
                "source": "現代と旋廻軸",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間に取つて、または所謂現代に取つて、最も都合の好いことは、旋廻軸に於ける無限の陥没または忘却、または消失である。",
              "citation": {
                "source": "現代と旋廻軸",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の門下生は、急に目の前が陥没して、数千丈の谿谷ができたような気がした。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "野津第四軍は第一、第二軍の中間を覆ひ、大山総司令官の率ゐる第三軍と左右の翼をそろへて遼陽城を陥没し、新輸送をもつて圧し寄せた敵の線列兵を沙河の会戦で血祭りと砕いた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "面前の渦の一角が陥没した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、参木の前の陥没帯の波の端から芳秋蘭の顔が浮き上った。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "深く陥没んだ地勢に添うて折れ曲って行っている一筋の細い道が見える。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "他方の人は長い間若くていて急にドシンと陥没ちる」相川は今その言葉を思出して、原をじりじり年をとる方に、自分をドシンと陥没ちる方に考えて見て笑ったが、然し友達もああ変っていようとは思いがけなかった。",
              "citation": {
                "source": "並木",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥沼に陥没しかかった旅人のように、無暗矢鱈に藻掻き廻るその裸形の男三人、時に赤鬼があばれるように、時にまた海坊主がのたうち廻るような幻妖なポオズ――だが、それも極めて短い瞬間の印象でなければならぬ。",
              "citation": {
                "source": "電気風呂の怪死事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまで、濛気に遮られてずっと続いていると思われた密林が、ここで陥没地に切り折れている。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "陥没と、大湿林の天険がいかなる探検隊もよせつけぬといわれる、この大秘境の墻の端まできたのだ。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん、ひっ組んだまま陥没地に落ちたのだろうと、マヌエラは気もそぞろであったが、やがて紅い蔓花で花環を編んで、じぶんを救おうとして死んで故郷へもどったドドのために、接吻とともに底しれぬ墓へ投げこんだ。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
