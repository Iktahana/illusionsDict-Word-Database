    },
    "definitions": [
      {
        "index": 1,
        "gloss": "transitional",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この時期は社会にとって過渡的な段階であり、様々な変化が起こるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の意見はあくまで過渡的なもので、最終的な結論ではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいシステムへの移行は、現在過渡的な状態にある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学生時代は、社会人になるための過渡的な期間だと感じていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それはあくまで過渡的な方法であるが、然し我々画の観賞者はこれを期待してゐる、また画壇の実力時代の招来のためにもさうした方がよい。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれは、たとえそういう過渡的の形式のものがあるにはあっても、それが非常にまれであるということかも知れない（『宇宙の成立』一六七頁参照）。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "米内首相退職、組閣の大命は近衛公へ下つた、――日本は東洋は世界は急速度に転換しつゝある、旧制度は刻々に崩壊し新秩序が刻々成立しつゝある、――私達は切に切に時局の安定を希求する、それを実現するために強力政治を熱望する、――現状維持派よ、退却せよ、新人登場せよ、過渡的生活を止揚して新生活を建設しよう。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、今日の地球上の情勢は、二つの世界、プロレタリア・農民インターナショナルの結成と、ファッショ化した世界ブルジョアの過渡的協力との対立をますます激化させつつある。",
              "citation": {
                "source": "プロレタリア文学における国際的主題について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして、わが作家同盟が、その成員と活動の歴史性により過渡的制約性として、現在まだ少なからず小市民性的要素を包括している場合、その小市民性こそが困難な闘争に際して「左」右両翼への偏向を生む社会的要因である場合、われわれの警戒と努力とは、相互的な関係において常に結ばれている。",
              "citation": {
                "source": "前進のために",
                "author": "――決議によせて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、過渡的にもせよ、こうして憲法が変ったことは、それにつれて民法、刑法の変更をもたらし、これまでの日本の婦人がおかれていた全く従属的な地位は高められました。",
              "citation": {
                "source": "婦人大会にお集りの皆様へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤岩栄氏の存在はいかにも時代的であり過渡的で、この「しかし」の心理に深い連関をもっています。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェトではあらゆる生産が計画的生産であるから、管理者は、工場内の専門技師、工場委員会などを確りと統制し、過渡的なソヴェト社会の具体的困難を突切って、社会主義的な生産を高めて行かなければならない。",
              "citation": {
                "source": "「インガ」",
                "author": "――ソヴェト文学に現れた婦人の生活――",
                "note": "青空文庫"
              }
            },
            {
              "text": "農民作家の任務は農民的文学の過渡的な形式や手法を併用しつつ、都会のプロレタリアートと階級的な立場に於ける、相互の利害で協力しあう単一な「結合」への自発性を刺戟しなければならない。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主権在民の憲法に天皇という特種な一項目があって、新聞では大臣も天皇も公僕であるといいながら身分上、経済上そして政治上の特権は十分たもたれているという事実は、日本の民主的生活の道がどんなに過渡的なものであり、まだどっさりと封建の尾をひいたものであるかを物語っている。",
              "citation": {
                "source": "明瞭で誠実な情熱",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日響いている国民文学の声にある政治への文学の協力は、従って、それよりずっとずっと手前の、現在の日本をこめた世界の大多数の社会がおかれている矛盾、混乱、撞着の中でいわれているのであり、その実際条件は、当然のこととしてその呼び声にも様々の過渡的な制約を加えざるを得ない。",
              "citation": {
                "source": "平坦ならぬ道",
                "author": "――国民文学にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘーゲル哲學の前には、究極的な、絶對的な、神聖な何物も存し得ず、一切の物は自己の消滅性、過渡的性質を示さなければならない、これはヘーゲルの方法の必然的な歸結である、然るに彼自身がこの歸結を引き出さなかつたのは、彼が體系を作る必要に迫られたからである。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "或はまたブルジョワジーは現在を永遠化し、プロレタリアートはこれを過渡的として把握すると云はれる場合、そこに意味されてゐるのはもと客觀的な歴史的時間とは違つたもののことでなければならぬ。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら多くの場合に然るごとくわが研究会の場合においても、数の増加によって、一時的過渡的の現象ではあるとしても、全体としての会員意識の薄弱――著しく活動的なる少数と非活動的なる大多数との分立――を来したことを率直に認めなければならない。",
              "citation": {
                "source": "三田社会科学研究会",
                "author": "野呂栄太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで現在、農村に集団農場、箇人耕作をする中農、及富農と並存している過渡的情勢で、一番、野菜類穀物類を売り出す可能をもっているのはどの部分か。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした、過渡的な時代に於ける文学――小説の問題が如何なる方向に、何処に解決の途を見いだすべきであろうか。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "シーボルトについて蘭学医学を研めた三十九歳の生涯は二度獄に投ぜられ、後シーボルトの孫女を配偶者に迎へるまで、過渡的維新史の数奇な裏面史であつた。",
              "citation": {
                "source": "南予枇杷行",
                "author": "河東碧梧桐",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち文樂座は明かに純藝術的な演技であるが上村源之丞座は未だ全部が純藝術的になり切らない、宗教的意義の名殘をとどめてゐる過渡的な演技を含むと云ふべきである。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この文化の過渡的矛盾を認識しないならば、新劇運動は永遠に貧困を脱し得ないであらう。",
              "citation": {
                "source": "暫く黙せしめよ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "過渡的な名称であろう。",
              "citation": {
                "source": "演劇の様式――総論",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもまた憂ふべきわが国の現代的風景であつて、いづれは「文化」の向上によつてのみ救ひ得られる過渡的症状でありませう。",
              "citation": {
                "source": "文化とは",
                "author": "――力としての文化　第一話",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼もまた、実体という概念を、ことごとく排除し、それを意識の流れ、あるいは方向として解体して、流れの止まった状態を「実体的部分」と呼び、飛び去る状態を「過渡的部分」と呼んで、それより六年後でた友人ベルグソンの『物質と記憶』のテーマを、彼独得のやりかたで体系づけて展開したのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "公武合体＝尊王攘夷のたてまえに――この、本来過渡的な、折衷的な政治綱領を過渡的折衷的なそれとせず、純一むくにこれに終始せんとした珍しく生一本な政治家だった。",
              "citation": {
                "source": "新撰組",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがつて昌造、嘉平、幸民、富二らの日本活字創成の苦心も、開國の雪崩をうつやうな過渡的な容貌をおびてゐるのも自然であらう。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "昌造自身、かういふ當時の男女風習についてどんな見解をもつてゐたか、彼の今日殘る著書のうちにも示してゐないのでわからないが、假に何らか新らしい見解が彼にあつたとしても、さういふ風俗なり慣習上の問題は當時の過渡的な政治や科學よりむづかしいもので、明治の維新なくしては考へられぬことであらう。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に彼は「半ファシズム」、「前ファシズム」、「隠蔽されたファシズム」、等々の過渡的諸段階のカテゴリーを厳正に使用する試みを与えている。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、実際には、資本主義の枠の内でも過渡的に、部分的に計画性をもち得る面もあるわけなんだ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "過渡的な状況ですしあれこれと妥協点が求められているし、或線で彼我一致の利害もあり複雑ですから、決して前のめりはいけないけれども、昨今の事情にふさわしい範囲で相当いそがしくなります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、芝居に関しては、「いわゆる、新派は、過渡的なものでしょうな。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だから彼はナポレオン、シーザー、ミケランジェロ、ベートホーヴェン、ショパン……ショパン、そうだ、そう云えば今しがた林田から電話がかかつてね、もしや昨夜僕がショパンのレコードを耳にしたか、もし耳にしていたらどの辺まできこえたかとてきいて来たぜ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
