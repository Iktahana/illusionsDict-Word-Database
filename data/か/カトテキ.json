[
  {
    "uuid": "80ee3762-1926-5758-b2cf-92beba8812a5",
    "entry": "過渡的",
    "reading": {
      "primary": "かとてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
