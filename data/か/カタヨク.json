        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "不時着した飛行機は片翼を失い、かろうじて着陸した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの鳥は片翼を負傷しており、高く飛ぶことができないようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "組織にとって、片翼だけが突出していても全体としては機能しない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "三角形の砂地が向うに、蘆の葉が一靡き、鶴の片翼見るがごとく、小松も斑に似て十本ほど。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "波を渡るか、宙を行くか、白き鵞鳥の片翼、朝風に傾く帆かげや、白衣、水紅色、水浅葱、ちらちらと波に漏れて、夫人と廉平が彳める、岩山の根の巌に近く、忘るるばかりに漕ぐ蒼空。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも見得があるから、お前、松明をつけて行って見ろ、天狗の片翼を切って落とした、血みどろになった鳶の羽のようなものが落ちてたら、それだと思えなんて、血迷ってまさ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼空の半を蔽うた黒い鳥、片翼およそ一間余りもあろうと思う鷲が、旋風を起して輪になって、ばッと落して、そのうつぎの花に翼を触れたと見ると、あッという人の叫声。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「我だって天狗の片翼を斬って落すくらいなら、朝飯前だ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三里の山道、谷間の唯破家の屋根のみ、鷲の片翼折伏した状なのを見たばかり、人らしいものの影もなかつたのである。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　つゝと鷲が片翼を長く開いたやうに、壇をかけて列が整ふ。",
              "citation": {
                "source": "雪靈續記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "片翼になって大道に倒れた裸の浜猫を、ぼての魚屋が拾ってくれ、いまは三河島辺で、そのばさら屋の阿媽だ、と煮こごりの、とけ出したような、みじめな身の上話を茶の伽にしながら――よぼよぼの若旦那が――さすがは江戸前でちっともめげない。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　つつと鷲が片翼を長く開いたように、壇をかけて列が整う。",
              "citation": {
                "source": "雪霊続記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そのうちに、鳶の羽が、少しづゝ、石垣の間へ入る――聊かは引いて抜くが、少しづゝ、段々に、片翼が隠れたと思ふと、するりと呑まれて、片翼だけ、ばさ／＼ばさ、……煽つて煽つて、大もがきに藻掻いて堪へる。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の気を奪ふため、故らに引込まれ／＼、やがて忽ち其最後の片翼も、城の石垣につツと消えると、いままで呼吸を詰めた、群集が、阿も応も一斉に、わツと鳴つて声を揚げた。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い石の正面大階段を登ると、どっしりした鉄の扉の片翼が開いている。",
              "citation": {
                "source": "ドン・バス炭坑区の「労働宮」",
                "author": "――ソヴェト同盟の労働者はどんな文化設備をもっているか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "君がいないと矢張り僕は片翼が奪われたようで淋しい。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　ザビーネ　中庭の向こう側、家の片翼の一階に、二十歳の若い女が住んでいた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く聯携して、腹背からたえず信長を苦しめていた反信長派の一環、武田信玄が忽然と死去したことも、本願寺にとっては、片翼をもがれたようなものだったし、つづいて越前の朝倉、江州の浅井、伊勢の長嶋門派の殄滅をうけたことなど――満身｜創痍の傷手だったといっていい。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうわしの病気もあらかたよくなったで、心配して下さらんでもよい。",
              "citation": {
                "source": "キンショキショキ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから分りかたよく、というのはハイと云えるけれど、鼻でくくったようなというのは苦笑ね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
