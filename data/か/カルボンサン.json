        "examples": {
          "standard": [
            {
              "text": "酢酸やクエン酸のように、分子内にカルボキシ基を持つ化合物を総称してカルボン酸と呼ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このカルボン酸は水によく溶けるが、炭素鎖が長くなると次第に疎水性が強くなっていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "エステル化反応を進めるために、カルボン酸とアルコールに少量の硫酸を加えて加熱する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "他のアミノ酸から窒素を受け取る活性が最も強いアミノ酸は２種類のジカルボン酸であるグルタミン酸とアスパラギン酸である。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォン・オイラーたちおよびブラウンシュテンたちの２つの酵素反応メカニズムの双方でジカルボン酸が関与することは我々の同位体による結果にとって魅力ある説明を与えた。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "この存在は末端にあるアミノメチル基が直接またはプロリンやピロリドン・カルボン酸を経て酸化的に分解したことを指摘している。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "アミノジカルボン酸はアミノ基転移で役割を果たし、この過程に関連している対応するα−ケト酸は炭水化物のサイクルに参加する。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            }
          ]
        }
