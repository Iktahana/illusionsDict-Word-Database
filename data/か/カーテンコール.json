        "examples": {
          "standard": [
            {
              "text": "拍手が鳴り止まず、主演俳優は三度目のカーテンコールでようやく満面の笑みを見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「アンコール！」の叫びとともに、出演者全員がカーテンコールに応えてステージに再登場した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "感動のあまり立ち上がった観客たちは、スタンディングオベーションでカーテンコールを彩った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鳴り響く喝采の中、指揮者は何度もカーテンコールを繰り返し、楽団員一人ひとりを称えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "緞帳を又上げて、カーテンコール。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝでも、カーテンコールあり。",
              "citation": {
