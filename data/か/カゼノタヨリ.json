        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼が急に会社を辞めて海外へ渡ったという話を、風の便りに聞いたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "風の便りで、あの二人がとうとう結婚することになったと知った時は本当に驚きました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "恩師が体調を崩されていると風の便りに耳にして、急いで手紙をしたためた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "風の便りに聞けば、山の眷属の西国の諸山にも急にこどもの出生の数を増したという。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "卷頭、約百枚の「風の便り」は、文學界、新潮、文藝の三册子に、三分して發表したのを、このたび一つにまとめたものである。",
              "citation": {
                "source": "『風の便り』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもなお私は変らぬ愛情をあの人の上に捧げていたのですが、その中に風の便りに、あの人がどうやらアメリカで結婚したらしいと云う噂を聞きました。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "題を「風の便り」とした。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままで三度も、そのやうな胸のときめく風の便りを受けとつた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼にとつては、ただこの友人が、それはいい、おれもそんな風の便りが欲しいよ、と言つて呉れたら滿足だつたのである。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "批評を忘れやうとして、ことさらに、「風の便り」などといふロマンチツクな題材をえらんだ筈である。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まごまごして、彼もその批評の遊戲に誘ひこまれたなら、「風の便り」も、このあと書きつづけることができなくなる。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは葉書でも手紙でもない、まつたく異樣な風の便りにしよう。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは「風の便り」の文獻になり得ない。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな場合、もし彼が、つぎのやうな風の便りを受けとつたとしたなら、どうであらう。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（風の便りはここで終らぬ。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは私に、第二、第三の風の便りをも書かせると約束して置きながら、たつぷり葉書二枚ぶんのをかしな賀状の文句を書かせたきりで、私を死なせてしまふおつもりらしゆうございます。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままで三度も、そのような胸のときめく風の便りを受けとった。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼にとっては、ただこの友人が、それはいい、おれもそんな風の便りが欲しいよ、と言って呉れたら満足だったのである。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "批評を忘れようとして、ことさらに、「風の便り」などというロマンチックな題材をえらんだ筈である。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まごまごして、彼もその批評の遊戯に誘いこまれたなら、「風の便り」も、このあと書きつづけることができなくなる。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは葉書でも手紙でもない、まったく異様な風の便りにしよう。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは「風の便り」の文献になり得ない。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな場合、もし彼が、つぎのような風の便りを受けとったとしたなら、どうであろう。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（風の便りはここで終らぬ）　あなたは私をおだましなさいました。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは私に、第二、第三の風の便りをも書かせると約束して置きながら、たっぷり葉書二枚ぶんのおかしな賀状の文句を書かせたきりで、私を死なせてしまうおつもりらしゅうございます。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも、Ｋ大学を卒業してから東京の中学校の教師をしていたとかいう事を風の便りに聞いた。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん気が荒くなって、※さんのたぶさを掴んで打った、とかで、田地は取上げ、という評判でね、風の便りに聞くと、その養子は気が違ってしまったそうだよ。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "京からの時々の風の便りに貴い身分の人達の多くが亡くなられたと云う事を聞くことがあるのだが、それと同じ様に身分の賤しい人々も沢山に死んでいる事であろうと思われる。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "真偽は分らぬが、風の便りだ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると又そのうちに吾輩がタッタ一人で、淋しい絶影島の離れ家に引込んだ話を風の便りに聞いたので、これには何か仔細が在りそうだ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月の初に亜米利加に出帆して浦賀に着くまでと云うものは風の便りもない、郵便もなければ船の交通と云うものもない。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、九州で、女学校の体操教師をしていると、近頃風の便りにききました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
