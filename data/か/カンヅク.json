[
  {
    "uuid": "5834d161-ee57-5315-b3c0-a61eab18b566",
    "entry": "感づく",
    "reading": {
      "primary": "かんづく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
