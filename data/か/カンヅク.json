    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to sense",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "誰も何も言う前に、何かがおかしいと感づいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その犬は、近づいてくる嵐を感づいているようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は彼女の何気ない発言に隠された意味を感づいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「部屋に入ってきたとき、雰囲気に変化を感じた？」 「うん、私も感じたよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は彼の不快感を感づき、話題を変えようとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "松島は小菊の帰りが遅くなると、後口があるようなふうにして電話をかけ、そっと探りを入れてみたりすることもあり、少し怪しいと感づくと、帳場に居たたまらず、出先の家のまわりをうそうそ歩くことも珍しくなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな他愛もない術を正気の者なら直き感づくであろうに、と其処の杉の生垣の葉を片手の親指と人差指とでお民は暫くしゃりしゃり揉んで居た。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "速総別王はそれと感づくと、びっくりして、女鳥王といっしょにすばやく大和へ逃げ出しておしまいになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡は始めて来た家に長居するのは失礼だと来た時から思っていて、機会あるごとに座を立とうとするらしかったが、葉子はそういう岡の遠慮に感づけば感づくほど巧みにもすべての機会を岡に与えなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「莫迦にしているわ、奥さんなんて」「いくら冷血の博士だって、こう毎晩続けて奥さんが遅くっちゃ、きっと感づくよ」「もう感づいているわよオ、感づいちゃ悪い？",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ旅人が通っても、感づくことは出来なかったろう。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のことをも感づくことができずに、全く満足し切っているように鈍い、その癖どこかおどおどしている女の様子に、妄に気がいらいらして、顔の筋肉一つすら素直に働かないのであった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにうすうす感づくのは仕方がないが、何も知らせないほうがいいだろう。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「云つて見りやア、まア、神さまのお告げを感づく力、さ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれさえすべての方面に経済をすれば、子供は感づくまい。",
              "citation": {
                "source": "父",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ナニ、警察へちょっと……野郎感づくと遁がしちまうから……』　Ｆ楼の亭主はそういいながら電話室へ入ると、じきに電話を切って出て来たが、馴れ切った中にも、流石に異常な緊張を見せてそそくさと出ていった。",
              "citation": {
                "source": "ある遊郭での出来事",
                "author": "公娼存廃論者への参考資料としての実例",
                "note": "青空文庫"
              }
            },
            {
              "text": "畜生犬め、それと見るなり、初めはおれの脹脛に咬みつきをつたが、紙束をおれに取りあげられてしまつたと感づくと、いやに哀れつぽい金切聲をたてたり、おべつかを使つたりしはじめたけれど、おれは構はず、『へん、お氣の毒さま、あばよ！",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その暇にも権高な伯爵夫人の顔だちに、一点下品な気があるのを感づくだけの余裕があつた。",
              "citation": {
                "source": "舞踏会",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮令今は感づかなくても、あゝいう奴だから、いつ感づくか知れない。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、少し歩いてるうちに、どうも、変な気持だ……と感づくと同時に、頭に手をやると、帽子がのっかっている。",
              "citation": {
                "source": "話の屑籠",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが追々笑って済ませなくなるまでには、――この幽鬱な仮面に隠れている彼の煩悶に感づくまでには、まだおよそ二三箇月の時間が必要だったのです。",
              "citation": {
                "source": "開化の良人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、彼等は――少くとも妻は、僕のこう云う素振りに感づくと、僕が今まで彼等の関係を知らずにいて、その頃やっと気がついたものだから、嫉妬に駆られ出したとでも解釈してしまったらしい。",
              "citation": {
                "source": "開化の良人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュワルツコッフは、それを何時になったら感づくことやら。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "田鍋のやつは、勘は鈍いが、あれで相当｜克明でねばり強いから、そのうちにはきっと一件を感づくに違いない。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちがつかまえると感づくと、この船内をはしりまわって、なかなかつかまえられませんぜ」「ふーん、それはお前のいうとおりだな」　と、事務長はうらめしそうなかおになって、本船の方をふりかえった。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁信ならずとも、感づくことでありましょう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お角さんは、そのいわゆる、習わぬ経を繰返す門前の小僧の咽喉が意外にいいことを感づくと同時に、これをひとつものにしてみたら、どんなものであろうという気がむらむらと起りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの悲哀が神に仕える人を起こすように、この世にはまだ古をあらわす道が残っていると感づくのも、その彼であった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が子弟の教育に余生を送ろうとしているのも、一つはこの生涯の無才無能を感づくからであった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "グーセフが見ているのに感づくと、彼は、顔をねじ向けて言う。",
              "citation": {
                "source": "グーセフ",
                "author": "ГУСЕВ",
                "note": "青空文庫"
              }
            },
            {
              "text": "中二階の六疊を中にはさんで、梯子段が分れて二階が二間、八疊と十疊――ざつとこの間取りで、なかんづくその中二階の青すだれに、紫の總のしつとりした岐阜提灯が淺葱にすくのに、湯上りの浴衣がうつる。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "王女は王子がぐっすりねいったのをかんづくと、にっこり笑って、おき上りました。",
              "citation": {
                "source": "ぶくぶく長々火の目小僧",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たよりいろ／＼、なかんづく、緑平老からの手紙は涙がこぼれるほどうれしかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかんづく島薗順次郎博士は、その頃京大に居られて、私の製法によつて自ら強力「オリザニン」を製し、多數の脚氣患者に試驗し、また衝心性の重症患者にも試みて好成績を得、愈々脚氣の主原因はヴィタミンＢの缺乏であると斷定された。",
              "citation": {
                "source": "ヴィタミン研究の回顧",
                "author": "鈴木梅太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、一方ケエラにあるユウジェニイには、さういふ弟の巴里における生活上の變化、なかんづくその信仰の喪失が、彼女の日々のおほきな心痛になり出してゐた。",
              "citation": {
                "source": "モオリス・ド・ゲランと姉ユウジェニイ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
