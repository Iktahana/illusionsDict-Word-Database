        "examples": {
          "standard": [
            {
              "text": "「ごめん、来週の火水木は出張で不在にするから、返信は金曜以降になるかも。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あのカフェ、火水木しか開いてない隠れ家的なお店なんだけど、すごく雰囲気がいいんだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今学期の集中講義は火水木の3日間で終わるから、後半はゆっくりできるね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "と、彼等は、月火水木……と繰り方を換えた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週をわけて、土日月の朝まで林町にいるとしあと火水木金とアパートにいる、そう仮定して、アパートで暮す暮しかたの反動として林町でお客攻めもつらいし又所謂家庭的な雰囲気が恋しすぎるのもこまります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "偉大なる夢と月々火水木金々の努力、斯くして偉大なる現実は生れるのだ。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "火水木金土一　渭水は大河だが、水は浅く、流れは無数にわかれ、河原が多く、瀬は早い。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
