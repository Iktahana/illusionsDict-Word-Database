    "definitions": [
      {
        "index": 1,
        "gloss": "infusion of kudzu, cinnamon, etc., used as an antifebrile, for hangovers, etc.",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "風邪のひきはじめに、葛根湯を飲んですぐ寝た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昨日の飲みすぎで頭が痛いから、葛根湯を飲もうか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "病院に行く時間がないので、ドラッグストアで葛根湯を買ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔から、体の調子が悪いと母が葛根湯を勧めてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "まるで脈を一つ採ったことの無い、自分の風邪をひいたのには葛根湯を飲んで、それで治る医者なんだ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "風薬の葛根湯ぐらいならいいが、疵薬でも買やあしねえか」「ようがす。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "友の一人が少し風気で携行した葛根湯か何か煎じてゐたが、山上の寒さの身にしむ宵とて皆に分けて飲ませる光景、外の山には雪が積つてゐてその上を弦月が照らしてるといふわけである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃の風邪の薬は例の葛根湯で、少し熱が強ければ、セキコウを加える。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この薬たしかに効能あるやうに覚えければその後は風邪心地の折とてもアンチフェブリンよりは葛根湯妙振出しなぞあがなひて煎じる事となしぬ。",
              "citation": {
                "source": "矢はずぐさ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから養子が死んでそのまた養子が跡を続いだら葛根湯がアンチピリンに化けるかも知れない。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩飯も拔きまして、葛根湯を二杯も呑んで、一寢入りとすると、曉方御店から小僧が飛んで來ました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "凧の詭計",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の小言を葛根湯と間違えてやがる」「でもね、親分。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なアに、三輪の親分の顔が見てえという話で――」「止さねえか、馬鹿野郎」「へッ、これで葛根湯が四服目だ」　手の付けようがありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "順序を立てて話して見るがいゝ」「昨夜お勢は戌刻（八時）過ぎまで無事だつたさうですよ」「誰が見たんだ」「お秀は客の歸る一寸前、少しばかりの隙を見付けて、お萬に葛根湯を煎じさせて、四疊半へ持つて來させて飮ませたさうです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青い帶",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お勢は葛根湯を飮まなかつたらしいよ、吐月峰の中は藥で一杯だ」「へエ――？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青い帶",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何んだね、親分」「昨夜、お勢が葛根湯を飮むところを見たのか」　平次の問ひは不思議でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青い帶",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐しくこんがらかつてゐるから――ところで、昨夜お勢が葛根湯を飮むところを見なかつたのかい」　平次はまだ葛根湯に取憑かれてをります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青い帶",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛根湯を飮ませると言つて、藥を吐月峰に捨て、その後で殺されたやうに見せるために、いろ／＼の細工をした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青い帶",
                "note": "青空文庫"
              }
            },
            {
              "text": "順序を立てて話してみるがいい」「ゆうべお勢は戌刻（八時）過ぎまで無事だったそうですよ」「誰が見たんだ」「お秀は客の帰るちょっと前、少しばかりの隙を見付けて、お万に葛根湯を煎じさせて、四畳半へ持って来させて飲ませたそうです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "青い帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お勢は葛根湯を飲まなかったらしいよ、吐月峰の中は薬で一杯だ」「ヘエ――？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "青い帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだね、親分」「ゆうべ、お勢が葛根湯を飲むところを見たのか」　平次の問いは不思議でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "青い帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしくこんがらかっているから――ところで、ゆうべお勢が葛根湯を飲むところを見なかったのかい」　平次はまだ葛根湯に取憑かれております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "青い帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛根湯を飲ませると言って、薬を吐月峰に捨て、その後で殺されたように見せるために、いろいろの細工をした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "青い帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛根湯橘外男-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）瑞典｜：ルビの付く文字列の始まりを特定する記号（例）｜静かに！",
              "citation": {
                "source": "葛根湯",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本には昔から葛根湯といって、風邪にすぐ効く素晴らしい薬があるが」　と切り出したら、「日本の訳のわからん薬なんぞ、無暗に勧めないでくれ、ＮＯ！",
              "citation": {
                "source": "葛根湯",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は元来葛根湯という煎じ薬が大好きで屁のようなことでもすぐ女房に葛根湯を煎じてもらうのであったが、何もグスに葛根湯を勧めるのは親切気なぞあってのことではない。",
              "citation": {
                "source": "葛根湯",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくグスタフは葛根湯を飲んだ。",
              "citation": {
                "source": "葛根湯",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一そんなことがあろうとは思われぬが、もしや私のやった葛根湯の中に、間違って何かの毒でも混入していたのではなかろうかと、私も蒼くなった。",
              "citation": {
                "source": "葛根湯",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とこの粗忽しい医者めが聴診器を当てながら聞くから、「葛根湯です。",
              "citation": {
                "source": "葛根湯",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの煎じ薬の葛根湯です。",
              "citation": {
                "source": "葛根湯",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
