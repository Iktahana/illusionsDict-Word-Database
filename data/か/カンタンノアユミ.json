    "definitions": [
      {
        "index": 1,
        "gloss": "like the young man who tried to walk like the Kantan people, gave up, and forgot how to walk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "流行のスタイルばかりを追いかけて自分本来の良さを見失うのは、まさに邯鄲の歩みと言える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ライバル企業の経営手法を安易に模倣して失敗し、自社の強みまで忘れてしまうようでは、邯鄲の歩みを踏むようなものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "背伸びをして都会的な振る舞いを真似た結果、地元の言葉すらぎこちなくなってしまい、邯鄲の歩みの怖さを実感した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "基礎を疎かにしてプロの高度な技術だけを盗もうとするのは、邯鄲の歩みに陥る典型的なパターンだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それは邯鄲の歩みを学ばないうちに寿陵の歩みを忘れてしまひ、蛇行匍匐して帰郷したと云ふ「韓非子」中の青年だつた。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは邯鄲の歩みを学ばないうちに寿陵の歩みを忘れてしまい、蛇行匍匐して帰郷したと云う「韓非子」中の青年だった。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            }
          ]
        }
