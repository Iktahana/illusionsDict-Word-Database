    "definitions": [
      {
        "index": 1,
        "gloss": "left-hand opponent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "上家が欲しそうな牌をあえて絞って、相手のペースを乱す作戦に出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よっしゃ、上家から出た牌でロン！」と、彼は得意げに牌を倒した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "初心者の上家が予想外の打ち方をするので、こちらの戦略が狂いっぱなしだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "上家の捨て牌が偏っているのを見て、染め手を狙っているのではないかと警戒した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "蝶ちゃんのおとうさんは、うちのまわりの者から頼まれて、おやじのその商売の昇華を引卸すに相当骨を折ったものだ」　これ等がすでに清太郎の父の上に現れた池上家の人間の現実遊離の浮游性であった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "半月ほど経って再び嘉六が来て池上家の重立った人々の意見を代表して、あらためて池上とわたくしに向って相談を開始しました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一週間の後を期し、わたくしは一先ず母の家へ戻り、池上家から公然認められた花嫁候補として、いよ／＼清太郎との結婚の具体的な交渉に移ることに相談が纏まりました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉六の報告のあった翌日、池上家から公式に結婚解消の挨拶がありまして、二番番頭が揉手をしながら「この度は、何とも、はや」と悔みのようなことを言って絹一匹金一封を添えたものを置いて帰りました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は下町にある自宅が大家族でうるさいので、勉強の都合上家を出て、下宿から学校に通っているのだそうである。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居の方でも小坂部といえば、尾上家に取っては家の芸として知られている。",
              "citation": {
                "source": "小坂部伝説",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾上家でそれを家の芸としているのいうのは、かの尾上松緑から始まったのであるが、一体それはどういう狂言であるか判っていない。",
              "citation": {
                "source": "小坂部伝説",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お光さんは器量もよし気質も優しいし、家に田地もだいぶあるし、その上家と家との今までの関係もあることだから、そうしたら双方ともつごうがよいだろうと書いて、そのあとへ但し書がつけてある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして上家の捨て牌をとって来て自分の牌二枚と共に曝すわけだが、このとき上家の捨て牌をとらずして、既に河に前から捨てられてある牌をとって順子をつくる。",
              "citation": {
                "source": "麻雀インチキ物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば二四索を持っているとき上家が四索を捨てる。",
              "citation": {
                "source": "麻雀インチキ物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "上家をはじめ他の人達がよく注意して居れば勿論こんな馬鹿馬鹿しい胡魔化しにはかからないが、すこし戦が酣になって来ると、よくこれが行われる。",
              "citation": {
                "source": "麻雀インチキ物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "嶺上牌を一寸みたり、上家がすてない先の場牌を摸して、自分がとらないときには、例えばその七筒が誰のところへ入ったなどを覚える。",
              "citation": {
                "source": "麻雀インチキ物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもどうにか詫びがかなって、もとの尾上家に復籍して、明治二十四年の春から再び東京の舞台を踏むことになった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、お茶の水面白かった」こういったのは最上家の浪人。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「最上家の浪人｜金井半兵衛」　続いてもう一人の武士がなのった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はすべての不愉快な出来事を物語った後、これ以上家に置いたらば、どんな不幸が起るかも知れないから早速大英博物館へ寄附するつもりだと言った。",
              "citation": {
                "source": "怪談綺談",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣り寺を境に一段高くなった土手の上に三坪ほどな平地があって石段を二つ踏んで行き当りの真中にあるのが、御爺さんも御父さんも浩さんも同居して眠っている河上家代々之墓である。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はそれとも知らないから、しゃがんだまま熱心に河上家代々の墓を礼拝している。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう云うとおかしいが余は河上家の内情は相続人たる浩さんに劣らんくらい精しく知っている。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "河上家代々の墓を杖で敲いても、手で揺り動かしても浩さんはやはり塹壕の底に寝ているだろう。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿呆、ぐず、のろま、意久地なしは云ふに及ばず、気取り屋、おしやべり、臆病、卑怯、未練、ケチンボ、コセツキ屋、悧巧者、ひとりよがり、逆上家、やきもち屋、愚痴こぼし、お世辞屋、偽善者、偽悪者、影弁慶。",
              "citation": {
                "source": "サニンの態度",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "城内の家屋は皆井上家時代の重臣の第宅で、大手の左右に列っていた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂上家の某が家を脱して、浪人等を募集し、皇室を守護せむことを謀つた。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは此に堂上家の名を書せずに置く。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし蘭軒の語に分明に「移家」と云ひ、「構成湖上家」と云ふを見れば、どうも薬湯の家とは認め難い。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "△北朗来の翌日より井上家から毎日、御馳走をもつて来て下さる、（一二君のオツ母さんと云ふ人が実に料理の妙手で専門家正にはだし也）北朗は勿論、放哉大に悦に入りて毎日いただいたこと。",
              "citation": {
                "source": "北朗来庵",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴風俗伊達な刀の一本ざし、ある時には豐臣秀頼の追善にと、にはか雨にぬれる男女に傘百本を寄附したりしたといふが、柳里恭柳澤淇園が通つたとも、堂上家の浪人を男妾にしてゐたが、その男が義に違ふことをしたので放逐し、その後は男を近づけなかつたともいはれてゐる。",
              "citation": {
                "source": "凡愚姐御考",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "最上家が上杉謙信の枝城の村上に滅ぼされて、その家臣の滝川家も野に隠れているとき、徳川時代となった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川時代を通じて、つねに譜代の士族に圧迫されていた旧士族の最上家の臣たちは、明治になると再び勢力を盛り返し、進んで文明進化の急先鋒に立った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
