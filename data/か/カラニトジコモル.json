        "examples": {
          "standard": [
            {
              "text": "失恋のショックで、彼女はしばらく部屋に閉じこもってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「最近、全然顔を見せないけど、大丈夫かな？殻に閉じこもってるんじゃない？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は新しい環境に馴染めず、徐々に殻に閉じこもるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "親からの過干渉に耐えかねて、彼は自分の殻に閉じこもることを選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一女性が一族の誇りという殻に閉じこもるなんて信じられません。",
              "citation": {
