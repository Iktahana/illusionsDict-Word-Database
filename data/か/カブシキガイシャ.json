    "definitions": [
      {
        "index": 1,
        "gloss": "stock company",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は、長年の夢だった自分自身の株式会社を設立した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この株式会社は、地域経済の活性化に大きく貢献しているんですよ」と、地元住民が誇らしげに語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "株主総会では、役員報酬に関する重要な議決が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "あとで聞くとこれは箱根土地株式会社の作った道路で専用道路だからとの事であった。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三代目の横井何太郎が、Ｍ――鉱業株式会社へ鉱山を売りこみ、自身は、重役になって東京へ去っても、彼等は、ここから動くことができなかった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍ――鉱業株式会社のＯ鉱山にもストライキが勃発した。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも書物が何々株式会社の「商品」であるとすればもとより当然のことである。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相互信托株式会社も其一つである、二人は当初親しく往来して彼の事業の創始の際などは、白川はかなり立入つた相談にも与つたのである。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニュウヨウクのメリケン粉株式会社から贈られたのだ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "その兄さんというのが、何とか云う、朝鮮にも、満洲とか、台湾にも出店のある、大な株式会社に、才子で勤めているんです。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その日までに、あなたはフランス中部鉄器株式会社の営業支配人におなりになるでしょう。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてすみませんが、「最低俸給五百｜磅にて、フランス中部鉄器株式会社営業支配人として働くことに同意致し候」と、お書きになって下さい」　私は彼の云う通りにしました。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ところが、居住者の名前はそこの壁の下のほうに書いてありましたが、フランス中部鉄器株式会社なんて云うそんな名前はないのです。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人でアーサー・ハリー・ピナー氏に、そのフランス中部鉄器株式会社の仮事務所で会見することは、むしろ我々に興味のある経験だと云うことに」「しかしどうしたら会えるだろう？",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそこの床の上には、上衣やチョッキがぬぎすててあって、そしてドアの背後についている鉤金に、フランス中部鉄器株式会社の専務取締役が、自分の首の廻りに自分のズボンツリをまきつけてブラさがっていた。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日までに、君は仏・中英金物株式会社の営業部長になっていることだろう。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は、仏・中英金物株式会社の営業部長として、最低賃金五〇〇ポンドにて職務遂行することに、まったく同意するものである。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに君も賛成してくれるだろうが、アーサー・ハリー・ピナー氏と仏・中英金物株式会社の仮事務所で相まみえることは、僕ら両名にしてもそれなりに興味深い経験となろう。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "上着とベストが床に落ち、扉の後ろの鈎金から、首まわりに吊り帯を巻き付け、仏・中英金物株式会社社長はぶら下がっていた。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし一九九二年十月に、米ボイジャー社と日本のソフト制作者グループとのジョイントベンチャーによって、日本法人のボイジャージャパン（正式名称、株式会社ボイジャー）が設立されており、一九九三年三月のリリースをめどに日本語化の作業が進められている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩野さんと彼は後に、タイトルの制作子会社としてパイオニアから独立したレーザーディスク株式会社とボイジャー共同のプロジェクトを起こしました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーザーディスク株式会社に籍を置いているという、萩野正昭という人物との出会いも、記事がきっかけになりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞けばレーザーディスク株式会社の中にも、新しいメディアとしての可能性を探ろうとする考え方はあるとのこと。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当初、レーザーディスク株式会社との付き合い方は、仕事一本単位の請負でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためのソフトウエアを、レーザーディスク株式会社が開発することになったのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした発想で企画された〈コンピューター・エンコーディッド・ディスク〉の開発にあたって、技術の元締めとなるべく、祝田さんはレーザーディスク株式会社と嘱託契約を結びます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四六年五月、東京通信研究所は株式会社に組織変更して、東京通信工業を名乗る。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アスキーが同社の製品の販売にあたっていた時期を経て、日本法人としてマイクロソフト株式会社が設立されたのが一九八六年。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の父は、今迄多くの事業で失敗し、未だ余憤が消えてゐなかつた為か、忽ち形もなひ製薬株式会社の社長になつたり、東北銀行創立、専務取締役になつたりした。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本橋か銀座に何々株式会社と列んで白煉瓦の事務所を構える事が出来る。",
              "citation": {
                "source": "駆逐されんとする文人",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、京子が大手町で降り、今井商事株式会社のあるビルディングに入り、そのエレベーターで胸を躍らせながら吊り上げられていたとき、すぐそれと並んだもう一つのエレベーターで、村川が倭文子と会うために、胸を躍らせながら吊り下げられていたのを、夢にも知らなかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――岸野は雑穀、海産、肥料問屋、ホテル、××工場、精米株式会社を経営し、取引所会員、拓殖銀行其他の株主、商業会議所議員、市会議員をやっている。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
