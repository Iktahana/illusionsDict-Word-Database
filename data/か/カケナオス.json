        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "電話が繋がらなかったので、数分後に掛け直すことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「すみません、もう一度掛け直していただけますか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "担当者と話したかったのだが、席を外していたので、後で掛け直すように言われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "番号を間違えれば、改めて掛け直すから、それだけ忙しくなる。",
              "citation": {
                "source": "硝子を破る者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いなけりゃ、かけなおすだろ」「だって、呼出しがあって、どこにもいなかったら、たいへんよ」「そうか、そうか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は眼鏡をかけなおす。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで一つの川の橋をかけなおすだけでも、非常な巨額の経費を要することになる。",
              "citation": {
                "source": "亡び行く国土",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、ぼくのほうからかけなおすと言ったら、彼女は、「ＯＫ」　と、こたえた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "かけなおすと玲子が電話に出た。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
