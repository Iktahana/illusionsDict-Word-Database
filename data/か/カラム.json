        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "化学実験で、化合物の分離に充填カラムを用いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "蒸留装置のカラムの温度を上げることで、分離効率を高めることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このクロマトグラフィーカラムは、特定の不純物を選択的に除去するように設計されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい素材を使ったカラムの開発が進んでおり、高効率な分離が期待されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
