        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "部屋の仕切りとして、彼は唐紙を上手に活用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "朝日を浴びた唐紙には、美しい陰影が浮かび上がっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供が唐紙に穴を開けてしまい、親に叱られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
