    "definitions": [
      {
        "index": 1,
        "gloss": "thick printed paper (for covering sliding doors)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は古い日本家屋の唐紙の模様に、日本の伝統美を感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "職人が一枚一枚手作業で唐紙を貼り、部屋に落ち着いた雰囲気を演出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この部屋の唐紙は、繊細な植物の柄が描かれていて美しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それは子規氏の特有の原稿用紙（唐紙？",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規常用の唐紙に朱罫を劃した二十四字十八行詰の原稿紙いっぱいにかいたものである。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は枕元の火鉢の傍で縫いかけの子供の春着を膝へのせたまま、向うの唐紙の更紗模様をボンヤリ見詰めて何か考えていたが、思い出したように、針を動かし始める。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "発汗剤のききめか、漂うような満身の汗を、妻は乾いたタオルで拭うてくれた時、勝手の方から何も知らぬ子供がカタコトと唐紙をあけて半分顔を出してにこにこした。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いてみるとかなりひどいゆれ方で居間の唐紙がすっかり倒れ、猫が驚いて庭へ飛出したが、我家の人々は飛出さなかった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が去年来はじめた時ぶんはまだ小用の時は唐紙の外へ出てしたのだが。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐紙などに水がついたあとにできる「しみ」が、どうかすると不規則な花形模様に広がることがある。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "掃除は早いが畳がいたんだり障子｜唐紙へ穴をあけるのでは少なくも日本の女中の登用試験では落第であろう。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の八番の唐紙をすっとあけると中に二人。",
              "citation": {
                "source": "疲労",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "書齋の唐紙を開けると明るいランプの下に井田はソフォクレースを讀んで居た。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "間の唐紙をたて切る女中の後からちらとその客の様子を見て取つた。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "破れた唐紙の陰には、大黒頭巾を着た爺さんが、火鉢を抱えこんで、人形のように坐っている。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまだ新しい小説や脚本は出ていぬし、抒情詩では子規の俳句や、鉄幹の歌の生れぬ先であったから、誰でも唐紙に摺った花月新誌や白紙に摺った桂林一枝のような雑誌を読んで、槐南、夢香なんぞの香奩体の詩を最も気の利いた物だと思う位の事であった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "見えたのは紅唐紙で、それに「立春大吉」と書いてある。",
              "citation": {
                "source": "鼠坂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの裂けた紅唐紙の切れのぶら下っている下は、一面の粟稈だ。",
              "citation": {
                "source": "鼠坂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その癖蚊屋を弔つて三人の寝てゐる六畳との堺の唐紙は締めてある。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐紙を一重隔てて、隣の部屋に大の男の、しかも軍人が三人寝てゐるのが、さほど苦にもならないのである。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボロボロの唐紙半切に見事な筆跡で、薄墨の走り書きがしてあった。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一間二枚の襖は銀泥に武蔵野の唐紙。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "短冊形に切った朱｜唐紙の小片の一端から前歯で約数平方ミリメートルぐらいの面積の細片を噛み切り、それを舌の尖端に載っけたのを、右の拇指の爪の上端に近い部分に移し取っておいて、今度はその爪を書物のページの上に押しつけ、ちょうど蚤をつぶすような工合にこの微細な朱唐紙の切片を紙面に貼り付ける。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱唐紙は色が裏へ抜けていなかったから裏は赤くなかったのである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころでもすでに粗製のうその朱唐紙があって、そういうのは色素が唾液で溶かされて書物の紙をよごすので、子供心にもごまかしの不正商品に対して小さな憤懣を感じるということの入用をしたわけである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本物の朱唐紙だとちっともあとが残らない。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "信乃が腕をこまねいてうつむいている前に片手を畳につき、片袖をくわえている浜路の後ろに、影のように現われた幽霊の絵を見ていた時、自分の後ろの唐紙がするするとあいて、はいって来た人がある。",
              "citation": {
                "source": "竜舌蘭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと一つの部屋から隣の部屋へ行く時にも必ず間の唐紙にぶつかり、縁側を歩く時にも勇ましい足音を立てないでは歩かない人と、また気味の悪いほどに物音を立てない人とがある事を考えてみると、三毛と玉との場合にもおもな差別はやはり性の相違ばかりではなくて個性の差に帰せらるべきものかもしれない。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "通された二階はまだ荒壁のまゝで、唐紙もろくに入れてなかつた。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなくかれはズボンチョッキのこざっぱりしたふうで唐紙の外へすわった。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃ西田さんちょっといってくるから頼む」と糟谷は唐紙の外から声をかけてでてしまった。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっくろな灰の雲からかみなりを鳴らせ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これぞ、笑止というか、こっけいというか、それとも当然なことというか、あの先ほど右門が不審を打った、四本の新しいからかみふすまの一本でありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
