        "examples": {
          "standard": [
            {
              "text": "大統領首席補佐官（官房長官）は、大統領の最も側近として仕える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ホワイトハウスの官房長官は、大統領のスケジュールを厳密に管理する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「官房長官、大統領の午後の予定は変更ありませんか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
