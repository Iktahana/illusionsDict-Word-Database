        "examples": {
          "standard": [
            {
              "text": "霞石は、長石に似た鉱物だが、化学組成が異なりアルカリ性の火成岩に産する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地学の授業で、様々な鉱物標本の中に霞石を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域の火山岩には、珍しい霞石の結晶が含まれているそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また一方隕石中には、地上の火成岩中に頻出する鉱物、すなわち、石英、正長石、酸性斜長石、雲母、角閃石、白榴石、霞石を含んでいない。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
