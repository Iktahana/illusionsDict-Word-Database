        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "幻想的な川霧に包まれた橋の上を、始発電車がゆっくりと走り抜けていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "早朝の渓谷を訪れると、真っ白な川霧が水面を這うように漂っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わあ、川霧のせいで対岸が全く見えないね」と、彼女は目を細めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "冬の冷え込んだ朝、温泉街の川から立ち上る川霧が情緒ある風景を作り出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "まして川霧の下を筏の火が淡く燃えながら行く夜明方の空に、杜鵑が満川の詩思を叫んで去るという清絶爽絶の趣を賞することをやだ。",
              "citation": {
                "source": "夜の隅田川",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "道子が堤防の上に立ったときは、輝いていた西の空は白く濁って、西の川上から川霧と一緒に夕靄が迫って来た。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏摩后その故を問うと、某ヴィシュヌを念ずるに一心にして妻がいかにかの一儀を勤むるも顧みず「川霧に宇治の橋姫朝な／＼浮きてや空に物思ふ頃」ほかにいいのがあるんだろうと、九月一日の東京｜然と大焼けに焼けた妻が拙者を詛うて、別嬪でも醜婦でも、一切の物、わが夫に見られたらたちまち破れおわれと詛うた。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "川霧たちこめて、水聲高く聞ゆ。",
              "citation": {
                "source": "多摩川冒險記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「朝ぼらけ家路も見えず尋ねこし槙の尾山は霧こめてけり　心細いことです」　と言って、またもとの席に帰って、川霧をながめている薫は、優雅な姿として都人の中にも定評のある人なのであるから、まして山荘の人たちの目はどれほど驚かされたかもしれない。",
              "citation": {
                "source": "源氏物語",
                "author": "橋姫",
                "note": "青空文庫"
              }
            },
            {
              "text": "外をながめながら後ろの板へよりかかっていた薫の重なった袖が、長く外へ出ていて、川霧に濡れ、紅い下の単衣の上へ、直衣の縹の色がべったり染まったのを、車の落とし掛けの所に見つけて薫は中へ引き入れた。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "川霧はまったく晴れてオールに破れた川面が、小波をたてて、日にキラキラと光った。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "モヤモヤと川霧が立ちのぼって河が乳白色にぼかされてゆく。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「帰ってきたぞ」　一同は目をかがやかし、川霧のこめた川上をじっとみつめた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポカリと川霧を破ってボートがあらわれた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "川霧の消えて行くその朝、河岸では、筏をさがす彼らの姿が隠見した。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、うすれた川霧の対岸で、木肌も白いあの税庫にぶっつかった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓外は一面の乳色の川霧が森林の上層を速やかに流れていた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟呼べばたゞ川霧の答かな　　　　　　　昌琢「川霧の答」といふ無理な言葉に感ぜしならん。",
              "citation": {
                "source": "俳句の初歩",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "川霧の交った夜の靄がかけていて、遠くはぼーっとしていた。",
              "citation": {
                "source": "溺るるもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月、十月とたち、早朝など蔀を上げて見出すと、川霧が一めんに立ちこめていて、山々は麓すら見えないようなこともあった。",
              "citation": {
                "source": "ほととぎす",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "川霧立まよふ頃の夕まぐれ、ここの渡しをいそぎ橋場の岸近くなる時｜真崎稲荷の森かげをぬひて廓の灯を望み見たりし情景も明治四十一年の頃には既に過ぎし世の語り草なりけり。",
              "citation": {
                "source": "桑中喜語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "川霧がたてこめて月影は薄いが、ちょうど月の出で、蒼白い月光が断崖の面へ斜めにさしかけているので、そこだけがはっきりと見える。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "捨公方",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜はすでにほのぼのと明けたが、川霧が深く立ちこめて、馬の毛、鎧の縅の色も定かには見えぬ。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが川に沿うていること――所有者の話ではその川霧のため春の霜からこの農場は護られているそうだが、わたしにはそんなことはどうでもよい。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に言う通り、残んの月夜のことですから、川霧の立てこむる鴨川の河原が絵のように見えます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの日、川霧の向うへ消えて行った数々の本にもこの蔵書印が捺してあったに違いない。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「手形があるし大目付から急の通達があったようです」「大目付から、――」「われわれが立って来たあとで、なにかあったんじゃないでしょうか、そうでないにしても老中が積極的に出はじめたことは慥かなようですよ」　ひときわ濃く、川霧が条を描きながら巻いて来た。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川霧一　ちらと、彼方に灯が見えた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さびしい所だなあ』　白い川霧が降りていた。",
              "citation": {
                "source": "篝火の女",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
