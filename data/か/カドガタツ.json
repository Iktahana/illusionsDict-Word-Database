    "definitions": [
      {
        "index": 1,
        "gloss": "to cause offence (offense)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「本当のことを言うのも大切だけど、伝え方を工夫しないと職場の人間関係に角が立つぞ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は、部長のプライドを傷つけて角が立たないよう、あえて遠回しな表現で予算不足を訴えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「はっきり断ると角が立つから、とりあえず『前向きに検討させていただきます』とだけ言っておこうよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "雀部さん、貴方のやうに言ふと角が立つ。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなり廃めてしまっては角が立つ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「智に働けば角が立つ。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、「はア」と、曖昧な挨拶を返してしまつたので、それを今更ら問ひ糺すのも角が立つだらうと思ひ、もぢ／＼する心を煙草でごまかした。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪口のやり取りは、ほかの女らに對する面目もあるから、親しさうにやつてゐたが、話をすると、どこか角が立つのだ、それを融和するつもりでもあらう、氷峰は敷島の顏を見つめてゐたあげく、「なるほど、君はよく見ると美人の方ぢや、わい」と云ふ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「物も言いようで角が立つ」。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云って断われば角が立つ。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けれども必竟は本人のために嫁入けるんで、（そう申しちゃ角が立つが、）姉さんや市蔵の便宜のために、千代子の結婚を無理にくり上げたり、くり延べたりする訳にも行かないものだから」「ごもっともだ」と僕は承認せざるを得なかった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大庭　　お父さんが行つちや、角が立つて、やつぱりまづいかな。",
              "citation": {
                "source": "五月晴れ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いえ、私から聞くと角が立つから……。",
              "citation": {
                "source": "変な男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう申してはお気の毒、角が立つかもしれませんが、たしかあなた様におかれても、どうやら山影宗三郎様に、焦がれておいで遊ばすとのこと。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "智に働けば角が立つ。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆の裏には細い竹を何本となく横に渡してあるから、帆に角が立つのみか、捲き上げる時にはがらがら鳴る。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬はモ少し痩せて目は少し角が立つて居ました。",
              "citation": {
                "source": "千里駒後日譚",
                "author": "楢崎龍、川田雪山",
                "note": "青空文庫"
              }
            },
            {
              "text": "角が立つといったって、元々品のよいことじゃないのですから、あなた方は御自分で責任を持たない法はありませんよ。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じことを言っても角が立つ」　と父も十分経験がある。",
              "citation": {
                "source": "変人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日私達が行って後から直ぐっていうと何だか彼方へも角が立つようですから、そこは二人で相談づくにして下さい」「承知しました。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物事は何によらず人並みにやらねえとかどがたつから、おつきあいに行くんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
