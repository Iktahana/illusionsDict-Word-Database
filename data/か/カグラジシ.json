        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭に植えた神楽獅子のツバキが、鮮やかな赤い花を咲かせ始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この神楽獅子、花びらの形が獅子のたてがみみたいで面白いね」と園芸家が感心していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "茶花としても人気の神楽獅子のツバキは、その華やかな姿が愛されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "春の訪れとともに、神楽獅子の木が美しい花をたくさんつけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "神楽では、安曇磯良を象つた鬼面｜幌身の神楽獅子に近いものだつたのではないか。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くでいえば、熱田の神楽獅子などがそれだよ。",
              "citation": {
                "source": "百面相役者",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
