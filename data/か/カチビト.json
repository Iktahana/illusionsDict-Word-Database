          "standard": [
            {
              "text": "山道を歩く徒人は、すれ違う旅人に静かに頭を下げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "京の都には、馬に乗る者もあれば、徒歩で往来する徒人も少なくなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長旅に疲れた徒人が、峠の茶屋で一休みしている様子が目に浮かぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "成吉思汗　それから、僕が忘れようとしても忘れることのできないのは、父の也速該巴阿禿児が泰赤宇徒人に攻められた時、あの危急存亡の場合に僕を助けてくれたのは、君だった。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            }
