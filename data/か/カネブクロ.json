[
  {
    "uuid": "2fac8076-9a94-5451-8de8-09a602aaa324",
    "entry": "金袋",
    "reading": {
      "primary": "かねぶくろ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
