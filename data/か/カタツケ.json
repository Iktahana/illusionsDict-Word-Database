  {
    "uuid": "6c6c9fa3-3bef-54a7-80d3-5be7bd02f3b3",
    "entry": "片つけ",
    "reading": {
      "primary": "かたつけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tidying up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夕飯の前に、出しっぱなしのおもちゃを早く片つけちゃいなさい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "引っ越しの荷物の片つけがなかなか終わらず、途方に暮れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あーあ、せっかく部屋を片つけたのに、もう散らかされてる」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、その書類の片つけ、私がやっておくから置いといていいよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「いっそのこと、この、どさくさまぎれに、片つけッちまおうか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（何でございますか、私は胸に支へましたやうで、些少も欲しくございませんから、又後程に頂きましやう、）と婦人自分は箸も取らずに二ツの膳を片つけてな。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、家の者が寝静まってしまうと私も疲れを覚えて来て体をちょっと横たえようとし、そのあたりに散乱している絵具皿を片つけにかかる。",
              "citation": {
                "source": "健康と仕事",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手道具を整理したり、古い行李や箪笥の中を片つけた。",
              "citation": {
                "source": "霜",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木屋の人足がやっと四人来てくれて、振り落された瓦の破片や土塊の取り片つけに着手する。",
              "citation": {
                "source": "震災後記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "延べ都合十四人がかりでやっと家の外まわりの片つけだけが出来た。",
              "citation": {
                "source": "震災後記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の衣類を取片つけ袷を着る。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、片つけにめえりやした」「そうか、よかろう、武士らしくやれ！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、表向には、父の死を二日のあいだ秘して役所の用を片つけたのち喪を発表した。",
              "citation": {
                "source": "竹柏記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ひとつ公務から先に片つけるとしよう」十四　なるほどそこへ権頭、杢、中将の三人が入って来た。",
              "citation": {
                "source": "三悪人物語",
                "author": "忍術千一夜　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな仕事はいいよ」とさぶはきまり文句のように云った、「栄ちゃんなんかには勿体ない、おれ一人で片つけるよ」「いいったら」栄二はいつもうるさそうに答えた、「心配するなよ」　さぶは金杉の家へ移り、朝八時に来て、夜なべがなければ、晩めしを喰べて帰った。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人を自分の部屋へみちびいた弥生は縫いかけていた物を片つけ、縁側に面した障子をあけた。",
              "citation": {
                "source": "日本婦道記",
                "author": "風鈴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとくいはめっぽう払い物の多い家で、空罐だの洋酒やビールの壜だの、雑誌、新聞、ぼろ類など、一度では運びきれないほど多量な品が、月に二度ずつ出るし、それらの代価は取らず、「片つけてもらう」のだからと云って、反対に三コ平均の金を呉れるのだ、ということであった。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うちの　じじいと　おれが　けんかした　さあて　こいつを　どう　かたつける？",
              "citation": {
                "source": "つまさきチミーのはなし",
                "author": "THE TALE OF TIMMY TIPTOES",
                "note": "青空文庫"
              }
            },
            {
              "text": "この数日のうちに一かたつけてしまいましょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "段々手順が分って来て、大体朝七時半ごろから十二時すぎ迄で一かたつけて午後は四時間ほど、自分の時間にしようとしてやって居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、奧の間へ寢に入らしたあとを、妻が茶道具をかたつけて引き取らうとしたら、平塚さんはまだ帶さへ解かずに襖のかげに手を附いて待つてゐた。",
              "citation": {
                "source": "女子文壇の人々",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
