[
  {
    "uuid": "47567f62-0bde-58f7-9415-4f643c3fab4e",
    "entry": "換わり",
    "reading": {
      "primary": "かわり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "an exchange transaction",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この商品は、別の商品との換わりができません。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "株の換わりとして、債券を購入しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古い車を新しい車と換わりたいのですが、いくらくらいかかるでしょうか？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「じゃ、高等学校は丁度僕と入れ換わりです。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがコスト削減の厳しい圧力を受けた低価格のメモリーのパッケージは、急速にプラスチック製に置き換わりつつあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "物｜換わり星移り、人情はしだいに薄く、義気も落花の時節となりたるは、世人の常に言うところにて相違もあらず。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖人たちによる奇跡治療は異教の神による治療に置き換わり、異教寺院の役に立っている行為を採用するのは賢明であった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "望んだ死は与えられず、そのかわり現世の厳粛な苦しみを与えられた。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、――」立ちあがって、つかつか太宰のほうへ歩み寄り、「ばけもの！",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会にはこの自然が欠乏していてそのかわりに田舎の「人」が入り込んでいるのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは沖から寄せて来る風のために、海面がさざ波立って空が映らなくなり、そのかわり海水の色が透いて見えるためであります。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは普通の本でありますが、古い本には「与」の字のかわりに「夜」という字が書いてある。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと云って一概に私は※んだら歯の欠けそうな林檎や、切ったら血のかわりに粘土の出そうな裸体や、夕闇に化けて出そうな樹木や、こういったもの自身に対して特別な共鳴を感ずる訳ではない。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年五月十一日『東京朝日新聞』）　　　　　　　　　七十八　　　　　　写真測量　経緯機などを用いて測量すれば無論精密な結果を得られるが、そのかわり時間をつぶし、人を沢山に使わねばならぬ。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たたなわる葡萄畠や古い町々を涙を流して過ぎるかわりに、巡査と睨みあいながらバビロンをほっつきまわってるんだ。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妾はいつも間違いのないようにお取引を致しますかわりに、それだけに、駈引のある商人的なお取引はいやなのでございます。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――妾だったら、自殺するかわりに結婚するわよ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そのかわり、クリスマスには精神的な贈りものをきっとくれる？",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "平麦のかわりに丸麦を二度たきとして、ねりつぶしてねばりをつけた。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、彼らが市街のいずれかへ消えて行って、今夜ひっかえしてくる時には、靴下や化粧品のかわりに、ルーブル紙幣を、衣服の下にかくしている。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」先生、この時、チョイと目を転じて、メートルグラスの番人を見た、これはおかわりの合図。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわりまた、ちょっと見ると変なようでも読んでいるうちにだんだんおもしろくなって来るようなものがあれば、だれがなんと批評しようが自然に賛美者の数を増してくるであろう。",
              "citation": {
                "source": "俳句の型式とその進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわりに台所へのそのそ黙ってはいって来て全く散文的に売りつけることになったようである。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治初期を代表するような白シャツを着込んで、頭髪は多くは黙阿弥式にきれいに分けて帽子はかぶらず、そのかわりに白張りの蝙蝠傘をさしていた。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来アメリカにジャズ音曲とナンセンス映画とが流行する事実は、かの国に古い意味での哲学と科学と芸術の振るわない事実の半面であって、そのかわりに黄金哲学と鉄コンクリート科学と摩天楼犯罪芸術の発達するゆえんであろう。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宣伝を受けないものはそのかわりに剣戟を受けねばならなかった。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これが表沙汰になりましては、御屋敷の名前にもかかわります。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "満洲、蒙古、山東地方は、こっちが取らなけゃ、かわりに米国がそれを取るんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田と畠を頼母子講の抵当に書きこみ、或は借金のかわりに差押えられようとしていた自作農は、親爺だけじゃなかった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雪のかわりに、これから雨が降るもんだから、　そうら、あんなに、雨の卵ができている。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわりそんなきれを鼻緒に巻いた藁草履やわかめなどを置いて行ってくれる。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一方が村の人の共同湯に、一方がこの温泉の旅館の客がはいりに来る客湯になっていたためで、村の人達の湯が広く何十人もはいれるのに反して、客湯はごく狭くそのかわり白いタイルが張ってあったりした。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「言わんのやんな」勝子は返事のかわりに口真似をして峻の手のなかへ入って来た。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
