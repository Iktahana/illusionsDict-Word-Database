        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "なんか、この機械、変わりがあるみたいなんだよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の様子がいつもと変わり、心配になりました。",
              "citation": {
