        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅行用に丈夫な革製品のバッグを探しているんだけど、おすすめある？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "父の日のプレゼントに、長く使える上質な革製品の財布を選んでみたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この革製品のジャケット、最近手入れしてないから、ちょっとツヤがなくなってきたな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "使い込むほどに味が出るのが、本物の革製品の魅力だよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お店に並んでる革製品、どれも職人のこだわりが感じられる逸品だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "試みに一人の専門に洋傘を製造してゐる職人、或は皮革製品の専門職人と、デパートのその売場専門の係員へと専門商品に就いて討論さしてみたまへ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
