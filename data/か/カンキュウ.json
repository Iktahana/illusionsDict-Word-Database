[
  {
    "uuid": "cf3bc8aa-eea4-5f7c-94c5-f0bfae1d5693",
    "entry": "感泣",
    "reading": {
      "primary": "かんきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "being moved to tears",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "映画のラストシーンで、多くの人が感泣していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "恩師の言葉に、思わず感泣してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その演奏は聴衆を感泣させるほど素晴らしかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの話、本当に感動したよ。もう、泣いちゃった。」「え、感泣したの？すごいね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "将軍家に於いても、ただ二念なく大君の御鴻恩に感泣し、ひたすら忠義の赤誠を披瀝し奉らん純真無垢のお心から、このやうなお歌をお作りになつたので、なんの御他意も無かつたものと私どもには信ぜられるのでございます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将士の父兄子弟｜之を見て、皆感泣して、王の為に死せんと欲す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言はれて權藏は、『解りました、難有う存じます』と言つたぎり、感泣して暫らくは頭を得上げませんでした。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁未だ壮年の勇気を喪はざれど、生年限りあれば、かねて存命に石碑を建つるの志あり、我が来るを待ちて文を属せしめんとの意を陳ければ、我は快よく之を諾しぬ、又た彼の多年苦心して集めし義太夫本、我を得て沈滅の憂ひなきを喜び、其没後には悉皆我に贈らんと言ひければ、我は其好意に感泣しぬ。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "御内々で金十円也を謝礼用として賜わり、ほかに別段の思召として金子その他を頂戴したので翁は感泣して退出した。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争の惨禍を坐視し得ぬ鼻の表現から、世界的の博愛事業を生み出して、今日まで幾千万の人々をして人類愛に感泣せしめつつある婦人がありました。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その情義の篤き志を知りては、妾も如何で感泣の涙を禁じ得べき。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫妻は只々勿體なき仰せ冥加に餘る思召と感泣する許りである。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "正信おどろきて、直ちに政を改めて、舊に復し、三百八十九村の民、こゝに始めて蘇生して、感泣せざるもの無し。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから予は外に差支えのない限り、正に海軍当局の海の如き大度量に感泣して、あの横須賀工廠の恐る可き煤煙を肺の底まで吸いこみながら、永久に「それは犬である」と講釈を繰返して行ってもよかったのである。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればこそ、勿論長門守は、江戸大公儀の慈悲あるその処断を感泣しないまでも内心喜んで御受けしただろうと思われたのに、変り者と言えば変り者、慷慨家と言えば一種気骨に富んだ慷慨家です。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "御諚伝えましたらいずれも感泣致しますることで厶りましょう。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄太君から来信、その友情は私を感泣さした。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日も今日も樹明君の友情に感泣する、それはありがたいともありがたい手紙であつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "東隣は新築の護国神社、西隣は古刹龍泰寺、松山銀座へ七丁位、道後温泉へは数丁、どんぐり庵へは四丁――友人はみな親切、――すべての点に於て私の分には過きたる栖家である、私は感泣して、すなほに慎ましく私の寝床をこゝに定めてから既に一年にならうとしてゐる、――それに、それに。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "天才が一たび高尚な情操を潜つて※び出せば、山河も鳴動する、草木も感泣する。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての点に於て、私の分には過ぎたる栖家である、私は感泣して、すなおにつつましく私の寝床をここにこしらえた。",
              "citation": {
                "source": "四国遍路日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の午後は、樹明さんと冬村君とが、いよ／＼例の廃屋を其中庵として活かすべく着手したとの事、草を刈り枝を伐り、そしてだん／＼庵らしくなるのを発見したといふ、其中庵はもう実現しつつあるのだつた、何といふ深切だらう、これが感泣せずにゐられるかい。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまい酒だつた、枯木までよう燃える、感泣々々。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕ぐれ、ぢつとしてゐると、裏戸があいた、樹明君だ、電球を持つてきてくれた、そしてバツト、そして五十銭玉一つ、さつそく酒を買うてくる、……感泣々々。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "我兄迄感泣之万一を申上候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから予は外に差支へのない限り、正に海軍当局の海の如き大度量に感泣して、あの横須賀工廠の恐る可き煤煙を肺の底まで吸ひこみながら、永久に「それは犬である」の講釈を繰返して行つてもよかつたのである。",
              "citation": {
                "source": "入社の辞",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等被害民は他意あるに非ず、故に政府にして胸襟を開きて彼等に対しなば、彼等野人は先づ其の徳に向て感泣すべきなり。",
              "citation": {
                "source": "鉱毒飛沫",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時父は、重病の身を床より起して感泣して御挨拶を申上げた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この内外多端の時にあつて、古義神道を探求し、厳たる皇国観念に徹した彼は、私情に於て藩主破格の厚情に感泣し乍ら、重なる招聘にも応ぜず、藩禄を食まうとしなかつた。",
              "citation": {
                "source": "橘曙覧",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時相馬氏は年僅に廿五歳、學窓を出てから二年經つたばかりで、八千の健兒（當時の數）が歌ふ校歌の作詞を命ぜられた光榮に感泣してゐたといふ。",
              "citation": {
                "source": "校歌「都の西北」と私",
                "author": "相馬御風",
                "note": "青空文庫"
              }
            },
            {
              "text": "大いに感泣しているさ。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "感泣はしているようなものの忘れちまったんだから仕方がない」　兄妹は隔なき眼と眼を見合せた。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
