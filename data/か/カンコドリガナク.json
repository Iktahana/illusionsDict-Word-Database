        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "平日の午後とはいえ、この大型ショッピングモールに閑古鳥が鳴いているのは驚きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわあ、開店時間なのに閑古鳥が鳴いてるよ。サクラでも雇わないとまずいんじゃない？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔はあんなに活気があった商店街も、今ではシャッターが閉まり閑古鳥が鳴くばかりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "人気スポットだったはずが、ブームが去った途端に閑古鳥が鳴く寂しい場所になってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "大阪などでも、秋の祭りは、閑古鳥が鳴くと謂はれてゐる様に、宮の内外も寂しい。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
