        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "早朝の冷え込みの中、仲間たちと静かに鴨撃ちの準備を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ベテランの猟師は、水鳥の生態を熟知しており、的確な鴨撃ちを行う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「今日の鴨撃ちは、獲物が少なかったな。」と、彼は少し残念そうに言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "鴨撃ちのシーズンが始まり、猟友会では安全講習会が開催された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "何もかもうちあけて奥さんに許しを乞いなさい。",
              "citation": {
                "source": "オパール色の手紙",
                "author": "――ある女の日記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかもうち忘れて進んで行きました。",
              "citation": {
                "source": "天狗の鼻",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕達は何もかもうち忘れて、うっとり微笑まずにはいられませんでした。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "学者は、いつか三｜人の男たちが、幾百｜年の後になって、しかもうちそろって、かぎを持ちながら自分を訪ねてきたことを思い出しました。",
              "citation": {
                "source": "三つのかぎ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "（起き上る）なんかもうちつと、身になりさうなもんはないのか。",
              "citation": {
                "source": "医術の進歩",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だつて、そんなら、なんとかもうちつとお返事のなさりやうがありさうなもんですわ。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤豊治は三階へ上って、扉の鍵を（それはいつかもうちゃんと閉まっていた）開け、中へ入って電灯を点けた。",
              "citation": {
                "source": "亡霊ホテル",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんに会いたいというとすぐあげてくれ、そこでおなつはなにもかもうちあけて語った。",
              "citation": {
                "source": "契りきぬ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「済みませんが待っておくんなさい」とあるじが云った、「誰も動かすんじゃあねえって云ってましたから、どうかもうちょっとそのままでいておくんなさい」　そして、もういちどおじぎをして、あるじは板場へ戻った。",
              "citation": {
                "source": "あすなろう",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は晋太郎の養育になにもかもうち込もう、あらゆるものを抛うってこの子を生かすのだ。",
              "citation": {
                "source": "菊屋敷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
