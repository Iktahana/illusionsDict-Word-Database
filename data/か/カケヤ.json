[
  {
    "uuid": "bf2b0dd4-0258-5942-9aad-0ca11a27806d",
    "entry": "掛矢",
    "reading": {
      "primary": "かけや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mallet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "DIYでウッドデッキを作るため、大きな掛矢を使って杭を打ち込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お祭りの準備で、櫓の組み立てに掛矢が使われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重い掛矢を振り上げ、木の楔を打ち込んでいく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "木戸をも閉めよ、貫木をも鎖せ、掛矢で飛込んでも逢いたい。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意にぞうつとするやうな寒けがして、祖父は思はず羊皮の外套を心に浮かべたさうぢやが、そのとき突然、まるで掛矢の百挺も打ちおろしたかと思はれるやうな凄い物音が森ぢゆうに響き渡つて、頭の中がガーンと鳴り出したほどぢやつたといふ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、まるで、誰か頑丈な人間が、自分の体内を歩きまはりながら、掛矢で心臓や脈管を打ちまくるやうに感じた……それほど怖ろしく、この笑ひ声が彼の内心に響いたのだ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程、掛矢でブンなぐっても潰れそうもない面構えだ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面の玄関の板戸が、掛矢の一撃で凄じい音の下に折れ砕けた。",
              "citation": {
                "source": "寺坂吉右衛門の逃亡",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "手許にあった掛矢をふりかぶった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛矢の柄を杖づくように腰にあて、木材のうえに立ちはだかっているこの大きくない男に、手軽く近づけぬものを感ずるのであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は掛矢の柄を板囲いに立てかけ、からげた着物の裾をおろした。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛矢でもって扉を叩き割るような恐ろしい物音です。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "新田先生は、退院の後、すぐさま甲州の山奥の、掛矢温泉へ向かった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛矢温泉といっても、知らない人が多いであろう。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは温泉と言っても、宿は掛矢旅館がたった一軒しかない。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その掛矢旅館も、たいへんむさくるしい物置のような宿であって、客の数も、いたって少い。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛矢温泉に湧出る湯も、実はこの地獄沢からぷうぷうふきだしているガスによって、地中で温められている地下水だった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように、掛矢温泉がさびれているわけは、地下から湧出している温泉が、時々ぴたりととまって、温泉がお休になるせいであった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛矢旅館を、ひょっくりとおとずれた新田先生は、そこの主人の弓形老人から、たいへん歓迎を受けた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この掛矢旅館ののんびりした気分も、三方を高い山に囲まれたもの静かな風景も、あと僅かでおしまいになるのだ。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "春なおあさい掛矢温泉の岩にかこまれた浴槽の中に、新田先生は体をのびのびと伸ばして、はや二、三日を送った。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の上に、ちろちろと、見えかくれする怪しい火に、新田先生は、たいへん興味をおぼえたので、その翌朝、先生は、掛矢温泉の老主人がとめるのも聞かず、一人山をのぼって行った。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、地獄沢を後に、掛矢温泉へたどりついた時は、もうすっかり夜は明けて、朝となっていた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでもあろう、新田先生にしたところが、あの掛矢温泉につかって、病後の体をゆっくり丈夫にしたいと思っていたのであるが、はからずも、地獄沢の上の怪火に引きよせられ、火星兵団にぶつかったればこそ、こうして早く東京へ舞いもどらねばならなくなって来たのだから。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "コン吉はせんかた泣く泣く、大きな帽子箱と鞄とラケットを両手にさげ、とぼとぼとタヌのあとについて荘館の横手に廻ってみると、大公におかせられては、いまや、欅の大掛矢を振い勝手口の階段の横について、石炭を汲み入れる二尺四方ほどの鉄扉に対して大破壊を行なっている様子。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "謝肉祭の支那服　――地中海避寒地の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "斧を担ぎ掛矢を荷い、槍薙刀を提げた様子は将しく強盗の群である。",
              "citation": {
                "source": "郷介法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまに分るかと思うと鳶口や掛矢の事を聞かれる。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の鳶口や掛矢は先生何と翻訳して善いのか習った事が無いんだから弱わらあね」「もっともだ」と主人は教師の身の上に引き較べて同情を表する。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼をつぶつて居るところを、掛矢か何んかで叩込む外に、あんな藝當は出來ないよ」「驚きましたね、どうも。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "御宰籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "上に乘つて居た金之進が一とたまりもなく、もんどり打つて落ちるところを、喜助は下からひと思ひに突き上げたのだ」「――」「掛矢で叩き込んだやうに、刀が首筋を突拔けたのはその爲だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "御宰籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――」　それよりも八五郎を驚かしたのは、その踏臺の傍に無造作に抛り出してあつた、巨大な掛矢でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "妾の貞操",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も腰高の窓格子は、框ごと外されて、掛矢との因果關係を物語り顏ですが、此處は道具がなくても樂に外れるやうに出來て居り、掛矢の用途はさう簡單には讀切されさうもありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "妾の貞操",
                "note": "青空文庫"
              }
            },
            {
              "text": "凧のかげ夕方かけて読書かな夕立やかみなり走る隣ぐに沓かけや秋日にのびる馬の顔鯛の骨たたみにひらふ夜寒かな秋ふかき時計きざめり草の庵石垣に冬すみれ匂ひ別れけり　彼の俳句の風貌は、彼の人物と同じく粗剛で、田舎の手織木綿のやうに、極めて手触りがあらくゴツゴツしてゐる。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
