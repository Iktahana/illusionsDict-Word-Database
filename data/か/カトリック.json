        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は熱心なカトリック教徒で、毎週教会に通っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その大学はカトリック系の学校として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カトリックの聖歌隊の歌声は、とても美しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はカトリックの教えに基づいて、慈善活動に尽力している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "家の奥まつた部屋の中で、終日雀の鳴聲を聽きながら、優しく、惱ましく、恥かしげに、思ひをこめて針仕事をして居る娘を見る時、私はいつもこの抒情味の深い、そして多分に加特力教的な詩人の言葉を思ひ起す。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の奧まつた部屋の中で、終日雀の鳴聲を聽きながら、優しく、惱ましく、恥かしげに、思ひをこめて針仕事をして居る娘を見る時、私はいつもこの抒情味の深い、そして多分に加特力教的な詩人の言葉を思ひ起す。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十四年十一月黒ダリヤ烏羽玉の黒きダリヤを胸にあて加特力の尼はなにをかゆめむらむ。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教的共産主義者の小さい集團は四世紀に北阿弗利加に孤立してゐたが、（Donatismus）加特力教の成立と倶に衰亡した。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人にして加特力教徒だつた者の子供なのであらう。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人にして加特力教徒だった者の子供なのであろう。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、文中｜加特力教の語多し。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "善き加特力教徒はこれと殊にて神の愛子なり、これを陷れむには惡魔はさま／″＼の手立を用ゐざること能はず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌ふ僧の「ミゼレエレ」（「ミゼレエレ、メイ、ドミネ」、主よ、我を愍み給へ、と唱へ出す加特力教の歌をいふ）唱へはじむるとき、人々は膝を屈めて拜したり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに住める猶太教徒は、歳に一たび仲間の年寄をカピトリウムに遣り、來ん年もまた羅馬にあらんことを許し給はゞ、謝肉祭の時の競馬の費用をも例の如く辨へ、又定の日には加特力教徒の寺に往きて、宗旨がへの説法をも聽くべし、と願ふことなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し其人ならば、猶太教徒にあらずして加特力教徒なること疑なし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶太教徒若くは囘々教徒｜數人をして加特力教に歸依せしめ、洗禮を行ふなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は、君はわが加特力教の民にあらず、されば「アラチエリ」の寺にて説教のまねし給ふ筈なしとの事なりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "独逸、仏蘭西の戦ありし時、加特力派の国会に打勝ちて、普魯西方につきし、王が中年のいさをは、次第に暴政の噂に掩はれて、公けにこそ言ふものなけれ、陸軍大臣メルリンゲル、大蔵大臣リイデルなど、故なくして死刑に行はれむとしたるを、その筋にて秘めたるは、誰知らぬものなし。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "加特力教信ずる養父母は、英吉利人に使はるるを嫌ひぬれど、わが物読むことなど覚えしは、彼家なりし雇女教師の恵なり。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "アファナーシイ神父はただひと言、このバサウリュークとつきあひをするやうな者は、誰れ彼れなしに、基督教会と人類全体の仇敵である加特力の信者と看做しますぞ、と断言したきりぢやつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はとうに加特力僧どもがウクライナの地へ侵入して、哥薩克の民を加特力に改宗させつつあることも、二日にわたり、＊塩水湖附近で韃靼の軍勢が干戈を交へたことも口にしなかつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「われわれ哥薩克は、有難いことに、悪魔や加特力僧などにびくともするもんぢやないて。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「異端の加特力教徒でも、火酒に眼がないのだ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "――正教の国、露西亜の仇敵と内通し、ウクライナの国民を加特力教徒に売り、正教の寺院を焼き払はうとしたかどに依つてである。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "その仲間に加特力僧もひとり混つてゐるが、その風体が皆と同じで、正教の祭司などとはまるで似ても似つかず、一同とともに酒を呑み、浮かれ騒いで、その穢れた舌で淫らがましいことを喋り散らしてゐる。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまだその外に何か理由があるとしたら、それは金花が子供の時から、壁の上の十字架が示す通り、歿くなつた母親に教へられた、羅馬加特力教の信仰をずつと持ち続けてゐるからであつた。",
              "citation": {
                "source": "南京の基督",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルツテルは羅馬加特力教に反逆した。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼の魂はやはり羅馬加特力教の地獄を見ずにはゐられなかつたのである。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、ボーマンの『宗教犯罪の心的伝染』と云う著述の中にある事実ですが、十六世紀の始めチューリッヒの羅馬加特力教会に、所謂奇蹟が現われたのです。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうなって、当時の瑞西を考えると、新教アナバプチスト派の侵入をうけていて、加特力の牙城が危胎に瀕していたのですからね。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "滿谷、長谷川、徳永、近江、柚木、志貴、酢屋、僕の八人は何の目的も無く電車の終点まで乗つて下車し、引返して偶然博物館の前に出て、滿谷等は其附近を写生し、徳永、志貴、近江、酢屋と僕とは加特力教会の経営に成る当地の模範小学を参観した。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "加特力教のユウカリストの大会があつて六十万人の信者が諸国から入込んで居る維納へ、其れとは知らずに着いた風来の自分達は宿の無いのに困つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は御聖影のおん前に何か祭壇が設けられて居るであらう、白絹や榊で斎ひ清められて居るであらうと想つて居たが少しも其辺の用意が見え無かつたので、一方に満都の加特力教徒が荘厳な宗教的儀式に※狂して居るのに比べて甚だ物足らなかつた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニのうしろには、いつから乗ってゐたのか、せいの高い、黒いかつぎをしたカトリック風の尼さんが、まん円な緑の瞳を、じっとまっすぐに落して、まだ何かことばか声かが、そっちから伝はって来るのを、虔んで聞いてゐるといふやうに見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
