[
  {
    "uuid": "e995abe9-4b98-5e22-9960-6f083e5b74db",
    "entry": "仮親",
    "reading": {
      "primary": "かりおや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
