[
  {
    "uuid": "0fda1f8b-8d67-561f-9cf8-a1230bc61c29",
    "entry": "噛んで含める",
    "reading": {
      "primary": "かんでふくめる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
