      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to explain carefully and slowly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新入社員にシステムの操作方法を、噛んで含めるように教えてあげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "父は子供にもわかるように、歴史の複雑な出来事を噛んで含めるように説明してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は英語が苦手な私に、ゆっくりと噛んで含めるように発音を指導してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしこういう心になるまでには、私を教えるために、毎日、毎晩、見る者、聞くものについて、母様がどんなに苦労をなすって、丁寧に深切に、飽かないで、熱心に、懇に噛んで含めるようになすったかも知れはしない。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と蝶吉の項を抱いて口移しに噛んで含めるように、自分の赤心を語るため、今まで久しい間、時に触れ、折に当って、動かされた、至憐至愛の情の切なるを、ここに打明けて語ったのである。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間と云うものの総ての上について噛んで含める様に教えた様であった。",
              "citation": {
                "source": "正岡子規君",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "噛んで含めるやうに、色々の方面から、解いてきかしても、どうしても理解しない場合、これは彼女達ばかりとはいへまい、男達の場合にも『不意に襲ふもの』があれば、いつぺんに何もかも判つてしまふものらしい。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この際是非立ち退いてくれ」　と、噛んで含めるように腰弁から説明を受けながら、チュウとも云い得ず首をちぢめている。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえさんがこの上無理に刺青をすれば、どうしても死ぬに決まっているが、それでも構わずに遣る気か、どうだと云って、噛んで含めるように意見をすると、当人ももう大抵覚悟をしていたとみえて、今度はあまり強情を張りませんでした。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、ゆっくり言えばわからないはずはないとでも思ってるらしく、一語々々はっきり句切って噛んで含めるように言うんだが、早く言ったって遅くいったって、知らない言葉は解りっこない。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、千代松は低い聲をして噛んで含めるやうに言つた。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は私をその私立学校に、貧民窟の裏長屋に通わせるようになってから、私に噛んで含めるようにいいきかせるのだった。",
              "citation": {
                "source": "父",
                "author": "金子ふみ子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は私をその私立学校に、貧民窟の裏長屋に通わせるようになってから、私に噛んで含めるように言いきかせるのだった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞き給え……こうなんだよ」　と噛んで含めるように云いつつ正木博士はさも忌々し気に、舌に粘り付いた葉巻の屑を床の上に吐き棄てた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時に於て、平明に豊富に、噛んで含めるやうに未来を警告された先生の知見と誠意と能弁とに、僕は心の底から感歎した。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうです」　袋探偵は、若紳士に対して噛んで含めるように説いたつもりであった。",
              "citation": {
                "source": "心臓盗難",
                "author": "烏啼天駆シリーズ・２",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ムーッとお浦を見詰めながら、貝十郎は噛んで含めるようにいった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "物のいひ方だつて、少しは加減して、そこはなにさ、噛んで含めるやうに……。",
              "citation": {
                "source": "五月晴れ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "噛んで含めるように、腫物に触るように繰返してお銀様を説いているのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と丑松は噛んで含めるやうに言つた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは中村へ参っての口上は……」と左膳は、噛んで含めるように使いのおもむきを繰り返したうえ、「な、こういう次第だからとよく申して、同勢をすぐり、貴様には気の毒だが、その夜にでも彼地をたって江戸へ急行してもらいたい。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その金が見付かつたら、其場でお留を縛るんだぞ」「へエ――」　噛んで含めるやうに言はれてガラツ八は漸く飛出しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "がらツ八手柄話",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿曽はハナの手をとって、噛んで含めるようにいい聞かせてから、踏みつけた雪を、靴の底でゆっくりとモジリながら、雲を踏むような宙に浮いた足どりで、一歩一歩、慎重に渡って行った。",
              "citation": {
                "source": "白雪姫",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "此上敵を討つ積りで、うつかり人などを害めると、今度はお上の厄介になる――惡者が捕つても、そのお處刑はお上に任せることにしては何うだらう」　平次の調子は噛んで含めるやうです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "地獄から來た男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれほど噛んで含めるように言ったのに、どうしてお前はわからないのだ。",
              "citation": {
                "source": "悪人の娘",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お主の大事も忘れて、酒ばかり飲んで歩きやがって万一あの娘が死んだら、手前は腹でも切らなきゃア済むめえぜ」　平次の言葉は、囁き加減ですが、噛んで含めるように、半蔵の肺腑に喰い込んで行きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "殺され半蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "書畫骨董の氣違ひばかりは、こちとらの考へたやうなものぢやないよ」　平次は噛んで含めるやうに説明しますが、八五郎には結局解りさうもありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "名畫紛失",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆んなの思いも寄らない事をしているに違いない」「…………」　噛んで含めるような平次の言葉に、かりそめの拵え事を言ったのを愧じて、お文は丸い顎を襟に埋めました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "小唄お政",
                "note": "青空文庫"
              }
            },
            {
              "text": "このうえ敵を討つ積りで、うっかり人などを害めると、今度はお上の厄介になる――悪者が捕まっても、その処刑はお上に任せることにしてはどうだろう」　平次の調子は噛んで含めるようです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "地獄から来た男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その金が見付かったら、その場でお留を縛るんだぞ」「ヘエ――」　噛んで含めるように言われてガラッ八はようやく飛出しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "ガラッ八手柄話",
                "note": "青空文庫"
              }
            },
            {
              "text": "變なことをしちや反つて爲にならねえ、默つて主人に取次いで、どうして鈴を集めたか、仔細を話して明を立てなきア、何んな事になるか判らないぜ」　平次の態度には、商賣柄にも似ぬ、噛んで含めるやうな物優しさがありました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鈴を慕ふ女",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころぢやない、父親の市十郎を殺した奴と、お前を脅かしてゐる影法師とは、どうも掛り合ひがありさうな氣がしてならないのだよ」　平次は噛んで含めるやうに言ふのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "影法師",
                "note": "青空文庫"
              }
            },
            {
              "text": "「捨てないでちょうだいとはいいません……捨てるなら捨ててくださってもようござんす……その代わり……その代わり……はっきりおっしゃってください、ね……わたしはただ引きずられて行くのがいやなんです……」「何をいってるんだお前は……」　倉地のかんでふくめるような声が耳もと近く葉子にこうささやいた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
