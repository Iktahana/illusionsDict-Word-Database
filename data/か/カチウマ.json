        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "そのレースで勝った馬は、まさに穴馬だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼はいつも本命馬に賭けるが、今回は穴馬に期待している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "チームの予想外の躍進は、彼らを大会の穴馬にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "『わたしどもの言う馬が勝たなかったら、お金はそっくりかえしますよ――金一｜志で、この紙にきょうの勝ち馬がすっかり書いてある。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナショナリストは単に勝ち馬に乗るようなことはしない。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴ら、いい仕事をやってくれた、金儲けと勝ち馬を見つけてくれたから、賭けに加わることにしよう。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
