        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "スタジアムの屋根の上で、大会旗が強風に翻っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女の長いスカートの裾が、海風に翻ってひらひらと美しく舞った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ほら、あの船の帆が風に翻ってる。いよいよ出航だね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "玄関先に吊るした色鮮やかなこいのぼりが、春の風に翻りながら泳いでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その旗のをかしく風に翻るさま、衣の紐などの如く見えき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "父なる神は、古の畫工の作れる如く羽ある童に擔はれたるにはあらで、その肢體の上、その風に翻る衣裳の上に、許多の羽ある童を載せつゝ、水の上を天翔り給ふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "風に翻る鶴子の髪の毛が彼の頬を打つた。",
              "citation": {
                "source": "陽に酔つた風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "六祖｜慧能かつて二僧が風に翻る塔上の幡を見て対論するのを見た。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "『雨月物語』の中のいずれの章であったか、俺れが今度旅から帰るのは葛の葉の裏が白く風に翻るころだろうといった意味の文章があった。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "風に翻る袖、ほどけかゝつた肩掛、それが、木の葉のやうに光ります。",
              "citation": {
                "source": "遂に「知らん」文六（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後門外を歩むに耕したる水田に鳥おどしの色紙片々として風に翻るを見る。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒沢の合流点附近で昼食を済し、追々と開けて来る梓川の河原に林をなして生え茂ったドロ柳や川楊のしなやかな枝葉が河風に翻るのを美しと眺めて、足触りの柔い原始林の道を一直線に辿り、徳本峠の道と合してから、右に仰いだ明神岳の巍峩たる姿を後にして、前面に焼岳の噴烟が現れるともう河童橋である。",
              "citation": {
                "source": "秩父宮殿下に侍して槍ヶ岳へ",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）平洋の島にやどりて春見れば、草花さきて青葉しげれり鶯も鳴かずそあるらん島里は、春とはいへど梅もなければ　異域の孤島にありて連軒旭旗の風に翻るを見るは、快もまたはなはだし。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡麻竹の葉の上に霜がおりたか、風に翻るたびそれが匕首のように光る。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "千万無量の思慕を籠めた手拭が、ヒラヒラと夕風に翻ると、それを待ち構えたように、川を隔てた福井屋の二階欄干からは、赤い鹿の子絞りの扱帯が下がるではありませんか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "紅い扱帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "尽くることなく種々の面相に変わり得る彼の顔は、烈風に翻る布の裂け目よりも、更にゆがみくねった変てこな様々の渋面を作っていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
