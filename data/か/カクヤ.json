    },
    "definitions": [
      {
        "index": 1,
        "gloss": "finely chopped mixed pickles",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「お茶請けに出された覚弥のカリカリとした食感が、心地よいアクセントになっている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「祖母が漬けた自家製の覚弥は、酸味と塩気のバランスが絶妙で、ご飯が何杯でも進む。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「彩り豊かな覚弥を細かく刻んで、ちらし寿司の具材に混ぜ込んでみた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「京都の老舗漬物店で見つけた覚弥は、お土産としても非常に喜ばれる一品だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "こどもを抱いて石段をあがるところ、岡部覚弥の役で、そいつが狂女になって着物を着て、絵のすがたのとおり、はじめはネンネコヤネンネコヤとやっていて、終りに気狂いになるところをやる。",
              "citation": {
                "source": "美術学校時代の岡倉先生",
                "author": "板谷波山",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡したところ冥途もかくや、蕭寂たる幽境、一木一草も見當らんぢやないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "贄卓の上の色硝子の窓から差し入る夕日が、昔の画家が童貞女の御告の画にかくやうに、幅広く素直に中堂に落ちて、階段に敷いてある、色の褪めた絨緞を彩つてゐる。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて御料理番に折入つて、とやせむかくやせむと評議の上、一通の獻立を書附にして差上げたり。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣く聲、喚く聲、哀に救助を求むる聲は、悽まじき怒濤の音と打交つて、地獄の光景もかくやと思はるゝばかり。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "月は慘たり、月下の海上に砲火迸り、硝煙朦朧と立昇る光景は、昔がたりのタラント灣の夜戰もかくやと想はるゝばかり。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まあとにかくやつていらつしやい。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "※｜実に寒山のかなしみも、かくやとばかりふる雪に、積る……幕外へ。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、鼻紙へ密と置くと、冷い風に淡い紅……女心はかくやらむ。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡したところ冥途もかくや、蕭寂たる幽境、一木一草も見当らんぢやないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中にはいる事が出来るかどうか、まるっきり見当もつかないけれど、とにかくやって見よう。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "できるかどうか、とにかくやつてみやう。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "できるかどうか、とにかくやってみよう。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西郷隆盛もかくやと思はれるくらゐであつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の附近の田畑数町歩一面に、激戦地の跡もかくやと思はせるほど、巨大の根株や、丸太が散乱してゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ぐったりと衣紋を抜く）取る年の可恐しさ、近頃は歯が悪うて、人間の首や、沢庵の尻尾はの、かくやにせねば咽喉へは通らぬ。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから文学を留守にして、幻燈の街に出かけたり、とやかくやして、現在の僕になりました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角女異人（その對照として黒の裝束の男達も可いが）と舞子の群は、その共にでこでこした濃厚の裝束で西班牙のスロアアガの畫もかくやと思はれる美しい畫面を形造るのである。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白玉か何ぞと問いし古えも、かくやと思知れつつ、嵐のつてに散花の、袖に懸るよりも軽やかに、梅花の匂なつかしく、蹈足もたどたどしく、心も空に浮れつつ、半町ばかり歩みけるが、南無妙。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）といひかけて親仁は少年の傍へにぢり寄つて、鉄挺を見たやうな拳で、脊中をどんとくらはした、白痴の腹はだぶりとして、べそをかくやうな口つきで、にやりと笑ふ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと思ふ、かかる夕日に白銀の絹衣ゆるがせ、いまあてに花｜摘みながらかく愁ひ、かくや聴くらむ、紅の南極星下われを思ふ人のひとりも。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰌の五感は鳴り響けり、彼らは粗野なり、真に驚く、鰌のをどるは苦しきなり、彼いま燦爛かくやくたる光に飛ぶ。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄闇のほのかなる光のなかに老舗立つひと町は寡婦のごとくわれゆゑに面変り、かくや病みけむ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなあはれ空飛ぶ鳥と、地を匍ふ家の畜といつのまにかくや馴れけむ。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "黎明の不尽天地の闢けしはじめ、成り成れる不尽の高嶺は、白妙の奇しき高嶺、駿河甲斐｜二国かけて、八面に裾張りひろげ、裾広に根ざし固めて、常久に雪かつぐ峰、かくそそり聳やきぬれば、厳しくも正しき容、譬ふるに物なき姿、いにしへもかくや神さび、神ながら今に古りけむ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなあはれ空飛ぶ鳥と、地を匐ふ家の畜と、いつのまにかくや馴れけむ、なじかさはかくも親しき。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなくばアーク燈の眩ぶしい光のかげにあるかなきかに飛ぶ夜の蛍の燐光を闇の夜のそれよりも更に哀れぶかくやるせないものに感じなければならないのである。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京かくやくの夏の日は、今子午線の上にかかれり。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくやくの夏の日は、今子午線の上にかかれり。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "所詮、自由になる金は知れたもので、得意先の理髪店を駆け廻っての集金だけで細かくやりくりしていたから、みるみる不義理が嵩んで、蒼くなっていた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
