[
  {
    "uuid": "6d979990-258c-5be1-a2df-0732f19eb6bb",
    "entry": "覚弥",
    "reading": {
      "primary": "かくや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
