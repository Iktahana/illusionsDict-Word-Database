        "examples": {
          "standard": [
            {
              "text": "機織り機には、次の作品で使われるであろう綛が準備されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女は指先で綛の感触を確かめ、その質の高さを評価した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "夕日に照らされた作業場で、壁にかけられたいくつもの綛が影を落としていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
