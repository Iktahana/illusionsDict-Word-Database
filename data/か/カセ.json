  {
    "uuid": "de8173ee-8797-5068-b0f2-d4ab2aa2fbb1",
    "entry": "悴",
    "reading": {
      "primary": "かせ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-接頭辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "low",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「うちの悴せがれも、もうすぐ大学を卒業なんだ」と彼は嬉しそうに話した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "悴息子からの久しぶりの電話に、母親の声が弾んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "悴じじいなんて呼ばずに、おじいちゃんと呼んであげなさい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "丁度先客と對談中であつた彼は、ひどく憔悴して見えた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規の葬式の日、田端の寺の門前に立って会葬者を見送っていた人々の中に、ひどく憔悴したような虚子の顔を見出したことも、思い出すことの一つである。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は日々に憔悴し、血色が悪くなり、皮膚が老衰に澱んでしまった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しい月夜かなしい遠景かなしい薄暮になれば、労働者にて東京市中が満員なり、それらの憔悴した帽子のかげが、市街中いちめんにひろがり、あつちの市区でも、こつちの市区でも、堅い地面を掘つくりかへす、掘り出して見るならば、煤ぐろい嗅煙草の銀紙だ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはぜつたいぜつめいだ、おれは病気の風船のりみたいに、いつも憔悴した方角で、ふらふらふらふらあるいてゐるのだ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ながれてゆく砂と砂との隙間から、蛤はまた舌べろをちらちらと赤くもえいづる、この蛤は非常に憔悴れてゐるのである。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し私は自分と同胞の修道士の人達の顏が著しく蒼白く憔悴してゐるのを見た時、また其處に云ひ知れぬ寂しさと惱みの影を見た時、私の胸は怪しく悲しみを覺え、同時に或る驚きを感じた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの顔も蒼く憔悴していた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、思いなしか、眼の光にも曇りが出来て、何となしに憔悴した表情がこの人の全外容に表われているのであった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿本は、自分の膝に崩折れかゝったこの婦人の蒼ざめて、憔悴した、骨ばった顔を見た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へ婿君が、紋着、袴ながら、憔悴した其の寝不足の目が血走り、ばう／＼髪で窶れたのが、弔扎をうけに見えたのである。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく憔悴したつやのない青白い顔色をしてほかの人の群れから少し離れて立っていた姿が思い出される。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは本當です、現に私の一人の悴も、七八｜年以前の事、私が切に止めるのも聽かで、十｜月の祟の日に家出をしたばかりに、終に世に恐ろしい海蛇に捕られてしまいました。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十九回　薩摩琵琶春枝夫人の物語――不屆な悴――風清き甲板――國船の曲――腕押し脛押と參りませう――道塲破りめ――奇怪の少尉　春枝夫人は清しき眉を揚げ『あゝ其事！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夕べの乱れたる髪は活溌溌の鉄拐を表わせしに、今はその憔悴を増すのみなりけり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "容貌甚だ憔悴し、全身黒み痩せて、爪長く髯短し、ただこれのみならむには、一般｜乞食と変わらざれども、一度その鼻を見る時は、誰人といえども、造化の奇を弄するも、また甚だしきに、驚かざるを得ざるなり。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ながれてゆく砂と砂との隙間から蛤はまた舌べろをちらちらと赤くもえいづるこの蛤は非常に憔悴れてゐるのである。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかれは憔悴した魂をはばたいてもがくのである。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おん身がにくしんの兄はあまりに憔悴し、疾患し、酒亂のあしたに菊を摘まむとして敬虔無上の涙せきあへぬ痴漢である。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "感傷の人犀星に逢へば菓子も憔悴す。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝が念念祈祷するときに、菓子の如きものの味覺を失ひ、自働電話機の如きさへ甚だしく憔悴に及ぶことあり。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、しかし、いまは一本のかみの毛にさへ、全身の重量をささへうることの出來るまでに、あはれな病人の身體は憔悴してしまつた。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は時として私の肉體の一部がしぜんに憔悴してくることを感ずる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二つの心がわたしの胸の中でいつもかみあっておりますので、わたしはこんなに憔悴いたしてしまったのでございます。",
              "citation": {
                "source": "おしどり",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィンパーの一行は登る時には、クロス、それから次に年を取った方のペーテル、それからその悴が二人、それからフランシス・ダグラス卿というこれは身分のある人です。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄ばみ黒ずんで居た人の顏は、紅色を帶びて來て、漸く鮮やかに美しくなり、悴け萎びて、硬ばつたり龜裂したりして居た人の皮膚は、※らぎ潤ひて生氣を増し、瑞々しく若くなつて、皹凍傷なども治り、筋肉は緊張し、血量は増加したるが如く見える。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "数年前に老妻を失っても悴があるので何とも思わなかった為作は、非常に力を落したものの、やがて嫁と孫の気もちが判って来ると、それに慰められるようになっていた。",
              "citation": {
                "source": "放生津物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、持ぬしは、意気沈んで、髯、髪もぶしょうにのび、面は憔悴はしていたが、素純にして、しかも謹厳なる人物であった。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもおまへはわがままに親しい人だと歌つてきかせる。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち意欲すべきものといふより、おのづと出来るにまかせるべきものといふことである。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
