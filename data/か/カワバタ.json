        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夕暮れ時、川端には犬の散歩をする人々の姿が見られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_content": "川端に建つ古民家は、風情があって絵になる風景だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "川端のカフェで、涼しい風に吹かれながら読書を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "牧牛会社の前までくると日が入りかかって、川端の榎の霜枯れの色が実に美しい。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時又は川添ひの間の宿で、一寸した料理屋が川端にある。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "正宗白鳥氏と、川端康成氏と、それから他の二三氏とが、新聞紙上にこれを論じ、そろつてみな僕の主旨に同感を表してくれた。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の一文から演繹された、川端康成氏の室生犀星論（朝日新聞）は適評だつた。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川端氏は僕と同じく、日本文壇に於ける傳統的東洋趣味の横行（それが西洋的近代文學の發育を妨げてる）を悲しんでゐる。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川端氏の室生君に對する言葉が、おそらくかうした複雜な感情を内包してゐる。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝川端　川面に垂れ下った柳。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「釣り合はねえ」　川端を去って行く八百屋。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝（Ｆ・Ｉ）川端　柳の木の下に悲恋に泣く男女の姿。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お光、Ｔ「一昔前なら　そんな嚇しも　利いただろうにね」　とせせら笑って五郎蔵を見て、Ｔ「此の間の晩　大川端でお武士に　投げ飛ばされて　ギュッと言わされたのは……　親分、あれは一体　誰でしたっけねえ？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）川端　君江が悲しそうに何度か※躇した後、遂に飛び込まんとする。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝橋の上――夜　お殿様と老臣と家臣が五名程川端を歩いて居る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝元の川端――夜　文六逃げて来た。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは門司市、東川端の卑猥な街、カアルトン・バアの青い給仕人の花風病の体温、ロシア女の新らしい技術の中で無頼漢の唄う流行歌。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "川端竜子の絵もある意味であたまは働いているが、いつも少し見当のちがったほうへ働いていはしないか。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その妹のお道といふのは、四年前に小石川西江戸川端の小幡伊織といふ旗本の屋敷へ縁付いて、お春といふ今年三つの娘まで儲けた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　妹を自分の屋敷に殘して置いて、松村は草履取一人を連れて、すぐに西江戸川端に出向いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "西江戸川端の屋敷には主人の小幡伊織が居あはせて、すぐに座敷に通された。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "３＝生島屋の附近　川端で土蔵の白壁が見えて居て柳の木が一本ある。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "川端に土左衛門が置かれてある。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "川端を逃げる深編笠の侍。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝六舟を岸へ着けて川端を追う――　右門船頭を抱き起した。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "１５＝川端の寺のある処　深編笠の侍は其処の土塀を飛び越えて姿を消す。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
