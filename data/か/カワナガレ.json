    },
    "definitions": [
      {
        "index": 1,
        "gloss": "being carried away by a current",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "不注意で川に落ち、激しい流れに川流れしそうになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "船が沈没し、乗客たちは次々と川流れしていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「助けて！川流れしちゃう！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "鯉を釣りあげ損じて、川流れになった筈の為さんが無事に寝ているというのは案外であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門が微笑んで、Ｔ「河童の川流れか」Ｔ「へッ」　と伝六。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "引かれて、やがて蔭ある処、小川流れて一本の桐の青葉茂り、紫陽花の花、流にのぞみて、破垣の内外に今を盛りなる空地の此方に来りし時、少年は立停りぬ。",
              "citation": {
                "source": "紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山々高く聳えたる間より細き谷川流れ出て海に落る。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "身｜退いて　即ち長往し、川流れて　去つて復ること無し。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点でもやはり龍代の見込みが百パーセントに的中していたのかも知れませんが、元来、風来坊の川流れであった私が、それから後というものは、龍代にも負けないくらい性格の一変ぶりを見せましたもので、どこで得た知識かわかりませんが、自分でも驚くほどの才能を発揮し初めたものです。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の凹める處は、小川流れ、水田あり。",
              "citation": {
                "source": "東京の近郊",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、箱書に「昨日と過ぎ今日と暮して飛鳥川流れて早き月日なりけり」と認めて、その儘使ひならしたものだつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生から大概な人はそれをやらないから、瓢箪の川流れみたようになッてしまう。",
              "citation": {
                "source": "人格の養成",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫌だからとて「瓢箪の川流れ」のごとく浮世のまにまに流れて行くことは志ある者の快しとせざるところ、むしろ愧ずるところである。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "漣織りて月照りて夕暮たのしいさゝ川流れ／＼て行く水に秋も近しと眺むればいかに惜まむあゝ夏よ。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「川流れだあ」　この声で米友が思わず飛び上って、例の地団太を踏みました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちぇッ」　地団太を踏んで、激しく身ぶるいをすると、「川流れだあ」　続いて罵り騒ぐ声がするものですから、「それ見たことか」　米友は身ぶるいして、槍を取り直して意気込みました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちぇッ」　走りながらも、身をふるわして憤りを発しているところを見ると、その川流れ！",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だから、言わねえこっちゃねえ」　ただ遠音に、川流れの警告を聞いただけで、米友の発憤ぶりは何事だろう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま叫ばれた川流れの本尊こそは余人ではない、わが道庵先生に相違ない、と早くも独断してしまっている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちぇッ」　幾度か舌打ちをして、もどかしがり、子獅子が千仞の谷から、こけつ、まろびつ、這い上るような勢いで、川下の、その川流れの、溺死人の、独断の推定の道庵の土左衛門の存するところに、多数が群がり集まって、罵り騒いでいる方向に飛んで行きました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "米友は最初から、そう断定してかかっているのですから、「御免なさい、その川流れというのに一目逢わせておくんなさい、気がせいてたまらねえ」　人を掻きわけるようにして寄って見ると、そこには道庵らしい人は見えません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "3880石を繞り、草を穿ちて、広き川、狭き川流れ落つ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「窪田君のような隅田川の河童がいるんですから、万事この人に任かせておくといいです」「河童が川流れをするようなことはあるまいね」と久野は自身で、警句のつもりで言った。",
              "citation": {
                "source": "競漕",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、小さいながら川流れが二筋に分れて、どうしてもそれよりは進めないところに来ました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "drowning in a river",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "残念ながら、行方不明だった子供は川流れで亡くなっているのが発見された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "事故で川流れした友人の捜索が続いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "cancellation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "計画していたイベントは、悪天候のため残念ながら川流れとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "約束した rendezvous は、相手の都合で川流れになってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「え、今日の約束、川流れなの？がっかりだなあ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
