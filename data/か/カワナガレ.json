[
  {
    "uuid": "47d454a9-6489-5e31-a2fa-a2282809eda4",
    "entry": "川流れ",
    "reading": {
      "primary": "かわながれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
