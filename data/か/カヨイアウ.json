    "definitions": [
      {
        "index": 1,
        "gloss": "to communicate with each other",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "遠く離れていても、手紙で近況を伝え合い、心を通い合わせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "二人は、言葉はなくとも、互いの瞳を通して深く通い合っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "SNSを通じて、世界中の人々がアイデアを交換し、通い合っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "親子がお互いの気持ちを理解し、温かく通い合う時間は大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "歴史上の偉人たちも、書簡を通じて思想を共有し、通い合っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "真に恋する同志には、たといどんな障碍物がその間に横わって居ろうとも、かのラジオの電波が通うように、その心臓の搏動の波は互に通い合うと思う。",
              "citation": {
                "source": "恋愛曲線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、三人の夢が、幻像を画いて通い合うとすれば、自分が帰った後の蒲団には、舞台姿の逢痴が横になっていて、その側から掻巻をかかげ、入り込もうとしている久米八は、さぞ自分が残した、温かみに眉を顰めることであろう。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、それが、妙に自分とばかり通い合う、奇異な存在ではないかとも考えられてきた。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの身体の血がお互いに通い合うかと思われた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "封建時代の自由恋愛が、どんなに恐しいものであったか、青侍と将軍の娘の胸にも、赤い血が通い合うという、――これが奇談でなくて何でしょう」　小栗緑太郎はそう言って壇を下りました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "夢幻の恋",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ一郭に住んでいるというだけで、お互いに通い合うものもほとんどない人々が、なんとなく顔をつき合わせて暮している恰好でした。",
              "citation": {
                "source": "Ｓの背中",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
