        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は人格者として知られているが、金銭にルーズだという瑕瑾があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "どんなに素晴らしい芸術作品にも、探せば何かしらの瑕瑾は見つかるものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この論文は全体的によく書けているが、結論部分の論理展開に若干の瑕瑾が見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "shame",
        "register": "standard",
        "nuance": null,
