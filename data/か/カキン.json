    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(domestic) fowl",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この農場では、鶏や七面鳥といった家禽を平飼いで育てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "鳥インフルエンザの発生により、多くの家禽が殺処分される事態となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "スーパーの精肉コーナーには、様々な種類の家禽の肉が並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "それへ家禽か牛肉のスープで汁気たっぷりに煮込んだ栗を混ぜる。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人の邸で屡々家禽を何者にか盗まれる。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が朋輩の家禽や牛馬の夥伴では、日本産でも純粋種は大切にして雑種は賤んでおるさうだ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、現在の私の宅と同町内で、その頃｜長寿斎という打物の名人があった、その横丁を曲がって真直突き当った家で、いろいろ家禽が飼ってあった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "矮鶏のモデルを探したはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、以前、葉茶屋の狆と、戸川さんの狆との対照のこともあるから、家禽専門家の言葉を信用せぬわけには行きません。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "矮鶏のモデルを探したはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは型にはめていじめて作ったもので鉢植えの植木と同様、そういう不具物を見本にしたのではフランスの家禽通が承知をしまい。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "矮鶏のモデルを探したはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "家宅倉庫の浸害に因れる家畜家禽の斃亡。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくとも、その窓の下の狭い庭はあらゆる家禽や家畜で一杯になっていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルヌ河に沿うた古い町で、パリに供給する小麦・チーズ・卵・家禽・野菜などの多くは此処から運ばれると聞いていたが、通りすがりに一番に目を惹いたものは、街路の左側に高い方塔を一つ聳やかしたゴティク様式の古いカテドラルだった。",
              "citation": {
                "source": "ヴェルダン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――最も合理的に耕作された田畑、緑の樹蔭に掩はれた村、肥えて嬉々として戯れてゐる牧獣や家禽の群、薫ばしい草花に包まれた家屋、清潔に斉然と整理された納屋や倉、……甦つた農業！",
              "citation": {
                "source": "新らしき祖先",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "農婦はその足もとに大きな手籠を置き家禽を地上に並べている。",
              "citation": {
                "source": "糸くず",
                "author": "LA FICELLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "家禽は両｜脚を縛られたまま、赤い鶏冠をかしげて目をぎョろぎョろさしている。",
              "citation": {
                "source": "糸くず",
                "author": "LA FICELLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の前には広場の様な処が有って、野生の草花が咲いたり、家禽などが群れて居る。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この村人の育うものは、鳥では一番に鶏、次が七面鳥、家鴨などはまれに見るもので、一軒の家に二三匹ずつ居る大小の猫は、此等の家禽を追いまわし、自分自身は犬と云う大敵を持って居るのである。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まめに働く女房も、家政を見るやら、家禽の世話をするやら、いろいろと仕事があった。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "獵の獲物や家禽、また其の他食卓の珍味が村々の間で取引されてゐた。",
              "citation": {
                "source": "驛傳馬車",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "猟の獲物の鳥獣や、家禽や、その他の珍味が、村々には景気よく出まわり、食品店、肉屋、果物屋には人がつめかけていた。",
              "citation": {
                "source": "駅馬車",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただもう世間並みに付和雷同し、個性なき食物、いわば家禽の如く宛てがい扶持に大事の一生をまかせているかである。",
              "citation": {
                "source": "味を知るもの鮮し",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "家禽屋だの食料品屋だのの商売は素晴らしい戯談になってしまった。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "柊も、寄生樹も、赤い果実も、蔦も、七面鳥も、鵞鳥も、猟禽も、家禽も、野猪肉も、獣肉も、豚も、腸詰も、牡蠣も、パイも、プッディングも、果物も、ポンス酒も、瞬く間にことごとく消え失せてしまった。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔬菜市場、家禽市場などがこれである。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔭で、平和な家禽一同をいっときホッとさせる。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "しからば、『もし穀物、及びその他の全然人間の勤労によって作られる如き野菜類を別とすれば、すべての他の種類の粗生生産物――家畜、家禽、すべての種類の獲物、地中の有用な化石や鉱石類等は、社会が発展するにつれて当然より高価になる。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "家とか道具とか家畜とか家禽とか、特に男女の人物とかがそれである。",
              "citation": {
                "source": "人物埴輪の眼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝夕、家畜や家禽に飼料をやるのが仕事であつた。",
              "citation": {
                "source": "秋の雲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は畑仕事の経験といへば、少年の頃郷里の実家で父や兄の後にくつついて野良に出たこともあり、朝鮮で、十年間、これも本職は家畜家禽の飼育であつたが、やはり、農園といへば水田も畑もあつたから、忙がしい時には馬耕の助手にもなり、果樹の消毒や麦の種蒔きなどに駆り出された。",
              "citation": {
                "source": "秋の雲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "進化唱来三十年、一声能破万夫眠、家禽淘汰鑑人力、生物起源帰自然、埋骨帝王廟前地、留名学界史中篇、請君長臥九泉下、誰怪偉功千歳伝。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦場における人命の浪費に加えて、戦勝者は一般に敵の領土を荒し廻り、豚や家禽を殺したり、運び去ったりし、そして将来の生活資料を出来るだけ減少してしまう。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "時にはプレインと称せられ、ロシア人はステップと呼ぶ、灌木のない茫漠たる草原は、豊富な牧草に蔽われ、多数の家畜や家禽の牧場に非常に適している。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "』Sir John Chardin's Travels, Harris's Col. b. iii. c. ii. p. 865.　異教韃靼人、カルマック族、及び蒙古人は、奴隷を使用せず、そして一般により平和な無害な生活を送り、彼らの唯一の富を成す家畜と家禽の生産物で満足している、と云われている。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
