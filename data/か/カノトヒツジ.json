        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "叔父は辛未の年に生まれたと聞き、牧歌的な雰囲気を纏っているなと感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "辛未の年に創業した会社は、着実に成長を続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地方では、辛未の年には豊作になるという言い伝えがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "四年（辛未）　一八七一○一月、中村翫雀大阪より上京し、守田座における御目見得狂言の三浦之助、好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿二日、辛未、霽、禅師公登壇受戒の為に、定暁僧都を相伴ひて上洛せしめ給ふ、将軍家より、扈従の侍五人を差遣はさる、是御猶子たるに依りてなり。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日、辛未、天晴、風静なり、今日申剋、御所の上棟なり、相州以下諸人群参す。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一日、辛未、晴、若宮辻の人家焼亡す、酉戌両時の間、廿余町悉く灰燼と為る。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七日、辛未、霽、将軍家の御持仏堂の御本尊、運慶造り奉り、京都より渡し奉らる、開眼供養の事有る可し、信濃守行光奉行として其沙汰有り。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四年辛未、二十五歳。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚引続いた翁の手記に、「明治四年辛未十月｜下拙（翁）退隠。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「初代有信、通称徳兵衛、父流芳院春応道円居士、元禄四年辛未五月十八日、二十二歳」と云ふのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」此によつて逆算するに、若し二人が此年に相識つたとすると、辛未より丙子まで数へて、丙子は第六年となるのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陽が歳暮の詩に「一出郷国歳再除」と云つたのは、庚午の除夜を神辺で、辛未の除夜を京都で過すと云ふ意である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次年八年辛未二月二十一日には嵯峨の竹里の家が出来た。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "辛未の春より初夏に至るまでは、霞亭が已に竹里にゐたからである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "樵歌に「辛未二月予将卜居峨阜、留別社友諸君」の詩がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その百四十七　北条霞亭の竹里の家に宿つた韓凹巷等五人の客は、翌日辛未三月二十九日に、主人と共に嵐山に遊んだ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "辛未の三月は小であつたので、二十九日が春尽になつてゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その百四十八　北条霞亭は辛未十月三日に任有亭から梅陽軒に移つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "辛未二月より六月に至る、竹里に於る初期、六月より十月に至る、任有亭に於る中期、十月より壬申の春初に至る、梅陽軒に於る後期、霞亭の嵯峨生活は此三期を合して約一箇年に亘つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "霞亭は辛未二月十九日に竹里に来て、六月四日に去つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "吟平は辛未の日録に見えてゐる榎本吟平か。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "年は辛未三十歳であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三百五十四　明治辛未四月十一日後の棠軒日録を続抄する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "辛未に政太郎が早世したとすると、其｜齢は二十五歳で、父の六十五歳の時に終つたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三百五十五　明治辛未八月二十一日後の棠軒日録を続抄する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "孫祐の死は棠軒日録の辛未の部に見えない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "枳園は前年辛未の夏実子｜約之を失ひ、冬｜妻勝を失ひ、家を養嗣子亀三郎に託して此遊の途に上つたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "八年辛未　平八郎十九歳。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「明治四｜辛未歳五月二十八日｜建之」　空には秋の風が鳴っていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和六年｜辛未三月九日病中起筆至五月念二夜半纔脱初稿荷風散人",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝暦紀元｜辛未の年二十四歳にして始て江戸に来り芝三島町に家塾を開いたが宝暦十年二月の大火に遭い、身を以て免れ日本橋｜浜町山伏井戸の近くに移居した。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四十　明治四年辛未の春毅堂は司法省出仕を命ぜられ宣教判官に任ぜられた。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
