[
  {
    "uuid": "54fe47fb-526b-5df7-a920-b42e674c83a5",
    "entry": "関心を持つ",
    "reading": {
      "primary": "かんしんをもつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
