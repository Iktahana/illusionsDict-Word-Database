        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ヨガのポーズで、みんな片足立ちで集中していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "片足立ちの状態で靴下を履こうとして、危うく転びそうになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は片足立ちでバランスを取りながら、器用に靴を履いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "僕のではない、他の中隊の一卒で、からだは、大けかったけど、智慧がまわりかねた奴であったさかい、いつも人に馬鹿にされとったんが『伏せ』の命令で発砲した時、急に飛び起きて片足立ちになり、『あ、やられた！",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "片足立ち上るやいなや、右腕を挙げて思いきりピイプザアムの胸を突いたので、ピイプザアムは五六歩たじたじとうしろへよろけた。",
              "citation": {
                "source": "墓地へゆく道",
                "author": "DER WEG ZUM FRIEDHOF",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたづけてやる」　言下に、男は片足立ちとなって、その体を、舟の外へ斜に描いて見せた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "片足立ちに、脚を交しながら、唯七の二度目の後薙ぎが、貞之進の顔を斬った。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、その上で、一人の敵とわたり合っていた木村岡右衛門が、平八郎と背中あわせにぶつかって、『吉良方かっ』　と、前の敵へ向けていた刀で、平八郎の腰を撲り、自分も、片足立ちに蹌めいて、隅の板壁へ勢いよく体をぶつけた。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、風でも吹き去ったのか、そのまま誰も入ってくる様子はないので、かれは片足立ちになって、わらじの緒を結んでいた。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "木曾の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなりその剣風をくらッて、吹ッ飛ばされたかのごとく、あッ――と後ろへ片足立ち、気当を返して腰の太刀を、「おうッ」とすぐに抜きあわしたが、無論、自分の体を退いているので、その払いは虚にして空、キリキリ舞いをやったにすぎない。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "木曾の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
