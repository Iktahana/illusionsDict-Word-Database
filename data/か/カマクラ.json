[
  {
    "uuid": "6bc832fd-096a-52f5-a8bc-ca841d1b19cc",
    "entry": "かまくら",
    "reading": {
      "primary": "かまくら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mid-January festival in northern Japan, with snow huts in which children play house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "雪深い秋田では、子供たちがかまくらの中で楽しそうに遊んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "今週末、地元の祭りでかまくら作り体験ができるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わー、かまくらだ！入ってみようよ！」と、友達が提案した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "かまくらの中は、外の寒さとは別世界のように暖かかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "かまくら時代の百鬼夜行の絵巻物には、この妖怪がへんに生々しくかけているが、皆足を持ち、様々な姿態をつくして活動している。",
              "citation": {
                "source": "ばけものばなし",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "又かまくらを生て出でけん初松魚と云ふこそ心の骨折人の知らぬ所なり。",
              "citation": {
                "source": "芭蕉雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "東北では、かまくらと言うて、小正月に雪の洞窟を作つて幸の神のお祭りをします。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを「かまくら」と言うている。",
              "citation": {
                "source": "石の信仰とさえの神と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "年頭に、男の子たちが、鳥小屋・かまくら・道祖神小屋などに籠るのと、一つ意味のものであるが、かうして分居した団員が、その謹慎によつて、新な社会的資格を得る様になつた、と見る事が出来る。",
              "citation": {
                "source": "たなばたと盆祭りと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「このみちは、とうかいどうと　かまくらかいどう　みたいな　ものです。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただまえに挙げた『増かがみ』のものがたりをあたまにおいてかまくらの初期ごろにここで当年の大宮人たちが四季おりおりの遊宴をもよおしたあとかとおもうと一木一石にもそぞろにこころがうごかされる。",
              "citation": {
                "source": "蘆刈",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この第十二巻「かまくら殿の巻」は、巻の名を按じるとき“浮巣の巻”としようか“おん国母の巻”としようか、などと思い惑ったほど、内容は、東国の頼朝中心のうごきと、京、福原における平家晩鐘の中の話とが、ちょうど、半々になっている。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまでも「新・平家物語」は、平家が焦点ではあるが、そんな意味からも、一巻には、源氏を象徴する巻があってもよいかと思い「かまくら殿の巻」に決めた。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "snow hut",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「見て！庭に大きなかまくらができたよ。中でお餅焼いて食べよう！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "横手の雪まつりで、ライトアップされたかまくらが幻想的に並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供たちが身を寄せ合って、かまくらの中で内緒話に花を咲かせている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「かまくらの中って、意外と風がなくて暖かいんだね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
    ],
    "relations": {
      "homophones": [],
