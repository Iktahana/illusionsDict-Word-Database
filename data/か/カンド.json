[
  {
    "uuid": "6c6e027c-1837-505a-9e64-d804c9a689ff",
    "entry": "感度",
    "reading": {
      "primary": "かんど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
