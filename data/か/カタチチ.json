        "examples": {
          "standard": [
            {
              "text": "赤ちゃんは母親の片乳に吸い付いて、満足そうに眠りについた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "事故で片乳を失った女性が、勇気を持って人前で話した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は病気で片乳を切除したが、力強く生きていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「鬢のはずれの頸脚から、すっと片乳の上、雪の腕のつけもとかけて、大きな花びら、ハアト形の白雪を見たんです。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――幸坊はあたしの子だわ、あたしが苦労して育てて来たんじゃないの、誰にだって捨てろなんて云われる筈がないわ、たとえ庄さんにだって、……ねえ幸坊、あたし幸坊もう決して放しゃしなくってよ」　子供は泣きじゃくりながら、片手できつく乳房を握り、片乳へ顔のうまるほど吸いついていた。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
