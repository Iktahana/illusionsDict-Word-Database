        "examples": {
          "standard": [
            {
              "text": "川向かいに見える大きな屋敷は、昔からの地主の家だそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "橋を渡って川向かいの商店街へ、買い物に出かける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「見て、川向かいに虹が出てる！」と彼女が指差した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "川向かいの山の斜面が、紅葉で赤く染まっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "十日市という川向かいの町はずれに借家住居していられたが、七つ、八つ位な可愛らしいお嬢さんを連れて路ばたで遊ばしていられるのを時々見た。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして帰る日の朝には、宿の川向かいの貧しい家に夏蚕を飼っているのを勤労の心地で眺めたり、宿の寡婦の淋しい身上話をしみじみと聞いてやれるほどおちつきを得ました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
