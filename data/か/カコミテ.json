        "examples": {
          "standard": [
            {
              "text": "かるた大会では、囲み手の技術が勝敗を分ける重要な要素となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は囲み手が得意なので、詠み始めと同時に多くの札を取ることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "囲み手は、相手の動きを読んで素早く札に触れるための、熟練を要する戦略だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "俗気なき人と碁をかこみて、黄昏に至りて、碁の目見えわかねば、しばし子を下す手をとゞめて、浮世の外のこと語らふほどに、眉目いつしかあきらかになれるに、顧みれば梅が枝まるまどにうつりて、さながら一幅の墨画の如し。",
              "citation": {
                "source": "月譜",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "喬松とりかこみて、桃を擁護するに似たり。",
              "citation": {
                "source": "小利根川の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃林は、之をかこみて、二三町四方にひろがる。",
              "citation": {
                "source": "春の郊外",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ町の雜沓をはなれたるを取柄に、二階の六疊の一間に、三人火鉢をかこみて、ぬれたる衣かわかしなどす。",
              "citation": {
                "source": "房州紀行",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "巖の中より滴るしづく、滴り／＼て、凍りて大氷柱をなし、小龕をかこみて、白玲瓏たり。",
              "citation": {
                "source": "冬の榛名山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "木枯さけぶ夜すがら手摺れし火桶かこみて影もおぼろなる燈火の下に煮る茶の味は紅楼の緑酒にのみ酔ふものの知らざる所なり。",
              "citation": {
                "source": "矢はずぐさ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "日中しづけく　委曲らに聞ゆ凍て雪の坂ののぼりに、鞍高く乗り来る人の馬を　すぐしつ馬込　大森町中の馬場のほこりに　むれあそび、子ら声あぐる　七草もすぎこの寺や、南面に　清らけく墓をかこみて、夕づきにけり切りくづす崖かたつきに、作事場の男の子飯焚く。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
