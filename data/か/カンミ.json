[
  {
    "uuid": "80c4904f-134d-5663-b62e-3c597da13f70",
    "entry": "鹹味",
    "reading": {
      "primary": "かんみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
