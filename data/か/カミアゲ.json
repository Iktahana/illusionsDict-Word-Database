    "definitions": [
      {
        "index": 1,
        "gloss": "wearing one's hair up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「お嬢様、本日の晩餐会に向けて、美しく髪上げをいたしましょう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "着物に合わせて髪上げをすると、首筋がすっきりして大人びた印象になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "当時の女性たちは、日常の作業をしやすいよう、簡単に髪上げをして過ごしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "意匠を凝らせた贈り物などする場合でなかったから、故人の形見ということにして、唐衣と裳の一揃えに、髪上げの用具のはいった箱を添えて贈った。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "中宮から白い裳、唐衣、小袖、髪上げの具などを美しくそろえて、そのほか、こうした場合の贈り物に必ず添うことになっている香の壺には支那の薫香のすぐれたのを入れてお持たせになった。",
              "citation": {
                "source": "源氏物語",
                "author": "行幸",
                "note": "青空文庫"
              }
            },
            {
              "text": "中宮のおいでになる御殿の西の離れに式の設けがされてあって、姫君のお髪上げ役の（正装の場合には前髪を少しくくるのである）内侍などもこちらへ来たのである。",
              "citation": {
                "source": "源氏物語",
                "author": "梅が枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "院が昔このお后の入内の時お贈りになった髪上げの用具に新しく加工され、しかももとの形を失わせずに見せたものが添えてあった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "明後日コロンボに入ると云ふ日の夜、音楽会のありとてベツカの君誘ひ給ひたれば、例は波の音に唯聞き耽りて過ぎし日のまぼろしを追ふ頃を、髪上げ衣更へて甲板に出で申し候ふに、はや会場の整ひ居り候ふて、私は招かるる儘に大使の姪とやらん聞えたるスペインの貴婦人に並びて前列の椅子に着き申し候。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「三寸の人」は三月ほどの間にすくすくと成長して、「よきほどなる人」になり、髪上げや裳着せなどをする。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その時、荷馬車がちやうど橋を渡りきつてしまつたので、その言葉尻はもう聞き取れなかつたが、若者はそれなり鳧をつけてしまふのが業腹だつたと見えて、よくも考へないで咄嗟に泥土をひと塊りつかみあげるなり、それを女房のうしろから投げつけた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「食えるだけ食うんだよ、おれは朝飯前に柔道のけいこをしてきたから腹がへってたまらない、焼き豆腐があるか」「はい」　チビ公が蓋をあけると巌はすぐ手をつっこんだ、それから焼き豆腐をつかみあげて皮ばかりぺろぺろと食べて中身を大地にすてた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「火を慕って来おったのかも知れませんな」「そうかも知れぬ」　大野順平は腰をかがめて、その後脚をつかみあげた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨谷君はびっくりしたが、彼はもともと勇気があったから、立ちあがってお釜をつかみあげた。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と申しますと、大男は、又メツツをつかみあげました。",
              "citation": {
                "source": "プリンス・アド",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はオッチョコチョイだから、ざんぶと飛びこみ、川の底をもぐり廻つて、忽ち死体をつかみあげた。",
              "citation": {
                "source": "ぐうたら戦記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お魚女史は軽蔑しきって、弁吉の手を押しのけて、箱をつかみあげて、サッサとそれもフトコロへ入れてしまった。",
              "citation": {
                "source": "お魚女史",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、いきなりカエルをつかみあげると、ありったけの力をこめて、壁にたたきつけました。",
              "citation": {
                "source": "カエルの王さま",
                "author": "または鉄のハインリッヒ",
                "note": "青空文庫"
              }
            },
            {
              "text": "モオリーがそれほど深刻におれを忌避していようとは知らないし、ちょうど退屈している折だったので、一席、鮭の比較論をやってやると、モオリーは鮭の山から犬鮭を一尾つかみあげて、逆吊りにしてつくづくと眺めてから、「Yep’, he’s look like it.」　やあ、よく似てる、といっておれの顔をみた。",
              "citation": {
                "source": "南部の鼻曲り",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ、とばかりふらつく両手につかみあげた男靴女靴をあたりかまわず赤い絨毯の上へばらまいたらしく、女のよそゆきのエナメル靴、男靴が、そのやけっぱちな無茶苦茶ぶりに何とも云えないおかしみをたたえながら、あっちこっちにぶちまかれているのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えっ」とかんぷりは眼をみはり、きおいこんでバケツの中から鮒をつかみあげ、――それはもっとも大きな一尾であった、――私のほうへと突き出しながら云った、「しょっからへいってみせえま、このくれえの鮒は一つで五ひゃくもすんだぞ、先生」　このちび助のユダヤ人め、と私は心の中で罵った。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッとハズミがついたとき、彼は躍りかかって、あやかさんをつかみあげ、大きく一回転振り廻して振りとばした。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがの四十面相も、この怪異を見て、びっくりしましたが、たちまち、ことのしだいをさとって、そこにころがっている小林少年の胴体を、つかみあげました。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨人の腕は、ほんとうに、森の中へおりてきて、白犬をつかみあげていったのです。",
              "citation": {
                "source": "天空の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、あのとき、井上君か、ノロちゃんか、どちらかがつかみあげられたら、どうだったでしょう。",
              "citation": {
                "source": "天空の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨人の腕に、つかみあげられたときは、目がまわって、気をうしなってしまったが、ふと、目を開くと、高い空を、ヒューッ、ヒューッと、風のように、とんでいることがわかったそうです。",
              "citation": {
                "source": "天空の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにノロちゃんは、おとといの晩、犬がつかみあげられるのを、その目で見たんだろう。",
              "citation": {
                "source": "天空の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "貨車｜昇天　巨人の腕は、動物や人間をさらったばかりでなく、こんどは、あの大きな重い貨物列車を、雲の上へつかみあげていったのです。",
              "citation": {
                "source": "天空の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だが、貨車を一つだけつかみあげたとすれば、七両めからあとの貨車は、連結が切れてしまうから、そこにとりのこされたはずじゃないか。",
              "citation": {
                "source": "天空の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニワトリが盗まれたことだとか、牛が足をおったことだとか、畑に、大きな穴があいていたことだとか、それから、きみたちのうちふたりが見た、白犬が、つかみあげられたことだとか……。",
              "citation": {
                "source": "天空の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右からも前からも、途端に、物の具の固い腕が、彼女の嫋よやかな腕くびをつかみあげて、『ここは、北条方の里見義介が陣だ。",
              "citation": {
                "source": "篝火の女",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
