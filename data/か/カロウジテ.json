[
  {
    "uuid": "7d0d3707-6604-53b0-966c-0f9009d3e69d",
    "entry": "辛うじて",
    "reading": {
      "primary": "かろうじて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
