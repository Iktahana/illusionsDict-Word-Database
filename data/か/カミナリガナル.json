    "definitions": [
      {
        "index": 1,
        "gloss": "to thunder",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夕立の前に、遠くで雷が鳴り始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゴロゴロと雷が鳴り、空が暗くなってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "真夏の午後はよく雷が鳴る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "突然、大きな音で雷が鳴り響いたので、猫が驚いて飛び上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "何故と言ふに、それを行つた日に限つて、不思議に雷が鳴るからである。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし万吉が牢内できょうは雷が鳴ると云ったら、果たしてその日の夕方に大きい雷が鳴って、十六ヵ所も落雷したと云って、明治になるまで牢内の噂に残っていました」「じゃあ、きのうはその海坊主に天気予報を聞いて行けばよかったですね」と、わたしは云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父は例の通りに、朝から家を出たぎりですから、叔母ひとりが頻りに心配しているうちに、夕立が降ってくる、雷が鳴るというわけで、母も妹も不安がますます大きくなるばかり。",
              "citation": {
                "source": "蜘蛛の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、雷が鳴ると、その屋敷から諸越のところへ御見舞の使者が来ることになっていました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "風が吹く、雨がふる、雹が降る、雷が鳴る、実にさん／″＼な天気の真最中に、大次郎は駕籠でのり出しました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷７・16（夕）　梅雨が明けて雷が鳴る頃になつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷が鳴るとせいせいしていい気持ちだけれど、シボレーの古自動車なので、雨がガラス窓に叩かれるたび、霧のようなしぶきが車室にはいってくる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷が鳴るとせいせいしていゝ気持ちだが、シボレーの古自動車なので、雨がガラス窓に叩かれるたび、霧のようなしぶきが車室にはいる。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷が鳴る――はらはらしたのは仲にたつ人々であった。",
              "citation": {
                "source": "一世お鯉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "まい日七、八回の驟雨があり、ごうごうと雷が鳴る。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "くさめをすると、まるで雷が鳴るやうな、凄い音がして、木や草は嵐にあつたやうに吹きなびかされる。",
              "citation": {
                "source": "虹猫の大女退治",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄黒い雲が足下に一｜面にひろがっていて、遠くの下の方で雷が鳴るような音がしていました。",
              "citation": {
                "source": "強い賢い王様の話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉さまはじっとわたしの顔を見ていらしたが、ふいに、雷が鳴るまでここから発つのはやめたいと、子供のようなことをお言いなさる。",
              "citation": {
                "source": "牛乳と馬",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷が鳴るたんびに、眼の色は変つてたが、あれツとかなんとか言つて、人に抱きつかないところは、たしかに女丈夫の面影がある。",
              "citation": {
                "source": "村で一番の栗の木（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷が鳴るのでもない。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中、雨が降つて雷が鳴る。",
              "citation": {
                "source": "三太郎の日記　第三",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "◎お乙女｜姉さんはお仁王と綽名された丈け中々元気で、雷が鳴る時などは向鉢巻をして大鼓を叩いてワイ／＼と騒ぐ様な人でした。",
              "citation": {
                "source": "千里の駒後日譚拾遺",
                "author": "楢崎龍、川田雪山",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに交って雷が鳴る。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『雷が鳴るときに』とエミルが云ひました。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故電光が済んでから雷が鳴るんでせうか。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『電光が閃いてから、雷が鳴るのが聞え出す瞬間まで何秒かゝるか計つて置くと、暴風雨の雲とお前との間の距離が解るのだ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの母は雷が猛烈にきらいで、どういうわけだったのでしょう、考えてみれば滑稽だけれどひどく雷が鳴ると子供を三人自分の膝の前へかためて坐らせて、頭の上から黒いゴム布をかぶせて、息もつかないようにしていました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬱陶しい、忌々しい、さりとて雷が鳴るまでは、どうにもならぬのが竜之助の剣術ぶりです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "壬生と島原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったが、ともかく日本広しといえども、砂漠で雷が鳴ることを知ってるのは、俺一人であろうと、私は得意になった。",
              "citation": {
                "source": "雷嫌いの話",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷が鳴ると中途半端に作られたメウシが空から落ちてくると彼が言明したとリップマンは述べている。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨を呼ぶか、雷が鳴るか、穴山軍勝つか、胡蝶陣勝つか？",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
