        "examples": {
          "standard": [
            {
              "text": "その柔道大会は、勝ち抜き戦で優勝者が決まる過酷な形式だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は地区予選の勝ち抜き戦で、あと一歩のところで敗退してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回のゲーム大会は、総当たりのリーグ戦ではなく、シンプルな勝ち抜き戦形式が採用された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それからミドル級の勝ち抜き戦になり、終りのヘビー級となると一対一か、せいぜい三者対立くらいで勝敗を争うことになる。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
