[
  {
    "uuid": "1e862753-525e-548e-bd83-d3e81ec9d325",
    "entry": "変わった",
    "reading": {
      "primary": "かわった",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-語幹"
      ],
      "ctype": null,
