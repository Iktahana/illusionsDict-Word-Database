        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "忘れ物を思い出し、慌てて教室へ駆け戻った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "サイレンの音を聞き、人々は安全な場所へ駆け戻り始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「お母さん！」と叫びながら、迷子になった子供が母親の元へ駆け戻る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "女中はそのまま母屋へと駆け戻るが、走りながら振り返ってみると、その不審者は窓から身を乗り入れるようにしていたという。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いなしか、顔のこしらえまで、――傍にならんだのとそっくりなのに、聾桟敷一驚を吃する処に、一度姿を消した舞妓が一人、小走りに駆け戻るのと、花道の、七三とかいうあたりで、ひったり出会う。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と縁側に出て手を上げて追っ払い、室に駆け戻ると、生前Ｓ氏が使っていた仕事机から、錆びた安っぽいナイフを出して、死人の枕もとに置いたことが、ふーッと頭に泛き出したのだ。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "子牛は先に立ってぴょんぴょん跳ねながら、自分の足音に肝をつぶして親牛のところへ駆け戻る。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間に駆け戻ると、昂奮も焦慮も一挙に醒めはて、途方に暮れたような気持で木箱の上に坐りこんでいた。",
              "citation": {
                "source": "海豹島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……一方、加十の方は鶴子を担ぎ上げて来たが、見ると、鶴子はもう絶命しているので、慌てて玄関番の部屋へ飛んで行ってお馬に変事を告げ、また二階へ駆け戻ると、皇帝は食堂で酒を飲んでいられたが急に外套と帽子を取上げて寝室の方へ入って行かれた。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は鍵と箪笥をうっちゃって、死骸の方へ駆け戻ると、斧を引っつかんで、もう一度老婆の上に振りかざしたが、打ちおろしはしなかった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで本社に駆け戻ると、まさに群衆が包囲して、礫の雨を降らせている真ッ最中であった。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファラーの心から喜ばしい記憶の数々を引き出した火星人は、崖上に駆け戻るとたいそう物質的に見える幻影を作り上げた。",
              "citation": {
                "source": "西洋科学は素晴らしい",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はさきほどから一寸二人ともとろりといたしましたらもうどこへか御出になってしまったのでございますもの」　紅は礼を云うのも忘れて東の対にかけもどると、殿も母君も外の人達も御おきになってくらやみの中におどろきとかなしみとにとらわれて立って居る。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリスは笑い転げてしまってね、さとられたかもと森のなかへかけもどるはめに。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "陣中を大声でどなり、眠っている者を起こして歩いて、うまやにかけもどるなり、朝月の平首へかじりつくようにして、「おい、よく知らせてくれた。",
              "citation": {
                "source": "三両清兵衛と名馬朝月",
                "author": "安藤盛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
