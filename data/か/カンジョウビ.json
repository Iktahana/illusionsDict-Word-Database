        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "月末の勘定日には、多くの取引先から請求書が届く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この契約では、商品の引き渡しから30日後の勘定日までに支払いを行うことになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "年間を通じた経費の勘定日を事前に計画しておくことは、資金繰りに役立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "道楽者の叔父は、飲んで、飲んで、田舎一般の勘定日なる盆と大晦日の度、片端から田や畑を酒屋に書入れて了つた。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "失業者には癪に障るほど、時間はのろのろしているし、ようやく仕事にありついた者には、勘定日から勘定日への間には、時間は真空状態みたいに、早いのだ。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに勘定日の時間の速度などというものは、それは、受取ったためしのある稼ぎ人でなければ、分らない話である。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついにその奥さんの勘定日が来て、奥さん自身やって来た。",
              "citation": {
                "source": "少年・春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、六月｜晦日の朝……朝と云っても、やがて午に近い頃だそうですが、お角は島田と一緒に異人館へ出かけて行くと、きょうは晦日の勘定日でハリソンは店の方へ出ていました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蟹のお角",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は時子の呪いの総勘定日が近づいたことを知った。",
              "citation": {
                "source": "三角形の恐怖",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の勘定日にも妻が会計簿を持つて来て、今月の本代が二百三十円、こんな放蕩息子がゐたら早速放逐になるところですよといふのである。",
              "citation": {
                "source": "私の書斎",
                "author": "土田杏村",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「この十五日が工場の勘定日じゃけん、メリヤスを少し持って行こうと思ってますけに……」「私のうちも船の方じゃあ仕事が日がつまんから、何か商売でもしたら云うて、繻子足袋の再製品を聞いたんじゃけど、どんなもんだろうな？",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとタイムレコーダーは情容赦もなく遅刻の印しに赤い数字でがちゃりと捺す――そしてそれが差詰め勘定日の金高にビンビンと響いて来る。",
              "citation": {
                "source": "お菜のない弁当",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎月勘定日には工場の出口に待ち受けを喰つて勘定袋から容赦なく約束通りのものをさらつて行かれるのであつた。",
              "citation": {
                "source": "煤煙の臭ひ",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうするとこっちでその帳面を見て勘定日に差し引いて給金を渡すようにする。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "香代　（帳面と金を出して、磯の前に並べながら）当節ぢや、月半の勘定日だつてえのに、スラリと出してくれる人は無いんですよ。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の所は都合が悪いから月末の勘定日まで待つてくれと頼んでゐるのが解らねえのか。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘定日毎には、いつもミルコオトの銀行に行くんだよ。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は勘定日でお母様はきのうからその準備で御多用。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘定日（月二回の日当支払日）というと、それから数日間は極まって休む。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "取っただけを女の許で費い果すと、また出て来て次の勘定日までは欠勤なしに働きつづける。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "月末と十四日が勘定日と稱する日給受取日である。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "云うまでもないだろうが、十四日と晦日は勘定日で、職人たちが賃銀を貰う日であり、またかれらの家族たちが賃銀を貰って来るあるじを待っている日でもあった。",
              "citation": {
                "source": "ちゃん",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日｜稼ぎの者はべつとして、きまった帳場で働いている職人たちとその家族の多くは、月に二度の勘定日をなによりたのしみにしていた。",
              "citation": {
                "source": "ちゃん",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘定日の夕方だから客が混んでいて、その中に一人、重吉の眼を惹く男があった。",
              "citation": {
                "source": "ちゃん",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
