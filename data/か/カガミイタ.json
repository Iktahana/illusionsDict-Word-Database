        "examples": {
          "standard": [
            {
              "text": "能舞台の正面に構える鏡板には、時代を感じさせる力強い松の絵が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "役者が鏡板の前で静かに扇を広げ、幽玄な舞を披露し始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あの鏡板の松の緑は、特別な顔料を使って描かれているらしいよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "舞台照明が落ちると、鏡板に描かれた老松が暗闇の中にぼんやりと浮かび上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
