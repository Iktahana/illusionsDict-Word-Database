        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「わあ、素敵なカメオ！その繊細な彫刻、アンティークショップで見つけたの？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖母から譲り受けたカメオのブローチを、特別な日の襟元に添えるのが習慣だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ふうん、シェルカメオっていうのは貝殻を彫って作られるんだね」と熱心に展示を眺める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "重厚な額縁に飾られた大きなカメオは、かつての貴族の肖像画のようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "古めかしい油絵の額や、カメオや七宝の装飾品などが目についた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私に下すったのはイタリーのカメオが金の台にとりつけられている、極くさっぱりとした品であった。",
              "citation": {
                "source": "白藤",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柔かみのある灰色地に白で肖像のついているカメオを、装飾のない金の座で単純にとめてある。",
              "citation": {
                "source": "白藤",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い時にカメオだとかオールドゴールドとかいふやうな舶來タバコを吸つて、村の人々に感心さした旦那は、今でも敷島や朝日を吸はずに、金口の高いのをこれ見よがしに吸ひながら、お光にもタバコを喫めと口癖のやうに勸めてゐる。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、美術工芸品として世界に有名なボヘミアン・グラスの見事なカットの杯やカメオのような透しやきの小箱などが飾られている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "えっ、これってギリシャのカメオじゃないの？",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワインはまるでカメオ細工、二人の共犯者が行う給仕はこれ以上望むべくもない。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七、八年頃からぼつぼつ舶来の両切が輸入、二十年頃に来たオールド、ピンヘッド、パイレートなど十本入り一函二銭五厘、後には三銭、紳士向きのカメオが六銭、もったいないほど安かったが、当時はカメオなど滅多に喫めなかった。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "北浜のサンボア迄のして、カメオなんていゝのがあるので快く飲む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハネる頃、嘉納先生来り、サンボアへ行き、カメオなんて高級品をのみ、パオンから南の大久屋まで行く、大酔ひである。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドアを開けたマーサ・ストーナリーは女帝さながらにマルーンのシルクに十センチのカメオ彫り、灰色の髪を豊かに結っていた。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
