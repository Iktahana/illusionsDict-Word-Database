[
  {
    "uuid": "7bdb5053-f7b0-550d-9712-74a3326e61f9",
    "entry": "渇死",
    "reading": {
      "primary": "かっし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
