[
  {
    "uuid": "c7b413d9-24a9-5536-b025-f0f5e5707e61",
    "entry": "駆け回る",
    "reading": {
      "primary": "かけまわる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
