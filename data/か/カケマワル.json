      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to run around",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子犬がドッグランに着くなり、リードを振り切って嬉しそうに駆け回っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "イベントの設営担当が、インカムに叫びながら右往左往して会場内を駆け回っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供の頃は、この辺りの田んぼを日が暮れるまで駆け回って遊んだものだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "資金繰りのために、社長自ら取引先を駆け回って頭を下げている姿を見て、胸が痛んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "刈り株ばかりの冬田の中を紅もめんやうこんもめんで頬かぶりをした若い衆が酒の勢いで縦横に駆け回るのはなかなか威勢がいい、近辺のスパルタ人種の子供らはめいめいに小さな凧を揚げてそれを大凧の尾にからみつかせ、その断片を掠奪しようと争うのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山登りがじょうずで、城山を駆け回るなどまるで平地を歩くように、道のあるところ無い所、サッサと飛ぶのです。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピクニックよりもダンスよりも、婦人何々会で駆け回るよりもこのほうがはるかに身にしみてほんとうにおもしろいであろうということは、「物を作り出すことの喜び」を解する人には現代でもいくらか想像ができそうである。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "モーリスがシャトーの玄関をはいってから、人けのない広間をうろつきまた駆け回る場面の伴奏も抑揚変化が割合によくできていて人を飽きさせない。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の伯母たちが何かというとぎょうぎょうしく階段や廊下を駆け回る。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供らは仲間がおおぜいできたうれしさで威勢よく駆け回る。",
              "citation": {
                "source": "竜舌蘭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつてのら猫の遊び場所であったつつじの根もとの少しくぼんだ所は、何かしらやはりどの猫にも気に入ると見えて、ボールを追っかけたりして駆け回る途中で、きまったようにそこへ駆け込んだ。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃の腑へ届く食物は、そのまま直ちに消化されて、血管を少女のような元気さと華やかさとで駆け回るように感じられた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「駒の朝勇み」という諺が有るが、駒が未だ馬と成らない内は、甚だしく逸り勇むもので、朝は好んで駆け回るが夕に及んでは、ヘトヘトになり朝の元気が無いのが常である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "水難救済会の制服を着た人たちが、右往左往に駆け回るありさまもまざまざと目に映った。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあいだから演芸会のことでだいぶん奔走しているようだが、世話好きなんだか、駆け回ることが好きなんだか、いっこう要領を得ない男だ」「親切なんですよ」「目的だけは親切なところも少しあるんだが、なにしろ、頭のできがはなはだ不親切なものだから、ろくなことはしでかさない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "半日、山や海岸を駆け回ると、運び切れないほどの獲物があった。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは雷があんまり調子に乗って、雲の上を駆け回るひょうしに、足を踏みはずして、地の上に落ちて、目を回したのでした。",
              "citation": {
                "source": "雷のさずけもの",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲は雲でおもしろがって駆け回る。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて床へ飛び降り、台所の敷石の上を駆け回る。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は椅子の脚から脚へ駆け回る。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "東西南北と群集の中を駆け回る様子なれば、なおも尾行するに、三十分ほどをへだてその人の右手に当たり、ドシリという音せしが、彼はまたここにも降りたりと、自ら拾い上げて、さも珍しそうに諸人に示しおれり。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄めいた古きものどもの玄武岩の地下室を駆け回るぼやけた印象がある。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでは交響曲の切れ端を、あすこでは協奏曲の断片を、通りがかりに聞きかじりながら、音楽会から音楽会へと駆け回るのは、もうたくさんだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事を捜すためにパリー中を駆け回ることがまだできなかったので、余儀なく意を決してヘヒトへ手紙を書いた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は部屋を駆け回るうちに、二度ばかりドアの傍にほんのちょっと立ち止まり、耳を澄ましたらしいのに、ラスコーリニコフはふと気がついた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜ベッドで横になっていると、居間の丘と谷を駆け回る音が聞こえ、そのせいでだいぶ睡眠不足になってしまった。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "休憩の時間になると、コゼットが遊び駆け回るのをジャン・ヴァルジャンは遠くからながめた、そして他の子供らの笑い声のうちにも彼女の笑い声を聞き分けることができた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "オツベルはいよいよやっきとなって、そこらあたりをかけまわる。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性を引っかけまわるといったような下司っぽい増長者は、こうした翁の謙徳と精進に対して愧死しても足りないであろう。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "金で使われているのを気が付かずに、向う鉢巻きの双肌脱いでかけまわるほど憐れな人種となり果てたのであった。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "臆病な白人の細君たちの中には、暗黒と敵襲との二重の恐しさに悲鳴をあげて泣き叫び、寝床の中にもぐりこむやら、ぶるぶる慄えながらかけまわるやら、大騒がはじまった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「艦載機帰艦用意――探照灯、左舷着水海面を照らせ」　艦内は号令を伝える声と、作業にかけまわる水兵たちの靴音やかけ声で、火事場のような騒であった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、子守唄をうたって赤子を抱き乍ら、野原をかけまわることだけは止めませんでした。",
              "citation": {
                "source": "狂女と犬",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "道灌山の深い草は、かけまわるにも、その中へしゃがんでかくれるにも好都合で気にいっていたのに、こわいことがあって、わたしたち子供は、もう道灌山へは行かなくなってしまった。",
              "citation": {
                "source": "道灌山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
