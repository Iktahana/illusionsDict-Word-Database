    },
    "definitions": [
      {
        "index": 1,
        "gloss": "spicy food",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この店の辛物はどれも癖になる美味しさだね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夏バテ気味だけど、ピリ辛の料理なら食欲が湧いてきそう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は辛いものが好きで、いつも激辛ラーメンを頼むんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "老夫婦が、たからものにでも触るようにして、背中を撫でたり、肩をとんとん叩いてやったりする。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり、ふたりの黒い老人のからだに、守られて、たからもののように美事に光って、じっとしている。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は生家の土蔵の奥隅になお二三十個のたからもののあることをも知っている。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "飽までも私の力であなたからものを強奪して行く罪人になります。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとからものを教はつて、よろしい、しゆう　とはいつたいなんだ。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――昔からものの本にも、人の口にも、音に響いたものである。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "影はお城の窓を下からも上からものぞいて見ましたし、あのこと、このこと、いろいろ見ていました。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ考えてからもの思う葦という題で毎月、あるいは隔月くらいに五六枚ずつ様々のことを書き綴ってゆこうというところに落ちついたのだ。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへばこの男は、しばしば學校を落第し、いまは彼のふるさとのひとたちに、たからもの、といふ蔭口をきかれてゐる身分であつて、ことし一年で學校を卒業しなければ、彼の家のはうでも親戚のものたちへの手前、月々の送金を停止するといふあんばいになつてゐたとする。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばこの男は、しばしば学校を落第し、いまは彼のふるさとのひとたちに、たからもの、という蔭口をきかれている身分であって、ことし一年で学校を卒業しなければ、彼の家のほうでも親戚のものたちへの手前、月々の送金を停止するというあんばいになっていたとする。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この土地は、東京の郊外には違いありませんが、でも、都心から割に近くて、さいわい戦災からものがれる事が出来ましたので、都心で焼け出された人たちは、それこそ洪水のようにこの辺にはいり込み、商店街を歩いても、行き合う人の顔触れがすっかり全部、変ってしまった感じでした。",
              "citation": {
                "source": "饗応夫人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきは雨脚が繁くつて、宛然、薄墨で刷いたやう、堤防だの、石垣だの、蛇籠だの、中洲に草の生へた処だのが、点々、彼方此方に黒ずんで居て、それで湿つぽくツて、暗かつたから見えなかつたが、少し晴れて来たからものゝ濡れたのが皆見える。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "膝は引き上がり、首は胴体からものすごい角度で垂れており、扉へ踵が当たって、我々の会話を妨げたあの音を出している。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊女はこれを聞くと、何と思ったか、それだけのものさえ持てようかという痩せた指で、剃刀を握ったまま、顔の色をかえて、ぶるぶると震えたそうじゃが、突然逆手に持直して、何と、背後からものもいわずに、男の咽喉へ突込んだ。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一体、女形の面裡からものが見えるッて事はないのに、駢指が真向うへ立ったんだ。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もういないかと思うと、穴の中からものうそうに頭を上げたりするのだった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、女からものをもらうのは、いやだから、はじめからお土産の強迫などもしなかったし、また、みんなと同じおもちゃの懐中鏡一枚の恩恵に浴したところで、つまらない事だと思っていたし、マア坊が僕たちの部屋へやって来て、かっぽれに鏡を手渡し、「かっぽれさんは、この女優を知ってる？",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はどうも、女のひとからものをもらったり、また、ものを贈ったりするのに、いささか、こだわりを感ずる。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手と同じように無言の人に自身までがなった気がしたが、この人が初めからものを言わなかったわけも明らかにしようとして何かと尋ねかけた。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて座敷の中へはいってからものを言えばよかったのである。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時与次郎はげらげら笑って、「電車に乗って、東京を十五、六ぺん乗り回しているうちにはおのずからもの足りるようになるさ」と言う。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからものの一分は静かであったが、また蠅はやって来た。",
              "citation": {
                "source": "蠅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚からものが落ちる音や、ギ――イと何かたわむ音や、波に横ッ腹がドブ――ンと打ち当る音がした。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京新聞ば読んでからもの云うんだ。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚からものを下したり、新聞紙がガサ／＼いつたり、疊を起すやうな音がしたり、タンスの引出しを一つ一つ――七つ迄開けてゐる。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑事が出ていってからものの五分とたたぬうちに、またもや慌ただしい足音が階段に聞こえて野田をひやりとさせた。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて――なんかといううちに、間もなく汐巻岬の突端にたどりついたわたし達は、光を失った三十メートルの巨大な白塔が、ガスの中からノッソリと見え始めたころ、不意に前方の闇の中からものもいわずに歩いて来た二人の男に出会った。",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それからものの五分と経たない内に、助役が急にキッとなって吉岡の肩先をしたたかにこ突いたんです。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあに、あの二人の忠誠な隊長に委せておけば大丈夫ですよ」　それからものの四、五分もたった後のことだった。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "よいやみの中からものの怪のように、例の傀儡師が現われた。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
