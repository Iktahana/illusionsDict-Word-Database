[
  {
    "uuid": "fd3426ab-65c0-568f-8d6d-8ea5a9d753c3",
    "entry": "噛み殺す",
    "reading": {
      "primary": "かみころす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
