      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to stifle a smile, yawn, etc.",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "会議中に面白い話が出たが、部長の視線を感じて笑いを噛み殺した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "不意に込み上げてきたあくびを、彼女は必死に噛み殺した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "悔しさがこみ上げてきたが、ぐっと唇を噛み殺して涙をこらえた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は相手の挑発に乗りそうになったが、怒りを噛み殺して沈黙を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "狐が、　「さあ、走れ、走らないと、噛み殺すぞ」といって足をどんどんしました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに余計な手数なんだが、馬鹿馬鹿しい」　という考えでおりますと、不思議に議場の隅に生あくびを噛み殺す奴が出て来るのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ交会の後雌蝮その雄を噛み殺す故、その子父の復仇に母の腹を破るのだと信じた。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も此お説法中は、時々失笑を禁じえなんだので、それを噛み殺すに少からず骨を折つたが。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も此お説法中は、時々失笑を禁じえなんだので、それを噛み殺すに不些少骨を折つたが。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、噛み殺すやうな憾みをのべたことがある。",
              "citation": {
                "source": "冬の風鈴",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アア彼何が為此の余の居間へ入ったのか何が為に死んだのか、真逆の狐猿の仕業で人一人を噛み殺す事は出来ぬ、合点の行かぬ事では有るが、昨夜の叫び声の出所だけは之で分った、彼の死に際の声で有った、爾すれば彼は夜の十二時が打って間もなく死んだものだ。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、冷笑するような声を出したが、やがて生欠伸を一つ噛み殺すと、「俊助ズィ・エピキュリアンの近況はどうだい。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」呂翁は、髭を噛みながら、笑を噛み殺すような顔をして云った。",
              "citation": {
                "source": "黄粱夢",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、この図々しいやつを相手にする気まづさを噛み殺す習慣が一般民衆の間にあるからで、これ即ち、われわれが互に「共通の表現」をもたぬ風俗上の欠陥に由来するのである。",
              "citation": {
                "source": "「現代風俗」はしがき",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからそれを、生きているまま口へ放り込んだ瞬間、針で舌縁を刺されるか、その前に逸早く奥歯で噛み殺すか、というスリルも共に味わうので、稚鮎を梅酢に泳がせ、梅酢を含んだところを生きているまま食うなど、この比ではない。",
              "citation": {
                "source": "採峰徘菌愚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ありゃ、元の支配の邸にいた犬ではござらぬか」「うむ」　こう言ってムク犬を評していたものもありましたけれど、元の支配ということだけすらが、この席では禁句でもあるかのように、「うむ」と言って噛み殺すように頷いたばかりで、駒井とか能登守とも言うものはありませんでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "汲子　　（両手で顔を覆ひ、笑ひを噛み殺す）亜介　　（ちらとその方をみて）さ、行かう、兎に角、下へ降りよう。",
              "citation": {
                "source": "頼母しき求縁（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三人の笑ひを噛み殺す気配。",
              "citation": {
                "source": "迷子になつた上等兵（ラヂオドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ツのキッカケをな」　彼はまた、たまりかねて忍び笑い、それを噛み殺すために幾条もの涙の流れをアゴの下まで長くたらした。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十　冷笑鬼",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく母などが、自分たちに関係のない話になると、欠伸を噛み殺すやうにして、眼のやり場にさへ困つてゐるのを見るが、どうしてあゝなのか知らと思ふくらゐである。",
              "citation": {
                "source": "花問答",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦が笑いを噛み殺すためであつた。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホ、ホ」　お半は少し蓮葉に言つて、笑ひを噛み殺すのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "紅い扱帶",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まだ若い方で、二十二三でせうか、口數の少い、おとなしい人ですが、お通にはことの外執心なやうで、へツ」　鐵之助は場所柄も辨へず、妙な苦笑ひを噛み殺すのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "恋をせぬ女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホ、ホ」　お半は少し蓮っ葉に言って、笑いを噛み殺すのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "紅い扱帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村吉右衛門は、あの通りの人柄だから、六代目みたいに大っぴらに笑わぬ代り、まことに苦り切った顔で、笑いを噛み殺すのに骨を折っている。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして給仕頭や小間使や大勢の女中たち、しまいには笑い声に惹かれて料理人や門番までが、恐る恐る広間の入り口近くへ覗きに来て、妻や私の気を兼ねながらいかに渋面作って笑いを噛み殺すのに骨を折ったことであろうか！",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "白をブランカというのね、純白の非常に美しい牝で、牡狼ならロボーが命令を守らないとかみころすのに、ブランカには寛大です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to bite to death",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
