        "examples": {
          "standard": [
            {
              "text": "今週末、会社で恒例の観桜会が開催される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人と一緒に、近くの公園で手作りの弁当を持ち寄って観桜会を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "おばあちゃんは、毎年この時期になると観桜会の話をしてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "前田鉄工場の仮装観桜会に行く、前田鉄工場の職工たちであった。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　観桜会の場所は、武蔵境の小金井であった。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは今日のこの仮装観桜会の主催者として、何よりもまず今日の晴天であったことを諸君とともに喜ぶ者であります」「だれも喜んでなんかいねえや」　だれかが後ろから怒鳴った。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "６　前田鉄工場の職工たちは観桜会のその場から、ことごとく警察に挙げられた。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「職工たちに仮装観桜会を開いてやろうと思うんです」「今年もかね？",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わたしは仮装観桜会はしません」「では、どうして……」「あなたが去年の仮装観桜会のころのことを思い出して、職工たちの今度の要求を全部｜容れてやっていただきたいのです」「全部？",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜もそろそろ咲きかけてるのに、厭ね、私たち‥‥」　なか子は五六年前、観桜会とかで足が痺れる程、一日立ちづめで働いた料理屋の生活を思ひ出してゐた。",
              "citation": {
                "source": "朝夕",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月の二日にごきげんをうかがって四月の観桜会へまねかれるだけだった。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは観桜会のときだけだよ。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この春｜二人で観桜会へお父さんのお供をしたのである。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
