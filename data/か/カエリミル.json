[
  {
    "uuid": "510fea18-87c6-5379-a1cf-01b537aae1d1",
    "entry": "顧みる",
    "reading": {
      "primary": "かえりみる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to look back on (the past)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古いアルバムを開いて、学生時代を顧みる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は自分の人生を顧みて、多くの後悔を語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多忙な日々の中で、たまには過去を顧みる時間も大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "かうなつて來ると、一體私は内容の方に心を惹かれるものですが、とても形式方面の缺點や非難を顧みる暇はありません。",
              "citation": {
                "source": "三作家に就ての感想",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "顧みると町の旅館の旗が竿頭に白く動いて居る。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの現象の多くのものは、現在の物理的科学の領域では、その中でのきわめて辺鄙な片田舎の一隅に押しやられて、ほとんど顧みる人もないような種類のものであるが、それだけにまた、将来どうして重要な研究題目とならないとも限らないという可能性を伏蔵しているものである。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下草を分けて進み、ふと顧みると、此身は何時しか深林の底に居たのである。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで僕は思った、僕に天才があろうがなかろうが、成功しようがしなかろうがそんな事は今顧みるに当たらない何でもこのままで一心不乱にやればいいんだ、というふうに考えて来ると気がせいせいして来た。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし現代の日本人から忘れられ誤解されている連句は本家の日本ではだれも顧みる人がない。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私自身の生理の歴史を顧みるのに、すべて人並に順調だったし、結婚から子供までも産んで居る。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜干に敷いた網の中を、ひらひらと拾ったが、朝景色を賞ずるよしして、四辺を見ながら、その苫船に立寄って苫の上に片手をかけたまま、船の方を顧みると、千鳥は啼かぬが友呼びつらん。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と出さうとした信玄袋は、顧みるに餘りに輕い。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に、医師の命をだに奉ずればよし、あえて他の感情を顧みることを要せざるなり。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しいかな今のわれらは刻々に押し流されて、瞬時も一所に※徊して、われらが歩んで来た道を顧みる暇を有たない。",
              "citation": {
                "source": "マードック先生の『日本歴史』",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "是はわざと流行に反対したの何のという六ずかしい意味ではなくて、氏には本来芸術的な一片の性情があって、氏はただ其性情に従うの外、他を顧みる暇を有たないのである。",
              "citation": {
                "source": "長塚節氏の小説「土」",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央の喧騒を批評的に見渡して自分たちの場席を顧みると、頼母しい寂しい孤独感に捉えられた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は行人を顧みるような素振りを装いながら、かの女の人柄や風態を見計うことを度々繰り返すようになった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "顧みると国文学者の分子の方が勝つてしまつた彼の生涯の中で、却て生れつき豊であつたと思はれる、物語作者の伎倆を現したのは僅かに過ぎない。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「某甲當年何十何歳、自ら顧みるに從來の自己は自己の豫期したりし所に負くこと大にして、而して今日に及べり、既往は是非に及ばず、今後は奮つて自ら新にし、自己をして善美のものたらしめ、從つて自己の目的希望をして遂げしめ、福徳圓滿、自己の理想境に到達するを期せん。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と女房は早や薄暗い納戸の方を顧みる。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、偶に行逢う人も、その村の家も、ただ漂々｜蕩々として陰気な波に揺られて、あとへ、あとへ、漂って消えて行くから、峠の上下、並木の往来で、ゆき迎え、また立顧みる、旅人同士とは品かわって、世をかえても再び相逢うすべのないような心細さが身に沁みたのであった。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから私は所換えに依って新らしくそそられた感興の湧くに任せてぐんぐん仕事に熱中し出して娘を顧みる余裕を失ったが、娘は起きるから寝るまで私の部屋に来て、黙ってくの字に坐ったなり、私の姿をまじまじ見ているのだった。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそう思う途端に、忽ちかの女は自分を顧みる。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、自分の内気な引込み思案の性質を顧みるより先に、此の住居の位置が自分を現代的交際場裡へ押し出させないのだと不満に思う。",
              "citation": {
                "source": "晩春",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、自分でもしばしば首席だということを顧みる必要があった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども自ら顧みる時は、何が故に我のみは天地の美に動かさるゝことの少なきかを怪しまずんばあらず。",
              "citation": {
                "source": "哀詞序",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "許宣は喜びに体がふるえるようであったが、しかし、貧しい己の身を顧みるとこうした富豪の婦人と結婚することは思いもよらなかった。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那様が御待ち兼ねの御客様を、お供申してまいりました」　と、かるさんの男が八郎を顧みると、二人は恭しくおじぎをして、「御苦労に存じます、どうぞ、ずっとお通りくださいますように」　八郎は草鞋の紐を解いて竹縁をあがった。",
              "citation": {
                "source": "人面瘡物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝで私は心理學の歴史を顧みる。",
              "citation": {
                "source": "混沌",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又それが出來た上はもう支那の事を顧みるには及ばない。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又それが出來た上はもう西洋の政治學を顧みるには及ばない。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は料らぬ深き歎きにあいて、前後を顧みるいとまなく、ここに立ちて泣くにや。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時はその怨懣だけで、いっさい他を顧みる余裕はなかったというのが実際であった。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to look behind (at)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
