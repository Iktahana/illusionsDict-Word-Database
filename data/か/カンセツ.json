  {
    "uuid": "e5a4884c-64d4-52fc-b4e4-23b942a92fcc",
    "entry": "冠雪",
    "reading": {
      "primary": "かんせつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "covering of snow (esp. on a mountain)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "北アルプスに初冠雪の便りが届いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "富士山の冠雪は、秋の訪れを告げる風物詩だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "例年より早く、山頂が冠雪し始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "春になっても、高い山の冠雪はなかなか解けない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "風の香も麻のうねりや馬の上　　　　冠雪　炎天下を馬上で行く場合であろうか。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "かけるにつれて、足のかんせつがギシギシとなり、ヌーッとのびた、まっ黒な長いツノが、なにかを、つき落とすように、クイクイと、あがったり、さがったりするのでした。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
