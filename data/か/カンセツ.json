[
  {
    "uuid": "5744d374-5251-5868-be5a-9393d949cdd8",
    "entry": "環節",
    "reading": {
      "primary": "かんせつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "segment (of worm)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ミミズの体は、多数の環節に分かれているのが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "生物学の教材で、環節動物の構造を詳しく学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この昆虫の幼虫は、環節がはっきりしていて、まるで小さなヘビのようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "長さは約七八寸もあつて、頭部の觸鬚、羽翼状突起の基部嚢状體、後部各環節の基部等で一番よく發光する。",
              "citation": {
                "source": "光る生物",
                "author": "神田左京",
                "note": "青空文庫"
              }
            },
            {
              "text": "かけるにつれて、足のかんせつがギシギシとなり、ヌーッとのびた、まっ黒な長いツノが、なにかを、つき落とすように、クイクイと、あがったり、さがったりするのでした。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
