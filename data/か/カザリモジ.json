        "examples": {
          "standard": [
            {
              "text": "古文書の冒頭には、美しい飾り文字が描かれていることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この本の装丁には、豪華な飾り文字が使われていて目を引く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供向けの絵本で、最初の文字だけ大きな飾り文字になっているよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "欧文の書籍や雑誌には、章や節のはじまりに来る単語の一字目を、イニシャルと呼ばれる特大の飾り文字で組んだものがあります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはロシア文字ではСだから、それ一つを飾り文字としては淋しすぎるのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……またたびと飾り文字を書いた喫茶店の両開きの扉をあけてはいる。",
              "citation": {
                "source": "陽気な客",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
