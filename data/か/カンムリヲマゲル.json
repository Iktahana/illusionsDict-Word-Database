        "examples": {
          "standard": [
            {
              "text": "いつも穏やかな彼が、珍しく冠を曲げてチームメンバーに厳しく注意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "たび重なる無責任な発言に、ついに部長も冠を曲げてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "些細なことで冠を曲げるのは、大人の態度とは言えない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "浩二は仲間外しにされるから、お冠を曲げる。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "作として何んなものだろうかと訊いているんだ」　と社長は共鳴しないと直ぐお冠を曲げる。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思う壺に篏まらないと直ぐにお冠を曲げる。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
