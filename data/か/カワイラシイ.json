    "definitions": [
      {
        "index": 1,
        "gloss": "lovely",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "おばあちゃんが手編みしてくれた、可愛らしい花の刺繍入りのポーチを愛用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "散歩中のトイプードルがこちらを振り向く仕草が、たまらなく可愛らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は可愛らしい見た目に反して、空手の黒帯を持っているというギャップがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "とにかくうすら寒い時候に可愛らしい筍をにょきにょきと簇生させる。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尻に敷いた褥は、可愛らしい高山植物で、チングルマの小さい白花、アカノツカサクラの赤い花などが、絨氈の斑紋になって、浮き上る、焚火の影に、鮮やかな織目を見せる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐあとから、こつこつ可愛らしい靴の足音がして、パン屋の七つになる女の児が、パンとお砂糖でつくった猫を持って来て呉れた。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "濕つた羊齒をかき分けると可愛らしい松茸が雀の子のやうにうづくまつてゐた。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」青年のうしろにもひとり十二ばかりの眼の茶いろな可愛らしい女の子が黒い外套を着て青年の腕にすがって不思議さうに窓の外を見てゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "可愛らしい女の子が達二を呼びました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでにも可愛らしいと思わぬことはなかったが、今日はしみじみとその美しさが身にしみた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが小さな、可愛らしい、夏夜の妖精の握り拳とでも云った恰好をしている。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカレビューやウィンナ舞踊を見た眼で見た少女歌劇は実に綺麗で可愛らしいものではあったが、如何にもか弱く、かぼそく、桜の花と云うよりはむしろガラス製の人形でも見るような気のするものであった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "午過ぎの秋の日を一杯に浴びて気持のよさそうに羽根をふるわせたり、可愛らしい頭をかしげてみたりしている。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一列に並べた食卓の真中に二条のレールを据え付け、この上を御馳走を満載した可愛らしい電車が徐々と進行する。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その可愛らしいくちばしから造つた巣、一所けんめいでやつた小動物の仕事、愛すべき本能のあらはれ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅夜に瀟洒な鉄線を組み立てている清洲橋を渡って、人形町の可愛らしい灯の中で青苦い香気のある冷し白玉を喰べ、東京でも東寄りの下町の小さい踊り場を一つ二つ廻って、貝原はあっさり小初の相手をして踊る。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「可愛らしい猫ですね」「まだ子供ですから」と、老人は笑っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "床に盆を置いて貰って、その上へ小さな机子（腰かけ）を置き、そこへ腰かけて、小ッちゃい、可愛らしい手で、ツメこんでいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "可愛らしい狐の女の子が黍団子をのせたお皿を二つ持って来ました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」青年のうしろにもひとり十二ばかりの眼の茶いろな可愛らしい女の子が黒い外套を着て青年の腕にすがって不思議そうに窓の外を見ているのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "笠井さんは、可愛らしいと思った。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、サタンがそんな可愛らしい河童みたいなものだとは、どうしても考えられない。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、きれいだわ」青年のうしろに、もひとり、十二ばかりの眼の茶いろな可愛らしい女の子が、黒い外套を着て青年の腕にすがって不思議そうに窓の外を見ているのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふとハーシュは縮れ毛の可愛らしい子供が水色の水兵服を着て空気銃を持ってばらの藪のこっち側に立ってしげしげとハーシュの車をひいて来るのを見てゐるのに気が付きました。",
              "citation": {
                "source": "車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い焔に包まれて、歎き叫んで手足をもだえ、落ちて参る五人、それからしまいに只一人、完いものは可愛らしい天の子供でございました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」青年のうしろにもひとり、十二ばかりの眼の茶いろな、可愛らしい女の子が黒い外套を着て、青年の腕にすがつて、不思議さうに窓の外を見てゐるのでした。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "可愛らしい佳い娘さんでした。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ、私の家から三丁ばかり離れて飯塚という家がございましたがそこの娘におさよと申しまして十五ばかりの背のすらりとして可愛らしい児がいました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事でひどく近所中の感じを悪くしたそうだが、細君の好人物と子供の可愛らしいのとで幾分か融和していたらしい。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡坐をかいたまゝ、勃凸は鼠の眼のやうな可愛らしい眼で、強度の近眼鏡越しに友達の顔を見詰めながら、向ひの部屋の物音に聞き耳を立てた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白い華車な顔にはめこまれた、鼠の眼のやうな可愛らしい眼がすわつて来ると、勃凸の全身は鞘を払つた懐剣のやうに見えた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つは毛深い熊があと足を前に投げ出してすわっている、それが首と前足とを動かして滑稽な格好をして踊りだすと腹の中でオルゴールのかわいらしい音楽が聞こえて来るのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネリには、かわいらしい男の子が生まれました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
