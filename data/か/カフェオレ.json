        "examples": {
          "standard": [
            {
              "text": "朝食にはいつも温かいカフェオレをマグカップになみなみと注いで飲む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "寒い日に喫茶店に入ったら、体が温まるようにと無意識にカフェオレを選んでしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女が作ってくれるカフェオレは、ミルクの泡がきめ細かくて本当に美味しいんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この前飲んだキャラメル味のカフェオレが忘れられなくて、またあのカフェに行きたいな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "休日の午後は、カフェオレを片手にのんびり読書するのが最高の過ごし方だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
