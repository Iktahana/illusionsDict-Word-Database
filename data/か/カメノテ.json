        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "磯遊びをしていたら、岩の隙間にぎっしりと亀の手がへばりついているのを見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "居酒屋のお通しで出てきた亀の手は、見た目に反して濃厚な磯の香りがして絶品だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわあ、本当に亀の手みたいな形をしてるんだね！」と子供がまじまじと観察している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "お珊は帯留の黄金金具、緑の照々と輝く玉を、烏羽玉の夜の帯から星を手に取るよ、と自魚の指に外ずして、見得もなく、友染を柔な膝なりに、腰をなよなよと汀に低く居て――あたかも腹を空に突張ってにょいと上げた、藻を押分けた――亀の手に、縋れよ、引かむ、とすらりと投げた。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "安亀の手の中にこんな手紙があった。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして大亀の手から揚団子をうけ取っては、つぶてのように中の広場へそれを撒いてあるくという段取だ。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾つにも折れている小さな紙は、大亀の手でひらかれた。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
