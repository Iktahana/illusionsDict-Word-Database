[
  {
    "uuid": "d0459b1b-60f9-5282-ad98-985caf24b1fe",
    "entry": "川筋",
    "reading": {
      "primary": "かわすじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
