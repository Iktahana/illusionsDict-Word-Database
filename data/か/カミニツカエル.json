    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to serve God",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は若くして教会に入り、生涯を神に仕えることに捧げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "神に仕える者として、常に清廉潔白でなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "修道女は祈りを捧げ、神に仕える日々を送っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の祖先は代々、その土地の神に仕える家系だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "内に省みるも、外に対するも、学を為すも、事に従うも、情を御するも、智を役するも、芸に遊ぶも、神に仕えるも、道に殉じるも、悪に堕ちるも、人間一切の事象は全て気の働きがするのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から異教を奉じ妖神に仕える者等が、ともすれば一団を形成して、王に背き、国を乱だし、世と相争い、敢然として固い誓いの下に、同心の身を犠牲にするのを見ても、その道友相得る喜びの大にして、相愛し相譲る念の深いことを知る。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして旧琉球政府は、こののろくもいを自然に出来上った根人（氏神すなわち根神に仕える女子）の上に置いてこれを支配させたのであります。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄んだ眼と高い額とは神に仕えるにふさわしい崇尊さを顔に浮べて居た。",
              "citation": {
                "source": "旅へ出て",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴下も神に仕える身でありながら、まだ生れないにしても、一つの生霊を自ら手を下して暗闇から暗闇にやってしまうなんて、残酷な方！",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡島の神主と云うのは、神社で神に仕えるものではない。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは神に仕える身だ」「神につかえる身だって。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大昔の宮廷では、皇女は生れながらにして、巫女となって神に仕える宿命を持って此世に現れられるものと考えていた。",
              "citation": {
                "source": "反省の文学源氏物語",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "海北道主貴は、宗像三女神の総称となっているが、同じ神と考えられてきた丹波の比沼神に仕える丹波道主貴は、東山陰地方最高の巫女なる神人の家のかばねであった。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊勢の斎宮に対して、後世賀茂の斎院のできたことからみれば、本来は主神に仕える皇族女子のほかにも、有力な神に接する女王の巫女があったことは考えられる。",
              "citation": {
                "source": "最古日本の女性生活の根柢",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄でも、地方地方の祭りの日に、家族は海岸などに出て、女だけが残って、神に仕える風がかなり多い。",
              "citation": {
                "source": "最古日本の女性生活の根柢",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、その神に仕える所の聖職者は、ただ単に神の姿を一般民衆に髣髴として見せ、神の言葉を恰もそれが真実の神の言葉であるような印象をもって伝えるばかりでなくて、一方に於て、その神と対立する所の悪魔の姿をも一般民衆にまざまざと伝える必要があったのです。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "美に仕えることが彼の内なる神に仕えることであった。",
              "citation": {
                "source": "（私はさきごろ）",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう女は、神に仕えるか、または、神のものであった。",
              "citation": {
                "source": "嫉みの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ見方で安川の献身的な仕えぶりをみたならば、女神に仕える神僕か女王に仕へる奴隷のやうにも見えるであらう。",
              "citation": {
                "source": "老嫗面",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの悲哀が神に仕える人を起こすように、この世にはまだ古をあらわす道が残っていると感づくのも、その彼であった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう彼はまた、しいてそんな風俗を固守しているでもないが、日ごろの願いとする古い神社の方へ行かれる日でも来たら、総髪こそその神に仕える身にはふさわしいと思われるからでもあった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤児に仕える者はそのまま神に仕える者である。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤児に仕える　神に仕える心――それがそのまま孤児に接する者の心でなければならない。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "神に仕える祈りの宮殿である。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "神に仕える心、幼きイエズスを育てる心、――まことにおごそかな心である。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "うらやましいね」「すると、原子爆弾は人類の居眠りをさます大気合いだったんですねえ」科学者と宗教「宗教は神に仕える人の道だね。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は神に仕える人の道を守るためにカトリックに入ったのでした。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし人間がその生の短きこと、死の一瞬にして来ることを知れば、神の怒を恐れてその行を慎み、ただしく神に仕える賢さを身につけることができるであろう、それ故死を忘れないように人間を戒めたまえ、とモーゼが神に祈ったのである。",
              "citation": {
                "source": "メメント　モリ",
                "author": "田辺元",
                "note": "青空文庫"
              }
            },
            {
              "text": "この森の高いところに静かさがある――神に仕える静かさが。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだままの者が神に仕えるはずがないではないか。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼によると、個人が神の僕であると同じに、社会は神に仕えるためのものであって、全く道徳的本質のものだ。",
              "citation": {
                "source": "道徳の観念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつぞや彼が死の問題を訊ねると同時に、鬼神に仕える道を訊ねた時にも、孔子は、ただ専念に人に仕えよ。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に仕える道がわからないでは、鬼神に仕える道は解らない、と教えた。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "一一（二六四）　季路が鬼神に仕える道を先師にたずねた。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
