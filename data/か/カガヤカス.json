    "definitions": [
      {
        "index": 1,
        "gloss": "to light up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "スポットライトが舞台を輝かし、主役が登場した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "太陽が昇り、まばゆい光が部屋を輝かした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "街灯が夜の道を輝かし、家路を急ぐ人々を照らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "束の間の閃光が私の生命を輝かす。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……朝餉を濟ますと、立處に床を取直して、勿體ない小春のお天氣に、水を二階まで輝かす日當りのまぶしさに、硝子戸と障子をしめて、長々と掻卷した、これ此の安湯治客、得意の處。",
              "citation": {
                "source": "鳥影",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でなければ、主義とか理想とかを丸呑み込みにして、それに盲従する単純すぎて鈍重な眼を輝かす青年が想像されて来る。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "抜身の槍の刑罰が馬の左右に、その誉を輝かすと同一に。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は彼の制作よりも寧ろ彼の為人の裡に詩を輝かす病的、空想的の人物であった。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "童が髪に燃えつきて仏の如く透徹らしめ、またしばし、輝かす、ふくらかに臀部の円みの滑りよく、白く、冷たき肉づきを、銀のうぶ毛を。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡て是等の錯綜せる哲理の外に、晃々としてこの大作を輝かすものこそあれ。",
              "citation": {
                "source": "処女の純潔を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何なる残忍酷薄な奴でもその鼻の表現に、自由自在に熱情の光を輝かす事が出来るものとしたならば、その人間の運命は如何に光明に満ち満ちたものとなり、その人間以外の社会生活は如何に暗黒な不安の裡に鎖される事でしょうか。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルビー嬢や真珠夫人、ダイヤ姫なぞと来ると、囚われても囚われ甲斐のある方で、家門の誇り、社交界のお飾りたるべく、皆もう後生大切に研きをかけては光り、光っては研きをかけつつ、身動きさえもそっとして、鼻の表現にそのプライドを輝かすばかりに夜を明かし日を暮しておいでになります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや暫くして、女が出て来て※の一行を招いたので、すぐに武器をたずさえて踏み込むと、一頭の大きい白猿が四足を牀にくくられていて、一行を見るや慌て騒いで、しきりに身をもがいても動くことが出来ず、いたずらに電光のような眼を輝かすばかりであった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「われらの王様の威光を輝かすために――」　と叫びました。",
              "citation": {
                "source": "船の中の鼠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聞いていたドレゴは、一段と顔の色を輝かすと水戸の手を取って引っ立てた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「欲しいなあ……」　彌生は深い息を衝いて憧れに滿ちた眼を輝かすのであつた。",
              "citation": {
                "source": "痴日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬ばかりが災難かと見ると、今はもう訓練者達の方も余程の困憊と焦躁にあふられて、冗談ぐち一つ利く余裕も失ひ、爛々たる真剣の眼を輝かすばかりであつた。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が父や兄に対する敬愛の思念が深ければ深いほど、自分の力をもって、少しでも彼らを輝かすことができれば私は何をおいても権利というよりは義務を感じずにはいられないはずであった。",
              "citation": {
                "source": "蒼白い月",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、仏像の製作者が、先ず斎戒沐浴して鑿を執った、そのことの裡に潜む力は、水をかぶり、俗界と絶つ緊張の中に存するのではなく、左様にして後、心を満たし輝かす限りないポイズの裡にあるのではないだろうか。",
              "citation": {
                "source": "透き徹る秋",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう不便でかつおたがいにきまりのよくない文化事情に立って、日本の若い人々に与えられる外国作家の作品翻訳は、必ずしも、ほんとに明日を輝かすものでない場合が少くない。",
              "citation": {
                "source": "はしがき（『文芸評論集』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし……」　彼がノートに書とめてゐるパスカルの言葉を読んできかせると、若い甥は目を輝かす。",
              "citation": {
                "source": "火の踵",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その樫尾大尉の艱難に鍛い上げた皮膚の色と、鉄石の如き意志を輝かす黒い瞳を正視した瞬間に、私はすべてを察してしまった。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手の間に掴み潰してしまえるような小娘のうつむき姿を机の前に眺めながら、彼は異様な圧迫と堪え難い衝動にかられて、卑しい目を輝かすのだった。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて太陽は光芒一箭、雲間を破ってその陸離たる光彩を燦然と輝かすのである。",
              "citation": {
                "source": "画室の言葉",
                "author": "藤島武二",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼白い肉体を内からの熱情で輝かすお信の美しさ。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、自分には万人の悲しい涙にぬれた顔を新しい歓喜をもって輝かすことは出来ないのだろうか。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "青空にかゝつてゐるごく薄い雲を通してくる日光が、峰に白雪をいたゞいた山々を輝かす有様は、実に美しくまた雄大であつた。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "草の上に、露のある頃から、金襴の前垂を輝かす源内法師を先に、白帷子に赤い頬かぶりをして、綾藺笠を其上にかづいた一行が、仄暗い郷士の家から、照り充ちた朝日の中に出た。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "左衛門　（目を輝かす）殺生をしても、姦淫をしても。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをやはり努めなければ、恐らく、文学をまた再び本当に輝かす時に、非常に骨が折れるのですね。",
              "citation": {
                "source": "文芸雑談",
                "author": "――某氏との談話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆村はキラリと眼を輝かすと、電話機を取上げた。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて私に来て、私をかがやかすものは、あなたをもきらめかします。",
              "citation": {
                "source": "めくらぶどうと虹",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「船長、いよいよメリー号が浮きあがりますよ」　老船長は、安楽いすの上に寝そべって、ずきんずきんといたむ腰をさすっていたが、クーパーのこの言葉に、子供のように目をかがやかすと、「わしは夢をみているのじゃないかな。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
