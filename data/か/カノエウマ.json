    "definitions": [
      {
        "index": 1,
        "gloss": "Metal Horse (7th term of the sexagenary cycle, e.g. 1930, 1990, 2050)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖父は庚午の生まれで、いつも行動的でエネルギッシュな人だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庚午の年は変化の多い年になると言われるが、今年は穏やかに過ごしたいものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この神社の創建は庚午の年と記録されており、非常に古い歴史を持つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "三年（庚午）　一八七〇○三月、守田座において市川左団次の丸橋忠弥初演、大好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日、庚午、聖徳太子の十七箇条の憲法、並びに守屋逆臣の跡の収公の田の員数在所、及び天王寺法隆寺に納め置かるる所の重宝等の記、将軍家日来御尋ね有り、広元朝臣相触れて之を尋ね、今日進覧すと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九日、庚午、小笠原御牧の牧士と、奉行人三浦平六兵衛尉義村の代官と喧嘩の事有り、今日沙汰を経らる、此の如き地下職人に対し、奉行と称して恣に張行せしむるの間、動もすれば、喧嘩に及ぶ、偏に公平を忘るるの致す所なり、早く義村の奉行を改む可きの由仰出され、佐原太郎兵衛尉に付せらると云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四日、庚午、晴、酉剋地震、戌剋地震、同時に雷鳴す。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年庚午、二十四歳。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶山は後六年文化十三年丙子に至つて、此庚午の観察を反復し、その得たる所を「筆のすさび」に記した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その五十九　庚午｜旺秋の茶山の尺牘には種々の人の名が見えてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その六十　菅茶山が蘭軒に与へた庚午の書には、人物の其十二として山陽が出てゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陽が歳暮の詩に「一出郷国歳再除」と云つたのは、庚午の除夜を神辺で、辛未の除夜を京都で過すと云ふ意である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その七十九　此書牘、文化乙亥の茶山の第一書に、主要なる人物として北条譲四郎の出て来たのは、恰も庚午の書に頼久太郎の出て来たと同じである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "慧琳は元和十五年庚午に八十四歳で卒したから、十二年に筆を絶つたとすると、入寂三年前に至るまで著述に従事したことになる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "後庚午の年に、再び広岡｜文台を訪うて其死に驚く紀事に、「凡経八年南帰」と云つてあるからである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今茲庚午三月子譲往訪先生。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その百四十五　北条霞亭は文化七年庚午三月六日に、伊賀の広岡文台の家を訪うて其死を聞いた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此春は庚午の春でなくてはならない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "霞亭は庚午の三月六日に広岡の家で旧師の死を聞いて、後事を営んだ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "霞亭は庚午の夏より冬に至るまで、林崎にあつて文庫の書を渉猟し、諸生を聚めて経を講じ、又述作に従事した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」末に「文化庚午夏日」と記してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此糾繩抄の文化七年庚午の下には七人の名がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは此「望之妻」は斎の妻狩谷氏は文化七年庚午六月十八日の朝歿したこととなるであらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "書上は此を「寛延三庚午年」としてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三百四十九　上に記するが如く、庚午二月二十日に棠軒は東京本所石原の阿部家別邸に著き、丸山本邸へ届けに往き、先づ津山氏を訪うた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "庚午には三十一歳になつてゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "庚午二月二十日に三十七歳の棠軒が、七十四歳の忠琢と三十一歳の碧山とに会したことは既に云つた如くである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "冲斎は庚午の年に七十一歳になつてゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三百五十一　わたくしは棠軒日録を抄して既に庚午四月六日に至つてゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」蘭軒の父｜信階の養母にして信政の妻であつた伊佐の生家、菓子商大久保｜主水は庚午の歳に猶店を今川橋に持続してゐて、棠軒は当時の主水と往来してゐたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三百五十二　庚午八月二十七日後の棠軒日録を続抄する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三百五十三　庚午十二月七日後の棠軒日録を続抄する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "庚午八月二十五日の生であつたから、六歳にして歿したのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
