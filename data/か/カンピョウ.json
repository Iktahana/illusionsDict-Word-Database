    "definitions": [
      {
        "index": 1,
        "gloss": "strips of dried gourd",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
