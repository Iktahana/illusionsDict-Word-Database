    "definitions": [
      {
        "index": 1,
        "gloss": "cloth dyed in a dapple pattern",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
