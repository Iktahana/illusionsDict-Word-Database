        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "都会の喧騒の中に、風鈴の涼しげな音色はあっという間に掻き消えてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、待って！今の聞き取れなかった。飛行機の音で声が掻き消えちゃって。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "霧の深い夜、怪しげな人影は街灯の光が届かない闇の中へと掻き消えるように去った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "花火が上がった後の静寂に、観客の歓声も次第に遠のき、夜のしじまに掻き消えていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "千鳥　口ほどでもない平家の追っ手ども、掻き消えるように逃げて行ったか。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "その秀政も涙にくれ、彦右衛門も落涙して、ここの一燈は、涙に掻き消えるかと思われるばかり暗澹な夜色に沈みきってしまおうとした。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅客の群も、ほとんど掻き消える。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
