    "definitions": [
      {
        "index": 1,
        "gloss": "consumer electronics",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「引越しの片付けが落ち着いたら、次はドラム式洗濯機などの家電製品を買い揃えたい」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「最新の家電製品は省エネ性能が飛躍的に向上しており、電気代の節約にも貢献してくれる」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「故障した家電製品を修理に出すよりも、買い替えた方が安く済むと言われて悩んでいる」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "東芝でさまざまな家電製品の開発に携わってきた山田正吾さん語り下ろしの「家電今昔物語」によれば、電気釜への初のチャレンジは、一九一五年頃、京都電灯によって行なわれたという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラスベガスで開かれた家電製品の展示会、コンシューマー・エレクトロニクス・ショーでのことだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに家電製品の中で賢くして意味のあると思われるものを、マッキントッシュの開いた人との対話の流儀に沿って電脳化しようとする腹だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "家電製品自体は作らないまでも、電脳家電が人に向ける顔のところは任せろと言い出すのは当然だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがかつての自動車や家電製品、半導体で起こったと同様の悲劇が、ここでもまた繰り返されようとしている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラフィックスや音を取り込んでなにか面白いことの起こる世界は、32ビットの３８６ＳＸ以上を使ったＷｉｎｄｏｗｓをのせたマシンや、ＵＮＩＸマシンに押し上げられ、この下に、電子時代の読み書き算盤のツール、いわば情報家電製品が誕生することになる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "安くて小さなマイクロコンピューターが機器を賢くする魔法として存在している以上、電脳化して意味のある家電製品は皆賢くなる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "家電製品をはじめ、あらゆる機器という機器がこいつを組み込んで機能を拡張することは、宮沢りえだって五十年たてば立派な婆さんになっているのと同等の、歴史の必然である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまな家電製品や機器に組み込まれ、あるいはワードプロセッサーやパーソナルコンピューターに身をやつして、世にはマイクロコンピューターがあふれ始めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "家電製品が横並びでずらりとかぶるお面の候補に、一番近いのはＷｉｎｄｏｗｓだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのアウトラインを報じる記事を読んで、「家電製品が横並びでずらりとかぶるお面の候補に、一番近いのはＷｉｎｄｏｗｓだ」と書いたこの原稿のことを思い出した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしほとんどの日本人は、ＮＥＣの三文字に日電の子会社、新日本電気の家電製品のイメージを重ね合わせていたはずである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "家電製品ならどんなものにも組み込んで、コントロールに使えるのでは、とそこまでは思う。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば家電製品を買い求めて、いざ使おうとして「電源はそちらで用意して下さい」などという但し書きを発見したユーザーは果たして怒りだすのだろうか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロコンピュータは家電製品にも積極的に使われて、産業としての地位を確立しつつありますが、今まで大型が担ってきた計算とか処理などの機能を備えたコンピュータが個人の手のとどく商品となったら、それをどのように分類したらいいのでしょうか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "子会社の新日本電気（現在の日本電気ホームエレクトロニクス）から家電製品が売り出され、それが唯一、ＮＥＣブランドと大衆との接点となっていたが、家電への進出はけっして成功したわけではない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人への売り込みを狙うなら、定価は家電製品並み、どうしても二〇万円は切りたい。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ステレオが、ビデオが、テレビがユーザーの注文を記憶するようになり、洗濯機、冷蔵庫、掃除機をはじめ、ありとあらゆる家電製品がコンピューターコントロールによる複雑な機能を売り物にしはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マイクロコンピュータは家電製品にも積極的に使われて、産業としての地位を確立しつつありますが、今まで大型が担ってきた計算とか処理などの機能を備えたコンピュータが個人の手のとどく商品となったら、それをどのように分類したらいいのでしょうか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "百貨店を歩いてあらためて見なおしてみると、家電製品や音響機器など、日常的に使われる道具はいずれもプラスチックのケースに収まっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
