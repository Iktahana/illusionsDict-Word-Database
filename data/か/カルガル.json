    "definitions": [
      {
        "index": 1,
        "gloss": "lightly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は100キロ以上あるバーベルを、まるで竹ぼうきでも扱うかのように軽々と持ち上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よっ、と」彼は高い塀を軽々と飛び越え、迷子になった子猫を助け出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ベテランの職人は、若手が苦戦していた複雑な工程を軽々とこなしていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最新の軽量ドローンは、強風に煽られながらも軽々と高度を上げていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "勿論これらのことは、僅かの紙数で以てさう軽々に云つて過ぎられることではない。",
              "citation": {
                "source": "アンドレ・ジイド管見",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "門の鉄扉の外側に子守が二、三人立って門内の露人の幼児と何か言葉のやりとりをしていると、玄関から逞しいロシア婦人が出て来て、逞しいむき出しの腕でその幼児を軽々と引っかかえて引込んで行った。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってここでいうところのチューインガム亡国論も畢竟はただ一場の空論に過ぎないと云われても仕方がないであろうが、しかしこの些末な嗜好品の流行の事実もそう軽々には見遁すことの出来ないものではあろうと思われる。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏んで蹴って又投げつけて、　格闘暫時――　結局フラフラの半次を軽々と肩に乗せる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "認めない人は、たいてい軽々にくさしてしまう。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんな軽々しい問題じゃないよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界じゅうの人間の元祖が一つであろうという事は単に確率論的の考察からもいちばん考えやすい事であるが、今ここで軽々しくそういう大問題に触れようとは思わない。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽々しい否定は早急な肯定よりもはるかに有害であるからである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このジャングルのなぞが解かれる日までは、われわれはそう軽々しくいろいろなイズムを信用して採用するわけにはゆかないであろうという気がするのである。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先の石段をおりるや、若き女はまず僕を乗らして後、もやいを解いてひらりと飛び乗り、さも軽々と櫓をあやつりだした。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『ハハハハハ冬が過ぎればまた春になりますからねエ』と小山はさも軽々と答えた。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "君よ、必ず永久の別れを軽々しく口にも筆にも上したまいそ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そういうふうにして、元来決して軽く見るべきはずでない、あらゆる意味で重大な多くの事がらを、朝夕に軽々しく見すごすような習慣を養うという事自身に現代の思想上の欠陥の一つの大きな原因があるのではあるまいか。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそういう例外な事件の記事よりも、日常街頭や家庭に起こりつつある、一見平凡でそうして多数の人が軽々に看過していて、しかも吾人の現在の生活に対して重要な意味のあるような事実を指摘し報道して、いくらかでも人々の精神的の幸福を増し不幸を予防するように努めるだけは努めたいものである。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この残りの刺身の幾片かのイメージがこの詩人の午後の半日の精神生活の上に投げた影はわれわれがその文字の表面から軽々に読過するほどに希薄なものではなく、卑近なものでもなかったであろう。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、もしも映画のトリックによって一人の男が三井寺の鐘を引きちぎって軽々と片手でさし上げれば、その男は異常な怪力をもっているように見えるのである。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹男さんだけはどこに行ったかどうも見えなんだ」　と妹や弟を軽々とかつぎ上げながらいった。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木戸はきしむ音もたてずに軽々と開いた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "跣足になった肉づきの恰好な彼女の脚は、木柵の横木を軽々と飛び越して林檎畑にはいって行った。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、衆を立たせて、使用法を弁ずる時は、こんな軽々しい態度のものではない。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "神職　秘しがくしに秘め置くべき、この呪詛の形代を（藁人形を示す）言わば軽々しう身につけおったは――別に、恐多い神木に打込んだのが、森の中にまだ他にもあるからじゃろ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿河台の老婦人は、あわれ玉の輿に乗らせたまうべき御身分なるに、腕車に一人｜乗の軽々しさ、これを節倹ゆえと思うは非なり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お丹は冷かなる微笑を含みて、「私も初のうちは御実家へお戻りのあるように、勧めてはみましたけれど、あなた方の重い御身分では、姑御が邪慳だからって、ついちょいと軽々しく、産の親御に顔は合わされぬとおっしゃるので、ま、ただいままで私が大切におかくまい申しました。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりは底抜けに気の弱い人、決して私との見合いを軽々しく考えたのでも、またわざと遅刻したのでもないと、ずっとあとになってからだが、そう考えることにした。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドリアンは気も軽々とモンマウス公爵夫人の弟のジョフレイと並んで進んだ。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが中味が矢張り菰ばかりで、軽々と、担がれたってね。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "その軽々とした、かわいらしいお姫さまの歩きかたに、王子もほかの人たちも、ただただおどろいていました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "人魚のお姫さまも、美しい白い腕をあげて、つま先で立ちながら、床の上をすべるように、軽々と踊りました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "船は、すみきった海の上を、たいしてゆれもせずに、軽々とすべっていきました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのありさまは、なにかに追いかけられて、身をひるがえしながら、軽々と飛んでいくツバメのようでした。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
