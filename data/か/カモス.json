[
  {
    "uuid": "ec5fc054-a53a-57ce-93e8-2687de5a83a2",
    "entry": "醸す",
    "reading": {
      "primary": "かもす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
