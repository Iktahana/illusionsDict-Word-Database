      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to brew (sake, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この老舗の酒蔵は、昔ながらの製法で素晴らしい日本酒を醸しているよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "自宅でクラフトビールを醸すのが最近の趣味なんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "丁寧に仕込まれた大豆が、芳醇な味噌へと醸される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ブドウを収穫し、ワインを醸すために地下貯蔵庫へ運んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "〔このみちの醸すがごとく〕宮沢賢治このみちの醸すがごとく粟葉などひかりいでしはひがしなる山彙の上に黄なる月いざよへるなり夏の草山とになひてやうやくに人ら帰るをなにをかもわがかなしまんすゝきの葉露をおとせり",
              "citation": {
                "source": "〔このみちの醸すがごとく〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの沢山の不愉快な顔が醸す一種の雰囲気は強い伝染性を持っていて、外から乗り込んで来る人の心に、すぐさま暗い影を投げないではおかない、そして多くの人の腹の虫の居所を変えさせようとする傾向がある。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しらしら醸す天の川、　　　　　はてなく翔ける夜の鳥、かすかに銭を鳴らしつゝ、　　　ひとは水繩を繰りあぐる。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯漫然と打捨って置くから、往々にして種々の禍害を醸すのだ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○二月、大阪梅田の劇場に団十郎乗込み、二興行の給料五万円は余りに法外なりという物議を醸す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるべくクローヴアーの厚く生え重つた渚の水気の切れた辺に席を取つて、牧瀬と歳子はもう二三十分も神経を解放し、たゞ黙つて夏の夜の醸す濃厚で爽かで多少｜腕白なところもある雰囲気に浸つてゐた。",
              "citation": {
                "source": "夏の夜の夢",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "灘の酒は実に醸するや、水悪ければ即ち敗る。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "醸家の酒を醸す、法あり技あり材あり具ありと雖、水佳ならざれば遂に佳なるを得ざるなり。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王の傍には僧｜道衍袁醸するの事、いかでこれ無くして已まん。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "室内の造作はプレーンでモダンな洋式を、どこか日本趣味に通じさしたものがあり、この室内とこの人間との雰囲気の醸す感じからは、東京の下町というものが一方｜洒脱でありながら一方ローカルなものを持っているのを受取らせます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事は距てられた男女の間に秘楽でもあるらしく思い潜ます作法を起して、結局は禁圧の効を奏するにしろ、途中の一ときは逆結果を醸すために、却って男女を悩ましやしませんかしらん。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたやオゾンの香のしめり、渦巻き縺れ、昼も、夜も、間なく、時なく、ひたぶるに暈めき、醸す死の恐怖、列ね立てたる柱には、『触るる者かく死すべし。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "』胸わるき油煙のにほひ女子らが汗に蒸されて、焦熱のこころあかあか火の車、または釜うで、餓鬼道の叫喚さながら人人が苦悩を醸す。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "風を祭る羽虫蜆花、通草咲き満ち、質素なり、この門の夏、放射線――醸す虫なり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾とても再び彼ら同志に逢わざるべきを、予想したればこそ、かく夫婦の契約あることを発表せしなれ、今日の境遇あるを予知せば、もはや愛の冷却せる者に向かいて、強いて旧事を発表し、相互の不利益を醸すが如き、愚をばなさざりしならんに。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正九年五月、『太陽』二六ノ五）（三）民俗１　さきに猴酒の事海外に例あるを聞かぬと書いたは千慮の一失で、『嬉遊笑覧』十上に『秋坪新語』忠州山州黒猿｜善く酒を醸す事を載す。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……即ち、ヘラクライトスは常住の実体を根底より否定し、世界の真相は生成を以てなさるべきものとなしたる為に、クセノフアネースの思想を継いだエレア学派との激しい論争を醸すに至つたのであるが、飽くまでも万物流転の説に立脚して……」　重い抑揚のあるＨ教授の声量が、快く私の鼓膜を打つた。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "原始人類に共存せる偶像崇拝の風習により、ある種族が定めた偶像例へば一定の動物とか植物とかは、其種族は之を食ふことを禁止し、若し之を食したならば其の物は毒となりて、之を食したものに疾病を醸すなどの迷信も、これに加へることが出来よう。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村の句には夕風や水青鷺の脛を打つ鮓を圧す我れ酒｜醸す隣あり宮城野の萩｜更科の蕎麦にいづれのごとく二五と切れたるあり、若葉して水白く麦黄ばみたり柳散り清水｜涸れ石ところ／″＼春雨や人住みて煙壁を漏るのごとく五二または五三と切れたるもあり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ静にして居ったばかりでは単に無聊に苦しむというよりも、むしろ厭やな事などを考え出して終日不愉快な事を醸すようになる。",
              "citation": {
                "source": "病牀苦語",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　学生は青年であり、即ち時代の新しい矛盾の下に発育して来た者だから、この矛盾が醸す各種のイデオロギーに著しく動かされる。",
              "citation": {
                "source": "学生の技能と勤労大衆",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが船客の耳に這入れば、一度に不安に駆られて騒擾を醸すに決まっている。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から思えば、あの時のあの思いつきこそ私にとって大破綻を醸すことになったのでしたが、其の時は自身素ばらしい思い付であると考えたのです。",
              "citation": {
                "source": "悪魔の弟子",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして当時民権を唱うる人々の内心を分析してその私党心あるを説き、またこの人々の身分を評論して無産の士族なることを説き、ついに民権論の国乱を醸すに至るべきを揚言せり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に田舎らしい頓間な空気の中に溶けこんだ、あの医者の粗忽な逸話の醸す酔いのためかもしれない。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論彼等は現代の文明に就て、より少く教育せられて居りますから其愚直は軽率なる罪悪を醸す原因となる場合もあるでせう。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの著者の態度は一方から云えば不徹底で生煮えのようでもあるが、ものの両面を認識して全体を把握し、しかもすべての人間現象を事実として肯定した上で、可と不可とに対する考えをきめようとしているらしく思われる。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかもすっかりわやじゃ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの同じ心理が恐るべき惨害をかもす直接原因となりうるのは劇場や百貨店などの火事の場合である。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう立場からすると、連句の共同作者としてはむしろその性格、情操、趣味等において互いに最も多様に相異なるしかもすぐれたそれぞれの特徴を備えた一集団を要するということになって来るであろう。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to cause",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
