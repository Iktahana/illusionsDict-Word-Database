    "definitions": [
      {
        "index": 1,
        "gloss": "calcium (Ca)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "骨を丈夫にするためには、毎日十分なカルシウムを摂取することが大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "牛乳や小魚には、豊富なカルシウムが含まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "植物の成長にもカルシウムは不可欠な栄養素だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「最近、足がつりやすいんだ。もしかしてカルシウム不足かな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "健康診断でカルシウム値が少し低いと指摘された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ぢいつと茫然黄昏の中に立つて、なんだか父親の映像が気になりだすと一歩二歩歩みだすばかりです深夜の思ひこれは泡立つカルシウムの乾きゆく急速な――頑ぜない女の児の泣声だ、鞄屋の女房の夕の鼻汁だ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上川魚は頭ごと食へるから、第二の国民の骨骼を大きくする為のカルシウム分もフンダンにある。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、カルシウムの錠剤。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海老の髭には、カルシウムが含まれているんだ。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このロック氏液というのは一プロセントの塩化ナトリウム、〇・二プロセントの塩化カルシウム、〇・二プロセントの塩化カリウム、〇・一プロセントの重炭酸ナトリウムの水溶液であって、ほゞ血液中の塩類成分の量に一致して居るから、心臓は血液を送りこまれて居ると同じ状態になって、その搏動を続けるのだ。",
              "citation": {
                "source": "恋愛曲線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「譬えば此の温泉の湯は化学的に分析すれば、硫酸と硫酸カルシウムと硫酸ナトリウム、硫酸カリウム、塩酸、硫酸アルミニウム、硅華硫酸鉄、まアそんなものだが、それは人体にとってはどうでも良いので、必要なのはこの温泉が果して病人に効くかどうかということだ。",
              "citation": {
                "source": "馬車",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとにさうで、半搗米を食べなくとも、カルシウムを飲まなくても差支へはないが、人間は兎も角も道徳的でだけはあつて欲しい。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も高温の星にはヘリウム、それに次いで高温で白色光を放つものには水素、中等程度の高温で黄色の光を放つ、たとえば我々の太陽のようなのではカルシウム、マグネシウム、鉄並びに他の金属元素が多く、最後に最も温度の低い赤色の星では炭素化合物なかんずくシアンが現われる。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "――山本有三氏の道義がこれまで放牧されている地域にあっては、歴史の推移につれて、従来の種類の草だけをいかに気を入れて氏の芸術論に云われているようにこちらのものにしても、カルシウムの欠乏は何となし顕著に感じられて来ている。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むこうの家の塵埃の中に、小麦の粉とカルシウムと粘土（すなわちセメント）の粉とがまじっているのです。",
              "citation": {
                "source": "塵埃は語る",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「当分つづけてカルシウムの注射をやってごらんなさい。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝのとこ毎日安藤先生がお來診になつてカルシウムの注射をして下さいます。",
              "citation": {
                "source": "業苦",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カルシウム煎餅も売つてゐますね。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カルシウム煎餅も売っていますね。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは宮沢賢治が在世の頃東北砕石会社の生産品として、彼自身もその売りひろめに奔走した石灰類なのであるが、今日漸くその効用がひろく認められて、今でも、東磐井郡長坂村付近にその後継会社があり、炭酸カルシウム、略してタンカルと呼ばれて、さかんに売り出されてゐる模様である。",
              "citation": {
                "source": "開墾",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "バースの温泉は硫化カルシウム及びソヂウムを主とする鑛泉で、温度は華氏百二十度の高きに達するものがある。",
              "citation": {
                "source": "温泉雜記",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大きな声を出す療法）同　　一一・三〇　カルシウム・ビスケット一個。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "合乗り乳母車　――仏蘭西縦断の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月の料理はあれでなかなかよくできているので、昆布には沃素と加里があり、田作にはカルシウムと燐がある。",
              "citation": {
                "source": "御馳走の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は病人の周囲に存在すると信じているコレラ毒は効果を発揮するのに飲料水中のカルシウムまたはマグネシウム塩を必要とすると考えた。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が言うにはアメリカ西部ではコレラは砂地の地域を迂回してカルシウム地区に猛威をふるい、カルシウムの多い水を使っている人たちには致命的な効果をもって猛襲し、砂岩や軟水を使う人たちを通り過ぎる。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともアメリカでも、従来の食事は、鉱物質の不足、特にカルシウムの不足に陥る傾向があったそうで、そういう点も充分留意してある。",
              "citation": {
                "source": "老齢学",
                "author": "――長生きをする学問の存在――",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通こういう副作用の予防には、カルシウムを同時に注射するのが常識になっている。",
              "citation": {
                "source": "ジストマ退治の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（＊石灰水＝水酸化カルシウムに二酸化炭素を吹き込むと炭酸カルシウムが沈殿する。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに吹き込むと可溶性の炭酸水素カルシウムになる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "公共水に含まれている塩は殆ど限られていて、ナトリウム、カルシウム、マグネシウムの炭酸、硫酸、塩酸の塩である。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも白い沈渣が起きたら水にはカルシウムがあると結論する。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "この検査によって24,250グレインの水中にある１グレインのカルシウムを見つけることができる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまで公共の水に入っているのは殆ど炭酸、硫酸、塩酸のナトリウム、カルシウムおよびマグネシウムの塩に限られ、時には非常に微量の鉄が含まれていると述べてきた。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
