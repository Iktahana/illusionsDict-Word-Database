          "standard": [
            {
              "text": "うちの近所、夕方になると子供たちがかんかん坊主になって走り回ってるんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの子、元気すぎてまるでかんかん坊主みたいだね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "お寺の小僧さんたちが、修行の合間に遊んでいる様子は、微笑ましいかんかん坊主だよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "とても、にがい味がしていて、頭なぞ目高のくせにかんかん坊主で硬いのよ、食べられはしない、ふふ、でもね、内緒だけど弱っているの、いただくことあるわ。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
