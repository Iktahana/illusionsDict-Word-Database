        "examples": {
          "standard": [
            {
              "text": "豪華客船とはまた違う、素朴な船旅が楽しめる貨客船のデッキから遠ざかる港を眺めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "生活物資を満載した貨客船の入港は、島の人々にとって一週間で最も待ち遠しい瞬間だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "台風の接近により海上が荒れたため、明日の貨客船は全便欠航することが決まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "貨客船の食堂で出される簡素なカレーライスが、なぜか旅情を誘い、格別に美味しく感じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "二十三人の乗組員はぜんぶ救助され、ギリシアの貨客船で帰国したが、中島漁撈長だけは帰らなかった。",
              "citation": {
                "source": "おごそかな渇き",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
