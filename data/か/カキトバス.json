        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はメモ用紙に走り書きで何かを書き飛ばした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "時間がないから、とりあえず要点だけ書き飛ばしておこう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "簡単な報告書だったので、30分ほどで書き飛ばした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "それでも書ならば陶然として書き飛ばすがね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろ清閑を得ない為に手つとり早い随筆を書き飛ばすのである。",
              "citation": {
                "source": "野人生計事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をどう書き飛ばすにせよ、さうは註文に応じ難ければ、思ひつきたること二三を記してやむべし。",
              "citation": {
                "source": "大正十二年九月一日の大震に際して",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、多くの作家の生活様式が、月々四五十枚の原稿を二晩か三晩で書き飛ばすことを余儀なくさせ、しかも、その生活様式を改めようとしないのであるから、どつしりした、密度のある作品がなかなか生れて来ないのは当然である。",
              "citation": {
                "source": "新劇界の分野",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
