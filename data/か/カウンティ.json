        "examples": {
          "standard": [
            {
              "text": "アイルランドのカウンティを巡る旅で、歴史ある城や美しい田園風景を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イギリスのカウンティでは、それぞれ独自の文化や伝統が色濃く残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は、カリフォルニア州の小さなカウンティの郡庁で働いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "付け加えると、現時点での負債の総額が、確認できる限りでは八八ポンド一〇シリング、一方でキャピタル＆カウンティーズ銀行の預金残高は二二〇ポンドある。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューヨーク市カウンティ・トラスト会社の社長がピストルで自殺した。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
