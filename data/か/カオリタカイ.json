[
  {
    "uuid": "72221f1c-3e02-5f5f-b387-23dec84c6169",
    "entry": "香り高い",
    "reading": {
      "primary": "かおりたかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
