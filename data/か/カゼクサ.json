        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "土手に群生している風草が、夕暮れの秋風に吹かれて銀色に光る波のように揺れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幼い頃、道端に生えていた風草を抜いて、友達と互いにくすぐり合って遊んだ記憶が蘇った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "荒れ地でもたくましく根を張る風草は、晩夏になると地味ながらも風情のある細かな穂をつける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "防風草でも摘みながらいらっしゃい。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、松風草の葉ようなものは、ちょうど心臓を逆さにして、またその二股になった所が、指みたいな形で左右に分れている。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "銃鳴り剣閃めき、戦血地を染め、腥風草樹を槁らすの時に、戦争の現状を見る、然れども肉眼の達せざるところ、常識の及ばざるところに、閃々たる剣火は絶ゆる時なきなり。",
              "citation": {
                "source": "最後の勝利者は誰ぞ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "車行数里入田園、処処春風草色喧、欲問一千年古跡、牧童教我杏花村。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
