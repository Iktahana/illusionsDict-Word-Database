        "examples": {
          "standard": [
            {
              "text": "砂漠の真ん中で見つけた骨は、太陽に晒されて真っ白に乾ききっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ドライヤーを当てすぎて髪の水分が奪われ、毛先まで乾ききってパサパサだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわ、喉が乾ききって声が出ないよ」と、彼は掠れた声で呟いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "水溜りが乾ききった地面には、ひび割れた模様が複雑に広がっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこにいた　いきもの、　アリスと　みんなは　ぐるぐる　はしりっぱなしで　それを　かわききるまで　つづけたんだ。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            }
          ]
