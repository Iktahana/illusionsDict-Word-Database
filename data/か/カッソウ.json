        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "離陸準備のため、飛行機は誘導路を滑走していった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "着陸したばかりのジャンボ機が、ゆっくりと滑走してゲートに向かう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "パイロットは、滑走路を滑走する前に最終チェックを行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
