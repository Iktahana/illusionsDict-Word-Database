    "definitions": [
      {
        "index": 1,
        "gloss": "gliding",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "スキーヤーが雪面を軽やかに滑走していく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "グライダーは、風を捉えて優雅に空中を滑走した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "フィギュアスケートの選手は、氷上を滑走しながら美しい演技を披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "米良は空中滑走する、戦い疲れた陳独秀とビクトリア・カップよりセント・ジョウジ・プレースに至る山頂火車のなかで彼等は力なく握手して、空中の鏡の上にモーニング姿の印度人のイサックを発見するのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "地形がいい工合に傾斜を作っている原っぱで、スキー装束をした男が二人、月光を浴びながらかわるがわる滑走しては跳躍した。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "直線運動としては囚徒や職工の行列、工作台上の滑走台、ジュアンヌの机の前の壁を走り上る数字の列等が著しいモチーフとして繰り返される。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまの岩戸を開けるような恰好して、うむと力こめたら、硝子戸はがらがらがら大きな音たてて一間以上も滑走し、男爵は力あまって醜く泳いだ。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、もう一里弱ですから、このまま滑走してしまいましょう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちは一昨日真岡から豊原へ二十里の原生林の横断を果したが、六度もパンクして、とうとうこの追分口から滑走してはいってしまった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論プロペラーの回転を落した空中滑走である。",
              "citation": {
                "source": "人のいない飛行機",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴を鳴して橇道を滑走して来る橇の一隊をさへぎつて、皆なに訊いたが、一様に首をかしげて顔を見合せてゐるだけだつた。",
              "citation": {
                "source": "寄生木と縄梯子",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんたうに、それは芝生を滑走して、突端に迫つたならば、ものゝ見事にふはふはと離陸出来さうな青空であつた。",
              "citation": {
                "source": "心象風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺もひとつ今日こそは、大いに滑走するぞ、笑ふなよ。",
              "citation": {
                "source": "明るく・暗く",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お百合さんの滑走の姿を空想してゐるんだ、二つの脚が快活に左右に滑り出て、或は高く、或は……」「そんなことは止して呉れよ、俺は何だか妙に悲しくなつて来る。",
              "citation": {
                "source": "明るく・暗く",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その学生は彼女の腕を執って巧みに氷の上を滑走させてくれた。",
              "citation": {
                "source": "滑走",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "見透す限りに一直線の街道で、その対角線の中心を目差して進んで行くと、誰でも、ちよつと物狂ほし気に爽快な滑走！",
              "citation": {
                "source": "パンアテナイア祭の夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、そのスキーの跡は、平地滑走でありながら、両杖を突いていない。",
              "citation": {
                "source": "寒の夜晴れ",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行艇が離水する前に、はげしいいきおいで水上｜滑走をする。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは、飛行艇が水上滑走をはじめ、それから離水するまでが、大好きだ。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからすぐかけつければ間に合わないこともありませんわ、飛行機が滑走を始めれば、もうお仕舞いですよ」「ありがとうエミリー」と、ドレゴは本気になって感謝した。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行場の傍まで来ると、旅客機は既に砂煙をあげて滑走中だったので、ドレゴもエミリーも歯をぎりぎり噛み合わせて口惜しがった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがドレゴの運が強かったわけか、旅客機は滑走路のはずれまで行っても離陸しないでぐるっと方向転換をし、元の出発点に引返してきた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……すると――おそらく僕が余りに凝然と眼を視張って眼ばたきもしないでいるために起る視覚の錯誤なのだが、その巨大な提燈は、活躍を続けている花々しいシルエットをはらんだまま、スーッと音もなく滑走し、宙に浮んで、小さく、明るい月に変った。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "飽くまでも文明の利器として、認識しなければ面白くなかつたのであるが、母や私は鉄道馬車で国府津へ赴き、煙りを吐く汽車に乗り慣れたので、従令線路の上を走るとは云ふものゝ人間が後おしをして滑走する人車などゝいふ鉄道に驚くわけには行かなかつた。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　間もなく一団の駈け手は、砂を巻いて、滑走する巨大な磁石になつて次々にあたりの群勢を吸ひ込み、最初の何倍にも人数を増して、私達がおろ／＼と立ちあがつた丘の下に差しかゝつた。",
              "citation": {
                "source": "鱗雲",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きさは、ドイツの大飛行船ヒットラー号よりも何十メートルか大きいというから、東京駅がそのまま載って、まだ両端へ百メートルずつ出るという長い滑走路を造るのだそうだ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから飛行甲板を走りきるまでには、甲板の長さの幾層倍かの長い滑走路を走ったと同じことになる。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行甲板から重爆がとびだすのに、滑走路が短すぎるから、甲板は戦車の無限軌道式になっていて、そいつは飛行機のとびだす方向と逆に動くとかいいましたね」「そのとおりです」「いやそれがインチキだというのです。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから無限軌道の上で全速力を出せるまで準備滑走をやるのです。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
