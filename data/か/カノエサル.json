    "definitions": [
      {
        "index": 1,
        "gloss": "Metal Monkey (57th term of the sexagenary cycle, e.g. 1920, 1980, 2040)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庚申の年に生まれた彼は、頭の回転が速く、機転が利くタイプだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "次の庚申の年は2040年か。その頃には私もすっかりおばあちゃんだな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い記録によると、この地方で大飢饉があったのは庚申の年だったそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "庚申歳に七度はた五つ、　　　庚の申を重ぬれば、稔らぬ秋を恐みて、　　　家長ら塚を理めにき。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから小舎に帰って寝ましたがね、いゝ晩なんです、すっかり晴れて庚申さんなども実にはっきり見えてるんです。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上に庚申のほこらがあると聞く。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巌穴の底も極めたければ、滝の裏も覗きたし、何か前世の因縁で、めぐり逢う事もあろうか、と奥山の庚申塚に一人立って、二十六夜の月の出を待った事さえあるんです。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は又、曾て読んだ八犬伝の中で、犬飼現八が庚申山に分け入るの一段を思い出した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "七日、庚申、海水色を変ず、赤きこと紅を浸せるが如しと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿日、庚申、霽、内蔵頭忠綱朝臣勅使として下向す、先づ御車二両、已下御拝賀料の調度等、之を舁かしむ、疋夫数十人歩列す。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "車に乗った天女に抱かれて、多人数に囲まれて通った時、庚申堂の傍に榛の木で、半ば姿を秘して、群集を放れてすっくと立った、脊の高い親仁があって、熟と私どもを見ていたのが、確に衣服を脱がせた奴と見たけれども、小児はまだ口が利けないほど容体が悪かったんですな。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "庚申橋とかいふ橋の下に大小紅紫いろいろの友禪の半襟を綱に弔るして居たのが、如何にも春らしく京都らしく好い氣持であつた。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その回向堂は、また庚申堂とも呼ぶが、別に庚申を祭ったのではない。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さんぬる天保庚申年に、山を開いて、共同墓地にした時に、居まわりに寺がないから、この御堂を建立して、家々の位牌を預ける事にした、そこで回向堂とも称うるので、この堂守ばかり、別に住職の居室もなければ、山法師も宿らぬのである。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて傘一つ、山の端に大な蕈のようになった時、二人はその、さす方の、庚申堂へ着いたのである。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその机は、昔からここにある見覚えのある、庚申堂はじまりからの附道具で、何もあなたの母様の使っておいでなすったのを、堂へ納めたというんじゃない。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "築山の小さな祠や鳥居、赤松や木畫にある庚申薔薇の中門には眞萩や山吹がしだれかかり、その中門から門庭へ出入りができ、そこにはまた木※の植込があり、應接室の窓には八つ手や松ヶ枝が透かして見えた。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の集の挿画にある庚申薔薇の中門には真萩や山吹がしだれかかり、その中門から門庭へ出入りができ、そこにはまた木槲の植込があり、応接室の窓には八つ手や松ヶ枝が透かして見えた。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "庚申塚のある四辻を右の方に折れ曲ろうとすると、塚の背後の根本に藁畔をしてある禿榎の梢に止っていた一羽の烏がついと飛んだ。",
              "citation": {
                "source": "雁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "万延元年庚申、十四歳。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは野州庚申山で生捕りましたる山猫でござい位のことにして置けば無事だったのだが、そこが例のインチキで、弟の幸吉が飛んだ商売気を出した。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その春のある夜、太郎左衛門は浜松の城下へ往っての帰りに、遅く村の入口の庚申塚の傍まで来たところで、行手に当惑しているらしい、二人｜伴の女の立ち止っているのを見た。",
              "citation": {
                "source": "切支丹転び",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の姿は、次第に橋を距って、大きく三日月｜形に、音羽の方から庚申塚へ通う三ツ角へ出たが、曲って孰方へも行かんとせず。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（もみじを御見物と見えますが、これから巣鴨へ抜けて、）先生、あの邸はね、私どもが居た池のふちから、通天門と額を打った煉瓦の石の門を潜って、やはり紅葉の中を裏へ出ると、卯之吉という植木屋の庭を、庚申塚の手前へ抜けられますわ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳次に教えられた通りに、海辺の大通りを右へ切れると、庚申堂のそばに小さい草履屋が見いだされた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治二十六年予、故サー・ウォラストン・フランクス（『大英百科全書』十一版十一巻に伝あり）を助けて大英博物館の仏像整理中、本邦祀るところの庚申青面金剛像に必ず三猿を副える由話すと、氏はそれはヒンズー教のハヌマン崇拝の転入だろうと言われた。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『垂加文集』に〈庚申縁起、帝釈猿を天王寺に来たらしむ云々、これ浮屠通家説を窃みこれを造るのみ〉とあれど、遠く三国時代に訳された『六度集経』に、羅摩王物語を出して猴王（スグリヴァ、上出）衆を率い海に臨み、以て渡るなきを憂う。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『嬉遊笑覧』に『遠碧軒随筆』を引いて、庚申の三猿はもと天台大師三大部の中、止観の空仮中の三諦を、不見、不聴、不言に比したるを猿に表して伝教大師三猿を創めたという。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同例で庚申の三猿も伝教の創作じゃなかろう。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを庚申の三猿もて表わしたというが通説だ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "庚申の申は十二畜の猴に中る。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『筑紫琴の唄』にもある通り、庚申が叶え猴に通うより庚申の夜祈れば何事も叶うとしたらしい。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
