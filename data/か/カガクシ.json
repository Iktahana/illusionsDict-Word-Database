    "definitions": [
      {
        "index": 1,
        "gloss": "history of science",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「なるほど、科学史を紐解いていくと、世紀の大発見が実は単なる偶然の産物だったりして面白いよね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ニュートンとライプニッツによる微分積分の先取権争いは、科学史における最も有名な論争の一つとして知られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "中世の錬金術が、迷信を削ぎ落として現代の化学へと繋がっていく過程を科学史の視点から考察する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "科学史の講義では、当時の宗教的観念が新しい科学的知見をどのように阻害したかが語られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "このような実例は科学史上枚挙に暇ないほどである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結言　更に一般の場合、物その物の本来の使途以外に、此の白銅貨の如く科学的性能を様々に生かして用いられるものは色々とあると思うが、これが調査と研究とは、けだし文化史的にも科学史的にも興味のあることと信ずる。",
              "citation": {
                "source": "白銅貨の効用",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学史上最大の天才と言われるアルキメデスは、ローマの軍隊がシシリーのシラクサの城を攻めるに及んで、これに極力反抗し、自分の科学をあらゆる武器に応用した。",
              "citation": {
                "source": "スフィンクス（覚書）",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシア哲学がバビロン・エジプトの技術学とどんなに密接な史的関係があるかは、科学史家や技術史家の想定する常識となっている。",
              "citation": {
                "source": "技術的精神とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もそのためには従来の文化史や哲学史、又科学史や技術史自身さえをも、多少書き直す必要があるのであって、今ここに手短かに実証して見せるわけには行かぬ。",
              "citation": {
                "source": "技術的精神とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず第一は、例の技術に大きな関係があることで、自然科学自身と技術とで、どっちが自然科学史の根本動因であるかという問題だ。",
              "citation": {
                "source": "技術と科学との概念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学と技術との連関を分析する必要を最も手近かに感じて来たのは、一群の科学史家であった。",
              "citation": {
                "source": "生産を目標とする科学",
                "author": "――再三「科学と技術」とについて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、この解答を予想しながらかの設問を提起した側の科学史家が、最も誘惑を感じるのは、何となく科学を技術の手段のように見ようという態度である。",
              "citation": {
                "source": "生産を目標とする科学",
                "author": "――再三「科学と技術」とについて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然科学史に関係の深い物理学者には、大体二つ又は三の系統がある。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "と共に岡氏は九州帝大の桑木※雄博士の科学史を学んだものなのだ。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳翼博士に於ける哲学の風貌は、そのまま※雄博士の科学史をつづる思索の風貌である。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから科学史研究で独特な位置を占めている天文学の新城新蔵博士（上海自然科学研究所）を忘れてはならぬ。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "小倉氏の自然科学史に岡氏が協力する点については岡氏の政治的立場（というよりは氏の周囲の政治的傾向）から判断して、私は最初から危虞の念をもっており、羽仁氏や貴下にも多分その意をもらしたように記憶しております。",
              "citation": {
                "source": "平野義太郎宛書簡",
                "author": "一九三二年九月八日",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、もし、自然科学史が殆んど岡氏によって書かれたとすれば、御手紙のようなことは不可能だと思います。",
              "citation": {
                "source": "平野義太郎宛書簡",
                "author": "一九三二年九月八日",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然科学史の原稿井汲氏に御渡し下されたく、なお、御都合できましたら次の日曜か月曜頃御｜来駕を煩わし得れば幸に存じます。",
              "citation": {
                "source": "平野義太郎宛書簡",
                "author": "一九三二年九月八日",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて、人類学――一般史・科学史・女子大学史――解剖学――比較病理――倫理問題――犯罪統計――売淫――ザッヒェル・マゾッホ――教育問題――最後にスペンサーの名論……という仕組みで、要するに進化論に出でて進化論的｜綜合哲学に終るかなり大がかりな体系をなすはずのものであった。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三原でも、十日間、科学史、経済史、文化史、音楽史の講座をもち、二百五十人の人を締切って聴講せしめた。",
              "citation": {
                "source": "地方文化運動報告",
                "author": "――尾道市図書館より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学史上に名をとどめている古来の科学者は、いずれもこの「型」の所有者であった。",
              "citation": {
                "source": "救われた稀本",
                "author": "――寺田寅彦著『物理学序説』",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケルヴィン、ラサフォード、アーレニウス、オングストロームなどという科学史上の人びとから、薫陶を受けた由で、話は非常におもしろかった。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあのいつも多少不機嫌そうな顔をしているむつかしい爺さんが、原子におけるダルトンと同格に、同位元素の名において科学史に不朽の名を残した所以を幾分窺い得たような気がした。",
              "citation": {
                "source": "英国の物理学界と物理学者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に、科学史に残るような大科学者が「出来るはずがない」と言った発明が、その後間もなく出来たような例も沢山ある。",
              "citation": {
                "source": "千里眼その他",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで人類科学史上｜未曾有の大事件たる原子爆弾の研究に、こういう企てを試みることすら、いささかドン・キホーテ的であったことが、今度のアメリカの発表でよく分った。",
              "citation": {
                "source": "原子爆弾雑話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "回教国の科学がオマール・カイヤムの時に発達の絶頂に達し、これから下り坂になることはサートン博士の『科学史概論』にその事情を巧みに説いている。",
              "citation": {
                "source": "芸術と数学及び科学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダ・ヴィンチはまた同時に科学史上に抜くべからざる地歩を成した人であった。",
              "citation": {
                "source": "芸術と数学及び科学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民国十九年（すなわち昭和五年）十二月十五日天津にて発行の新聞『大公報』に葉恭綽という人が宋の沈括の科学上のことを記した通信を載せ、記者はその附記において支那の科学史のことを言って居るが、その終わりに次の如く言う。",
              "citation": {
                "source": "数学史の研究に就きて",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里に万国科学史委員会なるものがあり、伊太利の科学史家ミーリ氏が主になってやって居るのであるが、私はさきに誤ってこの委員会の通信会員に選挙された。",
              "citation": {
                "source": "数学史の研究に就きて",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のところ、東洋人中には私が唯一人でもあるし、相成るべくは支那日本の科学史特に数学史に関する報告をもしたいことに思う。",
              "citation": {
                "source": "数学史の研究に就きて",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "高橋至時は傑出した人物であってラランデの天文書を読破して『管見』を作ったのは日本の科学史上において注意すべきことであったが、それでも物理関係の事項については多くの理解がなかったらしい。",
              "citation": {
                "source": "文化史上より見たる日本の数学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖書に記されてある記事を社会科学的に、あるいは自然科学的に研究するのは、それ自体として興味あるテーマであることを失いませんが、その場合でも、科学史もしくは科学前史的見地から研究するのが正しいのでありまして、現代科学の理論的水準から見てその記事の当否を論ずるのは、聖書の正しい読み方ではないのです。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
