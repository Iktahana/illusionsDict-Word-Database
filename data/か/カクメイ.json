    },
    "definitions": [
      {
        "index": 1,
        "gloss": "revolution",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その国では、貧困にあえぐ民衆が立ち上がり、血なまぐさい革命が起こった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "産業革命は社会構造や人々の生活様式を根底から変革した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現代社会におけるAIの進化は、まさに情報技術の新たな革命と言えるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若者たちは、既存の価値観に一石を投じるような文化革命を求めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼の過去における一切の思想と感情とに、ある根本的の動搖があり、新しき生活の革命に入らうとする、けなげにも悲壯な心境が感じられた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私の信ずる所によれば、彼の自殺における「漠然たる不安」の一つは、近く來らんとする彼自身の心境的革命にまで、名状しがたき不安の困憊を感じたのである。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの大好きな魯迅先生は、所謂「革命」に依る民衆の幸福の可能性を懐疑し、まず民衆の啓蒙に着眼しました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら革命を起して人間の首を切つても、金持と天才との種を絶やすことは六かしい。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく大革命の騒ぎの最中でも、世界大戦の混乱と動揺の中でも、食事の時だけはこういう態度を持ち続けたであろう。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい芸術的革命運動の影には却って古い芸術の復活が随伴するように、新しい科学が昔の研究に暗示を得る場合は甚だ多いようである。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど二人ともに革命家である。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　別れの曲　ショパンがパリのサロンに集まった名流の前で初演奏をしようとする直前に、祖国革命戦突発の飛報を受取る。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は幕末の革命に飛び出したり、時には辻斬強盜などもやる方だが、犀星のは本當の古武士であつて、君主の前で禮節正しく構へてゐる。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から女というものは英雄と革命を愛することに変りはないのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はどちらかと云うと咄嗟の思い付きを愛する女で米良は自分の桃色の革命家の恋心について悲しまなかった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ彼女の支那女特有の秘密好きな冷理な性質が秘密結社と革命の企業を愛し、東洋女らしい敬虔さがボルシェヴィキの堅固な道徳に陶酔した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この支那の社会に直接プロレタリア革命は到底不可能な企業としか考えられぬのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "革命的左党は右党派軍隊に絶滅され、国民党は共産分子を除外して孫文の国民党はブルジョワ階級の走狗となった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は心持ち昂奮して床を靴尖で叩きながら立上ると、リー・シー・ツワンは遥かビクトリア・ビークの絶景の化粧された文明の礎を一瞥して、　――上海に於ける陳独秀のコムミュン騒動、また広東事変の失敗によって俺には熱狂的同志に対して俺自身に課せられた革命的任務の自覚が眼覚めたのだ。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは今暁飛行機で香港にくると陳独秀の革命的遺産をうけついだのだ！",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その革命の背後には幾千、幾萬の犧牲者があんな風にして苦しんでゐる。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は革命なんてほんとに厭やだと思ふ……」「だが、革命者の立場から云へば……」と、私は詞を挾みかけた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうだ……」「だから、僕は革命なんか厭やだと思ふんだよ。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一體、君はさう云ふ革命者の心持を肯定出來るのかね？",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「根本的に云へば、革命なんかを幾度繰り返してみたつて、少數の革命者が自我の滿足をかひ得るだけで、人間全體は決してより善くも、より幸福にもなり得ないと僕は思ふね。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "島田へのおみやげ大分あつまりました、何はなくとも、ともかくめいめいに何かと思ってね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フランスという国で、かくめいという大戦があった揚句、今までの掟をばかにするために、ワザとお寺や社をこわして、日本でいえばお女郎とかじごくとかいったような女を、神様同様に守り立てて、車に載せて押歩いたということを、三田の先生から聞きました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "獄窓の外にある荒木村重をとりまいて、その旗本や側臣のあいだに――或いは主の村重を挟んでであろうか――ともかくめいめいが勝手な声を出し始めているのであった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
