      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to move",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この机、一人じゃ重いから一緒に片してくれない？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "邪魔な荷物を早く片して、道を空けてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "パーティーの後、椅子を元の場所へ片した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "どういうわけでこの南海の片すみの土地がこの天皇と結びつけられるようになったのか私は知らない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の片すみのデスクの上に論文の草稿のようなものが積み上げてある。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりから驟雨のあとで場内の片すみには川水がピタピタあふれ込んでいた。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもシーザーやポンペイの活躍していた恐怖時代のローマの片すみで静かに科学の揺籃をつづっていたこの人の心境をうかがわせるに足るのである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう場合に、突然にどこからか現われて来て新生面を打開するような対象が、往々それまではほとんど物理学の圏外か、少なくも辺鄙な片すみにあって存在を忘れられていたような場合であることもあえて珍しくはないのである。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までに顧みられなかったわけは、単に、今までの古典的精密科学の方法を適用するのに都合がよくないため、平たく言えばちょっと歯が立たないために、やっかいなものとして敬遠され片すみに捨てられてあったもののように見受けられる。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学者のに限らず、一般に随筆と称するものは従来文学の世界の片すみの塵塚のかたわらにかすかな存在を認められていたようである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地所の片すみに地中から空気を吹き出したり吸い込んだりする井戸があって、そこでその理屈を説明して聞かせました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "名高い古城の片すみには昔の刑具を陳列した塔があります。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "片すみに小さくなっているむき出しの安っぽい棚の中に窮屈そうにこの叢書が置かれている。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし中には暇はあっても不精であったり、またわざわざ出かけるよりも室の片すみで茶をのんだりカルタでもやるほうがいいという人があるならばそれはその人々の勝手である。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋町の風月の二階に、すでにそのころから喫茶室があって、片すみには古色｜蒼然たるボコボコのピアノが一台すえてあった。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが雨のあとなどだと、店内の片すみへ川が侵入して来ていて、清冽な鏡川の水がさざ波を立てて流れていた。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸時代から明治時代にかけての涼味が、まだ東京の片すみのどこかに少しは残っているものと見える。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわりに今｜雛鳥を二羽、宿の裏手の鶏小屋の片すみの檻に養っている。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の炊事場の土間の片すみにこしらえた板の間に手機が一台置いてあった。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとしたらどこかの人生の片すみに、そんなすごい美人がころがっているかも知れない。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはかねて聞いていたさの字浦で、つの字崎の片すみであった。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に小官衙の片すみの一課などに任しておくべきものではないとも思われる。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "教場へはいると、まずチョッキのかくしから、鎖も何もつかないニッケル側の時計を出してそっと机の片すみへのせてから講義をはじめた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "美人は片すみにありて、応募の最終なりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは片すみの小さい潛戸をあけて、かこひの中へはひつた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬はその空地の片すみにころがっている、底も天井もぬけた、古ぼけた穀物だるの口もとにすわりこみました。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉屋は、そこいらの片すみへ穴をほって、おお／＼、かわいそうに／＼と言い言い、死がいをうめてやり、その上へ土をもり上げました。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "片すみには繩を張って、つぎはぎのせんたく物が干してある。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも大正のジャーナリズムの世界の片すみに起こった、ささやかな一つの現象の記録というほかには意味はない。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　近年まで、この風習が日本の片すみに残っていたが、惜しいことに、もうどこにも影をとどめなくなったらしい。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この広い日本の、この広い東京の、この片すみの、きまった位置に、自分の家という、ちゃんときまった住み家があり、そこには、自分と特別な関係にある人々が住んでいて、そこへ、今自分は、さも当然のことらしく帰って来るのである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうとは知らず彼は古い世界の片すみの一室にただ一人閉じこもっていて、室外の世界も彼と同様に全く昔のままで動いているような気がしていたのである。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その曲がった脊柱のごとくヘテロドックスなこの老学者がねずみの巣のような研究室の片すみに、安物の籐椅子にもたれてうとうととこんな夢を見ているであろう間に、容赦なく押し寄せる野球時代の波の音は、どこともない秋晴れの空の果てから聞こえてくるであろう。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
