[
  {
    "uuid": "9b21c7b4-eb18-5016-9475-6a695544a9b6",
    "entry": "片す",
    "reading": {
      "primary": "かたす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
