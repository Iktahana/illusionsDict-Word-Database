    "definitions": [
      {
        "index": 1,
        "gloss": "Kawasaki Steel Corporation (abbr)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの巨大な橋の建設には、川鉄製の鋼材が使われたらしいよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "取引先で川鉄の担当者と打ち合わせをしてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "川鉄の株価が最近、好調みたいだね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "伊勢四日市の諏訪神社の社司｜生川鉄忠氏これなり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒川鉄男、これがチーフメートであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてチーフメート黒川鉄男は、そのプログラムに従って他意なくやってのけた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉川鉄道で二子に行って若鮎を食うのも興がある。",
              "citation": {
                "source": "新茶のかおり",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんならね、川鉄の鳥鍋がいいわ」　マスクの顔が振りかえった。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "露路へはいりながら、しどい場処ですといって番地と表札をさがしたが、西川鉄五郎の家はどうしても知れないので空家のような家で聞くと、細い細い声で返事をした。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "蕎麦屋の利久",
                "note": "青空文庫"
              }
            },
            {
              "text": "長良川鉄橋陥落の図、尾張紡績会社破壊の図、第三師団兵士｜屍体発掘の図、愛知病院負傷者救護の図――そう云う凄惨な画は次から次と、あの呪わしい当時の記憶の中へ私を引きこんで参りました。",
              "citation": {
                "source": "疑惑",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "花街神楽坂　川鉄の鳥は大分久しく食べに行ったことがないが、相変らず繁昌していることだろう。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三人の小人数から十人位の会食の場合には、大抵川鉄ということにきまっていた、牛込在住文士の牛込会なども、いつもそこで開いた。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際神楽坂で、一寸気楽に飯を食べに行こうというような所は、今でもまあ川鉄位なものだろう。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿司屋の紀の善、鰻屋の島金などというような、古い特色のあった家でも、いつか芸者が入るようになって、今ではあの程度の家で芸者の入らない所は川鉄一軒位のものになってしまった。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに川鉄の鳥は、流石に古くから評判になっているだけであって、私達はいつもうまいと思いながら食べることが出来た。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリスからは公使森有礼君、法学士西川鉄次郎君、オーストリヤからは書記官河島醇君も出席した。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は浅間しいことに、これが自分のどんな性格を暴露して居るか、まるで心づかず、夕飯を川鉄でたべ、九段からずっと廻って家まで散歩して来、夜レコードで日本音楽をきき、いい心持で、睦しく、（まだ彼女の心の苦しさを感ぜず！",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰途には電車で迂廻して肴町の川鉄に寄って鳥をたぺたりして加藤の家へ土産など持って二人俥を連ねて戻って来た。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは京都の方から景蔵をたよって来て身を隠したり、しばらく逗留したりして行くような幾多の志士たち――たとえば、内藤頼蔵、磯山新助、長谷川鉄之進、伊藤祐介、二荒四郎、東田行蔵らの人たちを優にかばいうるほどの奥行きの深い本陣である。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、たとえば長谷川鉄之進、権田直助、落合｜直亮らの志士たちが小野の倉沢家に来たり投じて潜伏していられるということも、この谷なればこそそれができたのである。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで折尾の坑夫連の間に「鬼の安治川鉄棒で責める」という歌が流行るようになったのである。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒場・石神井の狩は猪を獲ることが多く、文政中の『嘉陵紀行』には荒川鉄橋の北の、今の川口町の辺に鹿の多いことを述べている。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもう一人、主人大坪石見の甥で、宇佐川鉄馬というもっともらしい四十男が、小峰右内の手伝いをして、十年越しこの屋敷の掛り人になっております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二人浜路",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は宇佐川鉄馬、――平次殿か、なにぶんよろしく頼みます」　薄髯を生やした、少し無精らしい角顔の背の低い男――いつでも眠そうで、無口ですが、そのくせ仕事には至って忠実で、障子も張れば、水も汲むといった肌合の人間です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二人浜路",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや一向――私は滅多に浜路さんとは口をきかないのでな」　宇佐川鉄馬は照れ臭そうに笑います。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二人浜路",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇佐川鉄馬は、本当は三十を越したばかりですが、誰の眼にも四十過ぎとしか見えない無精男です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二人浜路",
                "note": "青空文庫"
              }
            },
            {
              "text": "七「御用ッ」　平次が飛付いたのは、掛り人の宇佐川鉄馬でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二人浜路",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あッ、何をするッ」「宇佐川鉄馬、御用だぞ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二人浜路",
                "note": "青空文庫"
              }
            },
            {
              "text": "お篠を殺し、午吉を殺したのはお前だ」「何を馬鹿なッ」　宇佐川鉄馬は小さい身体を跳らせると、苦もなく生垣を越えて、四角な顔を醜く歪めたまま、逃げ腰ながら一刀の鯉口を切ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二人浜路",
                "note": "青空文庫"
              }
            },
            {
              "text": "「畜生ッ、どうするか見やがれ」　宇佐川鉄馬は一刀をギラリと抜くと、一気に縁側へ襲う様子を見せましたが、平次の構えの並々ならぬを見ると、諦めたものか、いきなり肌をくつろげて、ガバリとその切っ尖を自分の腹へ――。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二人浜路",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あッ」　おどろき騒ぐ人々、それを尻目に、宇佐川鉄馬は声を絞りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二人浜路",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
