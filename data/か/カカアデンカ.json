    "definitions": [
      {
        "index": 1,
        "gloss": "household with the wife as the boss",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
