        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の描く風景画は、その色彩感覚において同時代の画家の中で冠絶している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "そのバイオリニストの演奏技術は、他の追随を許さないほど冠絶していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "数ある城の中でも、姫路城の白く美しい姿は冠絶した存在感を放っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女の記憶力は冠絶しており、一度読んだ本の内容を細部まで覚えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この山の頂からの眺めは、まさに冠絶の美しさだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "科学は必ずしも人間最高の徳ではないが、しかし片手に幽玄の思想の玉を載せ、片手に溌剌たる科学の剣を握っていたならば、列国も之には一指もふれる事が出来ず、世界に冠絶した理想国家となるに違いない。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また兵学に精通し、敬神家で、槍は一代に冠絶し、春日の名槍を自在に繰り、剣をよくして、備前｜長船小豆長光二尺四寸五分の大刀を打ち振うのであるから、真に好個の武将である。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村重成ら決死の出陣に香で身を燻じた人多く、甚だしきは平定文容姿言語一時に冠絶し「人の妻娘｜何に況や宮仕へ人は、この人に物いはれざるはなくぞありける」（『今昔物語』）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "石橋の奇、天下に冠絶すると云ふものもあらむ。",
              "citation": {
                "source": "遊羽雜感",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体レフ・トルストイの思想と芸術とは、世界文学に冠絶した強靭な追求力、芸術的描写の現実性をもっているにかかわらず、当時ロシアに擡頭し発展しつつあった社会思想とは全然別な道を行っていた。",
              "citation": {
                "source": "ジャンの物語",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の女は一人たりとも自身たちの愚かさと、乳児死亡率の最高位であることで世界に冠絶したいとは願っていないのである。",
              "citation": {
                "source": "世界一もいろいろ",
                "author": "――日本文化中央連盟――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の女性の忍耐づよさが世界に冠絶していることも周知である。",
              "citation": {
                "source": "若い母親",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、レオナルド・ダ・ヴィンチは、ルネッサンス時代の大天才の一人であり、その綜合的な独創性は冠絶したものです。",
              "citation": {
                "source": "婦人の創造力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも支那の繪畫は、當時の世界に冠絶して居つた。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "揚州の富庶全國に冠絶する意味である。",
              "citation": {
                "source": "歴史上より觀たる南支那の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時揚一といふ諺があつて、富庶繁華を以て天下に冠絶して居つた。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくこれらは、古代時計の蒐集として、世界に類を求め得ないほどに冠絶したものに違いなかった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "類ひなく美しいわが国体の尊崇は、われわれの現在生きつゝある日本の、世界に冠絶する理想のすがたを夢み、その理想達成のために戦はんとするひたぶるな意志によつて示されなければならぬ。",
              "citation": {
                "source": "空地利用",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "類ひなく輝かしいわが国体の尊崇は、われわれの現在生きつゝある日本の、世界に冠絶する理想のすがたを夢みる一臣民としての悲願と、その悲願を幾代かゝつても達成しようとする、ひたぶるな意志とによつて示されなければなりません。",
              "citation": {
                "source": "文化とは",
                "author": "――力としての文化　第一話",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにおいて、私はなぜこう日本人のみが独り世界に冠絶した素質を有するかを考えざるを得なくなった。",
              "citation": {
                "source": "味覚の美と芸術の美",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の自然が、日本の気候風土が世界に冠絶していることは、今さら私が改めて言うまでもないと思うが、日本人の秀れた素質は、偏えに、この自然の天恵何万年を経た結果に帰すべきであろう。",
              "citation": {
                "source": "味覚の美と芸術の美",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "人形はむろんドイツが世界に冠絶した王国で、アメリカも、イギリスも、フランスも問題になりませんと鼻息が荒い。",
              "citation": {
                "source": "オルゴール",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇は万国諸王に冠絶する。",
              "citation": {
                "source": "流れ行く歴史の動力",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何となれば、日本と支那とは同種同文である上に、両国間の経済関係は世界に冠絶しているからである。",
              "citation": {
                "source": "三たび東方の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本を世界に冠絶する美の国、信仰の国たらしめたい。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし仏陀と菩薩像の深さは、飛鳥｜白鳳天平前期において世界に冠絶すると考えないわけにゆかないのである。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（その後、この歌のレコードが日本でもプレスされたが、果してスレザークにしては出来の良いものでなかった）　ブラームスとシューマンにおいても、スレザークはあらゆるレコード・アーティストに冠絶するだろう。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビクターには十六面の吹込みをしているが、独唱では、――幾度も書いたことだが、マスネーの『マノンの夢』〔Manon ― Le Re^ve〕 が絶品で、この歌のあらゆるレコードに冠絶する。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "小谷の攻略については、何といっても、彼の勲功は、冠絶していた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
