[
  {
    "uuid": "b92f3044-52d1-51a3-8c29-309755a92abf",
    "entry": "片恋",
    "reading": {
      "primary": "かたこい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
