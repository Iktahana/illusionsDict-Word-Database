    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unrequited love",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "何年も想い続けているけれど、この片恋が実る兆しはまったくない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼に彼女ができたと聞いて、私の淡い片恋は静かに幕を閉じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "片恋の相手が楽しそうに笑っているだけで、自分まで幸せな気分になれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "言い出せないまま終わってしまう片恋ほど、切ないものはない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それは、片恋というものであって、そうして、片恋というものこそ常に恋の最高の姿である。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　Ｙ君が片恋をした。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋は、必ず片恋のままで、かくして置け。",
              "citation": {
                "source": "困惑の弁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十二年三月　　片恋あかしやの金と赤とがちるぞえな。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "片恋の薄着のねるのわがうれひ「曳舟」の水のほとりをゆくころを。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "よひやみの、よひやみの、いづこにか、赤い花火があがるよの、音はすれども、そのゆめは見えぬこころにくづるる……ほのかにも紫陽花のはな咲けば、新にかけし撒水の香のうつりゆくしたたり、さて、消えやらぬ間の片恋。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、思ふままのこころを挙げてうちつけに掻き口説くよりも、私はじつと握りしめた指さきの微細な触感にやるせない片恋の思をしみじみと通はせたいのである。",
              "citation": {
                "source": "桐の花とカステラ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかしやの花さく見れば水の上にはかなき夏の夢もやどりぬ片恋のわれをあはれと鈴麦の花さく傍を通ひ来にけり夕青き微光の中をあがりゆく足長蜂は足を垂らせり玉赤き蝋マツチする草のなかすでに蛍の臭気むせべり　こうした所縁の深い新作が増補として、「第二桐の花」としてでも加えられねばならない恋々たる気持にもなる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "永井荷風氏が褒め、新しい「白樺」の人たち、武者小路、柳、志賀、里見、萱野の諸君までがロダン号の巻頭に寄せ書して、あれを読んで片恋の身に相成候とか何とか盛んに慇懃を通じて来たものだった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "片恋の清きうれひに泣く人よ。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「片恋」「かるい背広」「春の鳥」等第八、新俗謡体より出でたる印象風の景物詩。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、ここに特筆大書して置きたいのはわが詩風に一大革命を惹き起した『片恋』の一篇である。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかしやの金と赤とがちるぞえな、かはたれの秋の光にちるぞえな、片恋の薄着のねるのわがうれひ、曳舟の水のほとりをゆくころを、やはらかな君が吐息のちるぞえな。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "素知らぬ顔をしていて、心で恨めしく思っていたのに気もつかず、私のほうではあくまでも愛していたというのも、いわば一種の片恋と言えますね。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく似たことなどを近ごろは初めほど感ぜずにいた源氏は、今さらのように驚くべく酷似した二女性であると思って、苦しい片恋のやり場所を自分は持っているのだという気が少しした。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と考へて見るまでもなく「片恋」と極めて簡単に解つてゐたが、よく恋の心理を現した和歌などに「何故か――」「涙ながるゝ。",
              "citation": {
                "source": "明るく・暗く",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　官報局及び雌伏時代露語の両川・高橋時代の官報局・精神心理の研究・罪悪心理と下層研究・最初の家庭生活の失敗・『片恋』・官報局を去る　二葉亭の仕官を説く前に先ずその恩師古川常一郎を語らねばならない。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃『早稲田文学』を根城として専ら新劇の鼓吹に腐心していた逍遥は頻りに二葉亭の再起を促がしつつあったが、折も折、時なる哉、二葉亭はこの一家の葛藤の善後処分を逍遥に謀った結果、終に再び筆を操るべく余儀なくされたのがツルゲーネフの『アーシャ』即ち『片恋』の飜訳であった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ『片恋』一冊ぎりで再び彗星の如く隠れてしまう意であったが、財政上の必要が『片恋』一冊の原稿料では充たすに足りなかったので、あたかも凱旋将軍を迎える如くに争い集まる書肆の要求を無下に斥ける事も出来なかった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "といってエミリーの片恋を知った以上、そのままに放っておけない。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時支那の方に居る友達が集って、互に身上話などを始めて、一体山本さんはどうしたんだと言出したものが有ったら、その時彼は自分の一生は片恋の連続だと真面目顔に答えた。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、椋島技師の死刑が近いと聞いたので、彼女は片恋ながら、なにをおいても椋島を救いたく思い、それには、父博士によって、椋島技師の行状を有利に証言して貰うことができれば、必ず彼女の思いはとどくものと信じ、こうして生と死の境を彷徨する身体をここまで搬んできたのであった。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　さても、さほどまでに多くの人々に懐かしまれた女史の、胸の隠処に秘めた恋は、片恋であったであろうか、それともまた、互に口に出さずとも相恋の間柄であったであろうか。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　金持ちや美男に、片恋や失恋などがありましょうかと、簡単にかたづけられてしまいそうだが、恋というものの不思議さは、そこだといえないでもない。",
              "citation": {
                "source": "モルガンお雪",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
