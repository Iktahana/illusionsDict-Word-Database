    "definitions": [
      {
        "index": 1,
        "gloss": "since some time ago",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "予てからお伝えしております通り、来週の会議はオンライン開催となります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は予てから独立を考えていたようで、ついに会社を辞めましたね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この企画は予てから温めていたもので、ようやく実行に移せそうです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女が海外へ引っ越すことは、予てから家族の間では話題になっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで政宗に心服して居る者はとに角、政宗に対して予てからイヤ気を持って居た者は、政宗に付いて居るよりも氏郷に随身した方が吾が行末も頼もしい、と思うに至るのも不思議では無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに同年五月二十四日、予てから不快であった能静氏が、重態となったので、態々翁を呼寄せて書置を与えたという。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長｜予てから武田の戦法を察し、対抗の戦略を立てた。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "余りに浪士風人間の出入が激しいので、新撰組では、予てからその様子に不審を懐き、六月五日に思ひ切つて踏み込んでみると果して甲冑十組、鉄砲二三挺、その他長州人との往復文書が数通発見され、その中には、「機会は失はざる様」との頗る疑はしい文句があつた。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "段々訊くと、予てから猫の産月が近づいたので、書斎の戸棚に行李を準備し、小さい座蒲団を敷いて産所に充てていたところ、昨夜は宵から容子が変なので行李の産所へ入れるとは直ぐ飛出して息遣いも苦しそうに※々啼きながら頻りと身体をこすりつけて変な容子をする。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "北京に在留中から露西亜の暴状を憤って、同志と共にしばしば公使館に詰掛けて本国政府の断乎たる決心を迫った事もあり、予てからこの大破裂の生ずべきを待設けて晴れの舞台の一役者たるを希望していたから、この国交断絶に際して早まって提調を辞して北京を去ったのを内心｜窃かに残念に思っていたらしかった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄が、予てから私淑している二科会の幹部のＮ氏をも訪ねて見た。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに勝次郎という人の仕事の上手であることをも予てから知っており、この人と一緒に仕事することは、いろいろ智識を開くことにもなろう。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "鋳物の仕事をしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたですか」「ええ、どうも……」と、互いに名乗り合いこそしてはいないが、予てから、顔は充分見知っている仲、自然にその事が、談話の皮切りとなり、私が頭を擡ち上げると、きまり悪そうに其所を去ったことなども笑い話の中に出て、石川光明氏はいかにも人ずきの好い人。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "石川光明氏と心安くなったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸ッ子の住家であるかないかは、ナットーの買いぶりや、喰いぶりを見るが一番よくわかるということを予てから聴いていたが、彼等売り子の話を聞くと、成る程とうなずかせられる。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その彫像を予てから欲しがっていた胡買者のシモン・スヌッドはスパイダーに話を持ち掛けた。",
              "citation": {
                "source": "赤い手",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡田の次男は予てから、隣りずからのことで、私が白衣観音を製作していたことなどを知っており、師匠の代をやっていた種を知っていることだから、私の手柄のように褒めそやしている。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "初めて博覧会の開かれた当時のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄が、予てから私淑してゐる二科会の幹部のＮ氏をも訪ねて見た。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚に脱帽す６・29（夕）　独逸の軍隊が破竹の勢で東部仏蘭西に攻め込んだ時、そこらに住まつてゐた仏蘭西の住民は、予てから独逸人が吝つたれで、慾深で、有る程のものは掻つ払はずには居られない癖を知つてゐるので、てんでに財産を慝まふのに智慧を絞つたものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その呉氏が夫人を愛することも深いが、夫人も呉氏を尊敬し熱愛して、七十翁の夫君が歿せられたら殉死をする覚悟で、斉斉哈爾の呉氏邸には予てから二つの柩が備へられてゐると云ふ事である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような訳で、坂口は予てからの希望通り倫敦へ来て、伯父と一緒に住む事を許されたのである。",
              "citation": {
                "source": "Ｐ丘の殺人事件",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "予てから妻の様子を疑っていたとする。",
              "citation": {
                "source": "彼が殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "穆清は予てから左内の「日魯同盟論」に傾倒し、それがいつか幕府の外交策として採択される日の来ることを固く信じていた。",
              "citation": {
                "source": "城中の霜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の語るところによると、馬場派の行動には予てから監視が付けてあって、今夜の企てもすぐ通報があった。",
              "citation": {
                "source": "野分",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも単なる婦女子の常識以上に、道理と説き方とに人を動かすだけの力を持たせようとすれば、やはり予てから学び且つ考えておらねばならなかった。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼才だの、文學の鬼だのといふ難解な言葉は、あまり使用しないはうがいいのではあるまいか、とかねてから愚案してゐた次第であるが、しかし、それは私の見聞の狹いゆゑであつて、鬼にも、いろいろの種類があるのかも知れない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねてから考えている著書を早く書き初めなければならぬと思う事もある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねてから思い立っていた追憶の記を、このしおに書いておきたいと思う。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、かねてから先生が俳人として有名なことを承知していたのと、そのころ自分で俳句に対する興味がだいぶ発酵しかけていたからである。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぬいはかねてから、自分の身の上にも、いつかは恋愛が来るだろうとは覚悟していた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながらかねてからある不安なしにではなく考えていたことが、驀地に近づいてきているような一種の心の圧迫を感じ始めているのは明かだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二人に聞いて見ますと、二人はまだ会ったことはありませんが、かねてからお互に人と違った身体を持っていることを思いやって、両方で可愛そうに思っていたところですから、喜んで承知いたしました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼才だの、文学の鬼だのといふ難解な言葉は、あまり使用しないはうがいいのではあるまいか、とかねてから愚案してゐた次第であるが、しかし、それは私の見聞の狭い故であつて、鬼にも、いろいろの種類があるのかも知れない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はかねてから此の先生に好意を持つてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、あの夫婦の媒妁人だった筈だし、また、かねてからあの夫婦は、あなたを非常に尊敬している。",
              "citation": {
                "source": "嘘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
