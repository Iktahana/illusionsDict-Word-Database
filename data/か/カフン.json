        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "春になって、花粉がたくさん飛んでいるから目が痒い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ミツバチが桜の花からせっせと花粉を集めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スギ花粉にアレルギーを持つ人が多いようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "車の表面が黄色い花粉で覆われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "風は害虫を攘ひ、花粉の交媒を助ける。",
              "citation": {
                "source": "風と裾",
                "author": "――何人か良案はないか？――",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャンパンのキルクがボーイの鉤鼻から落下すると私のパートナアが横目をつかってボーイに現金で酒代とチップを渡すように催促して別に靴先につける天花粉の代金十｜仙を請求する。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "サラリーメンの洪水のために死骸のような建物の堰が破られて、空にそびえる高楼の窓が花のようにひらくと、女事務員の青と赤の色彩が花粉の媒介の役目をした。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポール流行品商会の二階の美容室では、太田ミサコが弟子にからだ中に花粉をはたかせていた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女の痩せた花粉のついた装飾にすら、僕は情欲をもって鎧ばっている。",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは日のよくあたる風の吹く、ほどよい湿度と温度が幸いする日、杉林が一斉に飛ばす花粉の煙であった。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば昔ある僧侶の学者が顕微鏡下で花粉をのぞいている間に注意して研究した微粒子の運動が、後日物質素量説の実証的根拠として一時盛んに研究されるようになった。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、虻が蜜汁をあさってしまって、後ろ向きにはい出そうとするときに、虻の尻がちょうどおしべの束の内向きに曲がった先端の彎曲部に引っかかり、従って存分に花粉をべたべたと押しつけられる。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲の花粉だってやっぱり僕らが運ぶんだよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "数千の火の玉小僧が列をなして畳屋の屋根のうえで舞い狂い、火の粉が松の花粉のように噴出してはひろがりひろがっては四方の空に遠く飛散した。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな蠅は花粉のような頭をしばらく振って死んでしまった。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに土曜日の京都は、沼の底に妖しく光る夜光虫の青白い光のような夜が、悪の華の巷にひらいて、数々のいまわしい出来事が、頽廃のメシベから放つ毒々しい花粉の色に染まる――というこの形容は誇張であろうか。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤き日はアカシヤのわか葉にけぶり、※肉の黄なる花ちらちらと噎ぶとき怖々と投げいだし、眠りたる霊の人間の五官にもわきがたきいと深きかなしみ……そのゆめはこころもち汗ばみて傷つきし銀毛の耳に痛き花粉は沁み、やるせなき肉体の憂欝に柔かにかろく魘さるれど、汝が母を犯したる霊の不倫をば知るよしもなし。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時過ぎて暮ちかき夏の日は血に染みし呼鈴の声のごとくふりそそぎ、嫋やかなる風は蜜蜂の褐色に、蜜蜂のつぶやきはかろく花粉を落す。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い繻子の手ざはりがきゆつ、きゆつと……暑い、苦しい、くるしい日、渋い鬼百合の赤さ、鮮かな臭の強さ、湿つた褐色の花粉の細かにちる……背後の床の間の大輪。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "附きやすき花粉のしめりのごとく、そはまた※の汗のごとくに顫へやすし。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸触つても指に付いてくる六月の棕梠の花粉のやうに、月夜の温室の薄い硝子のなかに、絶えず淡緑の細花を顫はせてゐるキンギン草のやうに、うら若い女の肌の弾力のある軟味に冷々とにじみいづる夏の日の冷めたい汗のやうに、近代人の神経は痛いほど常に顫へて居らねばならぬ。",
              "citation": {
                "source": "桐の花とカステラ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（小さい藍色の毛虫が黄色な花粉にまみれて冷めたい亜鉛のベンチに匐つてゐる…………）　私は歌を愛してゐる。",
              "citation": {
                "source": "桐の花とカステラ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても明るい山独活だ、雌蕋の花粉は唸つてる。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人の精神はその摂取する一語一音の中にあつて、既にかの花粉のごとく玉露のごとく、芬芬として離離として発光してゐるのである。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "胴は花粉で真っ黄だな。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（小さい藍色の毛虫が黄色な花粉にまみれて冷めたい亜鉛のベンチに匐つてゐる……）　私は歌を愛してゐる。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "金の花粉を漂わせた朝の空、森、岩、崖、芝地、椰子樹の下の村、紅いココア殻の山等の美しさ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火花のように、雷光のように、毒のある花粉のように、嶮しい悪意の微粒子が家中に散乱した。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "調べてみると、一度うつ向きに落ちたのが反転して仰向きになったことが花粉の痕跡からわかる。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちた花の花粉が落ちない花の受胎に参与する事もありはしないか。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花粉や花簪児を売っている化粧品店がそのちかくにあった。",
              "citation": {
                "source": "断橋奇聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆の施十娘は、文世高からもらった銀子をしまい、午飯を喫って、新しくできた花粉と珍しい花簪児を持って劉家へ往った。",
              "citation": {
                "source": "断橋奇聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ・練習始めおゝ、同志よ、あゝ、階級的同志よ、「同志といふ呼び名をいつかふんだんに使ひ合つたね」「あれは一体、何時のことだつたけね」あの時は君と僕とは同志であつた、だから文章の上でも日常生活の上でも同志よ――客観的状勢は――。",
              "citation": {
                "source": "小熊秀雄全集-13",
                "author": "詩集（12）その他の詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿母や女房に向つてはそんな口吻を洩してゐるさうですが、私に向つては、「｜お父さん」のやうになるよ――なんてからかふんですからな。",
              "citation": {
                "source": "夏ちかきころ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
