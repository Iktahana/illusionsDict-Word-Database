[
  {
    "uuid": "e8a36eac-65c7-5b83-acf5-c6995a062b28",
    "entry": "担ぐ",
    "reading": {
      "primary": "かつぐ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
