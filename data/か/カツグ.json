    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to shoulder",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "工事現場で、作業員たちが長い鉄骨を担いで運んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は大きなリュックサックを担いで、山道を登っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祭りの法被を着た男たちが、重い神輿を威勢よく担いで町を練り歩く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "貴下方大勢で、自分を担ぐようにして、此家へ引込んだはどういうわけです。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行は朝から重い天幕だの、写真器械だの、食糧品だの、雑嚢だのを引担ぎ、既に数里の道をテクテク歩き、流るる汗は滝のごとく、身体も多少疲れたので、このさき大子駅まで四、五里の間、二人ばかり荷物を担ぐ人夫を雇いたいものだ、と村中駆け回って談判に及んだが、誰も進んで行こうとする者はない。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャツや上衣は今朝剛力の担ぐ荷物の中へ巻入れてしまったので、暑い道中は誠に結構であったが、この寒さでは閉口閉口。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と令夫人は大きに担ぐ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "拾った金なら届けるわい」「じゃ、掏った金なら持ってるの……」「そや」「本当に掏ったの……」「当りきシャリキ、もちろん……おまけに、掏ったのが紙一枚、それが二千円とはごついやろう」「また担ぐんじゃない……」「まア、聴け……」　そして亀吉の喋ったのは、こうだった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "縄のかかつた四斗樽を、買つて帰ることになつて、松さんは担ぐために縄を掴んだが、芝居をするときのやうに、少しも力を入れないで、力む真似ばかりしてゐて、担がうとしなかつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて聞えて来る太鼓の音と神輿を担ぐ若い衆の挙げるかけ声。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　框の柱、天秤棒を立掛けて、鍋釜の鋳掛の荷が置いてある――亭主が担ぐか、場合に依ってはこうした徒の小宿でもするか、鋳掛屋の居るに不思議はない。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（酒か、）と喚くと、むくむくと起かかって、引担ぐような肱の上へ、妾の膝で頭を載せた。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴下方大勢で、自分を担ぐやうにして、此家へ引込むだはどういふわけです。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "艫を漕ぎ、網を引き、魚を担ぐであらう。",
              "citation": {
                "source": "来年は何をするか",
                "author": "――一九三〇年に対する私の希望・抱負・計画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（莫迦々々しい、何も浜口雄幸の褌まで担ぐ要はあるまい）　とくぐった途端、ガーンと銅鑼の音が鳴った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "広巳が蛇目傘を担ぐようにさして、大森の方からふらふらと帰って来たところであった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お前また妙な敵を持ったもんだな、金と女なら私だって殺してえほど怨があらあ、先の中洲の清元の師匠の口だと、私も片棒｜担ぐんだが、困ったな歌の先生じゃあ。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏神の祭礼に、東京で各町内、侠勇の御神輿を担ぐとおなじように、金沢は、廂を越すほどの幌に、笛太鼓｜三味線の囃子を入れて、獅子を大練りに練って出ます。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳しくみると、親父はよく都合の悪いときにばかり縁起を担ぐのであった。",
              "citation": {
                "source": "縁起に就いて",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "担ぐのは、踊りの晩に限られた為来りなんで。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつ、おれを担ぐのではないかと思っていると、彼はまた言った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "担ぐのは、踊りの晩に限られたしきたりなんで。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に、面の差し渡しが凡そ五尺にも程近い大太鼓を、最も太い孟宗竹の棒に吊して、これを二人の壮丁が前後して担ぐのである。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、貴婦人の動作、運動家の姿勢、重い荷物を担ぐ人、踊る人……と、それはもう数限りはない。",
              "citation": {
                "source": "交遊秘話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は真青になったが、前後の見境もなく、傍にあった石油缶の空き函を頭の上にひっ担ぐと、二十間ほど向うに見える明るい出入口を目がけて、弾丸のように疾走した。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、何十匹と獲た鰻のあごに蔓を通し、それを肩に担ぐ。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下（漁舎のこと）を中心とする数十間の地の積雪は、屈強な男たちの担ぐ畚に運ばれて、またたく間に除かれてしまった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも恐れ入りましたね、他を担ぐなんて。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お玉はこのおばあさんを担ぐつもりずらに」　とおげんは笑って、あまりに突然な姪の嬉しがらせを信じなかった。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は腰をかがめると、入口に斃れている松ヶ谷学士を肩に担ぐと、ドンドン階段の方へ駈け出して行った。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "或人の画に童子一人左手に傘の畳みたるを抱へ右の肩に一枝の梅を担ぐ処を画けり。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「また、かつぐんぢやないのか？",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何やかやそれぞれまとめて番ニョに乗せ、二人で差しあいにかつぐ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
