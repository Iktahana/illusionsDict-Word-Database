        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "而も、ついうつかりと生温い空氣のむつとした煙草葉乾燥室へはいつた刹那、輕い喘息の發作を誘發され、あとになつて今日は珍しく用心深く携へて來たアストオル吸入器が役に立つやうな羽目になつてしまつた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾燥室から運ばれる頭付軸木を手ごころで一定の分量だけ掴んで小函の抽斗に詰め、レッテルを貼った外函にさす、それを、手を打ち合わす、拍手のような動作のように、一瞬に一箇ずつ、チャッ、チャッとやってのけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "軸列と、浸点と、乾燥室は幹太郎の受持になっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "受持の浸点作業と、乾燥室から、事務室の計算係にまわされた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ葉をかいて乾燥する運びになるが、乾燥室建築の費用の捻出に惱まぬものはない。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾燥室は共同出資で建てることによつて、負擔を輕くするやうにしてゐるが、自分で一室建て増さねばならぬやうな時には、費用は少くとも百五十圓はかかり、それは年六分ぐらゐの利子で無理して借り入れられ、あとあとまでも長く尾を引く。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草乾燥室は焚口が相對して二室建つてゐた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日の夜明け、朝飯前に、昨夜の葉煙草を猫車に積んで、乾燥室へ押して行く。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "資金の都合から乾燥室を共同出資で建てねばならぬのと、乾燥といふ仕事の性質そのものが、個々別々では容易ならぬことなので、共同が始まつたのであるが、そしてこれは益々押し進めねばならぬことなのであるが、かうした矛盾があつては乾燥そのものの共同動作すらきはめて不徹底なものに終ることになる。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝飯をすました人々が、再び乾燥室に戻つて來た時のことであつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "組合員のほかにも暇のある人々がやつて來て、乾燥室の前に据ゑた、一間に四尺もの牀机に腰うちかけ、茶を飮んで、しばらく話をしては歸つた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "共同の費用のなかから買つて乾燥室においてある茶は、駿介などにもよくわかる、百姓には不似合な上茶であつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貰ひ湯がすみ、夕飯がすむ頃から、この乾燥室の牀机はさらに賑つた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、足もともおぼつかなげに、空いてゐる隣の乾燥室の中へ入つて行つた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿介は乾燥室のすぐ傍の井戸端へ行つて、顏を洗つたり、體を拭いたりした。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿介は、朝十時頃に乾燥室に行つて、釣り込んだ葉煙草を室内から取り出しにかかつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾燥室の近くにちよつとした廣場があり、櫻の木が一本立つてゐる。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは肥料代のほかにも、乾燥室の借入金なんぞがあるけんのう。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから乾燥方法が内地種の聯干とは違つて火力乾燥ですから、乾燥室に金がかかり、今迄よりも固定資本が要つて、下層農民にはなかなか作れないといふこともあります。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾燥室で夜を明して歸つて來ると、朝の涼しい間少し寢て、田へ入る。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして布半の温泉で冷えた体をあたゝめ、濡れた洋服や靴を乾燥室へあづけた。",
              "citation": {
                "source": "霧ヶ峰から鷲ヶ峰へ",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "船室の暑さときたら、蒸気を使う洗濯屋の乾燥室のようでした。",
              "citation": {
                "source": "手紙",
                "author": "一八九三年七月二二日付　チェンバレン　宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこれほど多くの穀類を、粒のままや、粉にしたのや、また刈り取ったままで貯えていたり、倉や物置や乾燥室を、こんなに夥しい麻布や羅紗や、羊の皮の鞣したのや生のままのや、乾した魚や、いろんな青物や、肉製品で一杯にしている者が他にあったらお目にかかりたいものだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾燥室はその性質上から二階にあったので階段を降りねばならなかった。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「紙幣乾燥室の女工」――岩藤雪夫）　この「オマタギ」の一節は、決して吾々の眼にその情景を彷彿させはしない。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この部分はコンクリート造りで、この一階が倉庫、乾燥室、ボイラー室になっている。",
              "citation": {
                "source": "アラスカ通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら過失に違ひおまへんね、何分小さいものだすよつてに、乾燥室から運び出す時につい燐を塗つた箱を落したんだすよつてに、過失と云へば過失だんね。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "『此処の乾燥室は三ヶ月に一度位ゐは屹度火が出るのです。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "山小屋は、広い料理場と乾燥室のついた、二階建のがっちりした建物で、大きな広間の天井には煤色の栂の太い梁がむきだしになっている。",
              "citation": {
                "source": "キャラコさん",
                "author": "雪の山小屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャーミングさんが山小屋へやって来ると、キャラコさんは、みなをひとまとめにして乾燥室へ押し込んで『おはなし』をはじめた。",
              "citation": {
                "source": "キャラコさん",
                "author": "雪の山小屋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
