[
  {
    "uuid": "3fb7014d-fbd9-56ce-a6f7-311c629206aa",
    "entry": "貫徹",
    "reading": {
      "primary": "かんてつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
