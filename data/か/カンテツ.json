      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "accomplishment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すなわち、数尺の鉛板あるいは百尺の水層を貫徹して後にも、なお機械に感じるのであるから、ビルディングの中の金庫の中にだいじにしまってある品物でもこの天外から飛来する弾丸の射撃を免れることはできないわけである。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の瞬間までどんなことでも胸一つに納めておいて、切りだしたら最後貫徹しないではおかない清逸の平生を知らない園ではないはずだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が貴方を愛する力の及ぶ限りはこの希望の貫徹に向つて進まねばならない。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が之れまで、自分の目的に趺蹉に趺蹉を來し、幾度びか斷然吾が志を抛たんと欲して、抛ち得ざるものは、親父の決心を思ふと、僕は飽くまで此の目的を貫徹せなければ生きてはゐられないと、奮然として勇猛心を起すが常だ。",
              "citation": {
                "source": "自傳",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "触れない小説の意味をもう少し説明しないと余の所存が貫徹しまいと思う。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてこの国では、妥協が貫徹への最短距離なのだ。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいおい、みんなどうしたんだい」　一足｜後れて出勤した課長は、この光景に不機嫌な顔をして叱ったが、内情を聞くに及んで愉快そうに笑いながら、社員を押し分けて自分が加奈江の卓に近寄り「よく貫徹したね、仇討本懐じゃ」と祝った。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一なる生命の根源に貫徹すべきのみ。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "――――――――――――――――　城代も両奉行もいちを「変な小娘だ」と感じて、その感じには物でも憑いているのではないかという迷信さえ加わったので、孝女に対する同情は薄かったが、当時の行政司法の、元始的な機関が自然に活動して、いちの願意は期せずして貫徹した。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんこの本の絶版騒動を体験する以前からも、本作りと普及のための仕組みに資本の論理が貫徹していることは承知していました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがある一人のデザイナーの美意識が徹頭徹尾貫徹した社会に放り込まれたとして、才気煥発で人に頭を抑えられることが大嫌いなあなたは、そこで何をするのだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "――――――――――――――――　城代も兩奉行もいちを「變な小娘だ」と感じて、その感じには物でも憑いてゐるのではないかと云ふ迷信さへ加はつたので、孝女に對する同情は薄かつたが、當時の行政司法の、元始的な機關が自然に活動して、いちの願意は期せずして貫徹した。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、規則の点だが、委員会で、おもての意志が、はたして貫徹するだろうか、僕は、その点に疑いを持つよ」波田が言った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "御｜寵愛の深い人であったから、お暇を許しがたく帝は思召したのであるが、いろいろなことを言い出して大臣が意志を貫徹しようとするので、帝はしぶしぶ許しあそばされた。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし永い画壇生活の中にあつて、自己の仕事を貫徹するといふ方法の樹てかたをきめながらその制約の中で、仕事を押さへ、押さへ進めてくるといふことも、これまた非常な『人間の力』を必要とする。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "取出でていうほどの奇はないが、二葉亭の一生を貫徹した潔癖、俗にいう気難かし屋の気象と天才｜肌の「シャイ」、俗にいう羞恥み屋の面影が児供の時から仄見えておる。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "産児制限に依て象徴される、婦人の享楽的権利の主張は、医術と薬剤の発達でドシドシ貫徹されている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうだよ、彼奴等に勝つためには科学的に正しい方針と、そいつをどんな事があっても最後まで貫徹するという決意性があるだけだ。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "その自負を最後まで貫徹するために、彼奴等に、捕かまったりしてはならなかった。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる理由があっても個人を殺すということはできないということを党の規律の中に挿入することを要求するんだ」「君の即座の死をもって中央委員は回答にかえるだろう」「僕は僕の死をもって目的を貫徹する」　低い、物凄い笑いが二百二十四号の口を洩れた。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "目的を貫徹するに、それが最も適当な方法だと考えたからだ。",
              "citation": {
                "source": "「古琉球」自序",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の如き考の起るのは、つまり触覚が他の感覚に比して一般的であり且つ実地上最も大切なる感覚であるから、この感覚より来る者を物の真相となすに由るので、少しく考えて見れば直にその首尾貫徹せぬことが明になる。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勤労大衆の意見、利益を代表して主張し、その貫徹のために闘う代表者を大衆選挙によって決定する仕組である。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、既に幾度か日和見主義分子を振い落し、プロレタリアート英雄主義に武装し、真に「鋼鉄」の党であったボルシェビキ党は、あらゆる困難な条件の中で最後まで革命を貫徹したのである。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤軍の中には共産党の細胞が形成され党の指導が貫徹している。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "男にしろ女にしろ、めいめいの条件に応じて生活意欲を貫徹するためには夫婦の結合にもそれがプラスの力となるものと、マイナスの作用を及ぼすものとある。",
              "citation": {
                "source": "夫婦が作家である場合",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学におけるレーニン的党派性の貫徹を、真のボルシェヴィク作家にふさわしく熱情と世界観によって、実践した。",
              "citation": {
                "source": "同志小林の業績の評価に寄せて",
                "author": "――誤れる評価との闘争を通じて――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
