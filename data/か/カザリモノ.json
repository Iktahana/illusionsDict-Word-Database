        "examples": {
          "standard": [
            {
              "text": "昔の帆船の船首には、勇ましい飾り物が取り付けられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その博物館では、歴史的な船舶に使われた様々な飾り物を見ることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "船の飾り物は、航海の安全を祈る意味合いもあったらしいね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
