    "definitions": [
      {
        "index": 1,
        "gloss": "nursing (a patient)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
