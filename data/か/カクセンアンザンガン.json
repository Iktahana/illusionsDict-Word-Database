        "examples": {
          "standard": [
            {
              "text": "地質調査で採取されたサンプルには、黒い角閃安山岩が多数含まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この火山岩は、火砕流によって運ばれてきた角閃安山岩で構成されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "露頭で見つかった岩石は、斑状構造を持つ角閃安山岩だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "石楠花の咲いていたその背後の絶壁は、高さ九十尺幅百二十尺の屏風を立てたような角閃安山岩から成立つ。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            }
          ]
        }
