        "examples": {
          "standard": [
            {
              "text": "宿命のライバルと呼ばれた二人の剣士は、十年ぶりに再会した御前試合の舞台でついに干戈を交えることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "戦国時代の武将たちは自らの領土と家名を守るため、隣接する大名と幾度となく凄惨な干戈を交えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "議場では与野党の論客たちが激しい言葉を飛ばし合い、さながら戦場で干戈を交えるかのような殺気立った雰囲気だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし聡明な徳川慶喜は、惰弱に慣れた旗本を以て、慓悍な薩長二藩の兵と、干戈を交えるということの、不得策であることを察していた。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国と国との間には干戈を交える真の戦争のほかに、つねに平和の戦争なるものがあって、これに敗ければやはり国は衰える。",
              "citation": {
                "source": "教育と迷信",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
