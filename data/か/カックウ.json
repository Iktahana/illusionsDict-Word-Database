    "definitions": [
      {
        "index": 1,
        "gloss": "gliding (through the air)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "鳥は翼を広げ、音もなく滑空していく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ハングライダーに乗った冒険家が、青い空を悠々と滑空した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "急降下する飛行機が、エンジン停止後も驚くほどの距離を滑空した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "風に乗って、紙飛行機が部屋の中を滑空している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "翅を擴げて、見事な滑空をして、十メートルも二十メートルも飛ぶ。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして長い滑空の末に眞黒なうねりの横腹にぷつりと頭を突込む。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな飛魚は、滑空距離も長く、五十メートルも百メートルも、翅を休めないで飛んで行く。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "エンジン・スイッチを切って得意な滑空。",
              "citation": {
                "source": "旅客機事件",
                "author": "大庭武年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして翼面荷重がきいて来て、機体は超音速ジェット機の滑空と同じ状態になる。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この状態でどんどん滑空しているうちに、機体の表面温度は更に上り、最高摂氏七百四〇度近くまで上る計算になる。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にできるのは唯、後に彼が囁いた支離滅裂な言葉を繰り返すこと、二人して明白かつ現実的なショックを受けた後、風の責め苦を受けつつ山間の隘路を滑空する機上で彼に叫びを上げさせたあるものに関する混乱した囁きを繰り返すことのみである。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗ろうと前進した時、何かが横を滑空し、頬を優しくなぜ、母の掌のような感触があった。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "シイラたちは、滑空するトビウオの下を、水を切り裂きながら進んでいく。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "道路の黒い路面に雨の層が次々に衝突しては、風の方向に向けて滑空していった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "フレズノのそのあたりは、街なみそれじたいが、時間のなかを過去に向けて存分に滑空して停止した場所、という雰囲気を濃厚にたたえていた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽が昇り、霧は次第に薄れ、その薄れた霧のなかを海鳥が滑空した。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルメットの前にまわってきて、小さなグライダーのように、木枯らしのなかを滑空していく。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だのに、滑空しつつ反転をつづける枯れ葉が、前方に見える。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
