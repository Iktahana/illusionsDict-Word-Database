    "definitions": [
      {
        "index": 1,
        "gloss": "moon-viewing on either the night of the 15th day of the 8th month of the lunisolar calendar or on the night of the 13th day of the 9th month of the lunisolar calendar, but not both nights",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "十五夜だけ見て十三夜を忘れるのは片月見といって、昔から縁起が悪いとされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「片月見になっちゃうから、来月も絶対にお月見しようね」と子供と約束した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "忙しさにかまけて先月の月見を逃したから、今月だけ見るのは片月見で気が引ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「えっ、今日お月見するの？ 先月見てないなら片月見になっちゃうよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「へえ、片月見になるのも忌ですから。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "片月見をすると悲しいことがあるといふ古い諺にとらはれて、月見のしつらへをしなかつたのがかうなるともの足らない氣持ちがした。",
              "citation": {
                "source": "おとづれ",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "金があつてしみつ垂れで、人づき合ひが嫌ひで、恐ろしく風流氣のある金兵衞は、八月十五日の名月も、この獨自のシステムで觀賞し、悉く良い心持になれたので、それを又くり返して、その頃嫌つた片月見にならぬやうにと、いとも經濟的な魂膽だつたに違ひありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "弱い浪人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
