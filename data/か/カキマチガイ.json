        "examples": {
          "standard": [
            {
              "text": "ごめん、宛名に小さな書き間違いがあったみたいだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この書類、名前の漢字で書き間違いがあったから、もう一度書き直す必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "電話番号をメモしたんだけど、一文字書き間違えてたみたいで、相手に繋がらなかったよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "どうにかガリが切れるようになってからも、同音異義語の誤りや漢字の書き間違いで笑いをとり続けます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "平家が思い忘れたか、赦文を書いた役人の書き間違いか、これはどういうことなのか、おれにはわからん」　狂ったように泣く俊寛の両手には、浜のぬれた砂がつかまれた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            }
          ]
        }
