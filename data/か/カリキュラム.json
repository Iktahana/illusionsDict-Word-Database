        "examples": {
          "standard": [
            {
              "text": "来年度の語学研修カリキュラムは、会話力を重視した内容に刷新されるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大学のウェブサイトで、各学部のカリキュラム詳細が確認できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいカリキュラムでは、実践的なプログラミング演習が大幅に増えました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「このカリキュラム、卒業までに全部終わるかな？」と彼は不安そうにつぶやいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この教育カリキュラムを担当する同社の笹原正隆教育訓練部長によれば、社内にはマイコンの権威は大勢いるが、会長、社長が〈生徒〉ではやりにくいだろうと配慮して、講師は日本情報研究センターの女性インストラクター二人にお願いした、という。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "カリキュラムの都合で一年の半分は授業を持っていなかった山下は、一九八〇（昭和五十五）年と翌八一年のそれぞれ半年を、マイクロソフトでソフトウエアの開発者として過ごした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★ホビイストへの公開状　私にとって、現在のホビイ市場における最大の問題は、すぐれたソフトウエアのカリキュラムや書籍、そしてソフトウエア自体が存在していないということです。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "カリキュラムで命題論理学の基礎を取り扱う時期になって、桜井はこのテーマならエレクトロニクスに対する松本の興味と数学の授業への関心を結びつけてくれるのではないかと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "中世大学のカリキュラムにおいて天文学は音楽、代数学、幾何学とともに４学科（＊文法、論理学、修辞学の３学科に続いて習う）となっていた。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃から種々の医学校においてしばしば解剖が行われるようにはなっったが、15世紀のパドヴァ大学の念入りのカリキュラムでも人体の研究のための準備がなされていなかった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はカリキュラムに化学の系統的な教育を最初に導入してガレノス主義者とパラケルスス主義者を調和させようとした。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ぎゅう詰めカリキュラムの現状からすると、医学史を必須課目にすることは好ましいとは言えない。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "預言者の学校で医学はカリキュラムの一部として必要だったに違いない。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学のカリキュラムは５年間で外科学のカリキュラムは４年間であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学のカリキュラムの欠点を厳しく指摘したもので多くの敵を作るとともに多くの友達を作った。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
