      {
        "index": 1,
        "gloss": "Hawaiian ladyfish (Elops hawaiensis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
