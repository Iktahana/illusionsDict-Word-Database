        "examples": {
          "standard": [
            {
              "text": "「お父さん、肩もみしてあげようか？」「おっ、助かるなあ。右の肩甲骨のあたりを頼むよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "デスクワークが続いて首が回らなくなったので、休憩時間に同僚と肩もみをし合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「はい、肩もみ券！有効期限はなしだよ」「ありがとう、今夜さっそく使わせてもらおうかな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "小屋は槍沢も大槍も殺生も槍の肩もみな屋根だけは出ている。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩もみてともに眠るか春の雨　　　　百洞　春雨の懶さとでもいうべきものを現した句である。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "よほど熟練しているのだろう、札の切りかたもみごとだし、茣蓙へ打ちつける音も冴えていた。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
