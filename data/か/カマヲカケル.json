    "definitions": [
      {
        "index": 1,
        "gloss": "to trick someone (into confirming or revealing the truth)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "刑事は容疑者の言葉の矛盾をつくために、巧妙に鎌をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼が本当のことを言っているか確かめるため、私はあえて鎌をかけてみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人の怪しい行動に、兄がさりげなく鎌をかけて真実を聞き出そうとしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "取引先の担当者が話をごまかそうとしていたので、決定的な証拠を出して鎌をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その写真を、直ぐに現像すると青山さんは、「つぼ半」へ遊びに上ったんだそうですが、そこで何気なく女中にその写真を見せてカマをかけると「おや、この中に、うちの旦那さんがいる」ってことが判って、それで、いよいよ、あの一網打尽の大捕物ってことになったんです……え？",
              "citation": {
                "source": "あやつり裁判",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしはお会いしたことないんです」「おや、ご夫婦なのに」　意外というより軽蔑の語調だったが、同じ調子で、「清さんも早く結婚すればいいのにねえ」　カマをかけるような言葉に、俺は、「まるで仙人みたいだから、結婚なんて考えませんね」「困った人ねえ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
