    "definitions": [
      {
        "index": 1,
        "gloss": "papercutting (performing art)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「寄席の紙切り師が、客からのリクエストを受けてあっという間に龍を切り出した。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「伝統芸能の紙切りを間近で見ると、ハサミの動きが流れるようで驚かされる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「『桃太郎！』という声が飛ぶと、紙切りは下書きもなしにその場面を再現した。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "たとえば机の上にある紙切りが見えないであたり近所を捜し回ることがある。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土人の売りに来たものは絵はがき、首飾り、エジプト模様の織物、ジェルサレムの花を押したアルバム、橄欖樹で作った紙切りナイフなど。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "原紙切りを職とする〈孔版家〉が育ち、プロの誇りをかけた新しい書体や技術の開発、器具の改良が進められました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "型彫りというものは、鉄へ反対にメガタに彫って、それが型となって、貿易向きのマッチ入れとか、灰皿とか、葉巻入れ、布巾輪、たばこ差し、紙切り、砂糖｜挟み、時計枠など、いろいろ外国向きの物品を作るのだが、それを一つあなたの意匠を凝らし、絵師の手を借りずに、ジカ附けに彫って頂こう。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "貿易品の型彫りをしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴンドラの形をした紙切りをはさんだ読みかけの本の頁をやたらにバラバラとめくったりして眠るまでの時間の費し方を考える様な様子なんかした。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "象牙の紙切り小刀で、初めの方を少し切って、表題や人物の書いてある処を飜して、第一幕の対話を読んでいる。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙切りで一方も二方も切りつつあるのは詩集か何かの本であるが、その中に遠い国で別れて来た恋人の目が笑みを含んで自分を見て居るやうに思はれるとはをかしいものであると云ふ歌。",
              "citation": {
                "source": "註釈與謝野寛全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオンの首のついた紙切りナイフが現れてきた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は日に一度、薄暗らい秘密の部屋へもぐりこんで、トラムプの匂ひをかぎ、ナポレオンの首のついた紙切りナイフをもてあそび、そしてあの重たい本をくりひろげて、決闘の絵をみるのであつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "色物には尺八の扇遊、ビール瓶の曲芸の直造、紙切りのおもちゃ。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙切りの正楽がいる、故柳枝（春風亭・七代目）門下の目の悪い若い前座がいる。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙切り遊びにたいくつして、山茶花も散つてしまつた。",
              "citation": {
                "source": "測量船拾遺",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　泰造は、水牛の角でこしらえたトカゲの形の紙切りで巻紙をきりながら、「あったようだよ」　そういうものの、はっきりとは思い出せないで、多忙な人らしいうっかりした調子で答えた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイヌは自分等の順番になると、大きな漆塗の杯に、酒をなみなみとつぎ、彫刻した紙切りナイフに似た、長い、薄い木片を杯の上にのせ、腰を下してから、いろいろな動作をつづいて行った。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このボール紙から、いかなるものが出来上がりましょうや、お目とめられてご一覧……」　彼はボール紙を左手に鋏を右手にもって落語家の「紙切り」の仕草よろしく、出鱈目の口三味線で拍子をとりながら、ボール紙を五本の指のある手の形に切り抜いていった。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かみきりや姿を見せよ神国のおそれを知らばやくたたらざれ",
              "citation": {
                "source": "簪につけた短冊",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、大きな、かみきりむしが飛んできてぷつりと切ってしまいました。",
              "citation": {
                "source": "谷間のしじゅうから",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘はそうしてセエラが見えなくなるまで、かじりかけのパンをかみきりもせず、じっとセエラを見守っていました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の長い触角で有名な、あのかみきりむしもやはりもとは白虫だ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "長いかみきりの触角を幼虫は何でつくるのだらう？",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、まるで此の不潔な必要を償ふように、それ等の幼虫の一つは、あとでは磨いた青銅と其の光輝を競ふ綺麗な蠅になるし、他のものは、見事な宝石や金の光彩と其の立派な上衣とを競はせて麝香の匂をさせてゐるかみきりになるのだ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "をとどし枯れたポプラを薪にしたところが、中には澤山のかみきり虫の幼虫が入つてゐて、木もこれでは生きられないと思ふ程だが、中に立派なかみきりの成虫が入つてゐた事だ。",
              "citation": {
                "source": "春",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜂、虻は朽木のうろなどに冬を隱れてゐるものだが、かみきりも越年するかどうか。",
              "citation": {
                "source": "春",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネズミはとうとうなわをかみきり、しばられていた両手は、自由になったのです。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
