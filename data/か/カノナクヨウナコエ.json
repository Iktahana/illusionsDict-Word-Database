        "examples": {
          "standard": [
            {
              "text": "「すみません…」と、彼女は蚊の鳴くような声でやっと答えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "体調を崩してからは、蚊の鳴くような声しか出せなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "先生に叱られた生徒は、蚊の鳴くような声で返事をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "緊張のあまり、スピーチの出だしは蚊の鳴くような声だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「…………」「下手くそやぞ、お前らの掏り方は……」「今夜はじめてだす」　次郎は蚊の鳴くような声を出して、「――かんにんしとくなはれ、大将」　と、ぺこんと頭を下げた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅弁の売子にしても、体躯に似合わず蚊の鳴くような声だ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "どす黒い口許から白い歯が震え、何か蚊の鳴くような声が洩れている。",
              "citation": {
                "source": "幽霊",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔色を見ると一向平素と変らないが、なにしろあまりひどい汗なので、一人娘の花世が心配してたずねると、庄兵衛老、れいのお不動様の三白眼で、じろりと花世の顔を睨めあげ、「馬鹿め、汗が、なんだ」　と、蚊の鳴くような声で叱りつけた。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "稲荷の使",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャラコさんは、蚊の鳴くような声で、つぶやいた。",
              "citation": {
                "source": "キャラコさん",
                "author": "女の手",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白いから、行って見ていらっしゃいよ」　キャラコさんが、蚊の鳴くような声で、いう。",
              "citation": {
                "source": "キャラコさん",
                "author": "ぬすびと",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に好奇心だけかそれとも同情といったようなものですか」　花は羞しそうにチラと上眼を走らせると、蚊の鳴くような声で、「王様は、いつか、あたしのことを、お鶴さんに、可愛いい娘だとおっしゃったそうですね。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "特種どころか、何もかもおさらばだ」　と呟くと、蚊の鳴くような声で支配人に、「覚悟はいいといってくれたまえ」　まもなく二人の局長が入って来る。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……みちみち酒月から聞いたろうが、こっちの訊ねることに返事をして貰えばそれでいいのだ」　花は蚊の鳴くような声で、「知っていることなら御返事しますけど」　キッと唇を噛んで、「でも、こんな……」「知らないことは訊きやしない。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、安南の諜報部長を電話に出してくれ、と蚊の鳴くような声でいう。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "どぎまぎして、顔を赤らめてうつむくのを、すかさず、グイとその肩先を掴んで、「どうだ、そうだろう」　蚊の鳴くような声で、「知りません」「そうか、お前は知らなかったのか。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「其方は、いずれの者じゃ、親共の商売、名前、真っ直ぐに申立てえ」「木場の廻船問屋、増田屋惣兵衛の娘、藤と申します」　娘は蚊の鳴くような声で、これ丈け言うのが精一杯でした。",
              "citation": {
                "source": "礫心中",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう短いひと言にさえわずかに残った気力を一所懸命あつめなければならないように、そして無駄をしないためにたくさんの話のなかから出来るだけ大切なひとつをよりだそうとするように、ながい間をおいてぽつりぽつりと蚊の鳴くような声でいいだすのであった。",
              "citation": {
                "source": "妹の死",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "謡は有名の美声で、体格相当に幅もあり量もあり、初心の我々蚊の鳴くような声と対照すこぶる妙。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
