        "examples": {
          "standard": [
            {
              "text": "温室には、見事な紫色のカトレヤがいくつも咲き誇っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母は、毎年誕生日に届くカトレヤの鉢植えをとても楽しみにしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カトレヤの甘く上品な香りが、部屋全体にふんわりと広がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "絵画教室のモチーフとして、大きなカトレヤの花がテーブルに飾られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "温室の中のカトレヤの花のような、眼の覚めるような若いお嬢さんが六人ばかり、部屋の隅の天鵞絨の長椅子に目白押しになって、賑やかな笑い声をあげている。",
              "citation": {
                "source": "キャラコさん",
                "author": "新しき出発",
                "note": "青空文庫"
              }
            }
          ]
        }
