[
  {
    "uuid": "d9bfb377-c968-5fa7-8f28-63a760983ac8",
    "entry": "揶揄う",
    "reading": {
      "primary": "からかう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-他動詞"
