[
  {
    "uuid": "9c14c3f4-f0f5-5d2b-88b9-bbce001ce34b",
    "entry": "柿の木",
    "reading": {
      "primary": "かきのき",
      "alternatives": [
        "カキノキ"
      ],
      "is_heteronym": false
    },
    "grammar": {
