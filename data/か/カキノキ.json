    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese persimmon (Diospyros kaki)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "田舎の祖父母の家には、毎年たわわに実をつける立派な柿の木が植わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "柿の木がオレンジ色に染まり始めると、この街にもようやく秋が来たのだと感じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今年もたくさんなってるね」と言いながら、竹竿を使って柿の木から実を収穫した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "冬になると柿の木は葉を落とし、枝先に残った数個の「木守り柿」が寒空に映える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "僕は民さん一寸御出でと無理に背戸へ引張って行って、二間梯子を二人で荷い出し、柿の木へ掛けたのを民子に抑えさせ、僕が登って柿を六個許りとる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿の木の下から背戸へ抜け槇屏の裏門を出ると松林である。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの遠くの柿の木を御覧なさい。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土蔵の横にある大きな柿の木の大枝小枝がまっさおな南国の空いっぱいに広がっている。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（飛行機に残つたのは僕、　　バットの空箱を蹴つてみる）三歳の記憶縁側に陽があたつてて、樹脂が五彩に眠る時、柿の木いつぽんある中庭は、土は枇杷いろ　蝿が唸く。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……玄關番から私には幼馴染と云つてもいゝ柿の木の下の飛石づたひに、うしろ向きに、袖はそのまゝ、蓑蟲の蓑の思がしたのであつた。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この柿の木が其中庵を庵らしく装飾するならば、そこらの茶の木は庵の周囲を庵として完成してくれる。",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・寒空のからりと晴れて柿の木・ふくらうがふくらうに月は冴えかへる・よつぴて啼いてふくらうの月・冴えかへる月のふくらうとわたくし・恋のふくらうの冴えかへるかな　二月十五日雪、雪はうつくしいかな、雪の小鳥も雪の枯草も。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども村人たちが、ほんたうに鳥右さんに感謝したのは、十日ばかりもつづけて村の山田をあらしに来た大｜猪を、鳥右さんが矢で射殺したときと、渡り者の山伏が、村の柿の木から、七十八の柿の実をぬすんで逃げようとしたのを、一里ばかりおつかけていつて七十一の柿の実をとりかへして帰つたときでありました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると奇妙なものが、庭の柿の木につないであつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿の仔は驚いて、向かふへ逃げようとしたが、首の縄が柿の木につないであるので逃げられなかつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして縄を柿の木から解いて、その端を栄蔵の手に握らせてくれた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくれんぼのつづきで、まだあの子供がどこかにかくれているかも知れないというので、盗人たちは、みみずの鳴いている辻堂の縁の下や柿の木の上や、物置の中や、いい匂いのする蜜柑の木のかげを探してみたのでした。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "門を出て、柿の木のそばまで来ると、何か思い出したように、かしらが立ちどまりました。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時過ぎの陽が門口に一本ある柿の木を染めていた。",
              "citation": {
                "source": "怪人の眼",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の隅になった赤い実の見える柿の木の下へ、嬰児を負った婦が来た。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに珍しき町の名に、大衆免、木の新保、柿の木畠、油車、目細小路、四這坂。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "園生は、一重の垣を隔てて、畑造りたる裏町の明地に接し、李の木、ぐみの木、柿の木など、五六本の樹立あり。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対側にひねこびて煩わしく空に枝を撓み張った柿の木が三四本一せいに若芽をつけています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何といふ悲しい光景であろう、そこには不意の輝きに驚かされた柿の木が真青に顫へ上つた、と思ふと、濡れた葉とまた真青な果の簇がキラキラと私の眼を射返した。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の右側は並んだ人家の下の低い崖で、左側は勾配の緩い畑地であったが、其処には熟した麦があり蜀黍があり、麻があり柿の木があった。",
              "citation": {
                "source": "蟹の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その屋敷の裏庭には、大きな柿の木があつて、枝々には澤山の實が赤く熟してゐて、その下にひよろ高いコスモスの花が白やうす紅に咲いてゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿の木の枝にそを掛け。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝平は、老耄の痩馬を、前の柿の木に繋いで置いて、すぐ馬小屋をつくりにかかった。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿の木の下に四角な穴を掘り、近くの山林から盗伐して来た丸太を組み立てて、その周囲には厚い土塀を繞らしたのであった。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シギもいつしかせんだんを去って、庭先の栗の木、柿の木に音のするほど雨も降りだした。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯今まいります」　柿の木の上で返事をして、五十四五の男が笊をかかえながら降りて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "日のまだ落ちない内から庭を覗いて居た月が白く、軈てそれが稍黄色味を帶びて來て庭の茂つた柿の木や栗の木にほつかりと陰翳を投げた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が其柿の木を知つた頃は鹿を吊るしたといふ枝は梯子も屆かぬ程上の方であつた。",
              "citation": {
                "source": "菠薐草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿を吊るした柿の木はどうしたといふと既になくなつて居る。",
              "citation": {
                "source": "菠薐草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
