        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "公園の古いベンチに座って読書をしていたら、カサリと軽い音を立てて枯葉が膝の上に落ちてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ねえ、この枯葉を山のように集めて、幼稚園のみんなで大きな焚き火をしたらきっと楽しいと思わない？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "強い北風に舞う枯葉が歩道の隅に吹き溜まりを作り、街並みに本格的な冬の訪れを告げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "動物園にて灼きつく如く寂しさ迫りひとり來りて園内の木立を行けば枯葉みな地に落ち猛獸は檻の中に憂ひ眠れり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近景には低い灌木がところどころ茂って中には箒のような枝に枯葉が僅かにくっ付いているのもある。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると、街路樹の葉が枯葉となって女や男の冬着の帽や服の肩へ落ち重なるのも間のない事だ。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンデンの嫩芽の萌えを見て過ぎしこゝに又来ぬ枯葉落つる日　静かな声、物うげな調子、それを味うて見るべきである。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "結句の『枯葉落つる日』この一句これを取離して見れば、ただそれだけのことで、何等作者の独創があるのでなく、唯一句の記号に過ぎない詞であるが、この歌の結句にこの一句を置いて見ると、この平凡な一句が一首全体の上に、非常に淋しい影響と共鳴とを起すのである。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンデンの枯葉の落つる秋もまたけおもき空は曇りてあるなり　これは前の歌のような感じを得られない歌である。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草が無くなると、よもぎの枯葉をきせるにつめて喫います。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度枯葉が風に吹れて飛んで来たやうに、爺いさんは卓の端まで来て、女主人の席の背後に引つ付いた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "小娘は此時極まつて、自分の髪の中から枯葉の引つ掛かつたやうな手を摘み出して、それにキスをする。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日覗いてみると蜂の巣のすぐ上には棚蜘蛛が網を張って、その上には枯葉や塵埃がいっぱいにきたなくたまっている。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔きみにならびて野にたてば〕きみにならびて野にたてば、　　風きららかに吹ききたり、柏ばやしをとゞろかし、　　　　枯葉を雪にまろばしぬ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "容貌をかえた低地にはカサコソと枯葉が骸骨の踊りを鳴らした。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　街路樹から次には街路から、風が枯葉を掃ってしまったあとは風の音も変わっていった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "口｜渇きし者の叫ぶ声を聞け、風にもまるる枯葉の音を聞け。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の莊嚴さを持たない裸樹はぎこちなく筋ばつた枝を空に張つて立並び、糊を塗りつけたやうにべた／＼な黒土の上には、芥と枯葉と枯草とがいぎたなく粘り着いて居り、もうすつかり春らしくなつて來た大空に對し殊更ら憐れな對照を作る。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯葉の塵塚に落ちたものからは火の手を挙げた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹の全体は、憎らしいほど落ち付き払って、枝に残った枯葉たちは、その一つ一つ小さな背へ、やがて散る前の、最後の一時の黄金色を、思い切り太陽の光から受けて、はかな相な満足にかがやいて居ます。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五本曲つたり倒れたりだが、竹垣を根岸流に取まはした、木戸の内には、梅の樹の枝振りの佳いのもあるし、何處から散つたか、橋の上に柳の枯葉も風情がある。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所に、癩病医者だと人はいうが、漢方医のある、その隣家の荒物屋で駄菓子、油、蚊遣香までも商っている婆さんが来て、瓦鉢の欠けた中へ、杉の枯葉を突込んで燻しながら、庭先に屈んでいるが、これはまたお雪というと、孫も子も一所にして、乳で育てたもののように可愛くてならないので。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦の芽が針程に延びて、木綿畑では、枯葉やはぢけたももの殻がかさかさと風に鳴る静かな朝のことであつた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一この塔婆だって、束にして、麁朶、枯葉と一所に、位牌堂うらの壁際に突込んであったなかから、（信女）をあてに引抜いて来たッてね、下足の若い衆が言っていました。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "睫毛ばかりに附着いて、小さな枯葉をかぶりながら、あの蓑蟲は掛つて居た。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日当りで暖かそうなが、青白い建ものの、門の前は、枯葉半ば、色づいた桜の木が七八株、一列に植えたのを境に、もう温泉の町も場末のはずれで、道が一坂小だかくなって、三方は見通しの原で、東に一帯の薬師山の下が、幅の広い畷になる。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方は笠を上にした茶褐色で、霜こしの黄なるに対して、女郎花の根にこぼれた、茨の枯葉のようなのを、――ここに二人たった渠等女たちに、フト思い較べながら指すと、「かっぱ。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之も堆かき枯葉を蹴って、何者かと挑み闘うように聞えた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "訪ねてくる人もなく、訪ねてゆく所もなく、そこらをぶらついていると、ひらひらと枯葉が一枚二枚、それも楢の葉である。",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのはろばろと眺め渡して行く起伏の末になると、枯蓮の枯葉は少くなり、ただ撓み曲った茎だけが、水上の形さながらに水面に落す影もろとも、いろいろに歪みを見せたＯの字の姿を池に並べ重ねている。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその小説のもつと大きなあぢはひを忘れて、そのふたりが咲き亂れたライラツクの花の下で最初の接吻を交したペエジに私の枯葉の枝折をはさんでおいたのだ。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、かれは豪放磊落を装い、かまわんかまわんと言って背広服で料理屋に乗込んだものの、玄関でも、また廊下でも、逢うひと逢うひと、ことごとく礼服である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは涙を流しながら笑っていた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
