[
  {
    "uuid": "13bd3949-73f0-5d55-8168-feec242139a4",
    "entry": "担ぎ込む",
    "reading": {
      "primary": "かつぎこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to carry into (esp. an injured person into a hospital)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "階段で転んで意識を失った老人を、近所の人たちが急いで近くの救急病院へ担ぎ込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "合宿中に熱中症で倒れた部員を、顧問の先生が慌てて保健室に担ぎ込んで処置を仰いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわっ、ひどい怪我だ！すぐに車に乗せて、駅前の外科へ担ぎ込むぞ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あの座敷にお獅子様を担ぎ込むんよ。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれを方々に担ぎ込むで、自分の代りに喋舌らしたものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "味を占めた書肆は要りもしない書物までせつせと文豪の手許に担ぎ込むやうになつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして石屋の担ぎ込むだ石だけでは何だかまだ物足りない様に思つて、いつそ石屋の主人も、人夫も、門先きを通りかゝつた跛の狗ころも、みんな石になつて欲しい様な表情をした。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなものを担ぎ込む人の気がしれないね。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "自殺を担ぎ込む「墓のサロン」の扉が口を結んでいた。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はただ卒倒していただけでしたから、「２３」がその鉄板のような脚を抱いて自分の部屋へ担ぎ込むと、間もなく意識を快復しました。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "屈強な若者たちの集団が道端や近隣の墓場から借りてきた石の地蔵を家の中に担ぎ込むと、その後をたくさんの群衆が付いて行く。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "――但し、日枝神社の祭礼が前にいった六月十五日で、一月飛んだ八月十五日が深川八幡、その翌月の九月十五日が神田明神という順序で、余なるは住吉神社の祭礼に神輿の海中渡御があるのと、三社の祭りに花川戸の兄哥たちが、自慢の神輿を吉原五花街へ担ぎ込むのとが、一風変ったおかしみがある。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時折よく通り合わせたのは、老いたる一人の猟師であったが、彼を猪小屋へ担ぎ込むと、火打ち袋から丸薬を取り出し、まず水の中へ抛り込んだ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂上の屋敷へも鉄棒でガチャンガチャンと地面を打って脅かす奴を真先にいずれも酒気を吐いてワッショイワッショイと神輿を担ぎ込む。",
              "citation": {
                "source": "山の手の子",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石崎助教授、松尾教授を相次いで担ぎ込む。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い坊さんが厚い蒲団を十二畳の部屋に担ぎ込む。",
              "citation": {
                "source": "京に着ける夕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごんえむ殿は千両箱をすぐ土蔵へ担ぎ込んだが、同時に持助どのへおせんを担ぎ込む決心をした。",
              "citation": {
                "source": "艶妖記",
                "author": "忍術千一夜　第一話",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に降りてきますよ」　明智は無神経な返事をして、運転手のさし出す書付に判を押して、いまわしい荷物を応接間へ担ぎ込むように命じている。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の背の叺、牛車のうえの穀俵などを、陣屋の兵站部へ担ぎ込むのだった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "花田と青島、黒布に被われたる寝棺をかつぎこむ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か帝大の医者に、もう一度診察してもらつたうへで、家で手当をするか、病室へかつぎこむかしようと思つて、その医者の撰定について相談をしてゐた。",
              "citation": {
                "source": "和解",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "生家の病院へかつぎこむ。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治座の若衆が二人がかりで、荒縄でくくり合せた蜜柑箱をかつぎこむ。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "万屋で平野屋へ棺を注文したのを見とどけると、へい、ただ今と用意してあった棺をかつぎこむ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "金鳳釵",
                "note": "青空文庫"
              }
            },
            {
              "text": "松野医師は子供専門なのだが、近くに医者がいないので、いつの間にか、仲仕たちの怪我人をかつぎこむ、外科医院みたいになってしまった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手がみやげ物をかつぎこむ。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
