[
  {
    "uuid": "b31595a9-8d02-5371-85b1-278fb5c83c8f",
    "entry": "患難",
    "reading": {
      "primary": "かんなん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
