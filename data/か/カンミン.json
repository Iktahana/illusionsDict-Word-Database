[
  {
    "uuid": "cd81e6f9-571d-559f-a48f-36d8a352db75",
    "entry": "官民",
    "reading": {
      "primary": "かんみん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
