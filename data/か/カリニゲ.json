        "examples": {
          "standard": [
            {
              "text": "あの人は数々の借り逃げを繰り返してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "借り逃げは信用を失うだけでなく、法的な問題も引き起こす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼が借り逃げしたと聞いて、みんな驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "借り逃げするような人間とは関わりたくない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "江戸旗本早乙女主水之介、道中半ばに無心致して恐縮じゃが、刀にかけても借り逃げは致さぬゆえ、暫時拝借願いたいと、かように口上申してな、よく釣れそうな道具一揃い至急に才覚して参れ」「呆れましたな。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "別当の背後には、将軍家がついているのであるから貸した金を借り逃げされるようなことは決してない。",
              "citation": {
                "source": "増上寺物語",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の縁をぽッと桜色に染めた真紀子はうるんだ瞼を眠むそうに開け、何がおかしいのかひとり倒れんばかりにげらげらと笑った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
