[
  {
    "uuid": "ce0d81f0-d09d-5fd8-955e-e88f2ba1dd3e",
    "entry": "軽はずみ",
    "reading": {
      "primary": "かるはずみ",
      "alternatives": [
        "かろはずみ"
      ],
      "is_heteronym": false
    },
    "grammar": {
