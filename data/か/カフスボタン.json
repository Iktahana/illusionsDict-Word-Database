        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "父親が大事にしていたカフスボタンを、成人のお祝いにもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はお気に入りのカフスボタンをスーツのシャツに装着し、鏡で確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "結婚式では、新郎の白いシャツにシルバーのカフスボタンが輝いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プレゼントされたカフスボタンが珍しいデザインで、とても気に入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "扉の裏側には、「ネクタイピン、カフスボタン、眼鏡、財布、その他金物類、　ことに尖ったものは、みんなここに置いてください」と書いてありました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人はめがねをはずしたり、カフスボタンをとったり、みんな金庫のなかに入れて、ぱちんと錠をかけました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉の裏側には、「ネクタイピン、カフスボタン、眼鏡、財布、その他金物類、　ことに尖つたものは、みんなこゝに置いてください」と書いてありました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人はめがねをはづしたり、カフスボタンをとつたり、みんな金庫の中に入れて、ぱちんと錠をかけました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本麻、赤縞ワイシャツに猫目石のカフスボタン。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "買物をし、食事をし、かえりに丸善によって、小林さんへの祝、カフスボタンを買う。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月二十二日（土曜）　Ｙの灰皿をかった家へカフスボタンを見に行ったが、やすくてよいのというのはなし。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "カフスボタンでいいということになる。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度津和野に建立された詩碑の文について相談をうけたので、少なくとも小学校の先生にも理解が出来、子供に説明のできるものをと思って、すぐれて、判り易く、戦争的な色彩のないものという観点から、先生の陣中詩集の中から「カフスボタン」を選んだ。",
              "citation": {
                "source": "思い出",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "笠森仙太郎はその時上着を脱いでワイシャツだけ着ておりましたが、例の癖で、貝細工のカフスボタンを嘗めながら、この千載一遇の好機――といって悪ければ、恋人美奈子嬢の必死の大厄をどうすることもできず、地団太を踏んで口惜しがっておりました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "運命の釦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　この時笠森仙太郎は、自分のカフスボタンが驚くべき力を持っていることを発見したのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "運命の釦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんか窮迫した時、困惑疲憊した時、仙太郎はカフスボタンを嘗める習慣を持っているのですが、するとその瞬間から、事情はガラリと変って、常に笠森仙太郎が成功者となり、勝利者となることがわかったのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "運命の釦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんの因縁もなく、誰の形見に貰ったのでもない、貝細工のつまらないカフスボタン――特色といえば、大学以来十何年間、それを持ち続けたカフスボタンが、禍いを転じて福とするばかりでなく、全く想像もつかない魔力を発揮して、持主のために偶然を支配してくれようとは誰が想像するものでしょう。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "運命の釦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白紙の答案も、荒天のボートも、植込のなかから飛出した活劇も、考えてみるとカフスボタン――かつて銀座の夜店で求めた、一円五十銭のカフスボタンの魔力だとすると、ナポレオン一世も、豊臣秀吉も、こんなマスコットを持っていたのかも知れない――笠森仙太郎は、歴史上の英雄達を、自分と同列に考えたくなるのでした。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "運命の釦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間にカフスボタンを、何べんなめたことでしょう。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "運命の釦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙太郎にも美奈子にも、一生｜費っても費い切れない、巨億の富がわけられ、近頃ではあまりかえりみなかった魔力のカフスボタンは、うすうす事情を知っている美奈子夫人がそっと自分の荷物の中に取込んで持出してしまいました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "運命の釦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし魔力のカフスボタンも、美奈子夫人にはなんの役にたたないとわかると、夫人はそれを、腹立ちまぎれに、ストーブの中にほうり込んで灰と一緒にどこかへ捨ててしまいました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "運命の釦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前が持って行ったカフスボタンはどうした」「――――」　仙太郎の問に、美奈子は悲しく頭を振りました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "運命の釦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――魔力のカフスボタンが本当に存在したかと仰しゃるのですか、とんでもない、そんなものがこの世の中にあるはずはありません、これは私のこしらえたささやかな比喩とお取り下さい」　云い了って話し手の牧野健一は壇を下りました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "運命の釦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい木魚だの、片方のカフスボタンだの、くずかと思うようなものもある。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった片方だけになってかえって来たカフスボタンを紫の小さいきれいな草編み袋にしまって何年も何年も持っていて、これから火にでも追われて逃げるときは其がマスコットと、背負袋に入れている、そんな気持も、書けば、あなたの同感なさることでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はワイシャツを脱ごうとして、右の方のカフスボタンが紛失しているのを知った。",
              "citation": {
                "source": "あめんちあ",
                "author": "富ノ沢麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさ、ちゃんと嵌め込んだカフスボタンを失ったと思えばいやな気持になった。",
              "citation": {
                "source": "あめんちあ",
                "author": "富ノ沢麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためにその人は、彼のカフスボタンをいつの間にかこっそりと盗み取ったのかも知れない。",
              "citation": {
                "source": "あめんちあ",
                "author": "富ノ沢麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は彼自身が考えた盗みをするために彼のカフスボタンを盗んだ。",
              "citation": {
                "source": "あめんちあ",
                "author": "富ノ沢麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその人はカフスボタンを故意に犯罪の現場へ捨てる心であろう。",
              "citation": {
                "source": "あめんちあ",
                "author": "富ノ沢麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、そのドッペルゲンゲルは彼自身である本体には知れないようにと、余り急ぎ過ぎたので、カフスボタンをうっかりしているうちに、現場へ取りおとしたのかも知れない。",
              "citation": {
                "source": "あめんちあ",
                "author": "富ノ沢麟太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
