        "examples": {
          "standard": [
            {
              "text": "赤ちゃんがなかなか降りてこなかったので、急遽鉗子分娩に切り替えることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鉗子分娩は、母体や赤ちゃんへの負担を最小限に抑えるために慎重に行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "担当の医師から、緊急時の選択肢として鉗子分娩の可能性について説明を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私の出産では、最終的に鉗子分娩で無事に赤ちゃんが生まれました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
