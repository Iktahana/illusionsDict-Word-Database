        "examples": {
          "standard": [
            {
              "text": "ベランダから飛ばした紙飛行機が、予想外に風に乗って隣の家の庭まで飛んでいった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「見て見て！ この紙飛行機、先端を少し重くしたからすごく安定して飛ぶんだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "授業中にこっそり折った紙飛行機を友達の机に飛ばしたら、運悪く先生に見つかってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "公園の芝生に寝転んで、子供たちが飛ばす紙飛行機のゆったりとした動きを眺めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "授業がはじまる迄は、子供のおもちゃの紙飛行機をぶっつけ合ったり、すげえすげえ、とくだらぬ事に驚き合ったり、卑猥な身振りをしたり、それでいて、先生が来ると急にこそこそして、どんなつまらぬ講義でも、いかにも神妙に拝聴しているという始末。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
