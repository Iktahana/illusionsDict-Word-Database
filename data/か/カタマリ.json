    "definitions": [
      {
        "index": 1,
        "gloss": "lump",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝食のテーブルには、焼き立てのパンの大きな塊が置かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "粘土をこねていたら、手のひらにひんやりとした塊ができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冷蔵庫から出したバターは、まだ硬い塊のままだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "昨日迄大変暑かつたのにも今日はボンヤリした日が射してゐて、時々夕立でも降らせさうな雲の塊が乾き切つた庭の土を薄暗くしたり、そして稀々しくも地面を匍ふやうな微風が所々に生えた雑草などを揺るので、私の心は思ひ出を巡るに似合はしい気分になつて、その蛇の思ひ出はだんだん拡がつていつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一塊の土塚、暗き竹藪の影にふるへて、冬の日の天日暗く、無頼の悲しき生涯を忍ぶに耐へたり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆不折が書いたので水彩の方は富士の六合目で磊々たる赭土塊を踏んで向うへ行く人物もある。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勢で車座に坐って茶碗でも石塊でも順々に手渡しして行く。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて茎の頂上にむくむくと一つの団塊が盛り上がったと思うとまたたくまにその頭がばらばらに破れて数十の花弁が花火のように放散した。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢には一塊の炭が燃え尽して、柔らかい白い灰は上の藁灰の圧力にたえかねて音もせずに落ち込んでしまった。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑色の楕円形をした食えない部分があってその頭にこれと同じくらいの大きさで美しい紅色をした甘い団塊が附着している。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭が暗い土塊になつて、ただもうラアラア唱つてゆくのだ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "前面には阜のような山が二つ、小隆起をしている、赤沢岳頂上の三角点も、大空を指さしている、谷は次第に高くなる、高くなると共に蹙まって来て、雪の蜿ねり方も、波のように烈しいが、嘉門次の語るところに依ると、雪の下は大小の石塊ばかりで、雪解けがしたら、却って歩きづらくて堪まらないということだ。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲消えて皹も亦拭ひ去らる、山色何の瑠璃ぞ、只だ赭丹赭黄なる熔岩の、奇醜大塊を、至つて無器用に束ねて嶄立せるのみ、その肩を怒らし胸を張れるを見て、淑美なる女性的崇高を知らず。",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "空々寂々の境で、山という山の気分が、富士山に向いて、集中して来る、谷から幾筋とない雲が、藍の腐ったような塊になって、立ち昇る、富士山はこの雲と重なって、心もち西へ西へと延びて来るようだ、蝕った雲の淵の深さが、何十尺かの穴となって、口が明く。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "農鳥山は大約三峰に岐れているようだ、手近を私たちは――後の話だが――仮に南農鳥と名づけた、雪が二塊ばかり、胸に光っている、近づくほど、雪の幅が成長して大きくなる、雪の側はいわゆる御花畑で、四ツ葉塩釜、白山一華、小岩鏡などが多い。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "間の岳の峰から、北岳まで尾根が繋がっていることは、ここで初めて確かめられた、我が三角測量標の下には、窪地があって、そこには雪田が白く塊まっている、一丁ほども歩いたかと思うと、また雪田がある、築土の塀の蔭に、消え残った春の雪のようだが、分量は遥かに多い。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "池は浅間大社のうしろの熔岩塊、神立山の麓から噴き出る水がたたえたもので、社の神橋の下をすみ切って流れる水は、夜目にも冷徹して、水底の細石までが、うろこが生えて、魚に化けそうだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵野に見るような黒土を踏んで、うら若いひのきの植林が、一と塊まりに寄り添っている、私たちの足許には釣鐘草、萩、擬宝珠、木楡が咲く。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "八ヶ岳の泥流が作りあげた凝灰質、集塊岩の美事なる累積である。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "信州の山岳の中でも、御嶽や駒ヶ岳などは、古くから多くの登山者を有していたが、宗教が権威を失った今日では、新しい登山家は、種々の理由からして、日本アルプスの中でも、殊に飛騨山脈を選び、飛騨山脈の中でも、最高点の槍ヶ岳や穂高岳の特色ある火成岩の大塊は特に多くの人々を引きつけているらしく思われる。",
              "citation": {
                "source": "上高地風景保護論",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷の中が、黄な臭いやうに、ボーッと明るくなつたとおもふと、高い空を浮ぶ雲が、夕日を受けて、鈍い朱に染まつた、蜩が、時間を一秒一秒刻み込んで、谷の中へ追ひ込んでゆくやうに、キ、キ、キと啼き落す、杉林の一本々々の樹が、どちらから寄るともなく、塊まつて、黒い法師のやうになつて、囁き合つてゐる。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "がそれは必ずしも、好きであるからではない、位置が南に偏り過ぎて、雪が早く融けるし、氷河は小ッぽけな塊に過ぎないし、富士山のように、新火山岩で、砂礫や岩石が崩れ易いので、高山植物は稀薄であるし、「好き」になるところまでは行かないが、それでも、最も多く心を惹かれる山である。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすべてを超越して、美しいものは、この山の隆々たる肉塊である。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上は大空で、否、大空の中に、粗削りの石の塊が挟まれていて、その塊を土台として、蒲鉾形の蓆小舎が出来ている。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜宮岩といふのは、木曾川の中流に、島を為して残つてゐる一大岩塊で、高山の様子がある。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十人も一塊りになって、乗り込んで行きやがる。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには私の過去の道筋で拾い集めて来たあらゆる宝石や土塊や草花や昆虫や、たとえそれが蚯蚓や蛆虫であろうとも一切のものを「現在の鍋」に打ち込んで煮詰めてみようと思っている。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがすむまで吾々の車は待たなければならないので車から下りて煙草を吸ひつけながらその辺に転がつてゐる岩塊を検査した。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "安山岩かと思はれる火山岩塊の表面が赤※色に風化したのが多い。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な河童橋は河風が寒く、穂高の山塊はすつかり雨雲に隠されて姿を見せない。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處に堆積した土塊のやうなものはよく見るとみな石炭であつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、土方風の男が一人縄で何かガラガラ引きずりながら引っぱって来るのを見ると、一枚の焼けトタンの上に二尺角くらいの氷塊をのっけたのを何となく得意げに引きずって行くのであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あたし、桜を見ていると、蛙の卵の、あのかたまりを思い出して、――」家内は、無風流である。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
