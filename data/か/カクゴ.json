    "definitions": [
      {
        "index": 1,
        "gloss": "readiness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "明日の厳しい試験に備え、昨夜から徹夜で勉強する覚悟でいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、どんな困難にも立ち向かう覚悟を決めて、新事業に乗り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この状況では、最悪の事態も想定した覚悟が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "結果がどうであれ、自分の選択には責任を持つ覚悟はできている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで、俳聖芭蕉は、みだりに作らないといふ覚悟を非常に持つてゐたさうであるが、その事は、私には此の場合特に重要な事と考へられる。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "げにもつれ易い感傷の綱の海を漕ぎゆくためには、否応なきストイシスムを身に付けて、胸襟打開いて事に当る平明さを、諦らめる覚悟が要ります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれやれ今日一日棒に振る覚悟をするより仕方もないと僕は思つた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが彼が帰化を決心し、日本の土となることを覚悟した時、言い知れぬ寂しさとやるせなさが、心の底にうずつき迫るのを感じたであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と死を覚悟していた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎氏も真の困難は、今日以後に在るという事に就いては、既に充分の覚悟をお持ちだろうと思います。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺にゃ覚悟が出来てるんだ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕るのを覚悟で行きやがるんだもんな。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "また永い歳月かかって体験から築き上げた考えと覚悟はもはや何物を持って来ても壊せず揺ぎないものと思っていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや諦めて既に覚悟の態であった昭青年が、この眼に出会って思わず心に湧き出た力がありました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち船はもうずんずん沈みますから、私はもうすっかり覚悟してこの人たち二人を抱いて、浮べるだけは浮ばうとかたまって船の沈むのを待ってゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一殺されないにしてももう縛られると私どもは覚悟しました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は「いき」の理解に際して universalia の問題を唯名論の方向に解決する異端者たるの覚悟を要する。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に数日後に、花がないのは覚悟でもう一度行ってみた。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い覚悟で行った札幌は暖かすぎて、下手なあぶなっかしい講演をやっていると額に汗ばんだ。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが十分の公算を有する事が明らかなれば、市民は十分の覚悟をもって変に備うべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "己一身の所信覚悟も定まって居らず、如何にして家族を指導し、一家を整え得べき。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく全巻を通じて無常を説き遁世をすすめ生死の一大事を覚悟すべしと説いたものが甚だ多い。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば第九十二段に弓の修業の心得から修道者の覚悟を説くのでも、直ちに移して以て吾等科学研究者の坐右の銘とすることが出来る。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしともかくも出発点における覚悟と努力の向け方においては自分が本当の南画の精神要旨と考えるものに正しく適合している。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「冗談言っちゃいけねえ清水の御貸元、それァ何かの間違いだ、俺ァ人殺しなンぞした事がねえ」　「何を言やがるんだ、言い逃れは聞かねえ、立派に証人があるんだ、小五郎ッ覚悟を決めて仕度しろッ」　小五郎、突然斬って来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「不具戴天の父の敵覚悟しろ――」　棚倉呆れたが、門弟と共に刀の柄に手を掛けて見構える。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉、刀を背向ける（背打ちにする覚悟らしい）。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その代りとして、四年兵になるまで残しておかれるだろうとは、自他ともに覚悟をしていた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤吉の死骸には少しも疵のあとが無いので、おそらく覚悟して身を投げたものであろうとは想像されたが、たとい自殺にしても一応はその仔細を吟味しなければならないというので、女房のお徳はきびしく取り調べられた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "重量をつけて海の底へ沈められては、さすがの猫ももう再び浮かび上がれないものとおまきも覚悟したらしく、人々にむかって嘆願した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、どうしても親殺しですから、七之助さんも覚悟を決めたらしいんです」「婆さんの顔がまったく猫に見えたのか」と、半七は再び念を押すと、お初は自分の眼にも七之助の眼にも確かにそう見えたと云い切った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "母にあてた書置は火鉢のひきだしに入れ、自分にあてた書置は自分のふところに押し込んで、彼も女のそばですぐ縊れて死のうと覚悟したが、ここで一緒に死んではかのお登久に済まないような気がしたので、彼は半分夢中でおみよの帯をかかえながら表へそっとぬけ出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかくご天覧いただいているところで失敗しては堪りませんよ。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはむろん、古書はふかくご渉猟でしょうな。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "resolution",
