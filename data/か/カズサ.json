[
  {
    "uuid": "3b69b9a8-4f9a-5222-a0f1-9a469d5e786c",
    "entry": "上総",
    "reading": {
      "primary": "かずさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Kazusa (former province located in the central part of present-day Chiba Prefecture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "上総は、古くから馬の産地として知られていた国だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "房総半島の半分を占める上総の地には、豊かな自然が広がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "江戸時代、上総国にはいくつもの藩が置かれ、それぞれが独自の文化を育んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "佃島と月島との間、及び月島六丁目と七丁目との間に各※小渠ありて、本澪の方と上総澪の方との間の往来の便とす。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば大川の水のおのづからに土砂を流出するもの、極めて自然の状態をなして遠浅の海底を形づくるが中に、佃島の東の本澪の遠く南品川の沖に達すると、佃島西の上総澪の月島下流に至るとの二線がやゝ深き水路をなすあるのみ、岩礁の伏在するもなく、特別の潮路の去来するもなし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "本澪は第五第二の砲台の間を南へ通ずるなるが、その深さ大抵二｜尋以上、上総澪はその深さにおいて及ばざること遠し。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "中川の澪は洲崎の沖の方に東より来りて横はれるなるが、本澪、上総澪、台場附近と共にこれらの澪筋もまた釣魚の場所たり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに植通はその信長に対して、立ったままに面とむかって、「上総殿か、入洛めでたし」といったきりで帰ってしまった。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "上総殿とは信長がただこれ上総介であったからである。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "上総介では強かろうが偉かろうが、位官の高い九条植通の前では、そのくらいに扱われたとて仕方のない談だ。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "常陸には筑波山、上総には鹿野山、上州には榛名、赤城、野州には日光、甲州には山が到る処にある。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……どこと申して行く処に当は無いので、法衣を着て草鞋を穿くと、直ぐに両国から江戸を離れて、安房上総を諸所｜経歴りました。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二日、甲辰、和田左衛門尉義盛、上総の国司に挙任せらる可きの由、内々之を望み申す、将軍家、尼御台所の御方に申合せらるるの処、故将軍の御時、侍の受領に於ては、停止す可きの由、其沙汰訖んぬ、仍つて此の如き類、聴されざる例を始めらるるの条、女性の口入に足らざるの旨、御返事有るの間、左右する能はずと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿七日、丁巳、和田左衛門尉義盛、上総の国司所望の事、内々御計の事有り、暫く左右を待ち奉る可きの由仰を蒙り、殊に抃悦すと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "和田ガ上総ノ国司ヲ望ンデヰマスガ「いけませぬ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にも先年、やはり内々ごひいきだつた畠山の御一族を心ならずも失ひなされてからは、この唯一の生きのこりの大功臣をいよいよ大事においたはりなされ、このたびの上総の国司所望の事もなるべくは御許容なされたいやうな御様子が私たちにさへほの見えてゐたのでございます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御父、和田左衛門尉義盛さまは、その頃、上総国伊北庄に御滞在でございましたさうで、鎌倉に兵起るの風聞に接しとるものも取りあへず鎌倉に駈けつけてみたら、御子息お二人捕へられてゐるので仰天して、ただちに御ところへ参り、拝謁のほどを願ひいれましたところ、御機嫌よくお許しに相成りすぐに御対面なさいました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ってましたと計りに関白の方では、此の大石を取れば碁は世話無しに勝になると、堂々たる大軍、徳川を海道より、真田を山道より先鋒として、前田、上杉、いずれも戦にかけては恐ろしく強い者等に武蔵、上野、上総、下総、安房の諸国の北条領の城々六十余りを一月の間に揉潰させて、小田原へ取り詰めた。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "高見王の御子｜高望王が平の姓を賜はつたので、従五位下、常陸大掾、上総介等に任ぜられたと平氏系図に見えてゐる。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "桓武平氏が阪東に根を張り枝を連ねて大勢力を植つるに至つたことは、此の高望王が上総介や常陸大掾になられたことから起るのである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "高望王の御子が、国香、良兼、良将、良は上総介、従五位上とある。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから良広には官位が見えぬが、次に良文が従五位上で、村岡五郎と称した、此の良文の後に日本将軍と号した上総介忠常なども出たので、千葉だの、三浦だの、源平時代に光を放つた家※の祖である。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にせよ護も名家であつて、護の女を将門の伯父上総介良兼は妻にしてゐる。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「負け碁は兎角あとをひく也」で、良正は独力の及ぶ可からざるを以て下総介良兼（或はいふ上総介）に助勢を頼んで将門に憂き目を見せようとした。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "同六年六月二十六日、十二分に準備したる良兼は上総下総の兵を発して、上総の地で下総へ斗入してゐる武射郡の径路から下総の香取郡の神崎へ押出した。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "記の此処の文が妙に拗れて居るので、清宮秀堅は、将門の妻は殺されたのでは無くて上総に拘はれたので、九月十日になつて弟の謀によつて逃帰つたといふ事に読んでゐる。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "良兼、護、今は父の後を襲ふた常陸大掾貞盛、良兼の子の公雅、公連、それから秦清文、此等が皆職を帯びて、武蔵、安房、上総、下総、常陸、下野諸国の武士を駆催して将門を取つて押へようとする。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "将門の弟の将頼は下野守に、上野守に常羽御厩別当多治経明を、常陸守に藤原玄茂を、上総守に興世王を、安房守に文室好立を、相模守に平将文を、伊豆守に平将武を、下総守に平将為を、それ／″＼の受領が定められた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "上総安房は早くも将門に降つたらう。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "本幹｜已に倒れて、枝葉｜全からず、将門の弟の将頼と藤原玄茂とは其歳相模国で斬られ、興世王は上総へ行つて居たが左中弁将末に殺され、遂高玄明は常陸で殺されてしまひ、弟将武は甲斐の山中で殺された。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "御存じの融通が利かないんだから、可、ついでにお銚子のおかわりが、と知らない女を呼ぶわけにゃ行かずさ、瀬ぶみをするつもりで、行ったんだ。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間の後、新吉が清荒神の駅に降り立つと、さっきの女はやはりきょとんとした眼をして、化石したように動かずさっきと同じ場所に坐っていた。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "正にこれしらくもにはね打かはし飛ぶかりのかずさへ見ゆる秋の夜の月あな面白の景色やなど眺めくらす。",
              "citation": {
                "source": "月",
                "author": "上田敏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
