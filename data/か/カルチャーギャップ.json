        "examples": {
          "standard": [
            {
              "text": "海外赴任当初は、職場の習慣やコミュニケーションの取り方にカルチャーギャップを感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "同じ国の中でも、都市と地方では思わぬカルチャーギャップがあるものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若い世代と年配の世代の間には、音楽の趣味で大きなカルチャーギャップがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夫婦の間でも、育ってきた環境の違いから小さなカルチャーギャップが生じるのはよくあることだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "買ってきてすぐに使い出せるパッケージソフトの完成を待つという彼らの決意を前にして、浜田はある種のカルチャーギャップにさらされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
