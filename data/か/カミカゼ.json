        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "終戦間際、若き兵士たちが神風特攻隊として海に散っていった悲劇を忘れてはならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父の部屋には、かつての戦友たちが神風として出撃する直前に撮った色褪せた写真がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "戦時中の狂気ともいえる神風の思想について、平和学習の展示を真剣に見入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
