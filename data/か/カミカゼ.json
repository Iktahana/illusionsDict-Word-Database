[
  {
    "uuid": "2ed9c803-0fd6-5457-8bb5-4404a3efdc18",
    "entry": "神風",
    "reading": {
      "primary": "かみかぜ",
      "alternatives": [
        "しんぷう",
        "かむかぜ"
      ],
      "is_heteronym": false
    },
    "grammar": {
