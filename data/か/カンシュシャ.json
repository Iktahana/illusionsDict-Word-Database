        "examples": {
          "standard": [
            {
              "text": "その看守者は、規則を厳守し、囚人たちに公平に接した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "毎朝、看守者は牢屋の見回りをして、異常がないかを確認する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "脱獄事件の後、刑務所の看守者は警備体制の強化を求められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画の中で、看守者が主人公に厳しい尋問をする場面があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "同家の看守者――執事をこう呼んでもいいと思う――は、過去の愉快な精神それ自身であった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
