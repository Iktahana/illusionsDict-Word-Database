          "standard": [
            {
              "text": "監督が「本番スタート！」と叫ぶと同時に、カチンコが打ち鳴らされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "撮影現場では、カチンコが鳴り響くたびに、俳優たちの顔に緊張感が走った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画のエンドロールで、制作の様子が映し出され、カチンコの音が効果的に使われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カチンコを打つタイミングを間違えてしまい、NGを出してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "寒さでカチンコチンに凍ってしまって、あたかも死んだようになってしまって、地面に落ちていきます。",
