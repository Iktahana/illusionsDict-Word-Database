        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「村唯一の小学校が廃校になったのは、過疎化が止まらない決定打だったな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「過疎化対策として、移住者に住宅の修繕費用を補助する自治体が増えている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「都会の喧騒を離れたい若者が増えても、地方の過疎化に歯止めをかけるのは容易じゃない。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「かつては賑やかだった商店街も、過疎化の波には勝てず次々とシャッターを閉めてしまった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "農業の衰退というその後の大きな流れの中で、力強く育てようと彼らが願った村は、過疎化に向かいます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だかその節の中には、大昔から佐渡ヶ島を洗つてゐる波のかそかな音が、まじつてゐるやうな気がする。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かそかに聞えて来る波の音のほか、外からは何の物音も伝はつて来ない。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "切通しをのぼると、かそかな春の夜風にのって、ひゅうひゃらりゃりゃと笛の音が聞えて来ました。",
              "citation": {
                "source": "狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすき瀬戸白の小皿に幾すくひすくへどあはれ、かそかそと声ばかりして、ころころと音ばかりして、掻き寄せて十粒に足らず、ひろへれど十粒を出でず、かそかそところころと、声するは音するは、空しき櫃の空櫃の米櫃の底。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすき瀬戸白の小皿に、幾すくひすくへどあはれ、かそかそと声ばかりして、ころころと音ばかりして、掻き寄せて十粒に足らず、ひろへれど十粒を出でず、かそかそところころと、声するは、空しき櫃の、空櫃の米櫃の底。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アそかそか、叔父さんがな、遠い所でこんなにええ物｜買うて来ておくれはった。",
              "citation": {
                "source": "御身",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鈴子ひとつ歌をつくって見せろ」「紫にかそか匂いておもほゆる今朝の淡雪消えまく惜しも」「ふーむ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「絵を出さしてやるさかいきばって描きなさい」「この子、絵筋がええさかい、きばって描かそか……」　といったぐあいで、現今のように審査という選定方法もなく、出品された以上は落第も及第もなかったので、結局それぞれの師の目にとまった絵が自選の形式で出品されていたわけである。",
              "citation": {
                "source": "最初の出品画",
                "author": "――四季美人図――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一剣に心こもりておのづから身のあはだつをかそかに知れり」「正眼に構えて敵に対ひつつしばし相手の呼吸をはかる」　これは戸山学校の剣道大会に優勝したときの緊張した剣客の歌である。",
              "citation": {
                "source": "睡蓮",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "射って見せますよ」　たのしげにいって、曳金にかけた細い指に、かそかに力を加える。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤独であつてもかそかなものではなかつた。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にせんとも死なめと云ひて寄る妹にかそかに白粉にほふ　これは大正時代の、病篤き一貧窮青年の死線の上での恋の歌である。",
              "citation": {
                "source": "女性の諸問題",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにせん共に死なめといひて寄る　　　　　　　妹にかそかに白粉にほふこれは松倉米吉というある鍛冶屋の息子がありまして、肺病で難儀をした。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにせん共に死なめといひて寄る　　　　　　　妹にかそかに白粉にほふそういうような境遇で、自分は今別れたらまた会うことができない境遇のときに、もちろん恋人もやっとのことで旅費をつくってきたというのであります。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日のあたる明り障子たゞ白じろと　ひろがり見し夢の　かそかなる思ひに　つゞく　　　　　堀君　三みつまたの花咲く日山原を　行きしかな。",
              "citation": {
                "source": "『かげろふの日記』解説",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカシヤと桑櫻間中庸かそかなる音して落つるアカシヤの花の香をひとりたのしむ幼子が拾ひあつめて手に持てるアカシヤの花に夕日させるも集ひきて桑の實とると見上げ居る子等の面わに夕日照りそふ",
              "citation": {
                "source": "アカシヤと桑",
                "author": "櫻間中庸",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとのまに／＼―　　かそかに　たゞ　ひそかにあれ　生ける時さびしかりければ、　若し　然あらば、　よき一族の　遠びとの葬り処近く―。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "（b）かそかなる風、森のいただきに起り、あるかなきかの呻き、空にみつる時、暴風雨近しと水夫たちは知る。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
