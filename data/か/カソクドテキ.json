[
  {
    "uuid": "2ec15251-bfd7-5f0e-b6dd-0c54f61cc505",
    "entry": "加速度的",
    "reading": {
      "primary": "かそくどてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
