        "examples": {
          "standard": [
            {
              "text": "大規模災害が発生し、救援物資を積んだ貨物機が緊急離陸した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "深夜、空港の滑走路には、海外からの貨物機が次々と着陸する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この貨物機は一度に何トンもの荷物を運べるから、本当にすごいよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい貨物機が導入されたおかげで、輸送能力が大幅に向上した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "世界暦二千年一月十九日　大西洋横断の旅客機と貨物機が二ヶ月前より頻々として行方不明となっていたが、その事件を調査の結果本日一大発見成る。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "バイカル機が嵐を避けるために、東境界線の北端を飛んでいる時、イギリスの貨物機と翼が接触し、乗客500人のうち100人を除く人命が失われたという。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし俺が乗って、ロケットが遅れていたら、英国貨物機とは衝突しないですんだだろうと。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもつきあいのほうはもう一人前とみなされているから、祝儀不祝儀、何かにつけて後から後から出銭が多い。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀟洒としてしかもつきぬしおりのある若木の姿など、新緑など、その茂みの中に顔を埋めたいと思います。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
