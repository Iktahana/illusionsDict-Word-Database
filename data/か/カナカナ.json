    "definitions": [
      {
        "index": 1,
        "gloss": "evening cicada (Tanna japonensis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "日が暮れ始めると、森の奥からカナカナカナ……と蜩の鳴き声が響いてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わあ、蜩が鳴き出したね。もうすぐ夏休みも終わりかぁ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "蜩の鳴き声を聞きながら、祖母の家の縁側で冷えたスイカを食べるのが毎年の楽しみだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「カナカナ……って、蜩の声を聞くと、なんだか少し寂しい気持ちになるね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "御院殿坂に鳴く蜩の声や邸後を通過する列車の騒音を聞くような心持がする。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷の中が、黄な臭いやうに、ボーッと明るくなつたとおもふと、高い空を浮ぶ雲が、夕日を受けて、鈍い朱に染まつた、蜩が、時間を一秒一秒刻み込んで、谷の中へ追ひ込んでゆくやうに、キ、キ、キと啼き落す、杉林の一本々々の樹が、どちらから寄るともなく、塊まつて、黒い法師のやうになつて、囁き合つてゐる。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "靄の深い黎明の空氣のなかに蜩が鳴きはじめる時分自分はよく眼を醒して窓を明けた。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "寐てゐて聽く蜩の聲。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは三田文學に出てあつた葛目氏の短篇亡母と蜩を讀んでゐた私に感懷は深かつた。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "曉を一番早く知らせる蜩は、夕方にも一番早くに鳴く。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ある夏の日に友人と二人で郊外の某｜旗亭へ行ってそこで半日寝ころがって蜩の声を聞きながら俳諧三昧をやった。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜩の声を聞きながら俳諧に遊んだあとでは、なおさらそうであった。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりの山では処々茅蜩殿、血と泥の大沼になろうという森を控えて鳴いている、日は斜、渓底はもう暗い。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「や、山の上で蜩が鳴かあ、ちょッ、あいつが二三度鳴くと、直ぐに起きやあがる。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ト見る時、また高らかに蜩が鳴いた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と唐突に奇声を放った、濁声の蜩一匹。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆふべの窓からはじめて裏山の蜩を聞いた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "山のみどりのこまやかさ、蜩のしめやかさ。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "又春光野に流れて鳥初めて歌ひ、暮風清蔭に湧いて蜩の声を作すが如し。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽ばかり秋の蝉、蜩の身の経帷子、いろいろの虫の死骸ながら巣を引※って来たらしい。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母は此方を見も返らで、琵琶の行方を瞻りつつ、椽側に立ちたるが、あわれ消残る樹間の雪か、緑翠暗きあたり白き鸚鵡の見え隠れに、蜩一声鳴きける時、手をもって涙を拭いつつ徐に謙三郎を顧みたり。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりの山では処々茅蜩殿、血と泥の大沼にならうといふ森を控へて鳴いて居る、日は斜、谷底はもう暗い。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うらがなし、落日の黄金片岡の槐にあかり、鳴きしきる蜩、あはれ誰葬るゆふべなるらむ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜩の金の線条顫はす声も、縁さへあらばまたの夕日にチレチレまたの夕日に時雨るる。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜩胸に、はた、夕日の幹に、つと来り、蜩なげく。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜩の歌蜩の啼き連るるなり、二つなり、啼き連るるなり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "金色に秋の日射の斜なし澄みとほる中、蜩は啼きしきるなり、急き急きて啼き刻むなり、二つ啼き、一つ啼き、また、こもごもに啼き速むなり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句蜩が二つ啼きまた一つがこもごもに岡の鉾杉わが宿の岡のなぞへに、杉いくつ屯せりけり、せうせうと屯せりけり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵬の大を以てしても蜩の小を以てしても、同じくこの限を破ること能はざるなり。",
              "citation": {
                "source": "人生に相渉るとは何の謂ぞ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して蜩の小を以て自らその小を知らず、鵬の大を以て自ら其の大を知らず、同じく限に縛せらるゝを知らず欣然として自足するは、憫れむべき自足なり。",
              "citation": {
                "source": "人生に相渉るとは何の謂ぞ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "時として君は黒い覆面をかけ、手中に見えざるピストルを閃めかし、盗心を神聖視し、憔悴しては銀製の乞食となつて彷徨ひ歩るき、消え失せんとしては純金の蜩の声を松の梢に聴いた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "目下の錯乱した官能には最早や轡虫と蜩と、隣家の自鳴鐘ときりぎりすとの区別さへつかぬほど昼と夜とが顛倒され、色触の世界にも何時しか夏と冬とが入れ代つて了つてゐる。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルメルトは赭ら顔で眼をしょぼしょぼさせた何となく田舎爺のような感じのする、しかしどこかなかなか喰えないような気のする先生であったが、しかしやはり一とかどのえらい学者のように思われた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん現在ではかえって科学の進んだために前よりも不幸になった人間も多数にありはするが、それは物質科学の方面だけが先駆けをしてほんとうの社会科学、現在のいわゆる社会科学よりももう少し科学的な社会科学、がはるかなかなたに取り残されたために生じた矛盾であり悲劇であるように思われる。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
