[
  {
    "uuid": "a6156a60-8338-5f3b-9dae-988423970b2b",
    "entry": "甘露",
    "reading": {
      "primary": "かんろ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
