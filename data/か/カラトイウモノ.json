[
  {
    "uuid": "d57cede7-f4e9-5212-aaec-a742181e10cc",
    "entry": "からと言うもの",
    "reading": {
      "primary": "からというもの",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
