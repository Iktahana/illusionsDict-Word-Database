        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "カッターナイフの切れ味が落ちたので、替え刃と交換した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "髭剃りの替え刃を買いに、ドラッグストアへ寄った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この古い芝刈り機の替え刃は、もう製造中止になっているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "念のため、工具箱にのこぎりの替え刃を一つ入れておく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "人々の視線一度に此方へ向かえば新郎のパナマ帽もうつむきける。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "膳に向かえば大野味噌汁。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもが、さし向かえば、些の尊敬をするわけでもない、自他平等、海藻のつくだ煮の品評に余念もありません。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って机にむかえば、下の離れ座敷でまたもや義太夫が始まった。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子は少し我慢さえすれば、親爺は何でも言うことを聞いてくれ、小遣いもつかえば映画も見て、わがままなその日が送れるので、うかうかと昼の時間を暮らすこともあり、あまり収入のよくない朋輩に、大束に小遣いをやってみたり、少し気分がわるいと見ると、座敷を勝手に断わらせもした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ささいな誤りさえ厳しく罰せられるというのに、かくもあからさまに刃向かえば、その先にはいったいいかなる運命が待ちかまえているというのか？",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "水を乞うて、手水をつかえば、やがて小さき窓より朝の物を差し入れられぬ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飜って思うのは、その詰らない事が良く出来るのは全気全霊で打対かわれるからで、我々の分際でさえ詰らない事なら、少し全気全霊で打対かえばたいてい出来るものなのであるから、聖賢の才能で之をするとすれば訳も造作もなく出来る筈なのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう激しい妄想に駆り立てられて来ると、どういう関係で倉地と自分とをつないでおけばいいのか、どうした態度で倉地をもちあつかえばいいのか、葉子にはほとほと見当がつかなくなってしまった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って机にむかえば、下の離れ座敷でもまたもや義太夫が始まった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは代用臓器が、たいへん小さくなったことと、そして金属をつかわなくても耐圧性人造肉をつかえば軽くてすむこととなった。",
              "citation": {
                "source": "千年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂、相対性理論をつかえば立派に証明のできることではあるまいか。",
              "citation": {
                "source": "科学者と夜店商人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋敷者なんぞがちっと暴い銭をつかえば、すぐに眼をつけられますよ」　それにしても、まだ判らないのは、かれが逐電の後、その屋敷ではなぜ彼の仮面の詮議をそのままにして置いたのか、なぜ代理の者を出して伊藤の店から買い戻さなかったのか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "仮面",
                "note": "青空文庫"
              }
            },
            {
              "text": "――イギリスがソ連とたたかえば一週間で壊滅されるだろう。",
              "citation": {
                "source": "便乗の図絵",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカとたたかえば一ヵ月でイギリスはつぶれるだろう、と。",
              "citation": {
                "source": "便乗の図絵",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸した問題として取あつかえば、何でもないが、自分の「黄銅時代」に集中して居る心持は、其那些細なことのように思われるものにでも振向かない。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじさんがこしらえた器械をつかえば、そういう古い時代の有様が見えるんだ。",
              "citation": {
                "source": "洪水大陸を呑む",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "錐をつかえばいいと分っていても、しからば、実際にはどんな形の錐にすればいいのか、その錐をうける土のかたさは、どんな抵抗を生じるものであろうか。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん光電管をつかえば、わけのないことです。",
              "citation": {
                "source": "什器破壊業事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたずらな、浮いた心でこの関所に向かえば、人は盲目になり、ぐうたらになる。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖師ヶ谷へカーに縫ってつかえばいいのにと思いついて。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本間、ホール半々につかえば五三〇〇と。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし十六両秤をつかえば六斤は七斤余りになります。",
              "citation": {
                "source": "風波",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は八時をすぎて、やや膚寒むの湖を、なかほどまではその山の頂を仰ぎながら、西にむかえばイントラ Intra の街の灯が水に揺く岬をまわると、サン・ジォヴァンニの小島の陰に、パランツァの灯火が望まれた、すぐ湖ぎしのホテル・ベルヴューに宿をとる。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞くともなくその響に耳を仮して、目は窓に向かえば、吹きしぶく雨｜淋漓としてガラスにしたたり、しとどぬれたる夕暮れの庭はまだらに現われてまた消えつ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、まともにたたかえば、これはどうしても火星人の勝で、地球人類の負となるだろう。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガス弾をつかえば、火星兵はやっぱり死んでしまうよ。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
