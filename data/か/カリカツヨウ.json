        "index": 1,
        "gloss": "classical form of i-adjective inflection formed by contraction of the \"ku\" adverbial form with the classical verb \"ari\" (\"aru\")",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
