  {
    "uuid": "04da5ecb-e899-5dc7-a254-e72c62acbb98",
    "entry": "かて",
    "reading": {
      "primary": "かて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "助詞",
        "接続詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "even if",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「そんなに慌てて走ったかて、もう電車は行ってしもたで」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一生懸命勉強したかて、本番で実力が出せへんかったら意味ないねん」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「少しくらい失敗したかて、死ぬわけやないんやから気にせんでええやん」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "馬場はときたま、てかてか黒く光るヴァイオリンケエスを左腕にかかえて持って歩いていることがあるけれども、ケエスの中にはつねに一物もはいっていないのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐竹の顔は肌理も毛穴も全然ないてかてかに磨きあげられた乳白色の能面の感じであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親が子を可愛がると言ふのが……さあ如何言はうか……意志的意識の世界で三文の値打があるだらうかてなあ――そりやあ親が子を可愛がるやうになつてることも必要でせう、併しそれが人間の口から如何の斯うのつて問題になるべき性質のものぢやないなあ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "野心があるから、孤獨なんて事を氣に病むので、他の世界の事なんかてんで問題にしてなかつたら、百年千年ひとりでゐたつて樂なものです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞内の貫きよう、壁皴の模様、かてて加えて、岩徹る清水は岩の肌を程よく潤して洞は枯石の成るところのものとは思えない。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで、そんなに、おこらんかてええやないか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひき込んである」「吉峰さんのおばさんがあしたお帰りですかて……」信子は何かおかしそうに言葉を杜断らせた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あしたお帰りですかて？",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その因縁でおいらちょいちょい父親の何とかてえ支那の家へ出入をするから、悉しいことを知ってるんだ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばセルロイドで作ったキューピーなどのてかてかした肌合や、ブリキ細工の汽車や自動車などを見てもなんだか心持ちが悪い。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上にかてて加えて往々記者の認識不足が不合理の上に不自然の上塗りをするのであろう。",
              "citation": {
                "source": "ニュース映画と新聞記事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾百年の永いとしつき、幾百万人の日本の男女の生活を吸いとって、てかてか黒く光っている。",
              "citation": {
                "source": "古典竜頭蛇尾",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "てかてかした円卓の上にまっ白な皿があってその上に立派な二房の黒ぶだうが置いてありました。",
              "citation": {
                "source": "黒ぶだう",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると給仕はてかてかの髪を一寸撫でて、「はい、誠にお気の毒でございますが、当地方には、毒蛾がひどく発生して居りまして、夕刻からは窓をあけられませんのでございます。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはそんなに大きくはありませんでしたが幹はてかてか黒く光り、枝は美しく伸びて、五月には白き雲をつけ、秋は黄金や紅やいろいろの葉を降らせました。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は白いだぶだぶの麻服を着て黒いてかてかしたはんけちをネクタイの代わりに首に巻いて、手には白い扇をもって軽くじぶんの顔を扇ぎながら少し笑ってみんなを見おろしていたのです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こうの少し小高いところにてかてか光る茶いろの馬が七匹ばかり集まって、しっぽをゆるやかにばしゃばしゃふっているのです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはそんなに大きくはありませんでしたが幹はてかてか黒く光り、枝は美しく伸びて、五月には白い花を雲のようにつけ、秋は黄金や紅やいろいろの葉を降らせました。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども元大先生からして自己流ですから弟子も皆な自己流で、ただむやみと吹くばかり、そのうち手が慣れて来れば、やれ誰が巧いとか拙いとかてんでに評判をし合って皆なで天狗になったのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かてて加えて爪皮の掛った日和下駄で、見上げるばかり大いのが、もくもくとして肩も胸も腹もなく、ずんぐり腰の下まで着込んだのは、羆の皮を剥いた、毛をそのままにした筒袖である。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音さえ、谺するまで、高い天井、大空に科学の神あって彼を守護するごとくであるのに、かてて加えた学友が、五人の数、彼を取巻いて、あたかも迷宮の奇き灰色の柱のごとく、すくすくと居合わせたのが、希有な侵入者を見ると、一斉に伝吾に瞳を向けた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると給仕はてかてかの髪をちょっと撫でて、「はい、誠にお気の毒でございますが、当地方には、毒蛾がひどく発生して居りまして、夕刻からは窓をあけられませんのでございます。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "てかてか髪をわけた村の若者が、みんなが見ているので、いよいよ勢いよくどなっていました。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなしい耕平のおかみさんが、葡萄のはひったあの桶を、てかてかの板の間のまん中にひっぱり出しました。",
              "citation": {
                "source": "葡萄水",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが事務所にはたった一人髪をてかてか分けて白いしごきをだらりとした若者が椅子に座って何か書いてゐた。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬が黒くてかてか光ってゐたし谷はごうと流れてしづかなもんだった、署長はもう興奮して頭をやけに振った。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗ってるものはみな赤シャツで、てかてか光る赤革の長靴をはき、帽子には鷺の毛やなにか、白いひらひらするものをつけていた。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と黄饅頭を、点頭のままに動かして、「茸――松露――それなら探さねば爺にかて分らぬがいやい。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "客は河豚で温まり、てかてかした頬をして、丹前の上になにも羽織っていなかった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂田はんをこんな落目にさせたのは、もとはといえば皆わてからやと、かえって同情してくれて、そしていろいろあった挙句、わてかてもとをただせばうどん屋の娘やねん。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
