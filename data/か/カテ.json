    "definitions": [
      {
        "index": 1,
        "gloss": "food",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "雪山で遭難しかけた際、リュックに忍ばせていた一本のチョコレートだけが唯一の糧だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "厳しい冬を越すために、村人たちは秋のうちに収穫した作物を冬越しの糧として蓄えておく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「これでお腹を満たして」と差し出された温かいスープは、明日も歩き続けるための糧となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "弱者の糧太宰治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）猛っている：入力者注　主に外字の説明や、傍点の位置の指定（例）「映画でも見ようか。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからの映画は、必ずしも「敗者の糧」を目標にして作るような事は無いかも知れぬ。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日々の糧が見えるだけだ。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから見ると、赤沢岳の鞍状の凹みの間から、常念岳が出たが、頂上は雲で見えなかった、昨夜の野営で一日分の食糧が減ったので、人夫の一人を解放して、下山させた。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分この乾草は、軍に献納した馬糧の残りであらう。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "持ち亙って来た行糧ももはやほとんど無くなっていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "行糧の料はすでに尽き、衣類、履ものも旅の責苦に破れ損じた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水無瀬はその弟妹の中の上の弟を語って、三月の行糧を、山の窟に蓄えた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れて始めて、日々の糧の心配なく、専心に書物の中のことと、実験室の成績と突き合せながら、使える部分を自分の工夫の中へ鞣し取って、世の中にないものを創り出して行こうとする静かで足取りの確かな生活は幸福だった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国の海軍ではこの器械を四十台使っているが、水夫二、三人掛りで十五分間も運転させると一日の食糧くらいは楽に出来るという事である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、彼女達の一家がこちらへ引移る前にしばらく仮泊していた品川の若木屋という旅館へ電話をかけて見ようと思って、彼女は近所の出入の酒や食糧品を売っている武蔵屋へ電話を借りに出ようとした。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも、貧しい糧のみで空腹を充たすまい。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の苦惱が私から糧をとり、そして私をへとへとに疲れさせてしまつたかのやうに。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車には宵のうちから糧秣や弾薬や防寒具が積込まれた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなのは、昨年の旱魃にいためつけられた地方だけかと思っていたら、食糧の供給を常に農村に仰がなければならない都会では、もっとすさまじいらしい。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十貫の豚が一匹あればツブシに売って、一家が一カ月食って行く糧が出るのだ。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "食糧を貯蔵しなかった怠け者の蟋蟀が木枯しの夜に死んで行くというのが大団円であったが、擬音の淋しい風音に交じって、かすかなバイオリンの哀音を聞かせるのが割に綺麗に聞きとれるので、これくらいならと思って安心したのであった。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは世界の食糧問題に対する相当の陰謀をも含むもので昔は極めて秘密に開催されたものであるさうであるが今年は公開こそはしなかったが別にかくしもしなかったやうだ。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ人類の食糧と云はゞスタンダードチョイスリーダー三　フレデリック大王の質問をまたずと雖も動物植物鉱物の三種を出づべからず。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も今日の世界の状態食やゝ足り亦は足らず、もし偏狭なる人間一群ありて動物は可〔哀さう〕なれば食すべからずと云はゞこれ人類の食糧の四分の一を奪取せんと企つるものに非や。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「糧秣や被服を運ぶんだ。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「糧秣や被服を運ぶのに、なぜそんなに沢山橇がいるんかね。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月給の不渡りと、食糧の欠乏と、張宗昌の無理強いの戦闘に、却って戦意を失ってしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "食糧や、慰問品の受領に鉄道沿線まで一里半の道のりを出かけていた十名ばかりが、帰ってきたのだ。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　米吉は、とうとうカンシャク玉を破裂さした、生活の糧まで食われるという法はなかった。",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その三原山行きの糧食としてＮ先生が青木堂で買って持って行ったバン・フーテンのココア、それからプチ・ポアの罐詰やコーンド・ビーフのことを思い出したので、やっとそれが明治四十二年すなわち自分の外国留学よりは以前のことであって帰朝後ではなかったことがわかった。",
              "citation": {
                "source": "詩と官能",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道では熊におびやかされたり、食糧欠乏の難場で肝心の貯蔵所をこの「山のおじさん」に略奪されて二三日絶食した人もある。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "糧と味噌と鍋とをしょって、もう銀いろの穂を出したすすきの野原をすこしびっこをひきながら、ゆっくりゆっくり歩いて行ったのです。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると日田の御金奉行は、その日田金を手蔓にして諸大名のお納戸金の遣繰りを初めとして、知行高の裏表、兵糧の貯蔵高まで立入ってコト明細に探り出す。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は計画どおり三カ月の糧を蓄えて上京したけれども、坐してこれを食らう男ではなかった。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
