        "examples": {
          "standard": [
            {
              "text": "環椎は、頭部を支え、うなずく動作を可能にする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "首の骨である環椎と軸椎は、頭の回転運動に深く関わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "落馬事故で、彼は環椎を損傷する重傷を負った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "昼でも暗いので電灯がかんかんついて、夜も昼のようだ。",
              "citation": {
                "source": "字で書いた漫画",
                "author": "谷譲次",
                "note": "青空文庫"
              }
            },
            {
              "text": "下谷の大通りのほうへ小半丁も下ると、軒なみに暗い家がならんでいるなかに、一軒灯のかんかんついている家があった。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとに残った文次、そっと戸口にたたずんで家内の気配をうかがうと――、　さながら仏事でも行なっているように、灯がかんかんついて、人声がする。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜を徹して机に向っている時など、室内は燈火がかんかんついているので、天明の近づいたことも知らぬうちに、思いがけず鶯の声を耳にすることがある。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
