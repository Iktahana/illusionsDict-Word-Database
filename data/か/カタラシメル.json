    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to finish telling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は自らの経験を詳細に語らしめ、聴衆を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "事件の全貌を語らしめるまで、尋問は終わらなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "真実を語らしめることで、彼女は心の重荷を下ろした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "岳神が冥合しているところの山そのものを岳神の上で語らしめるその「わたくし」であった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれには単に訳本をして自ら語らしめる、否訳文をして自ら語らしめると云う趣意ばかりで無く、別に理由がある。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝記記者としてのビリューコフは、終始一貫して事実に正確忠実であろうとし、常に「トルストーイ自身をして自己を語らしめるように努力」している。",
              "citation": {
                "source": "『トルストーイ伝』",
                "author": "――ビリューコフ著・原久一郎訳――",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルクスの先蹤として、宗教的イデオロギーの批判に従事したフォイエルバッハは、すでに記している、「思弁は宗教をしてただ、思弁みずからが考えた、そして宗教よりも遙かによく語ったところのものを、語らしめる。",
              "citation": {
                "source": "マルクス主義と唯物論",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに私は宗教をして自己みずからを語らしめる。",
              "citation": {
                "source": "マルクス主義と唯物論",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルクスの先蹤として、宗教的イデオロギーの批判に從事したフォイエルバッハは、すでに記してゐる、「思辨は宗教をしてただ、思辨みづからが考へた、そして宗教よりも遙かによく語つたところのものを、語らしめる。",
              "citation": {
                "source": "唯物史観と現代の意識",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに私は宗教をして自己みづからを語らしめる。",
              "citation": {
                "source": "唯物史観と現代の意識",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでは、ただ「気持が好い」とだけ語らしめる。",
              "citation": {
                "source": "生きている空間",
                "author": "――映画空間論への序曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ「気持がよい」とだけ語らしめる。",
              "citation": {
                "source": "芸術の人間学的考察",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "作中の人物をして比較的「多く語らしめる」ことは理の当然である。",
              "citation": {
                "source": "武者小路氏のルナアル観",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはこの人間の言葉に、（c）この（聖アウグスティヌス）に、（b）運命＊・宿命・出来事・運不運・神々・その他これに類する語句を、これ相応に語らしめる。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
