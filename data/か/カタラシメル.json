    "uuid": "382860c2-61d5-5def-8825-631386df0ea7",
    "entry": "語らしめる",
    "reading": {
      "primary": "かたらしめる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段"
      ],
      "ctype": null,
