        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "故人は白い花で飾られた棺桶に静かに横たわっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画のクライマックスで、主人公が棺桶から飛び出すシーンは衝撃的だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの古民家の裏庭には、昔使われていたような棺桶が放置されているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "棺桶を蔽う天蓋や、黒い幕は引きめくられた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親爺の皮膚は、薄黒く、また黄色ッぽく、白血球は、薬のために抵抗力を失って、まるで棺桶に半脚突ッこんだ病人のように気息｜奄々としていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、棺桶の中へは、いくらかの金を入れた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府で歳入の帳尻を合わせるために無茶苦茶にこの材木の使用を宣伝し奨励して棺桶などにまでこの良材を使わせたせいだといううわさもある。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレ莚よ、棺桶よ、荷い棒よと騒ぎ始めた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかといって棺桶や位牌のごとく生活の決算時の入用でもない。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この折詰を積んだ形が大一番の棺桶などは、どんなものです。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "力はあるし、棺桶をめりめりと鳴らした。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それは棺桶を聯想させた。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "堤の上を、藍染橋の袂から白包の棺桶が担ぎ出されて堤の上を南へ川に沿って行きます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな棺桶に半分足突っ込んだおっさんと同じようにせんといて……。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "棺桶の中にも酒をつめた瓢箪が入れられた。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "檀家がよく棺桶をかついで来た。",
              "citation": {
                "source": "竹林生活",
                "author": "――震災手記断片――",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬われはしたかも知れないが竟に誰にも愛されず、孤独な放浪の中に一生を送った伯父の、その生涯の寂しさと心細さとが、今、この棺桶の中に一杯になって、それが、ひしひしと三造の方まで流れ出して来るかのように思われるのであった。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人跡稀な山奥の火葬場で人を焼く序に、棺桶を発いて目ぼしいものを奪い取る。",
              "citation": {
                "source": "書けない探偵小説",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "四度目にはもう絶望ちいうて棺桶へ入れられかけた事もあります。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ棺担ぎが出て来て棺桶に太い棒を通した。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "得たりや応という中にテンデに羽織をぬいで棺桶を担ぎ上げた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ヤッと棺桶が立ち止った。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うの酒屋で一杯やろうか」「オッと来たり、その棺桶は門口へ降いとけ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーイシャンシャン、ヨーイ、シャンシャンウアーイ」　と一本入れた一同は、又もや棺桶を担ぎ上げて、人通りを押分け始めた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて棺桶は持ちだされて、天笠山の麓へ運ばれ、同地の風習に従って軽く棺の周囲に土を被せかけて葬られた。",
              "citation": {
                "source": "断橋奇聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには一個の棺桶が置いてあったが、その上に紙を貼って太い文字を書いてあった。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "棺桶の前には牡丹の花の飾をした牡丹燈が懸けてあった。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その前にあった棺桶の蓋が急に開いた。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、この中へお入りくださいまし」　女はその棺桶の中へまず自分の体を入れてから、喬生を引き寄せた。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "棺桶は二人を内にして、そのまま閉じてしまった。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ考えた結果、湖心寺の棺桶のことを思いだして、付近の者を頼んでいっしょに湖心寺へ行って、棺桶のある室へ行ってみた。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "棺桶の蓋の間から喬生の着ていた衣服のはしが見えていた。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで、かんおけをたてにして、ならべたようなかんじです。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
