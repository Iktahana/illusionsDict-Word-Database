[
  {
    "uuid": "4c053ec3-0eec-5294-9b15-62027576bc2a",
    "entry": "火口壁",
    "reading": {
      "primary": "かこうへき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
