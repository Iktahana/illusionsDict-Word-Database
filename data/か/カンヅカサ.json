[
  {
    "uuid": "f1d546fd-13ed-5d4c-bee3-5ffd9aa35796",
    "entry": "主神",
    "reading": {
      "primary": "かんづかさ",
      "alternatives": [
        "かみづかさ",
        "かむづかさ"
      ],
      "is_heteronym": false
