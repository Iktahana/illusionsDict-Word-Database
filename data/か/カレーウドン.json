        "examples": {
          "standard": [
            {
              "text": "肌寒い日には、熱々のカレーうどんが最高だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "白いシャツを着てカレーうどんを食べるのは、いつもちょっとした冒険だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "出汁の効いたカレーうどんは、老舗の蕎麦屋で食べるのが好き。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "急にカレーうどんが食べたくなって、帰り道にスーパーで材料を買い込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "おかめ、卵とじ、鴨南蛮、鍋焼――と、昔風なのからカレーうどん、きつねうどん（油揚げの入った奴。",
              "citation": {
                "source": "うどんのお化け",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "ま、そんなところを、毎日メニュウを変えて註文しているうちに、何うも、十日以上にもなると、倦きちまって、カレーうどんに生卵を落して呉れと註文したり、おかめと、きつねの合併したのを造って呉れと、言ったりし始めた。",
              "citation": {
                "source": "うどんのお化け",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "那波・渋沢・三橋・日野・安藤とゐて、サントリー十二年などあり、カレーうどん食って秦が東京から着いたのと入れ代りに、明日を約して帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
