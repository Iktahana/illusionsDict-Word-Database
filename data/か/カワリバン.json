        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "水やりは、家族で代わり番にすることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この作業は一人でやるには辛いから、代わり番で交代しよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちは、おもちゃの取り合いにならないよう、代わり番で遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "僕たちはこのやっかいな乳母車をかわりばんこに押していったのである。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はかわりばんこに、泉のふちの、しだやぜんまいの上に両手をつき、腹ばいになり、つめたい水の匂いをかぎながら、鹿のように水をのみました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、ぼくたちは学校へいくとき、かわりばんこに先生のポケットに手を入れていくんだ。",
              "citation": {
                "source": "うた時計",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずり落ちそうになる眠気と、倭文子の上に京子がどんな魔手を弄しているだろうとの不安とが、かわりばんこに、彼を襲って来た。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お房とお菊はかわりばんこに腰掛けた。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん、お父さん家にいるよ、お婆ちゃんも、小母ちゃんも銀座の方にこの頃通って、とても夜おそいの、だから僕だの父ちゃんが、かわりばんこに駅へむかいに行くんだよ……」　お君さんはおこったように沈黙って海の方を見ていた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二本の足をかわりばんこに動かして、まるで、目の前に希望がぶらさがっているような、あくせくした行進だ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はかわりばんこに手つだいあうことを約束しました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランプがついている下で、大きい瀬戸物のスープ入れの壺のまわりへ親子がかたまり、かわりばんこに木匙をつっこんでキャベジスープをたべた。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の前には少し黒味のかかった十銭丸二つと其よりも一寸大きい二十銭一つがかわりばんこにおどりをおどって居る。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆用事があるし、かわりばんこに出て、自分ひる間すみ子さん一人っきりにしておけず入棺がすむまで（午後六時頃）居た。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなかわりばんこにごちそうするの、あたしも、たびたびごちそうになったわ。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、三人でかわりばんこに一ツずつ話そうじゃ有りませんか」と直樹が言出した。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "お房とお菊とは、かわりばんこに腰掛けた。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてＴ君と私とをかわりばんこに見ながら、Ｓ温泉の説明をしてくれた。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は繻子のクッションの上に寝て、最近にサーカスを見物したとき眼をつけた軽業師の真似をしているらしく、片脚をかわりばんこに上へ蹴り上げていた。",
              "citation": {
                "source": "小波瀾",
                "author": "ЖИТЕЙСКАЯ　МЕЛОЧЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "両足をかわりばんこにあげているのは、かにさされないためでもありますが、便所にいきたいのをがまんしているためでもありました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新しくとりましょうよ、かわりばんこに……」　ばつがわるそうにそう言って伸子はちらりと亢奮した笑顔をした。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏草のもうすがれはじめた庭の軒さきで、かわりばんこに撮った下手な素人写真を添えて書類を出した。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい焔がゆれているような顔をしてトラヴィアタの中にあるメロディーを口笛で吹き、そうかと思うと、ブジョンヌイの歌を鼻うたでうたって、部屋じゅう歩きまわったあげく膝をまげた脚をピンピン左右かわりばんこに蹴出すコーカサス踊の真似などをした。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫く横になっていた方がいいよ」　着たまま毛布の下へ入り、湯たんぽを足の先、胃のうしろと、かわりばんこに動かして伸子は体を暖めようとした。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は「戦旗」をかりて来た日から、折にふれてはその二冊をかわりばんこにくりひろげて、読んで見るのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛のさきをぷつんと短くきった細筆のさきに桐をやいてこしらえた軽い墨をつけて、両眉をかわりばんこにもち上げて、口をすぼめるような表情で鏡を見ながら眉を描く手つき。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "和一郎と小枝、素子と伸子の二組は、かわりばんこにそういうふたとおりの条件に支配され、佐々のうちのものがパリについてから、和一郎たちにとっても、まる一日が自分たち若夫婦の自由につかえるという日がなかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッ、パッと、ツァーの写真と日本のおかめの面なんかが、かわりばんこに出たりするの。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フミエと洋一は、かわりばんに、となり村のくすりやへ、粉ミルクを買いにゆかねばなりませんでした。",
              "citation": {
                "source": "柿の木のある家",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳴尾君と私は始は二人かわりばんこに飯を焚いたが、そのうち私は横著を極め込んで、いつのまにか鳴尾君ひとり女房役に廻るようになった。",
              "citation": {
                "source": "西隣塾記",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
