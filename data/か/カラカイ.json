[
  {
    "uuid": "f4ac2aeb-625b-504f-b2d1-387e8364bf3a",
    "entry": "揶揄い",
    "reading": {
      "primary": "からかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
