        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "原始社会では物々交換が主流だったが、次第に貨幣経済へと移行していった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日の複雑な社会は、貨幣経済によって円滑に機能している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一部の地域では、まだ完全な貨幣経済に移行していない場所も存在する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これはなにも今日の貨幣経済の世の中だけの話ではなく、私たちの子供の頃から、既にそうであった。",
              "citation": {
                "source": "母性愛の蟹",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "物々交換の状態から貨幣経済に次第に進み、貸借の関係は複雑になって、頼母子のごときものも発達する。",
              "citation": {
                "source": "文化史上より見たる日本の数学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "福音書の記事に一致しない点があるからといって内容の真実性を疑ったり、また「銭も持つな」とあるからと言って貨幣経済の今日当座の汽車賃も持たずに飛び出したりするのはいずれも聖書の読み違いです。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "貨幣経済に於ける金本位さえマチマチになるこの世界だから、日本本位の思想が兌換され得ようなどということは、希望する方が無理ではないだろうか。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "貨幣経済が急激に発達し、利子を目ざす資本の蓄積がはじまり、都市が出現するに至ったことなど、すべてそこに聯関している。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時急速に貨幣経済の進展しつつあった日本においては、銅銭の需要は極めて熾烈であった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "貨幣経済の進展に従い銭貨を必要とした日本人は、この貿易を控えるわけには行かなかった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、シナの銅銭の輸入による貨幣経済の発展に伴い、金持の出現、高利貸の盛行を見るに至った結果、経済的な不平等への反抗運動として起ったのであった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは貨幣経済による富の蓄積が漸く著しくなって来た当時の経済界にとっては、容易ならぬ大事件であった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
