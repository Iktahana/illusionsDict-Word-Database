    "definitions": [
      {
        "index": 1,
        "gloss": "sweet-smelling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
