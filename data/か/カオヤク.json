        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの地域の顔役は、Aさんだと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は町の顔役として、様々なイベントを企画している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の映画に出てくる顔役は、たいてい怖い人だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その時、私を連れて行ってくれた人というのは、映画界の余程の顔役らしく、私たちはその日たいへん歓迎されました。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼鏡をかけているのが、その顔役の人で、もうひとりの、色の白いのが撮影所の所長です。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "車夫はその不景気を馬車会社に怨みて、人と馬との軋轢ようやくはなはだしきも、わずかに顔役の調和によりて、営業上｜相干さざるを装えども、折に触れては紛乱を生ずることしばしばなりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに徳兵衛の貧乏いよいよ迫り、ことしの暮は夜逃げの他に才覚つかず、しのびしのび諸道具売払うを、町内の顔役たちが目ざとく見つけ、永年のよしみ、捨て置けず、それとなく徳兵衛に様子を聞けば、わずか七、八十両の借金に首がまわらず夜逃げの覚悟と泣きながら言う。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔役は笑い、「なんだ、たかが七、八十両の借金で、先代からのこの老舗をつぶすなんて法は無い。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また翌日の一組は、れいの発起人の顔役とその十八の娘。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜も、Ｎ君の家へこの地方の若い顔役が二、三人あそびに来て一緒にお酒やビールを飲んだけれども、Ｎ君の人気はなかなかのものらしく、やはり一座の花形であつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔役のお客さんたちが帰つてしまふと、私とＮ君は奥の座敷から茶の間へ酒席を移して、アトフキをはじめた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "随つて、工藤様といへば、村の顔役、三軒の士族のうちで、村方から真実に士族扱ひされたのは私の家一軒であつた。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親は資金の金は騙し取られ、掠め取られて裸一貫にはなったものゝ、生来、物にめげない気象が役立って、西海岸の日本人間で多少は口利きの顔役になりかけていた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "附近の百姓ども、あれよあれよと騒いだが、村々在々の顔役共は真田邸で酔いつぶれているので、どうすることも出来なかった。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでわかったろう、この一覧と日記は南部の顔役の幾人かを結びつけるもので、これが見つかるまで夜もおちおち眠れない連中が大勢いるのだ。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここらにゃあ顔役とか親分とかいうものはいねえかね」と、半七は訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや、東京で三年、苦学して法律をおさめた（しかし、それは、通信講義録でも、おさめることが出来るようだが）そのような経歴を持ったとあれば、村の顔役の一人に、いやでも押されるのである。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう他国者の新顔を、痛めつけることは昔も今も暴力団的顔役の仕事である。",
              "citation": {
                "source": "大力物語",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "両国の河岸っぷちに見せ物小屋のなわ張り株を持っている松長ってえいう顔役がありますが、その親分が世話をしたとか、口をきいていっしょにしたとかいう話ですから、いってごらんなさいまし」「おまえ、そのうちを知っているかい」「おりますとも、よく知っておりますよ」「よしッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手はあまり筋のいい顔役じゃねえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は将棋遊歴をしてあるくのに、よくその土地の顔役の許を手頼つていつたもんだ。",
              "citation": {
                "source": "本因坊と私",
                "author": "関根金次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが晴代の最近の住替の動機だつたが、或る日｜一直からかゝつて、馴染だと言ふので行つてみると、土地の興行界の顔役や請負師らしい男が五六人頭をそろへてゐるなかに、その男がにや／＼してゐた。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何でもあんめえ、さ、一杯進ぜようて」「いや、一寸待った」　顔役で、部長の勘助が兵児帯をなおしながら立ち上った。",
              "citation": {
                "source": "田舎風なヒューモレスク",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤミ屋の親分、子分、水中の町の顔役、その結たくがたて糸となっていて町のあたりまえの人たちの水中生活の姿が浮び出ないしそこで赤旗をもっている人々の活動も添えものとしてあつかわれていて着実な町の生活とのつながりの現実の場面がわからない。",
              "citation": {
                "source": "予選通過作品選評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お二人さんお二階」　チョンチョンと下足札を鳴らすが、小屋は満員で、騒然としていて、顔役は、まがい猟虎の襟付外套で股火をし、南京豆の殼が処嫌わず散らかっているだけだ。",
              "citation": {
                "source": "山峡新春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "識ろうとする欲求によってではなく、社交上の情勢によって、顔役として坐っていた。",
              "citation": {
                "source": "狐の姐さん",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "輿論は自由党の経済的毛細管であり、動員網であるヤミ市の繩張り顔役の勢力に、社会党が一撃を加えたものと認めた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四七年の夏、軍事的半封建的なシステムをもって運営されていた町会が解散されたと同時に、各町会役員の変形した活動舞台である「文化会」がその町の顔役やボスによって組織された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "・ここにおちつき草萌ゆる（改作）三月十四日　曇、時々寒い雨が降つた、行程五里、また好きな嬉野温泉、筑後屋、おちついた宿だ（三〇・上）此宿の主人は顔役だ、話せる人物である。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔役の裔　久しい以前のこと、山の手から下町、下町から山の手と、殆んど処隈なく古ぼけた車に朴の木樫の木撫の木を載せて、いずれの太夫が用いすてたのやら、糸も切れ切れの古鼓を鳴らして、下駄の歯入れをなりわいに呼び歩く四十なにがしという爺さんがあった。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し、この自然児は長脇差の裔で、祖父も父も江戸に名高い顔役の一人であったとやら……。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "最もその時分、角力の親方だとか顔役だとか、人気役者とかいえば、そうした突拍子もないお祭りさわぎの葬式もあったが、チンコッきりおじさんを知っているものには不思議な微笑をもって送られた。",
              "citation": {
                "source": "お墓のすげかえ",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる顔役――そんな時に、人を担いで顔をうっている区内の政治好きが、楠本氏に草鞋を穿かせ、袴のももだちをとって連れてきた。",
              "citation": {
                "source": "議事堂炎上",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
