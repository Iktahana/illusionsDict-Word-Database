    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Kwansei Gakuin University (abbr)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「来年の春から、いよいよ関学に通うんだ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "関学のキャンパスは、歴史ある美しい建物で有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は関学を卒業後、すぐに大手企業に就職した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その頃、芥川は機関学校の先生をしてゐたし、久米は医者の雑誌の記者をしてゐたやうに思ふ。",
              "citation": {
                "source": "世に出る前後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "入社の辞芥川龍之介　予は過去二年間、海軍機関学校で英語を教えた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関学校時代、機械体操にかけては級中に鳴りひびいた川上機関大尉であればこそできた離れ業であった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃の実12・５（夕）　横須賀にある海軍機関学校の校長｜船橋中将が、大橋｜乙羽がまだ存命当時、道連れになつて、一緒に米国を横切つた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はそのために口を探し、同じ年の十二月に海軍機関学校の教官になつた。",
              "citation": {
                "source": "身のまはり",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――海軍機関学校の教官となり、高浜先生と同じ鎌倉に住みたれば、ふと句作をして見る気になり、十句ばかり玉斧を乞ひし所、「ホトトギス」に二句御採用になる。",
              "citation": {
                "source": "わが俳諧修業",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし僕は十年ののち、海軍機関学校の理髪師に頭を刈ってもらいながら、彼もまた日露の戦役に「朝日」の水兵だった関係上、日本海海戦の話をした。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　震災前のことだが、芥川竜之介君と私とは共に、横須賀の海軍機関学校に教師をしていた。",
              "citation": {
                "source": "交遊断片",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "海軍機関学校に居る頃から、彼は外川先生に私淑して基督を信じ、他の進級、出世、肉の快楽にあこがるゝ同窓青年の中にありて、彼は祈祷し、断食し、読書し、瞑想する青年であった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は或る重役上りの人がアインシュタインの相対性理論への反駁を書いたのを見たが、それには自説の賛成者として、海軍機関学校の一生徒の賛成の書信が大事そうに載せられていたのを、今偶々思い出すのである。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は機関学校の生徒の手紙が贋造であるなどとは決して思わない。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
