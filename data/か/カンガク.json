  {
    "uuid": "7b432504-2520-5dc3-8aa3-235ab879db35",
    "entry": "関学",
    "reading": {
      "primary": "かんがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
