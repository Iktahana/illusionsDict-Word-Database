        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "春の訪れを告げる沈丁花の香りが、風に乗ってふわりと部屋の中まで届いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、見て！トビが上昇気流に乗って、全然羽ばたかずに風に乗って飛んでるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "遠くの寺から響く鐘の音が、風に乗ってかすかに聞こえてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都会の喧騒を離れると、鳥のさえずりが風に乗って心地よく耳を打つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "腰から上が、風に乗る紙のようにふわりと前に落ちた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、定期風に乗る男　その、出島にある猟館には、仏蘭西大使館の司厨長中村銀次郎が住んでいた。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰から上が、風に乗る紙の様にふわりと前に落ちた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　駄夫はいきなり往来の真ん中で、まるで風に乗るやうにして、ステテコを踊つてみせた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
