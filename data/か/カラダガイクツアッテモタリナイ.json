        "examples": {
          "standard": [
            {
              "text": "新しい案件が次々と舞い込み、体がいくつあっても足りないくらい忙しい毎日だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "育児に家事に仕事と、彼女はいつも「体がいくつあっても足りない」と言っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イベント準備から広報活動、当日の運営まで、体がいくつあっても足りない状況だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "特にいわゆる心霊術師の場合に、そういう問題を一々とり合っていては、科学者は身体がいくつあっても足りない。",
              "citation": {
                "source": "心霊現象と科学",
                "author": "――『心の領域』について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "内外人の女たちにもてて、体がいくつあっても足りないほど騒がれているというこの根岸の花形騎手も、つい数年前まではメリケン波止場で砂糖馬車組合の幌荷馬車に鞭を打っていた労働者だったのである。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「時は来た」　と思い、彼はここのところ、体がいくつあっても足りない気がした。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
