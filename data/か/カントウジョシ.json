        "examples": {
          "standard": [
            {
              "text": "「ね」や「さ」のような間投助詞を多用すると、馴れ馴れしい印象を与えることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "方言特有の間投助詞は、その土地ならではの情緒を感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "文末だけでなく、文の途中に挟まれる間投助詞が日本語の特徴の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あのさ、昨日なんだけど……」のように、話しかけるきっかけを作る間投助詞。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
