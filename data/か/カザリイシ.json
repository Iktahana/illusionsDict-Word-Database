        "examples": {
          "standard": [
            {
              "text": "庭の池の底に敷き詰められた五色の飾り石が、水に濡れてキラキラと輝いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "そのブローチの真ん中には、深い緑色をした大きな飾り石が埋め込まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「見て見て、この飾り石、光を透かすと中の模様が動いているみたいだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父は旅先で見つけた珍しい形の飾り石を、玄関の棚に大切に並べていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "したがって、花瓶に插して煖炉の飾り石の上に置いておくと、翌年の夏まで優しい姿を保っているからである。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
