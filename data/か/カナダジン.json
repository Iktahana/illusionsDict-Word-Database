        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "僕の大学には、カナダ人留学生のグループがいくつかあって、いつも賑やかだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "トロントで出会ったカナダ人は、みんなオープンでフレンドリーな人が多かったな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "カナダ人の友人から、現地の美味しいパイのレシピを教えてもらったんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "カナダ人の建築家がデザインしたという、このモダンな建物は素晴らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "彼等はその以前に合衆國の汽船會社支店にもカナダの汽船會社支店にも頼みに行つたのだけれども、アメリカ人やカナダ人の歸國する者さへ收容しきれないのだから、といつてことわられたといつてゐた。",
              "citation": {
                "source": "大戰脱出記",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時分（仕立屋にお使に行つた頃よりずつと後のことである）私のゐた女学校はカナダ人が建てたものだから、当時イギリス第一といわれてゐた詩人に講演を頼んだ。",
              "citation": {
                "source": "豚肉　桃　りんご",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カナダ人なども来ているが、日本人の方が評判がいい。",
              "citation": {
                "source": "勘",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス人などは、だいきらいだが、ご命令によって、フランス系のカナダ人の娘と結婚する運びになっている。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏蘭西系のカナダ人のなかで第一のお金持ち、ジャン・アマンドさんのごうしゃな快遊船である。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初に、これだけのことを、頭にいれておいてもらわないと困るんだ」「相手はいったい何者だい」「ロバート・チニー……フランス系のカナダ人、香港で捕虜になって、こっちへ送られてきた。",
              "citation": {
                "source": "春雪",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも彼はギルマンの部屋のすぐ下を借りているフランス系カナダ人がある晩マズレヴィチと話しているのを聞いたことがあった。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "種痘を受けないフランス系カナダ人のあいだに今でも残っている災難はどうであるかと言う不変な例である。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "セント・ローレンス河に沿うフランスカナダ人の家屋は、軒を僅か上方に彎曲させてあるが、これがそれ等の外観にある種の典雅さを与えている。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペローはフランス系カナダ人で色が黒かつた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしフランソアはフランス系カナダ人とインディヤンの混血で、倍も黒かつた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "オスラーはケルト系カナダ人の牧師の息子であって父親の職業を継ぐつもりであった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
