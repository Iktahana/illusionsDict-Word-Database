      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "untalkative",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は寡黙な人物だが、その的確なアドバイスにはいつも助けられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「そんなに寡黙にしないで、もう少し話してみてよ。」と友人が彼に言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "熟練の職人は、寡黙に、しかし着実に仕事をこなしていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は寡黙な性格だが、一度信頼した相手には心を開く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "あるいはまた津田君の寡黙な温和な人格の内部に燃えている強烈な情熱の※が、前記の後期印象派画家と似通ったところがあるとすれば猶更の事であろう。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "競馬の話、株の話、時局の話、碁、将棋の話、盆栽の話――大体こういう場所の客の間に交される話題に洩れないものだが、湊は、八分は相手に話さして、二分だけ自分が口を開くのだけれども、その寡黙は相手を見下げているのでもなく、つまらないのを我慢しているのでもない。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは田舎者だけにわかる心理で、田舎言葉を丸出しにしても笑われるし、また努力して標準語を使っても、さらに大いに笑われるような気がして、結局、むっつりの寡黙居士になるより他は無いのである。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "-------------------------------------------------------　寡黙と消極的な態度とは私達一族の者の共通性格と言ってもいいのだ。",
              "citation": {
                "source": "秋草の顆",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒髪で血色も悪く、髭もなく寡黙なのですが、礼儀正しく笑顔も素敵です。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても私は、モデル椅子に坐りはじめてからといふものは、何うもこれまでの私とは稍趣きを異にした寡黙家に変つたやうに思はれて来た。",
              "citation": {
                "source": "心象風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの背の高いそして口から煙草を放したことのない……」「そうだ、あの寡黙な仙人のことだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "寡黙のすぐれてゐるといふのは、このことを言ふのである。",
              "citation": {
                "source": "新しい生",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、愈々寡黙に、愈々人ぎらいになった。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "立居のおだやかな寡黙な質で、にこやかな面だちは親しみ易いが、折おり妙に気詰りな思いがして座をはずしたくなる。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは内気寡黙のゆえともみえる。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寡黙な間喜兵衛でさえ、口こそきかないが、白髪頭をうなずかせて、一同の意見に賛同の意を表した事は、度々ある。",
              "citation": {
                "source": "或日の大石内蔵助",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "言語を慎みて多くす可らずとは、寡黙を守れとの意味ならん。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂おてんばは我輩の最も賤しむ所なれども、唯一概に寡黙を守れとのみ教うるときは、自から亦弊害なきに非ず。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "言語を慎み寡黙を守ると言う、其寡黙も次第に之に慣るゝときは、人生に必要なる弁舌の能力を枯らして、実用に差支を生ずるに至る可し。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方が明るくなると、一方はだんだん寡黙になる。",
              "citation": {
                "source": "九条武子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に重吉が井沢郡から代議士にうって出て見ろ、最高点をとるにきまっとる、と云う周囲の焙りつくような待ち遠しい目を身に受けながら、重吉は寡黙に、快活に温い頑強さで、自分がそれらの人々の希望している通りの者には決してならないことを自覚して暮しているのであった。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オフシェンコは、真面目そうな、寡黙な男だ。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "寡黙な、芸の引き立たないこの男は、容貌にも特徴がなく、いつも髪の毛に埃っぽい匂いがする――とまあそういったような、何から何まで役者らしくない男だった。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃、寡黙なＫＯの主将、八郎さんまで、「よかろう」と積極的に嘴をだします。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、手近い益満に、軽い、乙女心の恋を感じていたが、旅をし、男の数を知り――百城に逢うと、その顔立、物腰、寡黙の中のやさしさ――それは、益満の粗暴とはちがって、男の値打に経験の無い綱手には、ずっと、益満より、立ち優って見えた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "（春陽堂版拙訳『別れも愉し』『日々の麺麭』とその序参照）　ルナアルの歿後十五年、今日の若き劇作家、その多くは一度、此の寡黙な先輩に耳を傾けたやうに思はれる。",
              "citation": {
                "source": "仏国現代の劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "寡黙な人物を好むことは勝手である。",
              "citation": {
                "source": "劇作家としてのルナアル",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに、作品の価値は、寡黙な人物が如何に描け、饒舌な人物が如何に描けてゐるかに在る。",
              "citation": {
                "source": "劇作家としてのルナアル",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、寡黙な人物のみが登場する舞台は、よく喋舌る人物のみが登場する舞台よりも芸術的に優れてゐるとは言ひ難い。",
              "citation": {
                "source": "劇作家としてのルナアル",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者は、寡黙な人物をして「下手な考へ眠るに若かざる」如き退屈極まる格言を吐き出さしめ、よく喋舌る人物をして「夜の更くるを忘れしむる」ていの魅力ある駄弁を弄せしむることを得るのである。",
              "citation": {
                "source": "劇作家としてのルナアル",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "野原は何だかもくもくして、ゴムのようでした。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野原は何だかもくもくして、ゴムのやうでした。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐が来るといいがなあ」　すると足の下がなんだかもくもくしました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅なかまは、ここぞと三本のむちで、ふたりのせなかもくだけよとばかり、したたかぶちのめしました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
