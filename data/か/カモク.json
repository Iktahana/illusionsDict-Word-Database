[
  {
    "uuid": "cd97adad-5b42-5399-8733-0447a299711a",
    "entry": "寡黙",
    "reading": {
      "primary": "かもく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
