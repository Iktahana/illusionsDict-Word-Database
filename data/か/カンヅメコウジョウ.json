          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ほら、あの煙突が見える場所が、昔からあるトマトの缶詰工場だよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "港のすぐ裏手に位置する缶詰工場からは、いつも煮魚の香ばしい匂いが漂ってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "近隣の農家から運び込まれた大量の果実が、缶詰工場で次々と選別されていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自動化が進んだ最新の缶詰工場では、ロボットアームが高速で蓋を閉めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "型の通りの訊問があった後、昨夜のお末の動静を訊ねたところ、「夕刻の六時にお暇を頂きまして、それから河田町にございますミヤコ缶詰工場へ出勤いたしました。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時お末がここでお手伝いをしているかたわら、夜は河田町のミヤコ缶詰工場の検査場で働いていると自供したじゃありませんか」「おお、そうだった」　検事は呻った。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの調べのときは、お末をも問題視せず、またお末が缶詰工場で働いていることも、彼女がたいへんによく働く人間だと思った外に、別に気に留めなかった。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが今となっては、帆村の指摘する通り、彼女の勤め先が「缶詰工場」であることは非常に重大なる意義があるのだ。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずお末さんのアパートへ行って家宅捜索をした上で、河田町のミヤコ缶詰工場へ廻ったがいいと思います。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりは次のミヤコ缶詰工場へ行こう。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方検事たちの一行は、お末のアパートの捜査をすませたのち、ミヤコ缶詰工場へとびこんだ。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ひ漏らしてはならぬが、私の現在の住居は庭を隔てて西側に缶詰工場があり、その騒音と臭気が困りものだといへば困りものだが、会社側は工場長はじめ、たいへん礼儀正しく物わかりがよく、結局、こちらが我慢をするか、ほかへ移るかしなければ解決がつくまいと思はれる形勢である。",
              "citation": {
                "source": "暖地の冬から山国の春へ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（筈である……）　ただ今、私が住んでいる小田原の家というのは、隣りの缶詰工場の異臭と怪音を除けば、斎藤緑雨のいわゆる「海よし、山よし、天気よし」の三拍子そろつた恰好の住宅である。",
              "citation": {
                "source": "時　処　人",
                "author": "――年頭雑感――",
                "note": "青空文庫"
              }
            },
            {
              "text": "町はさして大きくはないが、貝の缶詰工場と、貝殻を焼いて石灰を作る工場と、冬から春にかけて無数にできる海苔干し場と、そして、魚釣りに来る客のための釣舟屋と、ごったくやといわれる小料理屋の多いのが、他の町とは違った性格をみせていた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大蝶」はその町でいちばん大きく貝の缶詰工場を経営してい、漁師たちの採る貝を沖で買い取るために、大蝶丸という船を持っていた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "助なあこは大蝶丸の水夫であり、お兼は「大蝶」の缶詰工場へ貝を剥きにかよう雇い女で、亭主があった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大蝶丸は町でいちばん大きな缶詰工場の持ち船であり、「大蝶」の旦那は町で指折りの顔役であった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は缶詰工場の若い雑役夫で、源太の妻より六つも年下だったというが、これは町の人たちのいい話題になった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貝殻が缶詰工場から運ばれて来ると、二人の事務員があらわれる。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝票を貰った缶詰工場の雇人は箱車を曳いて帰り、こちらの二人は事務所へはいって扉を閉める。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらはみんなそれぞれ得物を持っていたし、貝の缶詰工場のあるじである「大蝶」の旦那は、猟服に身を固め、猟犬を曳き、猟銃を肩に掛けていた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは一例にすぎないが、缶詰工場でも、役場の待合所でも、根戸川｜亭でも、堀南の洋食屋「四丁目」でも、漁師や船頭だけではなく、住民がちょっと四五人も集まれば集まったところで、すぐに浦粕の死活問題が論議された。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は貝の缶詰工場で働いていた娘で、名はきみの、年は十八歳であった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はもそもそと、少女のあとを不決断に追っていったが、その男は二十五か六で、缶詰工場の工員のように感じられた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貝の缶詰工場や石炭焼場から吐き出される煙は上へゆくほど薄くなる棒のように、たゆたいもせず立ち昇っている、村はずれからこちらは見るかぎりの荒地で、ひとところだけこんもりと松や珊瑚樹やポプラの茂っているのは沖の弁天という小さな社の境内である。",
              "citation": {
                "source": "お繁",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大長丸の持主は扶原という老人で、その村でも一か二といわれる金持であり、貝の缶詰工場を二つも持っていたが、職人を酷使したりひどい吝嗇家として有名だった。",
              "citation": {
                "source": "お繁",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとある日、銀太郎の妻は乳呑児とお繁を捨てて、定吉という缶詰工場の若い職工とかけおちをしてしまった。",
              "citation": {
                "source": "お繁",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
