    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wise",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "相手の挑発に決して乗ることなく、冷静に議論を収めた彼の対応は、実に賢い大人の振る舞いだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "限られた予算をやりくりして、長期的な資産形成を計画する彼女は、金銭面において非常に賢い判断ができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "賢い消費者は、単に店頭の価格が安いことだけでなく、商品の品質や環境への影響まで考慮して選ぶものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "悪賢い小商人がいちばん活々して生きてゐるといふ有様だ。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが不可ない、たゞ実地に対する賢い良心は「形式論」の闡明を希ふものであるから形式論は、考へられなければならない。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりにわいだめもない世の渦のために、折に心が弱り、弱々しく躁ぎはするが、而もなほ、最後の品位をなくしはしない彼女は美しい、そして賢い！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたが私をお嫁に貰うには、もっと立派な賢い人にならないじゃ――ねえ、判って」　お蘭に取って、この言葉は一時凌ぎの気休めであり、また四郎への励ましに使ったものに過ぎないけれども、四郎は永く忘れなかった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不断、お蘭のいうことはすべて賢い言葉だと思って、口移しに真似て見るのが四郎の癖であった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの子　宜い調和と賢い素直さと皓潔な放胆で適宜に生きるというほどいつの時代にだって新鮮な生き方はなかろうと思いますわ。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで何でも人からくれるものが善いものであれば何もおせっかいな詮議などはしないで単純にそれを貰って、直接くれたその人に御礼を云うのが、通例最も賢い人であり、いつでも最も幸福な人である。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども大人や賢い子供らは、みんな本当にしないで、笑っていました。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは狐のこしらえたものを賢いすこしも酔わない人間のお子さんが喰べて下すったという事です。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって残り惜しそうに餌を見た彼の素直な、そして賢い態度と分別は、少からず予を感動させた。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果として自然に他人のする事が愚かに見え従って自分がだれよりも賢いというような錯覚に陥りやすい。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、人間の頭脳の最高水準を次第に引き下げて、賢い人間やえらい人間をなくしてしまって、四海兄弟みんな凡庸な人間ばかりになったというユートピアを夢みる人たちには徹底的な災難防止が何よりの急務であろう。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあゝ三人とも賢いいゝこどもらだったのにじつに残念なことをしたと云ひながら大きなあくびをしました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな賢いお子さんでも災難といふものは仕方ありません。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは猫なんていふものは、賢いやうでばかなものです。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな賢いお子さんでも災難というものは仕方ありません。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの娘御の実の母様の名は、たしかお民とか申しましたが、それはそれは賢いお方で、元来あの蔵元屋の家付のお嬢さんで御座いました。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢い少女の黒髪と、慈父の首と懐かしい……春春は土と草とに新しい汗をかゝせる。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも拘らず、孝行な他の賢い子より、そのやくざで嘘つきな息子の方が可愛ゆくて憎もうとしても憎めない。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この子が憎いという時にはなげき、この子が賢いと嬉んでもなげかれる、この子が愚しく見えても歎かれる。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は道に賢い方法を取った、お前は凡身の息を止めて仏性の息を呼吸し始めた。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたが私をお嫁に貰うには、もっと立派な賢い人にならないじゃ――ねえ、判って」　お蘭に取って、この言葉は一時｜凌ぎの気休めであり、また四郎への励ましに使ったものに過ぎないけれども、四郎は永く忘れなかった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山男もずいぶん賢いもんだな」　亮二は薪をよく見ようとして、一足そっちへ進みましたが、忽ち何かに滑ってころびました。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白熊はなかなか賢いよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "クねずみはあんまり猫の子供らの賢いのがしゃくにさわって、思わず「エヘン。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは狐のこしらへたものを賢いすこしも酔はない人間のお子さんが喰べて下すったといふ事です。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢い人がききますと、ちゃんと見わけがつくのです。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（あはれ土耳古玉のそらのいろ、　　かしこいづれの天なるや）（かしこにあらずこゝならず、　　われらはしかく習ふのみ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とかしこい一言、小声でいうのを忘れなかった。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪かしこい読者は、はじめ五、六行読んで、そっと、結末の一行を覗き読みして、ああ、まずいまずいと大あくび。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
