        "examples": {
          "standard": [
            {
              "text": "このTシャツは、通気性の良いカタン糸で編まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "手編みのマフラーを作るために、柔らかいカタン糸を探している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このブランケット、カタン糸だから肌触りがすごく良いんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夏用のパジャマには、軽くて涼しいカタン糸がよく使われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "藍の地に簡単に白で模様を抜くだけならさしたる事でもないが、葉子は他人のまだしなかった試みを加えようとして、模様の周囲に藍と白とを組み合わせにした小さな笹縁のようなものを浮き上げて編み込んだり、ひどく伸び縮みがして模様が歪形にならないように、目立たないようにカタン糸を編み込んで見たりした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『恐縮です』　博士自らていねいに包みなほして、カタン糸にてゆはいて呉れたのを予はいただくやうに受取つた。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船側に平行して、棒形のローラーが一本つけてあり、舷の内側に、木製の傘形のものが立っていて、その上に、カタン糸の糸巻見たいな恰好をした、直径三寸ばかりのローラーがはめてある。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど学校で紐かざりを習っていたフサエは赤いカタン糸で麻の葉や鼓などを縫い取りながら自分の家にはカタン糸ばかりでなくいろんな色の絹糸が仰山あると、つい自慢をした。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "カタン糸は十二色並んでお菓子のようにつめられた小さい四角い箱が戸棚に並んでいる。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
