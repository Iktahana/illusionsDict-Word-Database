        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "鍵穴に異物が詰まってしまい、鍵が回らなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ドアの鍵穴を覗くと、中の様子が少しだけ見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い家具の鍵穴は、装飾的なデザインが施されていることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、僕は酔ったときの癖で、鍵穴に秘めた最期の手管をもって、ダンス・ホールからの女友達を眺めた。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は黙って立上ると、鍵穴を埋めた冷やかなものに触れた。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――レムブルグ、鍵穴をうめてください。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍵穴の眼玉はたちまちなくなり、犬どもはううとうなってしばらく室の中をくるくる廻っていましたが、また一声「わん。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍵穴の眼玉はたちまちなくなり、犬どもはううとうなつてしばらく室の中をくるくる廻つてゐましたが、また一声「わん。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐそばにある扉の鍵穴を、この子は露台と呼んでいます。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヘエ……」　と云いながら私はわれ知らず鍵穴に眼を近づけて内部をのぞいた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その室で伯父は死んだのです」　という声がうしろから聞こえると同時に私はゾッとして鍵穴から眼を退けた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは真鍮製のかなり頑固な洋式の把手で、鍵穴の附いた分厚い真鍮板が裏表からガッチリと止めてある。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "春夫さんはその扉の鍵穴にそっと眼をつけて見ましたが、思わず声を立てるところでした。",
              "citation": {
                "source": "クチマネ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫がどこから這入ってくるのかを見定めるため、扉の蔭にかくれていて、終日鍵穴から覗いてみようと考えた。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから扉を閉め、椅子を鍵穴のところに持って行って、一秒の間も油断なく、室内を熱心に覗いていた。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして再度鍵穴から覗いた時、そこにはもはや、ちゃんといつもの黒猫が坐っていた。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すぼけた小鮹が、扉の鍵穴に、指で踊った。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　で、口を手つだわせて、手さきで扱いて、懐紙を、蚕を引出すように数を殖すと、九つのあたまが揃って、黒い扉の鍵穴へ、手足がもじゃ、もじゃ、と動く。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」こう言って、ポケットから例の鍵を出して、戸口の鍵穴へはめて見ますと、ちょうどぴったり合って、戸がすらりと開きました。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお部屋の鍵穴にこの金の鍵がはまるのだが、あすこだけは、けつして開けてはいけないよ。",
              "citation": {
                "source": "星の女",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どろぼうの手下は、そつと戸の鍵穴からのぞいて見ますと、イドリスは、そのくるみを、かちんとたゝきわつて、こちらの鍵穴の方を見つめながら、「四十の一つだ。",
              "citation": {
                "source": "ダマスカスの賢者",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして頭に向つて、「わたしが鍵穴からのぞいてゐますと、イドリスは私の方を見て、四十の一つだと言ひました。",
              "citation": {
                "source": "ダマスカスの賢者",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二人が、やはり鍵穴からのぞいてゐますと、イドリスはおかみさんに、「そのくるみを一つよこせ。",
              "citation": {
                "source": "ダマスカスの賢者",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言ひ／＼鍵穴の方を見ました。",
              "citation": {
                "source": "ダマスカスの賢者",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、我が友よ、こいつが鍵穴に合うかどうか確かめに行こう。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "拡大鏡なしでもわかるでしょう、この鍵穴のなかの突起にひっかき傷があるので、ここに力を込めたのです。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "子どもの好奇心からぼくは鍵穴からのぞき込みましたが、見えるのはただ古い旅行鞄や、何か束ねた、そんなところにありそうなものばかりで。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘が失踪する数日前、彼の留守中に、彼の事務所を訪ねた一人の男が、扉の鍵穴に一輪の薔薇が※してあって、手近にかかっている一枚の石板に「マリー」という名前が書いてあるのを見たのである。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで　ナトキンは　かぎあなから　なかを　のぞいて　またしても　うたいます。",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            },
            {
              "text": "諭吉は、くぎをもってきて、そのさきをまげて、かぎあなにさしこんで、あっちにまわしてみたり、こっちにまわしてみたり、いろいろとくふうをこらしました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポケット小僧はドアの前にしゃがんでかぎあなから、のぞいて見ました。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かぎあなに目をあてますと、中に電灯がついているので、部屋の一部がよく見えます。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人の姿は、かぎあなからは見えません。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
