[
  {
    "uuid": "c2d695ae-d4bc-58a9-8ecb-3d98f0f99db5",
    "entry": "寒中",
    "reading": {
      "primary": "かんちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
