        "examples": {
          "standard": [
            {
              "text": "「糊付けされた手紙を破かないように、紙切りナイフを隙間に差し込んだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「レトロなデザインの紙切りナイフは、実用性だけでなくインテリアとしても優秀だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「海外のお土産で買った紙切りナイフは、刃が厚くて少し使いにくい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "土人の売りに来たものは絵はがき、首飾り、エジプト模様の織物、ジェルサレムの花を押したアルバム、橄欖樹で作った紙切りナイフなど。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオンの首のついた紙切りナイフが現れてきた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は日に一度、薄暗らい秘密の部屋へもぐりこんで、トラムプの匂ひをかぎ、ナポレオンの首のついた紙切りナイフをもてあそび、そしてあの重たい本をくりひろげて、決闘の絵をみるのであつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイヌは自分等の順番になると、大きな漆塗の杯に、酒をなみなみとつぎ、彫刻した紙切りナイフに似た、長い、薄い木片を杯の上にのせ、腰を下してから、いろいろな動作をつづいて行った。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
