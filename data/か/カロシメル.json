        "examples": {
          "standard": [
            {
              "text": "「人を軽しめるような言い方はやめなさい」祖母は、店員に対して横柄な態度を取る孫を厳しく窘めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自分の才能を過信するあまり、周囲の助言を軽しめて聞き流していたことが、今回の大きな失敗の原因だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "どんなに小さな仕事であっても、それを軽しめることなく真摯に向き合う姿勢こそが、プロとしての誇りだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "城地を求めて家格をひきさげるとは、そもそも、いかなる思い付……酒井の家風をご存じなら、権現さまとのお約束にも悖り、藩祖のお名を軽しめるがごとき愚かな所替は望まれぬはず。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人間の栄耀をかろしめるほどに深く思い入ったものが、――大臣の娘としての便宜と、美しい女としての特権とを捨離して顧みなかったものが、――それほど単純な心持ちでいたというのはおかしい。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
