          "literary": [
            {
              "text": "此日寒の入りなれど暖なり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大寒の入りのような厳しい寒さ、風も烈しい。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の住んでいないはずの、宗源寺の山門から時々怪火が洩れるとか、人の呻き声が聞えるという、頻々たる投書に基いて、地元｜柏野警察署が刑事の一群を踏み込ませたのは、本年の一月二十一日、朝から大雪が降った大寒の入りの当夜であった。",
              "citation": {
                "source": "仁王門",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "関西では寒の入りに油ものを食べぬと凍えるというだけだが、東北は一般にこの日を油しめといって、始めて種油を搾らせ、それを使っていろいろの食物をこしらえる。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
