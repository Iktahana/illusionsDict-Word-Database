        "examples": {
          "standard": [
            {
              "text": "幕末の港に、黒い煙を吐きながら巨大な火輪船が入港してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父は古い写真を見せながら、かつてこの川を火輪船が往来していた頃の話をしてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "博物館の展示室には、精巧に作られた外輪式の火輪船の模型が飾られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あそこに見えるのは火輪船じゃないか！」と、当時の人々は未知の乗り物に目を丸くした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "昨日途中で見た二艘の火輪船は、港口近くに停泊していた。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "港内測量のため異国の火輪船がはじめて新潟港外に悪魔的な花車な姿を現したとき、この虚無的な港市には未曾有の異変に当るべき武人も武器も持たなかつた。",
              "citation": {
                "source": "母を殺した少年",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本海の激浪を避けることには便利であつたが、屈託のない大河の運ぶ土砂のために港内は浅瀬のひろがるばかりであるし、火輪船の船体は日増しにふとる一方だつた。",
              "citation": {
                "source": "母を殺した少年",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに屈託のない信濃川は土砂を運ぶ一方で、港内は浅瀬のひろがるばかりであるし、火輪船の船体は日増しにふとる一方である。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夷官は必ず曰わん、日本は海国なり、陸道もて奔走すること、数百千里なれば、幣を費すこと甚だ巨し、火輪船を用いるの愈れりと為すに如かざるなりと。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
