        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新弟子の彼に、稽古のしやすい角部屋が与えられた。羨ましいな！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "相撲部屋の角部屋は、一番日当たりが良く、静かな部屋らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ホテルで予約した部屋が、ちょうど角部屋でラッキーだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「角部屋だから、夏は涼しくて冬は暖かいんだよ」と、先輩が教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "伸太郎　お前、とも角部屋へ戻っていたらどうだ。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブレイクの書斎は南西の大きな角部屋で、南の窓から前庭を見下ろせた。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて邸宅が見え、真っ暗だが、明かりが玄関と、角部屋の窓三枚だけ点いており、後者はビリヤード室らしい。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーシは玄関に行かず、明かりの点いた角部屋の方へ行って、窓をそっとたたいた。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
