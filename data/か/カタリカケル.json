[
  {
    "uuid": "a7ef41f4-9490-53ba-856b-8f09ac92292f",
    "entry": "語りかける",
    "reading": {
      "primary": "かたりかける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段"
