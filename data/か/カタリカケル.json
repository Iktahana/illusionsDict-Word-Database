    "definitions": [
      {
        "index": 1,
        "gloss": "to make a speech",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は壇上から熱く聴衆に語りかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私は迷っている子犬に優しく語りかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "小説の主人公は、読者に直接語りかけるような文体で書かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」ホームズがいつものようにうち解けた調子で語りかける。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫々の読者が夫々に生きて来た人生の季節の、どんな朝夕の心にこの一冊は語りかけるものをもっているだろうか。",
              "citation": {
                "source": "あとがき（『朝の風』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会にあって文学が政治とともに経済の上部構造であるにしても、芸術のように旺盛な人間の創造的表現が、人々の心に訴え、語りかける以上、それがまた立ちかえって政治に影響しないということはありえないことである。",
              "citation": {
                "source": "作家の経験",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私が彼に語りかけると、線香の煙の中から写真の麻吉が微笑んだように思われた。",
              "citation": {
                "source": "男子の本懐",
                "author": "A WISH FULFILLED",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌から視線を起こさない客人にアルブレヒトがそう語りかけると、アリソンは「じゃあ、メモリーのサイズに合わせた本当にちっぽけなベーシックってのはどうだい」と応えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、海外同胞へ「故國のたより」をラヂオで語りかける機會をもつてゐたので、この平和な光景を、早速に傳へたのだつた。",
              "citation": {
                "source": "東京に生れて",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そういう特種の社会哲学を、誰が誰に語っているのかと思えば、聴手には後に耳のないわたしへで、語りかけるのは福沢氏だった。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい戯曲作家は前述のやうな「対話精神」の上に立つことによつて、この複雑多様な観衆にも語りかけることができる。",
              "citation": {
                "source": "新劇の黎明",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでは一つ一つの樹木が私に向かって「神聖だ、神聖だ」と語りかけるようではないか？",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "少将は堪えられなくなって土の上に膝をつくと、まるで成親が傍らにいるでもするかの様に語りかけるのであった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "真っ赤な夕焼けの空のかなたに、あるいは灰色に霧がかった朝もやのかなたにそびえる大聖堂の尖塔がネロに語りかけるのは、これとは少し違った夢でした。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかでも溌剌と動いてやまぬのは、底知れぬ愛嬌をたたえた二つの眼で、こちらへ眼差をかえすごとに、しきりに大炊介に語りかけるのだが、なにを言おうというのか、大炊介にはついぞわからずにしまった。",
              "citation": {
                "source": "うすゆき抄",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし宵もまたこの上なくこころよかった――遊園の草木が芳香をはき、空の星屑がいつもの輪舞をおどり、そしてやみに包まれた海のつぶやきが、かすかに押しのぼりながら、たましいに語りかける時には。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手の賢者ぶった連中は、魂が魂に語りかけるのを見るといつでも、『人間に成し遂げ得る至聖の霊的交感は器質的病変の結果である』などと信じさせたがります！",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はまえもって、われわれに語りかける以前に何かの理由でアメリカ政府当局、または、南鮮政府の有罪の事実を知っているか、または強く疑っていたらしく思われる。",
              "citation": {
                "source": "清水幾太郎さんへの手紙",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなテーマが、どのように読者の生きた共感に語りかけるか、そこに文学がある。",
              "citation": {
                "source": "戦争はわたしたちからすべてを奪う",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の声を自分の声として、自分の耳に聞くと云うことは、沈黙の内で、気持と紙と語りかける相手とだけで、差し向いな習慣のついている者には、一つの苦痛に近い感じです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとテレビの画面には白い背景の中に太いゴシック体の赤い文字で『今僕は君に語りかける』と書かれたテロップが浮かび上がる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＴＶ―３６０の画面が乱れ、斜めにたくさんの縞模様ができてしまったが、それでもどうにか『今僕は君に語りかける』の文字がうっすらと浮かび上がる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今僕は君に語りかける」隼人は言った。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今僕は君に語りかける。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "斜めの縞模様が画面の右下から左上へ連続して流れ、白地に赤のゴシック体で『今僕は君に語りかける』のテロップがかろうじて見える。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝美がチャンネルを回してみるように言うのでそのとおりに空チャンネルを除く選局ボタンを一つずつ押してみると、まるでオリンピック中継のときのようにどの局の画面も全く同じ『今僕は君に語りかける』をやっている。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか近いうちに、僕は必ず君にもう一度語りかけるだろう。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＲＵＮのファンクション・キーを入力するとＴＶ―３６０に『今僕は君に語りかける』のテロップが鮮やかにうつる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今僕は君に語りかける。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は今君に語りかける。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は今君に語りかける。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
