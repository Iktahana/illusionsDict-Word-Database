      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "going off duty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夜勤の警備員が下番する際、日勤の警備員に引き継ぎを丁寧に行っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "終業時刻を過ぎても仕事が終わらず、なかなか下番できない日が続いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日の当番は重労働だったから、下番したらまず熱い風呂に入りたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「お先に下番します！」彼は同僚に声をかけ、颯爽と職場を後にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "扉の中からは何の返事も聞こえず、却て廊下番の兵隊共に引き立てられて、王宮の御門から逐い出されてしまいました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやくかばんへ入れたまえ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相場師か請負師とでもいったような男が二人、云い合わせたように同じ服装をして、同じ折かばんを膝の上に立てたり倒したりしながら大きな声で話していた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）若いかばんを持って鉄槌をさげた学生だった。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、そのとき、入口の戸をガラガラと乱暴にあけて、茶色のジャケツをきた少年が手さげかばんを持ってはいってきました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "はがきをそっと学校のかばんにしまって、うちじゅうとんだりはねたりしました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙はそれを聞くと、むっくり起きあがってあぐらをかいて、かばんのやうな大きな口を一ぱいにあけて笑ひました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くかばんへ入れ給へ。",
              "citation": {
                "source": "いてふの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙はそれを聞くと、むっくり起きあがってあぐらをかいて、かばんのような大きな口を一ぱいにあけて笑いました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と高く叫ぶ声がして、それからまるで大きなからすのように、嘉助がかばんをかかえてわらって運動場へかけて来ました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に客は取り散らしてあった書類を丁寧に取りそろえて、大きな手かばんに納めた。",
              "citation": {
                "source": "疲労",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の手かばんの中から白ばらの造花が一束出て来た。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝その乳をしぼってつめたいパンをひたしてたべ、それから黒い革のかばんへすこしの書類や雑誌を入れ、靴もきれいにみがき、並木のポプラの影法師を大股にわたって市の役所へ出て行くのでした。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もひとりの子ももう半分泣きかけていましたが、それでもむりやり眼をりんと張ってそっちの方をにらめていましたら、ちょうどそのとき川上から「ちゃうはあぶどり、ちゃうはあぶどり」と高く叫ぶ声がしてそれからいなずまのように嘉助が、かばんをかかえてわらって運動場へかけて来ました。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "耕一の方から来ている子供では一年生の生徒が二人ありましたけれどもそれはもう午前中に帰ってしまっていましたし耕一はかばんと傘を持ってひとりみちを川上の方へ帰って行きました。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その為め取り出すときに一枚切手が剥げて居て函の中に落ちてあり、も一枚はかばんへうつすとき剥げた。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は本の入ったかばんの上に座るのは一寸困りましたけれどもどうしてもそのお話を聞きたかったのでとうとうその通りしました。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はがきをそつと学校のかばんにしまつて、うちぢゆうとんだりはねたりしました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛糸の襟巻と、厚いシャツ一枚は、かばんに容れて持って来ました。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは洋服を着て皮のかばんを持ったどこかのおじさんであった。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほらふきの兵太郎君は着物だったので、まずかばんをはずして、しりまくりし、パンツをぬいだ。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三男　　ぼくのかばんのお弁当入れるところにね、もうひとつ貝があるから持ってきて。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十三年の初秋、思ひをあらたにする覚悟で、私は、かばんひとつさげて旅に出た。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、少し早く起きて食事を濟ませ、義雄は旅かばんを持つてそこを出た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁がはで、おもちやの學校かばんを肩にさげた知春と出くわしたが、この子はびツくり顫へあがつた樣子をして、伏し目に下を向いた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になると、旅かばんをならべて戸に寄せかけました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもなかでひとり、しんせつな友だちがいて、ふるいかばんをひとつくれました。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            },
            {
              "text": "かばんのうえには、「これになにかおつめなさい。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、あいにくなにもつめるものがないので、むすこはじぶんがそのかばんのなかにはいっていました。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、これが、とんだとぼけたかばんでした。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
