[
  {
    "uuid": "a4d61da8-cf0f-5201-8b44-1145245d539c",
    "entry": "下番",
    "reading": {
      "primary": "かばん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
