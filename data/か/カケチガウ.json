  {
    "uuid": "36cc9c8c-3984-59b8-93c1-8c7aa7ef0d62",
    "entry": "掛け違う",
    "reading": {
      "primary": "かけちがう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-他動詞"
