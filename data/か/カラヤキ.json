          "standard": [
            {
              "text": "タルト生地は、フィリングを入れる前に一度空焼きしておくとサクサクに仕上がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "チーズケーキの土台を作るのに、ビスケットを砕いてバターと混ぜ、型に敷いて空焼きした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "パイ生地を空焼きする際は、重石を乗せて形が崩れないように注意しましょう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
