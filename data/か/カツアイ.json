    "definitions": [
      {
        "index": 1,
        "gloss": "thirst",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は知識への飽くなき渇愛を抱いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "富に対する渇愛が、彼を不正な行為へと駆り立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "名声への渇愛は、しばしば人を孤独にする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "二一六　渇愛より憂を生じ、渇愛より畏を生ず、渇愛を離れたる人に憂なし、何の處にか畏あらん。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四二　渇愛に驅使せらるゝ人は兎の※に係つて走るが如し、結と著とに縛せられて數しば長時の苦を受く。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四三　渇愛に驅使せらるゝ人は兎の※に係つて走るが如し、故に比丘は己の離染を求めて渇愛を除遣せよ。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            },
            {
              "text": "戒―四清淨戒（別解脱律儀、身と語との不善を作さざるを誓ふこと、根律儀、感覺を制御すること、正命清淨律儀、生活法を節制すること、依縁律儀、生活需要品を節制すること）欲―渇愛。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
