[
  {
    "uuid": "3647613a-bd8c-58ce-950d-db0d989624ec",
    "entry": "借りパチ",
    "reading": {
      "primary": "かりパチ",
      "alternatives": [
        "かりぱち",
        "カリパチ"
      ],
      "is_heteronym": true
    },
