    },
    "definitions": [
      {
        "index": 1,
        "gloss": "borrowing something without returning it",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼、またあの漫画を借りパチしたらしいよ。もう貸さない方がいいんじゃない？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "オフィスにある共有のペン、誰かが借りパチしてそのままになってるな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あれ、このゲームソフト返したはずなのに...まさか借りパチされた？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は人のものを借りパチする癖があるから、あまり高価なものは貸さない方がいい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "眼ばかりパチパチさせて、心は眠ってるのもあった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "真言宗の坊主の印を結ぶのを極めて疾くするようなので、晩成先生は呆気に取られて眼ばかりパチクリさせていた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「学校の先生なんテ、私は大嫌いサ、ぐずぐずして眼ばかりパチつかしているところは蚊を捕え損なった疣蛙みたようだ」とは曾て自分を罵しった言葉。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "真言宗の坊主の印を結ぶのを極めて疾くするやうなので、晩成先生は呆気に取られて眼ばかりパチクリさせて居た。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも猶だ其根性が失せないから大きな詐偽や賭博の欺瞞をやつて実業家だと仰しやいますヮ……」と滔々と縁日の口上口調で饒舌り立てる大気焔に政治家君も文学者君も呆気に取られて眼ばかりパチクリさせてゐた。",
              "citation": {
                "source": "貧書生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学者を以て大のンきなり大気楽なり大阿呆なりといふ事の当否は兎も角も眼ばかりパチクリさして心は藻脱の売となれる木乃伊文学者は豈に是れ人間の精粋にあらずや。",
              "citation": {
                "source": "為文学者経",
                "author": "三文字屋金平",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三人昇って見るとさすがに、刀だけは持っていたが、ぼんやりした顔をして、目ばかりパチパチさしていた。",
              "citation": {
                "source": "大力物語",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは写真道楽で――といっても、下手の横好きのお仲間なのですが、ともかく道楽となると、東京市内や近郊でばかりパチリパチリやっているのではどうしても満足が出来ないので、忙しい仕事の暇をぬすんで各地方を随分めぐり歩きました。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "棒高跳決勝の時には陽は全く暮れ、明るく照明をうけた底を見下す観衆は西田と大江の名ばかり呼び続け、さて愈々二人が跳ぶ姿勢をとると水を打ったように静かになり、各国へ打つタイプライターの音と大空の上ではじけるオリンピアの焔の音ばかりパチパチとするだけだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっと仰向きに寝たまま、何を考える精もなく、ただ目ばかりパチクリ動かしていた。",
              "citation": {
                "source": "世間師",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて卵から孵化った生物のように、息を詰めて眼ばかりパチパチさして、口の中でオズオズと舌を動かしていた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一寸の間、途方に暮れたような気持になって、眼ばかりパチパチさせていたようであったが、やがて又、フト思い出したように問うた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを無理に口を利こうとすると、歯の根がガタガタ云い出して、すぐに吐きそうになって来るんですもの……仕方がないから丸で唖者みたようになって、眼ばかりパチパチさせていたら、警察の人達もとうとう諦らめてしまって、来なくなったようよ。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾のために一生懸命で、ラドウーラ様をお祈りしていた最中だったらしく、毒気を抜かれたように眼ばかりパチクリさせていた。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼ばかりパチクリ剥いたものである。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座があいた口が塞がらずに、道庵の面ばかりパチクリと見つめている体は、笑止千万です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、眼ばかりパチクリさせた。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姐さんも、お侍えも、ヤに眼ばかりパチクリさせてるじゃアねえか」　と、申しました。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ろ、お前の啖呵に脅えて、眼ばかりパチパチさせてゐるぢやないか」「相濟みません、女一人を夜中に叩き起して、家搜しといはれると、ツイ、かつとしますよ」「そいつは濟まなかつたな、ま、勘辨してくれ、お隣の支配人の孫三郎が、ツイ先刻殺されたんだぜ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鬼女",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう言ふ親分は」　伊三郎は目ばかりパチパチして居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "秋祭の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まて、まて」「彦左、しばらくその白髪首をあずけたぞ」　天魔太郎は、目ばかりパチパチやっている彦左ヱ門をうしろにのこして、夏の夜の闇のなかにすがたをかくしてしまいました。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラスビイユは面喰って目ばかりパチクリパチクリさしている。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦……旦那」と案に相違して、眼ばかりパチクリさせているホセの奴に、「莫迦なことでも何でも法律だから仕方がない」と私は頭ごなしに一喝してしまった。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "途端に、革のジャンパーを着て、飛行家の被るような革の帽子を被って、眼ばかりパチクリさせているその男が、板倉写真師であることに、妙子は心づいたのであった。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、いくら飛走の達人でも、どうして、いつのまにこんなところへきたんだろうと、竹童はじぶんのゆだんをつねって、目ばかりパチパチさせている。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
