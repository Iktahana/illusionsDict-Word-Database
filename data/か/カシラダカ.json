[
  {
    "uuid": "54527409-cfd0-529b-8a9d-afe77f648bf2",
    "entry": "頭高",
    "reading": {
      "primary": "カシラダカ",
      "alternatives": [
        "かしらだか"
      ],
      "is_heteronym": false
    },
    "grammar": {
