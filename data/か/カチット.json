        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ドアがカチッと閉まり、鍵がかかったことを確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は蓋をカチッと押し込み、中身がこぼれないようにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "登山靴のひもをカチッと結び、出発の準備を整えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このネジは緩みやすいから、カチッとしっかり締めておいてね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
