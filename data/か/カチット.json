    "definitions": [
      {
        "index": 1,
        "gloss": "with a click",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "スイッチをカチッと回すと、部屋の照明が明るくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "車のシートベルトがカチッと音を立てて締まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カメラのシャッターがカチッと小気味良い音を響かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいレンズがカチッと本体に装着され、準備万端だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その正面の青じろい時計はかっきり第二時を示しその振子は風もなくなり汽車もうごかずしづかなしづかな野原のなかにカチッカチッと正しく時を刻んで行くのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その正面の青じろい時計はかっきり第二時を示しその振子は風もなくなり汽車もうごかずしずかなしずかな野原のなかにカチッカチッと正しく時を刻んで行くのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その正面の青じろい時計はかっきり第二時を示し、風もなくなり汽車もうごかず、しずかなしずかな野原のなかにその振り子はカチッカチッと正しく時を刻んでいくのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といふ声とステッキのカチッと鳴る音がして誰か二三人はしご段をのぼって来るやうでした。",
              "citation": {
                "source": "黒ぶだう",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかたくさん笑ってやってください」と言うとたん、貝の火は鋭くカチッと鳴って二つに割れました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでマントがギラギラ光り、ガラスの沓がカチッ、カチッとぶっつかって鳴ったようでした。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）またそういって、撃鉄をカチッと行る。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、六畳の部屋へ入れられると、針助はカチッと錠をおろして、出て行った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "木崎のライカがカチッとシャッターの音を立てたのと、そのダンサーの体が崩れるように床の上へ倒れたのと、殆んど同時――というより、むしろ、シャッターの音が防音装置のピストルのかすかな音のように、彼女を倒した――と言ってもいいくらいだった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "カチッと音がしたかと思うと、パッとついた電灯の光の中に、白と黒とのあざやかな棒縞を着た京子が、ニコニコ笑いながら立っていた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、また、彼は掘りにかかつた――土はやはらかで、鋤が楽にとほると、何かカチッと音がした。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "カチカチカチッという硬いものをぶっとばす音だ。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがうしろにカチカチカチッと硬いものをはげしく叩くような音がしたので、うしろをふりかえってみると、さあ何ということであろう。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――東京ビルがカチカチカチッと崩れはじめたのは、それから間もなくのことだった。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、なにを考えたものか突然彼は、ふたたびとってかえすと、障子をガラリと開け、靴のままヅカヅカと、松山の寝床に近づいたが、ポケットから点火器をとりだして、カチッと火をつけると、左手で静かに枕元の方へさしだし、一方の右手を伸ばして夜具の襟をグッと掴むと、ソッと持ちあげてみた。",
              "citation": {
                "source": "麻雀殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に正木博士の言葉が途絶えて、何やらカチッという音がした。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "カチッという音がした。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は鉄扇が右に動き、カチッという音がして、石は右手へ転がり落ちた。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくポーチにたたずんでいましたが、いつまでたっても、なんの音沙汰もないので、留守なのだろうと思って、あきらめて帰りかけると、うしろで、カチッと掛け金がはずれる音がして、二寸ばかりあけた扉の隙間から、小鹿のような臆病そうな黒い大きな眼が、そっとのぞきだしました。",
              "citation": {
                "source": "キャラコさん",
                "author": "月光曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが室のどこかの壁に当ってカチッカチッと音）丁半で行くわね！",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（軍靴のカカトをカチッと鳴らしてから低い声で）一週間前に復員して参りました。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、カチッカチッと音がして、二三度火花を出してから、ライタアに火をつける。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてカチッカチッと小さな音がして、火の光が見える――お蔦が火打石でホクチに火を移しているのである。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カチッという音がして、明かりが点滅した。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "カチッと音がして、仮想機が作動した。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる細部に至るまで正確に――というのも五分もかからないでカチッという音がしたからだ。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "……もう久しく會わないでいて、あの方あんなことになつたけど――お氣の毒なことをしましたねえ」　カチッとした物の言い方で、テイネイなれど、冷たい。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
