    },
    "definitions": [
      {
        "index": 1,
        "gloss": "firmness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "買ってきたアボカドの硬さを確かめると、まだ食べるには早そうだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "グローブの革の硬さを取るため、専用のオイルを塗り込んで揉みほぐす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼はベッドのマットレスの硬さにひどくこだわりを持っており、何度か買い替えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "元子からいろいろの硬さのものが造られるが、元子自身は完全に剛体であると考えなければならない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手桶の冷たい水で曝した蕎麥は杉箸のやうに太いのに、黄蜀葵の特色の硬さと滑らかさとで椀から跳り出し相に成るのであつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵日本の女で別品といふのは、青みがゝつた皮膚の皮下組織が、稍厚くて硬さうに見える。",
              "citation": {
                "source": "魔睡",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弔花」は時代的精神を身をもつて分析してゆくところに、不敵な新しさを啓示されるもので、生硬さの憾みを覚えたが、それをこの場合に欠点として数へるよりも、その意気が追々と不足を補つてゆくものであらうと期待される。",
              "citation": {
                "source": "浪曼的時評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その彫りの硬さが良い出来ではなかつたが、その彫りの硬さや拙さが却つて人間の意志を忖度しない、たゞ立つてゐればいゝだけの置物の境遇にふさはしい、頑固さを表現してゐた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷倉氏はこれらの写実的風潮の中を潜つてきた人である、したがつて作風の上でもその変化は、独特の抵抗力をもつてゐる、計画的な画面の硬さや、陰影の明確さは、何れもその後の象徴的方法の前奏曲的なもので、下仕事として現はれたものと思はれる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "大智氏の作品は、さうした硬さや迫力を窺つたものではない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみは、ベニー・グッドマンを聴いたことがあるか」「いいえ、名前は知っていますけど……」「そうか、そのうち聴かせてあげよう」　寮長は、慶一の硬さに気づいたようだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝の診察によりますと、全体的に見まして、鮫の歯の硬さは、二倍半も強くなりました。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたりの独活の乳色に薄紅をさしたやうな、柔かい肌に見馴れた眼には、山独活は独活といふよりも、どこか虎杖を思はせるやうな青味と、手触りにいくらかの硬さとがあつた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ熟しきらない青い果実のいづれもが持つ、小生意気な手触りの硬さと無愛想な渋面とは、これにも見られなくはなかつたが、そんなものと一緒に、また柚の実特有の高い体臭がぷんぷんと匂つてゐた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも、はっきりは分からぬけれど、筋肉の硬さから判断して、殺害は昨夜の十二時頃に行われたに違いない」　誰に言うともなく、こう言って俊夫君は、死人のシャツのポケットをさぐりました。",
              "citation": {
                "source": "墓地の殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めは鋼鉄管と血管とを直接カットグートと称する糸で結びつけましたが、鋼鉄では融通がききませんから、後には一定の硬さを有するゴム管をその中間に挟むことに致しました。",
              "citation": {
                "source": "人工心臓",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうさにしても引き立てですと、いやにギラギラと光ってけばけばしい感じのするものですが、それも涸れて生々しい硬さが抜けて来ます。",
              "citation": {
                "source": "絹と紙の話と師弟の間柄の話",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹丸はおづ／＼しながら進み寄つて、教へられるまゝに、慄ふ手で、紫色の硬さうな脣へ水を塗つた。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば、その指環の表情の硬さが、この香水の表情をそこなふから。",
              "citation": {
                "source": "「香水の表情」に就いて",
                "author": "――漫談的無駄話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と自分も顏を撫で※して、ごは／＼と凸凹の多い、硬さうな父の顏を覗き込んだ。",
              "citation": {
                "source": "父の婚禮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "海気に焼け切った、横蔵の精悍そのもののような顔――鋭く切れ上がった眥、高く曲がった鼻、硬さを思わせる唇にもかかわらず、その髪は、豊かな大たぶさにも余り、それが解かれるとき、腕に絡んで眠る水精のように思われたのだった。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼は、そのとき泉にしたたる巨竜の血に浴したので、｜菩提樹の葉が落ちた肩一ヶ所のほかは、全身剣をはねかえす｜鋼鉄のような硬さになってしまったのである。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その硬さが急に解れていって、彼女の眼にキラリと紅い光が瞬いた。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木下杢太郎さんの顔友の額のうへに刷毛の硬さもて逆立つ黒髪、その先すこしく渦巻き、中に人差指ほど過ちて絵具の――ブラン・ダルジヤンの附きしかと……また見直せば遠山の襞に雪｜一筋降れるかと。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の小説手法から見れば、メロドラマ風の點が、多少鼻につくし、また當時にあつても、作者の處女作（――嚴密に云へば第二作）的な多少の生硬さが、眼についた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "解説",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて、後者は「味」よりも「力」を、「香」よりも「刺激」を、「光り」よりも「色」を、「弾力」よりも「硬さ」を、「密度」よりも「重さ」を尊重する傾きがあります。",
              "citation": {
                "source": "演劇漫話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと、Farce を笑劇と訳すのは、〔Come'die〕 を喜劇と訳すやうに、甚だ文学的でないやうに思はれるが、これも時代を経るに従つて、訳語の生硬さがなくなるであらう。",
              "citation": {
                "source": "ファルスの近代性",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治以後の文学を通じて、知識層の対話語の生硬さをみるがいい。",
              "citation": {
                "source": "映画のダイアローグについて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあの、結婚当初の盛子といふよりも、すでに十分成熟した、娘らしい硬さのすつかりとれ切つた、眩しさのない代りに何か直接的な女らしさといふやうなものであつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月の末に近く、一日急に冬らしい冷い雨が降つた時あてられて大腸を惡くして淡い赤い色のまじつた粘硬さへ出てゐましたが、尤もそれは二三日養生をして服藥してゐるうちに治癒したやうであつたけれども、まだ何となく便が固まらなかつたのが、こゝへ來てから毎日二三度入浴してゐる間に段々良くなつたやうです。",
              "citation": {
                "source": "初雪",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいへんな熱のあげかたさ。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　老美人は子供のようなはしゃぎかたさえ見せて、喧騒の渦の音が不安な魅力で人々を吸い付けている市の中心の方角へ、しきりに新吉を促し立てた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい死ぬとも、あのかたさまのお名はいいませぬ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
