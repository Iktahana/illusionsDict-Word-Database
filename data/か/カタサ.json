[
  {
    "uuid": "bec60bfe-9bc7-5759-bd62-bf96a433d52b",
    "entry": "硬さ",
    "reading": {
      "primary": "かたさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
