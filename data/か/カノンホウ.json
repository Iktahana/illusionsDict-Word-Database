  {
    "uuid": "0922e399-5bea-5aa3-95e6-7e9e0c19df8c",
    "entry": "カノン法",
    "reading": {
      "primary": "カノンほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
