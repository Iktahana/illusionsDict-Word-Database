        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はどんな状況にも滑脱に対応できる、優れた交渉術を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の滑脱な人柄は、初対面の人ともすぐに打ち解けさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この組織は環境の変化に滑脱な対応ができるため、常に成長を続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この頭の働きの領土の広さと自由な滑脱性とに関して芭蕉と対蹠的の位置にいたのはおそらく凡兆のごとき人であったろう。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と外交官の甥はさすがに円転｜滑脱である。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人がこうも円転滑脱、弁舌さわやかに、自分の立場を明らかにした以上、こっちからそれを崩しにかかることは、たいへんである。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、伊藤八兵衛の智嚢として円転滑脱な才気を存分に振ったにしろ、根が町人よりは長袖を望んだ風流人｜肌で、算盤を持つのが本領でなかったから、維新の変革で油会所を閉じると同時に伊藤と手を分ち、淡島屋をも去って全く新らしい生活に入った。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿岳は奇才縦横円転滑脱で、誰にでもお愛想をいった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤八兵衛に用いられたのはこの円転滑脱な奇才で、油会所の外交役となってから益々練磨された。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、この円転滑脱は天禀でもあったが、長い歳月に段々と練上げたので、ことさらに他人の機嫌を取るためではなかった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "円転滑脱ぶりが余りに傍若無人に過ぎていた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "表面は円転滑脱の八方美人らしく見えて、その実椿岳は容易に人に下るを好まない傲岸不屈の利かん坊であった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」かう思ふと、自分のこれまでに經て來た幾多の戀、信仰、詩人的努力、家庭の迫害、親不孝、妻子を虐待、友人の離散、失戀、懷疑、絶望、破壞、墮落、自殺未遂、戀愛的事業、生の自覺、悲哀苦痛の現實的體得など、それからそれへと變轉滑脱して來た間にも、自分は終始一貫してゐるのを、自分ながら痛切に感じた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く「僧院の秋」の会、曰く「三浦製糸場主」の会、曰く猫の会、曰く杓子の会、方今の文壇会｜甚多しと雖も、未滑脱の妙を極めたる、斯くの如き応酬ありしを聞かず。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊竹呂昇――ほんとにあの女こそ円転滑脱な、というより魅力をもった声の主だ。",
              "citation": {
                "source": "豊竹呂昇",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れ共、平氏が猶其の覆滅を来さざりしは、実に小松内大臣が、円融滑脱なる政治的手腕による所多からずンばあらず。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の堂々たる、又、円転滑脱たる外交ぶりは、ざっと次のような有様だったのである。",
              "citation": {
                "source": "今昔茶話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体の感じはどことなく膃肭獣に似てゐたが、事実この人は円転滑脱の域をとうの昔に通りこして、寧ろ常規を逸しがちの所が常態になつてゐるやうな人で、輸入部の連中からは「間借人」と敬称されて親しまれると同時に、些かうるさがられてもゐた。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "山縣侯は保守的思想を有し、伊藤侯は進歩的思想を有し、山縣侯は謹嚴端實の性格にして、伊藤侯は磊落滑脱の氣質なり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "山県侯は保守的思想を有し、伊藤侯は進歩的思想を有し、山県侯は謹厳端実の性格にして、伊藤侯は磊落滑脱の気質なり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って円転｜滑脱の鈴木君もちょっと狼狽の気味に見える。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "流しと板の間の境にある敷居の上であって、当人はこれから歓言愉色、円転滑脱の世界に逆戻りをしようと云う間際である。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう云へば、大泉は、かういふ場所では、なかなか幅を利かしてゐるらしく、それが、女たち一人一人を相手に、円転滑脱な応酬を試みるあたり、殆どそのための修練をした人間のやうである。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "また円転滑脱で、環境と相手とに従って様子を変えるのが巧みで、もっともらしい様子でよくしゃべり、聞き上手で、人の言うことにすぐ同化した。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "円転滑脱とでもいうのだろうか。",
              "citation": {
                "source": "風",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "ろくろ首の踊りはます／＼宛転滑脱となり、風船玉は川風に煽られつゝ、忽ち蒸汽船の白煙りを潜り抜け、忽ち高く舞い上って待乳山を眼下に見、見物人に媚ぶるが如き痴態を作って、河上の人気を一身に集めて居ます。",
              "citation": {
                "source": "幇間",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "親父は堅人に相違ないが、僕と違って、円転滑脱の才が利かない。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と星野さんは円転滑脱だ。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――寧子はそう思いながら、良人の円転｜滑脱な酒席ぶりを、見ない振りして眺めていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
