    "definitions": [
      {
        "index": 1,
        "gloss": "pelvic girdle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
