        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「うわっ！クライアントの書類にコーヒーをぶちまけちゃった！」彼女は恥ずかしくて顔を覆った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の失敗の知らせはあまりにもひどく、彼は顔を覆って泣いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供は怖いピエロから隠れようと、手で顔を覆った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は顔を隠すためにマスクで顔を覆った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "娘、突然激しく感動したる様子にて両手にて顔を覆う。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗吾郎は、笠で自分の顔を覆うて、渡し舟に乗る。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本は、もう、（突然、花火をやめて、袖で顔を覆う）何もかも、だめなのだわ。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛びくり目玉は……」「あれは普段のぢやよ……」　久良は煙りに咽んで、顔を覆うた。",
              "citation": {
                "source": "木枯の吹くころ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは、ただ想像だけとするならまことに素晴らしいがと……暫く経つうちに半信半疑の色が、セルカークの顔を覆うてきたのだ。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここに居てなまじ悲しい思いをするよりは」などと袖で顔を覆うて挨拶もしないでかけ込んでしまう人達もあった。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は緩慢な動作で、ハナでもかむように、両手で顔を覆うた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十四　ロッテナム美人術",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は両手で顔を覆うて突伏して泣きました。",
              "citation": {
                "source": "魂の喘ぎ",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはあの日着ていたワイシャツの布地です、ああ」夫人は両手で顔を覆うと、「やッぱり！",
              "citation": {
                "source": "恐怖の幻兵団員",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意に驚いた女が、両手で顔を覆う前に私はその輪郭だけをキャッチしたのです。",
              "citation": {
                "source": "法悦クラブ",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は両手で顔を覆うて沈み切ってしまった。",
              "citation": {
                "source": "奇巌城",
                "author": "アルセーヌ・ルパン",
                "note": "青空文庫"
              }
            },
            {
              "text": "井谷を送り出してから、貞之助が二階の部屋へ上って行くと、幸子は臥たまま浴用タオルで顔を覆うて吸入をかけていたが、「井谷さん又縁談を持って来やはったんやて？",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が顔を覆うていた本はベンチの下に落ちていた。",
              "citation": {
                "source": "犬の生活",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラスゴウ部長が片手で顔を覆う仕草は、ぎらつく目をアイダに見られたくないかのようだ。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
