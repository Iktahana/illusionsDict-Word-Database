[
  {
    "uuid": "57d4ee37-6083-5789-98bd-3e06d8c1fa2d",
    "entry": "蟷螂",
    "reading": {
      "primary": "かまきり",
      "alternatives": [
        "とうろう",
        "いもじり",
        "いいぼむしり",
