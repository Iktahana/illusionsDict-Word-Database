    },
    "definitions": [
      {
        "index": 1,
        "gloss": "praying mantis (esp. the narrow-winged mantis, Tenodera angustipennis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭の草むらで、緑色の蟷螂がじっと獲物を待っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、蟷螂を捕まえて観察したのが、昆虫に興味を持つきっかけになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わぁ、大きな蟷螂だ！」と、息子が興奮して指差した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "あっちからも、こっちからも、ばさばさと遁出すわ、二疋ずつの、まるでもって蟷螂が草の中から飛ぶようじゃ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "既にその時もあれじゃ、植木屋の庭へこの藁草履を入れて掻廻わすと、果せるかな、、蟷螂。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何ですって、」「どうだ、、蟷螂、」といいながら、お雪と島野を交る交る、笑顔で※しても豪傑だから睨むがごとし。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（蟷螂や、ちょうらいや、蠅を取って見さいな）――裸で踊っているのを誰だと思って？",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――蕎麦を一つ、茶碗酒を二杯……前後に――それまで蟷螂が蟋蟀に化けて石垣に踞んで、見届けますとね、熟と紙入を出して見ていなすったっけ、急いで勘定して、（もう一杯、）その酒を、茶碗を持ったまま、飲まないで、川岸へ雪を踏みなすった。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それ、十六七とばかり御承知で……肥満って身体が大いから、小按摩一人肩の上で寝た処で、蟷螂が留まったほどにも思わない。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "野人に蟷螂あり、斧を上げて茄子の堅きを打つ、響は里の砧にこそ。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟷螂の子は可愛い、油虫の子には好感が持てない。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、籠をおろしてみると、籠の中の朝顔に三寸位もある蟷螂が止まっていたが、斧も羽根も血だらけになっていた。",
              "citation": {
                "source": "堀切橋の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでお媽さんは、「お前さんは、蟷螂に斬られたんじゃないの」　と云った。",
              "citation": {
                "source": "堀切橋の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "炎天、日盛の電車道には、焦げるような砂を浴びて、蟷螂の斧と言った強いのが普通だのに、これはどうしたものであろう。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "子孫の種を取った後に雌は雄を食ってしまい、それが愛の完成であるあの蟷螂の精のようなものであった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　痩形の、小柄の、巾着切りか刑事見たいな、眼が迫って険しい、青いしゃっ面の、四十前後の、それは鼻っぱしの恐ろしい番頭君が、蟷螂さながらの敷居際の構えで、ヤッと片手の利鎌を振り立てた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この蟷螂少からず神経性だと見える。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵味方の衆寡はあだかも蟷螂の車轍に当る如く、蚊子の鉄牛を咬むが如きものがあります。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと行燈に蟷螂でも留ったとする……眼をぎょろりと、頬被で、血染の斧を。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はてな、懷え入えた筈だつけが」と兼博勞は懷から周圍を探して側へ落ちた小さな紙包を手にして「こうれ、うめえ物見ろえまあ」といつて開けて見ると一｜寸ばかりの蟷螂が斧を擡げてちよろちよろと歩き出した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へゝえ、此ん畜生奴こんでも怒つてらあ」兼博勞はちよいと蟷螂をつゝいて見て獨り興がつて笑つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんだつて俺ら見た、笹つ葉の枝にくつゝいてた處から出たんだ」與吉は蟷螂を弄りながらいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "此山蔭では蛙を「あんご」といふことや、蟷螂を「けんだんぼう」といふのだといふことやである。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　漸く僕が彼の肩先に蟷螂のやうな鉤型の腕をひつかけて、待つて呉れ！",
              "citation": {
                "source": "凩日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "前こゞみにのめり工合の細く骨張つた肩先きを、物を言ふ毎に角度をつけて振り向くと、おこつた蟷螂に似てゐた。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "生死ノ煩悶ヲ天空ニ求ムル如キ低級極マル小乘的信仰ヲ以テ、印度文明ノ密封セラレタル寶庫トシテ漸ク將ニ二十世紀ノ今日ヲ待チテ開カレントスル日本民族ノ大乘的信仰ニ對セントスル如キハ、實ニ龍車ニ向フ蟷螂ノ斧。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟷螂の竜車に刄向うよりもなお愚かしき手向いだてと思われるのに、引きもせずじりじりと、爪先立ちになって、九本の刄を矢来目陣に備えながら、退屈男に押し迫ろうとしましたので、京弥が伺い顔に傍らから言いました。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は唇を噛んで、起きあがらうとするのであるが、上半身ばかりが傷ついた蟷螂のやうに伸びあがつてはのめりするばかりで、身動きすらも出来ないのだ。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は総身を震はせて、傷ついた蟷螂のやうに首ばかりを前へ前へと伸すのだが、稍ともすれば草鞋は霜柱に埋つて吸ひつき、他合もなく腰がふらつくのみだつた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "簷のところで、蟷螂と蜂が争っていることもあった。",
              "citation": {
                "source": "吾亦紅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、窓から入って来た蟷螂が、その枕頭をあたふたと飛び廻った、――大きな緑のふしぎな虫であった。",
              "citation": {
                "source": "吾亦紅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふぐ、きす、かまきり、たつの落とし子などに似た人さえある。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜜蜂やかまきりの雄の運命ともよく似たところがあるのである。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
