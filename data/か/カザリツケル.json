        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "誕生日ケーキを、カラフルなトッピングで可愛らしく飾り付ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しいプロジェクトの開始を祝って、オフィスを風船で飾り付けよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "プレゼントの箱を、リボンとシールで丁寧に飾り付ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "お祭りの準備として、提灯やのれんで町並みを飾り付ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "わづかな資本で始めた店でしたけれど非常に器用なその母親が飾り付けるとお店の商品は生々して造花なんぞまるで生花のやうに上手な照明で見えるのでした。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてすぐにお城の装飾がかりの人たちに、このまどをほかのまどと同じようにかざりつけるように、お言いつけになりました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、なにもかもきれいにかたづけて、金のうつわをならべさせ、船もりっぱにかざりつけるようにさせておいてくださいませ。",
              "citation": {
                "source": "忠義者のヨハネス",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
