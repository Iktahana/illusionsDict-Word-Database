    "definitions": [
      {
        "index": 1,
        "gloss": "estivation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「このカタツムリ、干からびてるの？」「いや、暑い間はこうして夏眠してやり過ごすんだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "砂漠の肺魚は、泥の中で繭を作って数ヶ月間も夏眠を続けることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一部の両生類は、水不足と高温を避けるために地中に潜って夏眠に入る習性を持つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「最近アイツを見かけないな」「夏バテで自宅で夏眠中なんじゃない？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "……秋の人囮して　禽来ぬ山の　いのこづち晩夏眠れねば晩夏夜あけの冷さなど　　草田男　わが家の棟を超える、秋ちかい夜かぜのいちまいが、なにか、息ながい囁きをゆりこぼしながら、ゆつくり、隣の家へと、ふき移る。",
              "citation": {
                "source": "独楽",
                "author": "高祖保",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとどう云うわけかみんなもどっと笑ったのです。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、なんとかみんなと話し合いをつけてみよう」　そのなかで重立っているらしい三、四人を、すこし距れた木のかげへ連れ込んで、半七は小声で注意をあたえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかみんな睡ってゐたのだ。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木なんかみんなザラメを掛けたように霜でぴかぴかしています。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう云ふわけかみんなはほっとしたやうに思ったのです。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いつの間にかみんなはその人のまはりに環になって集って居りました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとどう云ふわけかみんなもどっと笑ったのです。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かま猫は、何とかみんなによく思はれようといろいろ工夫をしましたが、どうもかへつていけませんでした。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、もしかみんな読んだら頭はからっぽになるであろう。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだかみんな耳こすりでもしているようだと思いながら一時間がたちました。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういうわけかみんなしいんとして穴の明くほどわたくしどものことばかり見ています。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒をつくることなんかみんな大将の考えなんですよ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだかみんな変なぐあいですよ。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木なんかみんなザラメを掛けたやうに霜でぴかぴかしてゐます。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは斯うでなければいけないとかこれは斯うなればよろしいとかみんなそんなものは何にもならない。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳田さんは、旅籠のあんまに、加賀の金澤では天狗の話を聞くし、奧州飯野川の町で呼んだのは、期せずして、同氏が研究さるゝ、おかみん、いたこの亭主であつた。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんな伝説なんかみんな迷信ですよ。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに鼓があろうとは思わなかったんです……アハ……アハ……眠り薬の話なんかみんな嘘ですよ。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し先生にはどこかみんなとちがつたところがあるやうな氣がした。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖父さんはきつと、間もなく開けに来てくれるだらうけれど、もしかみんなが栄蔵のことを忘れてしまつて、出してくれなかつたら、どういふことにならう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だで、道のわきに井戸があったら、どんなにかみんながたすかる。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――猫又や可かり可かるで一時間――誰の作つたとも知れない狂句が、時々みんなの口に上つてゐたが、秋が深くなつて行くと共に、先生の姿は何時かみんなの記憶の中に薄れてしまつた。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、孫八の媼は、その秋田辺のいわゆる（おかみん）ではない。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、文法なんかみんな忘れた。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ほんとうの案内者は殺されてから案内する――　しかし、本当に死んでその証を見せたこの言葉は殊にこの案内者だけの言葉であったのか、それとも昔から一般案内者の間に伝わって居た一般案内者のうちの或者が或場合に遭遇する運命を予約したものかみんなには判らなかった。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だかみんなの影が薄いじゃないか。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私に、もっと力があれば、費用なんかみんな出したいんですの。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらかじめ日本でもＰＣの時代がくると教えてもらっているのに、なにかみんな自分で考えたような口ぶりも嫌味だよな」とも思えてきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "多勢でしたらおもしろかろうと思って二軒いっしょにお互いこの稲刈りをしたのだが、なんだかみんなの心がてんでん向き向きのようで、格別おもしろくなかった。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
