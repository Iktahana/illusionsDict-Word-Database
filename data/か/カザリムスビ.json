        "examples": {
          "standard": [
            {
              "text": "プレゼントの箱に、華やかな飾り結びを添えるだけで特別感が増す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、色とりどりの紐で、複雑な飾り結びのブレスレットを作っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "着物の帯に施された飾り結びは、着姿を一層引き立てる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "お守り袋には、魔除けの意味を持つ特殊な飾り結びが施されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そして父がくれた濃い牡丹色のベルベットの小幅のリボンを飾り結びにしてつけた。",
              "citation": {
                "source": "青春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
