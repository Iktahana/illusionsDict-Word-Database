    "definitions": [
      {
        "index": 1,
        "gloss": "house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古い家屋の解体作業が始まり、新しい商業施設が建設される予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地震の影響で多くの家屋が倒壊し、住民は避難を余儀なくされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域には、昔ながらの趣を残す日本家屋が点在している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は古民家を買い取り、自らの手で家屋の修繕とリノベーションを行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし夏の湿気がなく、家屋の構造がちがってる外国人にとって、こうした俳句は全然無意味以上であり、何のために、どうしてどこに「詩」があるのか、それさえ理解できないであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その建築の家屋の上に、雪がちらちら降ってるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣装にすれば色彩の鮮明な、白とか、青とか、水色とかいつたやうなものが好く、建築にすれば、感じの薄暗い田舎風の家より、明るい西洋建築や、軽快な都会風の家屋が好い。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "重兵衛さんの家は維新前にはちゃんとした店をもった商人であったらしいが、自分の近づきになった頃はいわゆる「仲持」すなわち、今の土地家屋売買周旋業と云ったような商売で、口と足とさえ働かしておれば自然に懐中に金の這入って来る種類の職業であったらしい。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間よりも家屋よりもこうした樹の方が年を取らぬものと思われる。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋に籠つて寐轉んで居ると、すぐ近くの階段や廊下を往來する人々の足音が間斷なく聞こえ、それが丁度御會式の太鼓のやうに響き渡り、音ばかりでなく家屋全體が其の色々な固有振動の週期で連續的に振動して居る。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故かと云えば、風のない国の家屋は大抵少しの風にも吹き飛ばされるように出来ているであろうし、冬の用意のない国の人は、雪が降れば凍えるに相違ないからである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる颱風なるものが三十年五十年、すなわち日本家屋の保存期限と同じ程度の年数をへだてて襲来するのだったら結果は同様であろう。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは非常に多数の家屋が倒潰したのだと思った、同時に、これでは東京中が火になるかもしれないと直感された。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森市の家屋とは著しい対照である。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また構造物の模型実験が従来はいわゆる力学的相似にかまわず行われているのに飽き足らず、この点について合理的な模型を作る方法を考案し、その一例としてパラフィンの混合物で二階建日本家屋の模型を作りその振動を験測したりした。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭火から出る炭酸｜瓦斯は熱した空気と一緒に天井へ上り障子の紙を透して外へ出るから日本の家屋ではそう恐ろしい害はない。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私の趣味としては、もつと空氣の明るく近代的で、工場や、煙突やが林立し、一方に生産的市場が活動しつつ、一方に赤瓦の洋風家屋などの散見する情趣、即ち大都會の郊外にみる近代的生活の空氣がすきなのだ。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "麓の低い平地へかけて、無数の建築の家屋が並び、塔や高楼が日に輝やいていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の四辻に写真屋があり、その気象台のような硝子の家屋に、秋の日の青空が侘しげに映っていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "くらい家屋の中に住むまづしい人間のむれをおそれる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄私達が土人街｜印度家屋の油の濃い日本女（ここに住む日本髪の女が世界中で一等醜い女だということは貴方にも直きお分りになるでしょう）以外に恋の体力をあらわさなかったのに、たとえ英国種にしろアダは水際だった、いわば我々日本人にとって彼女は孟買のエンゼルなのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関銃の音が静寂を破って響き渡るたびに人々は黙々として家屋の囲壁のなかに自己を守護するのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の眞晝近く、地上のすべての事物は、人も、樹木も、家屋も、電柱も、また砂にまぎれる小蟻さへも、息を途絶えさすやうな劇しい暑さに疲れ果てて、ぢつと聲をひそめて立つてゐるやうに思はれるその眞晝近く、私は理科大學研究室の窓際の机に向つて、一所懸命に蘭科植物の葉色素研究の爲めに顯微鏡を覗き込んでゐた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――病院の下の木造家屋の中から、休職大佐の娘の腕をとって、五体の大きいメリケン兵が、扉を押しのけて歩きだした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその電気事業のために、蕃人の家屋や耕作地を没収しようとしたのだ。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二重硝子を透して遠くに、対岸の黒河の屋根が重い支那家屋の家なみが、黒く見えた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の家屋が木造を主として発達した第一の理由はもちろん至るところに繁茂した良材の得やすいためであろう、そうして頻繁な地震や台風の襲来に耐えるために平家造りか、せいぜい二階建てが限度となったものであろう。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "原始的にはあるいは南洋に系統を引いていないとも限らないであろうが、しかしたとえそうであっても現時の日本家屋は日本の気候に適合するように進化し、また日本の各地方でそれぞれの気候的特徴に応じて多少ずつは分化した発達をも遂げて来ている。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたら、家屋は、みんな、いやでも完全な耐震耐火構造になるだろうし、危険な設備は一切影をかくすだろうし、そして市民は、いつでも狼狽しないだけの訓練を持続する事が出来るだろう。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし江戸時代には、あの辺はみな武家屋敷で、夜桜どころの話じゃあない、日が落ちると女一人などでは通れないくらいに寂しい所でした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋの家はわたしの家から直徑にして四町ほどしか距れてゐなかつたが、場所は番町で、その頃には江戸時代の形見といふ武家屋敷の古い建物がまだ取拂はれずに殘つてゐて、晴れた日にも何だか陰つたやうな薄暗い町の影を作つてゐた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は二十三四で、どこかの武家屋敷の中間らしく、帯のうしろには木刀をさしていたが、両腕を荒縄で固く縛られて、両足を投げ出して、銀杏の木の根につながれていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "世話のやける抱えなんかおくより自分の体で働いた方がよほど気楽だというんで、いい姐さんが抱えをおかないでやってる人もあるし、桂庵に喰われて一二年で見切りをつけてしまう人もあるわ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾なんかおく身上じゃありませんよ」　お島は腹立しそうに言った。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
