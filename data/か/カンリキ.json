    "definitions": [
      {
        "index": 1,
        "gloss": "hand-operated powered cultivator",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "家庭菜園の畝（うね）を耕すのに、この小型の管理機は本当に便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "年配の農家さんでも、この管理機なら楽に畑作業ができるって言ってたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ジャガイモの植え付け前に、土を柔らかくするために管理機で耕しておこう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "アレンはかねてから、フロッピーディスクドライブの管理機能をベーシックに持たせるように、ゲイツに注文を出していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲイツはこの作業を延ばし延ばしにしてきたが、一九七六年の二月になって、管理機能を持たせたディスクベーシックの開発作業に一気にけりを付けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "カセットテープを供給媒体としてゲームが普及していったあと、少しずつ書きはじめられていた日本語ワードプロセッサーや一部の業務用ソフトは、ドライブの管理機能を付け加えたディスクベーシックによって供給されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ディスクベーシックの貧弱なファイル管理機能では、今後フロッピーディスクが当たり前になり、さらにハードディスクに大量の情報を蓄積して使うようになった段階ではまったく対応しきれなくなる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この三月にＩＢＭがハードディスクを内蔵して発表したＰＣ ＸＴ用に開発されたＤＯＳの２・０では、従来のＣＰ／Ｍ互換の方式とは異なった、機能を大幅に強化したＵＮＩＸ流のファイル管理機構が採用されている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが２・０からは、ＵＮＩＸ流のファイル管理機能が組み込まれ、周辺機器などをコントロールするデバイスドライバーと呼ばれるソフトウエアを組み込んで、容易にシステムを拡張できるようになっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "將來の社會に對する彼らの積極的提案、例へば、都會と農村との對立の廢止、家族制の廢止、私的營利事業の廢止、賃銀勞働の廢止、社會調和の宣傳、國家を變じて單純なる生産管理機關となすこと、すべてこれらの提案は、全く階級對立の消滅に歸着するものである。",
              "citation": {
                "source": "共産黨宣言",
                "author": "カール・マルクス",
                "note": "青空文庫"
              }
            },
            {
              "text": "理論的にも実際的にも絶対主義の立場をとる幾つかの政府は医学評議会や委員会のような医学管理機関を作った。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
