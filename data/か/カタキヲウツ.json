[
  {
    "uuid": "96ec8578-6f75-5853-b5ee-bf19a97a396f",
    "entry": "仇を討つ",
    "reading": {
      "primary": "かたきをうつ",
      "alternatives": [
        "あだをうつ"
      ],
      "is_heteronym": true
    },
    "grammar": {
      "pos": [
        "表現",
        "Godan verb with 'tsu' ending"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to avenge (someone) by striking down their killer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は亡き父の仇を討つために、単身で敵の潜伏している廃工場へと乗り込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「俺が必ず仇を討ってやるからな」と、彼は力尽きた友の亡骸を抱きしめて誓った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長い隠忍自重の末、ついに積年の仇を討つ絶好の機会が、今この手に巡ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その讐仇を討つのに……邪魔に……邪魔になるのは貴方一人……」「……エエッ……さてはおのれ……」「お覚悟ッ……」　という必死の叫びが、絹を裂くように庭先に流れた。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼年時代厳島に詣で、家臣が「君を中国の主になさしめ給え」と祈ったというのを笑って「何故、日本の主にならせ給えとは祈らぬぞ」と云った程の男だから、主君の仇を討つということなどよりも、陶を滅して、我取って代らんという雄志大略の方が強かったのである。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶対に、警部、あなたにはわかるでしょう、その盾は守りきれなかったが、正義の剣の方は、まだ仇を討つためにそこにあるということが。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "お二人が首尾好く本意を遂げられれば好し、万一敵に多勢の悪者でも荷担して、返討にでも逢われれば、一しょに討たれるか、その場を逃れて、二重の仇を討つかの二つより外ない。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし何かこれが犯罪ならば、きつとこの藤枝が仇を討つて見せます。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "可哀相に、その幼児は大きくなつて、父の仇を討つつもりである一家の人々を鏖殺せんとした。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "封建時代の息子なら父の仇を討つのに一生を捧げたかも知れぬが、明治に生れた彼にはそんな気もちはなかつたのだろう。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟の仇を討つ――そういう法は無い筈だ。",
              "citation": {
                "source": "寛永武道鑑",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠知はこの異変を聞いて、もとは自分の一時の疎懶ゆえと後悔したが、もはや追付かず、表向きに顔を出すことが出来ぬ身になり、その後、金平のお金という女と夫婦になり、そのお金の親の仇を討つというのが大団円になっている。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "田宮坊太郎は、幼少の折に父を討たれ、恰も仇を討つ為に此世に生れて来た様な人で、金毘羅の利生によつて仇を討つと、まもなく死んで了つた様である。",
              "citation": {
                "source": "玉手御前の恋",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此方は奉行所、一応吟味の上、　奉行「悪漢無頼の曲者、殊に舅の仇を討つは武士の嗜み、天晴な手柄」　というお誉め言葉がありまして、早速帰宅を許されました。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ようし、わしがきつと仇を討つてやる」　かういふ時には、かういふ言葉が、極く自然に出るものらしい。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その裾を素早く踏み止めた大力無双の甚五衛門は憐れむように声を落とし、「なるほど、女の身であって見れば、命を助かりたい一心で、親の仇を討つ身じゃなどと、この場に臨んで偽りを云うも決して無理とは思われない。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その阿新丸が難なく本間某の邸に忍び込んで、子供ながらも天晴父の仇を討つた孝心に感激した私は、前のと反對に阿新丸の顏は見る度に撫でたものである。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、貴殿が頼朝の人相を見たように、朝敵を平らげ父の仇を討つような男であろうか？",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大變なことでしたね、お孃さん」「姉の仇を討つて下さい、親分」　慰められるとツイ涙聲になつて、平次に取縋りさうにするのは、さすがに小娘氣の失せないお勢ですが、平次がまだ若くもあり、好い男でもあるのに氣が付くと、ハツとした樣子で立ち縮みます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "閉された庭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お關、今お前の父親の仇を討つてやる。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "二人濱路",
                "note": "青空文庫"
              }
            },
            {
              "text": "お萬の仇を討つて下さい」　手代の榮吉はそつと袖を引きました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "雛の別れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へえ、さう言はれると、面目次第もありませんが、この野郎は私に取つては親と弟の仇だつたわけで」　その親の仇を討つた吉之助は小さくなつてをります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女御用聞き",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった十五になったばかりの娘が、姉の仇を討つ気にでもならなければ、そんなことができるわけはありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「申す迄もなく、弟御さんの仇を討つ心算で同じ町内に住んだのでせうね、旦那」　平次はたまり兼ねて口を容れました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "遺書の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「勝は夫婦約束までした嬉し野が燒け死んでから、ひどく佐野喜を怨んで、折があつたら仇を討つてやると、友達中に觸れ廻り、腹卷には何時も匕首を呑んでゐたさうだ」「殺した道具は脇差だぜ」　平次もさすがにムツとした樣子です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "雪の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "たつた十五になつたばかりの娘が、姉の仇を討つ氣にでもならなければ、そんなことができるわけはありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "雪の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿ッ、幽霊が人を殺してたまるもんか」「すると」「お前だから話すが、人に言うな、あれはみんな、お駒の細工さ」「ヘエ――」「お勝手からそっと出て、遠廻りして庭木戸を入って、姉の仇を討つつもりだったんだよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の精",
                "note": "青空文庫"
              }
            },
            {
              "text": "「申すまでもなく、弟御さんの仇を討つ心算で同じ町内に住んだのでしょうね、旦那」　平次はたまり兼ねて口を容れました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "遺書の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、いまにきっと現われますよ、奴はヤンセンの仇を討つために、どこかで僕を狙っているに違いありませんからね」　話している時、書生が入ってきて、「龍介様にお手紙でございます」と手紙を渡した。",
              "citation": {
                "source": "骸骨島の大冒険",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "壮太はぴったり壁に耳をつけて聞くと、「そうだ、Ｃ・Ｃ・Ｄ潜水艦もぶん取ったし、春田龍介という小僧も生捕ったから、いよいよ骸骨島へ引上げて、潜水艦は外国の海軍に売渡し、龍介の小僧はヤンセンの仇を討つために、島の底へ生埋めにしてやるんだ！",
              "citation": {
                "source": "骸骨島の大冒険",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夫の仇を討つていけなかつたでせうか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "五つの壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "）◯往路、車中より神戸の南部の工場地帯が今もなお炎々と燃えつづけているのを見て、「畜生、かたきをうつぞ」と心に叫ばしめた。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
