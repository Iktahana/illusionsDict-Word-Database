          "standard": [
            {
              "text": "バンクーバーで働いている同僚は、カナダ英語特有の少し丸みを帯びたイントネーションで話す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "カナダ英語の辞書を引っ張り出して、アメリカ英語との単語の違いを調べてみよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "イギリス英語とカナダ英語では、『color』と『colour』みたいに、スペルが違う単語がいくつかあるんだよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼が話すカナダ英語は、とても聞き取りやすく、親しみやすい響きがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
