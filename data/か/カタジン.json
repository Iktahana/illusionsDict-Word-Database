[
  {
    "uuid": "2f715a75-b4cf-5e2c-89e6-076c62163916",
    "entry": "堅人",
    "reading": {
      "primary": "かたじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "square",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は堅人だから、融通が利かないところがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの堅人が、まさかそんな冗談を言うとは驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "堅人と言われることも多いが、彼の仕事ぶりは信頼できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そうして災害当時まだ物心のつくか付かぬであった人達が、その今から三十七年後の地方の中堅人士となっているのである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画などは不良少年少女の見るものであるといったような時代放れのした気持が、いわゆる教育家や、特に真面目な中堅人士の間にいくらかでも残っている間は教育映画の時代は廻って来ないであろう。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに長屋中、皆な私を可愛がってくれまして、おとなしい方だよい方だ、珍しい堅人だと褒めてくれるのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "やむなく我は堅人を装わんとす。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村中堅人物の養成と拓士訓練の為に設立せられたもののやうであるが、この本州の北端の原野に、もつたいないくらゐの堂々たる設備である。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのような堅人がどうして麗姫のことを御気に掛けられますかと問わざるを得なかった。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、この青年ぐらい、おとなしい、堅人はめったにありません。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那に於いて、君子というのは、日本に於ける酒も煙草もやらぬ堅人などを指さしていうのと違って、六芸に通じた天才を意味しているらしい。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんなんぞは堅人だから可いけれど、本当にあんな者に係合ひでもしたら大変ですよ」「さう云ふ事が有りますかな」「だつて、私の耳へさへ入る位なのに、お前さんが万更知らない事は無からうと思ひますがね。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかに、あの女の切り下げ髪にふらふらなすって、だんなほどの堅人が目じりをさげたんじゃござんすまいね」「ござんしたらどうするかい」　ところが、右門が意外なことを口走ったものでしたから、伝六がすっかり鼻をつままれてしまいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒平さんは無類の堅人ぢやけに、自分とこが晩作で、ほかの人がすんでしまつたあと一人乾燥に殘つて、ほかの人に手數をかけるのはすまん云うて、少しぐらゐ損をすることなんぞ構はん。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "堅人であることに違ひはないが、同時に、どういふ場合にも、めつたに損をするといふことのない人間のやうに見てゐたからである。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙に紛糾った親類筋をたどってみると、その家とお今の家との、遠縁続きになっていることや、その製糸工場の有望なことや、男が評判の堅人だということなどが、兄の心を根柢から動かしたらしかった。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり昔の堅人とか、水野｜越前守式の人にはそういうところがある。",
              "citation": {
                "source": "ばけものばなし",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、堅人だと云ってからかった。",
              "citation": {
                "source": "鴻ノ巣女房",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お菅ちゃんは相変らず堅人だ……」「唐変木っていうンだろう？",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗ての昭和研究会の中堅人物であり、国民学術協会の実質的幹部であり、岩波書店の最もよき顧問頭脳であり、幾つかの文化科学的辞典の中心執筆者であり、天下の青年知識層を魅了した幾多の書物の著者である。",
              "citation": {
                "source": "三木清を憶う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう小一年あまり出逢うたこともない、あの堅人の露月の声でありました。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれども昔のお武家は御気象が至って堅い、孔子や孟子の口真似をいたして、頻に理窟を並べて居るという、斯ういう堅人が妹に見込まれて、大事な一人娘を預かった。",
              "citation": {
                "source": "根岸お行の松　因果塚の由来",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処に奧木佐十郎と云って年齢六十に成る極く堅人がございます。",
              "citation": {
                "source": "霧陰伊香保湯煙",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "右委員会委員は、地方文化に関係ある官庁及び民間各職域に於て、識見と指導力ある第一線的中堅人物を以てこれに当てること。",
              "citation": {
                "source": "地方文化の新建設",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "堅人の伊兵衛のすることだから間違いはあるまいと、忠相は最初から知って見ぬふりをしているのだった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなかの堅人、これなら当分いっしょにいても、さして間違いはあるまい。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "堅人で通っていた質屋久兵衛の頭へ、万破れることのない奸計が浮んだのは。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "浮世芝居女看板",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾ては淺草で左官をして居た彦兵衞、飮む、打つの道樂が嵩じて、一時は巾着切の仲間にまで身を落しましたが、今から五年前、別れてゐた女房の末期の諫めに、飜然として本心に立ち還り、娘のお富を引取つて、神田で堅人に生れ變つた經緯――平次は何も彼も知つて居たのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "巾着切の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつては浅草で左官をしていた彦兵衛、飲む、打つの道楽が嵩じて、一時は巾着切りの仲間にまで身を落しましたが、今から五年前、別れていた女房の末期の諫めに、翻然として本心に立ち還り、娘のお富を引取って、神田で堅人に生れ変った経緯――平次は何もかも知っていたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "巾着切りの娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれは恐ろしい堅人で、自分のものは鐚一文持つちや居ません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "幽靈の手紙",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、この塾が地域共同社会の理想化に挺身する中堅人物の養成ということにその主目標をおいていた自然の結果だったのである。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "問屋先でも、Ｔ氏の吝嗇は有名だったが、しかし信用のできる堅人、期日を守る勤勉家としては、誰にもみとめられていた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうその点は至って堅人でございますのでな。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
