[
  {
    "uuid": "daae9c2e-5e86-5c71-b150-3b06212c7bca",
    "entry": "輝く",
    "reading": {
      "primary": "かがやく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
