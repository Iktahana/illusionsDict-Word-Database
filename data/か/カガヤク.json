      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to shine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "磨き上げられた床は、照明を反射してピカピカに輝いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夏の夜空には、数えきれないほどの星が輝いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の瞳は、まるで宝石のようにキラキラと輝く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夕日が海面を照らし、あたり一面が黄金色に輝く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてこの侘しい印象は、ネオンサインの輝く今の新宿にも、不思議に依然として殘されて居るのである。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼の理論の上に輝く何かしら神秘的の光環のようなものを想像している人もあるらしい。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を始めて気づいて驚いている私の鼻の先に突き出た楓の小枝の一つ一つの先端には、ルビーやガーネットのように輝く新芽がもうだいぶ芽らしい形をしてふくらんでいた。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸は夕陽にきらきら輝く湖面に浮きつ沈みつ、「あいたたた、あいたたた、ひどいぢやないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう時、下りて見ると、麓の草原は雨の雫で緑がシットリと輝くのと対照して、山の新しい雪が、キラキラと雲母のように光って、雪と雨とを区別する境界線が、山の中腹に引かれている。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "三千の兄弟たちが、あの光り輝く工場の中の部署についている三千の兄弟たち、あの工場以外のどの工場にも、労働者街にも溢れている、全プロレタリアの均しく背負っている苦痛なんだ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし少数のある人々はこの生涯の峠に立って蒼空を仰ぐ、そして無限の天頂に輝く太陽を握もうとして懸崖から逆さまに死の谷に墜落する。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄雲を透した日光が暫く此の靜かな村里を照らして、ダリアやコスモスが光り輝くやうに見えた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに今年は実際に小春の好晴がつづき、その上にこの界隈の銀杏の黄葉が丁度その最大限度の輝きをもって輝く時期に際会したために、その銀杏の黄金色に対比された青空の色が一層美しく見えたのかもしれない。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸善の棚へ黄金色に輝く恐ろしい爆彈を仕掛て來た奇怪な惡漢が私で、もう十分後にはあの丸善が美術の棚を中心として大爆發をするのだつたらどんなに面白いだらう。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、中根は營庭に輝く眞晝の太陽を眩しさうに、相變らず平べつたい、愚鈍な顏を軍曹の方に差し向けながらにやにや笑ひを續けてゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は窓際に凭つて、緑の牧場と、輝く海とを見降しながら縱な空想に耽つた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日は輝く浮世はせわしい。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の夏始めに、涼み台が持ち出されて間もなく、長男が宵のうちに南方の空に輝く大きな赤味がかった星を見付けてあれは何かと聞いた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸善の棚へ黄金色に輝く恐ろしい爆弾を仕掛けて来た奇怪な悪漢が私で、もう十分後にはあの丸善が美術の棚を中心として大爆発をするのだったらどんなにおもしろいだろう。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "友染の切に、白羽二重の裏をかさねて、紫の紐で口を縷つた、衣絵さんが手縫の服紗袋に包んで、園に贈つた、白く輝く小鍋である。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "園が、人を分けて廊下を茶室らしい其処へ通された時、すぐ其の子爵夫人の、束髪に輝く金剛石とゝもに、白き牡丹の如き半※の、目を蔽ふて俯向いて居るのを視た。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南北の流れにては月の出づるところ東岸に迫られて妙ならねど、東西の流れにては月は直に河水の水面よりさし昇るところなれば、見渡す眺めも広※として、浪に砕くる清き光の白銀を流すが如くいと長く曳きてきら／＼と輝くなど、いふにいはれぬ趣きあり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "と家内に一言して、餌桶と網魚籠とを持って、鍔広の大麦藁帽を引冠り、腰に手拭、懐に手帳、素足に薄くなった薩摩下駄、まだ低くならぬ日の光のきらきらする中を、黄金色に輝く稲田を渡る風に吹かれながら、少し熱いとは感じつつも爽かな気分で歩き出した。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、森のはずれに立って、云い合わせたように、遠い寺の塔に輝く最後の閃光を見詰める。",
              "citation": {
                "source": "秋の歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後に、ある日Ｋ君と青山の墓地を散歩しながら、若葉の輝く樹冠の色彩を注意して見ているうちに、この事を思い出して話すと、Ｋ君は次のような話をしてくれた。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学校で教わったナショナルリーダーの「マッチ売りの娘」の幻覚のように、大きなクリスマストリーが、神秘的に光り輝く霧の中に高く浮かみ上がる。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その薄明の中に、きわめて細かい星くずのような点々が燦爛として青白く輝く、輝いたかと思った瞬間にはもう消えてしまっている。",
              "citation": {
                "source": "詩と官能",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の木立ちも墓地から見おろされるふもとの田園もおりから夕暮れの空の光に照らされて、いつも見慣れた景色がかつて見たことのない異様な美しさに輝くような気がした。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る寒い晩なぞ、婆様は私の寝巻をみんなお剥ぎとりになっておしまいになり、婆様御自身も輝くほどお綺麗な御素肌をおむきだし下さって、私を抱いてお寝になりお温めなされてくれたこともございました。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉桜のころで、光り輝く青葉の陰で、どうどうと落ちている滝は、十八歳の私には夢のようであった。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは畑のかなたの萱原に身を横たえ、強く吹く北風を、積み重ねた枯草で避けながら、南の空をめぐる日の微温き光に顔をさらして畑の横の林が風にざわつき煌き輝くのを眺むべきか。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "げにわれは思う、女もし恋の光をその顔に受けて微笑む時は花のごとく輝く天津乙女とも見ゆれど、かの恋の光をその背にして逃げ惑うさまは世にこれほど醜きものあらじと、貴嬢はいかが思いたもうや。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と叔父さんの指す方を見ると、朝日輝く山の端を一匹の鹿が勢いよくむこうへ走ってゆく、その後をよほど後れて二匹の犬、ほえながら追っかけて行く。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "スコルピオン座や蟹座が隣の栗のこずえに輝く。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to light up (with happiness, hope, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夢が叶った彼の顔は、喜びで輝いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい家族を迎え、彼の毎日は希望に輝くものになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "合格発表の掲示板を見て、受験生たちの顔が期待に輝く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "困難を乗り越えた後の達成感で、チーム全員の顔が輝いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
