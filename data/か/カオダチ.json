    "definitions": [
      {
        "index": 1,
        "gloss": "looks",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は彫りの深い顔立ちで、どこかエキゾチックな雰囲気がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃のアルバムを見ると、彼の顔立ちは今とほとんど変わっていない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "赤ちゃんは、父親によく似た可愛らしい顔立ちをしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ただ顔立ちに似気なく厚肉の唇は生の情慾に燃え血を塗ったようだった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "顎や頬が涼しく削げ、整った美しい顔立ちである。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今夜、何か話があるの」　小初の義務的な質問が、小初の顔立ちを引締まらせた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……ね……そうして不良少年らしい顔立ちのいい少年を往来で見付けると、お湯に入れて、頭を苅らして、着物を着せて、ここへ連れて来るのが楽しみで楽しみで仕様がなくなったの……もっとも最初のうちは爪だけ貰うつもりで連れて来たんですけどね。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉は、薄皮の瓜実顔に眉が濃く迫っている美人で、涙っぽい膨れ目は艶ではあるが、どんな笑い顔をも泣き笑いの表情にして、それで平生は無難なまとまった顔立ちでも単純だった。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰どっしゃろ」　と、鼻の低い妓は感に堪えていたが、急に、あ、そや、判ったと膝をたたいて、「――ひょっとしたら、鈴子はんどっせ」　鈴子は「文の家」から出ている十七歳の舞妓で、やがて襟がえをすれば、先斗町をうならせるだろうと言われるくらい、可愛いい顔立ちだった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "上流に育ったらしい気品のある顔立ちだが、どこか濃艶な色っぽさがあり、十代に輝いたであろうこの女の新鮮な美しさが、今三十代になって再び成熟し切った美しさにしたたっているかのようであった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こぢんまり纒まった可愛いい顔立ちで、おまけに色が白かった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あどけない可愛い顔立ちは、十六、七の少女のようだった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔立ちが似ているのだ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "和服の着流しに総しぼりの帯、素足に革の草履――という身なりは、どこか遊び人風めいていたが、存外律義そうな顔立ちで、「腹が空いてるのンか」　と、きいた声は、女のように優しかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉毛は薄いが、顔立ちはこぢんまりと綺麗にまとまつて、半ズボンの下にむきだしにしてゐる足は、女の子のやうに白かつた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝三郎の妻は痩形でどこか影の薄い感じのする顔立ちだが、どちらかといえば陽気好きである。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その端麗な顔立ちが、雨にうっすりと濡れ、街の火に光って一層引締って見える。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま夫人は髪や服装を現代にはしているが、顔立ちは鹿鳴館時代の美人の系統をひくものがあった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "土着の武蔵野の女には元来こういうタイプがあるのか、それともこの夫人だけが特にこういう顔立ちに生れついたのか、かの女は疑いながら、しかし無条件に通俗な標準の眼から見たら、結局こういうのが美人と云えるのではないかと思ったりした。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "デリケートな顔立ちのつくりに似合う浅い頭髪のウェーブ、しなやかな肩に質のこまかな縮緬の着物と羽織を調和させ、細く長めに曳いた眉をやや昂げて嬌然として居るＸ夫人――だが、葉子はＸ夫人のつい先日迄を知って居た。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「奥さんは日本風の顔立ちのおとなしい美人でしょう、妹さんは違いますね。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実私としては白日の下で近来あれ程高貴で美麗な顔立ちを見たことが無いのだ。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみちはいつまでも稚な顔の抜け切らぬ顔立ちの娘であった。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "がっちりした彼女の顔立ちにそれがよく似合った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩せて小柄で色が浅黒く、きりっとした顔立ちでしたが、無口で、あまり笑わず、地味で淋しそうな感じのするひとでした。",
              "citation": {
                "source": "女類",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "逸作のような端正な顔立ちには月光の照りが相応しそうで、実は逸作にはまだそれより現世に接近したひと皮がある。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあまりに完全な立派さが却って悲運を想わせるような顔立ちでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうあんな辛い奉公はさせへんぜ」　種吉は蝶子に言い言いしたが、間もなく所望されるままに女中奉公させた先は、ところもあろうに北新地のお茶屋で、蝶子は長屋の子に似ず、顔立ちがこじんまり整い、色も白く、口入屋はさすがに烱眼だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十三歳だが、十代に見えるくらい、一見無邪気な可愛いい顔立ちで、ほっそりと痩せた横顔の青白さは、まるで胸を病む少女のようにいじらしく、ふと女たちにはやるせなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、貴子がただ女友達と二人きりで乗ったとすれば、章三のその計画も無意味なものになってしまうところだったが、案の定貴子は上品な顔立ちの青年と二人空いた座席へ並んで腰を掛けた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は化粧栄えのする顔立ちで、ホテルの食堂へはいっても人目を惹くだろうが、それにしては身につけているものがお粗末すぎる。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザックセン王宮の女官はみにくしという世の噂むなしからず、いずれも顔立ちよからぬに、人の世の春さえはや過ぎたるが多く、なかにはおい皺みて肋一つ一つに数うべき胸を、式なればえも隠さで出だしたるなどを、額越しにうち見るほどに、心待ちせしその人は来ずして、一行はや果てなんとす。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "身なりはもちろん粗末であったが、その顔立ちといい姿といい、この毛皮売の老人の道連れにはなにぶん不似合いに見えたので、三人の眼は一度にかれの上にそそがれた。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
