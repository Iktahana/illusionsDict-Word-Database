        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "転んでしまい、膝に軽いかすり傷ができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "自転車で壁にぶつかったが、幸いかすり傷で済んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "このくらいのかすり傷なら、消毒して放っておけば治るだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
