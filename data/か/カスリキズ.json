    "definitions": [
      {
        "index": 1,
        "gloss": "scratch",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「痛いよ〜！」と子供が泣き出したので見たら、膝に小さなかすり傷ができていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "バラのトゲで腕にできたのは、血も出ないようなかすり傷だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「大丈夫、これくらいのかすり傷ならすぐに治るさ。」と彼は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "へんなことには兵十の頬ぺたに、かすり傷がついています。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かすり傷ぐらい受けたて、その血が流れとるのを自分は知らんのやし、他人も亦それが見えんのも尤もや。",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、エビルはかすり傷だらけの身体に一糸もまとわず、髪の毛を剃られたサムソンの如くに悄然と、前を抑えながら家に戻った。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛人無為一　樹の根に、踝を打ちつけて、青いあざを残したけれど、痛みはその時だけで、手の甲の傷も、ほんのかすり傷だった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お辰は柳吉の方を向いて、蝶子は痲疹厄の他には風邪一つひかしたことはない、また身体のどこ探してもかすり傷一つないはず、それまでに育てる苦労は……言い出して泪の一つも出る始末に、柳吉は耳の痛い気がした。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "倒れるときちょっと頭をうったのは、それに興奮していたせいもあって脆くも意識を失ったのだが、かすり傷ひとつなかったのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大袈裟に倒れたわりにかすり傷ひとつなかったという点で、豹一はますますしょげて、情けない状態になっているのを、多鶴子はかつ安心し、かつおかしいと思った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのいたましい変事の記憶がまだ世人の記憶に新しいのに、今度はまた新しい皇帝が皇后とスイッツルの湖畔をドライブしていたとき、不慮の事故を起こして、そのために若く美しいアストリード皇后陛下はその場で崩御され皇帝も負傷され、ただうしろの座席に乗っかっていた運転手だけが不思議にかすり傷一つ負わなかった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シンプソンは鈍器の杖でストレーカの頭部を殴りつけ、身を守ろうとしたストレーカの小型ナイフではかすり傷ひとつ受けないままで、そして馬はその盗人が秘密の隠し場所へ連れ込んだか、さもなくば男ふたりの争うさなかに逐電したまま今なお荒野をうろついているのやも。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "家来は主人を殺すはおろか、かすり傷ひとつ負わせても死罪、事の次第に因っては獄門にも磔刑にもなる。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は、かすり傷一つ負わなかったのだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、かすり傷を負った豹のような、凄い表情をしながら、二人の後姿を睨んでいた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦茶色の外皮の堅さは、こんな場合にもかすり傷一つ負わさない。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが安心、かすり傷だ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだそのほかに、相手にぶたれたのか、あるいは自分で打ったのか、彼は左の額に石で打ったようなかすり傷をうけていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は、かすり傷一つ負はなかつたのだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、かすり傷を負つた豹のやうな、凄い表情をしながら、二人の後姿を睨んでゐた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポストまで出かける、Ｗ店で一杯、Ｎ店で一杯、またＦ店で一杯、方角が解らなくなる、道徳を失ふ、二度誰何された、何しろ防空警戒中だ、満身の瘡痍――たゞしかすり傷だけ、――辛うじて帰庵、前後不覚で寝てしまつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんのかすり傷だが、血が流れ出て、襯衣の前を真紅に染めた儘、刻を移さず郡警司フランク・グリイン氏のまえへ引き出された。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "おちぶれた集團のなかの馬鹿な爭論に卷きこまれて、かすり傷一つこしらへるのも怖ろしくてたまらないのだ。",
              "citation": {
                "source": "雨",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんのかすり傷ですもの。",
              "citation": {
                "source": "九月一日",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦闘旗の色はいよいよ紅く、味方はかすり傷一つしていないのだ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、航空母艦『オリオン』だけは、かすり傷一つ負っていない。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の顔は泥と血で汚れ、かすり傷が一面についてゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、しらべてみると幸いにかすり傷ばかりでありました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "傷は、かすり傷ですよゥ！",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、けがはほんのかすり傷でしたので、子ジカは朝になると、もうなんともなくなりました。",
              "citation": {
                "source": "にいさんと妹",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "一回、二回ともレーヤーチーズがかすり傷を受け、第三回目、いよいよはげしい接戦になり、ハムレットがだんだん上手へさがる。",
              "citation": {
                "source": "ハムレット",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "子はかすり傷ひとつ負わず救い出されたのだった。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを吸ふにも、もし口に何のかすりきずもなければ、害はないのだ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
