[
  {
    "uuid": "f1ad8f4a-a206-593a-81d8-491a3b8a53bb",
    "entry": "感覚的",
    "reading": {
      "primary": "かんかくてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
