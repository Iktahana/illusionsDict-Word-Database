        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "客船が桟橋を離れる瞬間、色とりどりの紙テープが宙を舞い、別れを惜しむ声が響いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "優勝パレードの沿道から投げられた紙テープが、アスファルトをカラフルに染めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "学芸会の舞台セットを作るために、100円ショップで赤と青の紙テープを買ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ほら、そんなに強く引っ張ったら紙テープがちぎれちゃうよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "丁度紙テープを投げるように西から東へ延びて行くのであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "発信機の方はピアノの鍵盤のようなものにアルファベットが書いてあって、それで通信文をたたいて行くと受信機の方ではタイプライターが働いて紙テープの上にその文句をそっくりそのままに印刷して行く仕掛けである。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アップル※が発表され、数多くのホラ吹きどもが講演者となってパーソナルコンピューターの未来にかける夢を思うままに語り、十代も半ばの小僧が紙テープに記録したソフトウエアを売り、山と詰まれた広告ビラがバタバタとはけていく先駆者達の祭りで、古川は完全に熱に浮かされた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "足にながい赤い紙テープを目じるしにして、電気鳩をおいかけてゆきましたが、ざんねんにも見うしなってしまいました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき鳩の足には、長い赤い紙テープのほかに、小さなガラスびんがさかさまにつりさがっていました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い紙テープをながくひきながら、ぐんぐんとんでいって、やがて、すがたがみえなくなりました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は無器用に水色の紙テープで引くくった桃色と赤のスウィートピーの小さい花束を大事に持って帰って机の上にさした。",
              "citation": {
                "source": "粗末な花束",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "◎先泣いて居た女の子　◎人ごみの中の自分の心持　◎Ａの心持　◎こい水色の紙テープで不器用にむすんだ束を二つ買う。",
              "citation": {
                "source": "一九二三年夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "キーボード、プリンター、紙テープパンチ、紙テープリーダーを一体にまとめたＡＳＲ―33は、本来の用途以外にも、比較的小型のコンピューターシステムの入出力機器として使われていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "文書を送る際はまず、テレタイプに組み込まれた電動タイプから入力した文字をコードに変えて、紙テープに打ち出してやる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "送られてきた信号は相手方でいったん紙テープに打ち出され、これを読みとると逆に電動タイプライターが文字に再現してくれる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ八週間の集中した作業の末、一九七五年の二月下旬に、アレンは仕上がったベーシックを収めた紙テープを持ってアルバカーキーへ飛んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙テープをテレタイプに読ませて翻訳プログラムを送り込むと、アルテアからの反応が返ってきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒ったユーザーの一人が会場からベーシックの入った紙テープを持ち去り、これがつぎつぎとコピーされてユーザー仲間のあいだで急速に広まった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "プログラムやデータを保存しようとすれば、これまではアルテアにテレタイプをつなぎ、紙テープに打ち出すしかなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが紙テープでは、素早く情報を読み書きすることはできなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙テープで記録を取るしかないテレタイプが唯一の入出力装置だったこうしたシステムの使い勝手は、ミニコンピューターにははるかに及ばなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙テープを打ち出すタイプライターとブラウン管ディスプレイを備えたＰＤＰ―１の本体は、キャビネット三台分ときわめて小さく仕上がっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソフトウエア絡みはもっと多種多様で、中には一五、六歳としか思えない子供が紙テープを広げていたりする。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてこのプログラムを収めた紙テープがＤＥＣのミニコンピューターを納入した大学や企業に流れては、各所にゲーム中毒患者を発生させた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした背景があった中で、ＭＩＴＳの主催したデモンストレーションの会場から漏れ出したベーシックの紙テープが、大量にコピーされてホビイストのあいだに広まった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでＣＣＣは、書き手が紙テープに収めてプログラムを登録してくれれば、注文に応じてきわめて安い値段でコピーして郵送すると『ＤＤＪ』に告知した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以外にＣＣＣが求めたのは、一オンス（二八・三五グラム）あたり一ドルの紙テープのコピー料と送料だけだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "石田はＣＣＣに問い合わせを入れ、「日本で公開してかまわない」との確認をとったうえで紙テープを取り寄せた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者のリチェン・ワンは８０８０のアセンブラーでタイニーベーシックを書き、紙テープには機械語に変換されたプログラムが収められていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "小野はまず紙テープの機械語のプログラムを手元にあった逆アセンブラーでソースコードに変換し、中身の分析を行った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京電機大学の安田寿明は、「改良パロアルト版の紙テープとソースプログラムのリストを、実費で頒布する作業を自宅で引き受けよう」と申し出た。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本あたり五ドルを送ってくれれば、紙テープに収めた機械語のプログラムとマニュアルを郵送するという広告を『バイト』に出すと、すぐに注文が集まりはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「テープ投げは、出航とともに始まりますので、今しばらくデッキでお待ちください」　フェリーのクルーに紙テープを手渡されながら、首藤は辺りを見渡した。",
              "citation": {
                "source": "湯けむり",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
