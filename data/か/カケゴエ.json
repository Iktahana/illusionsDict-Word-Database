[
  {
    "uuid": "0500772d-09fb-52ad-a91c-f88ac15af16e",
    "entry": "掛け声",
    "reading": {
      "primary": "かけごえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
