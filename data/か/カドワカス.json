    "definitions": [
      {
        "index": 1,
        "gloss": "to kidnap",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "村の祭りの喧騒に紛れて、見知らぬ男が幼い子供を拐かそうとしたという噂が広まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔話の絵本には、美しい娘が山に住む恐ろしい怪物に拐かされる場面が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "悪党たちは商家に押し入って金品を奪っただけでなく、跡取り息子まで拐かして逃走した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "囈　語竊盜金魚強盜喇叭恐喝胡弓賭博ねこ詐欺更紗涜職｜天鵞絨姦淫林檎傷害｜雲雀殺人ちゆりつぷ墮胎陰影騷擾ゆき放火まるめろ誘拐かすてえら。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "囈語竊盜金魚強盜喇叭恐喝胡弓賭博ねこ詐欺更紗涜職｜天鵞絨姦淫林檎傷害｜雲雀殺人ちゆりつぷ墮胎陰影騷擾ゆき放火まるめろ誘拐かすてえら。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡っ引の人達の鑑定では、おそらくお角さんをかどわかす手段であったろうというのです。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「去年の心中一件と、今度の一件と、まるで縁のねえ事か、それとも何かの糸が繋がっているのか、まずそれを考えなけりゃならねえ」「友蔵の奴が又なにかやったかね」「おれもそんな事をかんがえたが、若い娘ならばともかくも、やがて四十に手のとどく女房をかどわかすということもあるめえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は見掛けに因らないと云いますが、この米屋の奴らなぞは頗る上手にごまかしていたと見えます」「金右衛門を斬ったのは、娘をかどわかす為ですか」「こんな奴らですから、慾心も無論に手伝っていたでしょうが、これこそ本当のかたき討ちのつもりなんですよ」「これもかたき討ちですか」と、私はすこし意外に感じた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやらこの辺の若い衆が、別嬪さんをかどわかすのらしい。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よかろう、うんとかどわかすがいい。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誘拐は重罪であるが、主人の子供をかどわかすのは、その罪がいよいよ重い。",
              "citation": {
                "source": "半七捕物帳",
                "author": "河豚太鼓",
                "note": "青空文庫"
              }
            },
            {
              "text": "小夜子サンを手ッとりばやくかどわかすには、セラダの生きているうち、トオサンやぼくらが小夜子サンが身を隠すのを期待しており、つまり彼のかどわかしに嬉々として協力の情熱を惜しまぬ時期に限るようです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の世はそんなものではない」「ですが、住田や玉子をかどわかす荒業ができるぐらいなら、ボクを海へ帰らせるのにペコペコすることはなさそうですよ」「ザコを殺して大罪を犯すのは愚の骨頂だぜ。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "代官の首を斬るというほどの役者ではないが、お蘭さんをかどわかすぐらいのことをやり兼ねない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどの犯罪の目的は、篠崎家の宝石をぬすみだすことと、緑ちゃんという女の子をかどわかすことなんだが、黒い魔物がほうぼうにあらわれて、新聞に書かれたりすれば、わたしは、こんなまっ黒な人種ですよ、ご用心なさいと、まるで相手に警戒させるようなものじゃないか。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お出むかいなんて、ていねいなことばを、使っていますが、むろん、明智探偵をゆうかいする、かどわかすという意味なのです。",
              "citation": {
                "source": "虎の牙",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう、あんたを、かどわかすことができて、じつにゆかいですよ。",
              "citation": {
                "source": "虎の牙",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん、賢二をかどわかすためだ。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "電人Ｍは、きみのおとうさんの秘密を手に入れるために、きみをかどわかすつもりかもしれない。",
              "citation": {
                "source": "電人Ｍ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "於通は、のら息子の三蔵を利用し――三蔵は於通をかどわかすつもりで――この二人が家出したのを、お沢は、あの小野の里のあばら屋で、後で、どんなに悲しんだことだろうか。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
