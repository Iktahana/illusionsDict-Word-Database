          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝の冷たい空気の中で深呼吸をすると、心身に新しい活力を注入できる気がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地域の活力を取り戻そうと、商店街の若手有志が週末の歩行者天国を企画した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "睡眠時間をしっかり確保したおかげで、今日は朝から仕事に対する活力がみなぎっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "会社の業績を立て直すには、ベテランの経験と若手の活力を融合させることが不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "総長にでもなる人にはやはりそれだけの活力があるのかと思われた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隙間なく密生しても活力を失わないという特徴があるために垣根の適当な素材として選ばれたのであろう。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "活力の満ちた、しめっぽい熱帯の空気が鼻のあなから脳を襲う。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう飛びぬけた頭脳を持っていて、そして比較的短い年月の間にこれだけの仕事を仕遂げるだけの活力を持っている人間の、「人」としての生立ちや、日常生活や、環境は多くの人の知りたいと思うところであろう。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけにやはり充実した理窟なしの活力といったようなものが足りなくて淋しい。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカン・レビューにはそういう古典的な意味での音楽などはない代りに、オリンピックのグラウンドや拳闘のリンクに見らるる活力の鼓動と本能の羽搏きのようなものをいくらかでも感ずることが出来るのであった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸上の生活力を一度死に晒し、実際の影響力を鞣してしまい、幻に溶かしている世界だった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "有機系とはなんの交渉もないものが繁殖し始めるとその有機系の調和が破壊され、その活力が阻害され結局死滅する、それと同時にその死滅を促成した反逆者の一群も死滅することは当然である。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがこの動物の活力であり、智慧であり、精霊であり、一切であることを私は信じて疑わないのである。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かしら強い活力で幹から吹き出しているように見えた威勢のよかった葉がきわめてわずかな圧力にも堪えず、わけもなく落ちるのが不思議なようにも思われた。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸びて行く活力だけです。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活力の一形式にすぎない。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは第一自分の経験もないし、また観察すべき材料も手近にないからよくはわからないが、たとえば女のからだのある変化に随伴して起こりがちなヒステリーなどは、鬱積した活力が充分に発現されないために起こる病的現象だとすると、前の仮説の領域から全く離れたものとは思われない。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この望みが、もう全く活力のない私を自分に捨てかねる原因になっている。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分を発展しなくてはやまない活力、これが人生を楽しむ要素である。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じようではあるが「全線」の巻頭に現われるあの平野とその上を静かに流れる雲の影のシーンには、言い知らぬ荒涼の趣があり慰めのない憂愁を含んでいるが、ここでは反対に旺盛な活力の暗示がある。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでもってみると維摩は言葉でもって説明せずにその生命的活力の源を発するのは理屈や説明ではすでに廻り遠い。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角、文化の知識で押し詰められるまでは押し詰め、それから先、越えなくてはならない真理への境を、「信」で飛越して行って、真理を体験に持ち来し、それを生活力にしようというのが仏教の信仰の仕方です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、あとは私たち民族それ自体の持つ逞しき現実の生活力に任せて、自由に発達を遂げさせて行くのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この際、迷いの心ぐらい現実の生活力をくさらせるものはありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "区々たる藩閥の巣窟に閉籠り、自家の功名栄達にのみ汲々たる桂内閣ごときでは、到底、永遠に日本の活力を増進せしめる事は出来ない。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "自信力は希望を生じ、智識を生み、活力となり、発展となる。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "子に親を養育する義務がなく、社会に敬老思想のない外国では、老いて生活力を失った人々が、家庭からも社会からも全く廃人扱いをされてしまう。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の目的が平和にあらうとも、芸術にあらうとも、信仰にあらうとも、知識にあらうとも、それを今批判する余裕はないが、とにかく戦争が手段である以上、人間の目的でない以上、それに成効の実力を付与する軍国主義なるものも亦決して活力評価表の上に於て、決して上位を占むべきものでない事は明かである。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "七つ八つの小池に、ほとんどうっちゃり飼いにされながら、毎年、池の面が散り紅葉で盛り上るように殖えて、種の系続を努めながら、剰った魚でたいして生活力がありそうもない復一親子三人をともかく養って来た駄金魚を、何か実用的な木っ葉か何かのように思っていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という無造作な生活力だろう。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活力の弱さうな好人物で、夜は近所の将棊所へ将棊をさしに行くのを唯一の楽しみにしてゐる。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活力が強い、とでもいうのか、とにかく業の深い人だと思った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は殆ど他人には満足に口もきけないほどの弱い性格で、従って生活力も零に近いと自覚して、幼少より今｜迄すごして来ました。",
              "citation": {
                "source": "わが半生を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
