[
  {
    "uuid": "67eefba8-01b6-5393-bb8d-2ad620fc9047",
    "entry": "仮屋",
    "reading": {
      "primary": "かりや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "temporary residence or shelter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "建設現場の隣に、資材置き場を兼ねた作業員の仮屋が建てられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "台風で家が壊れたため、しばらくの間、近くの公民館を仮屋として避難生活を送った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祭りの期間中だけ、神社の境内に露店のための仮屋が並ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "登山中に突然の雨に見舞われ、朽ちた小屋を仮屋にして夜を明かした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "お二人は蚊屋野にお着きになりますと、ごめいめいに別々の仮屋をお立てになって、その中へおとまりになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでまったくなんのお気もなく、すぐにおうまにめして、大長谷皇子のお仮屋へ出かけておいでになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日切腹候場所は、古橋殿｜取計にて、船岡山の下に仮屋を建て、大徳寺門前より仮屋まで十八町の間、藁筵三千八百枚余を敷き詰め、仮屋の内には畳一枚を敷き、上に白布を覆い有之候由に候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "正保四年｜丁亥十二月｜朔日興津弥五右衛門景吉｜華押　　　　興津才右衛門殿　正保四年十二月二日、興津弥五右衛門景吉は高桐院の墓に詣でて、船岡山の麓に建てられた仮屋に入った。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮屋の周囲には京都の老若男女が堵の如くに集って見物した。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の便宜上、米町川の上流、大笹に地を選んで、とにかく、在家を土蔵ぐるみ、白壁づくりに、仮屋を合せて、女神像をそこへ祭って、可心は一生堂守で身を終る覚悟であった処。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "斑竹山房とは江戸へ移住するとき、本国田野村字｜仮屋の虎斑竹を根こじにして来たからの名である。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日は牛頭天王の祭りとて、大通りには山車小屋をしつらい、御神輿の御仮屋をもしつらいたり。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと離れた仮屋建てのほうに詰めきっていた。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "市街の大半を占めてゐる焼跡には、仮屋建ての鑿の音が急がしく響き合つて、まだ何処となく物の燻る臭気の残つてゐる空気に新らしい木の香が流れてゐた。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、あの頃のまゝの姿で、今や追はれ追はれて、名前も知らなかつた東京のとある郊外の茅屋に、仮屋して佗しい日を送つてゐる。",
              "citation": {
                "source": "環魚洞風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつぞや私が泣き出すと、乳母が私を抱き、祖母さんは団扇で私を扇ぎ、お父さんは太鼓を敲き、お母さんは人形を持ち、家中の者が行列をなして、親見世（今の那覇警察署）の前から大仮屋（もとの県庁）の前を通って町を一周したのを覚えている。",
              "citation": {
                "source": "私の子供時分",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに大仮屋に出勤していた私の叔父で、当時十五になる利口の青年が、相談なしに東京に連れて行かれたので、祖父さんの落胆は一通りではなかったとのことだ、私は彼の盗まれた日、親戚の者が大勢本家に集まって、人が死んだ時のように、声を立てて泣いたのを覚えている。",
              "citation": {
                "source": "私の子供時分",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "御仮屋は新しい平張で、正面に紫の幕、緑の机掛、うしろは白い幕を引廻し、特別席につづいて北向に厩、南が馬場でした。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "御仮屋の前の厩には二百四十頭の牝馬が繋いでありましたが、わけても殿下の亜剌比亜産に配せた三十四頭の牝馬と駒とは人目を引きました。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "源も馬を競馬場の溜へ繋いで置いて、御仮屋の北側へ廻って拝見すると、郡長、郡書記なども「フロック・コォト」の折目正しく、特別席へ来て腰を掛ける。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "十｜輌ばかりの人力車が静粛な群集の中を通って、御仮屋の前まで進みました。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿下は知事の御案内で御仮屋へ召させられ、大佐の物申上る度に微笑を泄させられるのでした。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿下は大佐と馬博士とから「ファラリイス」の駒の批評を聞召され、やがて長靴のまま静々と御仮屋を下りて、親馬と駒とを御覧になる。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼奴を見ると、祖父を思出さずにはおられやせん」　と楽しそうに話しておりますと「ファラリイス」の駒も大概御覧済になりましたので、御仮屋の北側に記念の小松を植えさせられました。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "御仮屋の北にあたる埒の際に、源の家族が見物していたのですが、両親の顔も、叔母の顔も、若い妻の顔すらも、源の目には入りません。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿下は御仮屋の紫の幕のかげに立たせられ、熱心に眺入らせ給うのでした。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "居残る人足は腰を曲めて御仮屋を取片付ける最中。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "取壊さずにある御仮屋も潜み、厩も隠れ、鼻の先の松は遠い影のように沈みました。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "十輌ばかりの人力車が静粛な群集の中を通って、御仮屋の前まで進みました。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "コクトオは気がちがいそうになって日がな一日オピアムばかりやってるそうだし、ヴァレリイは十年間、唖者になった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさ、ラジオのニュウスで聞いた」「あいつ、うまく災難にかかりやがった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が馬鹿な事ばかりやらかして、ちつとも立派な仕事をせぬうちになくなつて、残念でなりません。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が馬鹿な事ばかりやらかして、ちっとも立派な仕事をせぬうちになくなって、残念でなりません。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、わかりやしません。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
