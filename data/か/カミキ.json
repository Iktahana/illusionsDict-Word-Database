[
  {
    "uuid": "c1e9051c-f379-53b9-a1ae-c1a770aeff6a",
    "entry": "上期",
    "reading": {
      "primary": "かみき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
