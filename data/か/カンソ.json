        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "簡素幽邃といふのが、あなたたちの風流の極致だらうぢやないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがすなはち簡素幽邃の美かね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "裕福などころか、転々として居を追はれる両親に附いて、町から村へ、山へ峡谷へと、土方や坑夫の間を、ひどく簡素な生活の間を生ひ育つた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその白い蝋燭が、簡素で明淨な部屋と調和し、いかにも貴重で藝術的なものに見えるのである。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處は修道士の寢室で、廊下の兩側に正しい區劃をなして、簡素な寢臺が置かれてある。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に簡素清冷に御暮しになったとて、三千石ではどうなるものでもない。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉は、その簡素で優雅な行き届いた利休の作法にむしろ呆れ果て、ただただ感嘆を続けつつ、饗応を受けて帰りました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は簡素なふだん着の縫い方をこの婦人に一つ習っただけです。",
              "citation": {
                "source": "智慧に埋れて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして因縁の所生によって簡素な生活を生涯守られるだけの遺産をうけた一処女、身を幸とも不幸とも判断しかねて居るのです。",
              "citation": {
                "source": "智慧に埋れて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓に菫色の日覆を取り付けた簡素な木造の二階家が、丈の高い松の木立ちと一緒に、池の面に姿を映していた。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い天井は、他の室と同じ英国貴族の邸宅に見るような花紋の浮彫りがしてあり、古代ギリシヤ型の簡素な時計が一個、書籍を山積した大デスクの上壁に、ボタンで留めたようにペッタリと掛っている。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "是非も無い、簡素な晩食は平常の通りに済まされたが、主人の様子は平常の通りでは無かった。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡素だ、飛び飛びの石、萱の屋に衝き上げ門、ここは西山荘。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことや簡素は自然の徳、われ敢て強ひて衒はずとも、おのづから身に驕る宝なければ、常住水に魚鱗の苔を洗ひ、野に出で丘にのぼりて、時に鮮菜の土をはたく。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "新らしき文化住宅地緑ヶ丘の突端にある此の馬込の新居は、明朗にして簡素、月・霧・燈・火の夜景は亦九十九谷の名にそむかず、少くとも近代詩趣の一年なり。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡素で贅が無く、しかも明朗で、如何にもその頭腦のよさを思はせた。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家は簡素で風致があり、和にして洋、何か虔ましくて、まことに田園の住居と思へる。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十一年六月小田原にて白秋識その一簡素な庭古風の庭　　　　　大正十年秋、上州富岡某氏別荘にて紅葉を焚いて　　　同七年秋、名古屋月見坂にて山中消息　　　　　同七年冬、小田原伝肇寺にてある人の庭寂しい庭だ、閑かな庭、古めかしい日本の庭、風雅な庭、それでも極りきつた、強ひて取澄した庭、幽かな庭。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡素な紅葉、静かな紅葉、その紅葉の下枝には、雀も二羽来て啼いてゐる。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡素だと思へば簡素、寂しいと云へば寂しい。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋風の簡素なものだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "桟橋へ上って見て私の第一に喜んだのは、その前の広場に群って客待ちしている簡素な馬車の幾つかであった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもまだ私と庄亮とは諦めがつかないので、真岡に上ると、市内見物の道すがら、縁の青い波型の飾りをそよがした例の簡素な幌馬車をリリリンリンリンで、最寄りの自動車屋をあちこちと探し廻ったものだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」小沼農場　赭いガサガサした粗皮の椴松、蝦夷松、たもの木などの丸太で組立てた樺太庁農事試験場の歓迎門は流石に簡素であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という簡素と高貴。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく校倉式の丸太組の露西亜人の家々は簡素で、また幽雅で、しかもいい寂色に古びていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めて簡素であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それをののかんそのことの、　　ゆゑはにはかに推し得ね、　　　大礼服にかくばかり、　　　　　美しき効果をなさんこと、　　　いづちの邦の文献か、　　　　　よく録しつるものあらん……しかも手練の写真師が、　　三秒ひらく大レンズ、千の瞳のおのおのに、　　　朝の虹こそ宿りけれ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガチョウの丸焼きにはリンゴとかんそうモモのつめ物がしてあって、湯気が立っていてとてもおいしそうでした。",
              "citation": {
                "source": "マッチ売りの少女",
                "author": "THE LITTLE MATCH-SELLER",
                "note": "青空文庫"
              }
            },
            {
              "text": "をばてきのやんかんそふもこのごろハ、ちとふやり／＼と心も定めかねをりハすまいかと思ふぞや。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年一月二十日　姪春猪あて",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
