[
  {
    "uuid": "088fd3af-b199-50cc-9e4f-ec1b6b8e04e8",
    "entry": "渇く",
    "reading": {
      "primary": "かわく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be thirsty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あー、喉が渇いた！冷たいサイダーを一気に飲み干したい気分だよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "真夏の炎天下でテニスをしていたら、いくら水分を摂っても喉が渇く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長時間のプレゼンを終えた後の彼の喉は、カラカラに渇ききっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "緊張のあまり、喉が渇いて何度も生唾を飲み込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "要心を通越した臆病な処へ、渇くのは空腹にまさる切なさで、一つは其がためにもつい出億劫がるのが癖で。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま慧鶴青年は、それを読んで行って、渇く人が水を得たように眼を離せなくなった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "渇くのは尚ほ辛くつて、雨のない日の續く時は帆布を擴げて、夜露を受けて、皆が口をつけて吸つたんだつて――大概唇は破れて血が出て、――助かつた此の話の孫一は、餘り激しく吸つたため、前齒二つ反つて居たとさ。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ咽が渇く、咽が渇く」との嘆声八方より起る。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "後から考えてみると、数回この山に登った奴が全然知らぬ道理はない、きっとこの雨の中を汲みに遣られては堪らぬと、自分等も咽の渇くのを我慢して、焚火に噛り着いていたいため、知らぬ顔の半兵衛を極め込んでいたものと見える。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コラッ、貴様ッ、ろくろく働きもせぬくせに、生血のような水を唯飲みしようとは、怪しからん奴だ」と呶鳴り付けたが、考えてみればあれも人の子、咽の渇くのは同じだろうと惻隠の心も起り、「皆飲むなよ」と、長い竹筒の水を渡してやれば、先生竹筒に口を当てるが早いか、逆様にして皆ゴボゴボと飲んでしまった。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも彼等は、常に渇くように詩を求めている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人若し口の渇くこと甚しくして舌の燥くこと急なれば、熊の掌も魚の腴も、それ何かあらん。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と下りて来て、長火鉢の前に突立ち、「ああ、喉が渇く。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渇くのは尚ほ辛くつて、雨のない日の続く時は帆布を拡げて、夜露を受けて、皆が口をつけて吸つたんだつて――大概唇は破れて血が出て、――助かつた此の話の孫一は、余り激しく吸つたため、前歯二つ反つて居たとさ。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきには汗出でて咽喉渇くに、爺にもとめて山の井の水飲みたりし、その冷かさおもい出でつ。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも雪の中の十二月だ、情ない事には熱くて口の渇く母親に、小さく堅めて雪を口へ入れたんだけれど、降たての雪はばさばさして歯に軋むばかりで、呼吸を湿らせるほどの雫にならない。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉助は夜なかにふと眼をさまして、喉が渇くままに枕もとの水を飲んで、それから煙草を一服すったが、二階じゅうはしんと寝静まって夜はもう余ほど更けているらしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "饑渇く如く義を慕う者は福なり、其故如何？",
              "citation": {
                "source": "聖書の読方",
                "author": "来世を背景として読むべし",
                "note": "青空文庫"
              }
            },
            {
              "text": "渇く者はおのずから水を取る、これその本然の必要に促されてである、その如く人が罪を取るはその本性上しかる所であって、人は到底罪人たる境涯より脱し得ぬと、これこの語の暗示する所である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだはいよいよ熱って来て、熬つくように喉が渇くので、かれはよろめく足を踏みしめながら、ふたたび水甕のそばへ歩み寄ろうとする時に、暮れかかる表から一人の男が影のように入って来た。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "坑夫達は口が渇くと、勝手にそこへ出掛けては水を飲んだ。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "渇く日誰か汝を花の園にも交へめや。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾ら飮んでも喉が渇く。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　むかし、むかし、大むかし、帝｜堯が自分の治めてゐた天下を譲らうとするのを、にべもなくはねつけて、箕山の奥に隠れた許由が、あるとき口がひどく渇くので、谿河の水際におりて、透きとほるやうな水を両手の掌に掬んで飲んでゐたことがあつた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞に渇くんだよ、昨晩少し飮んで來たからな。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "真に渇くんだよ、昨晩少し飲んで来たからな。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "今初まッた事では無いが、先刻から酔醒めの気味で咽喉が渇く。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、心身がある一つの對象に向つて統一された状態にあることを、張り切つた力の感じ、充實感と云つたやうなものを、深い自覺に於てといふよりは、ほとんど本能的な欲求として、渇くやうな氣持で求めてゐたが、さういふ彼の求めに最も端的に應へてくれるものが肉體的な勞働であらうといふことは肯ける。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ知識欲を滿したいといふ、渇くやうな純粹な望みだけなのだから。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊んでゐる子供は、のどが渇くと見えて、よく水を欲しがつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "無識の得７・19（夕）　平民にお腹の空く時があるやうに、大名にも咽喉の渇く事がある。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなものを飲つて、後で咽喉が渇くだらう。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "波頭が砂浜をはい上がって引いたすぐあとの湿った細砂の表面を足で踏むと、その周囲二三尺ほどの所が急にすうとかわくが、そのまま立ち止まっていると、すぐにまた湿って来ます。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんなは、おなかもすくし、のどもかわく。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to thirst for",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は常に新しい刺激に渇いており、休みの日もじっとしていることがない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "権力に渇いた男は、かつての友人を裏切ってまで高い地位を手に入れようとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若い才能たちは、自分の実力を証明できるチャンスを求めて渇いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "称賛に渇いている彼は、SNSの「いいね」の数に一喜一憂している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
    ],
