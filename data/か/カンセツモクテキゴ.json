          "standard": [
            {
              "text": "英語の第4文型では、動作の対象となる相手（〜に）が間接目的語として配置される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「『彼に本をあげた』の『彼に』が間接目的語になるんだよ」と先生が黒板に図を描いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "フランス語の代名詞の位置を覚えるとき、直接目的語と間接目的語の語順でみんな混乱する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "文法書によれば、間接目的語は「誰に」という受取人を表す役割を担うことが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
