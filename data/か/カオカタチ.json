        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は母親譲りの整った顔かたちをしていて、誰もが振り返るほどだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "幼い頃の写真は、現在の彼の顔かたちとほとんど変わらない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の顔かたちから、どことなく異国の血を感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "年頃も顔かたちも丁度註文通りに見えたので、かれは更に奥女中の雪野というのを連れて来て眼利きをさせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしておもしろい事にはその彫刻に現わされたガルダの顔かたちが、わが国の天狗大和尚の顔によほど似たところがあり、また一方ではジャヴァのある魔神によく似ている。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ化け物の顔かたちがだんだんにちがったものとなって現われるだけである。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔かたちもおんなじでした。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのひとの名前も、また、顔かたちさえ記憶から遠ざかっている現在なお、あの鮨やの親爺の顔だけは絵にかけるほど正確に覚えているとは、よっぽどあの時の鮨がまずく、自分に寒さと苦痛を与えたものと思われます。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "逸作は身体を揺り上げながら笑っている間に画家らしく、雛妓の顔かたちを悉皆観察して取ったらしく、わたくしに向って、「名前ばかりでなく、顔もなんだかお前に肖てるぜ。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に横はる蒼く萎びたお辻の死体……彼は、小さくても肉付きのよい顔かたちの人並すぐれてよく整つてゐた若い頃のお辻が、いつの間にか年をとつて、こんなに蒼く萎びたかと、納棺前のお辻の死体の傍で感じたことを思ひ出した。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔かたちを見るなり、柳吉の妹だと分った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は、顔かたちから、いずまいの美しいけだかいことといったら、世の中にくらべるものもないくらい、りっぱな、りりしい人でした。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　暗いなかで顔かたちはわからないが、僕ももう大抵の鑑定は付いた。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔かたちを一目見るなり、柳吉の妹だと分った。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹一のようないくらか蒼ざめた、顔かたちの整った青年は、ボーイにうってつけなのだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、その顔かたちが、俊子と瓜二つに生長しているんだ。",
              "citation": {
                "source": "殺人迷路",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はまだ二十五六の若い男で、こんな稼業には似合わないおとなしやかな色白の、人形のような顔かたちが人の眼について、人形常という綽名をとっているのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても様々な憧れに満ちた表情の動きは同じ顔かたちでありながら何と底深く洞ろな相違に充ちてゐることであらう！",
              "citation": {
                "source": "痴酔記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るにつけ、その顔かたちは激しい雨にでも打たれたものゝやうな窶れと憂ひに覆はれてゐた。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しそうだとすれば得難い珍品だ、何にも動きのない顔にこそ、いろいろな動きの顔かたちが想像出来るものなのです。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉親の人々の顔かたちがいくつとなく浮びあがり、その中にはもうこの世にゐない人達の、たゞ呆然と、とり済した御面が、ありありと入り交つてゐた。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうは思いきわめながらも、林之助がまつげの塵ともいうべきは、かのお里の初々しいおとなしやかな顔かたちであった。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所などをさせずに、小間使いとして手回りの用事でもさせたら顔かたちといい、性質といい、取り回しといいこれほど理想的な少女はないと思うほどだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はつきりと、私は秀子の美しい顔かたちを幻に描いた。",
              "citation": {
                "source": "痴想",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、臨終に間もないかも知れない青年の顔かたちを、たゞ茫然と見詰めているだけであった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、彼等に就いては、その思想と情熱とそしてその顔かたち以外に関しては、何んな経歴も知らなかつた。",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが今日は、吾ながら不思議な想ひであつた――なにしろ自分の顔かたちが、斯んなぼんくらな己れの霊魂と遊離して、空間のうちに新しい座を占めてゆくといふ想ひに最も微妙な張合ひを覚えるかの如きであつた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もが思はず見惚れてしまふといふのだから顔かたちのことなどを、殊に美女の観察や形容の言葉には拙劣な私がなまじな吹聴を試みぬ方が無事ではあるのだが、その時私は不意と、一体誰も彼もが見惚れるほどの美女とは何んな顔か？",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔かたちは解らないが、見るからに長身の立派やかな男で、百合子の現れるのを待遠しがつてゐる風らしく、立ちあがつて廊下をぶら／＼と行きつもどりつしたりしてゐた。",
              "citation": {
                "source": "まぼろし",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々の顔かたちも見慣れた村の風景も濛つとした黄昏時の乳色の中に舞ひ出した彼女の姿は、まことに寒村居酒屋の娘とは享けとれぬ艶やかさであつた。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顔かたちから声音までが余りによく肖ているので、不意にその幼な名を呼びかけると、彼女は思わず振り返ったが、又もや足を早めて立ち去った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "閲微草堂筆記（清）",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔かたちから着物は勿論、右の襟の角の反れているのから、左の袖を半分捲いているのまで、すべて寸分も違わないので、夫人はおどろいて殆んど仆れそうになった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "閲微草堂筆記（清）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつらは、女を玩ぶに、女を裸にして玩ばなければ満足のできないやからなのだ――ちぇッ、いいざまをして、この女め、笑ってやがる、小憎らしい笑い方だなあ――　主膳はこう言って、三眼｜爛々として、西洋婦人の豊満な肉体美をながめているうちに、その女のかおかたちがだんだんお絹に似てくる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
