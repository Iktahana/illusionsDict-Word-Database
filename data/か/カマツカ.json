        "examples": {
          "standard": [
            {
              "text": "庭の片隅に植えた鎌柄（かまつか）が、白い花を咲かせ始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "秋になると、鎌柄の実は赤く色づき、鳥の餌となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この低木は鎌柄といい、丈夫で育てやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
