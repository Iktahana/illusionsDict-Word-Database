        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その国際会議には、経済界、学術界、政界など、各界の著名人が集まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ノーベル賞受賞のニュースは、国内の各界に大きな喜びと刺激を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい政策を巡り、各界から賛否両論の声が上がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "…自らの意見を形成するのは、関係当局と関係各界が行うべきことである」と釘をさしていることも、申し添えておく。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんにち揺がない大出版企業の代表者たちが、文化上どのような性質をもつ存在であるかということは、渡米ラッシュの各界代表選出にさいして、出版界だけが人選にゆき悩んでいる実状に語られている。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人代議士はじめ各界の婦人も登場した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長年の言論出版統制に苦しんできた日本の各界は、用紙割当の内閣移管は、政府の言論出版統制に具体的根拠を与えるものとしてつよく反対した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の日本において、各界を通じて、豪い人物と感心するのは西田先生と幸田露伴先生とである、と或る友人が私にいったことがある。",
              "citation": {
                "source": "西田先生のことども",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化の面では文学の新運動ばかりでなく、戦争中もっとも戦争協力を強いられたラジオ、新聞の民主化に着手され、ＧＨＱの協力によって日本のラジオの民主化のために民間各界の代表をあつめた放送委員会が組織された。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて各界に於ける最大の裏切りは、その道の者が行うのですよ。",
              "citation": {
                "source": "中庸",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で特に傑出しているのがルミ子というパンパンで、美貌に於ても、独自の見解に於ても、各界の一流の女傑に比して遜色ないほど、一家をなしていらせられるです。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月二日に、Ｎ宮はじめ各界の名士五十九名に逮捕命令が下ったが、そのなかに、当然あるべき石田という名がないので、祖父は、むやみに腹をたて、逃げようにも行先がなく、やむをえず居残りになっていた家扶や家令に、さんざんにあたりちらしたそうである。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "年はまだ三十五の男盛り、礼智に長け、公平な物の観方で政治に臨んできた態度には、各界から異口同音の同情が寄せられた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "またウソだと思ったら、現代において最も代表的に高度に強烈に生きている各界の人々に今の演劇雑誌を読ませてごらんなさい。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戰前、ある婦人雜誌では、あかン坊の命名サービス欄を設け、各界の名士を名づけ親係りに依囑し、讀者の好評をはくしたこともあつた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだかけ出しの新聞記者時代に「楯の半面」という続き物で、各界の名士百三十人と対談した。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "各界で名のある人たちが毎月ひとりずつ、自分の好みの寄り道、つまり酒の店を一軒、紹介する。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日鳴尾君と私は田中さんの東京放浪時代の形見とでも云うべき署名帳を見せてもらったが、それには実に各界名士の署名が綺羅星の如く並んでいて、よくもかく万遍なく天路歴程が出来たものだと二人とも魂消てしまった。",
              "citation": {
                "source": "西隣塾記",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本からも、西園寺全権や牧野全権をはじめ、各界の人がパリーにきた。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "文壇、各界いろんな顔が無慮六、七十名も集るので、浅間山麓の鳥類どもも顔マケの観がある。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
