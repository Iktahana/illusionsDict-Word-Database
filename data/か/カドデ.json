    "definitions": [
      {
        "index": 1,
        "gloss": "setting off (on a long journey)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "卒業の記念に、彼はバックパック一つで世界一周の門出を迎えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "旅立ちの朝、駅で家族に見送られ、いよいよ門出だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「さあ、新しい冒険の始まりだ！門出を祝って乾杯しよう！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "さても私の境涯の、その最初の門出は「門司の旅館で船を待つ間、船の汽笛が鳴るたびに火のつくやうに泣き出」したのであり、「その日はそれに、吹く降るの日で」あつたのである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「駅逓馬車」による永い旅路の門出の場面などでも、こうした映画の中で見ていると、いつの間にか見ている自分が百年前のワルシャウの人になってしまう。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして我が室生犀星は、けなげにも發奮して立ち、新生活への勇ましき門出をしてゐる。",
              "citation": {
                "source": "室生犀星君の飛躍",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時かれは二十二歳であったが、郷党みな彼が前途の成功を卜してその門出を祝した。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "）蓮月　――あなたはどうしてその半分冷静に半分情熱が残って居る焦立たしい心境から悪の途へ門出されたのです。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、「いや、神聖な男の方の世界の門出を汚してはならない！",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "母に似ぬ娘は美形で、近所では春日小町と呼んでいたが、ある名門出の社会学者に片着いていたが、一人の女の子を残して急病で夭死し、彼女の身辺に何か寂しい影が差し、生きる気持が崩折れがちであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、門出だから、と言ひつつ弟の方へ手を差し出した。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど輝かしい人生の門出の、第一夜に、鶴は早くも辱かしめられた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを流石は忠三郎氏郷だ、戦の門出に全軍の気が萎えているようでは宜しく無いから、諸手の士卒を緊張させて其の意気を振い立たせる為に、自分は直膚に鎧ばかりを着したということが伝えられている。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の人生への門出は、このように幸福でした。",
              "citation": {
                "source": "貨幣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "渦まく淵を恐れず、暗礁おそれず、誰ひとり知らぬ朝、出帆、さらば、ふるさと、わかれの言葉、いいも終らずたちまち坐礁、不吉きわまる門出であった。",
              "citation": {
                "source": "喝采",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてわたしはおまえへの恋の打ち明けから求婚まで何一つ隠さず相談して来た庵の同棲者のこの秋雄からお艶に関して彼とかの女との間柄に就ての意外の打ち明け話から、わたしは天地もひっくり返る想いをし、こゝに新なる心理に門出した。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさき留める）おさき『行きなさるなら門出の仕度。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茲に収められた七章八十余篇の詩は、明治四十二年の二月（邪宗門出版当時）より大正二年の四月（朱欒廃刊迄）に至る、概ね四ヶ年間の制作であつて、恰度私の青春の花期に当つてゐる。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "末造自身も一種の晴がましい心持はしているが、それはこれまで抑え抑えて来た慾望の縛を解く第一歩を踏み出そうと云う、門出のよろこびの意味で、〔te^te-a`-te^te〕 はそれには第一要件になっていた。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "子の十郎直基（隆基という本もある）は、父が撃たれたと聞くと、せめて父が討死せしところを見ばやと、馬を返す所を、青木所左衛門出で合い、「音に聞えし真柄殿、何処へ行き給うぞや、引返し勝負あれ」と呼びければ、「引くとは何事ぞ、悪い男の言葉｜哉。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これで門出の杯はすんだ、出かけよう、油断して痴漢を討もらすな」　それは舟乗りとなっていた男の声であった。",
              "citation": {
                "source": "赤い土の壺",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二木検事と村井記者は、同期の、赤門出の法学士だった。",
              "citation": {
                "source": "殺人迷路",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "媼は我に向ひて、カムパニアの馬に勝るべき足どりの駒なり、幸運の門出は今ぞとさゝやきぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これがお前の門出を祝うお酒だよ」こう言って一口飲んで弟にさした。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「暫くの別れは互の希望の門出で、幸福の緒口なのだ。",
              "citation": {
                "source": "喜びと悲しみの熱涙",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "門出の日は縁起を祝って、不吉なことはだれもいっさい避けようとしているが、父も娘も忍ぶことができずに泣いていた。",
              "citation": {
                "source": "源氏物語",
                "author": "松風",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻「お茶を一つ差上げませう」蒲「どうしても敵討の門出だ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "要は期せずして偶合したので、久しい歳月の間に、こんな事は多くあろう（宝永五年板『風流門出加増蔵』（『西鶴置土産』の剽窃物）三ノ二、伊勢町の大盃といえる大尽云々、六十を過ぎて鬢付嗜み女郎と討ち死にと極めて銀使いける云々）。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "サラミヤ姫は、兄君の門出の前に自らを励まして、いさぎよい言葉を捧げようと努めたのです。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に感嘆されても称讃されても藪睨みの感嘆や色盲的の称讃では甘受する事が出来ないで、先ず出発の門出からして不満足を感ぜざるを得なかった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二歳ごろの時、浮浪少年とのかどで、しばらく監獄に飼われていたが、いろいろの身のためになるお話を聞かされた後、門から追い出された。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、すぐにそれが新聞にのって、町かどで二シリングで売られるのです。",
              "citation": {
                "source": "のろまのハンス",
                "author": "――むかしばなしの再話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お前さん、近所で聞くとね、これが何と……いかに業体とは申せ、いたし方もこれあるべきを、裸で、小判、……いえさ、銀貨を、何とか、いうかどで……営業おさし留めなんだって。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
