        "examples": {
          "standard": [
            {
              "text": "ソメイヨシノよりも一足早く、鮮やかな濃いピンク色の寒緋桜が咲き始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "公園の入り口に植えられた寒緋桜の並木道は、早春の訪れを告げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "沖縄では、寒緋桜が本土の桜よりも早く開花し、春の風物詩となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "またあるいは寒緋桜ともいわれている。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
