    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hide-and-seek (game)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "公園で子供たちが楽しそうに隠れんぼをしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「私が鬼だから、みんな隠れんぼしよ！」と、妹が元気に叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "小さい頃は、よく兄と隠れんぼをして遊んだものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "猫がカーテンに隠れんぼをしているかのように、じっと動かない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "Ｓ＝附近――　三次此処まで来て立ち止って、勝坊に、Ｔ「隠れんぼうをして遊ぼうか」　と言い出した。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互いに現実から隠れんぼうをしているような者同志の一種の親しさ、そして、かばい合うような懇な眼ざしで鮨をつまむ手つきや茶を呑む様子を視合ったりする。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の二三人は麦畑の中で隠れんぼをしてゐる。",
              "citation": {
                "source": "神馬",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「諸君よ、今暁吾々が行う潜行は、祖国を頽廃から救う、偉大なる隠れんぼうである。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎はチロといっしょに、俵の山を乗り越えたり、周りをぐるぐる廻ったり、隠れんぼうをしたりして、遊びました。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハイド・アンド・シーク」は隠れんぼを意味するので、その洒落である。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、がんりきほどの眼力で、子供の隠れんぼを見落すはずもあるまい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは子供達の、「も・う・い・い・かアーい」「まア・だ・だ・よーオ」　という隠れんぼの声だ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、「もういいかアーい」「まアだだよーオ」　という隠れんぼの呼び声に他のいかなる音よりも似ていることは確かです。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりやっぱり隠れんぼである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もういいかアーい」「まアだだよーオ」　という隠れんぼの呼び声は今や全国的であるけれども、その発祥は武蔵野で、武蔵野界隈にだけ古くから伝わっていたにすぎないもののようだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう考えて改めて笛の音にきき入ると、モウイイカイ、マアダダヨオ、という子供たちの隠れんぼの声が、この笛の音律と舞いの内容に深いツナガリがあって民族のハラワタをしぼるようにして沁みでてきたものではないかと思われ、そう信じても不当ではないと言いきりたいような大きな感動に私はひきこまれていたのであった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろフシギなのは、無邪気な子供たちの遊びの中に、この武蔵野の隠れんぼのように哀調切々たる呼び声が呼び交されることの方ではありませんか。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五万何把の藁束分けて、隠れんぼどこかと探チてまわる。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には、次男が近所の子供を相手に隠れんぼをはじめ、押入れに隠れようとして、家にはいないはずの父をそこに見つける。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠れんぼをすると、お時は、ぞうりをふところに入れて、家の前にあった大きなしいの木に登ったものだ。",
              "citation": {
                "source": "こま",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠れんぼなどはどうだろう」　モカ達みんな笑い出してしまった。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、またわいわい言っていたが、「隠れんぼうをしよう。",
              "citation": {
                "source": "過ぎた春の記憶",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、隠れんぼでは、あんまり巧く隠れて、みんなが彼のことを忘れてしまう。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『その煙のやうなものゝ中で、僕達、エミルと一緒に隠れんぼをして遊びましたつけ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして翌日は朝から蝋小屋の中で、従兄弟達と角力をとったり、隠れんぼをしたりして遊んだ。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校の往きかえりはもとより、戦争ごっこや、鬼ごっこや、隠れんぼなどで、誠吉が不利な立場に立っていると、何とかして彼を助けてやろうとした。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家にはおゆみと同じ年の娘があり、よく遊びに往ったり来たりしていたのだが、或るとき、その家で隠れんぼをしていて、おゆみが土蔵の中へ隠れた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "狂女の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま隠れんぼをしているの、鬼が来ても黙っててね。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "狂女の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らなくても、主人の居間を隠れんぼのグラウンドにするなんていうことの見境はあるのだが、そこに頓着のないところにこの低能さ加減がある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいちはしなかったが夜は抱いて寝るらしい、大助を背に乗せて馬のまねをするとか、庭で砂いたずらとか、鬼ごっこや隠れんぼうをするとか、自分が子供のように面白がって、さきだちになって遊ぶ。",
              "citation": {
                "source": "つばくろ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死を相手に恐ろしい隠れんぼをやってるかのようで、相手の幽鬼の顔が近づくごとに指弾を食わしていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんな固くなるこたあねえぞ、紋太なんぞおれの家来だ、さあ呑め、隠れんぼうが悪けれあめくらの鬼だ、じゃんじゃん騒ごう」「若さま少し静かにあそばせ」宙野が渋い顔をした。",
              "citation": {
                "source": "若殿女難記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和三十一年五月、この本のために書き下ろす）６　隠し方のトリック「もういいかい」「まあだだよ」の隠れんぼうの面白さは機智とスリルにある。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の子供が地面に四角な区劃を描いて、ある特定のゴミ、マッチの棒などの木や藁の切れっぱしだとか、小石などをその区劃の中の土に埋めて隠すと、他の子供がそれをさがし出すという、いわば「隠れんぼう」を極端に縮小したような遊びであった。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
