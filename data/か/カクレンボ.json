[
  {
    "uuid": "bc145c63-027a-55ed-8664-8271e5d2db95",
    "entry": "隠れんぼ",
    "reading": {
      "primary": "かくれんぼ",
      "alternatives": [
        "かくれんぼう"
      ],
      "is_heteronym": true
    },
    "grammar": {
