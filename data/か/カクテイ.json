  {
    "uuid": "ff97dc2d-6cf0-5f72-bdf5-a15b40125632",
    "entry": "角觝",
    "reading": {
      "primary": "かくてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "strength contest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古代ローマの闘技場では、剣闘士たちが角觝を繰り広げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "その二人の力士の取組は、まさに角觝と呼ぶにふさわしい熱戦だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼らは互いのプライドをかけて、技術と力の角觝に挑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "其処で、野寺の観音堂の拝殿へ上り、其方盲人にて角觝は成るまじ、腕おしか頭はりくらか此の二つの中にせむ。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "闘鶏、闘犬、闘牛の類を惣て野蛮だといつて悪くいふ者もあるが、人間様に角觝がある間は這般な事を云はれまいと思ふよ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "抽斎は角觝を好まなかった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔評〕南洲｜壯時角觝を好み、毎に壯士と角す。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "柔らかい毛布にくるまって上には志んの持って来た着物をかけられ、脚部には湯婆が温かくていい気持になってほとんど何も考えないでウトウトしていたが眠られはしなかった。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくていま、追憶の空はあかあか、血のごとも雲は顫へ楽の音の慄くなかに、閃めくは聖体盒の香の曇、骨も斑らに白白と浮びちり、あはれ早や沈み暈めく。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "『かくていまや多大の成功をもって計画をなし遂げた我々には、犯罪の証跡を残さないための努力だけがただ一つ残された。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくていつき育てしほどに十五歳の時家長｜空しくなりぬ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくていまこの一家は陰悪な空気にとざされているのである。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃと申して、まだお若かくていらせらるるので下らぬけんかをおこのみなされてのう、　お叱り申すねうちもない様な又わたくしももうお小言を申す等の事にはあきましてのう。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "キェルケゴールは云ふ、「時間と永遠とが接觸すべきであるならば、このことは唯時間のうちに於てのみ行はれ得る――かくていまや我々は瞬間の前に立つのである。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくていまこれら一切の出來事の總體は一つの連續として、表象されることが出來る。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の家は冬向きは実に暖かくていい。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "三一―三三鷹その被物を脱らるれば、頭を動かし翼を搏ち、願ひと勢とを示すごとく　三四―三六神の恩惠の讚美にて編めるこの旗章は、天に樂しむ者のみ知れる歌をうたひてその悦びを表はせり　三七―三九かくていふ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "七六―七八わが語りゐたる間、かの火の生くる懷のうちにとある閃、俄にかつ屡※｜顫ひ、そのさま電光の如くなりき　七九―八一かくていふ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "九四―九六獸包まれて身を搖動し、包む物またこれとともに動くがゆゑに、願ひを現はさゞるををえざることあり　九七―九九かくの如く、第一の魂は、いかに悦びつゝわが望みに添はんとせしやを、その蔽物によりて我に示しき　一〇〇―一〇二かくていふ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "三匹はお風呂へはいつてしまふと、矢張りお風呂はあつたかくていいもんだなあとよろこんでニコニコしてゐます。",
              "citation": {
                "source": "三匹の小熊さん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お家のベツトの中へはいつて、お猫さんは、「川の水の中より、おふとんの中がずつとあつたかくていいや。",
              "citation": {
                "source": "川の中へおつこちたお猫さん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくていよいよ、古いブルジョア社會（およびその諸階級と階級對立と）の代りに、各人の自由な發達が衆人の自由な發達の條件となるやうな、協力社會が生ずるのである。",
              "citation": {
                "source": "共産黨宣言",
                "author": "カール・マルクス",
                "note": "青空文庫"
              }
            },
            {
              "text": "九死に一生を得た情熱漢天民の、かくていかに新夫人を全魂全霊で、愛撫しつくしたことか。",
              "citation": {
                "source": "吉原百人斬",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくていよいよその仏像が出来上ったところが、鳥羽法皇これを御覧になって、かくのごときの立派なものは洛外に出してはならぬとお禁じになった。",
              "citation": {
                "source": "奥州における御館藤原氏",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくていわゆる「部落改善」は、思ったほどまではなくとも、ともかくも相当の成績を挙げることができました。",
              "citation": {
                "source": "融和促進",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "飴ン坊の句、かくていよ／＼青鞜社の全貌を小気味好く描き尽してゐるではないか。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかほか温かくていまにも潰れさうである。",
              "citation": {
                "source": "はるあはれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初私は工藝の美そのものの性質を述べ、次には工藝の本道が何であるかを論じ、かくていかなる工藝が最も美しいかを説くであろう。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○かくていそぐほどに雪吹ます／＼甚しく、橇を穿ゆゑ道遅く日も已に暮なんとす。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日温かくていいの。",
              "citation": {
                "source": "或る少女の死まで",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも君は気が短かくていかん。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたちの眉宇はかくていよいよ晴れやかなりと申せます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくていつも少数の小雑誌や集会や結社のみであった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
