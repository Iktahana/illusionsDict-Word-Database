[
  {
    "uuid": "517bf4c7-7402-5888-9e45-ac22e09485e8",
    "entry": "画定",
    "reading": {
      "primary": "かくてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
