    "definitions": [
      {
        "index": 1,
        "gloss": "demarcation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長年にわたる領土紛争を経て、ようやく両国の国境線の画定について最終的な合意に達した。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "海底資源の開発を進めるため、関係諸国は排他的経済水域の画定を急いでいる。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "学問分野の画定は、研究の専門性を高める一方で、学際的な視点を妨げる懸念もある。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "「自分と他者との境界を画定できないことが、彼の精神的な苦悩の根源にあるようだ」",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "都市計画の策定にあたっては、まず市街化区域と市街化調整区域を厳密に画定しなければならない。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "プロジェクトの初期段階で、各部門が担うべき責任の範囲を明確に画定しておくことが成功の鍵となる。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "国境画定委員とかいふ、あれさ、同勢二十人からの団体らしい。",
              "citation": {
                "source": "けむり（ラヂオ物語）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "タトヒ一歩ヲ譲ルト雖モ経略ヲ画定ス、之ヲ中策トス。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那すでに無力なりとすれば、次いで来るものは勢力範囲画定の問題である。",
              "citation": {
                "source": "三たび東方の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "この現地測量隊として、アンゴラ政府の派遣せるものは、技師二十六人、技手以下測量人夫三百八十人、充分なる食糧と準備を整え、約十八班に分れて、中央国境唯一の土人町ビイサウを基点として約一カ年半の予定をもって、東西｜蜿蜒千五百｜哩の国境画定測量に従事することとなったのであった。",
              "citation": {
                "source": "令嬢エミーラの日記",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "柔らかい毛布にくるまって上には志んの持って来た着物をかけられ、脚部には湯婆が温かくていい気持になってほとんど何も考えないでウトウトしていたが眠られはしなかった。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくていま、追憶の空はあかあか、血のごとも雲は顫へ楽の音の慄くなかに、閃めくは聖体盒の香の曇、骨も斑らに白白と浮びちり、あはれ早や沈み暈めく。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "『かくていまや多大の成功をもって計画をなし遂げた我々には、犯罪の証跡を残さないための努力だけがただ一つ残された。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくていつき育てしほどに十五歳の時家長｜空しくなりぬ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくていまこの一家は陰悪な空気にとざされているのである。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃと申して、まだお若かくていらせらるるので下らぬけんかをおこのみなされてのう、　お叱り申すねうちもない様な又わたくしももうお小言を申す等の事にはあきましてのう。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "キェルケゴールは云ふ、「時間と永遠とが接觸すべきであるならば、このことは唯時間のうちに於てのみ行はれ得る――かくていまや我々は瞬間の前に立つのである。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくていまこれら一切の出來事の總體は一つの連續として、表象されることが出來る。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の家は冬向きは実に暖かくていい。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "三一―三三鷹その被物を脱らるれば、頭を動かし翼を搏ち、願ひと勢とを示すごとく　三四―三六神の恩惠の讚美にて編めるこの旗章は、天に樂しむ者のみ知れる歌をうたひてその悦びを表はせり　三七―三九かくていふ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "七六―七八わが語りゐたる間、かの火の生くる懷のうちにとある閃、俄にかつ屡※｜顫ひ、そのさま電光の如くなりき　七九―八一かくていふ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "九四―九六獸包まれて身を搖動し、包む物またこれとともに動くがゆゑに、願ひを現はさゞるををえざることあり　九七―九九かくの如く、第一の魂は、いかに悦びつゝわが望みに添はんとせしやを、その蔽物によりて我に示しき　一〇〇―一〇二かくていふ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "三匹はお風呂へはいつてしまふと、矢張りお風呂はあつたかくていいもんだなあとよろこんでニコニコしてゐます。",
              "citation": {
                "source": "三匹の小熊さん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お家のベツトの中へはいつて、お猫さんは、「川の水の中より、おふとんの中がずつとあつたかくていいや。",
              "citation": {
                "source": "川の中へおつこちたお猫さん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくていよいよ、古いブルジョア社會（およびその諸階級と階級對立と）の代りに、各人の自由な發達が衆人の自由な發達の條件となるやうな、協力社會が生ずるのである。",
              "citation": {
                "source": "共産黨宣言",
                "author": "カール・マルクス",
                "note": "青空文庫"
              }
            },
            {
              "text": "九死に一生を得た情熱漢天民の、かくていかに新夫人を全魂全霊で、愛撫しつくしたことか。",
              "citation": {
                "source": "吉原百人斬",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくていよいよその仏像が出来上ったところが、鳥羽法皇これを御覧になって、かくのごときの立派なものは洛外に出してはならぬとお禁じになった。",
              "citation": {
                "source": "奥州における御館藤原氏",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくていわゆる「部落改善」は、思ったほどまではなくとも、ともかくも相当の成績を挙げることができました。",
              "citation": {
                "source": "融和促進",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "飴ン坊の句、かくていよ／＼青鞜社の全貌を小気味好く描き尽してゐるではないか。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかほか温かくていまにも潰れさうである。",
              "citation": {
                "source": "はるあはれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初私は工藝の美そのものの性質を述べ、次には工藝の本道が何であるかを論じ、かくていかなる工藝が最も美しいかを説くであろう。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○かくていそぐほどに雪吹ます／＼甚しく、橇を穿ゆゑ道遅く日も已に暮なんとす。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日温かくていいの。",
              "citation": {
                "source": "或る少女の死まで",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも君は気が短かくていかん。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたちの眉宇はかくていよいよ晴れやかなりと申せます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくていつも少数の小雑誌や集会や結社のみであった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
