[
  {
    "uuid": "2d830847-59d6-5fa9-94dc-9997df4924af",
    "entry": "空威張り",
    "reading": {
      "primary": "からいばり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
