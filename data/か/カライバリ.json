      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bluffing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はいつも自信満々な態度をとるが、実際は空威張りに過ぎない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ふん、私には通用しないぞ！」と、彼は空威張りをしてみせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「そんなに大きな声を出して、空威張りしたって無駄だよ」と、友人は笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "経験の浅い新人ほど、空威張りをしてしまう傾向があるのかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "天才者常に空威張りし、予言者嘆息するはまことに許容すべきのみ。",
              "citation": {
                "source": "地上組織",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショーのおやじは、あの空威張りの傲慢の時の方が似合いますね。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――人前では彼や彼の言い草を空威張りであしらうようにとくに気をつかったものの、内心では彼を恐れていた。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "空威張りするように見えるかもしれません――が、まったくほんとうの話なんです、――私は、こうして死ぬのはなんというすばらしいことだろう、そして、神さまの御力のこんな驚くべき示顕のことを思うと、自分一個の生命などという取るにも足らぬことを考えるのはなんというばかげたことだろう、と考えはじめました。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆さん――この壁はがんじょうにこしらえてありますよ」そう言って、ただ気違いじみた空威張りから、手にした杖で、ちょうど愛妻の死骸が内側に立っている部分の煉瓦細工を、強くたたいた。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "うわべは昔以上に生気溌剌たるものがあるようで、実は付け元気や空威張りになって来た。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字通りの身一つで、これから立つてゆかなければならないと云ふことは妻の前では雄々しいことではあつたが、四十近かい男にとつては、何とない風の吹くやうな空威張りのところが漂ひ、嘉吉にはその空虚さが何となくたまらなかつた。",
              "citation": {
                "source": "朝夕",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そんな困難に辟易するようでは、上は柿本人麻呂から下は武者小路実篤に至る語彙の豊富を誇っていたのもことごとく空威張りになってしまう。",
              "citation": {
                "source": "文章",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソコデ私の見る所で、新政府人の挙動は都て儒教の糟粕を嘗め、古学の固陋主義より割出して空威張りするのみ。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを輕々しくも見る物が癪に觸る、聞く事が氣に入らないと云て、恰も外國人を一種外道のやうに認めて空威張りを爲やうと云ふのは、是れは只自から侮辱を買ふに過ぎぬ。",
              "citation": {
                "source": "明治三十一年三月十二日三田演説會に於ける演説",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、世の中を見ると、のう、庄吉、武家は、徒らに、空威張りのみで、金子の前に、頭を下げぬ者が、幾人おる」「そうでござんすとも――」「調所のやった密貿易を、わしは、学ぼうと思う。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私はこの人の権威を感ずると申しましても、この権威の出どころたとえば空威張りとか、どういうようにその人が顰面をしましても、自分の権威をつくろうとしましても、そういうところからその人の権威を、私は認めることができないと思います。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かと空威張りをしてみても、やはり声をひそめてこそこそしていたことが、俄に頭に映ってきた。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その空威張りして、しかも馬鹿者の多かった大名・侍等が地位を失い、土民との間に階級の区別を見ない。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "百万人と雖も君は往け、一人と雖も我れ逃げん、なんていふ空威張りとは違ひますぜ。",
              "citation": {
                "source": "風俗時評",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "樗牛が得意で物を書いてゐた時代に、漱石先生は田舎廻りの英語教師か何かをしながら、「高山の林公が何を云つてやがるんだい」と空嘯いてゐたと云ふが、漱石先生などの眼からは、樗牛の空威張りが嘸や馬鹿げて見えたであらう。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大資本を有する三越の如きも、いたずらに小さな内地において「我が三越は世界いずれかの百貨店に劣らない」などと空威張りせずに、眼を海外に転じて、ロンドンであるとか、パリであるとかいう、世界の市場に乗り出して貰いたいと思います。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時から、侍の世界の、虚偽と空威張りと馬鹿馬鹿しさを聴かされて育っているのである。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "平次身の上話",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼はきわめてばかげた光景を思い浮べてみるのだが、それはたとえば、この憐れむべき学生、この空威張りの坊や、脚の曲った髯の男が、エルザのベッドの前にひざまずき、手を合わせて許しを乞うている情景だった。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども彼は、そういう空威張りの危険な無益さを認むることにおいては、あえて人後に落つるものではなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、ゲルマン風の感傷性と、パリー人的な空威張りと、生来の自惚れとが、不思議に混合してる人物だった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "大袈裟な言葉や羽根飾り、ブリキの剣と厚紙の兜とをつけた芝居がかりの空威張り、そういう扮装の下にはいつも、操り人形のギニョル式に歴史をもてあそんでる無謀なヴォードヴィル作者サルドゥー流の、救済しがたい軽薄さが見て取られるのであった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに虚栄的な怠惰の一形式であった――知的労働はあらゆる労働のうちで、最も点検しがたいものだったし、最も空威張りのきくものだったから。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "空威張りと皮肉と悲痛との交じり合ってる様子だったが、激しやすい大袈裟な率直なしかもたえず人生に欺かれてる精神が、その下に隠れていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」しかしそういう空威張りも、費やした金を償ってはくれなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "公衆中では仲間の人々の空威張りにやはり調子を合わしていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘つきの英雄を――法螺吹きのシラノや空威張りの雛っ子のシャントクレルなどを――この時代が英雄としてることは、無理からぬことだ、と彼は言った。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はそれを拒んで、空威張りに襟の留め金まではずした。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、おれは今どうか嘘をついたり、空威張りをしたりはしたくないものだ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことばに力を入れたのは、ただの空威張りだったということにはならないでしょうか……」「そうですよ、そうですよ！",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
