        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの歴戦の勇士は、かつての戦いで片目を失い、眼帯をトレードマークにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「彼は生まれつき片目なんだけど、それを感じさせないほど仕事が正確なんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "拾ってきた子猫は片目が見えなかったが、元気に部屋中を走り回っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
