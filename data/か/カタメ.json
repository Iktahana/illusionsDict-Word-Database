[
  {
    "uuid": "eb01fb82-f3e0-50a9-99ed-d6118cdc4c01",
    "entry": "固め",
    "reading": {
      "primary": "かため",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
