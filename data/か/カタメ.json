  {
    "uuid": "7fdeea9a-549e-5fb7-bde8-63e7e4446d98",
    "entry": "片目",
    "reading": {
      "primary": "かため",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one eye",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「うわっ、眩しいな。片目を開けるのがやっとだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はライフルを構え、片目をつぶって慎重に標的を狙った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "寝ぼけ眼でスマホの画面を見ると、眩しすぎて思わず片目を覆った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "前髪を斜めに流した彼女のスタイルは、いつも片目が隠れていてミステリアスだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "要するに顔面における「いき」の表現は、片目を塞いだり、口部を突出させたり、「双頬でジャズを演奏する」などの西洋流の野暮さと絶縁することを予件としている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある者は、びっこになり、片目になり、腕をなくして追っぱらわれた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど片目の十蔵がかく語りしものを痛きことかなと妹は眼をみはり口とがらせ耳をおおいて叫びぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "受付の十蔵、卓に臂を置き煙草吹かしつつ外面をながめてありしがわが姿を見るやその片目をみはりて立ちぬ、その鼻よりは煙ゆるやかに出でたり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時われかの貧しき少女が狂犬のうわさせしといいし片目の十蔵を憶い起こしぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この十蔵が事は貴嬢も知りたもうまじ、かれの片目は奸なる妻が投げ付けし火箸の傷にて盲れ、間もなく妻は狂犬にかまれて亡せぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに想い候え、十蔵とは奸なる妻のために片目を失いし十蔵なり、妻なく子なく兄弟なく言葉少なく気重く心怪しき十蔵なり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "見忘れたもうなと言いもおわらず卓の横に立つは片目の十蔵ならんとは。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "十蔵はわれを寿きて杯を飲み干しつ、片目一人、この船に加わりいることをかねて知りたまいしやと問う。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "十蔵はその片目を細くして小歌うたいつ、たちまち卓を打ちて、君よかの問いの答えはいかにしたまいしとその片目をみはりぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "片目を微かに開きしもまた閉じたり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺だって貴様、俺だって貴様……とにかく貴様みたいな偽善者は千篇一律だからだめだよ……なあ西山」　牡蠣のような片目が特別に光って西山の方に飛んできた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女様み気色に触る時は、矢の如く鬢櫛をお投げ遊ばし、片目をお潰し遊ばすが神罰と承る。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と仕事着の膝を軽くたたいて、羽織を着て、仕事場の神棚へ、拝をして、ただ一つ欅の如輪木で塵も置かず、拭込んで、あの黒水晶のような鏨箪笥、何千本か艶々と透通るような中から、抽斗を開けて取ろうとして――（片目じゃろうね。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ちょっと、おまけに、大目玉八貫小僧のように、片目を指の輪で剥き出すんですもの。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　職人も吃驚しましたって、ええと聞くと、（片目は富さんが入れましたでござりましょう。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（片目は見事に入れますが、座をかえて、もう一つの目は息が抜けます、精が続かない。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と咳き、がっしりした、脊低の反身で、仰いで、指を輪にして目に当てたと見えたのは、柄つきの片目金、拡大鏡を当がったのである。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と一歩ひきさま、暗い方に隠れて待った、あの射的店の幽霊を――片目で覗いていた方のである――竹棹に結えたなり、ずるりと出すと、ぶらりと下って、青い女が、さばき髪とともに提灯を舐めた。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨組の逞ましい、この女の足袋は、だふついて汚れていた……赤ら顔の片目｜眇で、その眇の方をト上へ向けて渋のついた薄毛の円髷を斜向に、頤を引曲げるようにして、嫁御が俯向けの島田からはじめて、室内を白目沢山で、虻の飛ぶように、じろじろと飛廻しに※していたのが、肥った膝で立ちざまにそうして声を掛けた。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　となぜか、わけも知らない娘を躾めるように云って、片目を男にじろりと向け直して、「何てまあ、馬鹿々々しい。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜目にも光る白銀の服を着こんだ奴この奇體なそれでゐてみたものもない片目の兇賊。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「や、おぬしは片目だな。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「平次だとて、片目だとて許すことがならうか。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議といおうか、偶然といおうか、さきに木の上に投げ落されたときに、その片目を大きい枝の折れて尖っているところに貫かれたので、そればかりは骨となっても元のところにかかっているのであった。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "中野さんと戸塚の野郎は前から心安いんか」　三好が仄白い光りの中で片目をつぶって笑った。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりしっかりした芸術作品を持ったり他の事業でも真摯な地歩をかためて居る女性以外には装飾的な表皮の感情は多くひらめかして居ても本質的な真面目な熱情や感情が浅薄です。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまでも愛の所作は消えないのではないが、それがため、あなた達は――胸から膝まで――すつかり黄金の甲冑で、かためられてしまふ。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その軍事的性質は、国民的解放の意義が失われ過ぎ去った後までも存続し、日清、日露の戦争に勝利を博すると共に、ます／＼支配的地位をかため、発展した。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏みかためられ、凍てついた道から外れると、馬の細長い脚は深く雪の中へ没した。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "being blind in one eye",
        "register": "standard",
