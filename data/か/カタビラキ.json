    "definitions": [
      {
        "index": 1,
        "gloss": "single door (as opposed to a double door)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "廊下の突き当たりにある狭い収納庫は、場所を取らない片開きのドアになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "古いアパートの玄関は薄い鉄製の片開きで、防犯面で少し不安があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "観音開きよりも、このスペースなら片開きの扉の方が使い勝手が良いだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "書斎の入り口を、重厚な木製の片開きドアにリフォームした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ト、漸くに雪のしっかり嵌り込んだのが脱けた途端に、音も無く門は片開きに開いた。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは十二時過ると扉もおとなしく片開きにしてある入口が、今夜はさあっと開いたままで、煌々と燈火のついた広間に人影もない。",
              "citation": {
                "source": "十四日祭の夜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とつつきに古びた襖が二枚はまつてゐ、廊下の突当りは片開きの襖になつてゐるらしい。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "様式の変化に富み、小箪笥風のもの、「けんどん」のもの、「片開き」のもの等種々あって内部は引出のもの多く、時としては硯箱や印箱も入れてある。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
