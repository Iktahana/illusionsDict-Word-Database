        "examples": {
          "standard": [
            {
              "text": "「愛だの恋だの言ったって、婚姻届なんて所詮はただの紙っぺら一枚の話だろ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ポケットの底をまさぐると、雨でボロボロになった督促状の紙っぺらが出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "必死に集めた署名が、権力者の前では何の価値もない紙っぺらとして扱われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「こんな紙っぺらに頼らなくても、俺たちの絆は揺るがないさ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私の考えではあんな普通の紙っぺらにご執心なのは理解できません。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
