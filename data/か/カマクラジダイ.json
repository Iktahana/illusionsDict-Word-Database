    "definitions": [
      {
        "index": 1,
        "gloss": "Kamakura period (1185-1333)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "鎌倉時代から続く老舗の暖簾をくぐると、歴史の重みが肌に伝わってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大河ドラマの影響で、最近は鎌倉時代の武士の生き様に関心を持つ人が増えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "元寇という未曾有の危機によって、鎌倉時代の社会は大きな転換点を迎えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「鎌倉時代の刀剣って、造形が力強くて実戦向きな感じがするよね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかるに、この仮名は初のうちは相当正しく音韻を表わしたであろうが、院政・鎌倉時代から室町時代と次第に音韻が変化して行った間に、仮名と音韻との間に不一致を来し、仮名が必ずしも正しく音韻を代表しない場合が生じた。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人が漢字で日本語を書いたものと西洋人がローマ字で日本語を写したものとが、その重なものであるが、支那人のものは鎌倉時代のものも多少あるが、室町時代のものはかなり多い。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かように、種々の音が同音に帰した結果、同音の仮名が多く出来、鎌倉時代に入ってその仮名の使いわけすなわち仮名遣が問題となるにいたったのである。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かように変化した形は鎌倉時代以後口語には盛に用いられたのであって、それがため、室町時代には動詞の連用形が助詞「て」助動詞「たり」「つ」などにつづく場合には口語では常に変化した形のみを用いるようになり、また、助動詞「む」「らむ」も「う」「ろう」の形になった。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、クグは鎌倉時代以後、漸次キ・ケ・ギ・ゲに変じて消失した。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上二種の変化は大体鎌倉時代には完成し、室町時代には既に長音に化していたもののようである。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉時代の化け物と江戸時代の化け物を比較し、江戸の化け物とロンドンの化け物を比較してみればこの事はよくわかる。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるつで鎌倉時代見たいだなあ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの鎌倉時代の禅宗の高僧、道元禅師という大知識が、すでに至高の修業を積まれた上、三年の間支那へ留学されました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さとりは全然不必要だと主張するのは、鎌倉時代に起った新興仏教の法然、親鸞、日蓮等の諸宗祖の見解で、これを述べる前に、曹洞禅の中のあるものの説くさとり不必要論を紹介しますと、さとれるようなさとりは小さなものだ。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉時代の親鸞聖人は聖徳奉讃の和讃を作って歎慕の意を表せられております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安末期より鎌倉時代にかけて法然、親鸞、日蓮、道元の諸宗祖によって、新興仏教が時代に応じて興りました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉時代の上長けたらんといと床し。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、この場合、何人も恍として鎌倉時代の人となるであろう。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "左様、何でも鎌倉時代の中葉、北條時宗頃の人でしたろう。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鎌倉時代に、私はもっと素直な気持で、あなたにおつき合いすれば好かったと思ってました。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、きつと、鎌倉時代によそから流れて来た不良青年の二人組が、何を隠さうそれがしは九郎判官、してまたこれなる髯男は武蔵坊弁慶、一夜の宿をたのむぞ、なんて言つて、田舎娘をたぶらかして歩いたのに違ひない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉時代だけぢやなく、江戸時代になつても、そんな義経と弁慶が、うろついてゐたのかも知れない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづれにしても鎌倉時代以前よりの、北奥の大豪族であつたに相違ない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉時代の末、津軽に於いて安東氏一族の間に内訌あり、遂に蝦夷の騒乱となるに到つて、幕府の執権北条高時、将を遣はしてこれを鎮撫せしめたが、鎌倉武士の威力を以てしてこれに勝つ能はず、結局和談の儀を以て引き上げたとある。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉時代足利時代から徳川時代へかけて、地勢上奥羽と同じく産馬地として鳴つて居る。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男女｜距ての作法も、先生が、昔、鎌倉時代に遊行衆といった禁慾者の教団が男女混同で一室に眠るとき定めた儀式から思い付かれたものなのだ」　と言いました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉時代に一遍上人という特殊の念仏を布教する聖僧があった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この猿楽が能の初まりである事は確実らしいので、能の曲目に選ばれている伝説や史実に、その以前の鎌倉時代以後の事がないのを見てもわかる。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、鎌倉時代以来の大名で、潰れなかつたのは、九州で島津氏、奥州で伊達氏くらゐだけで、山名、細川、両上杉、今川、京極、畠山、赤松、大内、九州の少弐、大友、菊池氏など、みんな亡んでしまつたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "恩顧譜代の家の子郎党に取り囲まれた鎌倉時代の武士と比べると、幕末の武士達は、もう武士でなくなつてゐるわけである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉時代、足利時代、降って徳川時代に至っては、その禁令がいよいよ厳重になって、ひそかに鷹を飼うものは死罪、それを訴人したものには銀五十枚を賜わるということになっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "御覧なさいまし、『八犬伝』は結城合戦に筆を起して居ますから足利氏の中葉からです、『弓張月』は保元からですから源平時代、『朝夷巡島記』は鎌倉時代、『美少年録』は戦国時代です。",
              "citation": {
                "source": "馬琴の小説とその当時の実社会",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉時代の人は、自然に鎌倉時代の言語風俗習慣を持ち、また同じ時期の思想や感情を持っており、奈良朝時代の人は、自然に奈良朝時代の言語風俗習慣を持ち、また同じ時期の思想や感情を持っていたのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
