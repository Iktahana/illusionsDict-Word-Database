[
  {
    "uuid": "609fd1cc-8bf4-5bc8-a5fc-5b07476136ab",
    "entry": "勘決",
    "reading": {
      "primary": "かんけつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
