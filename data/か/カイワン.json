[
  {
    "uuid": "49c65830-9b2f-5733-be04-4e549cb1112b",
    "entry": "怪腕",
    "reading": {
      "primary": "かいわん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
