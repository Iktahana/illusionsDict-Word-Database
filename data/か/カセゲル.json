[
  {
    "uuid": "c4fc9a69-61ea-5079-b810-08f0ddae78b5",
    "entry": "稼げる",
    "reading": {
      "primary": "かせげる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
