    "definitions": [
      {
        "index": 1,
        "gloss": "flaring up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夕暮れ時、太陽が西の空にカッと照りつけて、空が燃えるように赤くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "暗闇の中、懐中電灯の光がカッと灯り、周囲を照らし出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "遠くで花火がカッと上がり、夜空に一瞬の彩りを添えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その言葉使いの野卑で憎らしかったには、傍で聞いている子供心にもカッと腹が立った。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "制服、私服の警官隊が四人、前後からドカドカッと入って来た。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに小さな五六人の人かげが、何か堀り出すか埋めるかしてゐるらしく、立ったり屈んだり、時々なにかの道具が、ピカッと光ったりしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆んど同時に、陳長財の手元にもニッケル鍍金のものがピカッと光った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに小さな五六人の人かげが、何か掘り出すか埋めるかしているらしく、立ったり屈んだり、時々なにかの道具が、ピカッと光ったりしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄かにカッと明るくなった。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体どこへ行くのやら、向うに一本の杉がある、ちらっと頭をあげたとき、俄かに豚はピカッという、はげしい白光のようなものが花火のように眼の前でちらばるのを見た。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして吉田はうっかりカッとなってしまって、「もうそれ以上は言わん」　と屹と相手を睨んだのだった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに小さな五、六人の人かげが、何か掘り出すか埋めるかしているらしく、立ったりかがんだり、時々なにかの道具が、ピカッと光ったりしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、歯にカッと辷って、脣を決明果のごとく裂きながら、咽喉へはずれる、その真中、我と我が手に赤熊が両手に握って、「ううう、うう！",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その向うの一そう烈しいかげろうの中でピカッと白くひかる農具と黒い影法師のようにあるいている馬と、ファゼーロかそれともほかのこどもか、しきりに手をふって馬をうごかしているのをわたくしは見ました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしがしっかりのみ込みました」　その時です、お月さまがカブンと山へおはいりになって、あたりがポカッと、うすぐらくなったのは。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂田は毎夜傍に寝て、ふと松本のことでカッとのぼせて来る頭を冷たい枕で冷やしていた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鈴子は小郷の部屋へ呼ばれたんだな」　そう思うと、鶴雄はふと激しい嫉妬に燃えて、カッと天井を睨み上げた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鶴雄は本当にカッとした。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――で、断られてカッとなったんですか」「そうでしょうね。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹吉は、カッと拳銃の先を見つめながら、「射て！",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝでおど／＼している様では俺もおしまいだと思うと眼の前がカッと血色に燃えて、用って何もありません、唯歩いているだけです。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性の肢態の動きを想わせる軽薄なテンポに咄嗟に、巴里楼の広間で白いイヴニングをきて客と踊っていた妓の顔を想い出し、カッと唇をかみしめながらキャバレエの中にはいった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして……私の後継ぎにはやはり音丸という子供が来ると……」　私は思わずカッと耳まで赤くなった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう気が付くと同時に私は思わずカッとなった。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前を見舞いに来たんだ」　私はイヨイヨカッとなった。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一突きで、カッとなるか涙をぽろっと滴すかの悲惨な界の気持にまで追い込められた硬直の表情で、鼈四郎はチャブ台の前に胡坐をかいた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もじもじしているうちに、カッと癇癪が起って来た。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊達騒動の講釈や芝居で、むやみに甚い悪者にされて居る原田甲斐は、其の実｜兇悪な者では無い、どちらかと云えばカッとするような直情の男だったろうと思われるが、其の甲斐は即ち此の宗時の末だ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其間に氏郷は印籠から「西大寺」（宝心丹をいう）を取出して、其水で服用し、彼に計謀あれば我にも防備あり、案ずるな、者共、ハハハハハハ、と大きく笑って後を向くと、西大寺の功験早く忽ちにカッと飲んだ茶を吐いて終った。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたならで誰とゝ云れてカッと赤面し、乾きたる舌早く、御亭主こそ冗談は置玉え、私約束したる覚なし。",
              "citation": {
                "source": "風流仏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　浄瑠璃の行われる西の人だったから、主人は偶然に用いた語り物の言葉を用いたのだが、同じく西の人で、これを知っていたところの真率で善良で忠誠な細君はカッとなって瞋った。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　夫人と……別れたあとで、主税はカッと障子を開けて、しばらく天を仰いでいたが、「ああ、今日はお妙さんの日だ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉桜を洩れた六月の陽が、カッと、その上に照りつけていた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "flying into a rage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "信号無視した車を見て、思わずカッと頭に血が上ってしまったよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "待ち合わせに遅刻した彼に、彼女はカッと顔を赤らめて怒鳴った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供がわざと困らせるようなことを言うから、カッと怒っちゃったじゃないか！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "opening suddenly and widely (e.g. eyes, mouth)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "突然の大きな音に、子供たちは目をカッと開けて固まっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "驚いて、彼の口はカッと開いたまま、声も出なかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "鏡を見て、顔色がSuddenly悪くなっていることに気づき、目をカッと見開いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 4,
        "gloss": "acting resolutely",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "迷ってる暇なんてない、カッと決心して、このチャンスを掴みに行こう！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "失敗してもいいんだ。カッと勇気を出して、新しいことに挑戦してみよう！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "状況は厳しいけど、ここで立ち止まるわけにはいかない。カッと状況を打開するぞ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
    ],
