  {
    "uuid": "5833aafc-d16e-57f7-b77d-cba5c0edebd6",
    "entry": "カット",
    "reading": {
      "primary": "カット",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cut",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この固い肉は、よく切れるナイフでカッと切らないと食べにくいね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "厚紙をカッと切って、工作の土台を作ろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "髪を少しだけカットしてもらったけど、ほとんど変わらないかな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "いや、コンネクテカット州だ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この過程と、映画の一つ一つのカットの連続を見てその一つのシーンの内容を理解する過程とは大体において同じようなものである。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画の一つのカットの内容はそういう練習を待たずに直接に視覚的に頭の中に飛び込んで来るのであるが、その代りその「意味」といったようなものは非常に複雑なもので、多くの場合に一と口では云われないようなものが多い。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから映画のカットはむしろ一つの文章である。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "展覧会場では、この二つの頂点の処の肝心な数コマが白紙で蔽われて「カット」されていたことからしてみると、相当に深刻な描写があって人間の隠れた本能を呼びさますものがあるものと見える。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "全十二巻の詞書というものを売っていたので買ってみると、詞書の上段に若干の画面の写真版が並んでいて、その中には上記のカットされたもののうちの二、三があるので大抵の想像が出来る。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（以上一カット）　げっそりした三次、その儘行き出すと、勝坊は懐かしげに三次の袖をつかんで付いて来る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "両者カット・バックよろしく。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（半次と拍子木のカットバックよろしく、追々急速になって遂に、フラシュバックになった時）　拍子木チョンチョンチョンチョン……で幕が開いたらしい。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上のカットバック追い追い急激に物凄きスピードとなり、結局――　＝五郎蔵の家の表　バラバラと半次の一行、飛び込んで行く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（両者カットバック適当に）　＝柳島の妙見――　見張の児分「来た！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝走る馬　カットバック、若干。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "カットバック、若干。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くワイワイ騒いでる群集（五、六カット程で）カメラ近寄ってその人垣の中から悲鳴が聞える。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅びた主家の家臣らが思い思いに離散して行く感傷的な終末に「荒城の月」の伴奏を入れたのは大衆向きで結構であるが、城郭や帆船のカットバックが少しくど過ぎてかえって効果をそぐ恐れがありはしないか。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一にはカットからカット、場面から場面への転換の呼吸がいい。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甦生した新しい茂兵衛が出現して対面してから、この思い出す瞬間までのカットの数が少しばかり多すぎるから思い出しがわざとらしくなるのではないか。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの間隔をもっとつめるか、それとも、もっと「あわただしさ」を表象するような他のカットの※入で置換したらあの大切なクライマックスがぐっと引き立って来はしないかと思われる。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "田園調布のアパートの二部屋を借りて、一つは居間、一つはアトリエに使っていて、田島は、その水原さんが或る画家の紹介状を持って、「オベリスク」に、さし画でもカットでも何でも描かせてほしいと顔を赤らめ、おどおどしながら申し出たのを可愛く思い、わずかずつ彼女の生計を助けてやる事にしたのである。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一ページには十七字集と題して、幼稚な、しかし美しい夢に満ちた俳句が、紫鉛筆や普通の鉛筆でかき並べてあって、その終わりの余白には当時はやった不折流のカットがかいてある。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆるカットバックの技巧で過去のシーンを現在に引きもどすことが随意にできるのもおもしろくないことはないが、これは言わば「フィルムの記憶」の利用であって、人間の脳の記憶の代用に過ぎない。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局トーキーの中のただ一片のカットを見物したと同じに、興味はただそれだけで泡のように消えてしまうのである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "単にフィルムの断片をはり合わせるだけで、一度現われたと寸分違わぬ光景を任意にいつでもカットバックしフラッシュバックすることもできる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花は剪刀でカットされた後に空間的モンタージュを受ける。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアノの鍵盤とピアノの音とが、銅鑼のクローズアップとその音とに交互にカットバックされるところなどあったように記憶する。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者が姫君を診察するとき、心臓の鼓動をかたどるチンパニの音、脈搏を擬する弦楽器のピッチカットもそんなにわざとらしくない。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
