[
  {
    "uuid": "5bcdb35f-4441-5e4d-b506-2c0b57459d53",
    "entry": "彼",
    "reading": {
      "primary": "かれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "代名詞"
      ],
