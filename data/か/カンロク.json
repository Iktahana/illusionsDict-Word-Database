          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はまだ三十代だが、大企業のCEOを務めるだけあって圧倒的な貫禄を漂わせている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ベテラン俳優が舞台に登場した瞬間、その貫禄に圧倒されて会場の空気が一変した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長年この道一筋でやってきた職人の背中には、言葉を超えた貫禄が備わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "部長は厳しいが、いざという時に部下を守るその姿勢にはリーダーとしての貫禄がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いわば、首席の貫禄がないのだった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに映り出る青年があまりに若く美しくして先生と呼ばれるに相応しい老成した貫禄が無いことを嘆いた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば、その鬱情を乗り移らせるのに勢ひ大きな、貫禄のありさうな漢字を好んで書いたものであつたらう。",
              "citation": {
                "source": "私の書に就ての追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今までやつた美術品にしても工芸品にしても、一流の定評のあるものばかりで、多分に冒険性を含んだ野心家の「試み」をやられては、折角築き上げて来た芸館の一流品展観所としての貫禄を少からず損ずると、支配人が急に主張し出したといふことも仲介者は伝へた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家附き娘だけあって、貫禄はあるし、どこから見たって立派な奥さんだわ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十四歳で死したるかれには、大作家五十歳六十歳のあの傍若無人のマンネリズムの堆積が、無かったので、人は、かれの、ユーゴー、バルザックにも劣らぬ巨匠たる貫禄を見失い、或る勇猛果敢の日本の男は、かれをカナリヤとさえ呼んでいた。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本画家、洋画家、彫刻家、戯曲家、舞踏家、評論家、流行歌手、作曲家、漫画家、すべて一流の人物らしい貫禄を以て、自己の名前を、こだわりなく涼しげに述べ、軽い冗談なども言い添える。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまたこの家の主人に対して先輩たる情愛と貫禄とをもって臨んでいる綽々として余裕ある態度は、いかにもここの細君をしてその来訪を需めさせただけのことは有る。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」背後のドアをそっと細めにあけ、舞台を覗いて、「何か、こう、貫禄とでも、いったようなものが在りますね。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」背後のドアをそつと細めにあけ、舞台を覗いて、「何か、かう、貫禄とでも、いつたやうなものが在りますね。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨今ますます青森県の重要人物らしい貫禄を具えて来ました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "額も顎も両の手も、ほんのり色白くなったようで、お化粧が巧くなったのかも知れないが、大学生を狂わせてはずかしからぬ堂々の貫禄をそなえて来たのだ。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば首席の貫禄がなかったのだ。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "年齢から云っても貫禄から云っても、もちろん子路が彼等の宰領格である。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現下の時局に処する玄洋社一派の主義主張について色々な質問を受けたり議論を吹っかけられたりしたが、頭山満はもとより一言も口を利かないし、奈良原到も、今度はこっちから理窟を云いに来たのではない、諸君の理窟を聞きに来ただけじゃ……と睨み返して天晴れ玄洋社代表の貫禄を示したのでイヨイヨ尊敬を受けたらしい。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば首席の貫禄がなかったのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがは天下の執権、ご威勢もさることながら、おのずからに備わるご貫禄もまたあっぱれでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "越後から米つきに頼まれたんじゃあるめえし、こんなちゃちな詮議にのこのことお出ましになりゃ、貫禄がなくなりますよ、貫禄がね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろに若侍をふたり従えて、眼のくばり、体のこなし、おのずから貫禄品位の見える老武家です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "年のころは五十かっこう、今がいちばん分別盛りな年配も年配でしたが、諸家諸侯にも出入りのかのう身分がそうさせたものか、さすがに貫禄品位じゅうぶん、丁重いんぎんに両手をつくと、そらさずにいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ジロリとやって貫禄豊かに、のうこりゃ下郎、とやりました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも長門、犯信ゆえに栄誉ある大阪城代の職を過ったとは言え、さすがに名家の末裔、横紙破りの問題起した風雲児だけのものがあって、態度、おちつき、貫禄共に天晴れでした。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "千二百石直参旗本の貫禄を肱枕にのせて、長々とそこに横たわりながら、やがて弾き出した琴の音に聴き入りつつ、目を細めつつ、京弥菊路のふさわしい一｜対を眺めつつ、出来るものなら生れ代って二日か三日主水之介になりたい位でした。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「許せよ」　駕籠から降りて鷹揚にいいながら、ずいと店先へはいっていったものでしたから、男まえといい、貫禄といい、番町あたりの大旗本とでも目きき違いをしたのでしょう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これは余談ですが、人はやはり身に備わった芸技と、その命運の示すところに左右されるものとみえて、りっぱなお直参にもなれる身分でありながら、断然江戸錦は関取修業をつづけ、のち三年にして関脇の栄位を修め、恰幅貫禄ならびにその美貌から、一世の人気をほしいままにしたということでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "長脇差の親分じみた、色の黒い、デップリとして貫禄のある田宮氏は、褞袍のまま紫檀の机の前に端然と坐って、朝日を吸い吸い私の話を聞いてくれたが、聞き終ると腕を組んで、傍の宇東記者をかえり見た。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "corpulence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
