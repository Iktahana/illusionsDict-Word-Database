        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "寝起きに大きくあくびをして、全身の体を伸ばした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "運動の後は、クールダウンとしてゆっくりと体を伸ばすことが大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長時間座っていたので、立ち上がってぐーっと体を伸ばし、凝りをほぐした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "猫は気持ちよさそうに背中を丸めたり、体を伸ばしたりしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "赤くなった腕をさしのべて風呂いっぱいに体を伸ばすと、ふいと女らしくなって来る。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のランニングシャツはうすねずみ色に汗と垢がしみついており、体を伸ばす度に、たくましい皮膚と脊柱がみえた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が突出部に足をかけて体を伸ばすと、顔が木の頂より高くなったので、枝に残っている茶色に光る手の跡がよく見えた。",
              "citation": {
                "source": "予謀殺人",
                "author": "A CASE OF PREMEDITATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとレーニは弁護士の上にしなだれかかったが、このように身体を伸ばすと、彼女の美しく発育した身体がはっきりと見えるのだった。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
