  {
    "uuid": "8766e94e-edb5-5fae-871e-dd0a276abbb4",
    "entry": "枸橘",
    "reading": {
      "primary": "からたち",
      "alternatives": [
        "きこく",
        "カラタチ"
      ],
      "is_heteronym": true
    },
