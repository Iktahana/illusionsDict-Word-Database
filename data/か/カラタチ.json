    "definitions": [
      {
        "index": 1,
        "gloss": "trifoliate orange (Citrus trifoliata)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "冬の冷たい風の中、枸橘の生け垣だけが青々とした葉と鋭い棘を保っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母の家の庭には、子供の頃からあった枸橘の木があり、春には白い花を咲かせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この辺りでは、防犯対策として枸橘を庭の境界線に植える家が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "薄きたない白が、尾を垂れ、歩くにつれて首を揺り乍ら、裏のすきだらけの枸橘の生垣の穴を出入りした姿が今も遠い思い出の奥にかすんで見える。",
              "citation": {
                "source": "犬のはじまり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "江南の橘は江北に行けば枸橘となると云ふやうなもので、其土地に依つて形は變つて來るが原則は同じことである。",
              "citation": {
                "source": "日本の眞の姿",
                "author": "竹越與三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖堂を出るとき石段で転んで、眼のまわりをそんなにし、また枸橘の垣根で頬をひっ掻いたといった。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "からたちの垣根萩原朔太郎からたちの垣根の中に女のはしやぐ聲のする夕餉の葱のにほひする灯ともしごろからたちの垣根を過ぐる侘しさよ。",
              "citation": {
                "source": "からたちの垣根",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣りのからたち寺の樹立、これだけは昔のままらしい。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電柱の雀がからたち寺へ飛んで行く。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴんちょぴんちょ、たちからたちから。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからたちまち闇が戻されて眩しい花の姿は消えましたので、ガドルフはせっかく一｜枚ぬれずに残ったフラン［※５］のシャツも、つめたい雨にあらわせながら、窓からそとにからだを出して、ほのかに揺らぐ花の影を、じっとみつめて次の電光を待っていました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はレインコオトの襟を立て、池の縁にあるからたちの垣根の前にぼんやり佇んだが、すぐに電車道に沿って色の褪せた博覧会の正門の方から、洋傘を阿弥陀に傾けながら、私の方へ向かって歩いて来る我がミハエルの姿が目に入った。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸車のお家とめくらのじいさんちの間に、からたちの垣根を結んじまったから。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "からたちは、灌木である。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道のそばには野茨の赤い実が玉を綴ればからたちの黄色い実が刺の間にまんまろく挟まつてゐる。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳河女学校にて額髪の笑ふ女童このごとくあどなきものを恋ふとありにし我老いぬただに愛しき額髪の面あげてあるその子ら見れば夏ごろも匂ふ少女は朝ひらくからたちの花と清しかるべし中学伝習館にて我、中学伝習館を学業卒へずして去りぬ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、ニューヨーク市では、「一｜分早ければ一｜人多くたすかる」という標語をかかげて、市民の間からたちまちに一千万円以上のお金をつのっておくりとどけました。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "官能は、鮮緑色と菫色との火のあまたのぎらぎらしゆらゆらしている焔と共に、回旋した奇妙な香炉からたちのぼる、互にまじりあって争っている薫香に、圧せられた。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくよく原因を聞いてみると、今の持ち主が高利貸で、家賃をむやみに上げるのが、業腹だというので、与次郎がこっちからたちのきを宣告したのだそうだ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸子は學校でも家でも「からたちの唄」や「カナリヤの歌」なぞと一緒に、その歌を意味も分らずに、何處ででも歌つた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　窓下の丁字の花がはつきりと香つて来る薄雲りの晩に、森と青野が、町端れの音田の部屋でトランプ合戦に耽つてゐると、からたちの生垣の向ふで、「音チ、居るか？",
              "citation": {
                "source": "まぼろし",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "市区改正や区劃整理で、からたちもだんだんに東京市内から影を隠して来たが、それでも場末の屋敷町や、新東京の住宅地などには、その生垣をしばしば見受ける。",
              "citation": {
                "source": "亡びゆく花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも文化式の新しい建物などで、からたちの垣を作っている家は殆どない。",
              "citation": {
                "source": "亡びゆく花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "からたちの垣をめぐらしているのは、明治時代かあるいは大正時代の初期に作られたらしい旧式の建物に限るようである。",
              "citation": {
                "source": "亡びゆく花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺も杉や柾木やからたちをめぐらしているのは新しい建築でない。",
              "citation": {
                "source": "亡びゆく花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するにからたちは古家や古寺にふさわしいような、一種の幽暗な気分を醸し成す植物であるらしい。",
              "citation": {
                "source": "亡びゆく花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "からたちの生垣のつづいているような場所は、昼でも往来が少い。",
              "citation": {
                "source": "亡びゆく花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その薄暗い中に、からたちの花が白くぼんやりと開いている。",
              "citation": {
                "source": "亡びゆく花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句にもからたちの花という題があるが、あまり沢山の作例もなく、名句もないようである。",
              "citation": {
                "source": "亡びゆく花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "からたちは木振りといい、葉といい、花といい、総ての感じが現代的でない。",
              "citation": {
                "source": "亡びゆく花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらのからたちもやがては抜き去られてトタン塀や煉瓦塀に変るのであろう。",
              "citation": {
                "source": "亡びゆく花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "からたちで有名なのは、本郷竜岡町の麟祥院である。",
              "citation": {
                "source": "亡びゆく花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの春日局の寺で、大きい寺域の周囲が総てからたちの生垣で包まれているので、俗にからたち寺と呼ばれていた。",
              "citation": {
                "source": "亡びゆく花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
