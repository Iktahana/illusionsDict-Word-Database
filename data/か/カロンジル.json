[
  {
    "uuid": "e8d2051c-88cb-57bf-bdb7-b7cf47ae7672",
    "entry": "軽んじる",
    "reading": {
      "primary": "かろんじる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
