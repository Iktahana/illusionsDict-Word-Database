      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to look down on",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は自分の経験を軽んじすぎて、新しいプロジェクトで失敗を繰り返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「そんな些細なことと軽んじてはいけない。それが後に大きな問題を引き起こすこともある。」と先輩は諭した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "若手社員は、ベテランの意見を軽んじる傾向があり、チームの雰囲気が悪化していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、周囲の反対を軽んじるように、独自のスタイルを貫き通した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「堂々たる男子が、何故生を軽んじる、事情があるなら商量にあずかろうじゃないか」　そこには法海禅師が背に衣鉢を負い手に禅杖を提げて立っていた。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "「堂々たる男子が、何故生を軽んじる、事情があるなら商量にあずかろうじゃないか」　法海禅師が背に衣鉢を負い手に禅杖を提げて立っていた。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうであれば小さな事をするにおいて小さな事だと軽んじるのは、自分の心を尊ばない基なのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本にも佐藤氏の『山相秘録』のような書があって、鉱山を鑑定するのに望気の法ですることを説いたものもあり、また実験を重んじて学説を軽んじる実際家の鉱山師等は今｜尚望気の秘伝に拠って山を判断しているのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと形式は軽んじるようなものではない。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "形式は精神に比べてこそ下であるが軽んじるべきではなく、形式は精神の拠りどころで在って、形式を離れて精神が存在する筈も無く、また精神を別にした形式の存在も無い。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "壱岐が来よったから、軽輩に、馬の稽古させて、騎銃隊を作るのだと申したら、軽輩が大勢馬上で、拙者らが徒歩で、もし出逢った時には、一々下馬して通りますか、それとも乗打ちしますか、たださえ、上を軽んじる風が現れた折、考えものだ、と、申しおったが、何うじゃ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日々々と、ひとりでに軽んじる気持になっていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう言つても、役者を軽んじるのではない。",
              "citation": {
                "source": "若手歌舞妓への期待",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "近時ジャーナリストの喧声はややもすれば学園を軽んじるかに見える。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生にして学窓への愛とほこりとを持たぬことは自ら軽んじるものである。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この後の方の見解は哲学を例の思想の科学だと云ったあの科学的な性質をば哲学に就いて軽んじるものであって、つまり哲学とただの世界観的常識との区別を抹消して了うものだから、今は一顧の価値も有たない。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘーゲルは組織に対して方法を軽んじるが、体系と方法とは対立するものではなくて単なる裏表にすぎない。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だがこのことは、自然弁証法や史的唯物論が持っている科学の実際的な方法としての意義を、少しでも軽んじるということではない。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "議会に於けるデモクラシー的（社会学的）多数が、社会に於ける社会科学的大衆と、直接の連関があるという単なる一個の事実を、決して軽んじることは出来ぬと云うのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして文化問題は社会層の意識の自由な表現を無視出来ないのだから、この困難は決して軽んじることは出来ないのである。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し之に対して、福沢諭吉が結局啓蒙家に過ぎなかったからと云って、その文化史上の意義を軽んじることは出来まい。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら農村問題を少しでも軽んじるならば、それだけ社会問題即ち労働問題が、発生する特殊な因縁だったからだ。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "その自由の人民を指して「非国民」であるとののしるがごときは、人間の基本人権を軽んじるものである。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど彼は、ひとたび師と仰いだからにはと、そういう自分の性質に合わない点までも、常に、謹んで聞き、かりそめにも、それを以て、師を軽んじるようなことはなかった。",
              "citation": {
                "source": "剣の四君子",
                "author": "小野忠明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、決して、朝命を軽んじるわけではないが……。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに自分の嫡男であろうと、こういう暗愚を見せられたら、家臣たちもおのずと氏真を軽んじるであろう。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、主君のためにはいのちを鴻毛より軽んじる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――決して秀吉を軽んじる気ではないらしいが、土岐一族の名門という自尊と、また、実世間の体験や新時代の教養をも兼ね備えた知識人とみずからゆるしている自負が自然、（君は愛すべき男だよ）　というような、何とはなく、彼を下に見る態度にどこか現われて来るのだった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大将、馬相を観る目がないな）　若い忠興はふと軽んじるような念を抱いたが、いつか佐和山城内で、父の藤孝から懇ろに諫されたことばを思い出して、（いやそう見ては、自分こそ、人を観る目がない者かも知れぬぞ）　と、すぐ、自己を戒めて、駄馬に乗って行く秀吉の姿を見送っていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのせいもあろう、今も、彼のまわりにいる円満の家士はみな、（巌流様――）　とか、（先生）　とか、敬って、新参の師範とはいえ、軽んじるふうは誰にも見えなかった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "君がいたずらに人を軽んじるから一言｜酬いたのだ。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大事におうては身を惜しみ、小利をみては命も軽んじるという質だ。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "韓猛という男は、ちょっと強いが、神経のあらい男で、すぐ敵を軽んじるふうのある部将だ。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生のこれへ来られたのは何事ですか」　しかし劉璋は、彼を軽んじることなく、堂上に請じて、大賓の礼をとった。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
