        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "神社の鳥居の笠木は、長年の風雨に耐え、色が少し剥がれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "宮大工は、新しい鳥居の笠木を丁寧に削り、滑らかな曲線を作り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "参拝者は、鳥居の笠木をくぐり、清々しい気持ちで境内へと足を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
