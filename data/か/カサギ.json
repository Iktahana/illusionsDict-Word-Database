          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "石垣の上に、雨水が浸透しないように笠木が設けられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庭の塀の笠木が古くなり、新しいものに交換することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "神社の鳥居の最上部にある横木は笠木と呼ばれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "飛びもしないのに、おやおやと人間の目にも隠れるのを、……こう捜すと、いまいた塀の笠木の、すぐ裏へ、頭を揉込むようにして縦に附着いているのである。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そうすると、見失った友の一羽が、怪訝な様子で、チチと鳴き鳴き、其処らを覗くが、その笠木のちょっとした出張りの咽に、頭が附着いているのだから、どっちを覗いても、上からでは目に附かない。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "角力は五日間首尾能く打って帰る時に、　花「鳥居の笠木を落したから、旦那様鳥居を上げて下さらんでは困る」　と云うので惣次郎が金を出して鳥居を以前の通りにしました、其の鳥居は只今では木なれども花車の納めました石の鳥居は天神山に今にあります。",
              "citation": {
                "source": "真景累ヶ淵",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからこいつが轆轤座、切梁、ええと、こいつが甲板の丑、こいつが雇でこいつが床梁、それからこいつが笠木、結び、以上は横材でございます」　ポンポンポンといい上げてしまった。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやはうしろへよろめいて膝を突き、庄兵衛は笠木塀のほうへ歩み寄った。",
              "citation": {
                "source": "十八条乙",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、木戸になっている笠木のない部分へ手を掛けると、それを外へ乗り越えようとした。",
              "citation": {
                "source": "十八条乙",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤巻という家はあった、古びた黒い笠木塀をめぐらせた小さな構えで、門からひと跨ぎの処に玄関が見える、宗吉はいちど通り過ぎて戻り、思いきって玄関に立った。",
              "citation": {
                "source": "金五十両",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両家の庭境は笠木塀になっているが、一部だけ柾木の生垣のところがある。",
              "citation": {
                "source": "艶書",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……またそこを西へ下り、かこいの笠木塀を越えると、一段ずつ果樹畑とか菜園などがあって、いちばん下は小さな流れのある谷底のようになっている。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若君は笠木塀を乗り越えるとき泣きそうになり、台地を跳び下りるとき膝を擦剥いた。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白くなったらしい、笠木塀を乗り越えるのも、台地を跳び下りるのも、番人が来たときの隠れ方も、だんだんいたについてきたし、自分でも流れにはいってしゃくうようになった。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "笠木塀を乗り越えるときの泣きそうな顔や、浅草界隈の話をしたとき、さも羨ましそうに、　――そこへは若もいけるの。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "笠木塀を隔てた向うは、小者長屋と馬役の小屋が並び、そのうしろに厩がある。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもときどき、思ひ出したやうに、甚だ散文的な口調で、あれが三ツ峠、向ふが河口湖、わかさぎといふ魚がゐます、など、物憂さうな、呟きに似た説明をして聞かせることもある。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……遅めの午飯に、――潟で漁れる――わかさぎを焼く香が、淡く遠くから匂って来た。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケエブル・カアで登つて行つて見れば、山上には榛名湖のやうなところがあつて、鯉、鮒、さてはわかさぎなぞの養へるほどな水を湛へながら、田畠を開拓しようにも灌漑の方法もなく、熱い温泉をうめる水もないとは、不思議なくらゐのところだ。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟の人唄を唄へばいと寒き夢かと思ふ湖畔亭かな　わかさぎ釣の舟でもあらう、舟の男が唄を唄ひ出したので湖畔亭の平静が破れ、初めて生命の躍動が感ぜられた、それはしかし寒い夢でも見てゐる以上のものではなかつた、その位春とはいへ山の上は寒かつたのである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "驛前の露店にてわかさぎ佃煮を買ふ。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も此れは其の後の話だが、島の次郎八と云う漁師が、或朧月の夜｜晩くわかさぎを漁して帰る時、幽かに聞いた歌の声が、全くお光の声の様で、耳を澄して聞くといよいよ夫れに違いない様だから、次郎八は声をしるべに舟を漕いで行くと、何処まで行っても茫々とした朧月夜の湖で、人の影もない。",
              "citation": {
                "source": "漁師の娘",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あたい、麩なんかぐにゃぐにゃしていや、塩からい、わかさぎの乾干がつっつきたいんですもの、くたびれちゃった。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてわかさぎの乾干をやるよ。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「指してゆくかさぎの山を出でしより天が下にはかくれ家もなし」この和歌は、昔から尊王主義者の敬誦する和歌である。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
