        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お祭りの屋台で買った紙風船を、小さな弟と交互にポンポンと突き合って遊んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖母の家の古い引き出しから、懐かしい色合いの紙風船がいくつか出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ほら、あんまり強く叩きすぎると紙風船が潰れちゃうから、優しくね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ふっと息を吹き込むと、しわくちゃだった紙風船が丸く膨らんで鮮やかな縞模様を見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「人情紙風船」が山中貞雄の遺作ではチトサビシイ。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "里子を預かるくらいゆえ、もとより水呑みの、牛一頭持てぬ細々した納屋暮しで、主人が畑へ出かけた留守中、お内儀さんが紙風船など貼りながら、私ともう一人やはり同じ年に生れた自分の子に乳をやっていたのだが、私が行ってから一年もたたぬうちに日露戦争がはじまって主人が出征し、畑へはお内儀さんが出た。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんじゅうの前に動いた私の心の惰性は、ついその隣の紙風船屋へ私を導いて、そこで私に大きな風船玉を二つ買わせた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんじゅうを食う事と、紙風船をもてあそぶ事との道徳的価値の差違いかんといったような事を考えながら、また子供の手をひいて暮れの銀座の街をぶらぶらとあてもなく歩いて行った。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "国際紙風船倶楽部　世界各国の紙風船の愛好家の集りに、国際パン倶楽部といふのがあつた、倶楽部では四年目毎に、各国順番で総会を開らくことになつてゐた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "第×回国際パンクラブ総会が開かれた、フランスからやつてきたクラブ員は、紙風船を手にして壇上に立つた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か御礼をしたい気持ちでいつぱいなんですが、思ひつきがなくて、――出発の前夜、銀座で買つた紙風船を一つ贈物にしました。",
              "citation": {
                "source": "シベリヤの三等列車",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙風船は影の薄い東洋人にばかり似合ふのかと思ふと、このロシヤのお婆さんにもひどくしつくりと似合ひました。",
              "citation": {
                "source": "シベリヤの三等列車",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　先日ラヂオで拙作「紙風船」を放送した。",
              "citation": {
                "source": "「文壇波動調」欄記事",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "『紙風船』について岸田國士　この作は、順序としては私の第四作である。",
              "citation": {
                "source": "『紙風船』について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達の一団は、紙風船を貼っているのである。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うの隅で、麻の糸つなぎをやっている囚人たちは、絶えず視線をチラリチラリと紙風船の作業場へ送って、快い昂奮を貪るのであった。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙風船の作業は、一番初めに、あの花びらのような材料の組み合わせを作る。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず五十嵐の方が、二つに折られて来た紙風船をとって、いきなりこのフットボールの上にパッと被せる。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで紙風船の作業は終った。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは五十嵐が、出来上った紙風船を、お椀を積むように、ドンドン積み重ねてゆく。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、まるで鼓を打っているように、紙風船の肛門を貼ってゆくのであった。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へえ、これだけ出来ています」　私はその紙風船の花びらの束を解いて、パラパラと引繰りかえしていたが、「おい、一枚足りないぞ」「え？",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は柿色の花びらのついた紙風船が、もう来るか来るかと、首を長くして待った。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（あ、来たぞ）柿色の紙風船は、遂に私たちの方に廻って来た。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそこに千番に一番のかねあい……というほどでもないが、糊のついたところに例の裸のラジウムをくっつけるが早いか、その方を下にしてポーンと柿色の紙風船に貼りつけたのであった、つまり鉛筆の芯の折れほどのラジウムは、紙風船の花びらと尻あてとの紙の間に巧みに貼り込まれてしまったのだった。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十嵐はその柿色の紙風船に見向きもせず、腕をサッと横に伸ばして今まで出来た紙風船の上に積みかさねた。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへお誂え向きに検査係が来て、その一と山の紙風船を向うへ持っていった。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてラジウムは、柿色の紙風船の中に入ったまま、私の手を離れていったのだった。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、紙風船が欲しいのですがネ、すこし注文があるので、一ついろいろ見せて下さい」「よろしゅうございます。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――紙風船といいますと、こんなところで……」　と小僧さんは指さした。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのことだ、私の坐った膝の前、あの懐しい紙風船が山と積まれているのだ。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
