    "definitions": [
      {
        "index": 1,
        "gloss": "to stoop",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "落とし物を拾うため、彼はそっと屈んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の目線に合わせて、先生は優しく屈んで話しかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重い荷物を持ち上げる際、腰を痛めないように一旦屈むと良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "狭い通路を通るため、彼は頭を下げて屈んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "紺服の役人はメリケン粉のからふくろを手に団子のように捲きつけていましたが少し屈むようにしました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて四阿の向うに来ると、二人さっと両方に分れて、同一さまに深く、お太鼓の帯の腰を扱帯も広く屈むる中を、静に衝と抜けて、早や、しとやかに前なる椅子に衣摺のしっとりする音。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺服の役人はメリケン粉のからふくろを手に団子のやうに捲きつけてゐましたが少し屈むやうにしました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と風流に屈む柳腰。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "息杖で背後へ反っくり返るのと、楫棒を握って前のめりに屈むんじゃ、から、見た処から役割が違いやさ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　密と、下へ屈むようにしてその御神燈を※すと、他に小草の影は無い、染次、と記した一葉のみ。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱の蔭に成つて居た髮が前へ屈む度にともし灯の光に觸れる。",
              "citation": {
                "source": "菜の花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　慌てて彼の見向く途端に、「些と」と戸口より半身を示して、黄金の腕環の気爽に耀ける手なる絹ハンカチイフに唇辺を掩いて束髪の婦人の小腰を屈むるに会へり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "思わず立ち上がった私は、鏡台の前へかけよると、屈むようにして、改めてあたりの様子を見廻わしたのでございますが、抽斗の前の畳の上に投げ出された黄楊櫛には、なんと旦那様のお手に握られていたのと全く同じ髪の毛が三、四本、不吉な輪を作って梳き残されておりました……。",
              "citation": {
                "source": "幽霊妻",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後から抱えられて、グサリと突き立てられたとき、屍体には、屈むのと、伸びる反射運動とが連続して起るのだ。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（同右☆☆）６　バルベックのグランド・ホテルへ二度目に行つた時、彼は彼の靴のボタンをはづさうとして屈む。",
              "citation": {
                "source": "續プルウスト雜記",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "主「何うも女は美いが歩きつきが悪いな、ちと屈む癖があるから反らせるが宜い、お前烟草を人に付けて出すのに、それでは色気がない、斯うすると宜い」　と教えて貰う。",
              "citation": {
                "source": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "author": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、聴きとがめたが、まさか、まだ、三郎兵衛が、先き潜りをしているとは、思わぬ浜川平之進、左に刀を抱いて、「下りる――穿きものを――」　と、垂れを自分で上げかけたとき、「へ、お穿きもの――」　妙に、掠れた、笑うような、ばけ物ごえで言った三郎兵衛、かごに引ッついて屈む。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論丈も高くなつて、屈むに及ばない。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、彼女に折れ屈むことを教えて置かなければいけない。",
              "citation": {
                "source": "理想の女",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と君江はわずかに顔を擡げながら、起直りもせず、仰向きに臥たまま両腕をひろげ、木村が折屈むのを待って、ぐっと引寄せながら、「わたし、夢を見ていたのよ。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は、しばらくそれを見送っていたが、やがて屈むと、地に置いてあった線香の束を取り上げ、「どれ、それでは妾は、ちょっと道了様へ。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はなぜ、臥ている自分に、耳に口を当てて訊いてくれないものかと思ったけれど、村長は前へ少し屈むのも、またこうやって傍に付いているのも危険に思ったから、耳へ口を付けるなどは思いも寄らぬことであった。",
              "citation": {
                "source": "悪魔",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "帳場に入って主人をゆり起そうと屈むと、「生意気な真似をしやがる、赤星の野郎！",
              "citation": {
                "source": "鳩つかひ",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、烈しい風を眞正面に受けて、前へ屈むやうにして、時とすると、この突風に逆らひ、風にとられた息をつくために、口へ手を當てて、振り返らずにはゐられなかつた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "（震えながら、なおもなおも耳の上に屈む）良　三　耳が？",
              "citation": {
                "source": "宵（一幕）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』しかく陳じて影長き大槍揮りて投げ飛ばす、之をまともに確かと見て、巧みに避けしヘクトール、身を屈むれば其上を青銅の槍飛び過ぎて、　275大地に刺さる、こを拔きて私かにパラス・アテーネー、ヘクト，ルの目に觸れずしてアキルリュウスの手に渡す。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々は低く屈むような長屋根をいただいていて、巨大な灰色や赤ちゃけた色の家畜が河へ水を飲みに来るように見えた。",
              "citation": {
                "source": "サレーダイン公爵の罪業",
                "author": "THE SINS OF PRINCE SARADINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑部様は、稀代な醜男だが、屈むにも骨が折れそうな、隆々たる筋肉をそなえ、ごろ武家、ぐれ旗本をも、よく威伏せしめる金力と腕力の保有を、その風貌は実証して余りがある。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつかれにございましょう」　利三が、前に屈むと、光秀は、なにか驚いたように、面を向けて、「利三か。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は柵の下へかがむ。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の気の神処の澄み、岩が根の言問ひ止み、かいかがむ荒素膚の荒魂の神魂び、神つどへる水上は思ふべきかな。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄あかり、かがむ童もなにかよき鮎の色沢あり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣り寺、寺の古墓、日あたりは未だも暑けど、墓掃くとかがむ影すら、閼伽汲むと寄るすらも無し。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣り寺、寺の古墓、日あたりは未だも暑けど、墓掃くとかがむ影すら、阿閼汲むと寄るすらも無し。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
