[
  {
    "uuid": "a59393fb-5cc9-5474-bb52-d5f1775fc3d4",
    "entry": "数の子",
    "reading": {
      "primary": "かずのこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
