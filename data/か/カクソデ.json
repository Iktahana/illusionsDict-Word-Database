    "definitions": [
      {
        "index": 1,
        "gloss": "square sleeves",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その羽織は、ゆったりとした角袖が特徴的で、現代的なデザインにも合わせやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古文書に描かれた人物は、角袖の衣装を身につけていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "和服の講座で、角袖の畳み方を習った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「舞妓さんの着物って、袖の形が特徴的だよね。あれも角袖の一種なのかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "かれは高野山に籍を置くものだといった、年配四十五六、柔和ななんらの奇も見えぬ、懐しい、おとなしやかな風采で、羅紗の角袖の外套を着て、白のふらんねるの襟巻をしめ、土耳古形の帽を冠り、毛糸の手袋を嵌め、白足袋に日和下駄で、一見、僧侶よりは世の中の宗匠というものに、それよりもむしろ俗か。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "込み合う雑沓の人々も、角袖の外套や手柄をかけた日本髷や下町風の男女が、目立って交っていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてそれらのすべては晝夜角袖が尾行した。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は高野山に籍を置くものだといつた、年配四十五六、柔和な、何等の奇も見えぬ、可懐い、おとなしやかな風采で、羅紗の角袖の外套を着て、白のふらんねるの襟巻を占め、土耳古形の帽を冠り、毛糸の手袋を箝め、白足袋に、日和下駄で、一見、僧侶よりは世の中の宗匠といふものに、其よりも寧ろ俗歟。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかなぞも余り男と一緒に歩いたり何かするものだから、角の交番でね、不審にしてね、角袖巡査が家の前に立っていたことがあったと云いますよ。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事がちょうど終わった時、小田刑事の部下の波多野さんが角袖でふうふう言って入ってこられましたが、私たちの姿を見てちょっと躊躇されました。",
              "citation": {
                "source": "暗夜の格闘",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私はとりあえず、品川署へ電話をかけて二人の角袖巡査にその家の見張りをさせ、ひとまず帰ってきたのでございます」「それはご苦労様。",
              "citation": {
                "source": "暗夜の格闘",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い横町で、ばたばたと後を追っ駈けて来て体を検べる二人の角袖に出逢いなどしたが、足は自然に家の方へ向いて行った。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ電報が来て帰っちゃった」　きっちり襟元を合わせて絣の角袖を着、袴をつけた吉本も一緒に、茶を飲んだ。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨も埋もるるばかり肥え太りて、角袖着せたる布袋をそのまま、笑ましげに障子の中へ振り向きしが、話しかくる一言の末に身を反らせて打ち笑いぬ。",
              "citation": {
                "source": "書記官",
                "author": "川上眉山",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草という土地がら、大道具という職業がらには似もつかず、物事が手荒でなく、口のききようも至極穏かであったので、舞台の仕事がすんで、黒い仕事着を渋い好みの着物に着かえ、夏は鼠色の半コート、冬は角袖茶色のコートを襲ねたりすると、実直な商人としか見えなかった。",
              "citation": {
                "source": "草紅葉",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如く浜町のあそびは芸者買の半分にも足らざるほどにしてしかも振られるといふ事なければ流行ること夥しく、遂に芸者組合より苦情出で内々その筋へ歎願密告せしかば大正五年四月の頃より時の警視総監西久保某といへる人命令を部下の角袖に伝へてどしどし市中の白首を召捕りけり。",
              "citation": {
                "source": "桑中喜語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い雨外套を着た職工風の男が一人、絣りの着流しに八字髭を生しながらその顔立はいかにも田舎臭い四十年配の男が一人、妾風の大丸髷に寄席芸人とも見える角袖コートの男が一人。",
              "citation": {
                "source": "寺じまの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い雨外套を着た職工風の男が一人、絣りの着流しに八字髯を生しながらその顔立はいかにも田舎臭い四十年配の男が一人、妾風の大丸髷に寄席芸人とも見える角袖コートの男が一人。",
              "citation": {
                "source": "寺じまの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日角袖か刑事みたいな人が御宅へ調べにきたことがあったそうである。",
              "citation": {
                "source": "先生を囲る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝から五六人の角袖が宅の前をあちらへ行つたりこちらへ行つたりするでないで、さうすると土手の方にも警部の様な人と巡査が二三人立つて居るんですよ。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うへえ」　五、六歩後へ退って、小手をかざして塔の上の方を見上るならば、五重塔の素ッ天辺、緑青のふいた相輪の根元に、青色の角袖の半合羽を着た儒者の質流れのような人物が、左の腕を九｜輪に絡みつけ、右手には大きな筒眼鏡を持って、閑興清遊の趣でのんびりとあちらこちらの景色を眺めてござる。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ右手の道からこれも小走りに出て来る角袖の刑事。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（鍬を振る）（すると再び揚幕から、これを追って走りでてくる角袖が七人。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（鍬を振る）すると再び揚幕から、これを追って走り出て来る角袖が七人。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから若者のつもりでは、角袖の眼をくらまそうとして、さも平気らしく、そばのお冬に声をかけて見たり、はては、からかったりしているのが、格二郎には一層腹立たしくて、悲しくて、それに又、あのお冬｜奴、いい気になって、いくらか嬉しそうにさえして、からかわれている様子はない。",
              "citation": {
                "source": "木馬は廻る",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きみの魂なんかくそでもくらえだ！",
              "citation": {
                "source": "手早い奴",
                "author": "THE QUICK ONE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
