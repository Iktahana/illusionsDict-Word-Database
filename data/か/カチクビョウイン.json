        "examples": {
          "standard": [
            {
              "text": "具合の悪い鶏を家畜病院に連れて行ったら、すぐに診察してもらえた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "近所の家畜病院は、牛や馬のような大型動物の診療も行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末は家畜病院が混むので、事前に予約した方が良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "日は向う河岸の家畜病院の頽れたる露台を染め、入口の硝子戸の前に薬塗らるる色｜黄なる狂犬を染め、隣れる健胃固腸丸の広告に苦き光を残しつつ沈みゆく。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは打ち捨てておいては危険だと思われたので、すぐに近所の家畜病院へ連れて行かせた。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夫は僕も家畜病院長を呼んで診察をして貰ひましたがな……。",
              "citation": {
                "source": "牛車",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            }
          ]
