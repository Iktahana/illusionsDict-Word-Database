    "definitions": [
      {
        "index": 1,
        "gloss": "rule allowing the clear winner of a bout to touch down first to avoid injury",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
