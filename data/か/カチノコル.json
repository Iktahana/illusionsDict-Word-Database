          "standard": [
            {
              "text": "二次試験を勝ち残り、最終面接に進むことができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの選手は、常に冷静沈着に試合を運び、最終戦まで確実に勝ち残るだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日の試合に勝ち残らないと、来週の決勝戦には行けないから、絶対に負けられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「いつかも云ったとおり、おれは野口をたのみにしている、上村も相当やるだろうが、勝負まで勝ち残るのは野口だと思う。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
