        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ちょっとごめんよ！」と、満員電車の人混みを無理やり掻き退けるようにして降りた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "生い茂る草木を手で掻き退けながら、道なき道を進んで森の奥へと足を踏み入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "机の上に山積みになった書類を横に掻き退けて、ようやくパソコンを置くスペースを作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "降り積もった雪を足で掻き退けて、埋もれていた郵便受けの蓋をやっとの思いで開けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その道筋に、夥しく沈めたる材木は、恰も手を以て掻き退ける如くに、算を乱して颯と左右に分れたのである。",
              "citation": {
                "source": "木精（三尺角拾遺）",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其道筋に、夥しく沈めたる材木は、恰も手を以て掻き退ける如くに、算を亂して颯と左右に分れたのである。",
              "citation": {
                "source": "三尺角拾遺",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "抽出しという抽出しは皆んな調べてしまったが、あとはどうするんだ」「抽出しなんかにあるものかね、お待ち」　女は男を掻き退けるようにたんすの前へ出ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手人は擧つたかい、お神樂の」　八五郎は平次を掻き退けるやうに顏を出します。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "「悪者に追っかけられたとか言って、蒼い顔をしていますよ、親分――」「馬鹿ッ、何だって冒頭っからそう言わないんだ」　平次はガラッ八を掻き退けるように、入口へ飛出して見ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "朱塗の筐",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙って見ていた平次は、ガラッ八を掻き退けるように、半蔵の側へ寄りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "殺され半蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「惡者に追つ驅けられたとか言つて、蒼い顏をして居ますよ、親分――」「馬鹿ツ、何だつて冒頭つからさう言はないんだ」　平次はガラツ八を掻き退けるやうに、入口へ飛出して見ました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "朱塗りの筐",
                "note": "青空文庫"
              }
            },
            {
              "text": "（掻き退ける）政吉　　確り縛れ。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手人は挙がったかい、お神楽の」　八五郎は平次を掻き退けるように顔を出します。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "女の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆっくり内衣嚢から巻煙草入れを取り出して、金口を一本つまみ取ると、炭の上にたまった灰を静かにかきのけるようにして火をつけて、のどかに香りのいい煙を座敷に漂わした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山口は中につまっている印度製の輝いた麦藁細工の黒象をかきのけると、お杉にひとつと思って、アメシストの指環を抜きとった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう、小母さん、退きねえ――」　と、婆やを、かきのけるように格子先を、白い目で睨んで、「おい、おまはん一てえ、どこのどなただ？",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたが安吾巷談か」　私が友人と酒をのんでいると、友人をかきのけるようにして、私に握手をもとめた酔っ払いがある。",
              "citation": {
                "source": "巷談師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それが出來なかつた、――どれ、見せてくれ」　平次は事件に觸れたくない樣子で、お秀をかきのけるやうに入りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お秀の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それが出来なかった、――どれ、見せてくれ」　平次は事件に触れたくない様子で、お秀をかきのけるように入りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お秀の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "余吾之介はその魍魎をかきのけるように、思わず二三歩引き退きました。",
              "citation": {
                "source": "十字架観音",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
