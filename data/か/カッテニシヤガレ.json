        "examples": {
          "standard": [
            {
              "text": "「何度言っても分からないなら、もう勝手にしやがれ！」と父は怒鳴り、自室にこもってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ジャン＝リュック・ゴダールの『勝手にしやがれ』は、即興演出を取り入れたヌーヴェルヴァーグの傑作だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「フン、助言を無視するっていうなら勝手にしやがれ。後で泣きついてきても知らないぞ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ジャン＝ポール・ベルモンドが演じるミシェルの奔放な生き様は、『勝手にしやがれ』というタイトルそのものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "乞食乙　――勝手にしやがれ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手にしやがれと、そっぽを向くより致し方がない。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「勝手にしやがれ。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六　相手は女だ、城は蝸牛、何程の事やある、どうとも勝手にしやがれと、小宮山は唐突かれて、度胆を掴まれたのでありますから、少々捨鉢の気味これあり、臆せず後に続くと、割合に広々とした一間へ通す。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「心臓を強くしなさいよ」とはじめは慰め励ましていたわたしが、だん／＼屈辱の憤りを感じて来て、「勝手にしやがれ」と気を短くしてしまった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "源吉は歩きながら、こんな事が分らない、そして又そこ迄行かうとしない百姓に、心から腹を立て、「勝手にしやがれ、俺ア俺アだ。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "權三　勝手にしやがれ。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやおや、鼻がまるで鍛冶屋の勝手にしやがれ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "私などであれば「勝手にしやがれ」と、突き放すところなどを、芥川は最後まで、気にしていたらしい。",
              "citation": {
                "source": "芥川の事ども",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でえ、勝手にしやがれとばかり、寝て終ったのだ。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　えい、勝手にしやがれ！",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "へん、勝手にしやがれだ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし、勝手にしやがれ……」　ようやく意識を恢復した私は腹立ち紛れに父に喰ってかかった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手にしやがれと思い思い、何だか気になるから開けてみたら、豈計らんやだ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お休みい……」「布哇でクリスマスだよオオ――だ……」「勝手にしやがれエエ……エ……だ……」「アハアハアハアハアハ……」　ところがこうした愉快な会話が、霧が晴れると同時にグングン裏切られて行ったから不思議であった。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "六「ちぇっ、勝手にしやがれ……」　黒吉は、ネトネトと口の中で澱んだ言葉を吐棄てた。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、もうどうでも勝手にしやがれと思つて、その折角こしらへてきてくれた設計圖はそこにおつぽり出してしまひました。",
              "citation": {
                "source": "緑葉歎",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "麥藁帽子なんぞ勝手にしやがれ！",
              "citation": {
                "source": "エトランジェ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし教師の前では勝手にしやがれと自暴自棄にわめきたてていた。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（京都へ帰るなり、甲府へ追って行くなり、勝手にしやがれ。",
              "citation": {
                "source": "甲州鎮撫隊",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手にしやがれ、と私は糞度胸を据ゑて黒珈琲を飮みかけようとした途端に、こんな事を思ひついた。",
              "citation": {
                "source": "鳥料理",
                "author": "A Parody",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手にしやがれ、と私は糞度胸を据えて黒珈琲を飲みかけようとした途端に、こんな事を思いついた。",
              "citation": {
                "source": "鳥料理",
                "author": "A PARODY",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手にしやがれ」　と云ったが、仕事が終って村の者が山からゾロゾロ降りてくると、存八のネグラのことをきいてくれたのである。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争なんか勝手にしやがれという連中は、クイズや競輪で、これも当てッこに熱中している。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "開いたなりの傘をそこへ抛り出して、勝手にしやがれという態度で、跛足の足を引きずって、雨の中をさっさと駈け出してしまいます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう人のこういう場合は方々に例の多いことだが、勝手にしやがれ、と云うよりほかに仕方がないように私は思う。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その七　宮様は一級紳士",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　　勝手にしやがれ。",
              "citation": {
                "source": "運を主義にまかす男",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "底野　　勝手にしやがれ。",
              "citation": {
                "source": "運を主義にまかす男",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺のこの世の幸福も、いやさあの世の幸福も、どうなりと勝手にしやがれだ！",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は詮方なくお眠みなさい、とか、左樣なら、とか云つて出て來やうとすれば、『勝手にしやがれ。",
              "citation": {
                "source": "六號室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
