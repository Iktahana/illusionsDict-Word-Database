        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この看護法は、患者さんの心に寄り添うことを何より大切にしているんです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔の看護法を学ぶと、今の医療がどれだけ進歩したか実感するわ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の看護法は、細やかな配慮に満ちていて、いつも安心させられます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しい看護法の実践で、患者さんの回復が早まったという報告もある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」「今は一般看護法です。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護法の実例なぞは、校長が一々生徒を集めて教えて呉れます。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また校長が自ら看護法など学術的に教えて居ります。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この問題に関係があるのか無いのかハッキリしないが、それから時日がしばらく経って、内務省は精神病院主・院長・会議に於て、精神病院法並びに精神病者看護法改正に関する希望を諮問している。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "雄弁術、音楽、美術、民族舞踊、応急看護法。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
