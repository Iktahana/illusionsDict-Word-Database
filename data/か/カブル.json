      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to put on (one's head)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "寒かったので、家を出る前にニット帽を深く被った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "雨が強くなってきたので、フードをしっかり被って道を急いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は帽子を被ると、途端にお洒落な雰囲気になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "工事現場では、安全のために必ずヘルメットを被る必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "坊主の除れたフランスのセーラーの被る毛糸帽子。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな風な訪問を致す時はヴェエルを被るものでございましたかねえ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、不束なる女ども、猥に卿等の栄顧を被る、真に不思議なる御縁の段、祝着に存ずるもの也。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやに気位を高くして、家が広いから、それにどうせ遊んでいる身体、若いものを世話してやるだけのこと、もっとも性の知れぬお方は御免｜被るとの触込み。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやに気位を高くして、家が広いから、それにどうせ遊んでいる身体、若いものを世話してやるだけのこと、もっとも性の知れぬお方は御免被るとの触込み。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ汚ないばかりでなく、見るからして彼ははなはだやつれていた、思うに昼は街の塵に吹き立てられ、夜は木賃宿の隅に垢じみた夜具を被るのであろう。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪艶やかに中腰になった処を、発奮で一打、ト颯と烏の翼の影、笹を挙げて引被る。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、慌しく中折をぐいと被る。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　赫となった赤熊が、握拳を被ると斉しく、かんてらが飛んで、真暗に桜草が転げて覆ると、続いて、両手で頬を抱えて、爺さんは横倒れ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで茸の扮裝は、縞の着附、括袴、腰帶、脚絆で、見徳、嘯吹、上髯の面を被る。",
              "citation": {
                "source": "くさびら",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ばかりじゃ無い、……雁、燕の行きかえり、軒なり、空なり、行交う目を、ちょっとは紛らす事もあろうと、昼間は白髪の仮髪を被る。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "目も鼻もなく、あたまからただ灰色の布を被る。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三の烏　すると、人間のした事を、俺たちが引被るのだな。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……羽織は、まだしも、世の中一般に、頭に被るものと極った麦藁の、安値なのではあるが夏帽子を、居かわり立直る客が蹴散らし、踏挫ぎそうにする……　また幕間で、人の起居は忙しくなるし、あいにく通筋の板敷に席を取ったのだから堪らない。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "茸は立衆、いずれも、見徳、嘯吹、上髭、思い思いの面を被り、括袴、脚絆、腰帯、水衣に包まれ、揃って、笠を被る。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い炎が、影もなく橋にぴたりと寄せた時、水が穂に被るばかりに見えた。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう場合には仕方がないから、役者に烏帽子を被るなといっておくのですが、舞台へ出るのを見ると、チャンと烏帽子を被っている。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣服は……金持になれば直に良い衣類を買って被るよ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕将｜陳亨、安の為に斬られ、徐忠亦｜創を被る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは氏郷の方から好んで為出したことではないが、他の大将ならば或は遁逃的態度に出て、そして敵をして其企図を多少なりとも成就するの利を得、味方をして損害を被るの勢を成さしめたであろうに、氏郷が勇敢に職責を厳守したので、敵は何の功をも立てることが出来なかった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎧を着るには、鎧下と云って、錦や練絹などで出来ているものを被る。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "血液鬱滯は姑らく論ぜず、すべて適度の血量増加、即ち血壓増加は、心理に於ける陽性作用を致し、感情に於ては愉快怡和亢奮を現はし、理性に於ても同じく其の影響を被るに相違無いが、感情亢昇の爲に掩はれて、卻て聊か其の働が鈍らされるが如き觀を呈するに至る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等の物は時間の影響を被ること、植物動物等の如く明白ならざるものであるが、而も猶長時間の後には、明らかに時間の影響の加被せざるにあらざることを示すのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "老子や漢高の氣は高く升りて天にあらはれ、遠く望んで之を知る可きほどであつたと云ふのに、佛陀なぞのは土星の鉢卷や袋蛛蜘の袋のやうに、僅に其の體に貼して小光圈をなして居るに過ぎぬのは、自由の力の大なる畫家が、束縛を被ること大なる彫刻家に降伏して居る結果でも有らうか知らぬが、をかしく思はれる。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "稀には非器分の大打撃を被るによりて死を致すのも有るが、而も其の死と同時に器分の或物が破壞缺損せらるゝは疑ふ可からざることである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "当方からお給事をしようと云うんじゃなし、第一欲しいと仰有ったって、差上げるやら、平に御免を被るやら、その辺も分らないのに、人の大切な令嬢を、裸体にして検査するような事を聞くのは、無礼じゃないか。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、其の頭へ、棕櫚の毛をずぼりと被る、と梟が化けたやうな形に成つて、其のまゝ、べた／＼と草を這つて、縁の下へ這込んだ。",
              "citation": {
                "source": "人魚の祠",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦痛の顏の、醜さを隱さうと、裏も表も同じ雪の、厚く、重い、外套の袖を被ると、また青い火の影に、紫陽花の花に包まれますやうで、且つ白羽二重の裏に薄萌黄がすツと透るやうでした。",
              "citation": {
                "source": "雪靈續記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "またゲエテはナポリ人が馬車を赤くし、馬首に旗を飾り、色斑らな帽子を被るのは趣味の野蠻なのではなくて、明るい周圍の爲めだと云つてゐる。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔卑屈の友らをいきどほろしく〕宮沢賢治卑屈の友らをいきどほろしく粘土地二片をはしりてよぎり崖にて青草黄金なるを知りのぼりてかれ草黄なるをふめば白雪きららに落ち来るものか一列赤赤ならべるひのきふたゝび卑屈の友らをおもひたかぶるおもひは雲にもまじへかの粘土地なるかの官庁に灰鋳鉄のいかりを投げよ",
              "citation": {
                "source": "〔卑屈の友らをいきどほろしく〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to be covered with (dust, snow, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長期間使わなかった家具は、すっかり埃を被っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昨夜からの雪で、庭の木々は真っ白な雪を被っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "砂漠を旅していると、すぐに砂を被ってザラザラになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ペンキ塗りの作業中は、誤って塗料を被らないよう注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "to bear (e.g. someone's debts, faults, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "チームの失敗はすべてリーダーである自分が被ると、彼は力強く宣言した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "部下が起こした問題の責任を、上司がすべて被ることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社が倒産し、残された借金を彼一人で被ることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの時、私が嘘をついたせいで友人に濡れ衣を被せてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 4,
        "gloss": "to overlap (e.g. sound or color)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ラジオから流れる音楽と、外を走る車の音が微妙に被っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "複数の人が同時に話すと、声が被って何を言っているか聞き取りにくい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "デザイン画の色の配置が少しずれていて、一部が被っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会議のスケジュールが他の重要なアポイントと被ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 5,
        "gloss": "to be similar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新商品のアイデアが、既に発表されている他社の製品と被っていると指摘された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼のプレゼンテーションの内容は、以前聞いた話とかなり被る部分があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "兄弟なのに、二人の声質が驚くほど被っていて区別がつきにくい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近の流行歌はどれも同じようなメロディーで被って聞こえる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 6,
        "gloss": "to be fogged (due to overexposure, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あちゃー、暗室のドアを誰か開けたな？ せっかく現像したフィルムが全部被っちゃったよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この写真、なんだか全体的に白っぽくない？」「あー、これは撮影中に光が漏れて被っちゃったんだね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "せっかくの旅行写真なのに、感光して被ったせいで何が写っているのかさっぱり分からない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 7,
        "gloss": "to close",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「もうすぐ芝居が被るから、終演後の挨拶の準備を袖で待機して始めておいて。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幕が被ると同時に客席から沸き起こった拍手に、主演俳優は安堵の表情で深く頭を下げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今日の公演、何時に被る予定？」「予定通りなら、あと10分もすれば終わるはずだよ。」",
              "citation": {
