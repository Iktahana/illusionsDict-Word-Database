[
  {
    "uuid": "9af3532f-0b2e-526a-98fc-469213b83736",
    "entry": "被る",
    "reading": {
      "primary": "かぶる",
      "alternatives": [
        "かむる"
      ],
      "is_heteronym": false
    },
    "grammar": {
