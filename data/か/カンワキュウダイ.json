    "definitions": [
      {
        "index": 1,
        "gloss": "getting back to the subject at hand, ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
