[
  {
    "uuid": "fd335673-62a9-5d0c-bc6c-cb347bfaefe8",
    "entry": "郭公",
    "reading": {
      "primary": "かっこう",
      "alternatives": [
        "カッコウ",
        "カッコー"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "common cuckoo (Cuculus canorus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "初夏の森で、郭公（カッコウ）の鳴き声が聞こえてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "郭公は、他の鳥の巣に卵を産み付けることで有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ほら、あれが郭公だよ。早朝によく鳴くんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "郭公の鳴き声は、日本の夏を告げる風物詩の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "かく／＼と語れば、「そは承けがたき事」と打かたぶき打かたぶきするほどに、又も一声二声うちしきれば、「あれが声を郭公とや。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿に落着いてから子供等と裏の山をあるいていると、鶯が鳴き郭公が呼ぶ。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "郭公の場合には明らかに雌を呼ぶためだと解釈されているようであるが、ほととぎすの場合でもはたして同様であるか、どうかは疑わしい。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう郭公鳥も鳴きませぬ。",
              "citation": {
                "source": "沼の家",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "郭公や時鳥が自分を呼んでいるような気がする。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから辛夷の花が咲き、郭公が訪れ、木の芽が木の種類によつて花よりも美しい鮮明な色に染まり、雲雀が謠ひ出し、あらん限りの春の花が一時に競ひ咲くまでには一ヶ月を要しないだらう。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く西方の山で郭公がしきりに啼いてゐた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時には、数剋もお待ちになつたのに、つひに郭公の一声も聞かれず、むなしくお帰りになられまして、まあその事くらゐが、わづかにお奥の笑ひ話の種になつたやうなもので、他にはこのとしには楽しい思ひ出もあんまりございませんでした。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山から降りたら、郭公が鳴いてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥州藤原家が何時の間にか、「だんまり虫が壁を透す」格で大きなものになつてゐたのも、何を語つてゐるかと云へば、「都のうつけ郭公待つ」其間におとなしくどし／＼と鋤鍬を動かして居たからだ。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちらでもかつこう、こちらでもかつこう、郭公が啼いて、雨が霽れて、田舎は涼しい涼しいな。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "有明の月に血を吐くほととぎすの悲歎を曾て見知らぬ私は寧ろキヤベツ畑の雨に啼く郭公を楽しいものに哀れみ、昔ながらの古い前栽の繁みに飛ぶ蛍よりも客待の人力車のかげに仄かに蒼白いお尻のパツチを光らす東京の蛍をこの上なく今の心に親しむ。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵からの酒宴が深更に及んだが、折柄、時鳥の鳴くのをお市の方聞いて、さらぬだに打寝る程も夏の夜の夢路をさそふ郭公かな　と詠ずれば、勝家もまた、夏の夜の夢路はかなき跡の名を雲井にあげよ山郭公　二十四日の暁方、火を城に放つと共に勝家始め男女三十九人、一堂に自害して、煙の中に亡び果てた。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「凡人の態ならず、秀吉は天魔の化身にや」　と驚いて居る時、秀吉は既に此処に移転して、「啼たつよ北条山の郭公」と口吟んで、涼しい顔をして居た。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "別荘は、しんとしていて、絶えずよい草の香りのする風が吹き、しきりなしに鳴く郭公の声が遠く近くきこえるばかりであった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　新子は、次の朝｜郭公とミヒヒという山羊の声で眼がさめた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば郭公の啼くのが、カツ、コウと二音を重ねるのであるが、あれと似てゐる。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "郭公も實に澄んだ寂しい聲であるが、佛法僧はその寂びの中に更に迫つた深みと鋭どさとを含んで居る。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角、筒鳥にせよ、郭公にせよ、杜鵑にせよ、その啼聲のおほよその口眞似も出來、文字にも書くことが出來るが、佛法僧だけは到底むつかしい。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鳥も郭公などと同じく、暫くも同じところに留つてゐない。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、佛、法、僧などの乾いた音色ではゆめさら無く、郭公、筒鳥の寂びた聲に較べては更に數段の強みがあり、つやがある。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "郭公は朝に、筒鳥は晝に、呼子鳥はゆふぐれに、佛法僧は夜に。",
              "citation": {
                "source": "樹木とその葉",
                "author": "夏を愛する言葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに似たものに郭公がある。",
              "citation": {
                "source": "樹木とその葉",
                "author": "若葉の山に啼く鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "榛名山に登る時、ずつとうち續いた小松の山の大きな傾斜に松のしんがほのぼのと匂ひ立つてゐるなかに聞いた郭公なども忘られ難い。",
              "citation": {
                "source": "樹木とその葉",
                "author": "若葉の山に啼く鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "奧州で豆蒔鳥と呼ぶのはこの郭公のことらしい。",
              "citation": {
                "source": "樹木とその葉",
                "author": "若葉の山に啼く鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "石楠木咲き、郭公、啼く。",
              "citation": {
                "source": "樹木とその葉",
                "author": "空想と願望",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひ初めたは、郭公鳴く青葉の頃、産土の祭禮の日よ、それより後は胸に一つの塊りを得て、一日も苦悶の絶えた日は無い。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨナーの鯨、ソロモンの蟻、イシュメールの羊、アブラムの犢、シェバ女王の驢、サレクの駱駝、モセスの牛、ベルキの郭公、マホメットの驢だ。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭も床屋にきたからでしょうが、四角なかっこうに、きれいにかりこんでいます。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから渡り鳥のかっこうや百舌も、又小さなみそさざいや目白もみんなこの木に停まりました。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
