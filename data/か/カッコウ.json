      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "shape",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この椅子、座り心地はいいんだけど、ちょっと変わった格好をしてるよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "庭の植木を大きなハサミで整えて、きれいな円錐の格好に仕上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「見て見て！あの空に浮いてる雲、ソフトクリームみたいな格好だよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その停止している所は、舌の先のようで、お正月の海鼠餅の格好だ。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　行李は、ひょうきんな格好で、水を吸って沈むまでを、浮いてごみ屑と一緒に流れた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十月十七日『東京朝日新聞』）　　　　　　　　　二十二　　　　　　護謨の新原料　近頃｜葡国領西部アフリカで発見された一種の植物の球根は丁度｜蕪菁のような格好をしているが、その液汁中には護謨を含み、これを圧搾して酒精で凝らせると二分の一プロセントくらいのゴムが取れる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中根はあわてて無格好な不動の姿勢をとつたが、その顏には、それが癖の間の拔けたニヤニヤ笑ひを浮べてゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、彼は、それと同じことを、鮮人部落の地理や、家の格好や、その内部の構造や、美しい娘のことなどを、執拗に憲兵隊で曹長に訊ねられたことを思い出した。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "背｜格好から歩きつきまで確かに武だと思ったが、彼は足早に過ぎ去って木陰に隠れてしまった。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然を恐れることなしに自然を克服しようとする科学の発達には真に格好の地盤であろうと思われたのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "住居に付属した庭園がまた日本に特有なものであって日本人の自然観の特徴を説明するに格好な事例としてしばしば引き合いに出るものである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おでこは心の広さを現わし、小さく格好よく引きしまった鼻はインテリジェンスとデリカシーの表象であり、下がった目じりは慈愛と温情の示現である、という場合もあるであろう。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな、今で言えばスーツケースのような格好をした黒塗りの革鞄に、これも赤く大きく千金丹と書いたのをさげていたと思う。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、煙管貝のような格好で全体灰色をした一種の巻き貝であって、長さはせいぜい五六｜分ぐらいであったかと思う。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に悲惨な格好をしていたものであった。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "切り立ての鋏穴は円形から直角の扇形を取りのけた格好をしている。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫を捨てに出た人が格好の捨場を求めて歩いて行くうちに一つの橋の袂に来たとすれば、その人はまたおそらく当然そこでその目的の行為を果たすに相違ない。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女房の母親で、年紀の相違が五十の上、余り間があり過ぎるようだけれども、これは女房が大勢の娘の中に一番｜末子である所為で、それ、黒のけんちゅうの羽織を着て、小さな髷に鼈甲の耳こじりをちょこんと極めて、手首に輪数珠を掛けた五十格好の婆が背後向に坐ったのが、その総領の娘である。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひなは七月に行った時はまだ黄色い綿で作ったおもちゃのような格好で、羽根などもほんの琴の爪ぐらいの大きさの、言わば形ばかりのものであった。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その水中を泳ぐ格好がなかなか滑稽で愛敬があり到底水上では見られぬ異形の小妖精の姿である。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも親鳥がこんな格好をして水中を泳ぎ回ることは、かつて見たことがない。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は近所のあらゆる曲がり角や芝地や、橋のたもとや、大樹のこずえやに一つずつきわめて格好な妖怪を創造して配置した。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "必要な建築学上の規則に牴触しない限りはあらゆる好きな格好のものを設計してもよいはずである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの物の形の基礎には立体的正多面体の基本定型が伏在していて、条件によってその中の格好なものが成長の萌芽となるであろうという想像がついたようである。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは少し脱線であるが、珊瑚礁を作るような珊瑚のうちに、上記の噴泉塔とも類似し、またシャボテンのうちに瓜のような格好で、縦に深く襞のはいったのがある、あれともいくらか似た形のものがある。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロバビリティの問題、エントロピーの時計の用途は存外に広いという事を思い出すに格好な時機ではあるまいか。",
              "citation": {
                "source": "時の観念とエントロピーならびにプロバビリティ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の目の格好を一生懸命にかいてだいたいよくなったと思って少し離れて見るとその目だけが顔とは独立に横に脱線したりつり上がりねじれなどした。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際輪郭線がわずかに一ミリだけどちらかへずれても顔の格好がまるで変わってしまうのは恐ろしいようであった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画監督のシュネイデロフ氏はだれも格好な話し相手がなくて、すみのほうの椅子に押し黙って所在なさそうに見えた。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つは毛深い熊があと足を前に投げ出してすわっている、それが首と前足とを動かして滑稽な格好をして踊りだすと腹の中でオルゴールのかわいらしい音楽が聞こえて来るのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "親熊は突然あと足を折って尻もちをつくような格好をして一度ぐるりと回るかと思うと、急いで駆け出すが、すぐに後ろを振りむいて何かしら自分の腰に食いついている目に見えぬ敵を追い払おうとする様子をする。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "脈搏や呼吸なども実際「秒」で測るに格好なものである。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十格好と思われる病身そうな青白い顔に、あごひげをまばらにはやしているのが夜目にもわかった。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
