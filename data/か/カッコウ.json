        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「これ、いくらくらいしたの？」「まあ、3万円格好ってところかな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "あの二人は、付き合い始めてからもう5年格好になるんじゃないかな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "会場には、およそ200人格好の招待客が集まっていて圧倒された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
