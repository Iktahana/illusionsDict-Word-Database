  {
    "uuid": "0824a2f0-e81e-5f6b-8474-a83011458768",
    "entry": "格好",
    "reading": {
      "primary": "かっこう",
      "alternatives": [
        "かっこ",
        "カッコ"
      ],
      "is_heteronym": false
    },
    "grammar": {
