    },
    "definitions": [
      {
        "index": 1,
        "gloss": "moneylending",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔は個人間の金貸しも普通に行われていたらしいよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の父は金貸し業を営んでいたと聞いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "違法な金貸しには絶対に関わってはいけないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "下谷のある町の金貸しの婆さんの二階に間借りして、うら若い妻と七輪で飯を焚いて暮している光景のすぐあとには、幼い児と並んで生々しい土饅頭の前にぬかずく淋しい後姿を見出す。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちは金貸しを業と致しおるな」「へいへい。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金貸しは面白かろう」「へい、御冗談、へいへい。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃あの人は、人の顔さえ見れば、金貸したろか金貸したろか、と、まるで口癖めいて言っていたという。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをそんな風に金貸したろかと言いふらし、また、頼まれると、めったにいやとはいわず、即座によっしゃと安請合いするのは、たぶん底抜けのお人善しだったせいもあるだろうが、一つには、至極のんきなたちで、たやすく金策できるように思い込んでしまうからなのである。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、せかせかと空しく探し歩いているうちに、ひょっくり、別の友達に出くわし、いきなり、金貸してくれと言われるが、無いとも貸せぬともあの人は言えぬ。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "金貸したろかなどという口癖は、まるでそんな、利用してやろうなどといういやしい気持を見すかしてのことではなかろうかとすら思われたのだ。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、今まで人の顔さえ見れば、金貸したろか金貸したろかと利用されてばかしいたあの人が、やがて、人の顔さえ見れば、金貸してくれ金貸してくれと言うようになった。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三村は千万長者といわれ、三十七八年の戦争の時、ぼろ船を買い占めて儲けたのは異数で、大抵各方面への投資と土地で築きあげた身上であり、自身に経営している産業会社というようなものはなく、起業家というより金貸しと言った方が適当であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあげく五月雨の降る或る夕方のこと、手に手に棒千切を持った十四五人が「金貸し後家」の家のまわりを取り囲むと、強がりの青年が三人代表となって中に這入って、後家さんに直接談判を開始した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀才、はざま貫一、勉学を廃止して、ゆたかな金貸し業をこころざしたというテエマは、これは今のかずかずの新聞小説よりも、いっそう切実なる世の中の断面を見せて呉れる。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、グスタフソンは深々と座席に埋めた大きな體を重たさうに動かしながら、「どうも聞き覺えのある名前だと思つて今まで頭をひねつてゐたんだが、そいつは金貸し兼仲買人のやがて七十になる爺さんだよ。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、忠一の方は兼業の金貸しを発展させて金融業の事務所を作り、小さな地方銀行まで設立させていた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝればかまどの烟細しとは言ひながら、其日其日を送るに太き息｜吐く程にはあらず、折には小金貸し出す勢ひさへもありきと言ふものもありけり。",
              "citation": {
                "source": "鬼心非鬼心",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学の小使上がりで今金貸しをしている末造の名は、学生中に知らぬものが無い。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、よく激烈な夫婦喧嘩をする金貸しの美しい細君の――聲であつたと確に思ふが――姿はその縁がはにも、どこにも見えなかつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやぢは北海道へ行つて金貸しをしてゐたが、紀州へ歸つて死んだこと。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は日本橋檜物町の素人屋の二階を借りて棲んでゐる金貸しをしてゐる者の娘で神田の実業学校に通うてゐた。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金貸しが不徳だというなら、金貸しから金を借りる者も共犯者のわけだ。",
              "citation": {
                "source": "或る探訪記者の話",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "金貸しなどをしているものもあった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "百弗猫の小母さん木兎さん百｜弗貸すから家建てろ石で　たたんだ家建てろ煉瓦で　たたんだ家建てろ猫の小母さん木兎さん小猫にも百弗金貸した百畳　畳が出来て来るどんどん踏んでも踏みきれぬ朝晩踏んでも踏みきれぬ。",
              "citation": {
                "source": "十五夜お月さん",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "当人の白状によると、徳蔵を殺したあとで一方の伝介と夫婦になる気でもなく、かねて貯えてある六、七両の金とその百両とを持って、故郷の名古屋へ帰って金貸しでもするつもりだったそうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "弁天娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "袖摺稲荷の近所で……」「なんという男で、何商売をしている」「宗兵衛と申しまして、金貸しを商売にして居ります。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ　ばかりでなく、かねかしとか、よくないものが　はびこって、たかい　りしを　とっては　ひとびとを　くるしめて　いました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに　ぜにや　きゅうべえは、かねかしの　なかでも　いちばん　たちの　わるい　やつで、きゅうべえから　かねを　かりた　ひとは、みな　くるしんで　いました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
