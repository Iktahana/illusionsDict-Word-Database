        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は街の有名な金貸しで、多くの人が世話になっているそうだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "金貸しからお金を借りるのは、本当に最後の手段だと思った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あそこの金貸しは利子が厳しいから気をつけろ」と忠告された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
