        "examples": {
          "standard": [
            {
              "text": "突然の痛みに、彼は顔を歪めてうずくまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "そのまずい薬のせいで、子供は顔を歪めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "予想外の展開に、彼女は呆れて顔を歪めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」と、顔を歪める刹那にお三は例の扱い慣れた手つきで赤子の鼻を抓みました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "進藤も石が一つ殖える度毎に嬉しそうに眼を細くしてニコニコして見せるので、意地にも顔を歪める訳に行かん。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何処をやられたのです」と訊ねると、「膝ぢや」とそこを押へながら皺の多い蒼顔を歪める。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何処をやられたのです」と訊ねると、「膝じゃ」とそこを押えながら皺の多い蒼顔を歪める。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "」おときは顔を歪めるやうにして云った。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "という宣言であったが、それ程の切羽つまった現在の戦況であるにしても、これは又、何という残酷な事をするのだろうと慄え上っていると、又も更に驚いた事には、その候補生が自分の膝を、泥と血だらけの両手に掴んで、美しい顔を歪めるだけ歪めて、絶大の苦痛を忍びながらヨタヨタと立上った事であった。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨハネス、黙って突立ち、眼をしばたたき、まるで絶望したように、くしゃくしゃ顔を歪める。",
              "citation": {
                "source": "猿",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
