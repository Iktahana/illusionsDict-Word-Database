[
  {
    "uuid": "5ebc4419-237a-5d7f-95fb-faf041fe1a00",
    "entry": "河鹿",
    "reading": {
      "primary": "カジカ",
      "alternatives": [
        "かじか"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "kajika frog (Buergeria buergeri)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夕暮れ時、渓流沿いを歩くとカジカの澄んだ鳴き声が聞こえてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、夏休みに父とカジカを捕まえに川へ行ったものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地方では、カジカの生息環境を守るため、護岸工事に配慮している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "或日父は近頃にない早く、外来患者も病室の方も済まして、表の間の卓に頬肘を突いた儘、縁先の河鹿の鉢をヂツと瞶めてゐた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さう言つた父は急に立ち上がつて河鹿に手水をやつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は河鹿の鳴く渓流に沿った町の入口の片側町を、この老婦人も共に二三人と自動車で乗り上げて行った。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、ともよは、籠をもって、表通りの虫屋へ河鹿を買いに行った。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が今年ももはや初夏の季節で、河鹿など涼しそうに鳴かせる時分だ。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "河鹿を籠に入れて貰うと、ともよはそれを持って、急いで湊に追いついた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともよが買って来てそこへ置いた籠の河鹿が二声、三声、啼き初めた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともちゃん、帰らなくては悪かろう」　ともよは河鹿の籠を捧げて立ち上った。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "河鹿のような膚をしている。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二　私は一度｜河鹿をよく見てやろうと思っていた。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河鹿を見ようと思えばまず大胆に河鹿の鳴いている瀬のきわまで進んでゆくことが必要である。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはそろそろ近寄って行っても河鹿の隠れてしまうのは同じだからなるべく神速に行なうのがいいのである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼんやりしていれば河鹿は渓の石と見わけにくい色をしているから何も見えないことになってしまうのである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっとしばらくすると水の中やら石の蔭から河鹿がそろそろと首を擡げはじめる。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな風にして真近に河鹿を眺めていると、ときどき不思議な気持になることがある。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川龍之介は人間が河童の世界へ行く小説を書いたが、河鹿の世界というものは案外手近にあるものだ。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一度私の眼の下にいた一匹の河鹿から忽然としてそんな世界へはいってしまった。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その河鹿は瀬の石と石との間に出来た小さい流れの前へ立って、あの奇怪な顔つきでじっと水の流れるのを見ていたのであるが、その姿が南画の河童とも漁師ともつかぬ点景人物そっくりになって来た、と思う間に彼の前の小さい流れがサーッと広びろとした江に変じてしまった。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、こんな時こそ私は最も自然な状態で河鹿を眺めていたと云い得るのかもしれない。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は渓へ行って鳴く河鹿を一匹捕まえて来た。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが河鹿はどうしても自然な状態になろうとしない。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠅を入れても蠅は水の上へ落ちてしまったなり河鹿とは別の生活をしている。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはある河鹿のよく鳴く日だった。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河鹿の鳴く声は街道までよく聞こえた。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃は河鹿と同じくそのころの渓間をいかにも楽しいものに思わせる鳥だった。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ははたして河鹿の鳴きしきっているのを聞くとさっさと瀬のそばまで歩いて行った。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この瀬にはことにたくさんの河鹿がいた。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世にも美しいものを見た気持で、しばらく私は瀬を揺がす河鹿の声のなかに没していた。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はカジカンだ手で竿を畳み、子供たちの方へ堤の上を歩いて行つた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "壺の中へカジカ蛙をあまた容れ、網蓋の小孔より蠅を入れると、直様蛙の口へ飛び込んで嚥まるるもあれば、暫時して蛙の方へ飛び行き捉わるるもある。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
