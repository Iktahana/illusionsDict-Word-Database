        "examples": {
          "standard": [
            {
              "text": "彼の片口だけを聞いて、全てを判断するのは早計だろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "公平を期すために、双方の片口をじっくりと聞く必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "部長はいつもAさんの片口ばかり信じて、私の言い分を聞いてくれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
