    "definitions": [
      {
        "index": 1,
        "gloss": "shadow (e.g. on someone's happiness)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
