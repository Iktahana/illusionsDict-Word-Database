[
  {
    "uuid": "4b1c0879-766a-5d38-8fb9-569a9a43779c",
    "entry": "矍鑠",
    "reading": {
      "primary": "かくしゃく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "vigorous (in old age)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖父は90歳を超えてもなお矍鑠としており、毎朝の散歩を欠かさない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "その老経営者は、今も矍鑠たる姿で会社の舵取りを行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は年齢を感じさせない矍鑠とした口調で、若者たちに経験を語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "自分が物心づくころからすでにもうかなりのおばあさんであって、そうして自分の青年時代に八十余歳でなくなるまでやはり同じようなおばあさんのままで矍鑠としていたＢ家の伯母は、冬の夜長に孫たちの集まっている燈下で大きなめがねをかけて夜なべ仕事をしながらいろいろの話をして聞かせた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二歳年下で、六十歳の太田｜南畝がまだ矍鑠としてゐるのが気になつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう六十を越えて、それで前額は禿げているが、矍鑠としたシャンとした老人である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "年耳順を越えて矍鑠たり。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "齢は五十を超えたるなるべけれど矍鑠としてほとんと伏波将軍の気概あり、これより千島に行かんとなり。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くして件の青侍に導かれ、緩端に平伏したる齋藤茂頼、齡七十に近けれども、猶ほ矍鑠として健やかなる老武者、右の鬢先より頬を掠めたる向疵に、栗毛の琵琶股叩いて物語りし昔の武功忍ばれ、籠手摺に肉落ちて節のみ高き太腕は、そも幾その人の首を切り落としけん。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "七十代の婿と八十代の舅とは、共に矍鑠として潮風に禿頭を黒く染め、朝は早くから夜は手許の暗くなるまで庭仕事を励んだ。",
              "citation": {
                "source": "木魚の配偶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくこれは、これもまた矍鑠としているであろう気丈な彼の老妻が、困苦のなかにいよいよ澄んだ配慮を物語っていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "頽然たる老人である可きであったが、名に負う海洋で鍛えた体は矍鑠として尚逞しく、上下の歯など大方揃っていた。",
              "citation": {
                "source": "赤格子九郎右衛門",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "崔之庚は六十歳ばかりの矍鑠たる老人で、一代で富をなしたのだといわれています。",
              "citation": {
                "source": "碑文",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "七十歳に近い洪は、まだ矍鑠たるもので、肩には肉の厚みも見え、髪は短く刈り、顔色は浅黒く、太い眉と細めの眼とが特徴である。",
              "citation": {
                "source": "秦の出発",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "矍鑠として、甚だ陽気だ。",
              "citation": {
                "source": "木々の精、谷の精",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつしよにお伴をしておいで」　鍵屋の隠居神原直造は老来なほ矍鑠と云つた様子だつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、誰よりも一番似つかはしかつたのはあの老来なほ矍鑠とした端正な鍵屋の隠居、神原直造であつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「刈田伝二・行年七十二」彼はさういふ墓の下へ、昔は一しきり足繁く往来し合つた一人の老人――今も尚｜矍鑠として死ぬ色もない漁色家の老いたる友を埋めてしまつた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだお達者でいたのですか」「達者じゃ、矍鑠としちょる。",
              "citation": {
                "source": "岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十何歳かからは茶道に親しみ、茶筌を手にするすべを覚えて、爾来、それを続けて現在屈指の大茶人として認識されるに至っている、今日、七十七歳で矍鑠と好者生活を続ける根津さんは通常一片の美的趣味家ではない。",
              "citation": {
                "source": "現代能書批評",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日その人はなお矍鑠としておられるが、その人の日夜見て娯みとなした風景は既に亡びて存在していない。",
              "citation": {
                "source": "向嶋",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "同学の諸士は私よりは年下だのに早くも死んだ人が少なくないに拘わらず、われは尚心身｜矍鑠たる幸福を贏ち得ているからこの達者なうちに一心不乱働かねば相済まぬことと確信している。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分刈の頭髪は太い眉毛や口髭と共に雪のように白くなっているので、血色のいい顔色はなお更｜赧らみ、痩せた小づくりの身体は年と共にますます矍鑠としているように見える。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊池五山もまた矍鑠として数年前にはその詩話の補遺四巻を上木し、連月十六日を期して詩会を本郷一丁目の邸宅に開いていた。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "数馬の属する部落における組頭の名は藤作と云って六十に近い老人であったがさすがに昔は武士であっただけに矍鑠として壮者を凌ぎ、しかも主君に対しては誠忠無類の人物であった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――云う迄もなく梨園にはなお菊五郎、吉右衛門もいますし、幸四郎の長老も矍鑠としています。",
              "citation": {
                "source": "役者の顔",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度のアメリカ訪問で、一番印象に残ったのは、老人が沢山いて、それが皆｜矍鑠として、元気で働いていることであった。",
              "citation": {
                "source": "老齢学",
                "author": "――長生きをする学問の存在――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし科学が、人間の寿命をのばし、よぼよぼの年齢において、なお矍鑠たる健康を保たせることに、反対をする人は一人も無いであろう。",
              "citation": {
                "source": "老齢学",
                "author": "――長生きをする学問の存在――",
                "note": "青空文庫"
              }
            },
            {
              "text": "セミョーンは六十ほどの老爺で、痩せて歯はもう一本もないが、肩幅が広くて一見まだ矍鑠としている。",
              "citation": {
                "source": "追放されて",
                "author": "В　ССЫЛКЕ",
                "note": "青空文庫"
              }
            },
            {
              "text": "とって六十八にもなる兼良のことを、今さら老けたとは妙な言艸だが、事実この矍鑠たる老人は、近年めだって年をとった。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "とつて六十八にもなる兼良のことを、今さら老けたとは妙な言艸だが、事実この矍鑠たる老人は、近年めだつて年をとつた。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "大陸のかくしゃくたる太陽は、市街をも、人間をも、工場をも、すべてを高くから一目でじり／＼睨みつけていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だかくしゃくしゃしてたまらないのよ」と云った。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
