  {
    "uuid": "77aa17fc-5d84-54f2-b5b7-8e10458240b2",
    "entry": "借り集める",
    "reading": {
      "primary": "かりあつめる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to borrow money",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "会社が倒産寸前で、何とか資金を借り集めようと奔走した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人の手術費用を助けるため、皆で少しずつお金を借り集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新規事業を始めるために、銀行や知人から資金を借り集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "文典学者の出た寺にはそのほうの版木、修辞学者の出た寺にはまたそれと、律部も論部もバラバラに保蔵されているので、順々にまわって版木を借り集める。",
              "citation": {
                "source": "新西遊記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "刀だけは、本ものの、ピカピカするのが、どこの家にも五本や十本あったから、借り集めるのに苦労はいらない。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
