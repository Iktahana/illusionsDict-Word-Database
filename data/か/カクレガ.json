    "definitions": [
      {
        "index": 1,
        "gloss": "hiding place",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ここが俺たちの秘密の隠れ家だ。大人には絶対に見つからない場所だよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "指名手配犯は山奥の荒れ果てた山小屋を隠れ家として、数ヶ月間潜伏していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "敵の追及を逃れるため、騎士は地下水道の奥にある隠れ家へと滑り込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "）　生活上のある必要から、近い田舎の淋しい処に小さな隠れ家を設けた。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝まだ暗いうちに旧城の青苔滑らかな石垣によじ上って鈴虫の鳴いている穴を捜し、火吹竹で静かにその穴を吹いていると、憐れな小さな歌手は、この世に何事が起ったかを見るために、隠れ家の奥から戸口に匍いだしてくる。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三畳の隠れ家からお蝶はそろそろ這い出して来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、魔の棲むべき岩窟を、嘗て女賊の隠れ家であつたと言ふのは惜い。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　侵入者　郊外の田舎にわずかな地面を求めて、休日ごとにいい空気を吸って頭を養うための隠れ家を作った。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイヌと、熊と、樺戸監獄の脱獄囚との隠れ家だとされているこの千歳の山の中から、一個の榴弾を中央の学界に送るのだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも心細く、その言う処を確めよう、先刻に老番頭と語るのをこの隠れ家で聞いたるごとく、自分の居処を安堵せんと欲して、立花は手を伸べて、心覚えの隔ての襖に触れて試た。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此隠れ家にあてて多くの同志からの通信がくる。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎ヶ窟は其昔、若き恋に酔えるお杉と重蔵との隠れ家であった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐く何処にか隠れ家があろうと、四辺を隈なく照し視ると、穴の奥には更に小さい間道が有った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は幾度かお杉を置去りにして逃げようと企てたが、何日も不思議に其の隠れ家を見付出された。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はあれ、ここは屈竟の隠れ家である。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこで、あなたも大抵お察しでしょうが、竜濤寺という古寺は悪い奴らの隠れ家で……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも雪のふる日に、本所の番場辺へ行く途中、多田の薬師の前で俄かに癪が起って悩んでいるところへ、虚無僧の石田が通りかかって介抱して、自分の隠れ家の竜濤寺へ連れ込んだと云うんですが、いずれ女の方から持ち掛けたか、男の方から誘いかけたか、何かの理窟があるんでしょう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして妾のあとから、妾の隠れ家にいらっして下さらなければ嫌ですよ。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこにロココ風の隠れ家式の小亭がある。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人で町で買物をしてご飯も食べたあと暗くなってお京さんを隠れ家へ送り届けようと、その露地口へ入るときお京さんは痙攣している右の手で胸に十字を切った。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "笛の音の類、朝立ちの駅路の鈴、訪ふ人もなき隠れ家のべるの釦のほのかに白き、小夜ふけてきくりんのたま。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体が、享受的生活などというものが、そもそも生活無能力者の・最後の・体裁の良い隠れ家なんだぜ。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹腰と道家はそこから己の隠れ家に帰って、不思議な老人に教えられた時機の来るのを待っていた。",
              "citation": {
                "source": "赤い土の壺",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、幾等呼んでも返事がないので、隠れ家へ帰ろうと思って呼ぶことをよして歩いた。",
              "citation": {
                "source": "赤い土の壺",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道家は隠れ家に帰らずにそのまま川の堤の竹藪の中へ往って、彼の祠の前で夜の明けるのを待った。",
              "citation": {
                "source": "赤い土の壺",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、我々の隠れ家は私の以前の仲間たちには注意深く秘密にしておいたし、デュパンがパリで世間と交渉を絶ってからよほど年がたっていた。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　隠れ家　かくて磯山は奔竄しぬ、同志の軍用金は攫われたり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の隠れ家は渋谷のおさん婆という女の家でした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つまらない隠れ家を発見されたことはどうも残念だ」　源氏は車中でしきりにこう言っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "松風",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の夕顔夫人に、下の女房ではあったが、長く使われていて、あの五条の隠れ家にまでも来ていた女であることがわかった右近は、夢のような気がした。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁師の子は走って山里に到り、染工に就いて隠れ家を求めた。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隠れ家は知れているが、今すぐに逢わせるわけには行かない。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなにはしやぎやの、却つてあなたを寂しませる位にはしやぎ出すのが常であつた私が、人知れずあなたと私とのためにかくれがを思ひ、寂しいしづかな道を二人のために備へようとしてゐるのを、あなたはお信じになることができますか。",
              "citation": {
                "source": "道",
                "author": "――ある妻の手紙――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
