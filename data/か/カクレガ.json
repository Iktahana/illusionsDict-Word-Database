        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「たまには都会の喧騒を忘れて、こんな静かな隠れ家でゆっくり本でも読みたいね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "作家は執筆に没頭するため、海辺の小さな村に自分だけの隠れ家を構えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「へえ、こんなところに素敵な隠れ家バーがあったんだ。落ち着いて飲めそうだね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "定年後は軽井沢の隠れ家で、夫婦水入らずの時間を過ごすのが夢だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
