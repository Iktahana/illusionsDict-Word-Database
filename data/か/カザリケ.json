[
  {
    "uuid": "e5c8ea3f-0b2a-5a8b-8986-2789c84c23b3",
    "entry": "飾り気",
    "reading": {
      "primary": "かざりけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
