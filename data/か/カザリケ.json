    "definitions": [
      {
        "index": 1,
        "gloss": "affectation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は誰に対しても飾り気のない態度で接するので、周囲の人からの信頼が厚い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そんなに飾り気たっぷりに装わなくても、素直に自分の気持ちを言えばいいのに」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の文章はどこか飾り気があって、かえって本音が伝わりにくいのが残念だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あいつ、最近有名になってから急に話し方に飾り気が出てきたよな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都会の喧騒を離れ、飾り気のない田舎の風景の中で、心ゆくまでリラックスしたひと時を過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "飾り気一点なきも樸訥のさま気に入りてさま／″＼話しなどするうち京都々々と呼ぶ車掌の声にあわたゞしく下りたるが群集の中にかくれたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして飾り気のない姿の可憐さと、野山に教えられた無邪気な表情とをあくまで賞めそやした。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂心は飾り気の無い此の御房の打明話には、ハタと行詰らされて、優しい自分の性質から、将又智略を以て事に処することを卑しみ、覇気を消尽するのを以て可なりとしているような日頃の修行の心掛から、却ってタジタジとなって押返されたことだったろう。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂心は出塵してから僅に二三年だが、今は既に泥水全く分れて、湛然清照、もとより浮世の膠も無ければ、仏の金箔臭い飾り気も無くなっていて、ただ平等慈悲の三昧に住していたのである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "体重百四十｜斤に近い、六尺豊かの図体で、大一番の菜葉服の襟首や、袖口や、ズボンの裾から赤黒い、逞ましい筋肉が隆々とハミ出しているところは、如何にも単純な飾り気のない性格に見える。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋は洗面台と数冊の書籍とをそなえた飾り気のない小さい室である。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "などと檀紙に飾り気もなく書いてあるのが美しかった。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "又お母様は、「あの一軒屋に居りながら、いつの間に見て御座るのか」　と知り合いの人が感心しておりましたくらい髪なぞもチャンと流行風に結って、白いものなぞをチョッとかけておられましたが、それが又、飾り気がないままに譬えようもなく美しく見えました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、無邪気で、人がよくって、親切で、正直で、飾り気がなくって、男性的で、わたし大好きよ、ああいう男は」　みさをがやけにその男のことをほめるので、私は弱りました。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭から、なんの飾り気もなく、自分の行動を批判してくれる人が、ほしいのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは彼のまっすぐな、飾り気のない性質が好きだったし、かてて加えて、この久しぶりの面会が、わたしの胸に呼びさましてくれた追憶のおかげで、いやが上にも彼はなつかしい人物だったわけである。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこぶる不器用な飾り気のないものである。",
              "citation": {
                "source": "カーライル博物館",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーリキイの「ヴェ・イ・レーニン」はまことにゴーリキイらしい飾り気なさ、温かさをもって彼とレーニンとの意見の相異についても書いている。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天香師は慈悲深い飾り気のない徹底的な方です。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、例の飾り気ない調子でぶっきら棒な物の言い方をするのを横から聞いていると、この老人にはどことなく冒しがたい威厳が備っているようであった。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一層飾り気ない真心で彼女はインガに云った。",
              "citation": {
                "source": "「インガ」",
                "author": "――ソヴェト文学に現れた婦人の生活――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも、いッそ、今君が自分の経歴を語ったような具合いに、自然で飾り気がなく、寄席へ行ってもそのとおりしゃべったらどうや？",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体その時分の真面目は正史よりも、却つてこんな飾り気のない随筆などで分るものだ。",
              "citation": {
                "source": "黙々静観",
                "author": "勝海舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、半分失神していたような状態から意識をとり戻した今、朝子が感じているのは、あのときまではまるで生活になかった一つの真新しい飾り気ない悲しみである。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、素朴そのままの、何ら飾り気のない文章で、七年ぶりに帰還した、土人ナガウライの談話と銘打たれてある。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飾り気の無いＡの字は掘立小屋の入り口、奥に見えるは板敷か、茣蓙か、囲炉裏か、飯台か。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろあそこのお邸へは、種々雑多な人間がのべつにお出入りするのでね」――職人だけに物のいい方が、飾り気がなくぞんざいである。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには氏の人格の奥床しささえ窺われて、確信のそのまま溢れたような飾り気のない文章は氏の内面の生活の素朴を思わせ、人をしてすずろに尊敬の念を起こさせるのである。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は中学校で同級だったときのあの飾り気のない口調で、こんな風に最後の解決を語った。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄吉は五十をすぎた立派な紳士で、高価な洋服の胸に金の鎖をのぞかせ、頭髪は手入れの届いたオールバックで、その髪の毛は半白であつたが、理智と決断力によつて調和よく刻みこまれた顔はまだ若々しく典雅で、整然たる姿に飾り気のない威厳がこもつてゐた。",
              "citation": {
                "source": "外套と青空",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄貴が選挙の費用だの何だので金が要つたのでせう」「さうですか」　答へながら、他人ごとのやうにずばずば何でも話してしまふ喜作の飾り気のなさに、驚いてゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその縄は直ぐ前の秋に刈り取った稲の清らかな新藁で作り、一方の端を揃えてそれを切ることもなしに束ねたままを用いるのが正式で、これは飾り気のない質朴な心情を現したものである。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女のきものの着こなしまでが、その飾り気のなさや無邪気な雅趣によって、彼の眼には何かこう世の常ならぬ可憐なもの、いじらしいものに映るのだった。",
              "citation": {
                "source": "イオーヌィチ",
                "author": "JONYCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの見るからに素朴な、飾り気といっては微塵もない、粗朶のように剛ばった枝を綴って点々と赤い柿、それだ。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの飾り気たっぷりの言い回し、カビの生えた女大学式な考え、世の中を滅ぼすものとかなんとかいう、愚にもつかない屁理屈――いやはや、じつにやりきれん。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
