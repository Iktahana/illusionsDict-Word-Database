        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "若き窯元が手掛ける作品は、どれも個性的で温かみがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は先代の窯元から技術を受け継ぎ、新しい作品作りに挑戦している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回の展示会には、全国から選りすぐりの窯元たちの作品が集められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
