[
  {
    "uuid": "325256ad-2505-50c4-bcb4-ca384d1a3f83",
    "entry": "風の神",
    "reading": {
      "primary": "かぜのかみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
