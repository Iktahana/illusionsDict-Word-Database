        "examples": {
          "standard": [
            {
              "text": "庭の片隅に植えられた花梨の木が、春には見事な花を咲かせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "花梨の実は渋みが強いが、砂糖漬けにすると美味しく食べられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母は毎年、花梨を使って自家製の果実酒を仕込んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
