        "examples": {
          "standard": [
            {
              "text": "ローマ郊外にあるアッピア街道沿いのカタコンベを見学しに行く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "迫害の時代、信徒たちはカタコンベの壁に魚のシンボルを刻んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ガイドの忠告を無視してカタコンベの未公開エリアに入るのは言語道断だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "カタコンベ（地下墓地）　カタコンベは殆ど完全にキリスト教信者によってのみ使われた。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもカタコンベのすべての通路を線状に並べると、イタリアの全長になるだろうと言われている。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでは日の光が段々と衰え、案内人の声も妙に空しくこだますので、初めての旅行者はまさにあのカタコンベ[2]に降りてゆく気分にさえなってしまう。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "[2] カタコンベ　地下の納骨堂。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
