        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "重い荷物を持って階段を駆け上がったら、もう片息状態だよ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "高山病の症状で、空気が薄くて片息になることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "喘息の発作が起きて、急に片息になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "女を見出すと、片息の鹿を女の足元に抛り出した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに傷き片息になっている毛もののこととて、※くまもなく四股をくいくいと伸して息絶えた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の中を這出して、片息になってお前、本尊の前へにじり出て、台に乗っけて小さな堂を据えてよ、錦の帳を棒の尖で上げたり下げたりして、その度にわッと唸らせちゃあ、うんと御賽銭をせしめてやがる。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとにはお母さんが片息になって倒れているのを、皆で介抱しているようであったが、離れた処から見ていた上に、言葉が普通と違っているので、どんな経緯なのかサッパリわからなかった……という子守女たちの報告であった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いざとなれば死にさえすればいいのだ」鼈四郎は幼い時分から辛い場合、不如意な場合には逃れずさまよい込み、片息をついたこの無可有の世界の観念を、青年の頭脳で確と積極的に思想に纏め上げたつもりでいる。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち自身、こうあることが半ば死滅させられながら、まだ片息で、人に呑みかゝろうと蟠っている地方の因習や伝説の生活の中にいつからか住み馴染んでいる人間のように思われて来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "代助には、平岡の凡てが、恰も肺の強くない人の、重苦しい葛湯の中を片息で泳いでゐる様に取れた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時お前が一生この恩は忘れないって、片息になって、しっかり俺の頸へしがみついたあの時から、俺は、俺はお前を……。",
              "citation": {
                "source": "片男波",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "来て見りやおれの股ぐらから、あの野郎がもう片息になつて、面妖な面を出してゐやがる始末よ。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとう……とう……と、と、と……」　声は次第に弱った、涙は泉のごとくわいた、そうして片息になって寝台に手をかけた、もう這いあがる力もない。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "代助には、平岡の凡てが、あたかも肺の強くない人の、重苦しい葛湯の中を片息で泳いでいる様に取れた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間も片息でなお地面を、お吉は這い廻り悶えていたが、「九十郎殿……死なれたか……死なれたそうな。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦痛が全身を渡るとみえ、二人ながら片息だ。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしたことだとたずねると、音七と半兵衛は片息をつきながら、「この魚は、神様がくだされたのか、重吉ぬしがくだされたのか知らないが、ここで跳ねまわっているのを見るなり、夢中で双方からとりつき、一と口食い二た口食いしているうちに、このように骨だけにしてしまった。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかでもない、あれからめっきり蒲鉾の味がよくなって、これが通な人々の間に喧伝され、そろそろ売上げも多くなり、今日日はどうやら片息吐いているから、この分でいけば日ならずして店の調子も立ち直ろうとの取り沙汰。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "巷説蒲鉾供養",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　片息ながら平兵衛の話した一伍一什。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "巷説蒲鉾供養",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
