        "examples": {
          "standard": [
            {
              "text": "パンデミックの発生を受け、各国政府は急いで入国制限の措置を講じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "深刻なインフレを抑制するため、各国政府は利上げを含む金融政策の見直しを迫られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "環境保護団体が、海洋汚染対策を強化するよう各国政府に強く働きかけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "フランス敗戦当時の首相レイノー、フランス元大臣シューマン、英国前外交顧問ヴァンシッター卿その他を委員とする、いわゆる「欧州問題研究委員会」は「長期に亙る犠牲の多い戦争を終結させるために朝鮮で原子爆弾を使用すべきである」という文書を、西欧各国政府におくった事実をつたえている。",
              "citation": {
                "source": "平和の願いは厳粛である",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば国際司法裁判所を構成する時の如き批准の催促状を各国政府に出すことが局の重要な仕事であったことがある。",
              "citation": {
                "source": "国際聯盟とは如何なものか",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しばらく、文明の進歩のより進んでいるこれら諸国において、各国の国内経済が非常にうまく行っているために人口に対する妨げは何もなく、また各国政府は移住に対するあらゆる便宜を与えるものと、仮定しよう。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            }
          ]
        }
