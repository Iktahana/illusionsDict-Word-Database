[
  {
    "uuid": "0f75fb59-d140-54c6-8bfa-a98ea522e617",
    "entry": "火防",
    "reading": {
      "primary": "かぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
