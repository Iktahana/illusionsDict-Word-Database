        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は会議を休むための口実（託つけ）として、急な体調不良を主張した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ちょっと喉が渇いたんだ」というのは、彼女がおしゃべりをやめさせるための口実（託つけ）だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "実は内藤君も到頭説きつけられてしまって、今日が二度目の稽古だそうだ」　と千吉君は他の吹聴に託つけて自分のことを告白しているような口吻だった。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "某は心中｜深く立腹して、他の事にかこつけて雲飛を中傷し遂に捕へて獄に投じたそして人を以て竊に雲飛の妻に、實は石が慾いばかりといふ内意を傳へさした。",
              "citation": {
                "source": "石清虚",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「明日はあれがこつちに來るかも知れないのよ」　行夫は枕から頭を上げて空を見やりながら、私の留守の間の不安を稻妻にかこつけてほのめかした。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "松崎は鮎釣が好きだったところからそれをかこつけに同業の伯父から紹介状を貰って河内屋に泊り込んでいた。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかこつけで、私は風流の道づれにされた次第だ。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに仏事参拝にかこつけて、かたきのゆくえ捜索を黙許されたもので、それは非常の恩典であると伝えられたそうである。",
              "citation": {
                "source": "かたき討雑感",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、お鎌の亭主の徳之助が死んだので、死骸を竜濤寺へ葬って、その墓参りにかこつけてお鎌は始終出這入りをしていたんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し然う一々天氣にかこつけられちや、天氣も好い面の皮といふもんさ。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "して其の當座、兩人はこツそり其處らを夜歩きしたり、また何彼と用にかこつけて彼方此方と歩き廻ツて、芝居にも二三度入ツた。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯島時代に彼女は店の用事にかこつけ、二日ばかり帰らぬ松島を迎えに行き、小菊に逢ったこともあったが、逢ってみると挨拶が嫻やかなので、印象は悪くなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "松崎は鮎釣が好きだつたところからそれをかこつけに同業の伯父から紹介状を貰つて河内屋に泊り込んでゐた。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたたちは、人の世話にかこつけて、お酒を飲んで騒ぎたいのでしょう？",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫が旅行で多日留守、この時こそと思っても、あとを預っている主婦ならなおの事、実家の手前も、旅をかけては出憎いから、そこで、盲目の娘をかこつけに、籠を抜けた。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなしい性質の青年は、実家の言うなりに思い諦めたらしく、受験をかこつけに東京へ出て、それきり帰らなかった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恥しいから奥様なんてかこつけたのよ。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、芳子はわざとヒロポンにかこつけて、アンプルを割るという芝居までして、銀ちゃんのふところへ転がり込んで来たのだが、しかし、一つにはお腹の子供のこともあった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次の日からは、用事にかこつけて、嫁さんは遅れて食べに出る。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "傲慢な親信は仕事にかこつけて見向きもしなかったので、血気の多い親実は怒って矢を飛ばした。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はその室にあがって、誰れにもとつかず一礼すると、女の方は丁寧に挨拶したが、男の方は気がついたのか、つかないのか、飯にかこつけて僕を見ないようにしている。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "南條新子に対して、前川が何となく、好もしい感情を持っているらしかったから、事にかこつけて、暇を出した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを知った頼朝は、事にかこつけて義久の家へ往って、宗親を呼ばして罵り、怒りに顫える手に刀を抜いて宗親の髪を截った。",
              "citation": {
                "source": "頼朝の最後",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、作者は、パリの女売子の運命を語るにかこつけて、実在のメアリ・ロジャーズ殺害事件の、肝要な事実を詳細にたどり、さほど緊要でない事実は単に類似させておいたのである。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜おとよは下心あって自分から風呂もたててしまいの湯の洗濯にかこつけ、省作を待つのである。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより良家の娘が道楽半分に習うというのであるから、その器用不器用などは大した問題でもなかったが、澹山の別に恐れるところは、彼女が絵筆の稽古をかこつけに、今後はいっそう親しく接近して来ることであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が澹山の絵の催促にかこつけてたびたび此の店へたずねて来るのもそれが為であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私は其次の日の夕方それがどんな女か見たいやうな気もしたので行つたこともない教師の寓居へ用をかこつけて行つて見た。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこが、ちょっとむずかしかったので、手拭いにかこつけて、即答を避けたというわけでもあったのだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨をかこつけに、もう一日か二日も逗留していたいという継子さんの心持は、わたくしにも大抵想像されないことはありません。",
              "citation": {
                "source": "停車場の少女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
