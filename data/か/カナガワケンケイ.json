        "examples": {
          "standard": [
            {
              "text": "神奈川県警は、大規模な交通検問を実施して飲酒運転の撲滅を厳しく呼びかけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あそこに止まっているパトカー、神奈川県警のシンボルマークがついているね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "複雑な詐欺事件の真相を早期に解明するため、神奈川県警の捜査一課が総力を挙げて動いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "迷子になって泣いていた男の子を、パトロール中の神奈川県警の警察官が優しく保護した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "Ｋ大病院、警視庁、神奈川県警察部、臼杵病院を手玉に取って来たか。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、島中君が南病院に入院したときに、夫人が祕書の藤田君を伴って、その旨を神奈川県警察へ釈明に行った。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
