[
  {
    "uuid": "1e3bb955-0cd1-5711-8dd0-3d651fdb32a8",
    "entry": "仮借",
    "reading": {
      "primary": "かしゃく",
      "alternatives": [
        "かしゃ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
