[
  {
    "uuid": "34b0d4b5-fb10-58fa-9485-1ddb9e40321d",
    "entry": "科学力",
    "reading": {
      "primary": "かがくりょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
