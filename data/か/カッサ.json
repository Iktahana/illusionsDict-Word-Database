[
  {
    "uuid": "b6abc568-7d6c-510a-a8fa-3f8dba0f413a",
    "entry": "刮痧",
    "reading": {
      "primary": "かっさ",
      "alternatives": [
        "カッサ"
      ],
      "is_heteronym": false
    },
    "grammar": {
