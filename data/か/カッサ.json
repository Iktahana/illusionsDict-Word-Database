    "definitions": [
      {
        "index": 1,
        "gloss": "gua sha (traditional Chinese healing method)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "最近、顔のむくみが気になるので、かっさプレートでマッサージを始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "エステサロンで、かっさを使った施術を受けて全身が軽くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "中国の伝統医療であるかっさは、美容にも良いと評判だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "おびき出した娘をかっさらッちまうのは、館駅街に於てやる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前をかっさらって、又、夜ぬけをしようってんだ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつがうまくできると、みんなで拍手かっさいしてやる。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "モルジアナは大そうじょうずにおどって、みんなにかっさいされました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "中島はまた紳士の生活とかっさいする。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "汀まで雪に埋まった海岸には、見渡せる限り、白波がざぶんざぶん砕けて、風が――空気そのものをかっさらってしまいそうな激しい寒い風が雪に閉ざされた山を吹き、漁夫を吹き、海を吹きまくって、まっしぐらに水と空との閉じ目をめがけて突きぬけて行く。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四はだんご鼻の竹公という遊び人が、他人の囲い者をこかして金子六十両をかっさらい、いずれかへ逐電したからめしとってほしいというだんなからの訴え、最後は所々ほうぼうからの訴えをひっくるめた一件で、浅草と神田と日本橋ににせ金をつかました者があったという、あまりぞっとしない事件でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "町人ながら腹かっさばいたうえで直訴するたア、性根が見上げたもんじゃねえかよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまだにあのとおり行くえのわからねえところを見るてえと、下手人の野郎め、騒ぎの起きたどさくさまぎれにべっぴんをかっさらって、無理心中でもしたんじゃねえかと思うんですがね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの訴え状にもあるとおり、時刻は夕がたとしてありますが、その夕がたのおよそいつ時分に、どこでどうやってあの質屋の子せがれがかっさらわれたのか、かいもく手がかりがねえっていうんでしょ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、やたらに今斯うやって自分を遠い東京へつれて行く夫に対して、可愛くてたまらない心と、にくらしい、両手で、ガリガリとかっさいてやりたいような憎嫌を感じて居た。",
              "citation": {
                "source": "「禰宜様宮田」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして重い体を器用に調子をとりながら、綱渡りの一｜曲を首尾よくやってのけましたから、見物はいよいよ感心して、小屋もわれるほどのかっさいをあびせかけました。",
              "citation": {
                "source": "文福茶がま",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "只、男のそばから逃げ出したと云う事だけがかっさい拍手。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の気に入ったものをちょいちょいとかっさらう。",
              "citation": {
                "source": "川端柳",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同はかっさいした。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　少年たちはあっけにとられてかっさいした。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十余頭の海ひょうを、九人の少年がえいえい声をあわして運んで来たとき、年少組はおどりあがってかっさいした。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれよ、あれよと、見物の衆の拍手大かっさいである。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "観客は拍手大かっさいである。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物人は、わっとかっさいしました」「ふーん。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、それが、目の前に、投弓の家にころがっていたものですから、若干の草鞋銭なんぞは辞退しても、これをかっさらって行こうという賊心に駆られたのも、また無理のないところがありましょう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "キートンのペチャンのおかま帽子にキョトンとしたお人好しの姿は、大かっさいであった。",
              "citation": {
                "source": "私の洋画経歴",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは微であったその声が――遣る瀬ないその声が今はもう鼓膜も破れよとばかり捲きころがり、捲きころがり凡ゆるものをかっさらわずにはやまぬ巨浪のようにどうどうどうと益々高く益々ひろく。",
              "citation": {
                "source": "プロパガンダ",
                "author": "加藤一夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天才は楽々と大発明をして世の人からかっさいを受けるが、鈍才はいくら勉強しても上級学校に入学すらできない。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "知識の低い大衆が、トリックや照明や音楽にごまかされ大かっさいをおくっているのだった。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "贋金だ贋金だと嘘を吐き、かっさらって行こうとしたんだわ！",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして背で弟が泣こうが、眠ろうが問題にせないで、どんどん田圃を横切り、川のあたりを越えて隣り村まで遊びに行き、よく喧嘩したり物をかっさらったりして来た。",
              "citation": {
                "source": "あまり者",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "でないとおかっさんが困るから。",
              "citation": {
                "source": "あたまでっかち",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ソレ、先生におくれるな」「なにも獲物のねえやつは、かまわねえから、相手の咽喉ッ首へくらいついてやれ」「オイ、八百屋の初さん、そんなおめえ、天秤棒などかつぎだして、どうしようってんだ」「なあにね、これで相手の脛をかっさらってやりまさあ」「オーオー、糊屋の婆さん、戦場に婆さんは足手まといだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
