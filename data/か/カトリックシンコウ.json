        "examples": {
          "standard": [
            {
              "text": "彼は、カトリック信仰を持つ家庭に生まれ、幼い頃から教会に通っていたと話していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域の建築様式には、中世ヨーロッパのカトリック信仰が色濃く反映されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人の結婚式で、厳かなカトリック信仰の儀式に初めて触れ、深い感銘を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史を学ぶと、カトリック信仰がヨーロッパの芸術や文化に与えた影響の大きさに驚かされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "カトリック信仰のみ。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして別にカトリック信仰のみが唯一絶対の真理把握の道であることも述べた。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずカトリック信仰をもちなさいと。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
