[
  {
    "uuid": "a2b6bac8-b8aa-5ad0-8437-b37d1a37d5ea",
    "entry": "風通し",
    "reading": {
      "primary": "かぜとおし",
      "alternatives": [
        "かざとおし"
      ],
      "is_heteronym": false
    },
    "grammar": {
