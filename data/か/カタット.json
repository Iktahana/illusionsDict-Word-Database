        "examples": {
          "standard": [
            {
              "text": "静まり返った真夜中の部屋で、誰かがペンを落としたのか「かたっと」小さな音が響いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "読み終えた本をそっと机に置くと、古い木の天板が「かたっと」乾いた音を立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "箸置きから転げ落ちた箸が、漆塗りの盆の上で「かたっと」音を立てて止まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」　若いお父さんは、その青白い時計をチョッキのポケットにはさんで靴をかたっと鳴らしました。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて八日目の朝署長が役所へ出て出勤簿を検査してそれから机の上へ両手を重ねてふうと一つ息をしたとき扉がかたっと開いてデンドウイ属があの八日前の白服のまゝでまた入って来ました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "署長は思はず椅子をかたっと云はせました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "舗装路の上に、靴はかたっかたっと音を立てた。",
              "citation": {
                "source": "変る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何か、かたっという音が机の上にした。",
              "citation": {
                "source": "蘇生",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
