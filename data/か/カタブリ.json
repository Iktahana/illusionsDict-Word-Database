        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この時期は偏降りが続き、農作業がなかなか進まない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "偏降りのせいで川が増水し、橋が通行止めになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長かった偏降りがようやく終わり、洗濯物が外に干せるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "梅雨の偏降りは憂鬱だが、植物にとっては恵みの雨だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこは、上州藤岡の劇場で、乗り込みを両三日中に控え、ちょうど千秋楽の日であったが、儀右衛門はひさかたぶりに、法水の来訪をうけた。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "久かたぶりの今日の外出は、鬱し切つてゐた身毒の心持ちをのう／＼させた。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "生か死か、覆面探偵　帝都の暗黒界からは鬼神のように恐れられている警視庁の大江山捜査課長は、その朝ひさかたぶりの快い目覚めを迎えた。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、巨船クイーン・メリー号はひさかたぶりに、なつかしい海上にぽっかり浮かんでいる。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "師と門下生とが、ひさかたぶりに水いらずで向きあっているのであった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の下にふんだのは、ひさかたぶりの火星の大地であった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの大名の壺にも、供の侍がおおぜいいることだから、ひさかたぶりにおれも、この濡れ燕も、思うさまあばれられようというものだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶筅、匙、柄杓、羽箒などが手ぢかにならんで、忠相はひさかたぶりの珍客泰軒に茶の馳走をしているのだった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あれから諸国を修業して、久かたぶりに江戸恋しく道場をたずねてみると、あれほどの大先生が焼死されたという。",
              "citation": {
                "source": "初午試合討ち",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "逼塞をゆるされて、源七郎がひさかたぶりに屋敷の門をひらいた日のことである、まえぶれもなく、竹岡兵庫がおとずれて来た。",
              "citation": {
                "source": "青竹",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫にとっては久かたぶりの平地の生活が、妻にとっては想像することもできない明るい町が、その爪さき遠くにはひろがっており、二人をまっていてくれる筈である。",
              "citation": {
                "source": "霧の蕃社",
                "author": "中村地平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
