        "examples": {
          "standard": [
            {
              "text": "優勝が決まった瞬間、選手たちは歓喜雀躍して抱き合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年の努力が実り、彼女は歓喜雀躍して家族に報告した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "宝くじが当たった知らせを聞いて、彼は思わず歓喜雀躍した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは、クリスマスプレゼントを開けるたびに歓喜雀躍していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "子供が生れたという報を受取って、京都へ飛んで行き、やがて帰って来た時の、彼の歓喜雀躍ぶりは到底筆紙に尽せる所ではなかった。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙と一つ、仏と一つ　私はそのときに、私がこの宇宙の中にいるからして、私は受け取ることができもしなければ、しなくともいいのだということを知ったときに、ほんとうに、とても歓喜雀躍いたしました。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
