    "definitions": [
      {
        "index": 1,
        "gloss": "common gull (Larus canus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "港の防波堤に一羽の鴎が止まり、じっと海面を見つめている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "船が動き出すと、餌を求めてたくさんの鴎がデッキの周りを飛び交った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あっ、あんなところに鴎が巣を作ってるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "潮風に吹かれながら、空を自由に舞う鴎の姿を眺めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "間もなくして、何だか堪らないやうに隣室に行く）男　「可愛くもあり、可愛くもなし」………あゝさうか、あれは「鴎」の中の台詞だ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎外がうまい事を言っています。",
              "citation": {
                "source": "わが愛好する言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "森鴎外氏の「即興詩人」は、原作よりもずつと善いといふ定評がある。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは鴎外氏の創作なんだ。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等は鴎外氏にだまされたのだ」と。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正にその通り、即興詩人は鴎外氏自身の作つた翻案なのだ。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに鴎が飛んでいたと書けば都合よけれども飛魚一つ飛ばねば致し方もなし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "細木香以に就いては、森鴎外くはしくこれを述べて居る故、われら小倉袴のぶんを以てかれこれ言ふべきではないが、通人とは、世人が考へて居られる如き、藝者末社をひきつれ、自らを何のや主人と稱して長唄の稽古にいそしみ、その巷に於いて兄さん兄さんと呼ばれて居る樣の、そんなふざけたものではないやうである。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "外へ出て見ると月は高い、槍ヶ岳は大海から頭をのそりと出す烏帽子岩のようで、雪の白条は岩の上へ鴎が糞を落したようだ、自分は恍惚として、今山の巓に立っているのか、波の寄る渚を歩いているのかと、惑った、夜の自然は一切を平等にして、山とか海とかに仮現する異性を失わせる。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川君とは鴎外博士宅に毎月歌会のあつた頃、幾度も幾度も逢つた筈である。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざ雪ふらば降れ、風ふかば吹け、我が方寸の海に波さわぎて、沖の釣舟おもひも乱れんか、凪ぎたる空に鴎なく春日のどかになりなん胸か、桜町が殿の容貌も今は飽くまで胸にうかべん。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこからか差す明りが、丁度波の上を鴎が走るように、床の上に影を落す。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "九竜に向けて二重デッキの白いランチが鴎のようにランプの尾を海水に引いて走りだした。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "時時白い鴎の群が水を滑るやうに低く飛んで、さつと身を飜しては船の陰に隱れる。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然主義運動に対立して平行線的に進行をつゞけた写生派、余裕派、低徊派等の諸文学（夏目漱石などその門下、高浜虚子、長塚節、永井荷風、谷崎潤一郎等）については、森鴎外が、軍医総監であったことゝ、後に芥川龍之介が「将軍」を書いている以外、軍事的なものは見あたらない。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "輕い、淡々しい雲が沖なる海の上を漂ふて居る、鴎が飛ぶ、浪が碎ける、そら雲が日を隱くした！",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "するすると向うへ流れて、横ざまに近づいた、細い黒い毛脛を掠めて、蒼い水の上を鴎が弓形に大きく鮮かに飛んだ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、池の真中から声を懸けて、おやじは小屋の中を覗こうともせず、爪さきは小波を浴ぶるばかり沈んだ筏を棹さして、この時また中空から白い翼を飜して、ひらひらと落して来て、水に姿を宿したと思うと、向うへ飛んで、鴎の去った方へ、すらすらと流して行く。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚もすら／＼泳ぐだらうし、松には藤も咲いてるさうだし、つゝじ、山吹、とり／″＼だと言ふ、其の間を、船の影に驚いて、パツと群れて水鳥が立つたり、鴎が泳いで居たり……」「然うで、然うで、其の通りで……旦那。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は鴎外の歴史小説が好きでしたけれど、芹川さんは、私を古くさいと言って笑って、鴎外よりは有島武郎のほうが、ずっと深刻だと私に教えて、そのおかたの本を、二三冊持って来て下さいましたけれど、私が読んでも、ちっともわかりませんでした。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちはそれより、浪の音や鴎の聲に耳傾けよう。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニイチエやビロンや春夫よりも、モオパスサンやメリメや鴎外のはうがほんものらしく思へた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニイチェやビロンや春夫よりも、モオパスサンやメリメや鴎外のほうがほんものらしく思えた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこんど軍隊からかえって来て、鴎外全集をひらいてみて、鴎外の軍服を着ている写真を見たら、もういやになって、全集をみな叩き売ってしまいました。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎外が、いやになっちゃいました。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一〇年の元旦にこの火山に登って湾を見おろした時には、やはりこの絵が眼前の実景の上に投射され、また同時に鴎外の「即興詩人」の場面がまざまざと映写されたのであった。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際この浜には乾いた枯蘆しかなく、水は遠浅の内海ですが、しかし沖のかたに潮満ち寄せる日中の白帆の群が介殻を立て並べたように鋭く閃めき、潮先の泡に向って飜り落ちてはまた煽ぎ上る鴎の光って入乱れる影が、ふと眼に入ると、どういうものか私は堪らなくなりました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき目にうつる船は、ずっと遠くに、カモメのように見えました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "船のしずんでいくありさまを見ていたのは、ただ、鳴きさけぶカモメと、水の中の、さかなたちだけでした。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、そのカモメやさかなたちも、ほんとうは、よくは見ていなかったのです。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
