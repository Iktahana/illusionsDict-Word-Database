        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "漁港に停泊している漁船の影から、鴎の鋭い鳴き声が聞こえてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "浜辺に落ちていた魚の干物を、数羽の鴎が激しく取り合っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夕暮れ時の海岸線を、鴎の群れがオレンジ色の空に溶け込むように飛んでいく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわっ、ソフトクリームを鴎に横取りされちゃった！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
