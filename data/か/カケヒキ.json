[
  {
    "uuid": "3b426a09-8853-5ff2-93c4-49974163a98c",
    "entry": "駆け引き",
    "reading": {
      "primary": "かけひき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
