        "examples": {
          "standard": [
            {
              "text": "優勝パレードの沿道では、色とりどりの紙吹雪が舞い、歓喜の声が響き渡っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "舞台のクライマックスで天井から紙吹雪が降り注ぎ、幻想的な演出に観客の目が奪われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「掃除が大変そうだけど、この紙吹雪が舞う瞬間はやっぱり最高に綺麗で盛り上がるね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "結婚式の退場シーンで、友人たちが手作りの紙吹雪を投げて祝福してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "美女たちがムーアを紙吹雪責めにした。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ楮幣を紙吹雪とすればよいのであった。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            }
          ]
        }
