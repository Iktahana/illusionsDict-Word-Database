        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「自分を棚に上げて正義を語るなんて、片腹痛いわ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ろくに練習もしていない彼が優勝を宣言するとは、片腹痛い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の見え透いたお世辞をずっと聞いていると、だんだん片腹痛くなってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "Ｔ「片腹痛い　返り討ちだ！",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女がこんな陳述をして居たとき、若い弁護人は、片腹痛いことに思つた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "これといって学歴も無い素人出の料理教師が、なにかにつけて理窟を捏ね芸術家振りたがるのは片腹痛い。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "當人は至極眞面目なのだらうが、傍から見ると、隨分片腹痛い場合がある。",
              "citation": {
                "source": "文藝中毒",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "獨逸語で 〔sittliche Entru:stung〕 といふと、頗る片腹痛い。",
              "citation": {
                "source": "當流比較言語學",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれで巴里歸りだなどゝ片腹痛いといふ樣なことが幾分職人肌のべらんめえ口調が交りつゝ語られた。",
              "citation": {
                "source": "記憶のまゝ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の手切文書を受けとった氏政は、是を地に擲って弟の氏照に向い、一片の文書で天下の北条を恫喝するとは片腹痛い、兵力で来るなら平の維盛の二の舞で、秀吉など水鳥の羽音を聞いただけで潰走するだろうと豪語したと云う。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、あんまり理想論を述べたてるのは止めて（御自分もさぞかし片腹痛いことだらうから――。",
              "citation": {
                "source": "新興芸術派に就いての雑談",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ程ののぼせ方で、主水之介に酔狂呼ばわりは片腹痛いわ」　にわかにうろたえ出した町役人共を尻目にかけて、怪死を遂げた古高新兵衛の骸に近よりながら、先ず鉄扇で打たれた脇腹を打ち調べてみると、然るにこれがますます不審です。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "出迎いなぞと片腹痛いわッ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺領の掟すらも弁えぬめくら武士が、目に角立ててのめくら説法、片腹痛いわッ。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "身延霊場に参って公儀直参が片腹痛いわッ。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "陪臣呼ばわりが片腹痛いわッ。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "片腹痛い真似を致さば、こやつでプツリ御見舞い申すぞ」　咄嗟にそこの長押から短槍はずし取って青江流手練れの位取りに構えながら威嚇したのは、九十一の老神官の沼田正守です。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "攘夷を唱うる者共の言もまた対馬には片腹痛い。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このようななまくら腕で、かたき討ちが片腹痛いわッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "片腹痛い言まで云ッてやがて下女が持込む岡持の蓋を取ッて見るよりまた意地の汚い言をいう。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を説くとは片腹痛い。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "局などと言われる狭い短い板の間の戸口に寄って薫の坐しているのを片腹痛いことに思う小宰相であったが、さすがにあまりに卑下もせず感じのよいほどに話し相手をした。",
              "citation": {
                "source": "源氏物語",
                "author": "蜻蛉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっといただく人が違っていたりしては片腹痛いではございませんか」　と姫君は言い、手紙は拡げたままで尼君のほうへ押しやった。",
              "citation": {
                "source": "源氏物語",
                "author": "夢の浮橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "何より片腹痛いのは、あの見るのも恥かしいやうな不態な恰好をしてゐながら、奴さん自分をいつぱしの優男と思ひこんでゐるらしいことだ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "山へ登るものが時に山を酒呑みの酒や、喫煙者の煙草にたとえているのには実に片腹痛いのである。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
