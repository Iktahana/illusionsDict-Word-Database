[
  {
    "uuid": "29cd1e39-20ca-5f14-98e1-ab17ee7e6c47",
    "entry": "頑な",
    "reading": {
      "primary": "かたくな",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
