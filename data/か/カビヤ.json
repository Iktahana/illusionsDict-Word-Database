        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古歌には、夜通し鹿火屋に詰めて田畑を守る農夫の侘しさが詠まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鹿火屋から立ち上る煙が、静かな山里に秋の訪れを告げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつては害獣から収穫を守るため、あちこちの田の端に鹿火屋が建てられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "われわれの心の皮膚はかなり鋭い冷湿の触感を感じ、われわれの心の鼻はかびや煤の臭気にむせる。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹雪があっしの頭に最初に浮かびやした。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
