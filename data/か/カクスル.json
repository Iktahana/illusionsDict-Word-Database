    "definitions": [
      {
        "index": 1,
        "gloss": "to draw (a line)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "地図上に、新しい建設予定地を赤い線で画した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "スケッチブックに、まず大まかな輪郭を鉛筆で画してみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この図では、関係性を点と線で画して分かりやすくしています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "換言すれば、この主張者たちは、世界人類の四分の一、則ち五億人を饑餓によって殺さんと計画するものなり。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者の拘束範囲が一つの面であるとすれば、後者はその面内にただ一つの線を画するような感じがある。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不易流行や虚実の弁については古往今来諸家によって説き尽くされたことであって、今ここに敷衍すべき余地もないのであるが、要するにこれは俳諧には限らずあらゆるわが国の表現芸術に共通な指導原理であって、芸と学との間に分水嶺を画するものである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば、この主張者たちは、世界人類の半分、則ち十億人を饑餓によって殺そうと計画するものではないか。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何人も疑う所のない点を疑う人は知識界に一時機を画する人である。",
              "citation": {
                "source": "知と疑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また小林は予ての持論に、仮令如何に親密なる間柄たるも、決して、人の意を枉げしめて、己れの説に服従せしむるは、我の好まざる所、いわんやわれわれ計画する処の事は、皆身命に関する事なるにおいてをや、われは意気相投ずるを待って、初めて満腔の思想を、陳述する者なりと、何事においても、総てかくの如くなりし。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や敵国に対して復讐戦を計画するにあらず、鋤と鍬とをもって残る領土の曠漠と闘い、これを田園と化して敵に奪われしものを補わんとしました。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "織女さまのおよろこびに附け込んで、自分たちの願いをきいてもらおうと計画するなど、まことに実利的で、ずるいと思った。",
              "citation": {
                "source": "作家の手帖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に疾病絶滅を計画する上に於いては、社会が単に社会的、個人が単に個人的では成就しない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上に説いたように、第一に社会的、第二に個人対社会と社会対個人的、第三に個人的、この三方面に於いて疾病の絶滅を計画する念慮と施設が十二分であったなら、永い歳月の後には、十二分の学術および経験の効力によって、或いは人間は疾病を絶滅出来るかも知れない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅葉の芸術的天分はエポックを画するだけの十分な力を持っていたが、それよりもなお一層｜勝れていたのは傘下の英才を統率して芸術的地盤を固めた政治的手腕であった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然派と高踏派或はスバル派、早稲田派と三田派等の間にも可なり鮮明な境界を画することができる。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれが大正十三年の春以後の東京に激増した事は、新日本の新紀元を画すると云ってもいい位だそうである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、「この創作集は日本探偵小説界の一時期を画する尊いモニュメントということができるであろう」",
              "citation": {
                "source": "『心理試験』を読む",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中には随分悪｜戯気の多い人もあるから、大に警察を騒がせて、草葉の蔭から笑ってやろうと計画する場合もあるだろう。",
              "citation": {
                "source": "闘争",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに、エドガア・アラン・ポオが探偵小説の鼻祖であるとおり、わが江戸川乱歩は、日本近代探偵小説の鼻祖であって、従ってこの創作集は日本探偵小説界の一時期を画する尊いモニュメントということが出来るであろう。",
              "citation": {
                "source": "「心理試験」序",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺人を計画するだけでさえ生に対する執着がむらむらと起るのであるから、殺人を行ったあげくにはどんなに猛烈に命が惜しくなるだろうかと彼は考えるのであった。",
              "citation": {
                "source": "死の接吻",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人の作が一時期を画するような新現象であるために世人はこれをロマンチシズムの代表者と見傚しました。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村の工業化の問題でも、それを計画する人々の間では、農村の若い娘の労働力というものが、重要な計算に入れられている。",
              "citation": {
                "source": "今日の文化の諸問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その原則の下に、大いに政府の政策の内部に積極的に参画することが望ましい。",
              "citation": {
                "source": "社大党はファッショ化したか？",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "余りけばけばしい装飾の遠慮、無力を一種の愛らしさとしていた怯懦の消滅、自分の手と頭脳にだけ頼って、刻々変化する四囲の事情の中に生活を纏め計画する必要に迫られたことは、其時ぎりで失せる才覚以上のものを与えた。",
              "citation": {
                "source": "私の覚え書",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にそれが大局的にみて百年の為に何事かを計画するという愉快な気分を失っていることでも互に似通っている。",
              "citation": {
                "source": "山の彼方は",
                "author": "――常識とはどういうものだろう――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、夫婦の愛情をおとりにし、運動に習熟していない妻であるわたしをとおして、宮本顕治をとらえようと計画する企図も試みられた。",
              "citation": {
                "source": "解説（『風知草』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "松田氏に聞けば、柏軒をして幕府の医官たらしめむとするは、兄榛軒の極力｜籌画する所であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「われわれは、一九一四年という年は経済史上の一転機を画するもので、全く新たなる時代が、われわれの経済生活の上に、この年とともに始まったものと考えざるを得ざるに至った。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ、私はプレンゲ氏とともに一九一四年はおそらく経済史上において将来一大時期を画する年となるであろうと思う。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度目には、たとえ参画するか否かを問われても、その道は選ばないだろうという予感があった　だが二度目のこのとき、参画はヨーコにとってもう少し近かった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二週間の研鑽学校を終えたとき、ヨーコは二人の子供を連れて参画する決意を固めていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "春日山から帰ったヨーコは、お決まりの淡々とした口調で「私は参画するよ」とタケシに告げ「あなたはどうする」と続けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかくするうち東の空白み渡りて茜の一抹と共に星の光まばらになり、軒下に車の音しげくなり、時計を見れば既に五時半なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
