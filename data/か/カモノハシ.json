        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "オーストラリアの動物園で、初めて生のカモノハシを見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カモノハシは卵を産む哺乳類として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あのカモノハシの独特のくちばしは、本当に不思議な形をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "全く死滅しないまでも山椒魚か鴨の嘴のような珍奇な存在としてかすかな生存をつづけるに過ぎないであろう。",
              "citation": {
                "source": "俳句の型式とその進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家鴨の嘴で突かれたり、牝鶏の羽でぶたれたり、鳥番の女の子に追いかけられるなんかより、どんなにいいかしれやしない。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほう、この家鴨の嘴みたやうな金具は、こりや何かな。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、今、相手が買ったばかりの家鴨の嘴を見せる。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴨の嘴よりたら／＼と春の泥昭和八年三月三日　家庭俳句会。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃い眉、濡みがちな眼つきをした大きな美しい眼、家鴨の嘴のように先端がやや赤味を帯びてそり返ってる太い低い鼻、人のよさそうなやさしげな厚い唇、元気な頑丈なふっくりしてる頤、高くはないが広い額。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリゲエタアや大蝙蝠の剥製だの、かものはしの模型だのの間で三造は独り本を読んでいる。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
