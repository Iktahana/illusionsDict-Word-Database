  },
  {
    "uuid": "1e0516c4-eaa2-54ce-8626-c39ecf7041b0",
    "entry": "客気",
    "reading": {
      "primary": "かっき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "youthful ardor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "若さゆえの客気で、彼は無謀な挑戦に挑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「今の君は客気に満ちている。少し落ち着きなさい」と先輩に諭された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の発言は客気によるものだろうが、もう少し周りを見るべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "又た事実に於ても此侠客気質の幾部分は、形骸を土木の労働者、鉱山の人夫などに止めて暫らくは存在しやう。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも曰附に違いないから、御亭主、一番｜侠客気を出しなさい。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し年が若かつたら、心気一転、姓名判断の易者にたのんで名でも変へて見る所だが、今ではそんな客気もない。",
              "citation": {
                "source": "名前の話",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、九州を過ぎ、中国筋を飛び、大坂、京の上空を過ぎて、近江の上空甲賀の山上まで飛んで来た時の佐助は、虚栄心に動かされやすい、青春客気の昂奮に、気も遠くなるくらい甘くしびれていた。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒川君の史論は、何等事相発展の裡面に哲理的批判を下す文明的史眼の萌芽なきを以て、主観的なる吾等には興味少なく候へ共、其考証精密なる学者風の態度は、客気にはやる等輩中の一異色に候。",
              "citation": {
                "source": "渋民村より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ青年客気感情の奔走するまゝに出たのである。",
              "citation": {
                "source": "世に出る前後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年の客気に任せて豪放｜不羈、何の顧慮する所もなく振舞うた。",
              "citation": {
                "source": "或教授の退職の辞",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "普段は写真を写されることを妙にテレ臭さがつて、単独で正面を切つて写したことなどは滅多になかつたにも関はらず彼は、何か目に見えぬものに逆せてゐる客気の人でもあるかのやうに、殉教者の如き一本気と、先達のやうな誇りを持つて、羞みを忘れた多くの姿勢をとつた。",
              "citation": {
                "source": "山を越えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "年少の客気があふれていたのであろう。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "予の渡江に急ならんとする、何ぞ少年の客気のみならんや。",
              "citation": {
                "source": "続野人生計事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "動もすればはやり勝ちな、一党の客気を控制して、徐に機の熟するのを待っただけでも、並大抵な骨折りではない。",
              "citation": {
                "source": "或日の大石内蔵助",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "集まるものはことごとく少壮の士、ふきだしそうな血は全身におどっている、その欝勃たる客気はなにものかにふれると爆発する、しかも今や涙をもって慈父のごとく敬愛する校長とわかれんとするのである。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん感情と一口に言っても高尚な感情もあるが、言うまでもなく今述べる感情は一時の客気である。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかくこの客気｜血気があれば考えに誤りを生じやすい。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "本間氏はそれを抱負の大きい所以に帰してゐられるが、私には年少の客気の思ひ上つた姿はいいとしても、その抱負らしく見せてゐる高慢な点が如何にも変に感じられるのを止められない。",
              "citation": {
                "source": "言文一致",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "日当りの良い家だけれども、なぜか陰気で、死の家とはこんなものかと考え、青年客気のあのころですら、暗さを思うと、足のすすまぬ思いがしたものである。",
              "citation": {
                "source": "青い絨毯",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに壮年客気に富んだ際であったとは云え、今から思えば実に滑稽なまでに昂奮したものであった。",
              "citation": {
                "source": "法隆寺再建非再建論の回顧",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時の余には賤しむべき一種の客気があって専門学校などは眼中にないのだというような見識をその答案の端にぶらさげたかったのである。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『文選』を耽読していたのと、どうも偏に山や石のついた字を使わないと、気分が露れないように思った年少｜客気の致すところと相俟って、こんな文章となってしまった。",
              "citation": {
                "source": "木曾駒と甲斐駒",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "名家の末路に花を飾ることをせず、後足で砂を懸けた腰抜武士の多きに憤慨して、何の腹の一つ位、切れといえば直にも切って見せると実際考えていた程、客気に逸っていた頃であるから、此処迄来たのを幸に五郎の英霊を弔ってやろうと立ち寄ったのであった。",
              "citation": {
                "source": "木曾駒と甲斐駒",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時あれほど熱中したのも、全く青年客気の致すところであった、とあとになってよく分った。",
              "citation": {
                "source": "私の履歴書",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "刻下の事情と云うものは、転瞬の客気に駆られて、とんでもない誤謬を伝え勝ちのものである。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "身のほどもわきまえずに客気にはやり、古今未曽有の大スクープをモノしようなどと企てたばっかりに、魔都「東京」の魑魍の呪を受け、こんな悲惨な最後をとげることになった。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "今となっては後悔もして居るが、その時は青年の客気で、女一人の骸を横たえる位の事は何んとも思っては居なかった――　簡単に言うと、海原伯爵家の次男に生れた私が、ある許されない女と、神戸へ逃げて世帯を持って居たことがある。",
              "citation": {
                "source": "死の予告",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、英米独仏の大辞書の完備に対して限りなき羨望の情が動き、ひたむき学究的な理想にのみふけりつつ、青春の客気で現実的方面については一層暗愚であったことは、後年とほぼ同様であった。",
              "citation": {
                "source": "『広辞苑』自序",
                "author": "新村出",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神にのみ偏して、肉体をおろそかにしつつ、青年の客気にはやった放恣な生活、眠らずに明かした幾夜、たばこの烟に濁った狭い部屋の空気の中で過ごした幾日、みずからを仕事へかり立てるために用いた幾多の陶酔剤――それがいま祟ってきた、祟ってきたのだ。",
              "citation": {
                "source": "悩みのひととき",
                "author": "SCHWERE STUNDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえ彼女は、クリストフのおかしな客気や、乱暴や、架空的な気分などを見て、彼があまり平衡のとれた人間ではないと思っていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアノの棚に肱をかけ、手に額を置いて彼は、年少の客気と惑乱との調子で自作の注釈をしてるクリストフを、ながめてやっていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "峰には未だ、残の雪がかっきりと、白く浮き上って見えるほどである。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "足もとは暗いが、木の梢だけは、夜の空にかっきりと黒く張って、穂高の輪廓は、ボーッと、物干棹でも突き出したように太く見える。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
