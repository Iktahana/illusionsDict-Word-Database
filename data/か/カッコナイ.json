        "examples": {
          "standard": [
            {
              "text": "答案用紙の指示は、カッコ内に詳しく書かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼のセリフのカッコ内には、「（不安そうに）」と演技の指示があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プレゼントに添えるメッセージは、カッコ内で補足情報を示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "以上冬期でないものおよび単独行でないもの（カッコ内のもの）も列記したが、これによって見ればほぼ容易な山行から漸次困難な山行へ進んでいるといえよう。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カッコ内の化合物は中間生成物と思われるものである（※）。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の第二のカッコ内の「利己的安定」という訳語は意味がわからない。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
