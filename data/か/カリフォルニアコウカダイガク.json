        "examples": {
          "standard": [
            {
              "text": "彼女は宇宙物理学の研究をするため、カリフォルニア工科大学への進学を目指している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カリフォルニア工科大学の研究チームが、新たな素粒子を発見したと発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "世界中から優秀な学生が、カリフォルニア工科大学で最先端の学問を学んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人はカリフォルニア工科大学の博士課程に進み、ロボット工学の分野で活躍している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "電子少年ウォズニアックアップル※を創る　一九五〇年八月、スティーブン・ウォズニアックは、カリフォルニア工科大学で電気工学を専攻したエンジニア、ジュリー・ウォズニアックの長男として生まれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイスクール時代の後半を、コンピューターの回路設計に夢中になって過ごしたウォズニアックは、父の母校であるカリフォルニア工科大学の受験に失敗し、地元のデアンザ・コミュニティー・カレッジにしばらく籍を置いたあと、一九六八年、コロラド大学に入りなおした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
