        "examples": {
          "standard": [
            {
              "text": "焦っていたのか、打者はタイミングが合わずにバットが空振った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は剣道の稽古で、相手の動きに反応しきれず竹刀が空振ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ボールが変化したため、バッターは大きく空振ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "素振りでは完璧なのに、本番になるとつい空振ってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それを青ギスがみつけると、ゆっくりとそばへ寄ったのではイソメが頭を引っ込めてしまうから、一間も先からとびついて、頭をくわえてからぶるぶると引っぱり出して食う。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大納言、嬉し気な表情）昨夜、あれの部屋に行って、ふと何気なく見ましたところが、お手紙は鶴に折られて、天井からぶるさがっておりましたじゃ。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして踵からぶるぶる顫えを走らせていた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            }
          ]
