        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "silent reading of the sutras",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎朝、僧侶たちは本堂で静かに看経に励み、心を整える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖父は亡くなるまで、日課として欠かさず経典を看経していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "座禅の後、参加者たちは各々、与えられた経文を看経する時間を与えられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "寺院の古い記録には、歴代住職の看経の様子が克明に記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（雪やみて朝日は青く、　　　　かうかうと僧は看経。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが佳※よ、鐘きこゆ、野に下りて葡萄｜樹の汁滴る邑を過ぎ、いざさらば、パアテルの黒き袈裟はや朝の看経はて、しづしづと見えがくれ棕櫚の葉に消ゆるまで、無花果の乳をすすり、ほのぼのと歌はまし、いざともに角を吹け、わが佳※よ、起き来れ、野にいでて歌はまし、水牛の角を吹け。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて薩摩の人に聞きしは、太閤本願寺僧をしてその国を細作せしめしより、島津大いに恨み一向宗を厳禁せしも、士庶のその宗旨を奉ずる者、弥陀仏像を柱の中に収め朝夕｜看経して維新後に及べり、と。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "――なお、これは余談ですが、まもなく本郷妻恋坂の片ほとりに、三体の子ども地蔵が安置されて、朝夕、これに向かって合掌｜看経を怠らぬ年老いた尼と、年若い尼のふたりが見うけられました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは暫く看経をいたして、あとで床に入りますから、どうぞお先へ……」　僕は逡った。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "看経が終るまで一時であろうが、その間だけでも睡り、尼僧が入って来たら起きようと心に決めた。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　そんなことを考えているうちに、看経は終った。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫君たちが看経したあとと思われる。",
              "citation": {
                "source": "源氏物語",
                "author": "椎が本",
                "note": "青空文庫"
              }
            },
            {
              "text": "守りをするのから牛乳の世話まで、和尚自身が看経の暇には、面倒を見ると云う始末なのです。",
              "citation": {
                "source": "捨児",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の方では看経を致すものもあり、本堂でお経を上げて居るものもありまして、種々働いて居りまする。",
              "citation": {
                "source": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "author": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉羽之介は不思議にも、先程の恐ろしい出来事と今聴く淋しき看経の声とに頭が擾され、今迄の来し方を思い出しました。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝毎晩看経をするのは、尼としては当然のことであったが、突然一同が打ち揃って、どこへともなく行くことがあった。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或深夜のことであったが据えてある五個の位牌の前で彼は看経に更っていた。",
              "citation": {
                "source": "稚子法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恩怨二ツ乍ら差別を立てず、彼は祭っているのであったが、看経中ばに不図彼は不思議な物音を耳にした。",
              "citation": {
                "source": "稚子法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風が枝を鳴らす音かも知れない……」　斯う呟くと気を取り直し一心に看経を続けて行った。",
              "citation": {
                "source": "稚子法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらばおれはこれから看経しょうぞ。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "看経も時によるわ、この分きがたい最中に、何事ぞ、心のどけく。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、市川猿之助の舞踊劇『黒塚』に心酔して、これを三、四回観たのであるが、那智から巡りきた行脚の僧の看経の功徳により、安達ヶ原の鬼女は悪夢から覚めたように過ぎし罪業を離脱し、ゆくりなくも童心に返って丸い大きな月が遍く照らす芒野にさまよいいで、幼きころ都にて習いおぼえし月の歌の踊り。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はい、仏間深く看経中にて思わぬ失礼――して何ぞ御用でござりまするか。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "梅雨に咲く花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お付きの尼僧の話では、朝は四時に起きて、本堂へ出て看経する。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の緊張がゆるむと、わたくしは寺僧が看経するらしい台の上に坐して、またつくづくと仰ぎ見た。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後｜看経のついでにある経に「仏法を学せんと思はゞ三世の心を相続することなかれ」とあるのを見て、これだと思ったことがある。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハイ」　看経を止めて、静かに振り向いた庵主の顔は、何という邪念のない平静さでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金の鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "庵室の中は貧しい灯が入って、鉄心道人は看経をおわったところでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "活き仏",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から下の本堂で、看経の鐘がゴーンと鳴りました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "観音様の頬",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも静かな看経のひまひまには、茶を立てたり、手習いをしたり、暦を繰ったり仏具を磨いたりして、まめまめしい日を送っていた。",
              "citation": {
                "source": "性に眼覚める頃",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかの日、信之助と別れた二岐道の畔に、小さな草庵を建て、朝夕を静かな看経に送り迎えしていた。",
              "citation": {
                "source": "春いくたび",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……月心尼は草庵のなかに坐ったまま、終日看経していた、心は静かに澄んでいたし、眼には仏の慈悲を思わせる浄光が溢れていた。",
              "citation": {
                "source": "春いくたび",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂ・Ｄバッジを包んだ手紙を、拾ってくれた少年の話で、中井、北見の二少年が、かんきんされている部屋の見当はついていますので、手さぐりで、その方へ、しのんでいくのです。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の少年は、あきらかに、魔法博士のために、かんきんされているのです。",
              "citation": {
                "source": "虎の牙",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
