        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "法要では、導師の声に合わせて参列者一同が看経を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は病気の母の回復を願い、毎晩、熱心に看経を続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "深夜の寺から聞こえてくる看経の声は、辺りの静寂に響き渡っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいお堂の落慶法要で、大勢の僧侶による看経が厳かに執り行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
