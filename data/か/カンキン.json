  {
    "uuid": "2825fc1b-461b-55cb-9090-f8f29670b161",
    "entry": "看経",
    "reading": {
      "primary": "かんきん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
