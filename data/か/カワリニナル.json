[
  {
    "uuid": "8051d5af-b4ed-5041-9b12-790555bf69b8",
    "entry": "代わりになる",
    "reading": {
      "primary": "かわりになる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行"
      ],
