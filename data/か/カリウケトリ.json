        "examples": {
          "standard": [
            {
              "text": "商品が到着次第、納品書を基に正式な受領書を発行し、今は仮受取とする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "書類に不備があったため、本受取ではなく仮受取として処理せざるを得なかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "これはあくまで仮受取なので、正式な手続きは後日改めて行います。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "荷物を受け取った際、ドライバーから仮受取のサインを求められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ともかく、ぼくがあなたの代理で、仮受取をおいてきました」　なんのことなのか、じっくりと頭にはいってこない。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これが水野家からの仮受取でございます、そちらへお渡し申します」　お銀様はその受取の書附を取り上げて、「弁信さん」　挨拶は弁信の方へ向いました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
