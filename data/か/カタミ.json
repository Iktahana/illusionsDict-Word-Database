[
  {
    "uuid": "5991dbdb-6c13-529d-a042-2d7bc37cee0e",
    "entry": "形見",
    "reading": {
      "primary": "かたみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "memento (esp. of a deceased person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖母の形見の指輪は、いつも私の指で輝いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "父の形見の時計は、動かなくなっても大切に保管している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "戦死した友の形見として、彼の愛用していた万年筆を受け取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は亡き母の形見である古い着物を、今でも時々袖を通している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（今から考へると、このシャンパン酒は彼の生前の形見だつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　子規の家から不折氏の家へ行く道筋を画いて教えてくれたものが唯一の形見として私の手許に残っている。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "床中で握りつめながら死んだといふ傷ましい形見の遺作であつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（この詩集に※入した金泥の口絵と、赤地に赤いインキで薄く画いた線画がその形見である。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからひと月もたって、Ｂ教授の形見だと言ってＮ国領事から自分の所へ送って来たのは大きな鋳銅製の虎の置き物であった。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかくの形見ではあるがどうも自分の趣味に合わないので、押し入れの中にしまい込んだままに年を経た。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋの家はわたしの家から直徑にして四町ほどしか距れてゐなかつたが、場所は番町で、その頃には江戸時代の形見といふ武家屋敷の古い建物がまだ取拂はれずに殘つてゐて、晴れた日にも何だか陰つたやうな薄暗い町の影を作つてゐた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "千駄木時代の絵はがきのほかにはこれが唯一の形見になったのであったが、先生死後に絵の掛け物を一幅御遺族から頂戴した。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼女の忘れ形見の年頃の寫眞である。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻の――昨日までは兎も角も生きてゐて、彼れと同じに人間であつたその妻の形見といつては、これだけになつてしまつたのだ。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "形見としてその二つ三つを取納め、余は引き裂きて庭に持ち出で、涙の種をことごとく烟とす。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨山中の寒い朝、哀れは同じ片思いの男と女は、温かい涙を形見の花に灑いで別れた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "重太郎は唯この形見の枝を保護することにのみ屈託して、夢のように岩石の間を辿った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お葉が形見の山椿の枝を抱えて、一旦は其場から姿を隠したが、流石に遠くは立去らなかった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋しい人の形見と思えばこそ、花も葉もない斯んな枯枝を、彼は幾多の不便を忍んで今まで身に添えていたのであろう。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうわけだから、家の人達はすぐにその人形を仏前に供えて、死んだ娘が唯一の形見として大切に保存している。",
              "citation": {
                "source": "河鹿",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "会談一時間ばかり、そこを出てから（結城孫三郎のあやつり人形見物はやめにして）やたらに歩きまはつた、ネオンサインのうつくしさ、デパートのさわがしさ、飲んだり食べたりのいそがしさ。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、何故僕は自分で幸子さんを殺したなぞと云い出したのかと、不思議に思うかも知れないけれど、それは只兄さんが死んだ幸子さんの思い出や、形見ばかりに綿々としている様子が、僕にはひどく哀れに思えると同時に、我慢のならない程反感を感じさせたからです。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は軍人の父が形見に残していった望遠鏡で男と女との媾曳を覗いた。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は淫慾のゆふべより飛散し散亂し、しかも哀しき肉身交歡の形見をだにもとめない頽廢徳者だ。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日記帳は、僕の形見として、この家に残して行こう。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども流石に背中のリユツクサツクには、母の形見を縫ひ直して仕立てた縫紋の一重羽織と大島の袷、それから仙台平の袴を忍ばせてゐた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、やがて贈り主の悲しき形見になつたその寫眞器は、支那の旅から歸ると間もなく、或る文學青年の詐欺にかゝつてうしなはれた。",
              "citation": {
                "source": "寫眞と思ひ出",
                "author": "――私の寫眞修行――",
                "note": "青空文庫"
              }
            },
            {
              "text": "討死と覚悟きめて、母のたった一つの形見の古い古い半襟を恥ずかしげもなく掛けて店に出るほど、そんなにも、せっぱつまって、そこへ須々木乙彦が、あらわれた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "討死と覚悟きめて、母のたつた一つの形見の古い古い半襟を恥づかしげもなく掛けて店に出るほど、そんなにも、せつぱつまつて、そこへ須々木乙彦が、あらはれた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "関係していた女はそれを聞いてひどく悲しんだが、いよいよ別れる日になると、禅宗の僧侶の衣の腰に着ける一本の紐を縫って持って来て、「これを、私の形見に、いつまでもつけてください」　と云ってそれを僧の腰へ巻いて往った。",
              "citation": {
                "source": "這って来る紐",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「師匠、これを、わっしに」「形見だから、執っといてくんねえ、乃公の後を継いでくれるのは、おめえだけだ」　海老蔵はそれから夕陽の影法師のような力ない足どりで帰って往ったが、それから一週間して綱右衛門は、海老蔵の死亡の通知に接した。",
              "citation": {
                "source": "お化の面",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）きちんと胸高なお太鼓に、一銭が紫粉で染返しの半襟も、りゅうと紗綾形見せたであろう、通力自在、姐娘の腕は立派である。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼をそうさした女のたった一つの形見だったのだ。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗谷〔一〕宮沢賢治まくろなる流れの岸に根株燃すゆふべのけむりこらつどひかたみに舞ひてたんぽゝの白き毛をふく丘の上のスリッパ小屋に媼ゐてむすめらに云ふかくてしも畑みな成りてあらたなる艱苦ひらくと",
              "citation": {
                "source": "宗谷〔一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
