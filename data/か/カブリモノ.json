        "examples": {
          "standard": [
            {
              "text": "ハロウィンの仮装パーティーで、友人が動物の被り物をしていて誰だか分からなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遊園地でキャラクターの被り物を買って、一日中頭に乗せて楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "誕生日サプライズで、主役の顔が印刷された被り物をみんなで被った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "フェス会場では、奇抜なデザインの被り物をしている人がたくさんいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
