          "standard": [
            {
              "text": "昔の小説では、金持ちが囲いを置く話が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は奥さんの他に囲いを抱えていたと噂されている。",
              "citation": {
