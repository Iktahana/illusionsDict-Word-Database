    "definitions": [
      {
        "index": 1,
        "gloss": "wall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "隣の部屋からの騒音がひどく、薄い壁をどうにかしたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地震で壁に大きな亀裂が入ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "画廊の白い壁には、様々な現代アートが飾られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供が壁に落書きをしてしまい、母親が困っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このアパートの壁は防音性が低い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "だつて君そこに浮気があります浮気は悲しい音楽をヒヨツと忘れさせること度々です空　空　空やつぱり壁は土で造つたものでした。",
              "citation": {
                "source": "不可入性",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「西部劇通信」だの「ゼーロン」だのを書いた昭和五年の頃は、彼の返り咲きの観があつたし、評判がよかつたのであるが、あの頃のものよりも、それから暫く後に書いた、水車小屋の壁に凭れて月の明りで手紙を読む短篇なぞの方が、遙かに牧野さんらしいものであると思はれる。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の正面の壁に子供の小学校の霜降の服と、糊でビリビリの日覆をかけた小学帽とが掛かつてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "カヤリの煙がユラユラと壁に映つて、十一時頃であり、そのうちまた出掛けさうな気配にもなつたりして、時は刻々に過ぎつゝあつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁をみるとユトリロの風景の複製と、誰のだか知れない裸かの女三人が浅瀬でボートに乗移らうとしてゐる絵とが掛かつてゐる。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "左側壁に一つの大きい窓。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面壁右隅に隣室に通ずるドアあり。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからマントを正面壁に掛け、机に来て甘味さうに吹かす。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大工ヤ壁屋ヤ沢山ノ仕事デ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の行く手には、死の壁以外に何も無いのが、ありありと見える心地がしたからだ。",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女が部屋に行つて見ると、お祖母さんは彼女の方を見向きもしないで、壁の傍で良子の袴を畳んでゐた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁一重隔てた校長室で、校長は矢鱈にその方に気を取られてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「壁に投げちやゐまいね。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕を出して午睡しようと思つてる時、「俺には女は当分当抵得られないものだ……」つて言葉の一字一字が、所々ハゲた壁の上にピヨコピヨコみえるやうな気がした。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁の隅には昼の蛾がポチポチゐた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アラ、来週はメーベルノーマンドの写真なのね、あたし今度は一人で来るわ」　予告のビラが横手の壁にあつたのをみて、Ｓ子はさういつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い冬の日が梁や壁を搾めつけるやうに、私も搾められてゐるんだ。",
              "citation": {
                "source": "暗い天候",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "春雨や人住んで煙壁を洩る　蔦かずらの纏う廃屋の中から、壁を伝って煙が洩れてる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙万象の秋、人の心に食い込む秋思の傷みを咏じ尽して遺憾なく、かの芭蕉の名句「秋ふかき隣は何をする人ぞ」と双壁し、蕪村俳句中の一名句である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬空に凍える壁、洋燈、寂しい人生。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁｜一重の隣家で、夜通し鍋など洗っている音がしている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その背後の壁には乾鮭がさがり、戸外には空也念仏の声が通る。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年はアパートの五階に住み荒漠たる洋室の中壁に寢臺を寄せてさびしく眠れり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下鐵道にてひとり來りて地下鐵道の青き歩廊をさまよひつ君待ちかねて悲しめど君が夢には無きものをなに幻影の後尾燈空洞に暗きトンネルの壁に映りて消え行けり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁に映りて過ぎ行けり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼年時代には、壁に映る時計や箒の影を見てさえ引きつけるほどに恐ろしかった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時、女中が杓文字の影を壁に映した。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "榊の影が大きく壁にうつって茄子や葡萄が美しくかがやいた。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水色の壁に立てけけた真白な石膏細工の上にパレットが懸って布細工の橄欖の葉が挿してある。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水部の線宮沢賢治きみがおもかげうかべんと夜を仰げばこのまひる蝋紙に描きし北上の水線青くひかるなれ竜や棲みしと伝へたるこのこもりぬの辺を来れば夜ぞらに泛ぶ水線の火花となりて青々と散る",
              "citation": {
                "source": "水部の線",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "barrier",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は言語の壁を乗り越え、海外で成功を収めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プロジェクトを進める上で、資金の壁が立ちはだかっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい技術を導入するには、古い慣習という壁を打ち破る必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この病気の治療には、いまだ大きな壁がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「もう無理だ」と彼は精神的な壁を感じていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "Chinese \"Wall\" constellation (one of the 28 mansions)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "東の空に壁宿が輝き始める頃、秋の夜長を感じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日の星占いによると、壁宿の人は恋愛運が良いらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「壁宿は水の星だから、感情豊かで直感力に優れるって言われているわ」と彼女が説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古代中国では、壁宿の動きを見て農事の時期を判断していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "壁宿と室宿が並んで見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 4,
        "gloss": "wall (of stones)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古い教会の庭には苔むした石の壁が残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの城の壁は、何世紀もの風雪に耐えてきたのだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の農家では、畑の周りを石の壁で囲んで野生動物から守っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "作業員たちが一つ一つ石を積み上げ、強固な壁を築き上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "崩れかけた壁の隙間から、小さな花が顔を出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
    ],
