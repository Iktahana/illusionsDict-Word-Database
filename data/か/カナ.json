    "definitions": [
      {
        "index": 1,
        "gloss": "I wonder",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「明日のバーベキュー、雨が降らないといいんだけどな。予報はどうかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あの限定商品はもう売り切れちゃったかな。まだ在庫があればいいんだけど。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「さっき外したメガネ、どこに置いたかな。カバンの上にも見当たらないや。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "蝉が鳴いてゐる、蝉が鳴いてゐる蝉が鳴いてゐるほかなんにもない！",
              "citation": {
                "source": "蝉",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば今晩かなしげに、かうして沈んでゐる僕が、輝き出でる時もある。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その志明かなれば冬の夜を、われは嘆かず、人々の憔燥のみの悲しみや憧れに引廻される女等の鼻唄を、我が瑣細なる罰と感じそが、わが皮膚を刺すにまかす。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなしきものまにや、のぞみうしなひ、いつさいより靈智うしなひ。",
              "citation": {
                "source": "偏狂",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "めざめよ、み空の金鑛、かなしくうたうたひ、なみだたれ、われなほ土地を掘らんとす。",
              "citation": {
                "source": "鑛夫の歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "靈智萩原朔太郎ふるへる、微光のよるに、いつぱつ、ぴすとるを撃つ、遠方に、金の山脈、かすかな、黒曜石の發光。",
              "citation": {
                "source": "靈智",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "祕佛萩原朔太郎つゆしものうれひはきえず、わづかなるつちをふむとて、あなうらをやぶらせたまふ。",
              "citation": {
                "source": "祕佛",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しだいに四方を眺むれば、遠き地平を超え、黒き眞冬を超えて叫びしんりつす、ああ聖地靈感の狼ら、かなしみ切齒なし、にくしんを研ぎてもとむるものを、息絶えんとしてかつはしる。",
              "citation": {
                "source": "巡禮紀行",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔郡属伊原忠右エ門〕宮沢賢治郡属伊原忠右エ門科頭にゴムの靴はきて冬の芝生をうちよぎり南ちゞれし綿雲に雨量計をぞさゝげたる天狗巣病にはあらねどもあまりにしげきこずゑかな",
              "citation": {
                "source": "〔郡属伊原忠右エ門〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔まひるつとめにまぎらひて〕宮沢賢治まひるつとめにまぎらひてきみがおもかげ来ぬひまはこころやすらひはたらきしそのことなにかねたましき新月きみがおももちをつきの梢にかゝぐれば凍れる泥をうちふみてさびしく恋ふるこゝろかな",
              "citation": {
                "source": "〔まひるつとめにまぎらひて〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなたにてきらめく川やさてはまた遠山の雪その枝にからすとまればざんざんと実はうちゆるゝこのときに教諭白藤灰いろのイムバネス着ていぶかしく五助をながめ粘土地をよこぎりてくる",
              "citation": {
                "source": "〔洪積の台のはてなる〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔ゆがみつゝ月は出で〕宮沢賢治ゆがみつゝ月は出でうすぐもは淡くにほへり汽車のおとはかなく恋ごゝろ風のふくらしペンのさやうしなはれ山の稜白くひかれり汽車の音はるけくなみだゆゑ松いとくろしかれ草はさやぎてわが手帳たゞほのかなり",
              "citation": {
                "source": "〔ゆがみつゝ月は出で〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔雲を濾し〕宮沢賢治雲を濾しまことあかるくなりし空かな子ら歓呼してことごとく走り出でしも宜なれや風のひのきはみだるるみだるゝ",
              "citation": {
                "source": "〔雲を濾し〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋宮沢賢治草穂のかなた雲ひくきポプラの群にかこまれて鐘塔白き秋の館かしこにひとの四年居てあるとき清くわらひけるそのこといとゞくるほしき",
              "citation": {
                "source": "恋",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "釜石よりの帰り宮沢賢治かぎりなく鳥はすだけどこゝろこそいとそゞろなれ竹行李小きをになひ雲しろき飯場を出でぬみちのべにしやが花さけばかうもりの柄こそわびしきかすかなる霧雨ふりて丘はたゞいちめんの青谷あひの細き棚田に積まれつゝ廐肥もぬれたり",
              "citation": {
                "source": "釜石よりの帰り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔このみちの醸すがごとく〕宮沢賢治このみちの醸すがごとく粟葉などひかりいでしはひがしなる山彙の上に黄なる月いざよへるなり夏の草山とになひてやうやくに人ら帰るをなにをかもわがかなしまんすゝきの葉露をおとせり",
              "citation": {
                "source": "〔このみちの醸すがごとく〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　　　　　　　　×　話頭一｜転、信義なき対人圏にあつて、芸術家が何を得るとしても何れは僅かなものである。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し人々は却々それに気が付かなかつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この計画的になされたものでこそなかつたが、仄かな表現や、語の気紛れな使用こそ、来るべきサンボリスムを予兆せる所のものである。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しパンセは起るものとして自己を益し、パンセしようとしてすれば良く行つて歴史家の知にしかならないものだ。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分自身であるといふことは、嘘をつかないことであり、自分自身であることは意志的であることである。",
              "citation": {
                "source": "詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「書いてゐる奴等はいつたい、いかなれば書けるのであらう？",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しさうとは気が付かない。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂはまたそれを感ずるから、「君等の考へてることは違ふ」とかなんとかいふ、とまれ形勢は悪くなるから、それ聴く方は漸く面倒臭がりだすから、尚も云はうとすれば声は次第に金切声になるとか、怒りつぽくなるとする。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さてはＢ君、俺の金がツケメかな」とＡ君が試みに思ふとする。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂといふ人間全体として何も無邪気ぢやないまでも、文学にしか頭が向かないところから、その他のことでは、尠くも不慣れくらゐのことはある。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "右は、Ａが金持でＢが貧しい場合だが、もしそれが反対であつても、必竟ＡがＢを、「あんな奴でも偉いのかなァ」と思ふ、つまり交際の上でＡがＢより優勢になることは同前なのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、文学志望で文学が書けぬといへば、尠くも近頃は「困つた」と思ふが、「いいものを書いてゐるが認められぬ」といふことは、「まあまあそのうちなんとかなるよ」と、それも甚だ好い気な調子で肩叩かれる。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "読んでみようかなと思つて読みだしたのであつて、斯く斯くの欲求を満すべくは芸術書に依るべきだとして読み出したのではなかつたのである。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
