    "definitions": [
      {
        "index": 1,
        "gloss": "steamed fish with grated turnip on top",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "料亭で運ばれてきた蕪蒸しの蓋を開けた瞬間、柚子の香りがふわっと座敷に広がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "白身魚をすりおろした蕪で包んで蒸し上げる、冬の京都を象徴する上品な料理だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あんかけがとろりとかかった蕪蒸しは、冷え切った体への何よりのご馳走だね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "小笠原章二郎の招待、まなかつをと白いさしみ、かぶらむし等々ウンと食って、若竹で鯛めし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "子持はぜ、鯛つくり、まなかつを、あら焚、かぶらむしと食べる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "hollowed-out turnip stuffed with chicken, shrimp, gingko nuts, etc.",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大きな聖護院蕪をくり抜いて、海老や銀杏、鶏肉を贅沢に詰めた蕪蒸しを客人に振る舞った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "中から熱々の出汁が溢れ出すこのタイプの蕪蒸しは、見た目のインパクトもあって喜ばれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわあ、蕪の中に宝箱みたいに具材が詰まっていて、どれから食べるか迷っちゃう！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
