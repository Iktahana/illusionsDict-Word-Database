    "definitions": [
      {
        "index": 1,
        "gloss": "carrier-based aircraft",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「うわあ、空母のデッキから次々と艦載機が発艦していく様子は、近くで見ると大迫力だね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最新鋭のステルス艦載機を導入したことで、艦隊全体の防空能力が飛躍的に向上した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "着艦フックの固定に失敗した艦載機が、あわや海面へと転落しそうになり肝を冷やした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "整備員たちが、油の匂いが漂う狭い格納庫内で艦載機のエンジンの最終点検を急いでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、この本州の北端の町にも、艦載機が飛んで来て、さかんに爆弾を落して行く。",
              "citation": {
                "source": "庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、そんな思いをして故郷にたどりついてみると、故郷はまた艦載機の爆撃で大騒動の最中であった。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「艦載機一号、出動用意！",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "空襲警報　艦載機一号の操縦者は、柳下航空兵曹長だった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗澹たる空中に、母艦をとびだした艦載機の爆音が遠ざかって行った。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああわが艦載機の行方はいずこ？",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "迫り来る敵機　大胆にも飛行島の夜間偵察をおえた柳下航空兵曹長は、艦載機一号を操縦して暗の中を東へ東へとびつつあった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "左舷十度、高度五百メートルに艦載機の前部灯が見えます」　おお柳下機だ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「艦載機帰艦用意――探照灯、左舷着水海面を照らせ」　艦内は号令を伝える声と、作業にかけまわる水兵たちの靴音やかけ声で、火事場のような騒であった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "艦橋も檣も起重機も、そして艦載機も、その激浪にのまれてしまったかと思われた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで一、二、三」　ついに艦載機はうまく格納庫に入った。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……備前岡山、備後灘、松山上空」とラジオは艦載機来襲を刻々と告げている。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "艦載機がこの街に現れてから九日目に、また空襲警報が出た。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……備前岡山、備後灘、松山上空」とラジオは艦載機来襲を刻々と告げてゐる。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし三日は名古屋方面に九十数機の来襲あり、また四日は台湾、沖縄へ艦載機延べ五百機来襲。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月十六日◯艦載機延べ一千機で関東、東海地区へ来襲。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさは果して艦載機の来襲がなく、八時五十分頃まで朝寝をした。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "また昨日の敵艦載機撃墜百一機と発表、またその前の十六日の撃墜にも二十数機追加あり、結果約三百機の敵機をやっつけ、敵の手持の千二百機の四分の一を倒したことになる。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日の艦載機千機の来襲で、千機という新記録を体験してからは、百機ぐらいは恐ろしくないらしい。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵艦載機はたいがい茨城千葉の方にいて、京浜地区まで来るのは少ないが、午後一時半Ｂ29の大挙来襲の徴ありと警告が出た。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては艦載機であるか、いや艦載機にしては早すぎる。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯艦載機来襲以来、待避壕はかなりものものしくなった。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄のこの前二回の艦載機の来襲の話も聞いた。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日は早目に帰京するつもりでいたところ、朝五時半から敵機動部隊が鹿島洋、九十九里浜沖から艦載機をぶんぶんとばすので、夕刻まですっかり平磯館に閉じこめられてしまった。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯本十四日、敵機動部隊は再び艦載機で攻撃を開始した。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯きょうは早暁から艦載機飛来。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "艦載機にのって引揚げる。",
              "citation": {
                "source": "不沈軍艦の見本",
                "author": "――金博士シリーズ・10――",
                "note": "青空文庫"
              }
            },
            {
              "text": "本艦でも、まったく不意うちのありさまで、甲板にいた水兵さんたちも、あれよあれよと、ロケットの出すガスの尾を見まもるばかりでしたが、この時勇ましい爆音が艦上に聞えると思う間もなく、二台の艦載機が、カタパルトの力でさっと空中にとびだしました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
