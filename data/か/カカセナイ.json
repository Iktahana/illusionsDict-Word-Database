    },
    "definitions": [
      {
        "index": 1,
        "gloss": "indispensable",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "プレゼンテーションの成功には、入念な準備が欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現代のビジネスシーンにおいて、ITスキルは欠かせない能力だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "毎朝のコーヒーは、私にとって一日を始めるのに欠かせないものになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チームワークを深める上で、お互いの信頼関係は欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "罪を軽くするには馬の無事が欠かせないとしっかり心得ている。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが欠かせない用事で日帰りで広島に帰った翌日のクリスマスに、突然深い淵に落ちました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の捉えた世界を物語って腹におさめることは、人の心にとって、息をすることや物を食べることのように欠かせないのだと書きました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、電子本に本領を発揮させる欠かせない要素と考えた、ネットワークによる流通の道を付けていこうと心が決まります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばどこの図書館にも欠かせない類の本を、デジタル化してやります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまな電子部品をおさえ、特に機器の小型化には欠かせない液晶ディスプレイを握っている日本企業には、強力な切り札があるということか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これをきれいに研いで下さいな」と小さな剃刀（婦人の身だしなみには欠かせない道具）を渡しながら言った。",
              "citation": {
                "source": "勇子",
                "author": "一つの追憶",
                "note": "青空文庫"
              }
            },
            {
              "text": "マニュアルがいかに重要であるか、特にイメージのつかみにくいマイクロコンピューターを理解してもらうためには懇切ていねいな解説が欠かせないかは痛いほど知りつくしている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "理解を助けるうえでは、情報の公開はどうしても欠かせないのだ」と説得し、ようやく同意を取り付けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで大型化すれば、鳥瞰的な視点に立って個々のモジュールの役割を厳密に定義するとともに、各モジュールのすり合わせを専門に行う担当者を配置することが欠かせないはずだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかりやすいマニュアルを書くための専門スタッフの養成が欠かせないという意識そのものが希薄な当時、かき集めたライターと開発者自身による効率の悪い共同執筆作業は、時間ばかりを食って満足な原稿を生み出せなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "教育家と財政家即ちブルジョアの技術的番頭も欠かせない。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい、たかが秘書にすぎないエルランガーが、上の城ではクラムよりも欠かせない人物なのだろうか？",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一人だけがためらいながら、むろんクラムは城でも村でも欠かせない人なのだ、といった。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "母も側から休むようにとすすめたが、彼は欠かせない御用があるからと断わり、時刻になると登城して、自分の役部屋へはいった。",
              "citation": {
                "source": "饒舌り過ぎる",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……人間は生きているというだけで誰かの恩恵を蒙っている、他人の造った家に住み、他人の作った米麦を喰べ、他人の織った着物を着る、日々の生活に欠かせない有ゆる必要な品々が、すべて見も知らぬ他人の丹精に依って出来たものだ。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――宗之助と自分との、かつて最も親しかった関係が、今や新しい方向へ転換しようとしている、この転換がどんな意味をもつかまだわからない、しかし見はぐらない要心は欠かせないぞ。",
              "citation": {
                "source": "彩虹",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "産地の遠近を問わず、上質の紙を数多く揃えるのは、多額の資金と選別眼が欠かせない要件であるし、なによりも紙が貴重な品であったことが、他のしょうばいとは違った気質を生んだものらしい。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸には火事が多いので、ふだんから心の用意はできている、荷物はできるだけ少なくとか、米はどんなにしても二日分くらい持つとか、飯椀に箸は欠かせないとか、切傷、火傷、毒消し薬などを忘れるなとか、みんな常づね口伝のように戒め合い、いざというときまごつかないだけの手順はつけてあるのだった。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "友助夫妻にも案内をしたのだが、これは欠かせない用があるからと、なにがしかの香典を包んで断わりが来ていた。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして絶対に欠かせないのは、マカロニ・アンド・ポテト・サラダだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれを食べるとしても、マカロニ・サラダは欠かせない。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだまだ欠かせない道具がある。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "優れた先生達は、彼女達の才能を開花させるべきだと彼に迫り、それには良い教育が欠かせないと指摘した。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "流行の先端を行く若者は、身に付けるものについては特に鋭敏であることは欠かせない。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼女にとって宝石同様に欠かせないものなんだよ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、僕に二度と再び斯くの如き駄文と恥をかかせない事を約束して下さい。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸田さんは、たしか歯がぼろぼろに欠けている筈ですから、戸田さんに恥をかかせないように、安心させるように、私も歯の悪いところを見せてあげるつもりだったのです。",
              "citation": {
                "source": "恥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただね、あんたさん、その御用達の話ですがね、裸麦の粉だの、蕎麦粉だの、挽割麦だの、または屠殺した家畜だのをお買い上げになる時は、どうぞ妾に恥をかかせないで下さいよ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
