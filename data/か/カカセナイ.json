[
  {
    "uuid": "3070f1cb-ce3b-55bb-8e1a-eda69c1b709a",
    "entry": "欠かせない",
    "reading": {
      "primary": "かかせない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
