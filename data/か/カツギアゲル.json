[
  {
    "uuid": "eff90d90-af0d-593e-8ca5-f65ba7e419d2",
    "entry": "担ぎ上げる",
    "reading": {
      "primary": "かつぎあげる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
