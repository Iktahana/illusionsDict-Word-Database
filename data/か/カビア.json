        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "高級ホテルの朝食で、小さな瓶に入ったカビアを見つけて驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "シャンパンには、やはりカビアがよく合うとソムリエが言っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "フォアグラのテリーヌにカビアを添え、特別な日のディナーを演出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "＊　そのキリコの繪と向ひ合つてピカビアの數枚の繪が並んでゐた。",
              "citation": {
                "source": "續プルウスト雜記",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピカビアは古代とたはむれてゐる。",
              "citation": {
                "source": "續プルウスト雜記",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "外のラフカの方に極いいカビア（チョールナヤ・イクラ〔ちょうざめの筋子〕）が一キロ一円五十銭であった。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピカソの近況、ピカビア、ハガル、キリコの傾向もまた注意さるべきであろう。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせフランシス・ピカビアは嫌ひではない。",
              "citation": {
                "source": "訳詩集「月下の一群」",
                "author": "その著者堀口大学に与ふ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
