        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "台所で焦げ付き、火災報知機がけたたましく鳴り始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "義務化された火災報知機の設置は、住宅の安全性を高めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "誤って火災報知機のボタンを押してしまい、管理人に謝った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "なほ、都市乾燥空気の大圧力と火災報知機の弾力性ボタン間に於けるキン急な相互関係。",
              "citation": {
                "source": "すらんらん集",
                "author": "仲村渠",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
