        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔の旅人は、ほとんどが徒歩で移動していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長距離の徒歩旅行は、体力と精神力が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ちょっとそこまで、車じゃなくて徒歩で行ってみようか。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
