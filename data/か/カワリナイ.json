        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ご家族の皆さんは変わりない？」「うん、父さんも相変わらず週末の釣りに夢中だよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お久しぶりです、その後お変わりないですか？」「ええ、おかげさまで家族全員元気にしています」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、田中さん！」「おお、しばらく。変わりないか？」「はい、何とかやってます！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "特に変わりない平穏な日常こそが、実は一番贅沢なことなのだと最近になって痛感する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
