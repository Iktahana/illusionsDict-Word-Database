[
  {
    "uuid": "1b9533ba-55f7-5541-9da2-84f708126f6b",
    "entry": "痂せる",
    "reading": {
      "primary": "かせる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
