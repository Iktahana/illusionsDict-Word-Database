    "definitions": [
      {
        "index": 1,
        "gloss": "company (i.e. business)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
