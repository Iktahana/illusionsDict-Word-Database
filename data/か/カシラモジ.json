        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "オーダーメイドで作ったシャツの袖口に、自分の頭文字をさりげなく金糸で刺繍してもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "アンティークの銀時計の裏蓋には、元の持ち主であろう二人の頭文字が絡み合うように刻まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼女は短い手紙の最後に、フルネームのサインの代わりに自身の頭文字を走り書きした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "プレゼント用の革財布に、彼の頭文字である「K.T」の刻印を打つよう店員に依頼した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      }
