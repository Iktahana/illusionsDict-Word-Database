        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "鉢植えの寒桜は、室内で育てやすく、冬の間も鮮やかな花を楽しめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "園芸店には、さまざまな色の寒桜が並び、購買客の目を楽しませていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は誕生日に、友人から小さな寒桜の鉢植えをもらって喜んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
