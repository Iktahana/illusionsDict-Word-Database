    "definitions": [
      {
        "index": 1,
        "gloss": "bad for one's health",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夜遅くまでスマホを見るのは体に悪いから、もうやめよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このジャンクフード、美味しいけど体に悪いからたまにしか食べないようにしてる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "タバコの煙が体に悪いのは知ってるけど、なかなかやめられないんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "運動不足も体に悪いって言うし、週末は少し散歩でもしようかな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それではあまり身体に悪いとて、おきみが粥を作り匙を添えて持って行った。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、先生が、背中を丸くしてお席に就いていてはいけない、体に悪い事です、と仰有れば、直ぐ自分の背中に気をつけました。",
              "citation": {
                "source": "いとこ同志",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「唯、何かこう頭脳の中に、一とこ引ッつかえたようなところが有って、そこさえ直れば外にもう何処も身体に悪いところはないで」「そうですかなあ」「俺を病人と思うのが、そもそも間違いだぞや」「なにしろ、あなたのところの養子もあの通りの働き手でしょう。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "左様御勉強ぢや身体に悪いでせう」と云つた事が一二度あつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこか体に悪いところのあるようなその女は、毎日枕を出して臥そべっていた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は女郎買なんかは嫌ひだけれど、身体に悪いから一月に一度は来るつもりだ。",
              "citation": {
                "source": "女が来て",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう御勉強じゃ身体に悪いでしょう」と云った事が一二度あった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙吉――正夫君、君はずいぶん煙草が好きなようだが、吸いすぎると体に悪いよ。",
              "citation": {
                "source": "囚われ人",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体に悪いです」「病気なのか」「イエ。",
              "citation": {
                "source": "牛",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それどころか、からだ具合が全体に悪い。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒が身体に悪い人に対して、無理に酒を飲ませてはいけないことくらいは、誰も皆知っている。",
              "citation": {
                "source": "無知",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも身体に悪い金属が存在すると、この試薬はその油を暗褐色または黒色にする。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに長くそして度々湯に入ることは、今の医学から言ったら身体に悪いのだそうである。",
              "citation": {
                "source": "温泉１",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めの中はこれだけ十分な防寒用意をしていれば大して身体に悪いこともなかろうと思っていたのであるが、暫くやって見るとこの仕事も余り健康の上には有難くないものだということが分った。",
              "citation": {
                "source": "雪雑記",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君の知ったことではない、身体に悪いから寝て居給え」　南条と呼ばれた奇異なる武士は兵馬の手を取って、牢の格子の角の隅をさぐらせました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "如法闇夜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "体に悪い空気は（タマネギ、西洋ニラネギ、マメによる）ゲップと放屁の衝撃によって取り除かれた。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝不足が一番身体に悪いわ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一｜身体に悪いし、その上みっともないわ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "バッキンガム宮殿のまわりは刺激臭のほこりが舞い、石炭ガスで吐き気がして、体に悪い。",
              "citation": {
                "source": "見えざる力",
                "author": "THE INVISIBLE FORCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこ一つ体に悪い所がなく、快適極まるといったような好条件な時は、自然、机の苦業百尺の下へ、われから心身を沈めてはゆけないらしい。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が夜に戸外を歩きまわると、からだにわるいのが痛快にからだにこたえて、よくわかるのだ。",
              "citation": {
                "source": "めくら草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
