        "examples": {
          "standard": [
            {
              "text": "「まさかこんな結末になるなんて、あの時は夢にも考えもつかなかったよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一般常識ではまず考えもつかないような、大胆かつ斬新な手法で問題を解決した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "10年前に今のスマートフォンの普及具合なんて、誰も考えもつかなかっただろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ええっ！ 犯人が彼だなんて、私にはこれっぽっちも考えもつかなかったわ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "上官連ですら、あいつは悪魔だ、人間じゃないと評したほどで、馬車の輪からも、轅からも、馬の耳からも、そのほか、そんなところに物が隠してあろうとは、作者などにはとても考えもつかない、つまり税関役人だけが眼をつけるようなところからいろんなものを探し出したものである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そういう気心の知れないような他所者が多いから、村の人達だってあまり附き合いたがらないし、自然何処の別荘番も冬なんぞになるとわれわれの考えもつかないような孤独な暮らしをしているらしいな。",
              "citation": {
                "source": "朴の咲く頃",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで考えもつかない不意に湧いた希望だった。",
              "citation": {
                "source": "姫たちばな",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「考えもつかない最終兵器ですね。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに、さもしい俗人の邪推をもって僧正の身のまわりをながめても、僧正に、それ以上なものがなければ淋しかろうとか、不幸だろうとかいうようなことは考えもつかない沙汰である。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
