        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "家族旅行では、子供が遊べる施設が充実した観光ホテルを選びました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "明日の朝、チェックアウトしたら、この観光ホテルから次の目的地へ向かいます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この辺りで一番評判の良い観光ホテルはどこですか？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "人民戦線が勝利して以来、フランス出版物の輸入をきびしく制限しつつ、何のために志賀高原のてっぺんに国際観光ホテルを建てて、外務省がそのために尽力しなければならないのであろうか。",
              "citation": {
                "source": "日本の秋色",
                "author": "――世相寸評――",
                "note": "青空文庫"
              }
            },
            {
              "text": "岬のこちらからは見えない側に観光ホテルが出来て、そこは海軍関係のひとたちの出入りするところとなっているそうだが、野原あたりとくらべると、ここは新興の熱い亢奮の中心からややはなれた感じで、気分もさほどたかぶっていない。",
              "citation": {
                "source": "日記",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "原爆遺跡ちんれつ所にころがる灼けた石、溶けた瓦、へしゃがれたガラスビン、そして埃をかぶった観光ホテルの都市計画パンフ。",
              "citation": {
                "source": "原爆詩集",
                "author": "峠三吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "物資がないと云えば、痛快にないね、観光ホテルでは、お客が食べたいものを注文するとそれから買い出しに行くというノンビリしたものであった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は加賀市になって、国際観光ホテルもあり、近くに立派なゴルフ場もある。",
              "citation": {
                "source": "私の生まれた家",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月も半ばすぎなので、暮から三ガ日へかけたほどの混雑はないが、それでも、この川奈の国際観光ホテルには、ここを冬の社交場にする贅沢なひとたちが二十人ほど、ゴルフをしたり、ダンスをしたり、しごくのん気に暮らしている。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "川奈の国際観光ホテルで、あんな思いがけないことがあった翌々日、東京の森川夫人から電話がかかってきた。",
              "citation": {
                "source": "キャラコさん",
                "author": "雪の山小屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "観光ホテルのデスクで働いて、なんということもなくチビチビとドルを貯めていた。",
              "citation": {
                "source": "復活祭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "高原の頂に国際観光ホテル建造中です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "将来この山頂には大きな観光ホテルを建てたらいゝ。",
              "citation": {
                "source": "函館八景",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし、パパを信じているわ……今にマンガンが当れば、こんなもの、造作なくでき上がるわ」「それは、そうでしょうけれど、……でも今のところは、一時立ち腐れね」「ほう、東洋一の観光ホテルを！",
              "citation": {
                "source": "墓が呼んでいる",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦前、名古屋で、洋食と言ったら、老舗の中央亭、朝日ビルのアラスカ、観光ホテル、ぐらいのものではなかったか。",
              "citation": {
                "source": "八の字づくし",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋食はアラスカ一軒、観光ホテルのグリルより、むしろ広小路のシキシマパンへござれ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上朝食と対面させられては悲しいので、近くの名古屋観光ホテルへ行くと、小林千代子・片岡鉄兵がいて一緒にグリルへ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "観光ホテルのグリルで、豆のポタージュとフライエグス、クラブハウス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "又観光ホテルのグリルへ出かける。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月五日（火曜）　十一時すぎに起きて、又観光ホテルへ食事に行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の終り名宝食堂でビクターの試聴会あり、それから観光ホテルへ食事に行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "石田守衛を残しといて貰ひ、二人で観光ホテルのグリルで朝食。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳が来り、道子と三人で観光ホテルへ夕食しに行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "観光ホテルのグリルで夕食。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "観光ホテルの理髪屋で理髪し、座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "観光ホテルへ食事に行く、ポタージュ、フィレソールのみ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "観光ホテルへ円タク。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲郡へ二時四十分着、蒲郡観光ホテルへ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時すぎ、何も食はないのも――と思ひ、道子も共に、観光ホテルのグリルへ、ポタアジュとトースト、ミートオムレツ、食ったら又腹がしぶり出す、ラキサトールのんだのに今朝思ふやうに下らなかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼終ると、観光ホテルの地下の理髪屋へ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
