        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今年は猟友会に入会し、初めての鴨猟に挑む予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "父は若い頃、冬になると仲間と連れ立って鴨猟に出かけていたそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の文献には、鴨猟で捕獲された鴨を使った料理の記述が見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "規制が厳しくなり、最近では鴨猟ができる場所も限られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "少なくも鴨猟場で「鴨をしゃくう」のに比べると猟者の神経の働かせ方だけでも大変な差別があるような気がするのである。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七十ばかりな主の翁は若き男女のために、自分がこの地を銃猟禁制地に許可を得し事柄や、池の歴史、さては鴨猟の事など話し聞かせた。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴨猟豊島与志雄　寒中、東京湾内には無数の鴨がいる。",
              "citation": {
                "source": "鴨猟",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、私は東京湾の鴨猟を余りに芸術的に見たかも知れないけれども、この鴨猟に残酷みを感ずること少いのを以て、私の心情を責める人があるとすれば、それは……理屈をぬきにして、ただ、まだ湾内の鴨猟を知らない人だと、それだけ云いたい。",
              "citation": {
                "source": "鴨猟",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは面白い、というわけで、早速、ピストルで鴨猟だ。",
              "citation": {
                "source": "話の屑籠",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、この「洲蘆の出島」は、もともと仏蘭西大使館の鴨猟地なのであった。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊東は愛する懐かしい人たちばかりで埋まった死人台帳に宝沢の名を書き込み、その日の日記の終わりに――宝沢法人、鴨猟のため、兜岩に赴き、暴風雨に遭難、溺死す。",
              "citation": {
                "source": "暴風雨に終わった一日",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨日｜須崎の種田家の別荘へ招待されて鴨猟をやった」と五分刈の浅黒いのが答えた。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼はある春の日にボートと銃とを持ち出し鴨猟をきめこもうとした。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "またそこには幅六尺ばかりの水路が縦横に切拓いており、秋から冬にかけて葦刈りや鴨猟の舟が往来した。",
              "citation": {
                "source": "葦",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　十一月下旬、大沼で鴨猟がおこなわれたとき、光辰は初めておたきを見た。",
              "citation": {
                "source": "若き日の摂津守",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんなにか仔細があるのだろう、鴨猟のときすでに、おたきの心には一種の疑惑がおこっていた。",
              "citation": {
                "source": "若き日の摂津守",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだ、鴨猟にいったときだ。",
              "citation": {
                "source": "若き日の摂津守",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴨猟を一例にとってみよう、あの日の獲物は七百羽ちかくあった。",
              "citation": {
                "source": "若き日の摂津守",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして初入部をし、鴨猟のことや、伊部村の老婆の話などで、「自分のしなければならないこと」の方向がおぼろげながらわかるようになった。",
              "citation": {
                "source": "若き日の摂津守",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――漁場は幡野村というところで、賀名川と安井川の合流点から少し下に当っており、鴨猟のときと同じように、半ば河原へかけて新しい仮屋が建ててあった。",
              "citation": {
                "source": "若き日の摂津守",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴨猟のときと同じ順序で、まず重臣たちに対する賜盃があり、こんどもまた望月吉太夫が、上段際まで席を進め、賀名川の鮎について説明した。",
              "citation": {
                "source": "若き日の摂津守",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
