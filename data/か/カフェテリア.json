        "examples": {
          "standard": [
            {
              "text": "会社のカフェテリアはメニューが豊富で、毎日違うものが食べられるから飽きない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学食のカフェテリアで、友達と今日の授業の復習をしながらランチを食べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "病院のカフェテリアは広くて明るく、患者さんだけでなくお見舞いの人も利用しやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの美術館のカフェテリア、窓から見える景色が最高なんだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ここはカフェテリア式の店で、前もって作ってある肉やサラダを、客が陳列してあるところまで行って、好みに合ったものを自由に取れるようになっています。",
              "citation": {
                "source": "アメリカの牛豚",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャーチ街のカフェテリアに留まるのも一苦労で、食後、自分を牽引する未知の力が一層強まっている感じがした。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
