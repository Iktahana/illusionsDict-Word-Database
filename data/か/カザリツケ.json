    "definitions": [
      {
        "index": 1,
        "gloss": "decoration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "クリスマスツリーの飾り付けは、家族みんなで毎年楽しみにしているイベントだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "結婚式の披露宴会場は、バルーンや花で華やかに飾り付けられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "お店の入り口は、ハロウィンの季節に合わせて、カボチャやおばけの飾り付けで賑やかだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "パーティーのために、部屋の壁にガーランドや風船の飾り付けをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "何故と云って――私の見出したところのその美しいミハエルの恋人たるや、何と今しも印袢天を着た会場整理の人足共に依って擔ぎ出された、何処か呉服屋でも出品したらしい飾り付け人形であったではないか！",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "わづかな資本で始めた店でしたけれど非常に器用なその母親が飾り付けるとお店の商品は生々して造花なんぞまるで生花のやうに上手な照明で見えるのでした。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、この辺までは無事ですけれども、その他、けば／＼しい金蒔絵の衣桁だの、虫食いの脇息だの、これ等を部屋の常什物にして、大きなはい／＼人形だの薬玉の飾りだの、二絃琴だの、時と気分によって戸棚から出し入れされて飾り付けられます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い壁紙を貼つた低い天井には、短冊のやうな国旗にまがへたビールの小旗を両隅から中ほど目がけて飾り付けてあつた。",
              "citation": {
                "source": "蛾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿香が帰っているなら、あれに手伝わせて早くお供え物を飾り付けたら好かろう。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "道端に立ち並んだ巴旦杏樹の蔭に慄へてゐる女のやうな男や、朱欄の階楼に蒼然として立竦んで居る美しい戦士などが、丁度祭礼か何かで街を飾り付けた人形のやうに其処にも此処にも見られた。",
              "citation": {
                "source": "闘戦勝仏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その七ツの燈火に照らされた向うの有様を見ると、見事な飾りをした広い廊下で、天井や壁に飾り付けてある宝石だか金銀だかが五色の光りを照り返して、まことに眼も眩むばかりの美しさである。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎの朝早く、お堂はすでに生け花と奉納された提灯で飾り付けられていた。",
              "citation": {
                "source": "死生に関するいくつかの断想",
                "author": "BITS OF LIFE AND DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブース全体もカラフルに飾り付けられている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸｜卓子の向うの仄暗い右側には、黝ずんだ古代｜雛……又、左側には近代式の綺羅びやかな現代式のお姫様が、それぞれに赤い段々を作って飾り付けてある。",
              "citation": {
                "source": "白菊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし生れつき皮肉な私の眼は、こんな風にしてこの室の変化に驚きながらも、この時既に、凡ての飾り付けの中に多くの胡麻化しがある事を発見していた。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも大急ぎで仕事を致しましたので、一時間半ばかりのうちに、やっとこの室を飾り付けてしまいました」「えっ……この室を……」「……はい……」　女は何気ない答えをしつつ、今日曲馬場で私を見上げた時とそっくりの無邪気な表情をしてストーン氏を見上げた。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁紙も、窓かけも、何もかも妾の死に場所を綺麗にしたいために新しく飾り付けたのです。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……こう申しましたら貴方はあの時計と髑髏が、何のために飾り付けてあるかという事が、おわかりになるでしょう。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二つのものは、わたくしが死を覚悟致しておりました事を、あとで狭山様におしらせするために飾り付けたのです。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一番上へ行つては細くなりますが、孔雀の羽根を飾り付けます。",
              "citation": {
                "source": "元時代の蒙古人",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の侍が「次の間の、飾り付けを致しましてござりまする。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "偖てお妾さんが別荘へ著いて見ると其の屋敷の並木道には花が一ぱい蒔散らしてあつて、部屋部屋の飾り付けは、目を驚かすばかりなのに、かてて加へて、その昼餐の献立の美しさ贅沢さといつたら又格別だつた。",
              "citation": {
                "source": "フランソア・コッペ訪問記",
                "author": "堀口九萬一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一體是や、何う云ふ了見だね」と自分で飾り付けた物を眺めながら、御米に聞いた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "飾り付けも立派でございまして、庭からずうと見渡すと、潮入りの泉水になって、模様を取って土橋が架り、紅白の萩其の他の秋草が盛りで、何とも云えん好い景色でございます。",
              "citation": {
                "source": "菊模様皿山奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "内部は一間きりの広々とした四角な部屋で、大きな囲炉裏の壁の上には、鹿の首や、賞牌や、ひからびた姫鱒や、喇叭銃や、そのほか訳のわからぬものが無数に飾り付けられてあった。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "タラノ音頭　――コルシカ島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く神仏を混淆してしまったような床の間の飾り付けが、まず半蔵をまごつかせた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "門松は入口のところに飾り付けられた。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、顳※を薫り佳き桃金嬢もて飾り付け、さて軽々と私を空に連れ去つた彼女らは雲々の間を抜けて、薔薇の葉に仮睡みゐたりし私を運び、風神は、そが息吹きもてゆるやかに、我がささやかな寝台をあやした。",
              "citation": {
                "source": "ランボオ詩集≪学校時代の詩≫",
                "author": "VERS DE COLLEGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために、船もたいそう美しくかざりつけられました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "御殿の中は、きらびやかにかざりつけられました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、またかざりつけてくれるんだ！",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまず大広間へお通りになって、金の銀とのかべと、宝石をかざりつけたまどとをごらんになって、大へんご感服なさいました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ここにたった一つ、かざりつけをしてないまどがあるのは、どういうわけだね。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとアラジンは、「陛下、それは、陛下のとうといお手で、かざりつけをしていただきたいと存じまして、わざわざ残しておいたのでございます。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
