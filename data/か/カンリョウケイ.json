          "standard": [
            {
              "text": "完了形は、完了した動作や状態を表すために使われます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「彼女はもう宿題を終えた」という文は、完了形です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "完了形には現在完了、過去完了、未来完了などがあります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「完了形って、いつ使うのが一番自然かな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "現在完了形をとつたものは、「向ひの山に月たゝり見ゆ（万葉巻七）」など言ふ文例を止めて居る。",
              "citation": {
                "source": "幣束から旗さし物へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
