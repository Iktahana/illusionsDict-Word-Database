[
  {
    "uuid": "c31d9111-a4bd-5832-8e2f-79f8b3a9e955",
    "entry": "彼氏",
    "reading": {
      "primary": "かれし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
