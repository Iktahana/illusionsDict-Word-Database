        "examples": {
          "standard": [
            {
              "text": "公園の環境整備が行き届いており、子供たちが安心して遊べる清潔な場所になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "災害に備え、自治体は地域の防災環境整備として、避難経路の確保や施設の補強を進めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "快適なオフィス空間を作るため、会社は社員の意見を取り入れながら社内の環境整備に力を入れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "キルドールが具体的に提案した環境整備のテーマは二つあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
