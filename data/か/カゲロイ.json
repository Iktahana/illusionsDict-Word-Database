        "examples": {
          "standard": [
            {
              "text": "夜明け前、東の空に陽炎が薄く見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "まだ暗い中に、かすかな陽炎が朝の訪れを告げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "山の端に陽炎が立ち上り、新しい一日が始まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
