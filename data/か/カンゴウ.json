        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "城の周囲を巡る環濠は、敵の侵入を防ぐ重要な役割を担っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "発掘調査により、古代の集落の環濠跡が発見された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その屋敷は、高い塀と深い環濠に囲まれていて、外部からの視線を完全に遮断していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "公園の池は、かつて環濠の一部であったという言い伝えがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
