        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は仕事でベネズエラの首都、カラカスに赴任することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カラカスの街は、アンデス山脈の美しい景色に囲まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "航空券を調べたら、カラカス行きの直行便は少なかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "もっとも、「カラカス（註二六）沖」というように場所の名や、または六二度一七分二〇秒、一九度二分四〇秒というように単に緯度経度が、書き加えてあるところも少しはあった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ、『カラカス沖』とあるね。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "南米ヴェネズエラのカラカスの原住民は犬、猫、及び跳び鼠を飼っている。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "カラカスの原住民が、犬その他の動物を飼って地震予知に役立てることは前に記した。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八二二年のヴェネズエラ大地震の前に、カラカスで馬が廐舎から高地へ逃げ出したということである（ミルン、前掲）。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴェネズエラ、カラカスの商人　鳴る、鳴る、盛んに鳴るヨ。",
              "citation": {
                "source": "雷嫌いの話",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
