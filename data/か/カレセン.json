    "definitions": [
      {
        "index": 1,
        "gloss": "younger woman (usu. 20-30 years old) who is physically attracted to mature older men (usu. 50-60 years old)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
