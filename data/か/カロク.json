[
  {
    "uuid": "8b55fc53-a9cc-5e5d-a712-0b52c3fa6559",
    "entry": "加禄",
    "reading": {
      "primary": "かろく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
