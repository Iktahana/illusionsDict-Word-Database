      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "increase in a samurai's stipend",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "主君への長年の忠勤が認められ、さらに百石の加禄を賜るという栄誉に浴した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「これでようやく家族に楽をさせてやれる」父は加禄の知らせを受け、仏壇の前で深く頭を下げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "戦功を挙げた武士たちに対し、恩賞として領地の加増や加禄が行われ、軍の士気は一層高まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "十八万石程から一足飛に四十二万石の大封を賜わったのだから、たとい大役を引受けさせられたとは云え、奥州出羽の押えという名誉を背負い、目覚ましい加禄を得たので、家臣連の悦んだろうことは察するに余りある。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "状に「丁卯加禄卅石、十年癸酉進徒士将領（歩行頭）之列、職禄百二十石、并旧禄為三百石」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼氏では此年春水が陞等加禄の喜に遇つたが、冬より「水飲病」を得て、終身｜全愈するに至らなかつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "行乞は身心晴朗でなければならない、足もかろく気もかろくなければならない、そしておちつきがなければならない、すなほさがなければならない。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "大田への道は山にそうてまがり水にそうてまがる、分け入る気分があつてよい、心もかろく身もかろく歩いた。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがね、その紫水晶の大粒な珠が、夕風にゆれたり、私が首を動かす毎に、ころころと両方の耳の下をかろくかはゆくうちますのよ。",
              "citation": {
                "source": "一平氏に",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤き日はアカシヤのわか葉にけぶり、※肉の黄なる花ちらちらと噎ぶとき怖々と投げいだし、眠りたる霊の人間の五官にもわきがたきいと深きかなしみ……そのゆめはこころもち汗ばみて傷つきし銀毛の耳に痛き花粉は沁み、やるせなき肉体の憂欝に柔かにかろく魘さるれど、汝が母を犯したる霊の不倫をば知るよしもなし。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時過ぎて暮ちかき夏の日は血に染みし呼鈴の声のごとくふりそそぎ、嫋やかなる風は蜜蜂の褐色に、蜜蜂のつぶやきはかろく花粉を落す。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かろく冷たき微風も鹹をふくみて薄青し、「秋」は流行の細巻の黒の蝙蝠傘さしてゆく。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "うらわかき盲人のいろ飽まで白く、そのほとりに頬を寄するは――かろくかさねし手のひらの弾く爪さき、それとなく隆達ぶしの唱歌など思ひ出づるはいとかなし。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と忍びかに、さては手速にうしろより珊瑚細工の車の柄かろく廻せば、ためらへる白の上衣と髪の毛に薔薇いろの靄さとけぶる。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かにかくに両手あげつつかろく叩き、撫でてあやせば、羽根はたき尻尾ふりきる。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "天つ日の光もわすれ現身の色に溺れて、酒みづきたづきも知らず、酔ひ疲れ帰りし我を、酒のまばいただくがほど、悲しくもそこなはぬほど、酔うたらば早うやすめと、かき抱き枕あてがひ、衾かけ足をくるみて、裾おさへかろくたたかす、裾おさへかろくたたかす、垂乳根の母を思へば泣かざらめやも。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、また、白日光耀の下で、形もない鰌の、日のこぼれの、藻屑の、ころころ田螺の、たまには跳ね蝦の立鬚まで掬おうとして、笊をかろく、足をあげ、手で鼻をつまみ、振りすて、サッとまた笊を、空へ、コラサッである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ子供のことですから、小遣い銭なんかろくろく持ってないんで。",
              "citation": {
                "source": "喫煙癖",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから星の破片の落ちたのを拾って来て、かろく土の上へ乗せた。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はかろく指さきでその赤とんぼの羽に触ってみた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はかろくそれを弾き飛ばした。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何だつたかろくに見もしなかつた。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "美き人なりき、花ごろもかろく被ぎて、――母ぎみの乳の香も薫ゆり、――薔薇のごとわれをつつみぬ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫夏の日なかに青き猫かろく擁けば手はかゆく、毛の動げはわがこころ感冒のここちに身も熱る。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅雨の晴れ間せ、水ぐるま、けふの午から忠信が隈どり紅いしやつ面に足どりかろく、手もかろく狐六法踏みゆかむ花道の下、水ぐるま…………せ、水ぐるま、雨に濡れたる古むしろ、圓天井のその屋根に、青い空透き、日の光、七寶のごときらきらと、化粧部屋にも笑ふなり。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "せ、水ぐるま、はやも午から忠信が紅隈とったしやつ面に足どりかろく、手もかろく、狐六法踏みゆかむ花道の下、水ぐるま…………　韮の葉芝居小屋の土間のむしろに、いらいら沁みるものあり。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
