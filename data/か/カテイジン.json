[
  {
    "uuid": "850c4fbb-6e06-5381-8a0b-0203c61b6811",
    "entry": "家庭人",
    "reading": {
      "primary": "かていじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
