    },
    "definitions": [
      {
        "index": 1,
        "gloss": "family-oriented man",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は仕事もできるが、何よりも家族を大切にする素晴らしい家庭人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "社長は「君も早く立派な家庭人になって、私を安心させてくれ」と笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "結婚して子供が生まれてからは、すっかり家庭人になったね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "世の多くの文士たちは、概して宿命的に不幸な家庭人で、わざわざ家を離れてさへ仕事をするのに、反對にその家庭的空氣の中でなければ、落着いて仕事が出來ないといふ犀星こそ、まことに幸福人と言はねばならない。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平和なる家庭なるかな、私は家庭人ではないけれど、家庭のあたたかいアトモスフイアは好きである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで彼は何かというと外で飯を喰うようなこともなかったし、小使の必要もなかったわけだが、長い下宿生活の慣習も染みこんでいたので、そこらの善良な家庭人のような工合には行かなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ宵のことで、彼は殺風景な応接室で、子供と一緒にお茶を呑みながらレコオドを聴いていたが、そうした家庭人になってみると、母のない子供の日常にも、何かはかない感じがまざまざ感じられて来て、楽しい気持にもなれないのであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "綺麗な風呂場や化粧室などの設備のあるところとか、日本風の落着きのいい部屋や庭のあるところとか、世間から隔絶されたひそやかな場所に潜んでいることが、家庭人であった彼の習性をすっかり変えてしまっていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角彼は家庭人の悲哀と言つたやうな気分に躓いたやうな感じであつた。",
              "citation": {
                "source": "折鞄",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際彼が家庭人か何うかは疑はしいので、今目の前に見る紳士のやうな怡楽は、感じてゐないのであつた。",
              "citation": {
                "source": "折鞄",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、このＲ氏夫妻のみならず、真個におのおのの業務に対する明確な責任感と、家庭人としての良心が円満な調和を保っている処では、何処にもこれに似た秩序の正しさと、健康な活動が在るように思われます。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び、此の善き隣人、美しい家庭人が、何うしてあのドロシイをああも悪魔的に凌辱虐殺したと信じられよう――。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "道者たらんとするものは、まず学生を振り出しに、つぎに家庭人として生活し、それから隠士に転化し、第四に、そして最後に、森へ入って、茎類を食し、百姓どもの慈善を受けて乞食にならなければならない。",
              "citation": {
                "source": "ヤトラカン・サミ博士の椅子",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも家庭人であって、そのままスッと、どこへでも気楽にはいりこめるようである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番よい意味の家庭人という感じである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭人でありながら、そのままどこへでも気楽に滑りこめるし、どんなに専門的な仕事に従事していてもいつも立派にそして平凡に家庭人だというような、理窟ぬきでそうなっている自然さがあった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぜいたくだの、もったいないなど、昔の京都の家庭人のようなのは、一旦病を得ては、名医といえども投薬のしようがなさそうである。",
              "citation": {
                "source": "美食と人生",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "琴もピヤノもうまかつたが琴の方では作曲もした、後日結婚してから助教授になつて研究を続けてゐたが、夫が実業家としてだんだん多忙な生活をするやうになつて彼女も純粋な家庭人となつたやうに聞いてゐる。",
              "citation": {
                "source": "豚肉　桃　りんご",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一個人としての松賀女史が家庭人になつて舞扇を裂き、厨房に魚介を煮るのは自由であるが、卑しくも流祖としての責任をそのまゝに放棄してしまつて、松賀流幾春秋の歴史を闇から闇へと葬り去つてしまふことは些か穏やかでない。",
              "citation": {
                "source": "巣鴨菊",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民としては最も国法に従順であり、社会人としては最も職務に忠実であり、家庭人としては最も善き子であり、親であり、兄弟であり、道徳においても志操において模範的と言われうべき者が、ただイエスの名に連なるがために、かくも人々から憎まれ嫌われようとは！",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの文学処女もこんな世の中では、よい家庭人として日本女性ぶりを発揮することでせう。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は決してこちこちな儀式ばつた家庭人ではなかつたのである。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭人としても厳正だったし、ジョッキーとしては、内外人の称讃をうけて、裏切ったことはない」と、たいへん恨みがましく抗議されて来た。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほどひどい物だったし、家庭人の児童にたいする読書の監視は、やかましかった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、山本富士子氏が出た一例なども、近頃、ミスを送る家庭人の気もちを、ずいぶん積極的に奮わせているのではあるまいか。",
              "citation": {
                "source": "押入れ随筆",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "モーツァルトの全貌を知らんとするには、それらの傑作を玩味すべきものであるが、単に一般家庭人が、モーツァルトの美しさ、愛らしさ、燦然たる天才の片鱗を知らんとするためには、子守唄の一曲、トルコ行進曲の一曲、ないし小夜曲の一曲を味わうだけでも充分だろう。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親のクレメンス・アウグストは純良高潔の士で、家庭人としても子供たちの信頼と夫人の敬愛をかちえていたが、母親の方はいささか特異な性格の持主で、機智縱横の精力家といったところがあり、文字どおりヒュルスホフ城の女王であった。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう立場にある――高山家の家庭人の心や内情にふかく立ち入っているオルガンチノの使命が――不成功に終ろうはずはない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄徳もいつかその中に溶け入って、他愛ない家庭人となりきっていた。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
