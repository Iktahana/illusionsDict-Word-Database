[
  {
    "uuid": "a8c409b0-0bdc-5b02-8124-701dff6f31cd",
    "entry": "関係がない",
    "reading": {
      "primary": "かんけいがない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
