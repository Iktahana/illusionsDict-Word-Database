        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "次回の幹事会で、年間予算の承認が得られる予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "マンションの幹事会で、修繕計画が話し合われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大学の幹事会は、学校運営の重要な意思決定機関だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この会合は予め幹事会の決議により、研究内容及び方法に関する意見及び希望を会員から募ったものを参考として組織部案を作製し、これを提出して会合後の研究組織を決定する為のものであった。",
              "citation": {
                "source": "〔付〕唯物論研究に就て（戸坂潤手記）",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "半年とたたない間に、第一に電気学会の幹事会に爆弾を抛りこまれて幹部一同が惨死をする。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "修道女は「けふは幹事会がありまして、マダム・ジッドも見えてをります。",
              "citation": {
                "source": "亜剌比亜人エルアフイ",
                "author": "犬養健",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
