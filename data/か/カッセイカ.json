        "examples": {
          "standard": [
            {
              "text": "「地方創生の一環として、廃校を活用したアートプロジェクトが地域の活性化に一役買っています」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "試合の後半、主力選手を投入することで攻撃陣が活性化し、一気に逆転ゴールを決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スマートフォンの設定画面から、新しいセキュリティ機能を活性化させる手順を確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
