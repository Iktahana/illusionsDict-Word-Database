[
  {
    "uuid": "7ae88736-e993-561e-a275-df6d40c6e042",
    "entry": "陰で",
    "reading": {
      "primary": "かげで",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
