[
  {
    "uuid": "266b4aeb-0395-505b-844d-9f7425ac0fe9",
    "entry": "官命",
    "reading": {
      "primary": "かんめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "official orders",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "藩主からの官命を受け、彼は遠方の任地へと旅立つことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "城下町に掲げられた官命には、新たな税の導入が記されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "役人たちは、官命を遵守し、国の指示通りに動いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "自分は官命によってその埋井工事を見学に行ったが、それは実に珍しい見ものであった。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "官命とはいいながら、何分にも殺生の仕事であるから、寺院を詰所に宛てるのを遠慮するのが例であった。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "天統の末年に、彼は官命によって、河の堤を築くことになったが、その工事中、幕下のものに昔話をして、彼は涙をながした。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼に追わる　宋の紹興二十四年六月、江州｜彭沢の丞を勤める沈持要という人が、官命で臨江へゆく途中、湖口県を去る六十里の化成寺という寺に泊まった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞庭の神　梁遂という人が官命を帯びて西粤に使いするとき、洞庭を過ぎた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "池北偶談",
                "note": "青空文庫"
              }
            },
            {
              "text": "余語医官命信恬陪侍。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その後二月とたたないうちに、突然官命を受けた夫は支那の漢口の領事館へ赴任することになるのです。",
              "citation": {
                "source": "或恋愛小説",
                "author": "――或は「恋愛は至上なり」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（第三）　明末の陽瑪諾の『唐景教碑頌正詮』の序には、この碑の發掘の次第を述べて、　　大明天啓三年（西暦一六二三）關中官命啓土。",
              "citation": {
                "source": "大秦景教流行中國碑に就いて",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事かと聞き質すと、この日意外にも、景教碑は官命で碑林に移轉されることになり、碑石はすでに持ち出されて居つたといふ。",
              "citation": {
                "source": "大秦景教流行中國碑に就いて",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "右及答弁候也内閣総理大臣侯爵　山県有朋　　　議会に投げかけた最後の一声兇徒嘯集の疑獄は、三十三年の十二月、前橋地方裁判所で公判が開かれ、「官命抗拒」「治安警察法違犯」と云ふ判決であつたが、検事の控訴で、事件は東京控訴院へ移された。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "北京にある日本公使館内の一室では、公使館附武官の木村陸軍少佐と、折から官命で内地から視察に来た農商務省技師の山川理学士とが、一つテエブルを囲みながら、一碗の珈琲と一本の葉巻とに忙しさを忘れて、のどかな雑談に耽っていた。",
              "citation": {
                "source": "首が落ちた話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "官命は官命なり、余の意志は余の意志なり。",
              "citation": {
                "source": "『文学論』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "倫敦に来てさへこの不安の念を解く事が出来ぬなら、官命を帯びて遠く海を渡れる主意の立つべき所以なし。",
              "citation": {
                "source": "『文学論』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "去れど官命なるが故に行きたる者は、自己の意思を以て行きたるにあらず。",
              "citation": {
                "source": "『文学論』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "文部省にせよ、何省にせよ、省の官命に因て派遣された者の行動に関し消息に関して督学官に非ず監督官にあらず一私人が本省に打電するといふべきことはあり得べきことでせうか、常識は之に対して否と答へることは明々白々と信じます。",
              "citation": {
                "source": "漱石さんのロンドンにおけるエピソード",
                "author": "夏目夫人にまゐらす",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝妻手人龍麻呂が雑戸を免ぜられて、天語連の姓を賜はつた（続紀養老三年）のは、其芸を採用する為であつて、部曲制度の厳重な時代ではあつたが、官命で転職させて、相応した姓を与へたのである。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "「連合艦隊司令長官命令。",
              "citation": {
                "source": "太平洋雷撃戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "司令官命令、各部隊は戦闘配備に就け。",
              "citation": {
                "source": "空の悪魔（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草奥山が官命によって取払われたのは明治十七年、その代地として当時田ンボの六区が与えられたが、区劃整理して縦横に道を通じて後、ようやく五六軒の名もないような小屋と、十軒あまりの飲食店などができたばかり、当時は新開地とよんでいたが、今の六区には比すべくもない田ンボの中の小さな遊園地である。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "先月の終りから北海道へ官命で視察にでて、二十日すぎでないと戻らない。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十一　稲妻は見たり",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで今回官命の役目は一段落となるのである。",
              "citation": {
                "source": "斑鳩物語",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って『正保図』の如く官命に依って選ばれたる地図に之を略する筈なければ、この場合ツフラノ沼はたとえ漠然と一湖を描けるのみなりとも、之を以て三湖を代表せるものと見て差支なしというを得んか。",
              "citation": {
                "source": "古図の信じ得可き程度",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは官命を伝える一種の公文書であった。",
              "citation": {
                "source": "『西遊記』の夢",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三校は無外氏が官命を以て黒部川の奥に入峡されたので、私一人で済ませた。",
              "citation": {
                "source": "普羅句集",
                "author": "前田普羅",
                "note": "青空文庫"
              }
            },
            {
              "text": "――しかし是非何とか報告をしろと、官命で出張した属官流に逼られれば、仕方がない。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども立派な御役人として、ある重要な事項取調のためという名義の下に、官命で遣って来たその人の財力と健三の給費との間には、殆んど比較にならないほどの懸隔があった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に官命で東洋に出張して参りました。",
              "citation": {
                "source": "放浪者",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
