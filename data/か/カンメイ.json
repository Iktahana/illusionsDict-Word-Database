    },
    "definitions": [
      {
        "index": 1,
        "gloss": "particular word that an owner includes in the names of their racehorses",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "競馬ファンの間では、「サトノ」や「アドマイヤ」といった特定の冠名を持つ馬主の馬が常に注目されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は自分の所有するすべての競走馬に、故郷の地名にちなんだ冠名「ミチノク」を付けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "G1レースの出走表を眺めていると、同じ冠名を持つ馬が複数いることに気づき、馬主の戦略に思いを馳せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      }
    ],
