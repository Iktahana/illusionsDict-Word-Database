    "definitions": [
      {
        "index": 1,
        "gloss": "roadside tea house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔ながらの風情を残す掛茶屋で、旅人は一服した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "山道の途中にある掛茶屋で、温かいお茶をご馳走になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古い街道沿いには、今も旅人を癒やす掛茶屋が点在している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "江戸時代、旅人たちは疲れた体を休めるために、よく掛茶屋を利用した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "Ｓ＝稲荷神社境内　（茶店は腰掛茶屋である。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　壯丁は車を離れて水を呑むもあり、皆掛茶屋の縁に集つて休んで居た。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はある友と市中の寓居を出でて三崎町の停車場から境まで乗り、そこで下りて北へ真直に四五丁ゆくと桜橋という小さな橋がある、それを渡ると一軒の掛茶屋がある、この茶屋の婆さんが自分に向かって、「今時分、何にしに来ただア」と問うたことがあった。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　勇美子も夜会結びの鬢を吹かせ、雨に頬を打たせて厭わず、掛茶屋の葦簀から半ば姿をあらわして、「石滝から来たのじゃあなくって。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら向うのひのきの陰の暗い掛茶屋の方で、なにか大きな声がして、みんながそっちへ走って行きました。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「た、た、た、薪百｜把持って来てやるがら」　掛茶屋の主人は、耳が少し悪いとみえて、それをよく聞きとりかねて、かえって大声で言いました。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風がごうごうっと吹き出し、まっくろなひのきがゆれ、掛茶屋のすだれは飛び、あちこちのあかりは消えました。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛茶屋に腰を下ろしている間に、前の通りで五十ばかりになる田舎者と馬車の馭者とが押問答をしている。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れに疲れし一行は、途中掛茶屋さえあれば腰を下して、氷水を飲む、真桑瓜を食う、饅頭をパク付く。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　小次郎法師は、掛茶屋の庇から、天へ蝙蝠を吹出しそうに仰向いた、和郎の面を斜に見｜遣って、「そう、気違いかい。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "道を挟んで、牡丹と相向う処に、亜鉛と柿の継はぎなのが、ともに腐れ、屋根が落ち、柱の倒れた、以前掛茶屋か、中食であったらしい伏屋の残骸が、蓬の裡にのめっていた。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ傍に、空しき蘆簀張の掛茶屋が、埋れた谷の下伏せの孤屋に似て、御手洗がそれに続き、並んで二体の地蔵尊の、来迎の石におわするが、はて、この娘はの、と雪に顔を見合わせたまう。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹の埒結ひたる中に、三四人土をほり居るあたりにて、路も分らずなりしが、洋服着たる坊ちやん二人、學校の戻と見ゆるがつか／＼と通るに頼母しくなりて、後をつけ、やがて木の間に立つ湯氣を見れば掛茶屋なりけり。",
              "citation": {
                "source": "彌次行",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛岡は晩、下谷の腰掛茶屋で厚揚のカツレツを御馳走して呉れました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "職業は奉行所の腰掛茶屋の主人であった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより臨時の掛茶屋であるから、葭簀がこいの粗末な店ばかりで、ほんの一時の足休めに過ぎないのであるが、若い女たちが白い手拭を姐さんかぶりにして、さざえを店先で焼いている姿は、いかにもここらの開帳にふさわしいような風情を写し出していた。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一行は四月二十三日の朝に江戸を発って、その夜は神奈川で一泊、あくる二十四日は程ヶ谷、戸越を越して、四つ（午前十時）を過ぎる頃にこの藤沢へ行き着いて、この掛茶屋にひと休みしているのであった。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が明石の宿屋で粗末な辨當を貰つて兵庫まで來ると、ある工場の傍に腰掛茶屋があつたが、荷車引等が飯を喰つて居る。",
              "citation": {
                "source": "旅行に就いて",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドリュック夫人の証言するところによれば、彼女はルール関門の対岸の、河の堤からそう遠くないところに、腰掛茶屋を営んでいる。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの腰掛茶屋や森の葉陰などで、遊び仲間のほかには誰にも見られないで、あらゆる気違いじみたまがいものの歓楽にふけるのさ、――勝手なことをしたりラム酒を飲んだりしてね。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "佃島には先生、不孝者を持って多いこと苦労をする婆さんが一人ね、弁天様の傍に吝な掛茶屋を出して細々と暮しています、子に肖ない恐しい堅気なんで。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、堤尻を駈上つて、掛茶屋を、やゝ念入りな、間近な一ぜんめし屋へ飛込んだ時は、此の十七日の月の気勢も留めぬ、さながらの闇夜と成つて、篠つく雨に風が荒んだ。",
              "citation": {
                "source": "光籃",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "西日をよけた番神堂の裏に丁度腰掛茶屋に外の人も居ず、三人は緩り腰を掛けて海を眺めた。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁和寺の掛茶屋に客を呼ぶ婆さんの白い手拭も佗びしさを添へた。",
              "citation": {
                "source": "菜の花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛茶屋の赤毛布に腰を卸せば、老婆茶を侑む。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "適※之あるも、掛茶屋ぐらゐのもの也。",
              "citation": {
                "source": "鹿野山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛茶屋に休息して、各※辨當を取出す。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "繪葉書を送るとて、裸男駄句りて曰く、來ぬ友を惜む梅見の日和かな　山を下れば、老樹最も繁き處に、掛茶屋あり。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
