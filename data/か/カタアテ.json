        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "冷え込む夜には、肩当てをして寝ると温かい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "母が手編みしてくれた肩当ては、軽くて肌触りが良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬の朝、布団から出たくない時は、肩当てを羽織って過ごす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
