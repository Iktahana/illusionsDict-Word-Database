        "examples": {
          "standard": [
            {
              "text": "昨日の野球の試合は、最終回に逆転して劇的な勝ち試合となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "監督は、この勝ち試合を次の大会への弾みにしたいと語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "サッカーチームは、連敗続きだったが、ようやく勝ち試合の感触を取り戻した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "誰もが諦めかけたところで、ベテラン選手の一打が勝ち試合を引き寄せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "藩では橋立の文珠閣で勝ち試合の恩賞と祝いさえした。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
