    "definitions": [
      {
        "index": 1,
        "gloss": "windy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今日はとても風の強い日だから、洗濯物は部屋干しにしたほうが無難ね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "風の強い海沿いの道を自転車で進むのは、想像以上に体力を奪われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "昨晩は風の強い夜だったせいで、庭に置いてあった植木鉢が見事に倒れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "こんな風の強い日にゴルフなんて、ボールがどこへ飛んでいくか分かったもんじゃない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "梅雨晴れのから風の強い日であって、番町へんいったいの木立ちの青葉が悩ましく揺れ騒いで白い葉裏をかえしていたのを覚えている。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしい風の強い日で空にはちぎれた雲が飛んでいるので、仰いで見ているとこの神像が空を駆けるように見えました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「風のない時はたての棒、風の強い時は横の棒、その他はみみずなどの形。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風の強い日は、どうもいけない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな風の強い日に、ひでえや。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "賤機山、浅間を吹降す風の強い、寒い日で。",
              "citation": {
                "source": "雛がたり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "風の強いゆえか、雲が綺麗だ。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの火事があってから、お母さまは、夜中に時たま呻かれる事があるし、また、風の強い夜などは、お手洗いにおいでになる振りをして、深夜いくどもお床から脱けて家中をお見廻りになるのである。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向う風の強い晩に、爺屋の棟に上ってこれを撒くとて文句を誤り「爺々眼さ灰入れ」と連呼したので向う風が灰を吹き入れてその眼を潰し、爺屋根より堕つるを鴈が落ると心得、婆が大きな槌で自分の老夫を叩き殺したというのだ。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨風の強い或る日に、彼はＨ青年と京子さんとに送られて、二人の娘と汽車に乗つた。",
              "citation": {
                "source": "芭蕉と歯朶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "（沖縄群島のような風の強い所には高く高く天にまで舞い昇るような雲雀は一匹も※翔していない。",
              "citation": {
                "source": "進化論より見たる沖縄の廃藩置県",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから熊さんの水撒車の通ったあとは、いくら暑い日でも涼しくて、どんな風の強い日でも、塵一ツ立ちませんでした。",
              "citation": {
                "source": "日輪草",
                "author": "日輪草は何故枯れたか",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは森田町は往来広く空ッ風の強い日などは塵埃が甚くて、とても仕事が出来ないという有様なので、転居したのです。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "高村東雲の生い立ち",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一週間許たった風の強い日に〆て十銭也とかき出しのついた大きい足袋が二足じいやの所にとどけて来た。",
              "citation": {
                "source": "大きい足袋",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天氣のいい日はええが、風の強い日なんどはなあ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "風の強いためか、押し返されるせいか、真直ぐに立ったと思うと寝る。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　運転士は車を止めて風の強い叢のなかに帽子を捜したが、しかしそれも物の二分とはかからなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "風のない夜は紫の煙が真直に空にのぼってゆきますけれど、少し風の強いときは軒端にまつわりついて、薄い絹紗で柔らかに包んだように何をも彼をも美しくすることがあります。",
              "citation": {
                "source": "蚊遣り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日（十一日）は風の強い、始めて蝉の声のする夏らしい日だ。",
              "citation": {
                "source": "有島武郎の死によせて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "真暗な風の強いさびしい晩でした。",
              "citation": {
                "source": "書簡　大杉栄宛",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "西北の風の強い日で、丁度九郎右衛門が神戸の家にいるうちに、神田から火事が始まった。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "また風の強い日に少し遠い蕎麦屋から出前を取ると、大げさかなと思われるようですが、器の上に砂のかぶっていることも少なくないのであります。",
              "citation": {
                "source": "蕎麦の味と食い方問題",
                "author": "村井政善",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍肩から吹き下ろす風の強いのには驚いた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり風の強いときは、皮の物でないと駄目だ。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小屋は風の強いときは寒いに違いないが、寝具があるので大したことはないと思った。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど風の強い曇天だったから、荷に挿した色紙の風車が、皆目まぐるしく廻っている。",
              "citation": {
                "source": "妙な話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄陽の射した天気だつたが、馬鹿に風の強い日だつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨はからりと霽れたが、風の強い日であつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　僕はこの頃空の曇つた、風の強い日ほど恐しいものはない。",
              "citation": {
                "source": "鵠沼雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れてるが風の強い日だった。",
              "citation": {
                "source": "奇怪な話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
