[
  {
    "uuid": "482e36f1-da7b-573d-908f-3b79d553bb2c",
    "entry": "乾いた",
    "reading": {
      "primary": "かわいた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-語幹"
      ],
