    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "砂漠のように乾いた風が吹き抜け、喉の奥がヒリヒリとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の乾いた笑い声が、静まり返った会議室に虚しく響いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "洗濯物がパリッと乾いた匂いを嗅ぐと、ようやく梅雨が明けた実感が湧く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "行く途々に牛の糞の乾いたやつがあるたびに、それを拾つて口に入れようとするのには閉口したと、よく祖母は話してゐた。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更らしく死んだ人を悲しむのでもなく妹の不幸を女々しく悔やむのでもないが、朝に晩に絶間のない煩いに追われて固く乾いた胸の中が今日の小春の日影に解けて流れるように、何という意味のない悲哀の影がゆるんだ平一の心の奥底に動くのであった。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "発汗剤のききめか、漂うような満身の汗を、妻は乾いたタオルで拭うてくれた時、勝手の方から何も知らぬ子供がカタコトと唐紙をあけて半分顔を出してにこにこした。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "堅く尖った足駄の朴歯が、世界一堅固な伯林の道路面に当って端的な乾いた反動の音をたてた。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋の天井にのぼった人たちは、器械の上の方からどんどん乾いた玉蜀黍をほうり込みました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "町には平凡な商家が並び、どこの田舎にも見かけるような、疲れた埃っぽい人たちが、白昼の乾いた街を歩いていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは渓の水が乾いた磧へ、小さい水溜を残してゐる、その水のなかだつた。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野はアラゴン人の物売りから冷果を買って妾の乾いた唇を潤しながら云うのでした。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その母も、流石に兄も、私も、そして附添ふ若い一人の看護婦も、高い熱でさらさらに乾いた灰のやうなお前の顏色を見、夢中の口から洩れる呻き聲を聞いた時、お前の上に嚴かに死が迫らうとしてあるやうな豫感に打たれて、堅く口を噤んでしまつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒竜江にはところどころ結氷を破って、底から上ってくる河水を溜め、荷馬車を引く、咽頭が乾いた馬に水をのませるのを商売とする支那人が現れた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "花立ての花もきょうはもう萎れて、桔梗も女郎花も乾いた葉を垂れていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾いたタオルがいる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（コロナは八万三千十九）　わたくしたちが柄杓で肥を麦にかければ、水はどうしてそんなにまだ力も入れないうちに水銀のように青く光り、たまになって麦の上に飛びだすのでしょう、また砂土がどうしてあんなにのどの乾いた子どもの水を呑むように肥を吸い込むのでしょう。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗の木が何本か立って枯れた乾いた葉をいっぱい着け、鳥がちょんちょんと鳴いてうしろの方へ飛んで行きました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまもなく小さな小さな乾いた雪のこなが少しばかりちらっちらっと二人の上から落ちて参りました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにその晩は強いふぶきで、外では風がすさまじく、乾いたカサカサした雪のかけらが、小屋のすきまから吹きこんで豚のたべものの余りも、雪でまっ白になったのだ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは溪の水が乾いた磧へ、小さい水溜を残している、その水のなかだった。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪は小止なく、今は雨も交らず乾いた軽いのがさらさらと面を打ち、宵ながら門を鎖した敦賀の通はひっそりして一条二条｜縦横に、辻の角は広々と、白く積った中を、道の程八町ばかりで、とある軒下に辿り着いたのが名指の香取屋。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日の夜を通した雨のなごりも、薄い皮一｜枚張つたやうに道が乾いた。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥濘が薬研のやうに乾いたんぢやあ、大変だ。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらはすっかり白くなり、風はまるで引き裂くよう、早くも乾いたこまかな雪がやって来ました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで乾いた牛の糞だ。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋の天井にのぼった人たちは、器械の上の方からどんどん乾いた玉蜀黍をはふり込みました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こけももがいつかなくなって地面は乾いた灰いろの苔で覆われところどころには赤い苔の花もさいていました。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾いたかすかな音が、そのたびごとに清逸の耳をかすめて、蝿の元いた位置に真白く光る像が残った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの子供のように澄んだ眼でじっとラムプを見つめながら、ぷつりぷつりと乾いた西洋紙に孔を明けている園の様子が見えるようだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾いたままで唇が無性に震えた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早く隣りの風呂屋で風呂の栓を打ちこむ音も乾いた響きをたてゝ、人々の軟らかな夢をゆり動かした。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞赤に熟した十九號（林檎の種類）の果が、紅い夕暮の光に浸つて、乾いた血のやうな黒さに見える。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一階から五階までありとあらゆる人工的商品をこまごま見せられて疲れかわいた目には特にこれらの草花が美しく見える。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
