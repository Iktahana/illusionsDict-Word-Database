          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの作家にとって、締め切り前に徹夜で執筆することは家常茶飯事らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この地域では、野生の鹿が庭に現れるのは家常茶飯のことだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼のような一流のプロ選手が、日々厳しいトレーニングを積むのは家常茶飯である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "）　　　家常茶飯附録　現代思想（対話）太陽記者。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "こん度｜私共の方で出すようになりました、あの家常茶飯の作者のライネル・マリア・リルケというのは、あれは余り評判を聞かない人のようですが、一体どんな人ですか。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "脚本は家常茶飯の外にまだありますか。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし生意気な事を言うようですが、家常茶飯は成功の作かも知れないと思います。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体家常茶飯というのはどういうわけですか。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "家常茶飯と云うと、また套語の嫌がある。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが家常茶飯に出る画家の姉えさんの孝行と好く似ています。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それですから、何故お前は家常茶飯のような危険極まる作を翻訳するのだと云う人もありましょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "こん度訳した家常茶飯だって、黙って出してしまえば、恐らくは誰も何とも思わずにしまいましょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者も家常茶飯として食べてしまいましょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "讃否は別として、現代思想というものが、幾分か領会せられる媒になるとすれば、雑誌に家常茶飯を出すのも、単に娯楽ばかりでなくなりますね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それがその時は人生の家常茶飯のやうに驚きとも悲しみとも胸に響かなかつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "▼農民小説や、戦争小説は、取つ付き易く、組み敷き難いものの最大なもので、これらをテーマに扱ふ作家は、幾多の難問題を控へて、よほどハッキリした頭の持主でなければ、所謂農民の家常茶飯事的物語りの作り手以外になることは不可能だらう。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "『浮雲』以後の精神的及び物質的苦悶に富んだ二葉亭の半世の生活からは最少し徹底した近代的悲痛が現れなければならないはずであったが、案に相違して極めて平板な不徹底な家常茶飯的葛藤しか描かれていなかったのは畢竟作者の根本の芸術的興味が去ってしまったからであろう。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "何十年来シベリヤの空を睨んで悶々鬱勃した磊塊を小説に托して洩らそうとはしないで、家常茶飯的の平凡な人情の紛糾に人生の一臠を探して描き出そうとしている。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし多くの自殺者を見ていたお陰には、自殺をすることが家常茶飯のように思われて、大した恐怖をも感じなかった。",
              "citation": {
                "source": "身投げ救助業",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや世故にたけたといわれる年頃では、そういう階級の狭い生活が多くの女の心に偏見と形式と家常茶飯への没頭、良人の世間並な立身出世に対する関心をだけを一杯にしていたであろう。",
              "citation": {
                "source": "歴史の落穂",
                "author": "――鴎外・漱石・荷風の婦人観にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣国の支那のことを伝へたのでも、このくらゐの間違ひは家常茶飯である。",
              "citation": {
                "source": "日本の女",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは日本人には家常茶飯に見る事だが、西洋人は滅多にやらぬらしい。",
              "citation": {
                "source": "雑筆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来季題とは何かと言へば、名月、夜長などと云ふ詩語の外は大抵僕等の家常茶飯に使つてゐる言葉ばかりである。",
              "citation": {
                "source": "発句私見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもその男は至極｜家常茶飯な顔をして、「さうです。",
              "citation": {
                "source": "寒山拾得",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "経文を伝法院に学ばんと貞子の語り蟋蟀の鳴く　由来家常茶飯事を歌によんで立派な歌にしたてたこと作者のやうな人は先づなかつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般の女子及び男子の貞操に関して考えた事はあっても自分の貞操は家常茶飯の事のように思っていた。",
              "citation": {
                "source": "私の貞操観",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "行きあたりばったり盲目的に取って来られた家常茶飯事という奴がその一つである。",
              "citation": {
                "source": "ヒューメーンということに就て",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡庸な眼で見られた凡庸な家常茶飯事、そういう作品が所謂ヒューメーンだという仮面の下に逃げ込んでゆく。",
              "citation": {
                "source": "ヒューメーンということに就て",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は電車へ乗る心算で、十銭持つて歩きながら、途中で気が変つて、煙草屋へはいると、平然として「往復を一つ」と云つた人間だからこんな事は家常茶飯である。",
              "citation": {
                "source": "あの頃の自分の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲人が間に立つて、見あひをし、夫婦になり、乏しい月給をかこちつゝ、子供が生まれ、年をとり、ひそかに墓場に運ばれてゆく、ありきたりの生涯にも、人生の深い悲喜哀樂は多分に暗示される筈であるが、先生はかゝる家常茶飯事には携はらなかつた。",
              "citation": {
                "source": "覺書",
                "author": "水上瀧太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで、話を聞かずに、外貌だけ見てゐるとしたら、誰でも、この婦人は、家常茶飯事を語つてゐるとしか、思はなかつたのに相違ない。",
              "citation": {
                "source": "手巾",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "又人の話によれば、人力車を走らせている間に、後から帽子を盗まれる事も、此処では家常茶飯事だそうです。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべては家常茶飯事のやうだつた。",
              "citation": {
                "source": "おもかげ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
