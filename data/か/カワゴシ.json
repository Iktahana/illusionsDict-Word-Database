[
  {
    "uuid": "9bda072c-12ec-5f5b-95f2-617a8a681416",
    "entry": "川越し",
    "reading": {
      "primary": "かわごし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
