    "definitions": [
      {
        "index": 1,
        "gloss": "crossing a river",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "対岸の神社から、賑やかな祭り囃子が川越しにうっすらと聞こえてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「川越しに見る花火も、水面に光が反射してなかなか風情があるものだね」と友人が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "川越しに手を振る友人の姿が見えたが、こちらの叫び声までは届かなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "霧の深い早朝、川越しにぼんやりと渡し船の影が浮かび上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「この間、島田で、大井川の川越しに使った蓮台を持ってる家を見付けた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは藤枝の宿で、熊谷蓮生坊が念仏を抵当に入れたというその相手の長者の邸跡が今は水田になっていて、早苗がやさしく風に吹かれているのを見に寄ったり、島田では作楽井の教えて呉れた川越しの蓮台を蔵している家を尋ねて、それを写生したりして、大井川の堤に出た。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "川越しの基点の三本継ぎの電信柱が見えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明くる日は大田切、関川越して野尻近き頃は、夏の日も大分傾き、黒姫おろしが涼しさに過ぎた。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等はいずれも腹這いになり、陽炎の立った砂浜を川越しに透かして眺めたりした。",
              "citation": {
                "source": "蜃気楼",
                "author": "――或は「続海のほとり」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう川越しの際の人足もその役筋から雇ってくれるので安かった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "また或る日川越しをする時であったが、旅客の多勢が集っていてその荷物なども容易に舟に積んでくれない。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか甲州道中の鶴川で、川越し人足を相手にやった二の舞を、そこでもやり出すつもりか知らん。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "能登守のような物のわかった、押しの利く仲裁人が滅多に出て来ようとも思われないのに、もし一人でも負傷させたということになると、今度は甲州の山の中の川越し人足とは相手が違って、非常な面倒なものになる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "川越しの小兵に負はれ五月雨　　　　紅緑　五月雨に水嵩の増している川を渡る場合に、人の背に負われて渡る、その自分を負うてくれる男は小兵であって、自分よりも背の小さい男である、という処にちょっとした矛盾と滑稽とを感ずるところがこの句の生命である。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の時には、大勢の川越し人足がいたけれども、今は水の出も少ないし、人足でなしに、橋を架けて橋銭を取って渡していました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "慢心和尚の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "定めの橋銭を払って、この橋を渡りきると、以前、川越し人足が詰めていた小屋があります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "慢心和尚の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の両岸には川越しの小屋が立っていて、真裸になった川越し人足が六七人ほど、散らばっているのが一目に見えました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "駒井能登守の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "能登守は、それがために数多の通行の人を留めてしまったことを気の毒に思って、早く手軽に通ってしまいたいのだが、鄭重にするために宿役人は川越し人足の勢揃いや人数配りに手数をかけてなかなかに時間を取るのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "駒井能登守の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "東海道には天竜川だの大井川だのという大きな川があるんだ、こんな山ん中のちっぽけな川とは違って、水もモットうんとあらあ、そこには川越しの人足も幾百人といるけれども、手前たちのようなわけのわからねえ人足は一人もいなかったんだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "駒井能登守の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前たちは山ん中の猿だから世間を知らねえや、だから教えてやるんだ、東海道の川越し人足はそうしたものなんだ、同じ人足でも人足ぶりが違わあ、第一、面からして違ってらあ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "駒井能登守の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "山猿と言われたのが口惜しけりゃここまで来てみやがれ、米友の槍が怖いと思ったら、早く川を通せろやい」　こう言いながら米友は、持っていた杖を片手に取ってブンブンと振り廻し、猿のような面をして白い歯を剥いて罵ると、たださえ気の荒い郡内の川越し人足が、こんなことを言われて納まるはずがありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "駒井能登守の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "人足どもも無暗に撲ることは乱暴だが、川越し人足である、これで通ったものを、東海道の人足とは人足ぶりが違うとか、面まで違うとか、山猿がどうしたとか、言わんでもよい悪口を言っているのはずいぶん向う見ずの無茶な奴だと思って、その鎮まるのを待っているが鎮まりません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "駒井能登守の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「矢でも鉄砲でも持って来やがれ」　岩の上に立った米友を下から渦を巻いて押し寄せた川越し人足、なにほどのこともない、取捉まえて一捻りと素手で登って来るのを曳と突く。",
              "citation": {
                "source": "大菩薩峠",
                "author": "駒井能登守の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "市川｜海老蔵は甲府へ乗り込む時にここの川越しに百両の金を強請られたために怖毛を振って、後にこの本街道を避けて大菩薩越えをしたということ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "駒井能登守の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "進めないわけではないが、進むには川越しをしなければならぬ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、この場合、衣裳をからげて、川越しをしてまで前進すべきや否やが疑問なのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの音は、そこの木立にからむ、大井川越しの西風の叫びとわかった。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
