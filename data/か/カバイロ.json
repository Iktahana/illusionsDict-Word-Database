    },
    "definitions": [
      {
        "index": 1,
        "gloss": "reddish yellow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夕焼けに染まる空が、グラデーション豊かな樺色に輝いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アンティークの木製家具は、長い年月を経て深みのある樺色に変色していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "秋の訪れとともに、公園の並木道は美しい樺色に色づき始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は新しいスカーフに、顔色が明るく見える樺色を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "焼きたてのクッキーは、こんがりと食欲をそそる樺色に仕上がっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "眞白い壁と薄樺色に塗られた木具とに、室の中は明るく柔かに沈んで、十字架の基督の像を挾んだ二人の聖者の像が正面の高壇にぢつと立つてゐた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "じき下には、地方裁判所の樺色の瓦屋根があって、その先には道庁の赤煉瓦、その赤煉瓦を囲んで若芽をふいたばかりのポプラが土筆草のように叢がって細長く立っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだ、ありがたかろう」　床の正面に、半分枯れかかった樺色と白との野菊を生けて、駄菓子でこね上げたような花瓶のおいてあったのを、障子の隅におろしてしまって、その代りに自分の懐ろから制帽を取りだして恭しく飾りながら、ガンベが拝むような様子をしてこういったっけ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に真直に立った足許に、なめし皮の樺色の靴、宿を欺くため座敷を抜けて持って入ったのが、向うむきに揃っていたので、立花は頭から悚然とした。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……踊の催しと言へば、園遊會かなんぞで、灰色の手、黄色い手、樺色の手の、鼬、狐、狸、中には熊のやうなのも交つた大勢の手に、引※され、掴立てられ、袖も振も亂れたまゝを汽車に乘つた落人らしい。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんど土の色と紛う位、薄樺色で、見ると、柔かそうに湿を帯びた、小さな葉が累り合って生えている。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "面赭く、耳｜蒼く、馬ばかりなる大きさのもの、手足に汚れた薄樺色の産毛のようで、房々として柔かに長い毛が一面の生いて、人か獣かを見分かぬが、朦朧としてただ霧を束ねて鋳出したよう。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠のずぼんの裾が見え、樺色の靴を穿き、同一色の皮手袋、洋杖を軽くつき、両個の狼を前にしつつ、自若たるその風采、あたかも曲馬師の猛獣に対するごとく綽々として余裕あり。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "残らず、薄樺色の笠を逆に、白い軸を立てて、真中ごろのが、じいじい音を立てると、……青い錆が茸の声のように浮いて動く。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "魴※の鰭は虹を刻み、飯鮹の紫は五つばかり、断れた雲のようにふらふらする……こち、めばる、青、鼠、樺色のその小魚の色に照映えて、黄なる蕈は美しかった。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの庭にも紅白は勿論、むらさきや樺色の変り種も乱れて咲き出した。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちも緑の褶が樺色に光る同じ色の着物を着ていたジュジュとエレンは、むす子の左右に坐った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "侯爵は鴎の影がなくなつたのでまた安心して樺色の実に嘴を入れ出した小｜鵯に眼をやりながら言葉を続ける。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とすらりと立った丈高う、半面を颯と彩る、樺色の窓掛に、色彩｜羅馬の女神のごとく、愛神の手を片手で曳いて、主税の肩と擦違い、「さあ、こっちへいらしって、沢山お煙草を召上れ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶくぶく樺色に膨れて、湯気が立っていたです。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "或者は黒いズボンのままで川へはひつて樺色の長い布を引摺出してくる。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外は樺色にくすんでいた。",
              "citation": {
                "source": "放生津物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "樺色の囚徒の服着たる一個の縄附を挟みて眼界近くなりけるにぞ、お通は心から見るともなしに、ふとその囚徒を見るや否や、座右の良人を流眄に懸けつ。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘆の枯葉をぬら／＼と蒼ぬめりの水が越して、浮草の樺色まじりに、船脚が輪に成る頃の、五位鷺の搏ちやう。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空｜蒼く晴れて地の上に雨の余波ある時は、路なる砂利うつくしく、いろいろの礫あまた洗い出さるるが中に、金色なる、また銀色なる、緑なる、樺色なる、鳶色なる、細螺おびただし。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫の早稲の米粒のような白い地体は薄樺色の皮膚に透けていた。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あまり綺羅びやかに最上級に洒落て居るので却って平凡に見える幾十組かが場の大部分を占めて居るので、慾一方にかかって居る樺色の老婆や、子供顔のうぶな青年が却って目立つ。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい、犢ほどの樺色の樺太犬がのそりと、その前には出ていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、絹川の土手にとりついた比には、※な樺色に燃えていた西の空が燻ったようになって、上流の方は微すらした霧がかかりどこかで馬の嘶く声がしていた。",
              "citation": {
                "source": "累物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗の毬彙がはじけて、樺色の実が路の上に落ちている処もありました。",
              "citation": {
                "source": "死人の手",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「瓦斯煖炉の明りかな」と思って見ると、なるほど、礬土の管が五本並んで、下の端だけ樺色に燃えている。",
              "citation": {
                "source": "鼠坂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に湿気のためにぐにゃぐにゃになった薄樺色地の二枚の色紙には、瀕死の病者のものとは思われない雄渾な筆つきで、次のような和歌がしたためられていた。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其所は半分から下に樺色をした杉板をそのまま張り、上には白い壁紙を貼つてあつた。",
              "citation": {
                "source": "蛾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其所には樺色の杉板に背を凭せるやうにして二人の客が話してゐた。",
              "citation": {
                "source": "蛾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか知らねど、蕋赤きかの草花のかばいろは阿留加里をもて色變へし愁の華か、なぐさめか、ゆめの光に咲きいでて消ゆるつかれか、なつかしや。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
