[
  {
    "uuid": "d6f05481-3ab6-55d5-9d92-55f2f8dbe318",
    "entry": "重ねて",
    "reading": {
      "primary": "かさねて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
