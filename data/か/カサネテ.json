    },
    "definitions": [
      {
        "index": 1,
        "gloss": "once more",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「すみません、もう一杯お茶をいただけますか？ かさねて。」と彼女は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "もう一度お願いできますか？ かさねて、よく聞き取れませんでした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "もう一度、かさねてやってみよう。もっとうまくやれるはずだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」　私は名誉の家の所以を語り、重ねてまた大隅君の無感動の態度を非難した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "真率にして富永は齢を重ねていつた。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ何がはかないと云っても、浮世の人の胸の奥底に潜んだまま長い長い年月を重ねて終にその人の冷たい亡骸と共に葬られてしまって、かつて光にふれずに消えてしまう希望程はかないものがあろうか。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "重ねて、Ｎさんには、おわびを言ひます。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は、眼を上げて、世界の出来事を見ると、地獄と極楽との絵を重ねて見るような、混沌さを覚えた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の三歳、五歳の祝ひ着は今の芝居のうちかけで見るやうな花蝶総縫ひのちりめんに下着を赤のゑぼしちりめんといふので重ねてありました。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに不思議なことはこの東海道には、京へ上るという目的意識が今もって旅人に働き、泊り重ねて大津へ着くまでは緊張していて常にうれしいものである。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」鳥捕りは風呂敷を重ねて、またくるくると包んで紐でくくりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　八十三で亡くなった母の葬儀も済んで後に母の居間の押入を片付けていたら、古いボールの菓子箱がいくつか積み重ねてあるのに気がついた。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーリーは縮写に失敗した後（一八七一）、このガラス格子を写真種板に直接に重ねて焼付けることを試みたらすぐ成効してたいそう嬉しがった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際もし映画｜殊に発声映画の技術が発達を重ねて行ってその器械がもう少し安くなって一般の使用に便利なようになれば、多くの学校の無味乾燥な教授の大部分は映画で置換えられるであろう。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、このような同人群像を試みるとしてはおそらく最も適任な石井氏が更に研究を重ねてこの絵の完成に勉められることを希望する。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすれば二色の写真が迅速に引続いて交互に現れるから、眼には丁度二色の写真を重ねて見るとほとんど同じ結果になり、従ってほぼ天然色に近いものが現れるのである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等は卵を重ねて家を建てようとし、虚無よりの創造にあがきながら、絶望の戰ひを戰つて來た。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天狗退治の大勇士とあって団九郎は得意満面で盃を重ねている。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "シングの「鑄掛屋の結婚」はこの三つのなかで芝居としては一番いいものだと今でも思つてゐるが、それは稽古を重ねてゐるうちに自然胸に感じられて來たことであつて、たつたそれだけのことでも、自分等の努力が手探りにわからせて呉れたのだと思ふとどんなに樂しかつたか知れない。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所々自然科學の言葉が使はれてゐたり、一度云ひ表したことを重ねて使つて效果を深めたり、作者の文體は知的な整つた感じを持つてゐる。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの僕のこの氣持が常に作品の上に無理を重ねてゐることから起つて來たことは爭へない。",
              "citation": {
                "source": "淺見淵君に就いて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　娘が黙つてゐるので、少年は「どうです」と重ねて尋ねた。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に歓楽の激しい地域を指示するように所々に群るネオンサインが光のなかへ更に強い光の輪郭を重ねている。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何にも云ひたくないと云ひつつも、思ふ処をまた述べ重ねてしまつたが、要するに芸術の道に於ては私は私である、芥川氏は芥川氏である。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くの低い落葉樹は鮮かな赤に色づいて、沈んだ空氣の中にぢつと葉を重ねてゐた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そら、あの石を積み重ねてある方へ走ってるんだ。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、二年分もあるのだが、自分の家に焚きものとするとて、畠のつゞきの荒らした所へ高く積み重ねて、腐らないように屋根を作りつけて、かこって置くのだ。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　宗保は、ねそを掴んで提げて来る薪を一把一把積み重ねて行った。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大磯近くなつて漸と諸君の晝飯が了り、自分は二｜個の空箱の一には笹葉が殘り一には煮肴の汁の痕だけが殘つて居る奴をかたづけて腰掛の下に押込み、老婦人は三｜個の空箱を丁寧に重ねて、傍の風呂敷包を引寄せ其に包んで了つた。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "其場所が全たく僕の氣に入つたのである、後背の崕からは雜木が枝を重ね葉を重ねて被ひかゝり、前は可り廣い澱が靜に渦を卷て流れて居る。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "まげて御承知くださるように重ねておねがい申します」「娘はゆうべ帰りまして、それからなんだか気分が悪いとか申して、きょうも一日｜臥って居りますので、まだ碌々に相談いたす暇もございませんで……」　お亀は一寸｜遁れの口上で、なんとか此の場を切り抜けるつもりらしかったが、相手はなかなか承知しなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうやら御来客の御様子でござりますな」「はい」「では、重ねてまいりましょう」　引っ返そうとするらしい女を、半七は内から呼びかえした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれから又｜十日と経たないうちに、強い人々もいよいよ臆病者の仲間入りをしなければならないような事件が重ねて出来した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
