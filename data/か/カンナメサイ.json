    "definitions": [
      {
        "index": 1,
        "gloss": "offering of the year's new rice harvest (imperial festival, October 17)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "神嘗祭、日本晴である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　神嘗祭り九月上旬までに集まつた諸国の荷前の初穂は、中旬に、まづ伊勢両宮に進められる。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一は、神嘗祭りであり、第二は荷前使である。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、神嘗祭りは、神宮と天子との間を親しくする為であつた。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした神嘗祭りの為の荷前を貢ぐ地方々々では、村・国の神に対しても、中央と等しく初穂を進める風を起し、或は盛んにせずには置かなかつたであらう。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　冬祭り・春祭り此を見ても、村々の秋の祭りは新嘗から出て居り、其が神嘗祭の日に近く、荷前の初穂の一部を以て行ふ様になつた事が知れる。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此地方化で、神嘗祭りの為に献つた荷前の残りの初穂を、地方の社々の神も試み喰べられたのが、秋祭りの起りである。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮廷の神嘗祭りは、諸国の走りの穂を召した風が固定して、早稲を以てする事になつたので、古くは一度きりであつたのかも知れぬ。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "神嘗祭りの原義は、今年の稲作の前兆たる「ほ」を得て、祝福する穂祭りの変形であつて、刈り上げ祭りよりも早くからあつたものとは言はれない。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月（月次祭）でも、九月（神嘗祭り）でも当らないから、此あきは、暦利用以前の秋に違ひなく、田為事の終る時期を斥す語であらう。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして見ると、秋祭りには、穂祭り・神嘗祭りの意義のものが多く、真の秋祭りとも言ふべき新嘗祭りは、段々、消えて行つた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は神嘗祭りである。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "其頃になると、神嘗祭りに近づいて来る。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、神嘗祭の話に移る。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "四神嘗祭・神今食・相嘗祭、此三つは新嘗祭に似て居る。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、まづ神嘗祭から話を進めて見る。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "神嘗祭とは、諸国から奉つた処の、早稲の走穂を、宮廷で整理して置かれて、九月になつてから、伊勢の大神に奉られることである。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "古くから神嘗祭と言うたか、どうか。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも、神嘗祭は、前に言うた相嘗祭と、関聯させて話さねばならぬ。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十七日（火）　神嘗祭である。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は神嘗祭で休みである。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、丸さん、やろうぜ」その六　豚箱の羅漢　昭和六年十月十七日――蹶起はこの神嘗祭の日を期して行われることになった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
