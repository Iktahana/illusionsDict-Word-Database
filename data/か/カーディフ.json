        "examples": {
          "standard": [
            {
              "text": "「来週、ウェールズの首都カーディフへ旅行する予定なんだ。カーディフ城に行くのが楽しみ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「カーディフ・ベイのウォーターフロントを散歩するのは気持ちいいね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ラグビーの試合で、カーディフのスタジアムは熱気に包まれていた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「カーディフでの会議の後、地元のパブでフィッシュアンドチップスを食べた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかるに、この法律が出てから間もなく、有名な石炭産地カーディフを中心とした南ウェールス地方の石炭坑夫約二十万人の大ストライキが起った。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "金がないので、カーディフまで徒歩で行って、そこで船に乗ろうと考えた。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
