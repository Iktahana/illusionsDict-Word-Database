        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "船長は荒れる波の中、梶棒をしっかりと握りしめて進路を保った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ヨットの梶棒を少し引くと、船首がゆっくりと左に曲がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "エンジンのない小舟で、梶棒一本で大海原に挑む漁師の姿があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、父に連れられて乗った手漕ぎボートで、初めて梶棒を操作させてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
