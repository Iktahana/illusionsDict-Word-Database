[
  {
    "uuid": "c87aa964-768e-5954-8185-a8818d1a0213",
    "entry": "梶棒",
    "reading": {
      "primary": "かじぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
