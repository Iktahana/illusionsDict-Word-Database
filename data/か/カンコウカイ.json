        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その稀覯本は、大学の刊行会によって復刻された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私たちは地元の歴史を記録するため、小さな刊行会を立ち上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "刊行会のメンバーが集まり、次号の企画について話し合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "勉強して書きつづけて、もう三、四枚で完結するかと思うところへ、国民図書刊行会の広谷君が雨を冒して来て、一時間ほど話して帰った。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "勉強して書きつづけて、もう三、四枚で完結するかと思うところへ、図書刊行会の広谷君が雨を冒して来て、一時間ほど話して帰った。",
              "citation": {
                "source": "火に追われて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大衆文藝』昭和二年六月、『犯罪文学研究』（国書刊行会）平成三年九月",
              "citation": {
                "source": "江戸川氏と私",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "並べて見ているだけでよろこばしい亢奮を覚えるというような工合で、国民文庫刊行会で出版した泰西名著文庫をよみ、同じ第二回の分でジャン・クリストフなども読んだ。",
              "citation": {
                "source": "祖父の書斎",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「現代日本小説大系」刊行委員会への希望宮本百合子「現代日本小説大系」が刊行される意味は、ただ日本の近代文学をもう一遍よみかえし、検討し、将来の文学に寄与するという風な、すべてのこれまでの刊行会の挨拶の範囲では、使命が果されないと思う。",
              "citation": {
                "source": "「現代日本小説大系」刊行委員会への希望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一七年に、そのころ後藤末雄氏によって訳された「ジャン・クリストフ」（国民文庫刊行会版）を読んだときの感銘。",
              "citation": {
                "source": "彼女たち・そしてわたしたち",
                "author": "――ロマン・ロランの女性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "［『大杉栄全集』第四巻、大杉栄全集刊行会、一九二六年九月］",
              "citation": {
                "source": "書簡　大杉栄宛",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "国書刊行会本を閲するに、誤脱はないようである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして頃日国書刊行会が『訪古志』を『解題叢書』中に収めて縮刷し、その伝を弘むるに至ったのを喜ぶのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃日珍書刊行会が『後昔物語』を刊したのを見るに、抽斎の奥書がある。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正五年に珍書刊行会で公にした『劇界珍話』は飛蝶の名が署してあるが、優の未定稿である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、兎に角国民文庫刊行会の「世界名作大観」の第一部の十六冊の大部分は平田禿木先生の翻訳である。",
              "citation": {
                "source": "平田先生の翻訳",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この瀟洒とした先生が国民文庫刊行会の「世界名作大観」の第一部の十六冊の大部分を翻訳したと言ふことは少くとも僕には神秘だつた。",
              "citation": {
                "source": "平田先生の翻訳",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "三分の一仕上げた頃から楽になって、少しずつ進みかけたが、半分を終った頃、小川町の国民文庫刊行会という名著を大部な予約で出版する家から、「戦争と平和」の上巻だけが出た。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "此書は、国書刊行会本の歌曲の部、或は日本歌謡集成に這入つてゐる。",
              "citation": {
                "source": "地唄",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
