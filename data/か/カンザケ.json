[
  {
    "uuid": "730308a5-1d84-54ed-9244-57cace124fc8",
    "entry": "燗酒",
    "reading": {
      "primary": "かんざけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
