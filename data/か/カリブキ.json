        "examples": {
          "standard": [
            {
              "text": "「わあ、すごい雨だね。屋根の仮葺が飛ばされないか心配だよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "本格的な瓦を載せるまでの間、とりあえず厚手のシートで仮葺を済ませておいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "予算の関係で、今年の冬は仮葺のままで過ごすことになりそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "自分方では仮葺きの屋根瓦を百枚ほども吹き落とされたと言って、それを告げに彼のところへ走り寄るのは隣家伏見屋の年寄役伊之助だ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔ふうな藁の仮葺きは、今もまだそちこちに見られるが、それとこの新らしい藁屋とのちがいは、誰の目にもはっきりとしている。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
