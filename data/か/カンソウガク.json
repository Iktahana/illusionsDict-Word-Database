          "standard": [
            {
              "text": "観相学は、顔の形や特徴からその人の性質を判断する学問だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は昔から観相学に興味があり、関連書籍を読み漁っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "科学的には根拠が薄いとされることもあるが、観相学は文化史において興味深い研究対象だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "人間の運命なるものが、もし観相学の対象であることに満足出来るならば、レーベンは「レーベンの哲学」の対象であることに満足も出来よう。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
