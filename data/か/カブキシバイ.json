    "definitions": [
      {
        "index": 1,
        "gloss": "kabuki play",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "父に連れられて初めて歌舞伎芝居を観に行ったが、その豪華絢爛さに圧倒された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "今日の夜は、新橋演舞場で話題の歌舞伎芝居を観劇する予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "歌舞伎座で、人間国宝の俳優が出演する歌舞伎芝居を観た。その迫力に鳥肌が立ったよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "剣劇の股旅ものや、幕末ものでも、全部がまだ在来の歌舞伎芝居の因習の繩にしばられたままである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが歌舞伎芝居が好きで、わけて田之助びいきの処から、其の楽屋に出入りしているうち同じ贔負の国太郎と知り合い、官吏の家庭とはまるで世界の違う下町生活の話を聴いて異常な好奇心と憧憬から自分から進んで黒繻子の襟のおかみさんになったのであった。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、今の歌舞伎芝居には可なり不満ですがね。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "外に行く処もありませんからよく参りますが、妾達の実生活と歌舞伎芝居の世界とは、もう丸きり違っているのでございますものね。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな可哀想なことを……」　そんな御冗談のうちに先生御夫婦はいろいろと私に歌舞伎芝居のお話をしてお聞かせになりました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "十歳の昔のころ祖母のお伴で屡々歌舞伎芝居を見に行くのであつたが、女に振られる悪侍やお殿様が「えゝツ、これほど云うても聞きわけもない、斯うなるからは可愛さあまつて憎さが百倍――」などゝ唸つて眼玉をむき出すのだが、いつの時でもその心持や顔つきが腑に落ちなかつた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが他の大劇場であったならば、さのみの議論にならなかったかも知れないが、なにぶんにも歌舞伎芝居の本城という歌舞伎座であるだけに、その本城をかれらに明け渡すということは、歌舞伎芝居が書生芝居に征服されたという形にもなるので、ここにいろいろの議論を生じたわけである。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "外に行く処もありませんからよく参りますが、妾達の実生活と歌舞伎芝居の世界とは、もう丸きり違つてゐるのでございますものね。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　細君は歌舞伎芝居が好きだつた。",
              "citation": {
                "source": "鶴がゐた家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おゆきの身についていて、東京の山の手に育つ子供の心には、きわめてもの珍しくうつったいくつもの癖が、くるわの習慣であったことが分ったのは、わたしが十七八になって、歌舞伎芝居をみるようになってからだった。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞伎芝居でも大向の彌次というものは、あなどりがたい批評家である場合があるし、その道の通でなければ、大体ああいう声そのものからして普通の喉から突嗟にしぼり出せるものではない。",
              "citation": {
                "source": "待呆け議会風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新大橋の日本橋區｜側の方をいつてみると、人形町通、および大門通りの舊吉原（元和三年に商賣はじめ）と歌舞伎芝居の勢力を見逃すことも出來ず、魚市場、金座、大商賣、本丸も控えてゐる。",
              "citation": {
                "source": "花火と大川端",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の歌舞伎芝居への関心から吾々が容易に脱せられないのは、その中に親しい人物を数多く吾々が持ってることが、最も大きな原因ではあるまいか。",
              "citation": {
                "source": "長篇小説私見",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は、歌舞伎芝居も飲食しながら見物されたものであるし、講釈も昼席で枕をかりて寝転びながら聴かれたものである。",
              "citation": {
                "source": "風俗時評",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "緋桜赤くぼかした八重ざくら、その蔭ゆけば、ほんのりと、歌舞伎芝居に見るやうな江戸の明りが顔にさし、ひと枝折れば、むすめ気の、おもはゆながら、絃につれ、何か一さし舞ひたけれ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も歌舞伎芝居にはその形が残っている。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "車の中では老人と商人体の男とのあいだにこんどくる歌舞伎芝居の噂がはじまった。",
              "citation": {
                "source": "遠野へ",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪人の女を含まぬ歌舞伎芝居も、ずっと昔からある悪女を改めて善人にして出すということは出来ないことであるし、又そういう妬婦のあることによって善人の女が更に引立つのである。",
              "citation": {
                "source": "役者の一生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に人形の舞台と歌舞伎芝居の舞台との関係について、ごくおおざっぱな話をしておいたが、今日はそれからもう少し路を開いていきたいと思う。",
              "citation": {
                "source": "人形の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点あの歌舞伎芝居に出る娘の伝統を失ってはならぬ。",
              "citation": {
                "source": "女性の諸問題",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには神社との密接な関係があったのでありますが、次第に徳川時代になって、歌舞伎芝居というものが全くそういう宗教とは縁のないものになってきた。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞伎芝居の楽屋などにも、こういう着物の着こなしをするものは、明治の時代の末あたりから既に見られなくなっていた。",
              "citation": {
                "source": "草紅葉",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝永年間房州で歌舞伎芝居興行の節、弾左衛門手下のものが、舞台に乱入して役者を脅迫した。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地には後世唱門師の居たことを示すべき資料を有せぬが、元禄宝永年間この瓦堂の地に、付近の京終・綿町などとともに、登大路北側から歌舞伎芝居相撲小屋等を移されたとあってみれば、これもその地が本来不浄とみなされた因縁をたどったものとも解せられるのである。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も日向佐土原在のビューと称する傀儡師部落の如きは、わずか二十戸ばかりの中から二箇の歌舞伎芝居の座ができて、各地を興行して巡っている。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの人々を世間では、やはり俳優と同じく、河原者とも、河原乞食ともいいましたが、それは河原者がキヨメの労役ばかりでなく、一方に人形も使えば、歌舞伎芝居もするという風に、遊芸の方面にも流れて行ったためなのです。",
              "citation": {
                "source": "融和問題に関する歴史的考察",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は細君に約束した以上一度で止めてしまうわけに行かなくって更に明治座かどこかの歌舞伎芝居に一度と、能に二、三度引っ張り出した。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞伎芝居の方は油屋お紺かなんかであったように記憶して居る。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
