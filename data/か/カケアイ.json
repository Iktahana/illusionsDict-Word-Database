    "definitions": [
      {
        "index": 1,
        "gloss": "negotiations",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「役所との掛け合いは父が引き受けてくれたので、手続きがスムーズに進んだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "予算を確保するため、財務担当者との粘り強い掛け合いが何時間も続いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「取引先との掛け合いがうまくいって、なんとか納期を延ばしてもらえたよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新条約の締結をめぐって、二国間の代表者が激しい掛け合いを演じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "隅の方で小僧が二人掛け合いで真似事の英語を饒舌っている。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草へ行く積りであったがせっかく根岸で味おうた清閑の情を軽業の太鼓｜御賽銭の音に汚すが厭になったから山下まで来ると急いで鉄道馬車に飛乗って京橋まで窮屈な目にあって、向うに坐った金縁眼鏡隣に坐った禿頭の行商と欠伸の掛け合いで帰って来たら大通りの時計台が六時を打った。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何代か前からきっと立派な血が流れて来ていて、それが子孫に現われて来るんですね」「これは家内とも相談ですが」と貝原は再び儀式的の掛け合いのように念を押して、「小初先生。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛け合いはもう手詰めになって来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんから自分の手先につかっている安蔵という奴に云いふくめて、二、三日まえからお亀の家の近所をうろついて、内の様子を窺わせているうちに、その屋敷からお蝶を一生奉公にかかえたいという掛け合いに来たことも判った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "それについて、行者の家の式部という奴がなにか紙屋へ掛け合いに行ったらしいんです」　そう云っているところへ源次も来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "源次の話によると、きのうの午過ぎにかの式部が炭団伊勢屋へたずねて来て、後家のお豊に厳重な掛け合いを持ち出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "改めておふくろ殿にお掛け合いをいたすために、こんにち罷り越した次第であると、式部は形を正しゅうしておごそかに云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いもよらない掛け合いをうけて、お豊は魂が消えるほどにびっくりした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "式部が掛け合いのことはお豊ひとりの胸に秘めて、店の者にはいっさい秘密にしてあったのであるが、もう斯うなっては匿しても隠されないので、お豊は番頭どもを呼びあつめて、その秘密を打ちあけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも彼はぬけ目のない一策を案じ出して、ひそかに伊勢屋へ押し掛けて行って、久次郎の母に厳重の掛け合いを申し込んだのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは今日の掛け合いの事情を問いただすために、日が暮れてからそっと祈祷所へたずねてゆくと、式部はさえぎって内へ入れなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は近づいて来た給仕を相手に妙に押しつぶしたような声で何か掛け合いをはじめている。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、冬の朝、黒門市場への買い出しの帰り廻り道して古着屋の前を通り掛った種吉は、店先を掃除している蝶子の手が赤ぎれて血がにじんでいるのを痛々しく見て、そのままはいって掛け合い、連れ戻した。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父が次郎のところへ掛け合いに行ったせいだろうと、すごすご帰った時の悲しみが、降るようにして、いま胸へ落ちて来た。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の朝、黒門市場への買出しに廻り道して古着屋の前を通り掛った種吉は、店先を掃除している蝶子の手が赤ぎれて血がにじんでいるのを見て、そのままはいって掛け合い、連れ戻した。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "与兵衛は淀橋辺にある丸多の地所と家作を抵当にして金を借り出す掛け合いに出かけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ相手の多左衛門が姿を隠してしまっては、万事の掛け合いが巧く行かないと思っている矢さきへ、丁度にここでその姿を見付けたので、重兵衛はこれ幸いと喜んで、いろいろに宥めすかして丸多の店へ連れて帰ろうとしたが、多左衛門はどうしても承知しない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "並大抵のことじゃあ埓があかないから、きょうは芝居を休んで掛け合いに来たのだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、男と女と入りまじりの芝居をするのは不都合だというので、浅川の方から鳳閣寺の芝居小屋へ掛け合いを持ち込んだが、四の五の云って埓が明かない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも少し変った奴で、楽屋で一杯飲んだ勢いで、舞台の唐人衣裳を着たままで原宿の弥兵衛の家へ出かけると、弥兵衛はなにか急用があって表へ出たあとで、子分の角兵衛という奴が親分気取りで掛け合いを始めました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけですから、この掛け合いも所詮無事には済みません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の弟子の小三津を文字吉が隠したと思って、その掛け合いに行っているところへ、丁度わたくし達が行き合わせたんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが親達の耳にはいって、師匠はとんでもないことを云うと掛け合い込まれた時には、表向きにはなんとも云い訳ができない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "善昌も覚悟したとみえて、この掛け合いのあいだに裏口からぬけ出そうとするところを、そこに張り込んでいた熊蔵に取り押えられました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かのヒュースケンの暗討ち一件をみても判ったことで、彼等からは幕府にむかって厳重の掛け合いを持ち込んでくるに相違ない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと秘密にやった使ですから、見す見す殺されたことを知っていても、幕府からは表向きの掛け合いは出来ません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "双方の親たちからやかましい掛け合いをうけた上に、二軒の得意場をうしなうのは知れている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その仔細をよく聞いた上で、兄にも成程と得心がまいったら、また掛け合いのしようもあろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士と武士との掛け合いに、真顔になって幽霊の講釈でもあるまい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
