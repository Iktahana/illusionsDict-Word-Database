        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「主人公とライバルの絶妙な掛け合いが、このアニメの一番の見どころだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "舞台上の二人がテンポの良い掛け合いを披露し、客席は爆笑の渦に包まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「君たちの掛け合い、息がぴったりすぎて、まるで本物の兄弟みたいだね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "即興の掛け合いがうまく決まると、役者としてこれ以上の快感はない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
