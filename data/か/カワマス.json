        "examples": {
          "standard": [
            {
              "text": "北の清流で釣れる河鱒は、身が引き締まっていて美味だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "河鱒の稚魚を放流する活動が、地元の漁協によって行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ルアーフィッシングで大物を狙うなら、河鱒は格好のターゲットだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は河鱒の生態について詳しく、その保護に尽力している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "蚊鉤釣りといへば主として河鮭と河鱒を釣るのであるが、英吉利に於けるその季節は毎年九月に終る。",
              "citation": {
                "source": "趣味としての読書",
                "author": "平田禿木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃の日本へは、亜米利加系の虹鱒や河鱒、北海道から姫鱒などが移入されて繁殖しているが、その頃の利根川へは、古来東日本の河川に遡ってくる日本鱒である。",
              "citation": {
                "source": "利根川の鮎",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
