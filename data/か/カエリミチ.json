[
  {
    "uuid": "87951d0b-9efe-5c8a-b0ad-02b4acce8e5f",
    "entry": "帰り道",
    "reading": {
      "primary": "かえりみち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the way back",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "帰り道、満月が煌々と道を照らしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "寄り道せずに、まっすぐ帰り道を急いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "懐かしい帰り道をたどり、昔住んでいた家を訪ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "帰り道にコンビニに寄って、夕食を買っていこう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "獲物は帰り道にあらわれる。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがよほどおかしかったと見えて、帰り道に精養軒前をぶらぶら歩きながら、先生が、そのグウ／＼／＼というかえるの声のまねをしては実に腹の奥からおかしそうに笑うのであった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　さて、二人がその帰り道である。",
              "citation": {
                "source": "若菜のうち",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで、ふたりは、暖かい部屋の中でからだを暖めて、帰り道のことを教わりました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのう学校からの帰り道、ふと目黒のチョッピリ叔母さんのところへ寄って行こうかと思って、そう思ったら、どうしてもきょう行かなければいけないような気がして来て、午後からはお天気も悪くなって雨が降り出しそうだったのだが、ほとんど夢中で目黒まで行ってしまった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術の道にも、普通のサラリイマンの苦労と、ちっとも違わぬ俗な苦労も要るだろうという事は、まえから覚悟していたところで、それくらいの事には、へこたれはせぬけれど、僕がきょう斎藤氏邸からの帰り道、つくづく僕自身の無名、矮小を思い知らされて、いやになったのだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それなら和太郎さんは、帰り道を一本松と茶屋の前にとってはならなかったのです。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――少し気取るようだけれど、ちょっと柄にない松島見物という不了簡を起して……その帰り道なんです。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今この駕籠に乗っている客も、やはり流行の横浜見物に行った帰り道であった。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　九月二十四日――横浜見物の帰り道に、二挺の駕籠が鈴ヶ森を通りかかったのは、その日の暮れ方であった。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは娘の三回忌、女房の一周忌に相当するので、源兵衛は下大須にあるただ一軒の寺へ墓参にゆくと、その帰り道で彼は三人の杣仲間と一人の村人に出会った。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その帰り道、千葉の八幡へさしかかって例の『藪知らず』の藪の近所で茶店に休んだ。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その帰り道に、かの円乗寺の前を通りかかった。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "無事にお届が相済んで祝着この上もない……まず一献……」　贋せ侍斬りに就いて大目附へ出頭した紋服姿の石月平馬と、地味な木綿縞に町の低い役袴を穿いた三五屋、佐五郎老人が、帰り道に招かれて夕食の饗応を受けていた。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹一は風呂敷に包んだ櫃を背負うて行く学校までの道が、あの質屋からの帰り道よりも辛かった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜夜ふけての帰り道に芋屋の角まで来ると、路地のごみ箱のそばをそろそろ歩いているおさるの姿を見かけた。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰り道で女だけでも先に殺ってしまおう！",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰り道で女のほうだけでも……）　彼はそう考えて、沼のような落ち着きを装いながら馬車を追い進めた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつらのわがままが、おれたちの生命を懸けての意志までも押し曲げることができるものか）　だいいち正勝にとって、帰り道での計画を果たすのにたとえ妹にもしろ、他人にいられては具合が悪かった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だって……」「それじゃ、帰り道にあの原始林にかかったら、隙を見て馬車から飛び降りるといいや。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私は帰り道に、序に立ち寄ったのであったが、そこの管理人は、非常に鄭重に応対してくれた。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとひとつ、ピーターソン、ちょっと帰り道で鵞鳥を買って、ここへ置きにきてくれないか。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の帰り道で彼女の妨害をするものがないよう見届けるのが我々のつとめだ。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあこの帰り道の方をたどろう。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども敬吾は、その帰り道にどう気がかわったものか、郵便局に残っていた二百円ばかりの貯金を引き出すと、その夜から行方を晦ましてしまった。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所で訊くと、おかみさんは三十三の厄年で川崎の初大師へ参詣に行って、その帰り道で暴れ馬に蹴られて、駕籠に乗って帰って来たが、それから熱が出たので今も寝ているという噂であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸多の店の菩提寺は中野にあるので、五月二十八日の命日に、女房のお才が番頭の幸八と小僧を連れて、多左衛門の墓まいりに行った帰り道に、淀橋の町はずれを通ると、その頃のここらには茅葺きの家がたくさんありました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだ、帰り道だから回向院前へ廻って、お俊の様子をよそながら見届けようぜ」　お俊は相生町一丁目に住んでいるとすれば、小栗の屋敷から三、四丁を隔てているに過ぎない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎兵衛は夜、酒を呑んでのかえりみち必ずひとつの水車を征伐した。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校からのかえりみち、ふらと停車場に立寄り、上野までの切符を買い、水兵服のままで、汽車に乗った。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
