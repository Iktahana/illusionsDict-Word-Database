        "examples": {
          "standard": [
            {
              "text": "上質なウールのカーディガンは、真冬の冷え込みの中でも体を優しく包み込んでくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はシャツの上にネイビーのカーディガンを重ね、落ち着いた印象で面接の場に臨んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このカーディガン、第ニボタンが取れかかってるわよ」と母が針と糸を持ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "登校中の女子生徒たちが、お揃いの指定カーディガンを着て楽しそうに談笑している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ネットに入れて自宅で洗えるタイプのカーディガンは、手入れが楽で毎日重宝している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "けっきょくのところ、破れ褞袍を重ねにした石田氏と、ほつれ放題の男物のカーディガンをひっかけて髪をふり乱した賢夫人が、六年の間、ただの一度も片附けられたことのない茶の間のチャブ台を挾んで向きあい、かくいう次女の百々子がオブザアバーの格で、ほどいいところに、漫然と介在しているにすぎない。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばさんのほうは、四十二、三の、見るからに逞ましい感じのひとで、寸足らずに着た紺絣のワンピースに、桃色のカーディガンを前ひろげに羽織り、素足に赤い鼻緒の下駄を履いている。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしゃまのユキ坊やは、毛皮のついたカーディガンのツウ・ピースを着て、しゃなりくなりと広間へ入って来たが、生花の枝に袖をひっかけて花瓶を倒し、腰から下をびしょ濡れにしてべそをかいた。",
              "citation": {
                "source": "キャラコさん",
                "author": "雪の山小屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は工員ふうで黄色いナイロン・ジャンパーを身につけ、娘は淡いピンクのカーディガンを、きちんと喉もとまで釦をはめて着ていた。",
              "citation": {
                "source": "赤い手帖",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本ふうな顔だちの、小柄な首の細い娘で、赤いカーディガンのようなものを着ていた。",
              "citation": {
                "source": "軍国歌謡集",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、濃紺の水玉の散った白のワンピースに、淡い水色のカーディガンを着ていたのを憶えている。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "スピードメーターの針は確実に上がり、カーディガンともつれ合うやけに耳障りな風の音がスピードオーバーを告げるブザーをかき消してしまう。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "長袖のシャツの上にはおったカーディガン。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族づれのおっちゃんやおばちゃんは、とっくにはじまっている秋に早くも調子を合わせ、セーターやカーディガンを着こんでいる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
