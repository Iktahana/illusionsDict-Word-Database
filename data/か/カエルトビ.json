        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "体育の授業で、クラスメイトと一列に並んで順番に蛙飛びをして体を温めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "息子が公園で友達と楽しそうに蛙飛びをして遊んでいる姿をベンチから眺めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "陸上部のウォーミングアップメニューには、足腰を鍛えるための連続した蛙飛びが組み込まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "句はその切字で分離されて居り、以下の「蛙飛び込む」は、目前の現実的印象を表現してゐる。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし「古池に蛙が飛び込んで水音がした」がなぜ散文で、「古池や蛙飛び込む水の音」がなぜ詩であるか。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古池や蛙飛び込む水の音。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山吹や蛙飛び込む水の音。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の枝を折り取りて蛇を打てば、蛇弱りて、蛙飛び去る。",
              "citation": {
                "source": "秋の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば古池や蛙飛びこむ水の音　　　　　　　　芭蕉といふ句を見て、作者の理想は閑寂を現はすにあらんか、禅学上悟道の句ならんか、あるいはその他｜何処にかあらんなどと穿鑿する人あれども、それはただそのままの理想も何もなき句と見るべし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に古池や蛙飛びこむ水の音　　　　　　　　芭蕉　の句に至りては殆んど春季の感なし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "久慈はにやりとしながら、「これが蛙飛び込む水の音かね。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "答「古池や蛙飛びこむ水の音」。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "古池や蛙飛びこむ水の音　　　　芭蕉の一句は古今の傑作として人口に膾炙する所、馬丁走卒もなほかつこれを知る。",
              "citation": {
                "source": "古池の句の弁",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "古池や蛙飛び込む水の音　これなり。",
              "citation": {
                "source": "古池の句の弁",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬と残夢と月と茶の煙とを無理に一句に畳み込み、三十日の闇と千年の杉とそれを吹く夜風とを合せて十七字の鋳形にこぼるるほど入れて、かくして始めて面白しと思ひし者が、翻然として悟りし今より見れば、これらの工夫したる句はむしろ「蛙飛び込む水の音」の簡単にして趣味あるに如かざるを知りたるなり。",
              "citation": {
                "source": "古池の句の弁",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "古池や蛙飛びこむ水の音、この句に我一風を興せしよりはじめて辞世なり。",
              "citation": {
                "source": "古池の句の弁",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙飛び込む水の音を御存じ？",
              "citation": {
                "source": "ピエロ伝道者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "余りにも漠然と、さながら雲を掴むやうにしか、「言葉の純粋さ」に就て説明を施し得ないのは、我ながら面目次第もない所とひそかに赤面することであるが、で、私は勇気を奮つて次なる一例を取り出すと――「古池や蛙飛び込む水の音」　之ならば、誰が見ても純粋な言葉であらう。",
              "citation": {
                "source": "FARCE に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙飛び込む水音を作曲して、この句の意味を音楽化したと言ふ人もなからうし、古池に蛙飛び込む現実の風景が、この句から受けるやうな感銘を私達に与へやうとは考へられない。",
              "citation": {
                "source": "FARCE に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俳句に上達したければ、少なくとも一万句は作り捨てるがよい、君達の思想にコビリ付いている先人の残滓、例えば、蛙飛び込む水の音とか、日ねもすのたりのたりかなとか、そういった月並な考え方はみんな出尽くしてしまって、それから始めて銘々の本当のものが出て来る」と。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "平次身の上話",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉はそれを句にしようとして「蛙飛び込む水の音」と言い、上五字はありのままに「古池や」と置いた。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「んじゃ、かえるとびやろかァ」と、久助君がいう。",
              "citation": {
                "source": "久助君の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
