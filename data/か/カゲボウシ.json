[
  {
    "uuid": "3c0e83a3-22fc-50d0-87da-a893798e7a36",
    "entry": "影法師",
    "reading": {
      "primary": "かげぼうし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
