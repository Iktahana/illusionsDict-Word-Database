        "examples": {
          "standard": [
            {
              "text": "夏祭りの抽選会、また空クジばかりで残念だったね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "宝くじを買うたびに期待するけれど、だいたいは空クジに終わってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このお菓子のオマケは、たまに空クジがあるから気を付けて。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "何回挑戦しても空クジばかりで、景品が当たる気がしないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこへ自分が帰って行って、「たからくじ」の秘密をはじめて打ち明ける。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし今電話をかけてやって――屋の奴さんに××楼の桃太郎さんに○○楼のひよ子さんの三人だけを今すぐ来てもらうことにしたけれど、それでも八人しきゃいないわ」「いいさね、しかたがないからくじ引きして負けたものが損なのさ。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            }
          ]
        }
