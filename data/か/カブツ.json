[
  {
    "uuid": "0c27033c-ce00-5d6f-bba9-6097d5c43594",
    "entry": "下物",
    "reading": {
      "primary": "かぶつ",
      "alternatives": [
        "げぶつ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
