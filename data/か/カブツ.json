      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "side dish (to have with a drink)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「今夜はいい酒が入ったから、何か気の利いた下物を用意してくれ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "主菜の合間につまむ下物として、銀杏の塩煎りが出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おっ、この下物は酒が進む味付けだね。もう一合頼もうか。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "樹明君から来信、私が酒を買ひ、君が下物を持つてくることになつた（酒代は、ありがたや、句集代を樹明君が保管してゐてくれたので、十分、十分、十分である）。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬治君が戻つてくる、樹明君が酒と下物とを持参した、やつぱり酒はうまい、二君がそれ／″＼帰つた後で、自分で自分の酔態を笑つたことである。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸福な夕――昨日のおかげで、酒はあるし、下物もあるし、身心は安らかだし。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、樹明来、そして敬坊来、酒は豊富、下物も豊富（野菜ばかりだが）、生ビールさへあつた、みんなほどよく酔うて、樹明君は九時頃帰宅、敬坊はとう／＼泊つた。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君が何だかいら／＼してやつてきた、一応帰つてまたきた、酒と下物とを小者に持たせて。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒も下物もすべてを樹明君が負担してくれた、いつもすまないと思ふが、さう思ふだけでどうにもならない。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒は加茂鶴、下物は焼鮎、……身にあまる優遇で野衲いさゝか恐縮の体。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣つた魚を下物にして、水上饗宴である、澄太さんは少しく、独壺（黙壺氏の誤記）さんも少しく、私は大に飲んだ。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒あり下物あり、友あり火あり。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮れて、樹明君と同道して岐陽さんを訪ねる、さつそく酒になる、久芳校長も浅川国手もやつてこられて、一升瓶が何本か倒れた、下物はお手のもので凝つたものばかり。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君が病状見舞に来てくれる、酒と下物とを持つて。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、たべる菊は普通は黄の千葉又は万葉の小菊で、料理菊と云つて市場にも出て来るのであるが、それは下物のツマにしか用ゐられぬ、あまり褒めたものではない。",
              "citation": {
                "source": "菊　食物としての",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等の菊は梅の肉で保たせると百日にも余つて其の色香を保つことが出来るものであるから、我等の如き富まぬ者の寒厨からも随時に一寸おもしろい下物を得られるのである。",
              "citation": {
                "source": "菊　食物としての",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "多く夏の釣でありますから、泡盛だとか、柳蔭などというものが喜ばれたもので、置水屋ほど大きいものではありませんが上下箱というのに茶器酒器、食器も具えられ、ちょっとした下物、そんなものも仕込まれてあるような訳です。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アア、酒も好い、下物も好い、お酌はお前だし、天下｜泰平という訳だな。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「構うことあ無えやナ、岩崎でも三井でも敲き毀して酒の下物にしてくれらあ。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「石塔に鉢卷」といふ壯んな諺が日本にはあるが、石塔になつた氣で鉢卷をして働いたなら、華嚴の瀧はその人の棺前の華では無くて、必ず酒の下物たる好い眺めであらう。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏中の好下物、盆の贈答に用ふる事、東京に於けるお歳暮の鮭の如し。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大箱とて、左右の石柱の絶壁、相距ること、ほぼ一町ばかりとなれる処に至り、釣り得たる「やまべ」を下物として、上戸は飲み、下戸は食す。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は名代部屋にぼんやりと待ち侘びている男の寂しそうな顔を頭に描きながら、それを下物にこころよく酒を飲んでいた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯さえ蒼白い顔は藍のように変わってしまって、ただ黙ってうつむいていると、やがて吉五郎はじろりと見かえって、「若けえ人に飛んだお下物を見せたが、おめえはあの女を知っているかえ。",
              "citation": {
                "source": "子供役者の死",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の死骸はふたたび屏風に隠されて、それからまたいろいろの下物などが出たそうですが、六三郎は箸も付けませんでした。",
              "citation": {
                "source": "子供役者の死",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "縮緬羽二重、絹地のほかにゃ手もかけたことのねえ上物染め屋と名を取った紅徳が、下物も下々の手ぬぐいを染めるたあ、不審じゃねえかよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏のように、落下物体が獲得するような加速度をもって、尖鋭、怪奇、意外、等の最高頂をめがけて突進してきた作家は、一度、方向転換して、余裕のある姿勢をとりなおさぬと抜きさしならぬキュ・ド・サック〔cul de sac ＝窮地行き止まり、袋小路〕へ頭を突っこんで動きがとれなくなりはしないかと考えられる。",
              "citation": {
                "source": "探偵小説壇の諸傾向",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガロはいいつけられたものを地下物置から取出すと、大きな盆の上に山盛にして、ドレゴの部屋へ持って来た。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "手拭を顔に掛けたり、外套をかぶつたりしてゐるそのいぎたない風景の上に、電燈は明々と明つて、幾つもの仕切板の角々のあのラックの光沢に反射してゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "線路に沿うたとある森影から青い洋服を着て、ミレーの種蒔く男の着て居るやうな帽子をかぶつた若者が、一疋の飴色の小牛を迫うて出て來た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く買って来ねえか」　戸に誰かぶつかる音。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "波うつやうな髮の上に紫いろの帽子をかぶつた娼婦たちも近づいてくる。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち止まつた私の前に、暗闇の中から、影のやうにひよいと近附いて來たのは、肩掛を頭越しにかぶつた、何となくみすぼらしい身成の外國の婦人だつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
