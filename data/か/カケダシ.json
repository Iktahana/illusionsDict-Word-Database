    "definitions": [
      {
        "index": 1,
        "gloss": "novice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はまだ駆け出しの料理人だが、将来有望だと評判だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "駆け出しの作家が、新人賞を受賞した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この業界では、駆け出しのうちは経験を積むことが何より大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "突然向うの家の板塀へ何か打っつけた音がしたと思うと一斉に駆け出してそれきり何処かへ行ってしまった。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーイ、ドン、で駆け出したのだが、村長さんも組合長さんも日頃馴れてゐることとて、腰の据り方といひ、手の振り方といひ、足の運び方といひ堂に入つたものであつた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "次ぎのランナーは、みんな年が若かつたので、元気にまかせて、担いでゐるのが肥えの筈であることを忘れて、ポチャポチャやりながら駆け出し疾走し始めた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "見習は、いきなり駆け出した。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "南向いている豚の尻を鞭でたたけば南へ駆け出し、北向いている野猪をひっぱたけば北へ向いて突進する。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして娘が跡へ引き返して来て、自分を見附けて、知らぬ世界へ引き摩つて行くのだらうとでも思つたらしく、フリツツは慌てゝ停車場を駆け出して、跡をも見ずに町の方へ帰つて行つた。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると突然子供はワアワアと唖のような声を出して駆け出しました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホンケが来たホンケが来た」と言って駆け出して行っては、この「ホンケ」を取り巻いて、そうして口々に「ホンケ、オーセ、オーセ」と言ってねだった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが向う河岸の役所の構内へ落ちそうになると、そこの崖で見ていた中年の紳士の一人は急いで駆け出して行って、建物の向うに消えた。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と叫びながら、寄宿舎から逃げるように駆け出してしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "群を離れた犬が一疋汀へ飛んで来て草の間を嗅いでいたが、笛の音が響くと弾かれたように駆け出して群の後を追う。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜘蛛はまるできちがひのやうに、枝のかげから駆け出してむんずとあぶに食ひついた。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『幸ちゃんに今帰ったからッて、そ言っておくれ、』と時田は庭の耳門へ入った、お梅はばたばたと母屋の方へ駆け出して土間へそっと入ると、幸吉が土間の入口に立っている。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはにぎり飯をほうり出して、手についてる御飯つぶを着物ではらい落としながら、大急ぎでその人のあとから駆け出した。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてジャンにさしずをすると、ジャンはあぶない足どりながらピエールを背負っていっさんに駆け出しました。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時こそ三十六計の奥の手を出して一散に駆け出し、危うく吾妻川の河底へ生埋めになる急場を辛くも通り過ぎ、四人相顧みて工夫の猛悪なるに驚ろく。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、あたかも一大秘密でも見出せしごとく、すぐさまその黄色い紙を衣袋に押し込み、物をも云わず、岬の上の別荘めざして駆け出した。",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ふん／＼と聞いていたが、急にパッと駆け出した。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と叫んで、威勢よく雪の中を駆け出して消えてしまったのである……　　　　＊　　　　＊　　　　＊「……僕は、それで呆然としてしばらく其場に佇んでいた。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとから薪割用の古鉈を提げた元五郎親爺が、跛引き引き駆け出したが、これも森の中の闇に吸い込まれて、足音一つ聞こえなくなった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ変に思って表へ駆け出して見ると、お天気の良い往来に人通りも無く、二三軒先で支那人が、「反物入りまションか」　と云っているだけです。",
              "citation": {
                "source": "クチマネ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "春夫さんは一目散に繁華な往来を駆け出しました。",
              "citation": {
                "source": "クチマネ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "口を袖で押えて駆け出して来た。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも子供の声がすると「また、ひろ子のやつが――」と呟きながらまきは駆け出して行つた。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂子は気分を襲つて来た悲惨な蝕斑に少し堪らなくなつて、駆け出して少女のやうに小布施のアトリヱへ転げ込んで、年下の男の友人に何かおいしいものでも喰べさして貰はなければ慰み切れない辛い気持になつた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の子供たちは咽喉へ嚥み下すのもまどろこしいようにせっせと食べ放って、遊び半ばで置いて来た応接間の方へ駆け出して行きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは、すっくり立上るや老人に、「さよなら」　と言ったなり、学園の方へ一散に駆け出しました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寮の老妻が駆け出して行って、池上にわたくしの来訪を告げている様子です。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると顔を赭くして急に駆け出した。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "流暢に出た大阪弁に弾みつけられてどんどん駆け出し、勢よく飛び込んでみると、おやッ！",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
