        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "先ほどの速報値から修正が入り、これが今回の選挙の確報となります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "統計局から昨年度の有効求人倍率の確報が出たので、資料を差し替えてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "確報が出るまでは予断を許さない状況ですが、おそらく我々の勝利でしょう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "速報は早くて助かるけど、やっぱり確報を確認しないと最終的な判断はできないな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "アグリパイナは折しも朝の入浴中なりしを、その死の確報に接し、ものも言わずに浴場から躍り出て、濡れた裸体に白布一枚をまとい、息ひきとった婿君の部屋のまえを素通りして、風の如く駈け込んでいった部屋は、ネロの部屋であった。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕えられて虜に降ったのだという確報が届いた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月十三日　マターファがサヴァイイを追われ、マノノに戻った由、確報あり。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すでに、有栖川宮が錦旗を奉じて、東海道をお下りになっているという確報も参っております。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＯＳは、返電があってから、本船の位置を確報して救助船に無駄な動きをさせずに一刻も早く誘き寄せるのが大変な仕事なのだ。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い間、なんの確報もはいらなかったが、彼はじっと待った。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "義仲の死が、確報されて来たのは、二十三日の晩であった。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「百方、手分けして、お行方を求めさせておりますが、まだ確報もございませぬ」　と、いまも彼の前にひとりの将が復命していた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに探らせてみても、確報をつかむに至らないのである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "その動機は、陳倉の守将｜※昭が、このところ病に罹って重態だという確報を得たからであった。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに“吉野落つ”と聞えても、味方による確報ではなく、吉野からの落人はまだ一人も、ここへはたどりついていなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この御文言では、隠岐のみかどが、はや本土へ御還幸あったと読まれますが、これでよいのでございまするか」「む、確報はまだ不明だが、敵の総がかりを見てからでは間にあわぬ。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっと言う間に、警官の一人は、空中たかくほうり上げられた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
