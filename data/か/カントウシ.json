    "definitions": [
      {
        "index": 1,
        "gloss": "interjection",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あっ」とか「ええと」といった間投詞が、会話の自然なリズムを作る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "日本語の間投詞を使いこなせると、ネイティブのような響きになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "驚いたときに出る「おっと！」という言葉も、分類上は間投詞にあたる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "感情をダイレクトに伝える間投詞は、言葉の壁を超えて通じることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "尤もそれも場合によるので、私のは特に感情の間投詞として、心に深き謙遜を感じ人格への先輩的愛慕を感ずる場合にのみ之れを用ゐる。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ人々の態度とおりおり聞こえる単語や、間投詞でおよその事件の推移を臆測し、そうして自分の頭の中の銀幕に自製のトーキー「東京の屋根の下」一巻を映写するのである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "春が来たからといって、私には間投詞を並べて、可愛い溜息を洩らすほどの若々しさもなく、また、暗い穴の底へ投り込まれたような鬱憂もないが、矛盾した自己を、やや離れた態度で、冷かに観照しうるだけの皮肉がある。",
              "citation": {
                "source": "鎖ペンを握って",
                "author": "――三月十九日夜――　　山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という間投詞を入れなければ喋れないようなレヴュ俳優の科白廻しを聴いていると、たしかにこれは男子の仕事ではないという気がするのである。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして滅多に興奮しない彼が日頃にもなく顔を赤く染めて、激しい間投詞を口にした。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この間投詞は僕が若者間に流行させているもので、知らるる通り「汝の感傷癖を嗤うよ。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アレ以来今日で五日になるが、毎日酒浸しだ」　ト云ッてその証拠立の為めにか、胸で妙な間投詞を発して聞かせた。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに対してホームズは時々質問や間投詞を挟んだ。",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "今泉雄作氏の説では、禅の喝のような一種の間投詞で、「ええなんじゃいの」といった意味であるとのこと。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "『君か』『や、何うも……』『誰かと思ひし』　霰の如き間投詞の互に交されたる後、灑ぎの水は汲まれ、草鞋は脱がれ、其儘奧の室に案内せられたるが、我等二人は先何を語るべきかを知らざりき。",
              "citation": {
                "source": "秋の岐蘇路",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "フツフウ、ユウユウと云ふ流行唄の二つの間投詞を取つて名づけた二匹の小犬が居て食卓の下で我我の足に突当り乍らうろうろする。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Yo'-heave-ho'（or yo'-hea-vo'）（ヨーゥヒィーヴォー）【間投詞】（水夫が重い物を捲きあげる時の）えんやらさ。",
              "citation": {
                "source": "熟語本位英和中辞典",
                "author": "Y",
                "note": "青空文庫"
              }
            },
            {
              "text": "Yoicks（!）（ヨイックス）【間投詞】狐狩に猟犬を励ます声。",
              "citation": {
                "source": "熟語本位英和中辞典",
                "author": "Y",
                "note": "青空文庫"
              }
            },
            {
              "text": "マツグは生憎脳天に空罎が落ちたものですから、quack（これは唯間投詞です）と一声叫んだぎり、とうとう気を失つてしまひました。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "クオラツクスと云ふ言葉は唯意味のない間投詞ですから、「おや」とでも訳す外はありません。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロツペはクオラツクス党を支配してゐる、その又ロツペを支配してゐるものは Pou-Fou 新聞の（この『プウ・フウ』と云ふ言葉もやはり意味のない間投詞です。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから年をとった女中が一人細目に硝子戸をあけて見た後、「おや……」何とか間投詞を洩らし、すぐに僕を往来に向った二階の部屋へ案内した。",
              "citation": {
                "source": "冬",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッグはあいにく脳天に空罎が落ちたものですから、quack（これはただ間投詞です）と一声叫んだぎり、とうとう気を失ってしまいました。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "クオラックスという言葉はただ意味のない間投詞ですから、「おや」とでも訳すほかはありません。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロッペはクオラックス党を支配している、そのまたロッペを支配しているものは Pou-Fou 新聞の（この『プウ・フウ』という言葉もやはり意味のない間投詞です。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "小野さんは一字の間投詞を挟む遑まなく、口車に乗って馳けて行く。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう観察した敬太郎は、この一句を前置に、今までの成行を残らず話そうと力めにかかったが、時々相手から「そうでございますとも」とか、「本当にまあ、間の悪い時にはね」とか、どっちにも同情したような間投詞が出るので、自分がむかっ腹を立てて悪体を吐いた事などは話のうちから綺麗に抜いてしまった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "もさはまをすから出た間投詞又は語尾で、単純な田舎の古朴な語とは言へない。",
              "citation": {
                "source": "「さうや　さかいに」",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この倦怠感は、表面は賑やかな応酬のかげにひそんで、争へない間投詞のやうなものになつてゐるのであらう。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前はいつも中途半端な間投詞を使ってごまかそうとしてる。",
              "citation": {
                "source": "二つの途",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大丈夫※」　疑問とも間投詞とも片のつかないその語尾は、お延にも何という意味だか解らなかった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその表現がまた刹那のひらめきの鋭い利用や、間投詞の巧妙な投げ込み方によって、一分のすきもないものである。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と云ふ間投詞や、絶えず海龜の苦しさうな歔欷とに妨げられて絶え／″＼に。",
              "citation": {
                "source": "愛ちやんの夢物語",
                "author": "ALICE'S ADVENTURES IN WONDERLAND.",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまには短い間投詞を殘して、沸然と立去る人もゐた。",
              "citation": {
                "source": "受驗生の手記",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "最大級の間投詞で以てシェストーフを語ることは、時間が経つと多少恥かしい結果になるだろうことを、覚悟しなければならないのではないかと思う。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
