        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝、慌てて家を出たら、左右でデザインの違う片跛な靴を履いてきてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "引越しのドタバタで棚板の支えを一個失くしてしまい、本棚が片跛に傾いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "揃いだったはずの湯呑みが一つ割れてしまい、今は柄の違う片跛なペアで使っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「なんだか今日の眉毛、左右で高さが片跛になっちゃった」と鏡を見て彼女は苦笑いした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
