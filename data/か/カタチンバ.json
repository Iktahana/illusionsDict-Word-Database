          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "事故で足を痛めてから、彼は少しだけ片跛を引きながら歩くようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い木製の椅子は脚の長さが揃っておらず、座るたびに片跛に揺れて落ち着かない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "遠くの方で、片跛な足取りの野良犬が夕日に向かってトボトボと歩いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「アゲマキ」という貝は瀟洒な薄黄色の殼のなかに、やはり薄黄色の帽子をつけた片跛の人間そのままの姿をして滑稽にもセピア色の褌をしめた小さな而して美味な生物である。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "お尻の上の帯をゆすぶりゆすぶり玄関の扉を開いて、新派悲劇みたいな姿態を作って案内したから吾輩も堂々と玄関のマットの上に片跛の護謨靴を脱いで、古山高帽を帽子掛にかけた。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……放神したようにダラリと開いた唇、真赤に血走ったまま剥き出された両眼、放散した瞳孔、片跛に釣り上った眉。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな小娘が片跛の下駄を履いて、六本木から神田まで驅けて來るといふのは、容易のことではありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分、何處へ」　後ろからガラツ八、これは下駄と草履を片跛に穿いて追いかけます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "南蠻祕法箋",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五六、大店の手代風ですが、餘程面くらつたものと見えて、履物も片跛、着物の前もろくに合つて居りません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "どんど燒",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分、どこへ」　後ろからガラッ八、これは下駄と草履を片跛に履いて追っかけます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "南蛮秘法箋",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五六、大店の手代風ですが、余程面くらったものと見えて、履物も片跛、着物の前もろくに合っておりません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "どんど焼き",
                "note": "青空文庫"
              }
            },
            {
              "text": "お孃さんが危いところへ行つたと知つて、下駄を片跛に穿いて本郷丸山から飛んで來たのさ」「なアーンだ」「それを身投げにしたところが俺の作だ」　平次は面白さうでさへありました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お秀の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢さんが危ないところへ行ったと知って、下駄を片跛に履いて本郷丸山から飛んで来たのさ」「なアーンだ」「それを身投げにしたところが俺の作だ」　平次は面白そうでさえありました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お秀の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し反省といふものがなく、徒らに尖端を狙つた輕佻浮薄ばかりを全部としてゐたら、日本の文學は片跛で、極めて不健全なお先走りのものになり終つてゐることと思ふ。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある時、かたちんばの下駄をはいてわずかに三町ばかり歩いた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まゆ毛はかたちんばになり、猶更わらわれた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす暗い、かたすみのところに、みすぼらしい年とったおばあさんが、かたちんばの古げたをよりわけて、あれか、これかと、くみあわせてみているのでした。",
              "citation": {
                "source": "緑色の時計",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の上に、手ぬぐいをかぶった、ひげつらの男と、大きな洗面器をかかえたものと、かたちんばのげたをはいた子どもなど、ひとりとして、まんぞくのふうをしない、人たちが集まっていました。",
              "citation": {
                "source": "かたい大きな手",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "mismatched (e.g. odd shoes)",
        "register": "standard",
