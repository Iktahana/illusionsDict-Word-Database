    "definitions": [
      {
        "index": 1,
        "gloss": "rhinoceros beetle (esp. the Japanese rhinoceros beetle, Trypoxylus dichotomus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夏祭りの夜店で、子供がカブトムシを欲しがっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "飼育ケースの中で、カブトムシの幼虫がどんどん大きくなっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昆虫採集に行ったが、なかなか大きなカブトムシは見つからなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "羽虫が飛び、甲虫が歩く。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜疋の甲虫が、夜だかの咽喉にはいって、ひどくもがきました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一疋の甲虫が、夜だかののどに、はいりました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一疋の甲虫が、夜だかの咽喉にはいって、ひどくもがきました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つのあかりに黒い甲虫がとまってその影が大きく天井にうつってゐたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "興味の向くままに六かしい数学的理論もやれば、甲虫の色を調べたり、コーヒー茶碗をガラス板の上に滑らせたりした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中川｜紀元氏の裸体画を見ていると、何だかある甲虫を聯想するが、何だという事が、はっきり思い出せない。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともよは湊が中指に嵌めている古代｜埃及の甲虫のついている銀の指輪さえそういうときは嫌味に見えた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はそっとこの甲虫をつまみ上げてハンケチで背中の泥を拭うていると、隣の女が「それは毒虫じゃありませんか」と聞いた。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポーセがせっかく植えて、水をかけた小さな桃の木になめくじをたけておいたり、ポーセの靴に甲虫を飼って、二月もそれをかくしておいたりしました。",
              "citation": {
                "source": "手紙　四",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つのあかりに黒い甲虫がとまってその影が大きく天井にうつっていたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂の上をはっている甲虫で頭が黒くて羽の煉瓦色をしているのも二三匹見かけた。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、こんなはげ山の頂にうさぎが何を求めて歩いているのか、また蜘蛛や甲虫や蝶などといかなる「社会」を作っているのか愚かな人間には想像がつかないのである。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つのあかりに黒い甲虫がとまって、その影が大きく天井にうつっていたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲虫の羽音が一さう高くなる。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと直交し弓なりに立って見える呉服橋通りの道路を、緑色の電車のほかに、白、赤、青、緑のバスが奇妙な甲虫のようにはい上りはいおり行きちがっている。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は依然波の間に点を為して見ゆる其の甲虫を、悲惨な思いをして眺めている。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄かにどこからか甲虫の鋼の翅がりいんりいんと空中に張るような音がたくさん聞えてきました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲虫の翅の音はいよいよ高くなり青い木はその一つ一つの枝まではっきり見えて来ました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　おそらく、私たちを乗せた巨大な甲虫は、今は一千五百尺以上の山中を驀進している。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ逃げ出せと、甲虫の突進だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの甲虫はその前をまた爆音高く通過した。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲虫に黒蟻が取りついた姿勢である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、甲虫の如き額をした・鼻の長い男の横顔をはっきり現していた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下段右側には動的表現界の代表者、犢、犬、猫、鷹、甲虫、鰐、紅鶴等の神々が列座し、左側には静的表現界の代表者、月、星、山、川、木、草、石等の神々が居流れております。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫色の紋のある美しい蝶が五、六羽、蜂が二種類、金亀子のような甲虫が一種、そのほかに、大きな山蟻や羽蟻もいる。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝶蛾や甲虫類のいちばんたくさんに棲んでいる城山の中をあちこちと長い日を暮らした。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹、シダ、コケ、花、鳥、ヘビ、ルリタテハもアゲハもカブトムシもみんな、それから山もだ」　いよいよ話がわからなくなって、慶一は高志の横顔を見なおす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "よっかめの　りすたちの　おみやげは　まるまるした　カブトムシ　６ぴきで、　ぬしさまからすれば　プラムプディングに　はいってる　プラムみたいな　ものなのです。",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            },
            {
              "text": "カブトムシは　１ぴきずつ　ギシギシの　はっぱで　ていねいに　くるんで、　マツバを　さして　とめてありました。",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
