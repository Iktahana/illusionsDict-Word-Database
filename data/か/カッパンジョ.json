        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "かつて賑わっていた活版所も、今ではほとんど見かけなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は古い活版所の跡地を利用して、カフェを開いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大学の研究室には、現役で稼働する活版所が併設されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "〔二、〕活版所ジョバンニが学校の門を出るとき、同じ組の七八人は家へ帰らずカムパネルラをまん中にして校庭の隅の桜の木のところに集まってゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、活版所　ジョバンニが学校の門を出るとき、同じ組の七八人は家へ帰らずカムパネルラをまん中にして校庭の隅の桜の木のところに集まっていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　活版所　ジョバンニが学校の門を出るとき、同じ組の七、八人は家へ帰らずカムパネルラをまん中にして校庭の隅の桜の木のところに集まっていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へは帰らずジョバンニが町を三つ曲がってある大きな活版所にはいって靴をぬいで上がりますと、突き当たりの大きな扉をあけました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　活版所　ジヨバンニが學校の門を出るとき、同じ組の七八人は家へ歸らずカムパネルラをまん中にして校庭の隅の櫻の木のところに集まつてゐました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へは歸らずジヨバンニが町角を三つ曲つてある大きな活版所にはいつて、靴をぬいで上りますと、突き當りの大きな扉をあけました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも親父は、私が活版所に出かけた留守のうちに、台所の窓から帯を垂らして首を引っかけたまま死んでいたのだそうで、寝床の煎餅蒲団の下には、「何事も天命です。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "中庭の側には活版所がある。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中庭の側には活版所があるのです。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の貧しい作家の勘で以てすれば、この活版所は、たしかに、そこに在ったのです。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸な事にはまだ紙型が築地の活版所から受け取って無かったので、これは災を免れた。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　勇吉は着いた翌日から、彼方此方と活版所をさがして訊いて歩いた。",
              "citation": {
                "source": "トコヨゴヨミ",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸くさがしあてた処は、場末の小さな活版所で、見積もあまり安くはないと思ったけれど、ぐずぐずしていて機会を失っては大変だと思って、勇吉は兎に角其処で印刷させることにして、その翌日すぐ原稿を持って行った。",
              "citation": {
                "source": "トコヨゴヨミ",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日して刑事が訪ねて来た時は丁度活版所から出来た暦を届けてよこして呉れたところであった。",
              "citation": {
                "source": "トコヨゴヨミ",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "よんどころなく交番所の巡査に訊くことになったが、日本橋のまん中で劇場のありかを訊くのはあまり田舎者じみていると、子供ごころにも極まりが悪く思われたので、わたしは巡査にむかって、青木活版所というのは何処ですかと訊いた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは青木輔清という人の経営している活版所で、千歳座の近所にあるということを私はかねて知っていたからであった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、巡査は「青木活版所……それは千歳座のうしろにある。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "活版所に就いて聞いたなら、先生ほど校正に嚴密なる人は他に多くないといふ證言を提供することと思ふ。",
              "citation": {
                "source": "那珂先生を憶ふ",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "この活版所に入りてここに泊り朝より夕まで業に就き、夕よりまた夜業とて活字を取扱う。",
              "citation": {
                "source": "良夜",
                "author": "饗庭篁村",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどこの清風明月の間にしばらくなりと居た者が活版所へ戻りて半夜なりとて明かさるべきにあらねば、次第に更けて人の通りの少なくなるを心待にして西へ東へと行きかえるうち、巡行の巡査の見咎むるところとなり、「御身は何の所用ありてこの橋上を徘徊さるるぞ」と問われたり。",
              "citation": {
                "source": "良夜",
                "author": "饗庭篁村",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八四八年一月、その草稿はまづドイツ文で起草され、二月二十四日のフランス革命の數週前、ロンドンの活版所に送られた。",
              "citation": {
                "source": "共産黨宣言",
                "author": "カール・マルクス",
                "note": "青空文庫"
              }
            },
            {
              "text": "「活版所は上海の某寺院であつて、支那人を使役してゐた。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の委員が十人近く、大挙して活版所へ校正に行く。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると活版所は昔からの仕来りで、来た人には茶菓を出したり、時分どきには御飯をとったりする。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった十六頁の校正に十人近くも行って、応接間はすっかり占領するし、接待はしなければならぬので、とうとう活版所で閉口して、私のところに謝りに来るようなこともあった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "南仲通りには、生糸取引所とか、米穀仲買商などが軒を並べていて、活版所はその喧騒の中にあった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
