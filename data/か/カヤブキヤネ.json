        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔ながらの集落には、趣のある茅葺き屋根の家が点在している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "雨漏りを防ぐため、茅葺き屋根の定期的な葺き替えが必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わあ、この茅葺き屋根、すごく立派だね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "茅葺き屋根の家は、夏は涼しく冬は暖かいと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "むかしの名所｜図絵や風景画を見た人はみな承知であろうが、大抵の温泉宿は茅葺き屋根であった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内者の三津子さんが前の人車に、わたくしが後の人車に乗せられて、木賃宿のようなきたない旅籠屋や茅葺き屋根の下に小さい床几を出している氷屋などがならんでいる、さびしい停車場前を横に切れて、黍畑のつづいている長い田圃みちを駈けぬけて行きました。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　長浜の村は、道路の近くの緑の崖の麓にあって、杉の木立の陰になった岩の池の周りに、全部で十二軒ばかりの茅葺き屋根の農家が散在している。",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "日当たりの悪い茅葺き屋根の家です。",
              "citation": {
                "source": "職業の苦痛",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、門の奥にある家は、――茅葺き屋根の西洋館はひっそりと硝子窓を鎖していた。",
              "citation": {
                "source": "悠々荘",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間にはいつも彼の部落が、天の安河の河原に近く、碁石のように点々と茅葺き屋根を並べていた。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の泊って居る所は竹の柱に茅葺き屋根というごく粗末な家でその向う側にもまたそんなような家があります。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の片側に、一、二軒ずつの茅葺き屋根、中には噴出しの井戸もあって御休処の小旗、埃まみれの汗を拭って井水に浸したトコロテンの一｜啜り、なんともいえぬ味があった。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人が近よってみると、やはり田舎は田舎で、街道を前に、崩れ築土の茅葺き屋根。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、少年がたちどまったのは、門こそありますが、ふるぼけた、そまつなかやぶきやねの家でした。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
