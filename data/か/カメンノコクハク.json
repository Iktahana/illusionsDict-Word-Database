        "examples": {
          "standard": [
            {
              "text": "高校生の頃、三島由紀夫の『仮面の告白』を読んで衝撃を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この小説は、主人公の少年が自己のセクシュアリティと葛藤する様子を描いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "『仮面の告白』は、戦後文学の金字塔として今なお読み継がれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "映画化もされたことがあるらしいが、原作の持つ独特の雰囲気をどこまで再現できているのだろうか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "三島由紀夫氏の「仮面の告白」だったかに、自分が生れたとき産湯を使わせられた盥の木肌を透して、まばゆい湯の揺れや金輪の光が金色に見えた、というような描写があった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
