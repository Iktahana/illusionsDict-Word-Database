        "examples": {
          "standard": [
            {
              "text": "茂山家の千五郎を中心とした上方狂言は、庶民的な親しみやすさがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "上方狂言のセリフ回しには、どこかユーモラスな響きが含まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「上方狂言のあの笑いのテンポ、いつ見ても飽きないわ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "正月の奉納行事として、地元の神社で上方狂言が披露された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "上方狂言師の巨頭、八十六歳の茂山千作が「枕物狂」を演じると聞いたボクは、これを見逃してよいものかと、昭和廿四年二月十二日の午後、金剛能楽堂へ歩を運んだ。",
              "citation": {
                "source": "枕物狂",
                "author": "川田順",
                "note": "青空文庫"
              }
            }
          ]
        }
