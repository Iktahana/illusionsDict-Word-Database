        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歳末セールは、明日から全国の各店で一斉に開催されます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "限定商品の在庫状況につきましては、お近くの各店に直接お問い合わせください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "チェーン店でありながら、駅前の店舗と郊外の店舗では、各店の判断で品揃えを変えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "本社の新しい方針を、各店の店長にオンライン会議で通達した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "各店頭の軒燈もぽつり／＼消え殘つて、眠たさうにまたたいてゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "繁栄策もいろいろ考えられているようだが、古本屋さんが各店分立で、町を固めているのもよしあし、合同して図書文房具中心の百貨店にでも固まる方が買う方も便利だが、これはできない相談かもしれない。",
              "citation": {
                "source": "神田界隈",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿司屋と客とは五分五分の勝負で、各店それぞれそれらしいのが来ている。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下一々について各店主人の持つ寿司観の長短を俎上に載せて見よう。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争前、カフェー汁粉屋その他の飲食店で、広告がわりに各店で各意匠を凝したマッチを配布したことがある。",
              "citation": {
                "source": "裸体談義",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "小売店が百貨店と対抗して商売するには、米国の連鎖店がしたように、百貨店の品を隅々までも精細に調査研究した上で、各店が連合協力して、一店毎に瀬戸物なら例えば火鉢、洋品店ならメリヤス襯衣という風に、二三種を各々奉仕販売するのも一方法である。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで各店が連合して、一店一種ないし二種の犠牲奉仕品を出すには、広告チラシも共同の物を作る。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、自動ピアノというものが、各店に設備してあり、これも五銭入れると、「ウイリアム・テル」だの「敷島行進曲」だのを奏するのであった。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫茶店のサーヴィスで、一番気に入ったのは、アマンドのチェーン、各店が、コーヒーなどの後に、コップ入りの番茶を、サーヴィスすることで、これは、後から後からと、所謂「回転」を急いで、追い立てられる感じと違って、「何卒ごゆっくり」と言われているようで気持がいい。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、各店ともに、大広間にワリ込みで、大勢の客が食ったり、飲んだりしている。",
              "citation": {
                "source": "牛鍋からすき焼へ",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
