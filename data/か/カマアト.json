        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "山の中腹で古い窯跡が見つかり、古代の生活を偲ばせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域の窯跡は、かつて陶芸が盛んだったことを示している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "発掘調査の結果、複数の窯跡が確認され、学術的価値が高いとされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ボランティアガイドが窯跡を案内し、歴史的背景を解説した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "風化した窯跡が、当時の人々の営みを静かに物語っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "刷毛目は大邱に近い鷄龍山から窯跡が發掘されたゝめ、戸籍がわかつてきた。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし墓の他には、僅かに陶器を造つた窯跡のようなものがあるくらゐで、ほとんどいふに足るものはありません。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は昭和三年、朝鮮へ古窯跡の探査と、陶器原料の蒐集の目的で渡った。",
              "citation": {
                "source": "明石鯛に優る朝鮮の鯛",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "その折、太口面（康津郡）すなわち木浦から少し手前、康津で高麗青磁の窯跡を探って、たくさんの資料を蒐集し、帰途、岩礁の多い海岸に沿って、曲浦渚汀を、順天・馬山・釜山方面へと巡遊した。",
              "citation": {
                "source": "明石鯛に優る朝鮮の鯛",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "この陶器は、瀬戸で産れていることだけは、従来から認識されて居ったが、その窯跡が発見されたのは、今から一年ばかり前（昭和五年頃）のことである。",
              "citation": {
                "source": "織部という陶器",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "その窯跡から様様な破片が出た。",
              "citation": {
                "source": "織部という陶器",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "志野の窯跡が発見されたことは珍しいことにはちがいないが、別に大したことではない。",
              "citation": {
                "source": "志野焼の価値",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾張、瀬戸だと思っていたら、なーんだ美濃だったか、そう言えば今まで瀬戸窯跡では発見されなかったようだね、これでおしまいなのである。",
              "citation": {
                "source": "志野焼の価値",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが図らずも美濃幾十の窯跡中一番古い大萱窯だったのです。",
              "citation": {
                "source": "瀬戸・美濃瀬戸発掘雑感",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "次から次へと近々の窯跡を発掘して行きました。",
              "citation": {
                "source": "瀬戸・美濃瀬戸発掘雑感",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの唐津郡各地の窯跡は今も青磁の破片で鏤められているといってよい。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "辰砂の窯跡はまだ攻究されておらぬが、恐らく開城附近に窯があったことは推測するに難くない。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一個は去年その窯跡から発掘せられた。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "産地はロンドンに近いローズンやスタフォードシヤィアであって、それらの窯跡より出る夥しい破片は昔いかに多量に生産せられたかを語る。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（近時本山氏の事業として大宅氏の試みられし発掘、または水町、金原両氏の努力によって幾多の古窯跡が明るみに出された。",
              "citation": {
                "source": "北九州の窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長与近在の窯跡から例の染附の猪口の断片が沢山出る。",
              "citation": {
                "source": "北九州の窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵高麗は元々朝鮮陶器でありまして、現に鶏竜山窯跡から様々なものが発掘されます。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "斑唐津、朝鮮唐津は朝鮮で焼けたもののように覚えている人が今でも少なくありませんが、現在唐津の岸岳古窯跡で発掘されるのを見ますと、日本で出来たことが証明されます。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "現にこの茶碗が発掘された付近数々の窯跡から現われる陶器の類、例えば志野、黄瀬戸、古瀬戸、天目、織部などいうものは一つとして醜いものはありません。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は尾張の瀬戸三十六窯と称される古代の窯跡の最初の探査発掘をしても歩いた。",
              "citation": {
                "source": "魯山人作陶百影　序",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くは美濃の久々利村の山中に志野焼の破片を見付出し、それを便りにその窯跡の探査を進め、遂に四五ヶ所の志野古窯を発見し、更に初期古織部の釉跡の発見にまで進んで、所謂古瀬戸の隠れてゐた種々相を発見した。",
              "citation": {
                "source": "魯山人作陶百影　序",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ調べた結果、この捏鉢は肥前の国庭木の産で、親しくその古窯跡を訪ねてその出所を知ることが出来た。",
              "citation": {
                "source": "京都の朝市",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し段々九州に於ける古窯跡の発掘が進むにつれ、二川より更に前に弓野あたりでも焼かれ、伝統を遡れば更に古く、何も二川のみでないことが分明になった。",
              "citation": {
                "source": "京都の朝市",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
