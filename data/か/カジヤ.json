        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大工は古くなった板を外すため、手に持った鍛冶屋を器用に扱っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "倉庫の奥から錆びついた鍛冶屋を見つけ、何十年も前の道具だと知った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "壊れた木箱の釘を抜くのに、ちょうど良い鍛冶屋を探している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
