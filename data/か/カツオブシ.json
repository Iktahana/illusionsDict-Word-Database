    "definitions": [
      {
        "index": 1,
        "gloss": "katsuobushi",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「おひたしに、削りたての鰹節をパラパラとかけるのが好き。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この鰹節、香りがすごく良くて、お味噌汁がワンランクアップした感じ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「お好み焼きのトッピングに、鰹節は欠かせないね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「鰹節って、カビ付けと燻製を繰り返して作られるんだって、知ってた？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "いくら資本主義の統治下にあって、鰹節のような役目を勤める、プロレタリアであったにしても、職業を選択する権利丈けは与えられているじゃないか。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリアは「鰹節」だ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰ってから用心に鰹節、梅干、缶詰、片栗粉などを近所へ買いにやる。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土佐の貧乏士族としての我家に伝わって来た雑煮の処方は、椀の底に芋一、二片と青菜｜一とつまみを入れた上に切餅一、二片を載せて鰹節のだし汁をかけ、そうして餅の上に花松魚を添えたものである。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また塩魚類｜鰹節の乾燥とか寒天の凍結とかいう製造方面の事柄にも物理学応用の範囲は意外に広大であるように見受けられる。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「これは、しやぼん、鰹節以上ですな。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰹節を半分に切って買うみたい。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからＴは国のみやげに鰹節をたった一本持って来たと言って笑われたこともある。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二一課　橋は流れて水は流れず　私たち鰹節をナイフで削るときには、鰹節を確と握り押えてナイフの方を動かして削ります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰹節を橋とし、ナイフを水としますと、この場合は、この章の標題とは反対の「水は流れて橋は流れず」であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、鰹節削りの鉋が出来て鰹節を削るときには、今度は鰹節の方を動かします。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合には橋に譬えた鰹節の方を動かし、水に譬える鉋は動かさないのですから、「橋は流れて水は流れず」です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰹節を削るのには必ず鰹節を握り押えて削るもの、すなわち「水は流れて橋は流れず」の一方ばかりの考え方に凝り固まっている人は、折角鰹節削りの鉋箱が出来ても、どこまでも鰹節の方を動かしてはならぬものとして、鉋箱を逆にして鰹節に宛てがうでしょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし鰹節と鉋の関係の融通ぐらいは、簡単なことですから誰でも無意識に自然にやっていて、別に大した考えを費さなくとも済みます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘定すれば一銭も差引無し、こちとらは鰹節で、お前様方が旨え汁を吸うといったようなものだ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "處で、その、お差支のなさを裏がきするため、豫て知合ではあるし、綴蓋の喜多の家内が、折からきれめの鰹節を※へ買出しに行くついでに、その姉さんの家へ立寄つて、同行三人の日取をきめた。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はははは、お言葉には及びません、饂飩屋さんで泊めるものは、醤油の雨宿りか、鰹節の行者だろう。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰹節を削りつゝ、それを贈つてくれた友の心を感じる、桂子さん、ありがたう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "君ニ逢ウタラ鰹節一本贈ルナドトイウテ居タガ、モーソンナ者ハ食ウテシマッテアルマイ。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち鱠には大根を卸しにし、煮物には大根を輪切にしたものを鰹節で煮てこれに宛てた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "卵味噌のカヤキといふのは、その貝の鍋を使ひ、味噌に鰹節をけづつて入れて煮て、それに鶏卵を落して食べる原始的な料理であるが、実は、これは病人の食べるものなのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「下の抽斗に鰹節があるから。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやにねこめが必死とくわえていたようでしたが、まさかにかつおぶしでこしれえた髪の毛じゃござんすまいね」「またとんきょう口を始めやがった。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも、ご先祖代代日本橋のほうでね、手広くかつおぶし問屋をやっていたんだそうなが、なんのたたりか、代代キ印の絶えねえ脳病もちの血統があるというんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、出来上がった料理にかけるため、かつおぶしをけずる。",
              "citation": {
                "source": "カンナとオンナ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人も、上等のカンナでかつおぶしをけずるわたしを不思議そうにみている。",
              "citation": {
                "source": "カンナとオンナ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、そんな立派なカンナなら、なにも、かつおぶしをおけずりにならなくとも、立派に、大工道具につかえるではありませんか」「大工道具に、立派に使えるほどの上等だから、かつおぶしがけずれるんだよ」　しばらくわたしの手許を見ていた詩人はつくづくといった。",
              "citation": {
                "source": "カンナとオンナ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと、そうですよ、やっぱり、料理は、金をかけないとダメですね」　わたしはだまって、かつおぶしをかき了ると、一杯ビールを飲みほして、しゃべり出していた。",
              "citation": {
                "source": "カンナとオンナ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「およそ反対だね、君のいうことは……詩人には、金のねうちは分らんと見える」　わたしは、かきあげたかつおぶしを詩人に見せた。",
              "citation": {
                "source": "カンナとオンナ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつおぶしは、うすい、うすい雁皮のように、湯上がりの乙女の肌のように……。",
              "citation": {
                "source": "カンナとオンナ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
