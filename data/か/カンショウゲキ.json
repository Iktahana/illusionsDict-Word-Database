        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔のメロドラマって、見てるといつも感傷劇になりがちだよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の書く脚本は、登場人物の心の機微を丁寧に描いた感傷劇が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日テレビでやっていた時代劇は、涙なしには見られない感傷劇だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの監督の作品はいつも、甘く切ない感傷劇で観客を魅了する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それを、彼が、いつぞや動坂の親達に示した感傷劇の涙で、伸子に強い感銘を与えてしまった。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
