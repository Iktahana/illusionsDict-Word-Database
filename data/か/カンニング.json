    "definitions": [
      {
        "index": 1,
        "gloss": "cheating (on an examination)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
