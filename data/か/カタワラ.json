          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の傍らにはいつも愛犬が寄り添い、どんな時も彼を癒していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "静かな湖の傍らで、彼は時間を忘れて読書に耽っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "食卓の傍らに置かれた花瓶には、季節の花が美しく生けられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "然しもし此の新体詩様式の困難が、次第に征服されてゆけば、其処に始めて詩歌は「生活の傍ら的なもの」から、「その中で生活の出来る詩歌」に迄到達することだと思ふ。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもいいが、外にも少し立派に衣食の得らるるような事を修めて、傍ら自分の慰み半分絵をかく事にしたらどうか。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし読物には事を欠かなくてマクスウェルの電磁気論（一八六五）や、マクスウェル及びヘルムホルツの色の研究、それからストークスやウィリアム・タムソンの主要な論文を読み、傍らまたミルの論理学や経済論を読んでいた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年生のときにＮ先生の研究の手伝いの傍らそれに縁のあるミラージに関する色々の実験をしたことも生涯忘れられぬ喜びであった。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、その傍らにいつも坐つて、一人の婦人が、俯向いたまま、身じろぎもせず、物靜かな様子で、縫ひ物をしつづけてゐた窓。",
              "citation": {
                "source": "窓",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自分の傍らに、雜誌で一ぱいになつた箱を持ち出し、そしてロダンに關する、印のついてゐる箇處を讀んでゐました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私はなほも暫らく、急勾配な屋根のある家々だの、その傍らに聳えてゐる御堂だのを眺めてゐました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしかは二週間ばかり夜も眠むらずに清三の傍らについていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の傍らには小さな字があって、そこから射して来る光が、道の上に押し被さった竹藪を白く光らせている。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光浴をするとき私の傍らに彼らを見るのは私の日課のようになってしまっていた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍らには彼の棲んでいる部屋がある。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "径の傍らには種々の実生や蘚苔、羊歯の類がはえていた。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずんずんずんずんと道を下りる、傍らの叢から、のさのさと出たのは蟇で。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも婦人の前、蝸牛が城を明け渡したようで、口を利くさえ、まして手足のあがきも出来ず、背中を円くして、膝を合せて、縮かまると、婦人は脱がした法衣を傍らの枝へふわりとかけた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は日本屈指の大新聞、東都日報の外交部につとめる傍ら、本郷｜西片町の小さな活版屋で、家庭週報という四｜頁新聞を、毎日曜｜毎に発行していた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂山が急に崩げて草の根で僅にそれを支え、其下が崕のようになって居る、其｜根方に座って両足を投げ出すと、背は後の砂山に靠れ、右の臂は傍らの小高いところに懸り、恰度ソハに倚ったようで、真に心持の佳い場処である。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして水の底をじっと見て、もう傍らに人あるを忘れたようである。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "礫多き路に沿いたる井戸の傍らに少女あり。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍らを見ると叔父さんは酒がまわったか銅色の顔を日の方に向けたままグウグウといびきをかいていた。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾個かの皿すでに洗いおわりて傍らに重ね、今しも洗う大皿は特に心を用うるさまに見ゆるは雪白なるに藍色の縁とりし品なり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年が落とせし楓の葉、流れて少女の手もと近く漂いゆくを、少女見てしばし流れ去るを打ちまもりしが急に手を伸ばして摘まみ、皿にのせて傍らに置きぬ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は身を起こしてしばし林の中をたどりしが、直ちに路にはいでず、路に近けれど人目に隠るる流れの傍らにいでたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生｜葎ではございますが、庭も少々、裏が山｜続で風も佳、市にも隔って気楽でもございますから御保養かたがたと、たって勧めてくれたのが、同じ教子の内に頭角を抜いて、代稽古も勤まった力松という、すなわちお雪の兄で、傍ら家計を支えながら学問をしていたが、適齢に合格して金沢の兵営に入ったのは去年の十月。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　自動車の助手に、松の枝を折らせ、掃立てさせた傍ら、柄杓を取って、パッパッと水を打つついでに、頭ともいわず肩ともいわず、二人に浴びせかけたのは、銅像の製作家、東京がえりの長髪の運五郎氏で、閣翁運八とともに、自動車で駆上って来た事は更めて言うに及ぶまい。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、大野ともいわず、九郎兵衛とも名乗らず、単に遊謙と称する一個の僧となって、小さい草堂を作って朝夕に経を読み、傍らには村の子供たちを集めて読み書きを指南していた。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "角川の家は代々の郷士で、傍らに材木｜伐出しの業を営んでいたので、家の雇人等も木挽の職人と一所に山奥へ入ることが屡々ある。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とかして彼等を撃退する工夫はあるまいかと、市郎も苦し紛れに種々考えていると、わが傍らにひらりと飛んで来た者があるらしい。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "其傍らには、彼の運命を象徴するような紅い椿の花が、地に落ちて砕けていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑顔は芝の涌泉堂という本屋の主人で、傍らに著作の筆を執っていたが、何か一つ当り物をこしらえようと考えた末に、かの鬼武の「自来也物語」から思いついて、蝦蟇の妖術、大蛇の怪異という角書をつけて「児雷也豪傑｜譚」という草双紙を芝神明前の和泉屋から出すと、これが果して大当りに当った。",
              "citation": {
                "source": "自来也の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、傍ら譯の分らぬものを書いて居た。",
              "citation": {
                "source": "自傳",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
