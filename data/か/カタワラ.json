        "examples": {
          "standard": [
            {
              "text": "会社勤めの傍ら、夜間に専門学校へ通い資格の勉強に励んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "趣味の陶芸の傍ら、地域の子どもたちに教えるボランティア活動もしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "育児の傍ら、在宅でフリーランスの仕事を続ける母親が最近増えているようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
