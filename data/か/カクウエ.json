        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "トーナメントの初戦で、優勝候補の格上チームと対戦することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は格上の相手にも臆することなく、堂々としたプレーで観客を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "たまの贅沢に、いつもより少し格上のワインを開けて楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "平幕力士が格上の横綱から金星を挙げ、会場は座布団が舞うほどの興奮に包まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "人間の自由平等といふことは、社會的や制度的には眞理であるか知らないが、人格上には決して有り得ない。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは人間の精神の力としては人に向っていちばん胸の奥に響き、骨の髄を揺がす機能を持っているものゝように思うが、それが不思議とあんたに於てはそのまゝ性格上には出ていない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＸＨＴＭＬ版の仕様固めを検討したチームは、用意されているタグを組み合わせるなどして、テキスト版に書き込まれた組み版要素をできるだけＸＨＴＭＬ版に移し替えるよう努め、どうしても表現できない圏点や一部の傍線に関しては、強調表示に置き換えた上で、規格上利用することを許されているコメント欄に、「点か、丸か。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｆ君はそれを一々語格上から分析せずには置かない。",
              "citation": {
                "source": "二人の友",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんな人格上の言葉になる。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "人格上の言葉に翻訳することのできないものには、自然が毫も人格上の感化を与えていない」　三四郎はまだあとがあるかと思って、黙って聞いていた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いやしくも人格上の言葉に翻訳のできるかぎりは、その翻訳から生ずる感化の範囲を広くして、自己の個性を全からしむるために、なるべく多くの美しい女性に接触しなければならない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし当時の単位は依然として大隊であり、傭兵の性格上極力大隊長の号令下にある動作を要求したのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして僕が社会主義者になってもう二、三度入獄していることについても、困ったものだがしかし君の性格上仕方があるまいというようなことを言って、礼ちゃんはそれに「ええ、あんまりできすぎるからだわ」と弁解して附け加えていた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "性格上のたたかいは、しばしば、神の恵みと強い忍耐深い祈りのないときには、古来の偉人たちにおいても絶望に終わるほかはなかったほど fatal なもののごとくに見えます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して水杵の図が格上に貼つてあつて、方言どつたりと記してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "又古鈔零本玉篇一本辺格上短下長、（延喜式図書令の度なり）その裏を装修せしも古鈔本の仏経なり。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この様子では己はまだ大いに性格上の修養をしなくてはならない。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こりゃあもう事業部に格上げして、逃げられないようにした方がいいんじゃないか」　小林はだめを押した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがＰＣ―８００１の周りで何が起こりつつあるかを認識した小林は、「もう専門の事業部に格上げして、ここから逃げられないようにしたほうがいいんじゃないか」と大内の決断を促した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "又は四十を越した彼の体質から来た性格上の変化であったかも知れないが、いずれにしても今度の脱獄後の彼の手口は、まるで今までとは別人のように残虐な、無鉄砲なものに変形していた。",
              "citation": {
                "source": "白菊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "教唆は精神的関係、即ち脅迫して承諾させ、口説いて同意をさせたものを含むのであるゆえ、鎌子がさきに線路に飛込み、倉持がその後を追っているから地位資格上倉持はむしろ殉死したのだ。",
              "citation": {
                "source": "芳川鎌子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "無意識　我我の性格上の特色は、――少くとも最も著しい特色は我我の意識を超越している。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、一定の階級の社会上の優越がその階級の思想の性格上の優越を規定する。",
              "citation": {
                "source": "危機における理論的意識",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はまだ淺學のせゐか、或は性格上、鎌倉以後の文學にはどうも同情がもてませぬせゐか、どうもさういふ本來の意味でトラヂックな人物は鎌倉以後の文學には到底見出し得ないのではないかと思ふのです。",
              "citation": {
                "source": "若菜の卷など",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドノバン君、こんなことは遊戯だからどうでもいいけれども、しかしカンニングで勝ったと思われては人格上の問題になるから、それだけは弁明しておくよ、僕はけっしてラインをわらなかったよ」「いやわった」「ではくつのあとと白墨の線とを見てくれたまえ」「そんなものは見んでもわかってる、きみは卑劣だよ」「卑劣？",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十幾年求めて与えられなかった性格上の饑が津々と迫る力に充たされて来る。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "知識上のことはいうまでもなく、その身体のうえにおいてさえも、近時、男子の体格上に起こる変動よりも、女子の体格に起こる変動が多い。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "総じて松王は品格上々にて貫目も充分にあり、応ふるところも応へたれど、慾をいへば調子がどす一てん張なるため、やや変化に乏きを憾とす。",
              "citation": {
                "source": "両座の「山門」評",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "人格上の言葉に翻訳する事の出来ない輩には、自然が毫も人格上の感化を与へてゐない」　三四郎はまだあとが有るかと思つて、黙つて聞いてゐた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――苟しくも人格上の言葉に翻訳の出来る限りは、其翻訳から生ずる感化の範囲を広くして、自己の個性を完からしむる為に、なるべく多くの美しい女性に接触しなければならない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
