[
  {
    "uuid": "1494cdb9-fdbc-58b3-954c-5c6ed49e44ba",
    "entry": "掛け軸",
    "reading": {
      "primary": "かけじく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
