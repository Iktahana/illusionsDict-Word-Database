[
  {
    "uuid": "4aed639f-d0a7-532a-9c2c-f1e92439bae8",
    "entry": "肩車",
    "reading": {
      "primary": "かたぐるま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
