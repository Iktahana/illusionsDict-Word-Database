        "examples": {
          "standard": [
            {
              "text": "学生時代の溜まり場では、点棒がそのまま現金に換わる賭け麻雀が日常茶飯事だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「遊びの範囲内だよ」と言い訳しても、法律上は賭け麻雀であることに変わりはない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昨日の賭け麻雀で負けが込んで、今月はもう昼飯代も残っていないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "あの雀荘、裏でかなり高レートの賭け麻雀をさせてるって噂だけど、摘発されないのかな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "だから素人が知らない人と賭け麻雀などはするものではない。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
