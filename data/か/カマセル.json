[
  {
    "uuid": "10f90757-b73c-5224-8e6e-ccb536b2df8a",
    "entry": "噛ませる",
    "reading": {
      "primary": "かませる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
