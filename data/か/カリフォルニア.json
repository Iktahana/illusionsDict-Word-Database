          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "冬の寒さを避けて、多くの観光客が暖かいカリフォルニアを訪れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は夢を追いかけ、生まれ育った東海岸からカリフォルニアへ移住した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カリフォルニアの夕日は本当に美しくて、感動するんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "IT産業が盛んなカリフォルニアには、世界中から技術者が集まってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "当時の土佐と熊本とでは、心理的には今の日本とカリフォルニアくらいのへだたりがあったのである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから三年の後、スティヴンスンは、其の時カリフォルニアに帰っていたファニイの後を追うて、大西洋を渡った。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分カリフォルニアの或る町で――実際に私の経験したことだが…………ハッと気がつく。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファニイの後を追うてカリフォルニア迄渡って来、極度の貧困と極度の衰弱との中に、友人や肉親との交通も一切断たれたまま・桑港の貧民窟の下宿に呻吟していた時のことだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃ちょうどカリフォルニアでは黄金熱が盛んで、この選民の街がちょうど通過点に当たっていたのだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "カリフォルニアの開拓者だったから、面白い話には事欠かなかった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "金銭の外を知らずと嘲らるる米国人すら、カリフォルニアの巨柏など抜群の注意して保存しおり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に戻ったわけではなく、カリフォルニアからかけてくれていると言います。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビル・トッテン、一九四一年カリフォルニア州ロングビーチ生まれ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "カリフォルニア州立大学卒業後、ロックウェル社でアポロ計画に携わった彼は、一九六七年、大型コンピューター用ソフトの受託開発を行なっていたＳＤＣ社に入社。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "たくさんの方言の生まれたＵＮＩＸの中で、本家のＡＴ＆ＴのシステムＶとカリフォルニア大学バークレー校で育ったＢＳＤは二大勢力となっていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてカリフォルニア大学バークレー校でＵＮＩＸのお守りに携わっていたビル・ジョイに頼み、このマシンにＵＮＩＸをのせる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "数多くの方言が生まれていたＵＮＩＸに関しては、カリフォルニア大学バークレー校のＢＳＤと本家であるＡＴ＆ＴのシステムＶ、さらにマイクロソフトがパーソナルコンピューター用に開発していたＸＥＮＩＸを統合して決定版を作る。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争前までは、カリフォルニアの農園で洗濯屋をやっていたおやじなんだ。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここに、カリフォルニアの片田舎に、ひとりの少年がありました。",
              "citation": {
                "source": "街の子",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘール（Hale）とその共同研究者等は、カリフォルニアのウィルソン山で金属のスペクトルを研究したが、それには一一〇ボルトの電圧で二アンペアと三〇アンペアと二通りの電流を通じた弧光の中でこれら金属を気化させた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カリフォルニアの石油は広いが浅いのです。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間ソ同盟の飛行機が北極を通過して一気に一万六百キロ翔んでカリフォルニアのサンジャシント飛行場へ着陸し、六十二時間九分で、北極経由モスクワ・北米間の「スターリン空路」を確立したことがあった。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、「怒りの葡萄」の中でスタインベックは、カリフォルニアの果樹園とそのまわりにあぶれている季節労働者――土地をとられた農民の群の有様を描いている。",
              "citation": {
                "source": "心に疼く欲求がある",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊饒なカリフォルニアの果樹園で、市価がやすいために収穫がのばされている。",
              "citation": {
                "source": "心に疼く欲求がある",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君たち、どこへ行くの」「カリフォルニアからニューヨークの方へ」「えっ、カリフォルニアからニューヨークの方へ。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月八日の午後、カリフォルニア州サン・マリノ町であき地に遊んでいたケティという三つの女の児が、草むらにかくれていた古井戸へおっこちた。",
              "citation": {
                "source": "鬼畜の言葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六四（昭和三十九）年にカリフォルニア大学のバークレー校で始まり、六〇年代後半の世界的な学生運動の源流となったフリースピーチ運動。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブッシュの思い描いたメメックスのようなシステムを作りたいと考えた彼は、ＮＡＣＡをやめてカリフォルニア大学バークレー校の大学院に入り、コンピューターと対話するように作業を進めるためのソフトウエアの研究に取り組んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "カリフォルニア州のバークレーに住む建築業者スティーブ・ドンピアは、もっとも早い時期にアルテアを手に入れた一人だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "カリフォルニアに移り住んだ彼は、マイクロコンピューターを使ったシステムに興味を持ち、ホビイストのグループに加わるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "開発チームのスタッフはアメリカ大陸を東から西へと飛んで、カリフォルニア州モントレーのデジタルリサーチと、ワシントン州ベルビューのマイクロソフトを訪れた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも西は、六月にカリフォルニア州アナハイムで開催される全米コンピューター会議（ＮＣＣ★）で会う約束を取り付けてから、ようやく受話器を置いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
