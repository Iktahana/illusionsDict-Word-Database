        "examples": {
          "standard": [
            {
              "text": "近隣の養鶏場で家禽コレラの発生が確認され、厳重な防疫態勢が敷かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "獣医師は、死亡した鶏の病理解剖を行い、家禽コレラが死因だと断定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "家禽コレラの蔓延を防ぐため、農場への関係者以外の立ち入りが禁止された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は牧畜業者に莫大な損失を与える家禽コレラと脾脱疽の２種類の動物疫病を研究した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "家禽コレラでも桿菌が発見され人工的に培養され健康な鳥に接種して致死的な病気を起こさせていた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は家禽コレラ、脾脱疽、ブタコレラに対抗するのに必要なワクチンを製造して牧畜業者を多大な損害から救った。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
