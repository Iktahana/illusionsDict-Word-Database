    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to return",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ただいま！」「お、やっと帰ってきたか。ご飯できてるぞ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "長い海外出張を終え、ようやく日本の土を踏んで帰ってきたと実感した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "数日前に家を飛び出した飼い猫が、お腹を空かせて帰ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は「必ず帰ってくる」という約束を残して、故郷を旅立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "ぼくお父さんはきっと間もなく帰ってくると思ふよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう涼しいからね」　ジョバンニは立って窓をしめお皿やパンの袋を片附けると勢よく靴をはいて「では一時間半で帰ってくるよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が余念なく話をしながら帰ってくると、背戸口の四つ目垣の外にお増がぼんやり立って、こっちを見て居る。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるたけ日の暮れない内に帰ってくる様によ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし日暮までには民子も帰ってくることと思いながら、おろおろして待って居る。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに政夫は学校へ行ったんじゃないか、暮には帰ってくるよ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし汽車に乗って丸亀や坂出の方へ行き一日歩きくたぶれて夕方汽船で小豆島へ帰ってくると、やっぱり安息はここにあるという気がしてくる。",
              "citation": {
                "source": "四季とその折々",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "華府を根拠にしてマウント・ウェザーの気象台などを見物して、帰ってくると非常な暑さで道路のアスファルトは飴のようになり、馬が何頭倒れたといううわさである。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇三郎もその内会に顔を出して、夜なかに家へ帰ってくると、表には変な奴が覗いている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃は七之助が商売から帰ってくる時に、その盤台にかならず幾｜尾かの魚が残っているのを、近所の人達が不思議に思った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとの座敷へ帰ってくると、いつの間にか其処には寝床が延べられて、雁金を繍った真っ白な蚊帳が涼しそうに吊ってあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方になると、ゆうべの通りに湯殿へ案内されて、帰ってくると今夜は別の着物に着かえさせられた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は自分のあとを嗣がせるつもりで、子供のときから一生懸命に長唄を仕込んだが、お俊は肩揚げの下りないうちから男狂いをはじめて、母をさんざん泣かせた挙句に、深川の実家を飛び出して、上州から信州越後を旅芸者でながれ渡って、二、三年前に久し振りで江戸に帰ってくると、深川の母はもう死んでいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "前線から帰ってくる将校斥候はロシヤ人や、ロシアの大砲を見てきたような話をした。",
              "citation": {
                "source": "チチハルまで",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、それぞれ試験がすんで帰ってくる坊っちゃん達を迎えに行っている庄屋の下婢や、醤油屋の奥さんや、呉服屋の若旦那やの眼につかぬように、停車場の外に立って息子を待っていた。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくお父さんはきっと間もなく帰ってくると思うよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "池から家へ帰ってくると、三人はこころもからだも、くたくたにつかれてしまったので、ふじだなの下の縁台に、おなかをぺこんとへこませて、腰かけていました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "松吉と杉作が、土曜の午後に、学校から帰ってくると、そのお餅を、町の克巳の家にくばっていくことになりました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三河にもらわれていったって、いつかまた帰ってくることもあるでしょう。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、おとなの世界にはいった人が、もう子どもの世界に帰ってくることはないのです。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくお父さんはきっとまもなく帰ってくると思うよ」「ああ、あたしもそう思う。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう涼しいからね」　ジョバンニは立って窓をしめ、お皿やパンの袋をかたづけると勢いよく靴をはいて、「では一時間｜半で帰ってくるよ」と言いながら暗い戸口を出ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "行きには人と犬との足跡のついた同じ道を帰りはただ人だけが帰ってくるのである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕はたぶん明日｜親父に会いに千歳まで帰ってくる。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブドリのおとうさんもおかあさんも、たびたび薪を野原のほうへ持って行ったり、冬になってからは何べんも大きな木を町へそりで運んだりしたのでしたが、いつもがっかりしたようにして、わずかの麦の粉などもって帰ってくるのでした。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてたびたび心配そうに相談しては、かわるがわる町へ出て行って、やっとすこしばかりの黍の粒など持って帰ることもあれば、なんにも持たずに顔いろを悪くして帰ってくることもありました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿のように疲れきって牢屋に帰ってくると、名主や役附の者どもは彼の剛胆を褒めそやして、総がかりで介抱してやった。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯を食ってしまって近所の銭湯へ行って帰ってくると、今夜の月はあざやかに昇っていた。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は昼のうち少し晴れたので、僕は宮の下の町まで買物ながら散歩に出て、一時間ほどもうろ付いて帰ってくると、その途中から霧のような細かい雨がまたしとしとと降り出して来て、夜になっても止みそうもない。",
              "citation": {
                "source": "河鹿",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声が軽い木魂となって山から林からかえってくる。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
