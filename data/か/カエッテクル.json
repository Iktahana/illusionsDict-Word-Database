[
  {
    "uuid": "0b36b930-7367-5057-b900-912fda10cb16",
    "entry": "帰ってくる",
    "reading": {
      "primary": "かえってくる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-来る"
      ],
      "ctype": null,
