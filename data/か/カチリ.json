    "definitions": [
      {
        "index": 1,
        "gloss": "with a clink (click, clack)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "鍵がドアの鍵穴に「かちり」と音を立ててはまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女が小さな箱の蓋を「かちり」と閉めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "安全ベルトが「かちり」と固定され、出発の準備が整った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "時計の針が「かちり」と次の時刻に進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "薄霧北の山の根に消えやらず、柿の実｜撒砂にかちりと音して宿夢拭うがごとくにさめたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ほんとに大丈夫だらうね‥‥‥』と、消毒著に著換へた私が其處に這入つて手術臺に面した窓際に立つた時、メスの刄を調べてゐた水島はかちりとそれを硝子臺の上に置いて、また低い聲でかう私に耳打ちした。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と件の桶を小脇に抱えて、縁側から、藁草履を穿いて出たが、屈んで板縁の下を覗いて、引出したのは一足の古｜下駄で、かちりと合して埃を払いて揃えてくれた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "首尾よく、かちりと銜えてな、スポンと中庭を抜けたは可かったが、虹の目玉と云う件の代ものはどうだ、歯も立たぬ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の刀は金属によってかちりと受け止められた。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と件の桶を小脇に抱へて、椽側から、藁草履を穿いて出たが、屈んで板椽の下を覗いて、引出したのは一｜足の古下駄で、かちりと合はして埃を払いて揃へて呉れた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっという掛声と共に少女の鼻端の白土は飛び壁に当ってかちりと床に落ちた。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉生は吸殻を吹きだして、かちりと音をさして煙管を置く。",
              "citation": {
                "source": "涼亭",
                "author": "――序に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹腰は驚いて横に刀を払ったが、払った拍子に己の刀が眼に見えない金属に触れてかちりと鳴った。",
              "citation": {
                "source": "赤い土の壺",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "首尾よく、かちりと銜へてな、スポンと中庭を抜けたは可かつたが、虹の目玉と云ふ件の代ものは何うだ、歯も立たぬ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から、からからと後歯の跫音、裏口ではたと留んで、「おや、また寝そべってるよ、図々しい、」　叱言は犬か、盗人猫か、勝手口の戸をあけて、ぴッしゃりと蓮葉にしめたが、浅間だから直にもう鉄瓶をかちりといわせて、障子の内に女の気勢。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊女は気がせいたか、少し狙がはずれた処へ、その胸に伏せて、うつむいていなすった、鏡で、かちりとその、剃刀の刃が留まったとの。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お若は我を忘れたように、じっとおさえたまま身を震わして、しがみつくようにするトタンに、かちりと音して、爪先へ冷りと中り、総身に針を刺されたように慄と寒気を覚えたのを、と見ると一｜挺の剃刀であった。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのはずみに掴まれた帯はゆるんで、帯に挟んでいたらしい何物かがかちりと地に落ちた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "木枕に押しつけていた耳が痛むので、かれは頭をあげて匍匐いながら、枕もとの煙草入れを引きよせて先ず一服すおうとするときに、部屋の外の廊下で微かにかちりかちりという音がきこえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも遲くなりました」　と僕がいふとぱた／＼と急いで足音をさせてかちりと掛金を外してがらりと雨戸を開けてくれた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜半に至って、彼が絵筆を地になげうつ音がかちりときこえた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "池北偶談",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………科人にしたもわたしから、さぞにくかろう　　　　お腹もたとう…………思ひせまつて梅川は、袖をだいてよろ／＼よろ、私の方へよろめいて、はつと踏みとまつて、手をあげた時、白い指がかちりと鳴つたのです。",
              "citation": {
                "source": "桜さく島",
                "author": "見知らぬ世界",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが何だかおかしいばかりでなく、その蝋燭があんまり重いので、夫婦が不思議がって眺めているうちに、どっちの粗相だか土間に落として、そこにある石にかちりとあたると、蝋は砕けて芯が出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学者は冷たい眼でじろり隣席の軍鶏を睨み／＼してゐたが、黙つて懐中から金貨を一つ取り出して、かちりと卓子の上に置いた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今頭髪を撫でつける」と、内隠しからポケット櫛を取り出して悠々と髪を分け直して、「後に残るものだからな、出来る丈け好い男に撮って呉れ」　かちりと、カメラが鳴った。",
              "citation": {
                "source": "土から手が",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだな、なんだな」と、おじいさんはいいながら、くわを入れてみますと、かちりと音がして、穴のそこできらきら光るものがありました。",
              "citation": {
                "source": "花咲かじじい",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云うと、かなり興奮の強い手もとでコップをかちりと矢代のに合せた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かちりと固く卷かれた新しい煙草に火をつける學生の身分が羨ましくて仕方がない。",
              "citation": {
                "source": "なぐさめ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙管を咥え、かちりと打った石の火がぼッと赤らんだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると向うのくら闇に、かちりと懸金を下す音がした。",
              "citation": {
                "source": "好色",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ライターをかちりといわせて、焔を煙草の先に近づけた。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "網は空間に花火のように開いて、蠅男の頭上からバッサリ落ち掛ったが、蠅男もさるもの、不意を打たれながらもツツーッと身を引けば、網はかちりと蠅男の左腕の中に仕込まれた機関銃に絡み付いた。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず食事をしたまえ」　といって、自分はポケットから煙草をだしてライターでかちりと火をつけた。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
