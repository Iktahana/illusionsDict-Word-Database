[
  {
    "uuid": "3269999a-9456-59c2-896d-69d71f3ddd0c",
    "entry": "感覚",
    "reading": {
      "primary": "かんかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
