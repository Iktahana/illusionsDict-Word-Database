        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「名字と名前の間に全角の間隔を入れちゃうとエラーになるから、必ず半角スペースを使ってね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「読みやすくするために、単語と単語の間に少し間隔を空けておいたからチェックしてみて」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
