        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "厄除けのため、形代に自分の穢れを移して川に流した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "神事では、参列者が息を吹きかけた形代が焚き上げられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大祓の儀式で使う形代は、人の形をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
