        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "会社の飲み会では、いつも彼が担ぎ屋になって場を盛り上げてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "誕生日のサプライズで、友人が担ぎ屋として一芝居打ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は昔から担ぎ屋で、人の反応を見るのが好きなんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "peddler",
        "register": "standard",
