[
  {
    "uuid": "1fed08ce-41f8-5715-bc53-b3475f6b3d12",
    "entry": "会を催す",
    "reading": {
      "primary": "かいをもよおす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-サ行"
      ],
