      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to hold a meeting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "来月、同窓会を催すことになったので、幹事として準備を進めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は地域の活性化のために、定期的に交流会を催している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "創立記念として、盛大なパーティーを催す予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「来週、重要な会議を催すから、資料準備を頼むよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この夜はあたかも嫩会の若き人々わが家にあつまりて劇談会を催す例会の夕なりしかば、通知するまでもなく皆々来りあつまる。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "○六月十七日、歌舞伎座にてコッホ博士歓迎観劇会を催す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後九時から甲板で舞踏会を催すという掲示が出た。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "革命児ダイナブックの背後に潜む目玉パワーの真実　パーソナルコンピューター業界の関係者を集めて勝ち抜きにらめっこ大会を催す企画は、どう考えてみても魅力に乏しい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は山の手の同好者をあつめて「絵馬の会」というのを組織し、自分がその胆煎となって毎年の春秋二季に大会を催すことにした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかに桜田浪士の追悼会を催すわけでもあるまい。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雛祭りの夜に怪談会を催すも変っているが、その聴き手には三本足の金華将軍が控えているなどは、いよいよ奇抜である。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてかれは、ホーテンスとドレゴとを、自分の部屋に招待して、晩餐会を催すことにした。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "合宿では月々一夜を選んで選手の休養かた／″＼、彼等の父兄や友達を招いで茶話会を催すのが例だつたが、この二三回この方日報社にとゞく戦争の実写映画と幻灯とを映写した。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日のこと、某は当時の大宗匠千利休を招いて、茶会を催すこととなりました。",
              "citation": {
                "source": "利休と遠州",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩九時に、学校時代の友人たちと日比谷のＳ楼で懇親会を催すことになっていたので、省線電車で駆けつけたのであります。",
              "citation": {
                "source": "玉振時計の秘密",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟子を二十人あまりかかえているうえに、学校の講師をも兼ね、尚そのうえに若艸会では春秋の二季に音楽会を催すことが例となっているから、奥住女史の生活はずいぶんと多忙であった。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、いいさ、それじゃあ僕が一つアカーキイ・アカーキエウィッチに代って夜会を催すことにするから、どうか今晩、お茶を飲みにやって来て下さい。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく女たちも新らしい地方総督の赴任を話題にして、総督がどんな舞踏会を催すだろうなどと、いろいろ取沙汰をしながら、相も変らず、衣裳につけるレースや縫附飾のことであれやこれやと心をくだいていたのに違いない。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だしきは未成年の男子と同じく、政治に関する演説及び集会を催すことすら禁じられております。",
              "citation": {
                "source": "選挙に対する婦人の希望",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "加藤しづえは、ヘッドコーターへ行って、こんな貧弱な法律はひどいから、もうすこしましにしろと云ったところ、では厚生省に、そのための委員会を催すよう、サジェストすると云ったがちっとも召集して来ない。",
              "citation": {
                "source": "往復帖",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　陣中の芝居　明治三十八年五月四日の午後、阿吉牛堡に駐っていた、第×軍司令部では、午前に招魂祭を行った後、余興の演芸会を催す事になった。",
              "citation": {
                "source": "将軍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜俄かに西田、加藤、渡邊三君を促し集めて短歌会を催すことにしたが、折柄来合せた高井覺太郎君の招かるままに、老虎灘途上の山の手にある同君の別宅に会し、晩※の饗を受けて夜更くるまで筆を執り、吟興の尽くるを知らなかつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長は教員室へ出かけて、今年は運動会の代りに極く内輪の生徒の成績品展覧会を催すことの相談をはじめた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は来月二十四日に、アルバート・ホールで音楽会を催すのですが、それに是非御出演下さい。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "天元社は終戦直後に出来た出版社で、気勢を揚げるために、主要な関係者や執筆者を招き、社員一同で、ちょっとした宴会を催すことになっていた。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はまた自分の邸で宴会を催す場合にも、非常に厳格な礼儀を固守していた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "スペードの女王",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二）　同じ本の中の「食卓の十三人」も面白い、青年時代から多くの女を愛した狂紳士が山荘に孤独な生活をしてその女達を思い出し、ある夜十三人の宴会を催す、風が吹いて戸がきしむたびに新しい客が来るけはいがする、主人は立っていちいち別の婦人の名を呼び挨拶するという筋である。",
              "citation": {
                "source": "ダンセニーの脚本及短篇",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだみなさんのご記憶にありましょうが、左団次の自由劇場以来、われわれの仲間で翻訳劇の私演会を催すことが流行し、近衛秀麿や三島章道や土方与志などの「芽生座」がまずトップを切りましたが、大正の終りごろになると、フランスのアヴァン・ギャルド運動に刺戟されてまた新しく勢いをもりかえしてきました。",
              "citation": {
                "source": "ハムレット",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人で揃って、林さんへ御年始に行こまいかや」　温泉場の徒然に、誰が発起するともなく新年宴会を催すことに成った。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　然し現在のキリスト教なるものは、多くは世界の資本家の涙金から同盟を作り、大会を催す――換言すれば、経済的に資本主義者に寄食しているものだ。",
              "citation": {
                "source": "反キリスト教運動",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "教会へあつまる子供らの画には、それぞれ特色があり、個性があらわれていたので、教会では、それらの作品をあつめて、一｜般にしめす展覧会を催すことになりました。",
              "citation": {
                "source": "天女とお化け",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "四日朝、札幌発、日高浦河につき座談会を催す。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
