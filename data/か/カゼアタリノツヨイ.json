        "examples": {
          "standard": [
            {
              "text": "山頂に近づくにつれて、風当たりの強い岩場が増え、足元が不安定になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海岸沿いのこの家は、風当たりの強い日には窓がガタガタと鳴る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬の日本海は、風当たりの強い日が多く、釣りをするには防寒対策が必須だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "九月四日は西が吹いて、風当たりの強いこの峠の上を通り過ぎた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
