        "examples": {
          "standard": [
            {
              "text": "その学会では、現代科学における科学的方法論の課題について熱い議論が交わされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "哲学の講義で、異なる学問分野における科学的方法論の比較が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、社会科学における独自の科学的方法論の確立を目指している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "研究論文では、採用した科学的方法論を明確に記述する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "科学はチェーホフから一切の希望を奪ったのだから、どうして彼が科学的方法論などを容認する筈があろうか、というわけである。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
