        "examples": {
          "standard": [
            {
              "text": "保育園の先生は、ボロボロになった童謡の歌集を開いてピアノを弾き始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "合唱部の練習では、毎回この分厚い歌集からランダムに選んだ曲を歌う決まりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "キャンプファイアーの炎を囲み、ギターの伴奏に合わせて歌集の曲をみんなで口ずさんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "賛美歌の歌集を手にした信徒たちが、静寂な礼拝堂に美しいハーモニーを響かせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      }
