          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古い書物の中に、美しい唐歌がいくつか見つかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "当時の人々は、唐歌を詠んで詩情を楽しんでいたのだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この中国の詩は、情景描写が鮮やかで心を打つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この唐歌、意味を教えてもらえる？」と、学生が先生に尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかるに何事ぞや、その志を述ぶるを定義とせる詩に訓して唐歌といひたるは、これやがて歌ふを旨とするなるわが国の歌を、誤りて、漢土の詩と同じく志を述ぶるものとなせるなり。",
              "citation": {
                "source": "人々に答ふ",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "神尾主膳は、同じ家の唐歌という遊女の部屋に納まって、太夫と禿とを侍らせて、朱い羅宇の長い煙管で煙草をふかしていると、慌しく、「白妙さんのお客様が、御急病でいらっしゃいます」「ナニ、藤原が急病？",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人がお肴申そうかの」三太夫はやさしく微笑して、「唐歌の一節吟ずるとしよう。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいでね、命日に、ぼくがまた薬屋からうた時計を借りてきて、やぶの中で鳴らして、アキコにきかしてやったよ。",
              "citation": {
                "source": "うた時計",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "からうた聲あげていひけり。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "からうたはこれにはえ書かず。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "この折にある人々折節につけて、からうたども時に似つかはしき（をイ有）いふ。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "男どちは心やりにやあらむ、からうたなどいふべし。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうやうなるを見てや、むかし安倍の仲麻呂といひける人は、もろこしに渡りて歸りきける時に、船に乘るべき所にて、かの國人馬の餞し、わかれ惜みて、かしこのからうた作りなどしける。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "男たちの心なぐさめに、からうたに「日を望めば都遠し」などいふなる事のさまを聞きて、ある女のよめる歌、「日をだにもあま雲ちかく見るものを都へとおもふ道のはるけさ」。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "・ゆふべしたしくゆらぎつつ咲く（月草）・おみやげは酒とさかなとそして蝿（樹明君に）・何を求める風の中ゆく・若葉あかるい窓をひらいてほどよい食慾　青葉のむかうからうたうてくるは酒屋さん　風ふく竹ゆらぐ窓の明暗　風の夜の更けてゆく私も虫もぢつとして　六月三日　曇。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界的に有名な大指揮者に歌のコーチをして頂けるかどうかが、これからうたう歌によって決定するのだと考えますと、胸がどきどきいたしました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は持っていた楽譜鞄の中から「さくらさくら」と「ほたる」の楽譜を取出しまして、ここに日本の歌の楽譜を持っていますがとお目にかけますと、ウッド卿が自分がピアノの伴奏をするからうたって聴かせて下さい、とおっしゃいました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "其がとりも直さず、うたであり、其諷誦法うたふからうたひと訴へ（うたへ）とが分化して来たのである。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "真言からうた・ことわざが出来た。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからうたは必須知識として、ことわざ同様の呪力あるもの、或は氏・国の貴人として、知らねばならない旧事とせられて居た。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺されたお嬢さんは、心臓の真上を殆んど正面からうたれたそうですが、正確にいうとどの位の角度だけ傾いていましたかしら」「さあ、それは……」警部はギクリとした。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、まず忠実にいいつけられた用事をはたし、ほかからうたがいの眼をむけられないためであった。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、人からうたれるのは、これがはじめてで、そのはずかしめは、エミイにとっては、先生からなぐりたおされたほどにも感じました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "……所在ないからうたうのさ……ずっと昔からある歌で、意味もなんにもないのだろうよ」「この岩窟深いのでしょうか？",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田原あたりからうたの足どりが次第に東へ迫るにつれて文句も冴えて来る、といつても、この「下り」のうたは、「上り」に劣る。",
              "citation": {
                "source": "東京の風俗",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いてこそ居たが、まさかこんなに酷からうたあ思はなかつた。",
              "citation": {
                "source": "妻恋行",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間に生まれて女を慕わざる若さは存在しない、私の若さも白秋の若さも人間の持つ同じものであるから、女を慕いそれをうたう時はこういう隙間や陰からうたうものらしいと、私の盗みはそこから眼をさましかけ、それに勉めたものである。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "私からうたを取り上げては私は食ふことが出來ないし、毎日ぶらぶら遊んでゐてはとても退屈で生きてゆかれさうもない、うたを取り上げたあとの私は空つぽなのだ。",
              "citation": {
                "source": "はるあはれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は二年とか三年とかの期限づきなら承知するが、生涯なんてとても受けあふことが出來ない、一體、あなたは私からうたを作る仕事を取り上げるもとは何に原因してゐるのか、それも承つて置きたいと私は言つた。",
              "citation": {
                "source": "はるあはれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはいろいろな女のことをお書きになるから、それが山上の焚火のやうにあかあかと讀まれて來て、もう、わたくしには讀みたくないからあなたからうたを奪つてしまひたいのだといふ意味であつた。",
              "citation": {
                "source": "はるあはれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなお氣持なの、死人のやうな蒼白いからだをしてゐる女つて、冷たくてそれで柔かくてすべすべしてゐて、ほほ、……さあ、その原稿をお渡しなさい、それはお約束どほり燒いちやつて今日からうたなんか、お作りになることお廢めになるがいいわ。",
              "citation": {
                "source": "はるあはれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこの壮麗な広間にあふれた、昼よりもずっと明るい黄金色の光が、みんなの眼をきらきらと輝かせている間に、みんなは急調子な、あてもなく人を求めるような息づかいで、花や葡萄酒や料理、埃、白粉、香料、それからうたげにのぼせた肉体などの、暖かい昂奮させるようないきれを、吸い込んでいる。",
              "citation": {
                "source": "餓えた人々（習作）",
                "author": "DIE HUNGERNDEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "平凡のようだけれど、真情からうたわれている詩。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い装いの人は、永い病気から恢復して、はじめてこの午後の斜光の中を愛する園を訪れたのですが、美しい柔かい旋律のうたは、この扉を今開こうとするときの堪えがたい期待と、あまりの美しさが、自分をうちまかしはしまいかというよろこばしいおそれとからうたいはじめられています。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
