        "examples": {
          "standard": [
            {
              "text": "日本語の文は、主語、述語、修飾語などで構成されるが、活用語は主に述語や修飾語として機能する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "動詞や形容詞は活用語に分類され、文脈によって形を変える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この教材では、まず基本的な活用語のルールを学ぶことから始まります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「走る」「美しい」「です」などは、すべて活用語の例です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "四段活用ですと、その活用語尾の中、前に述べた十二の仮名に関係のあるものはカ行とハ行とマ行であって、その活用語尾は次の通りです。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "四段の活用語尾の「カ、キ、ク、ケ」やカ変の活用語尾の「コ、キ、ク」が同じ行での段のちがいであると同様に、「ケ」の甲と「ケ」の乙とがカ行四段の命令形と已然形とにあらわれて来ますから、「ケ」の甲乙二類の別も、やはりカ行の中での段の違いであろうと考えられます。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
