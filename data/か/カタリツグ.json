    "definitions": [
      {
        "index": 1,
        "gloss": "to pass down (a story) from generation to generation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この祭りの起源は古く、村人たちはその由来を代々語り継いできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、先祖から伝わる家宝の物語を、子供たちに丁寧に語り継いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの英雄の伝説は、いつまでも人々の心に語り継がれるだろう。」と歴史家は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "わしは進んで深く語り継ぐであろう。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "教員は深い嘆息と共に、私の方を顧み、そして世にも哀れな面持で、語り継ぐのであった。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "○丈夫は名をし立つべし後の代に聞き継ぐ人も語り継ぐがね　〔巻十九・四一六五〕　大伴家持　大伴家持作、慕振勇士之名歌一首で、山上憶良の歌に追和したと左注のある長歌の反歌である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "憶良の歌というのは、巻六（九七八）の、「士やも空しかるべき万代に語り継ぐべき名は立てずして」というのであった。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお笠金村が塩津山で作った歌、「丈夫の弓上ふり起し射つる矢を後見む人は語り継ぐがね」（巻三・三六四）があって、家持はそれをも取入れて居る。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども国に歴史あり家に父母祖父母の思い出があるように、どんなに微々たる一商店にもそれ相当の、後々へ語り継ぐべき苦心の物語があるものです。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なよたけの話を語り継ぐ人は貴方なのじゃ。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "語り継ぐものとてないこの里の云い伝えはこのまま永久に消え去って行くのじゃ。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、言い継ぎ語り継ぐとは歴史の根本心情である。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を言い継ぎ語り継ぐのか。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "語り継ぐとは、祖先の悲願にわが一身を捧げることであり、殉じて悔いざるの情である。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "語り継ぐ人間が、再び彼の死によって一切の意味を語るであろう。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「以和為貴」とは憲法の条文となる前にまず端的な祈りであり、仏の前、民の前に言い継ぎ語り継ぐべき誓願であったろう。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
