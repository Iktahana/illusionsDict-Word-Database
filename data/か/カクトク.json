[
  {
    "uuid": "1f856bd4-47a4-5d96-ae48-2c3de85badca",
    "entry": "獲得",
    "reading": {
      "primary": "かくとく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
