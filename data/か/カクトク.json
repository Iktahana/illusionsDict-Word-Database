    },
    "definitions": [
      {
        "index": 1,
        "gloss": "acquisition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「よっしゃ！ギリギリのところで競り勝って、念願のAランクを獲得したぞ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "熾烈なコンペを勝ち抜き、ついに大手自動車メーカーとの独占契約を獲得した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はデビュー以来、持ち前のカリスマ性で瞬く間に多くのファンを獲得した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ポイントを貯めて豪華景品を獲得するために、毎日欠かさずアプリをチェックしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私の観る限りにおいて、現今社会は恐ろしく修辞的であり、謂はば人々は如才なさ、抜目のなさを獲得しようとする時にばかり、全的に活気を呈するといつた有様である。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も此の外観は真の詩からなつてをり、彼はそれを、全ての本物の芸術家の如く、天才の一撃で以てその暗い色と蒼白い色とを強調することに依つて獲得してゐる。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "良心や道徳を、人類の後天的獲得物だとする説がある。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題は、では何故にそれは後天的に獲得されたかといふことだ。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまれ、「後天的に獲得される」に到つた先天的事情は存在したではないか？",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその蔵する体験と批判的知見とは、個人的に獲得したものであるよりは社会的に継承したものである場合が多いかもしれない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "後者等は大体において人間心理を伝統的理想の鋳型に嵌めて活動させているとしか思われないのに反して、西鶴だけは自分自身の肉眼で正視し洞察し獲得した実証的素材を赤裸々に記録している傾向がある。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も同時に若干の湯銭を獲得したことも事実ではあるが。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画を見ることによって吾々は凡庸な観察眼の代りに異常に鋭い観察者の眼を獲得することになる。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……が、確かに合理的であつたあらゆる方法の中で、仕事をしながら、遠い靈感を獲得するといふ勇氣だけが私にはありませんでした。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民政府に於て左党の政策の欠如が右党に幸して、彼等は尨大な小ブルジョワを党に獲得し、南方の多くのブルジョワも三民主義の名に隠れて党に参加した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして人は千里眼順風耳を獲得し、かつて夢みていた鳥の翼を手に入れた。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「風流」といい「さび」というのも畢竟は自己を反省し批評することによってのみ獲得し得られる「心の自由」があって、はじめて達し得られる境地であろうと思われる。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう能力の獲得が一人の人間の精神的所得として、そう安直な無価値なものであろうとは思われないのである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し彼の作品の持つ明るさを以て、全世界を獲得すべきプロレタリヤの信念の明るさ、若しくは作者等の戰線を支配してゐる希望の明るさの表現されてゐるものと見ることには贊成出來ない。",
              "citation": {
                "source": "「青空語」に寄せて（昭和二年一月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし現在の科学の所得は、すでに科学の究極的に獲得しうるすべての大部分であると考え、吾人の残務はただそこかしこの小さい穴を繕うに過ぎぬと考えればプランクの説はもっともと思われる。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏は悪徳である、貧者はその自覚の抑圧に苦しみ、富の美徳を獲得せんと焦慮するために働きあるいは盗み奪う……」　呉服の地質の種類や品位については全く無知識な自分も、染織の色彩や図案に対しては多少の興味がある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、また一方、この同じ心理がたとえば戦時における祖国愛と敵愾心とによって善導されればそれによって国難を救い戦勝の栄冠を獲得せしめることにもなるであろう。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして食物も衣服も住居もめいめいが自身の労力によって獲得するのであるから、天災による損害は結局各個人めいめいの損害であって、その回復もまためいめいの仕事であり、まためいめいの力で回復し得られないような損害は始めからありようがないはずである。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して映画のほうでは、スクリーンの上の光像はまさしく二次元の平面であるにかかわらず、カメラの目が三次元的に移動しているために、観客の目はカメラの目を獲得することによってかえってほんとうに三次元的な空間の現象を観察することができる、という逆説的な結果を生じるのである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "通り過ぎる汽車の音の強まり弱まり消え去ることによって平面的なスクリーンはたちまち第三次元の空間を獲得して数平方メートルの舞台は数キロメートルの広さに拡張される。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "有色映画　音声を得た映画がさらに色彩を獲得することによっていかなる可能性を展開するかという問題がある。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　この私有制度を滅すに就ては、漸進的解放と、急進的革命の二つの方法があると思ひますが、漸進的にしろ、急進的にしろ、自由は与へられた処に獲得し得るものではなく、掴得する処に与へられるものであります。",
              "citation": {
                "source": "農民文化といふこと",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "則ち今度の土地解放なるものが毫も小作人の現在組織の行詰まりより来る痛切なる自覚せる欲求に基づいて手放され獲得したる結果でなく、温情的に与へられたる土地であるのだから、彼等旧小作人は其の土地解放の精神を忠実に実行して漸次其の範囲を拡大して行く如き事は迚も難い様に思はれる。",
              "citation": {
                "source": "狩太農場の解放",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は其の通りだと思ふ、迚も痛切なる自覚せる結果に依つて獲得したる制度なり習慣なり権利でなくては真に獲得者が之を我物として活用する事は不可能である。",
              "citation": {
                "source": "狩太農場の解放",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともすれば、他人のした事他人の獲得した良果を見て、盲目的に自分もまた、それと同じような良果を獲得しようと欲求します。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしかれは威厳をかくとくした。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱病めいた興奮のうちに、真相をかくとくして勝ちほこりつつ、そのくせ舌の上にむかつきの味を、心のなかにとほうもない恐怖を感じながら、孤独の男は豪華な中庭を行ったりきたりしていた。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで君はしかし、愛する友よ、精神的なものへゆくために感覚を通らねばならぬ人間が、一度でも英知と真の人間の品位をかくとくすることができると思うかね。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
