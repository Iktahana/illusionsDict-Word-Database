        "examples": {
          "standard": [
            {
              "text": "積乱雲が発達し、上空では見事なかなとこ雲が広がっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夕焼けに染まるかなとこ雲は、迫力がありながらも美しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "気象予報士が、かなとこ雲の出現は雷雨の前兆だと説明していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "空に浮かぶ巨大なかなとこ雲を見て、明日の天気が心配になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "かなとこ雲　東の方に築地をつきたる如く立つ白雲を、かなとこ雲といふよしなり。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "東に白雲の築地の如く見えたるは眼にしたれど、猶かなとこ雲の風情といふを知らず。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
