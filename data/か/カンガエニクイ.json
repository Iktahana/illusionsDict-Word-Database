[
  {
    "uuid": "2ba4b569-9cee-59df-a263-9b97c73b8e9e",
    "entry": "考えにくい",
    "reading": {
      "primary": "かんがえにくい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
      "ctype": null,
