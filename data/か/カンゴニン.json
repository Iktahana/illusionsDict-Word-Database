[
  {
    "uuid": "50686c5f-6979-552f-9d8f-2b7de1b5f3fb",
    "entry": "看護人",
    "reading": {
      "primary": "かんごにん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "nurse (male or female)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "父が入院した時、とても親切な看護人がついてくれて、本当に安心したんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "高齢者施設では、専門的な知識を持った看護人が常駐しているので、いざという時も安心です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの病院、看護人の一人ひとりが患者さんの話をよく聞いてくれるのが良いところだよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「お――い、お――い」　患者が看護人を呼ぶように、力のない、救を求めるような、如何にも上官から呼びかける呼び声らしくない声で、近松少佐は、さきに行っている中隊に叫びかけた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何しろ今日は看護人なんだから、」と云つて、九時少し過ぎに「桔梗」を出た。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "その病棟には、男の狂人ばかりで、看護人も男でしたし、女はひとりもいませんでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婢は子供の時分に聞いた、上野の戦ひの時の、傷病兵の看護人が男性であつたものを、女性にかへてから非常に成績が挙るやうになつた看護婦の起源の話（これは近頃、当時の生存者がラヂオで放送した話にもあつたが）を想ひ出した。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして初めて、私は医員達や看護人達や看護婦達に、極端で而も奇怪な私の療法を打明けたのであった。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、白服の看護婦と黒い半纏の看護人とが五、六人ばたばたと駆けつけてきた。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「男さえ見ると、だれでも自分の夫だと思うんだからな、始末が悪いや」　看護人が笑いながら言った。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　看護人が真面目な顔で訊いた。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護人はたまらん」ボーイは背中をボリボリかきながらこぼした。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ずつと後になつて知つたのだが、左ういふ病気の疑ひで私はその村に閉ぢ込められ、またおかくはその看護人として雇はれてゐたのであつた――冗談ぢやない。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院の中庭に驛傳の馭者來り、麋の狩人の成の果なる看護人、かなたを通り過ぐ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とか「貴様ア馬鹿だぞ、脳味噌をつめ替えなくっちゃア駄目だ」なぞと無謀な言葉を浴せるようになると、側に見ていた看護人や女中達は患者よりも院長のほうに不安を覚えて、そっと眼を見交わしては苦い顔をするのだった。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶々看護人でも近寄ろうものなら大声を上げて喚き出す始末で、他人の患部へ手を触れることを烈しく拒絶するのだった。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "老看護人の鳥山宇吉は、いつものように六時に目を醒すと、楊枝を啣えながら病舎へ通ずる廊下を歩いて行ったのだが、歩きながら何気なしに運動場の隅にある板塀の裏木戸が開放しになっているのを見ると、ハッとなって立止った。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも時たま院長がここから裏の雑木林へ朝の散歩に出かけたりすることがあるので、ふと思いついた看護人の鳥山宇吉は、それでは院長が出られたのかなと思いながら取りあえず木戸の方へ歩いて行った。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「全部いません」「先生を起して……」「その先生が見えません」　やがて鳥山看護人と赤沢夫人、続いて女中の三人が、しどけない姿で運動場へ飛び出して来た。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを看護人が死ぬる前の電光と命んでゐる。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議な看護人　話は、すこし前にもどる。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その患者に附いていた看護人は、不馴れであったため、すぐさま、医員を呼びに行かないで、患者に向って、そのナンセンスなことを告げた。",
              "citation": {
                "source": "二重人格者",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護人は又もや笑って相手にならなかった。",
              "citation": {
                "source": "二重人格者",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護人は驚いて急を鬼頭博士に告げた。",
              "citation": {
                "source": "二重人格者",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は助手や看護人を去らしめて患者と二人きりになり、催眠術をかけて、患者の妄想を、他の妄想に置き替えた。",
              "citation": {
                "source": "二重人格者",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "烈しい愛の感情を、具体的な日常の、そのときどきの事情に応じて必要な形で活かし、あるときは愛情ふかい看護人とし、或る時は活溌な助力的な友達として、或る時はまた美しいけもののように素朴で豊富で、きつく、新鮮な女として生かしてゆくのでなかったら、生きる力としての愛のねうちはどこにあるでしょうか。",
              "citation": {
                "source": "私も一人の女として",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "医務室には年とった看護人が一人いた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　僕は看護人に聞いた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　看護人はとんでもないことをというように顔をあげて答えた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護人には、囚人の中から選り抜きの、ことに相当の社会的地位のあったものを採用する。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは看護人が薬室から泥棒して来るのだった。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこの病監で、自分が囚人だということもほとんど忘れて一カ月余り送った後に、足の繃帯の中に看護人等の数本の手紙を巻きこんで出獄した。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は看護人の如く其の頭の辺に控え、彼の様子を見て、猶様々に思い廻すに、彼此の頃は好い悪事のないのに窮して居るかと、衣服其の他の上に何となく「財政困難」と言う意味が浮んで居る。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
