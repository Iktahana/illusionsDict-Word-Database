        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "近松は彼等の官能主義やイゴイズムにも目を注いでゐる。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "又彼等の或ものは官能主義の奴隷だった。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "又彼等の或ものは官能主義の奴隷だつた。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "―或精神的風景画―",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の政見に耳を傾けないのは怪しからんと腹を立てたり、天下の政治について質問されて、返事もできないほど、無学低能、官能主義のデカダン野郎などと考える。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼はまだフランス語に十分慣れていなかったので、後者の博識な皮肉、前者の頭脳的官能主義を、十分味わうことができなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音楽論は官能主義に徹して、伝統を無視したものであったが、畢竟はカンディンスキーの絵画におけると同様、理論に溺れて、優れた才能を伸し切らぬうちに倒れてしまった形である。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
