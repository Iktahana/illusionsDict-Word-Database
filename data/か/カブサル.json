[
  {
    "uuid": "b83a3cf6-9313-5464-b227-0d9e88f065ef",
    "entry": "被さる",
    "reading": {
      "primary": "かぶさる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
