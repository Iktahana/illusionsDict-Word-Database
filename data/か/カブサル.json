        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "突然、チームリーダーの重責が彼に被さった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "今回のプロジェクトの失敗の責任が、予期せず私に被さってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「え、私がやるの？」 突然の指示に、戸惑いが彼女に被さった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
