    "definitions": [
      {
        "index": 1,
        "gloss": "riverbank",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夕焼け空の下、川べりを散歩する夫婦の姿があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夏になると、子供たちは川べりで水遊びをするのが大好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "川べりに咲く菜の花が、春の訪れを告げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "釣り人は静かに川べりに腰を下ろし、竿を垂らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さもなければ、田舎の川べりにでも住んで、夏は縁台を出して夕顔の花をみてゐるといふ、あの消極的平安の中に安住しなければならないのです。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともよは学校の遠足会で多摩川べりへ行ったことがあった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――此の按摩杖を力に、川べりの水除け堤へ来ると、杖の先へ両手をかけて、ズイと腰を伸ばし、耳欹てゝ考えて居る様子、――と言ふ。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度その頃｜一竿を手にして長流に対する味を覚えてから一年かそこらであったので、毎日のように中川べりへ出かけた。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた実際において、そういう中川べりに遊行したり寝転んだりして魚を釣ったり、魚の来ぬ時は拙な歌の一句半句でも釣り得てから帰って、美しい甘い軽微の疲労から誘われる淡い清らな夢に入ることが、翌朝のすがすがしい眼覚めといきいきした力とになることを、自然｜不言不語に悟らされていた。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時分毎日のように午後の二時半頃から家を出でては、中川べりの西袋というところへ遊びに出かけた。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の家からやや一町も離れた所まで来ると、清逸は川べりの方に自分で踏みならした細道を見出して、その方へと下りていった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と然う思つて、落すやうに、川べりに手巾の濡れたのを、はらりと解いた。",
              "citation": {
                "source": "月夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　旧藩の頃にね、――謡好きのお武家が、川べりのその土塀の処を、夜更けて、松風、とかをうたって通ると、どこかそこの塀の中――中ならいいんですけど、壁が口を利くように、ウウと、つけ謡でうたうんですとさ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "其年も初秋の初夜過ぎて、白井氏が玉川べりの実家へ出向いた帰りだと云って、――夕立が地雨に成つて、しと／＼と降る中を、まだ寝ぬ門を訪れて、框にしつとりと置いて、帰んなすつた。",
              "citation": {
                "source": "玉川の草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "角のある人魂めかして、ぶらりと風呂敷包を提げながら、小川べりの草の上。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "連中は、ふらふらと二日酔いのような工合で、ぼんやり黒門を出て、川べりに帰りました。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見さっせえ、韋駄天のように木の下を駆出し、川べりの遠くへ行く仁右衛門親仁を、（おおい、おおい、）　と茶番の定九郎を極めやあがる。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "嵩増す潮は、さし口を挟んで、川べりの蘆の根を揺すぶる、……ゆらゆら揺すぶる。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は学校へ往き来の江戸川べりを調査している土俗地理学者の若い紳士であった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は目白の学校への往復に、その川べりのどこかの男の仕事場で度々｜出遇い、始めはただ好感を寄せ合う目礼から始まって、だんだんその男と口を利き出すようになった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この母と妻の母と、もう五十に手のとゞきさうな妻と、三人の老婆が、老鶏のやうに無意識に連れ立つて、長柄の川べりへ薺など摘みに行つた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただのときは水につかることのない、川べりのすすきや、萩の株が、黄いろくにごった水に横だおしになって、もまれています。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お艶様に申しますと、じっとお聞きなすって――だと、その奥さまのお姿は、ほかにも見た方がありますか、とおっしゃいます――ええ、月の山の端、花の麓路、螢の影、時雨の提灯、雪の川べりなど、随分村方でも、ちらりと拝んだものはございます。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「…………」「びっくりして土手へ出ますと、川べりに、薄い銀のようでございましたお姿が見えません。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……というのは羽織袴です――弁持も私も、銀行は同一取引の資産家だから、出掛けに、捨利で一着に及んだ礼服を、返りがけに質屋の店さきで、腰を掛けながら引剥ぐと、江戸川べりの冬空に――いいかね――青山から、歩行で一度中の橋手前の銀行へ寄ったんだ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫟林は、丘の上では果樹園や花畑の背後を囲みながら学校教職員の舎宅のある段と、学園の建物のある段と、その下の多那川べりの灌漑地帯の田畑の平地と、三段になっている地層を抱きかゝえるように多那川の岸にまで立ち続いております。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その親鶏が雛鶏に向うときのような太暖かい声の響きは、わたくしに去年のクリスマスまえ、学園の丘の河上の多那川べりで遇った乞食の老人の声を思い起させます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はなお一気には山かげに遠ざかり兼ね、太田の町外れからバスがあるのを幸い、下野の平野を山の遠輪に沿うて横へ利根川べりの妻沼の聖天まで走らせました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節と水の流れはわたくしを笹舟のように川下の夏へ移して今度はわたくしは多那川べりの鷺町の女乞食になりました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしが多那川について南へ下り鷺町の川べりの女乞食になってから二月ほど後の見聞です。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はわたくしの小屋の在る多那川べりとは正反対の西南の町外れの小橋の側に仲間のうちでサブリといわれる乞食小屋を慥えて住んでいます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "町を逆にとって返し、多那川の川べりの草堤に来てぶらり／＼逍遥します。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今この目の前の川べりには、鳥葉樹がはえている。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "利根川べりの田舎からであった。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
