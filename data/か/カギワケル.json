[
  {
    "uuid": "959b0db8-bfc9-5a02-9ae4-2f3321a5024f",
    "entry": "嗅ぎ分ける",
    "reading": {
      "primary": "かぎわける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
