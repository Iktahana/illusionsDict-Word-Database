        "examples": {
          "standard": [
            {
              "text": "電車が動き出したと錯覚するのは、隣の電車の仮現運動を見ているからだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画やアニメーションは、静止画の連続による仮現運動を利用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ネオンサインの点滅は、視覚的に仮現運動を引き起こし、人の目を惹きつける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "と云うのは心理学上の術語で仮現運動と云って、十時形に小さい円を当てて、その中心に符合させる。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
