[
  {
    "uuid": "6eb1a870-3023-56d5-967d-7fbdda75f711",
    "entry": "考え方",
    "reading": {
      "primary": "かんがえかた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
