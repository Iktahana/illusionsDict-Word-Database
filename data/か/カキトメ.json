    },
    "definitions": [
      {
        "index": 1,
        "gloss": "registered mail",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "重要な書類なので、必ず書留で送ってください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "郵便局から書留の不在通知が届いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "大学の願書を書留で郵送した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「書留です。こちらにサインをお願いします。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "それから暫らくして或日突然、恩地氏から一封の書留小包が届いた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生が郵便配達をつかまえて、ビールの息とシガーの煙を吹きかけながら、ことしもまたうんと書留を持って来てくれよなどと言って困らせている。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "書留にしなかつたからと云ふことが殊更不安を感じさせるのであつた。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはここへ来てからの、心覚えの童謡を、明が書留めて朝夕に且つ吟じ且つ詠むるものだ、と宵に聞いた。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその書留を受けとつたとき、やはり父の底意地のわるさを憎んだ。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその書留を受けとったとき、やはり父の底意地のわるさを憎んだ。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へ帰ると、思わぬところから書留が来ているかも知れない。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三日経ってから、私のあの二通の手紙が大きい封筒にいれられて書留郵便でとどけられました。",
              "citation": {
                "source": "恥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かならず、厳罰に附し、おわびの万分の一、当方の誠意かっていただきたく、飛行郵便にて、玉稿の書留より一足さきに、額の滝、油汗ふきふき、平身低頭のおわび、以上の如くでございます。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉稿、本日別封書留にてお送りいたしました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、陣痛の苦しみを味わった原稿だと思えば、片輪に出来たとはいえ、やはりわが子のように可愛く、自分で持って行って、書留の証書を貰って来なければ、安心出来ないという気持もあった……。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "書留めて行く中に、伯父の性質の、というよりも、伯父と彼自身との精神的類似に関するとりとめのない考察のようなものになって行った。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白いから、書留めて置こう。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは、こんな変な事を詳しく書留めて置こうとすること自体が、既に幾分病的なのかも知れない。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きておる智慧が、そんな文字などという死物で書留められるわけがない。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　書留など、どこから来たのだろうと、圭子が不思議に思いながら玄関へ出てみると、それは新子からの手紙だった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、立ちもどって来て、茶箪笥の上に、針箱と同居している用箪笥の小引出しから、判箱を出して、書留用紙に判を押して返した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "新子からの手紙は、もちろん母の宛名、お給金を送って来るには時期が早すぎるのに書留とは、と思いながら、母より先に見たって差支えあるまいと、サリサリと封を切ってみると、手紙と共に数枚の為替証書だった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき、書留を見た刹那、為替証書を見た刹那、精しくいえば、無意識に懐へしまったまでに、わずか二、三分たらずの間に、圭子の心は、決していたのである。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、母も美和子も、書留の来たことさえ、気がつかなかったのは、まことに幸運だったと、圭子の心は快哉を叫んだのである。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢さまが、ご病気の時、私がよく看護してあげたので、そのお礼として、お金を頂いたから、その内私十円だけお小づかいに取っておいて、後は書留で送ったはずよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、婆やがそこから、顔を出すと、「十日くらい前に、家へ書留が来なかったかしら。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか、上のお嬢さまが、書留らしいものを、お受けとりになったようでございますよ、たしか。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、お母さまは、私の送った書留を、圭子姉さんが、だまって使ったと思っていらっしゃるの……」「まさかとは思うけれど……」母は暗澹としていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此事逸聞らしいから、忘れぬ内に書留めおく）。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の日記に書留めたる外にも、種々平田父子の事を聞きたるも、予只今記臆惡く成て、一筆を留めざるは遺憾甚し。",
              "citation": {
                "source": "秘魯國に漂著せる日本人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、書留としてあるぢやあありませんか。",
              "citation": {
                "source": "身上話",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つひ鼻の先きなのに郵便をよこすことは度々ありましたが、書留といふのは變だと思つて、わたくし胸がどきどきしましたの。",
              "citation": {
                "source": "身上話",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "否応なくまたその月の大ミソカが迫り、止むなくわたしは原稿の皺を伸して一気呵成に書き続けようと、冷水浴を行つて部屋に取つて返すと、偶然国元から符箋のついた書留郵便が届いてゐた。",
              "citation": {
                "source": "わが生活より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『浮雲』第三篇は作者の日記の端に書留めた腹案に由ると、お勢の堕落と文三の絶望とに終るのだが、発表されたものを見ると、腹案の半ばにも達しないで中途から尻切とんぼに打切られておる。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
