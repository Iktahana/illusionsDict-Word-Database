          "standard": [
            {
              "text": "「あの、この封筒、中身が重要書類なので書留でお願いしたいんですけど。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "留守の間に届いた書留の再配達を、外出先からスマホで依頼した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ずっと待っていた合格通知が書留で届き、家族みんなで大喜びした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
