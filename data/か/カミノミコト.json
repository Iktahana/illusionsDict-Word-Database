          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "八百万の神の命が宿る、自然豊かな土地を守りたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祝詞をあげ、神の命に感謝と祈りを捧げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地方には、特定の神の命を祀る小さな社が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "エデンの園の蛇でさえ彼等の眼には、勝手に神の命令にそむいたアダムやエバより悪くはなかったのだ。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　黙って袖口を、なぞえに出した手に、はっと、女神の命に従う状に、赤熊は黙ってその刀を渡した。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夜就眠の時に當つて、明朝五時に於て覺めて、而して獵に赴かんと思ひ、或は六時に覺めて直に文を草せんと思ひて、そして五時或は六時に起き出づることも本より少くは無いが、然樣いふ精神の命令有るにあらずして、而もおのづからにして寤むることも亦少く無い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "雉名鳴女、天神の命を奉じ視に往しを天若日子射殺し、其矢天の安河の河原に達す。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夜就眠の時に当たって、明朝五時に覚めてそして猟に行こうと思い、或いは六時に覚めて直ちに文を書こうと思って、そして五時或いは六時に起き出すことも元より少なくはないが、そういう精神の命令が無くて自然と覚めることもまた少なくない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "濠州メルボルン辺に棲むと伝えた巨蛇ミンジは、プンジェル神の命のままに、疱瘡と黒疫もて悪人を殺すに能く、最高き樹に登り尾もて懸け下り、身を延ばして大森林を踰え、どの地をも襲う。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は神の命に依つて楽を奏でてゐる姿で、息さへ凝り固つてゐるかのやうだつた。",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "世謡ということは「国家の大事件を謡う」の意で、予言者と詩人とを兼ねた社会の先覚者が神の命を承けて詩歌の形でこれを民衆に告げることであります。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、雄々しい活力が、今私の心を揺る、サムソンのように、殿堂の柱に、今手をかけたサムソンのように神の命あれば山をも移す　信仰が野に来、自然に戻った私の胸に満つるのだ。",
              "citation": {
                "source": "五月の空",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食前の祷　天の父母、我が父母を生み、我が父母、神の命によりて我を孕み我を産めり。",
              "citation": {
                "source": "臨終の田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も此が神そのものでなく、神の命を受ける山の精霊に扮する者のわざだつたのである。",
              "citation": {
                "source": "日本文学における一つの象徴",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人かく神の命に背きてその恩寵を失へるがゆゑに能く善を行ひて以て聖旨を和ぐるをえず、キリスト來臨したまふに及びその從順の徳によりて神人はじめて融和すと四〇―四二【髮】枝。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "神――遠来の神――であつたとも、其神の命令に従ふ土地の神であつたとも、或は、さうした遠来の神の命令があるので、為方なしに土地の精霊が、誓約のしるしに、此を行うて見せたのだとも考へられる。",
              "citation": {
                "source": "田遊び祭りの概念",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大※の面は、全く口を閉ぢてゐる貌であるが、此面には、尊い神の命令を聴くと言ふ外に、其命令を伝達すると言ふ、二つの意味がある。",
              "citation": {
                "source": "鬼の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "神言に含まれた神の命は、伝達することによつて現れる。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「吾が大王ものな思ほし皇神の嗣ぎて賜へる吾無けなくに」（巻一・七七）という御答歌で、陛下よどうぞ御心配あそばすな、わたくしも皇祖神の命により、いつでも御名代になれますものでございますから、というので、「吾」は皇女御自身をさす。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "記録を調べても、神の命令の言葉は短く、其に応へる言葉は、長くなつて行つてゐる傾向が窺はれる。",
              "citation": {
                "source": "古代に於ける言語伝承の推移",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、力の優れたものに役せられる精霊が、さうした姿なり、声を以て、神の命じた用をたしに来る、とした考へのあつた事だけは訣る。",
              "citation": {
                "source": "信太妻の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此国に行はれる事は、天つ神の命令によつて行つて居るので、つまり、此天つ神の命令を伝へ、又命令どほり執り行うて居る事をば、まつるといふのである。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから天孫は、天つ神の命によつて、此土地へ来られ、其御委任の為事をしに来らせられた御方である。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "新嘗は、後にこそ刈り上げ祭りの様になつて居るが、ほんとうは、神の命令に依つて行つた、農事の報告であり、神嘗は、諸国から宮廷へ奉つた稲穂を整理して、更に、伊勢大神宮へ奉る行事である。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にかの欧州諸国はみずからキリスト教国と誇称すれども、いまだ上古の先知者が予言したるがごとく、牛羊とともに草を噛み、尾を垂れ首をたらし、真神の命に柔順なるの猛獅にあらざるなり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "風神ヘルメス、天神の命により、此婦を携えて、エピメトイスの家に至る。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "先だちて出でましし八十神の命以ちて、海塩を浴みて、風に当り伏せれと誨え給いき。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大国主神の殺されし時、御祖命の哭き悲みて、天神に訴えしは、レムミンカイネンの殺されしとき、その母の悲みて、死屍の所在を、太陽神に問いしと同じく、※貝比売と蛤比売と、天神の命によりて、大国主神を活かせしは、鳥の来りて、天の霊薬を以て、死せし青年英雄の屍体に注ぎて、之を蘇生せしめしと、略同じ。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大国主神、母神の命に従い、根国なる須佐能男命の許に至りし時、その女須勢理比売出で見て、目合して、還り入りて、其父に甚麗わしき神来りぬと云う。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して二人の姉の嫉妬心は、遂にプシヘの心を迷わしめ、好奇心に駆られて、夫神の命に背きて、火を点ずるに至りて、両者の分離となりぬ。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "釜の鳴るの理は物理学上の研究に属することと思うが、もし、その声が真に神の命令である、神は口なきために釜をして言わしむると信ずれば、迷信といわねばならぬ。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
