        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔の村では、新しいお触れは村役場の壁書きとして掲示された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "江戸時代の壁書きには、犯罪への罰則が厳しく記されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庶民は壁書きの内容を見て、幕府の政策を知った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この古文書には、当時の壁書きが忠実に転写されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「今日の壁書き、読んだ？新しい税金が導入されるってさ」と人々が噂しあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
