    "definitions": [
      {
        "index": 1,
        "gloss": "neighborhood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この駅の界隈には、美味しいレストランがたくさんある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜になると、駅前界隈は仕事帰りの人々で賑わう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学生時代を過ごした大学界隈は、今も変わらない風景が広がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この界隈の右方に鳥居をかいて「三島神社」とある。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マロニエの花にも近いというので、界隈の散歩人は入れ代り立ち代り少憩をとる。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルの上へ、まだ活字が揮発油で濡れているパリ・ミデイの一版を抛り出して、キャフェの蕭条をまづ第一に味わいに来たのは Boulevardier（界隈の人、或は大通漫歩の人と訳すべきか）と呼ばれている巴里の遺物である。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変らずこの界隈の褒めものの娘であり、ふた親の自慢娘ではあった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は強いままに当時の上司の命を受けて、東国の界隈の土蜘蛛の残りの裔を討伐に向った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "界隈の昇華した名家々々の流れを相互に婚姻を交えている間に、家の人間に土より生い立てる本能の慾望を欠き、夢以外に食慾が持てない咀嚼力の精神になってしまったのも原因の一つであろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしが向島の寮に囲われていた時分、旦那がとても嫉妬家でね、この界隈から外へは決して出してくれない。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃この界隈に噂が立ちかけて来た、老妓の若い燕というそんな気配はもちろん、老妓は自分に対して現わさない。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この界隈に在っては総てのことが喜劇の厳粛性をもって真面目に受け取られた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この界隈の人の間には共通の負けん気があった。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災前と比べて王子赤羽｜界隈の変り方のはげしいのに驚いた。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに今年は実際に小春の好晴がつづき、その上にこの界隈の銀杏の黄葉が丁度その最大限度の輝きをもって輝く時期に際会したために、その銀杏の黄金色に対比された青空の色が一層美しく見えたのかもしれない。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢切の斎藤と云えば、この界隈での旧家で、里見の崩れが二三人ここへ落ちて百姓になった内の一人が斎藤と云ったのだと祖父から聞いて居る。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "常連で、この界隈に住んでいる暇のある連中は散髪のついでに寄って行くし、遠くからこの附近へ用足しのあるものは、その用の前後に寄る。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼空は培養硝子を上から冠せたように張り切ったまま、温気を籠らせ、界隈一面の青蘆の洲はところどころ弱々しく戦いている。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会育ちの美食家の父娘は、夕飯の膳を一々｜伊勢丹とかその他｜洲崎界隈の料理屋から取り寄せた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この界隈の踊り場には、地つきの商店の子弟が前垂を外して踊りに来る。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき銀座界隈へまで出掛けることもある。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水泳場のある材木堀も界隈の蘆洲の根方もたっぷりと水嵩を増した。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山下界隈の怪しい酒場で酔泥れた一列の黒奴の火夫達が、最新流行歌をうたって和服の蠱惑の街に傾いた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "此界隈はもと孫逸仙が亡命中の隠れ場所であった。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "天満天神に朝｜詣りした五花街の女たちが、ふたたび睡るころ、北浜｜界隈は車だまりから人力車が一掃されて、取引市場をとりまいた各商店では、踊子がつけた腰の鈴のように電話が絶えまなく鳴り渡った。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "北浜界隈も、支那財界の大混乱のために、対支商談は不況のどん底に陥ってしまった。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この界隈の連合委員会の事業振興の決議案にもかかわらず、閑散とした取引市場をとりまいて、日一日と失業者と、彼らの飢えが生産余剰と反比例して街の広場に堆積して行った。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "納豆屋の「ナットナットー、ナット、七色唐辛子」という声もこの界隈では近ごろさっぱり聞かれなくなった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の見へあがると、この界隈を覆っているのは暗い甍であった。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　界隈の景色がそんなに沈鬱で、湿々として居るに従うて、住む者もまた高声ではものをいわない。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう男がこの界隈のビルディング街の住民であろうとは思われない。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼈甲屋や、衣裳屋、指物屋なぞの出入りが間遠になって来たのは、どうも怪訝しいと言う近所界隈の取沙汰じゃ……吾々もドウモそこいらが臭いような……事件の起りはその辺ではないかと言いたいような気持がするが、それから奥の深い事情が一つも判然らんけに困っとる。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぬいさんの家の界隈は貧民区といわれる所だった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
