    "definitions": [
      {
        "index": 1,
        "gloss": "to be piled up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "仕事の依頼が次々と重なり、対応に追われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "雪が降り積もり、家の屋根に厚く重なった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古い領収書が引き出しの中で山のように重なっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "片側の大名邸の高い土堤の上に茂り重なる萩青芒の上から、芭蕉の広葉が大わらわに道へ差し出て、街燈の下まで垂れ下がり、風の夜は大きな黒い影が道一杯にゆれる。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時君は、貴重なる蒐集品を救いだすため、火宅へ取って返したまま、永久に不帰の人となったそうだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、翁の齢の老に老の重なるしるしらしいものは見えなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それすら、複雑｜蟠纏を極めているのに、下より突き上げ上から展し重なるよう、十一の火山脈が縦横に走る。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茲にもたわわに咲きたわんだ桜の枝の重なる下――その病房の一つの窓が真黒く口を開けて居りました。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると、街路樹の葉が枯葉となって女や男の冬着の帽や服の肩へ落ち重なるのも間のない事だ。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし特殊の題目について重なる学術国の重なる研究者の研究の結果を up to date に調べ上げて、その題目に対する既得知識の終点を究める事は可能である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとき場合には公算論の指示する統計的方法を取る外なかるべきも、公算が変数の連続函数なりと断定し難く、また最大公算を有する場合が唯一ならざる場合には特別に慎重なる考慮を要すべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海洋に関する物理的事項の重なるものについては近頃出版した拙著『海の物理学』にその梗概を述べておいた。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人は子音の重なるのは不得意だから st がｓになることは可能である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし音の重なる場合には二つのものはそれぞれ単独にある場合の独立性を失わない。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと考えてみるとまだ三日しか間がない　余りま近く重なるはよくあるまいかしらんと気がついたので。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が心の何方に走れりとも知らで、乳に倦きれば乳房に顔を寄せたるまゝ思ふ事なく寐入し児の、頬は薄絹の紅さしたるやうにて、何事を語らんとや、折々曲ぐる口元の愛らしさ、肥えたる腮の二重なるなど、かかる人さへある身にて、我れは二タ心を持ちて済むべきや。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に數へる聲も次第に力を失つて行き、明瞭さを薄くして、助手の力強いバスの聲の響が高まつて行くのとは反對に、數が十、十一と重なるにつれて弱くかまれて行くのだつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その重なる一人は宿の主人なり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも最初のうちはあやまって堪忍されたのであるが、あまりにそれが度重なるので、ほかの芸人がすべて彼女と一座するのを嫌うようになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンチが度重なるに従って、工人の挙動がおとなしくなってきた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそうやって毎夜おそく湯へ下りてゆくのがたび重なるとともに、私は自分の恐怖があるきまった形を持っているのに気がつくようになった。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁はひとへなれど、おもひきつて大きく咲きたる、なか／＼に八重なる花の大なるより眼ざまし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "杏　あんずと漢めきたる名を呼ばるゝからもゝの花は、八重なる、一重なる、ともに好し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "名も無き小川のほとりなる農家の背戸の方に一本二本一重なるが咲ける、其蔭に洗はれたる鍋釜の、うつぶせにして日に干されたるなんど、長閑なる春のさま、この花のあたりより溢れ出づる心地す。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの矛盾ははなはだ貴重なる矛盾であり、実に無機界の科学と生物界の科学との矛盾である。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この意味でこの書は一部の貴重なる経典である。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上未熟な考察の一部をしるして貴重なる本誌の紙面をけがし読者からのとがめを招くであろうことを恐れる。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィーンのある男は厳重なる検閲のもとにウインドボイテル（軽焼きまんじゅうの類）を六十九個平らげた。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その巨石を取巻く大小の墓の前には、それぞれに紅と白の桃の花が美しく挿し並べて在ったが、その墓の間々へ物見高い近隣の町の者や、通りかかりの肥汲みの百姓や柴売り、又は近道伝の太宰府参りらしい町人なんどが真黒く、犇々と押しかけて、中央の白い花崗岩の石甃の上を、折重なるように凝視している。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "われとわが亡友との間、半透明の膜一重なるを感じた。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の上に山が重なり、秋の日の水のごとく澄んだ空気に映じて紫色に染まり、その天末に糸を引くがごとき連峰の夢よりも淡きを見て自分は一種の哀情を催し、これら相重なる山々の谷間に住む生民を懐わざるを得なかった。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雨ふれば北にたなびく天雲を君によそへてながめつるかな」、「北へ行く夕の雲の大空にかさなるみれば雨はふりつゝ」などいへる、地異なり時異なれば、たがひあるべき道理ながら、思ひくらぶれば、如何にも那方かいつはりなるべきやう浅まなる心には思はるゝを免れず。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどそはかならずよく燃ゆとこの群の年かさなる子、己のが力にあまるほどの太き丸太を置きつついえり。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to come one after another",
