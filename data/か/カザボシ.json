        "examples": {
          "standard": [
            {
              "text": "軒下に吊るされた干し柿が冬の冷たい風にさらされ、風干しにされることで甘みがじっくり凝縮されていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いいアジが手に入ったから、塩をしてからベランダで一晩風干しにしてみよう。明日の朝食が楽しみだね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "洗い立てのシーツを強い日光に当てるのではなく、あえて日陰で風干しにすることで、生地を傷めずにふんわりと仕上げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "職人が一つひとつ丁寧に風干しした漆器の下地は、驚くほど丈夫で美しい仕上がりになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "また一夜、一塩に漬けて置いた鰡を、翌日風干しに干して、焼いて食べると、甚だいける。",
              "citation": {
                "source": "蜻蛉返り",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
