        "examples": {
          "standard": [
            {
              "text": "感染力の強いウイルスが検出されたため、患者は直ちに陰圧設備のある隔離病室へ移された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「隔離病室での生活は孤独だけれど、看護師さんたちが防護服越しに励ましてくれるのが救いだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "院内感染を防ぐため、隔離病室への立ち入りは厳格に制限されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "隔離病室のある限りの窓にはかんかんと灯がともって、白いカーテンが引いてあった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼飯を終ると彼女はリヤカーに乗せられて、雨の中を隔離病室へ転室して行つた。",
              "citation": {
                "source": "続重病室日誌",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "隔離病室、男女不自由舎等これと同一で、これらの臨時附添はイロハ順に廻つて来るので一ヶ年一回は誰でも番があたる。",
              "citation": {
                "source": "続癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "重病室からちよつと離れて収容病室があり、更に離れて丹毒、チブス、赤痢等の病人が這入る隔離病室が三棟ぱらぱらと散らばつてゐる。",
              "citation": {
                "source": "癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は多摩川を眼下に見下ろす、某病院の隔離病室のベッドの上で、院長の手厚い介抱をうけていた。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
