        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "増水で流された丸木橋の代わりに、ひとまずロープを川の両岸に掛け渡した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "渓谷の端から端まで頑丈なワイヤーを掛け渡し、荷物運搬用の索道として利用する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "崩れかけた足場を補強するため、太い鉄骨を向こう側へ掛け渡すよう現場監督から指示が出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "両側の建物の屋上から屋上へと、祭りの提灯を下げるための綱が掛け渡されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "斜に生へたる大木を利用し、その木の半ば頃より丸太を彼岸に掛け渡す。",
              "citation": {
                "source": "十和田湖",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "又同じ時の歌に　紫の幕の草を掛け渡す小家に廻る水車かな　といふのもある。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "「〔Keine Bru:cke fu:hrt von Mensch zu Mensch.〕（人から人へ掛け渡す橋はない）」　私はつい覚えていた独逸の諺を返事に使いました。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Keine Brucke fuhrt von Mensch zu Mensch.（人から人へ掛け渡す橋はない）」　私はつい覚えていた独逸の諺を返事に使いました。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたには霧あはくかけわたす、加部島をながむれば、模糊たる影、水彩を薄絹にほどこせるがごとし。",
              "citation": {
                "source": "松浦あがた",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
