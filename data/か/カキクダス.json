      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to write from top to bottom",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "短冊に願い事を書き下すとき、筆先に全神経を集中させて一画一画を丁寧に運んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このタイトルを縦に大きく書き下すと、遠くからでも視認性がぐっと高まると思うよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "卒業式の式次第を墨汁で力強く書き下していくのは、毎年のベテラン教師の役目だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は大きな看板に、店の屋号を躍動感あふれる筆致で見事に書き下した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あなたの書き下す人間が、人間として一人前に活動しつつ、同時に其一篇のムードを構成している事は疑もない事実です。",
              "citation": {
                "source": "木下杢太郎著『唐草表紙』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は既に一首の歌を一行に書き下すことに或不便、或不自然を感じて來た。",
              "citation": {
                "source": "歌のいろ／＼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私の不便を感じてゐるのは歌を一行に書き下す事ばかりではないのである。",
              "citation": {
                "source": "歌のいろ／＼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎角、日本のものはかういふ風にしぜんに書き下すのがほんたうのやうである。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　此奇怪なる二人の問答には、少くとも三幕物に書き下すに足る演劇的の事實が含まれて居る。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　此奇怪なる二人の問答には、少くとも三幕物に書き下すに足る演劇的の事実が含まれて居る。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩的な、浪漫的な句は筆を執って紙にでも咏懐の辞を書き下す時に限るように考えています。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故この年にはすでにわが著作の「材料が揃って」いたのであって、ただ問題はそれを書き下すか否かにしかないように見える。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、「思いつくままに書き下す」というスタンダールの秘訣を讃え、それとはおよそ対蹠的な例として、飜訳という仕事を挙げたものであった。",
              "citation": {
                "source": "飜訳の生理・心理",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「名和長年」は幸田露伴先生が私の為にお書き下すつた本です。",
              "citation": {
                "source": "大森彦七と名和長年",
                "author": "松本幸四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、一度印刷してあるものをなおしてゆくという程度の仕事が大変ふさわしいのね、書き下すほど疲れず、しかも十分仕事としての緊張があり、且つ〆切りもなく又枚数もなおす範囲で自由で至極工合がようございます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（訳者注　ラ・フォンテーヌの物語の初めを参考までに書き下す――烏先生は木の上にとまって、くちばしにチーズをくわえていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to write out (at a stretch)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "締切が明日に迫り、彼は徹夜で残りの三章分を脇目も振らずに一気に書き下した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「すごい！ まさか一日でこれだけのロングインタビューを書き下すとはね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は旅先での感動を忘れないうちに、ホテルの便箋に数通の手紙をサラサラと書き下した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "構想に三年かけた大作を、彼はわずか一ヶ月の山籠もり合宿で書き下したという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "to rewrite classical Chinese in Japanese word order",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "論語の一節を、現代語訳ではなく、あえて古典的な候文のスタイルで書き下してみる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「レ点や一二点を見逃さずに、この漢詩を正しい日本語の語順で書き下してください。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "漢文の教科書には、白文を書き下す際の手順がフローチャートで分かりやすく解説されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は難解な古文書の漢文部分をスラスラと書き下し、周囲の院生たちを圧倒した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
