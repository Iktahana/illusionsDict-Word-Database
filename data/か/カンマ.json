        "examples": {
          "standard": [
            {
              "text": "ヨーロッパの一部の国では、小数点をピリオドではなくカンマで表記する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "設計図の「3カンマ5ミリ」という表記は、3.5mmを意味する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "古い会計帳簿には、金額の小数点をカンマで記しているものがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
