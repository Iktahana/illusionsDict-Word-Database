      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "New Year's pine decoration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "玄関の両脇に、立派な門松が飾られている。新年を迎える準備は万端だ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "年の瀬になると、街のあちこちで門松を見かけるようになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この門松、すごく立派だね！どこで買ったの？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "家紋が彫られた、オリジナルの門松を特注したそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "新年新年來り門松は白く光れり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ何となく軒端に菖蒲を葺いた郷国の古俗を想い浮べて、何かしら東西両洋をつなぐ縁の糸のようなものを想像したのであったが、後にまたウィーンの歳の暮に寺の広場で門松によく似た樅の枝を売る歳の市の光景を見て、同じような空想を逞しゅうしたこともあった。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "門松は静かに立っていた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "驛路の馬の鈴の音、しやんと來る道筋ながら、時世といひ、大晦日、道中寂りとして、兩側に廂を並ぶる商賈の家、薪を揃へて根占にしたる、門松を早や建て連ねて、歳の神を送るといふ、お祭の太鼓どん／＼／＼。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィーンで夜おそく町をうろついて、タンネンバウムを売っているのを見た時にちょうど門松と同じだと思ったのと、ヴェネディヒで二十五日の晩おびただしい人が狭い暗い町をただぞろぞろ歩くのを見てさびしい思いをしたきりでしたが、ことしはここの田舎で田舎らしい純粋の降誕祭を経験しました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等学校時代のある年の元旦に二三の同窓といっしょに諸先生の家へ年始回りをしていたとき、ある先生の門前まで来ると連れの一人が立ち止まって妙な顔をすると思ったら突然仰向けにそりかえって門松に倒れかかった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊豆山にて門松やたをやめ通る山の裾　五時半、熱海着。",
              "citation": {
                "source": "熱海の春",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "門松や輪飾りはめんどうくさいから止めにして、裏山から歯朶を五六本折ってきて瓶に挿した。",
              "citation": {
                "source": "雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには立派な門松が立ててあり、門の片方の柱には、味噌溜と大きく書かれた木の札がかかっていた。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……鳥居数をくぐり、門松を視ないと、故郷とはいえない、といわれる通りの気になって、おまいりをしましたり。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は磨いたように晴れて、背丈高い門松の笹の葉を、風がざわめかします。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風がだいぶ出て、門松の笹の葉の鳴る音や凧のうなり声が聞えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、門松をば必ず新の正月に立てました。",
              "citation": {
                "source": "樹木とその葉",
                "author": "故郷の正月",
                "note": "青空文庫"
              }
            },
            {
              "text": "今かんがえると実にばかばかしいお話ですがね」　文久三年正月の門松も取れて、俗に六日年越しという日の暮れ方に、熊蔵という手先が神田三河町の半七の家へ顔を出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の家の門松は只短い松の枝と竹の枝とを小さな杙に縛り付けて垣根の入口に立てたのみである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "津村正恭の『譚海』一五に、蝮蛇に螫されたるには年始に門松に付けたる串柿を噛み砕いて付けてよしと出づ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "天明五年正月の門松ももう取られて、武家では具足びらき、町家では蔵びらきという十一日もきのうと過ぎた。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに新年早々はどこの店でも門松を立て、国旗をかかげ、回礼者の往来もしげく、鉄道馬車は満員の客を乗せて走る。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "このほかにも、円朝物で脚光を浴びたものには「舞扇恨の刃」「業平文治漂流奇談」「緑林門松竹」等々、更に数種にのぼるのであるが、小さい芝居は一々ここに挙げない。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来の少い横町へ這入ると、追羽子の春めいた音も少しは聞えますが、その群の多くは玄関の書生さんや台所の女中さんたちで、お嬢さんや娘さんらしい人たちの立交っているのはあまり見かけませんから、門松を背景とした初春の巷に活動する人物としては、その色彩が頗る貧しいようです。",
              "citation": {
                "source": "二階から",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三日前に立てた門松も外してしまった。",
              "citation": {
                "source": "正月の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ先生のお宅を出たのは午後三時頃で、赤坂の大通りでは仕事師が家々のまえに門松を立てていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "勘平の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬研堀の歳の市は寒かろうと噂をしながら、半七は格子の外に立って、町内の仕事師が門松を立てるのを見ていると、亀吉は三十五六の男を連れて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三河万歳",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら立派な出入り屋敷をたくさん持っていても、才蔵を連れない万歳は武家屋敷の門松をくぐる訳にはゆかなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三河万歳",
                "note": "青空文庫"
              }
            },
            {
              "text": "お正月のお飾りを片付ける時分には、村中の門松や注連繩などを村のはづれへ持つて行つて、一｜緒にして燒きました。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "松、梅、竹、裏白、譲葉、……門松らしいものをこしらへて飾る。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も人並に門松を飾つた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの町を歩いても、軒ごとに門松や輪飾りが綺麗に出来｜揚って、新しい春がもう来たようであった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "洒落た花形の電気の笠などの下った二階の縁側へ出て見ると、すぐ目の前に三聯隊の赭い煉瓦の兵営の建物などが見えて、飾り竹や門松のすっかり立てられた目の下の屋並みには、もう春が来ているようであった。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "門松のある中に遊ぼうとするような娘子供は狭い町中で追羽子の音をさせて、楽しい一週の終らしい午後の四時頃の時を送っていた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
