[
  {
    "uuid": "93c0fd2e-6e86-5e4d-a413-92aacaabb103",
    "entry": "門松",
    "reading": {
      "primary": "かどまつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
