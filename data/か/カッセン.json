  {
    "uuid": "a630772e-51c1-5930-a93f-526a585226e2",
    "entry": "活栓",
    "reading": {
      "primary": "かっせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
