    "definitions": [
      {
        "index": 1,
        "gloss": "hair's breadth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ホームに入ってきた電車と接触しそうになったが、間一髪で身をかわした。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「落石が車のフロントガラスの数センチ先をかすめた。まさに間一髪の出来事だった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「締め切りまで残り1分というところで、間一髪、原稿の送信に成功した。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわっ！ 危ない！ ……間一髪で花瓶をキャッチできたよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "忙、閑、ともに間一髪。",
              "citation": {
                "source": "春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間一髪に於いて、狸の悲運は決定せられた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしたちのいま葬儀しつつある父と、その先代との間に家系も絶えんとし、家運も傾きかけた間一髪の際に、族中より選み出されて危きを既倒に廻し止めた女丈夫だという。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（清蔵に抱きつくようにして、清蔵のふところをさぐり、出刃庖丁を取り出し、逆手に持って清蔵の胸を刺さんとする）（清蔵）（間一髪にその手をとらえ）何をなさる。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、ふいと何か考へ直したやうな御様子で、御病床の将軍家のお顔をちらりとお伺ひなさつた間一髪をいれず、事ノ正邪デハナイ　お眼を軽くつぶつたままで、お口早におつしやいました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここが間一髪のところさ。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "間一髪のところで、こらえた。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）車が走り出す瞬間と、彼が降りようと決心が付く時とが不思議にも間一髪も挿まぬ同じ瞬間なので、彼は降りる機会を見失ふやうな気がした。",
              "citation": {
                "source": "白明",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "といっしょに、三本めの短いドスがかわすあとからおそいかかって、間一髪のところを上にそれつつ、プツリとまたふすまに突きささりましたものでしたから、うろたえたのは伝六で、なにはともかく正体を見届けなくてはとばかり、あわてて短檠をふりかざしながら、庭先へさし出そうとすると――「兄貴！",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "弾丸のように黒い影が横合いから飛びつけると、間一髪のうちに三島三郎兵衛の兇刃を払ってのけて、技もあざやか！",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死す」といふ事は何といふ簡明な、それでいて動かす事の出來ない、かはりを用ゐる事の出來ない力でせう、間一髪を入れない、迅速な、明確な、おごそかな、極めて弱くて極めて強い力ではありませんか……「死す。",
              "citation": {
                "source": "響",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と閑吉は鼻柱を衝かれて尻餠をつき、同時に和尚の体は大二郎の胸の下に飛び込んだ間一髪、見るもあざやかなハネ腰が掛つて、大二郎は丸太のやうな二本の脚で天井を蹴つて、背骨を床に打ちつけ、ウンと虚空をつかんでしまつた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……間一髪、私は、五臓六腑がものゝ見事に吹き飛んだ轟きに打たれて、全くの無意識状態の絶頂に飛びあがつた瞬間、物凄まじい勢ひで、突如、「ワーツ……！",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "間一髪、横手払い、チャリンと払った敵の太刀。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥が枝を渡つたのか、それとも照尺を縮めたのか――私には鳥の姿は見へなかつたが、何だか私は、厭に生真面目にてれ臭つたやうなあまりに能なし気な思ひで、よた／＼と伴いて行くと、待つ間もなく、間一髪、発砲の音で私は、思はず、ドキツとして蛙のやうに飛びあがつた。",
              "citation": {
                "source": "ダニューヴの花嫁",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "吃驚りしてたぢろいた妻達に、間一髪もいれさせず私は、いきなり妻が小脇にはさんでゐた模擬革のハンドバツグを、奪ひとるがいなや、「トラベラスだ、トラベラスだ、もう此方のものだ。",
              "citation": {
                "source": "競馬の日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "天然を講究する人一草一木の微を知り、人事を観察する人一些事一微物の真面目を識り、人間心中｜間一髪の動機を観る者は絶無にして僅有なり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方がないから、下宿の老婆を煽てて家じゅうから買物の空箱やら、クリイニングから洋服を入れてくるボウル紙の箱や何かをありったけ徴収し、それへ手当り次第に放り込んだのを糸で縛ってタキシへ投げ入れ、狂気のように疾駆させて、ほんとに間一髪のところで船へ聯絡する汽車の出発に間に合ったのだった。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く間一髪の出来事だった。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と甚太郎は、それまで構えていた黐棹を、ひょいと肩へ担いだが、間一髪の際を狙って武士は抜き打ちに斬り込んで来た。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "物蔭から「フッ」というと間一髪の同時に身構えるという、講道館五段以上の達人だから容易な事では手に合わない。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……間一髪を容れぬ生死の境がじりじりと、涯てしもなく継続して行く……手に汗を握る……死んだ画面であった。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその言葉が進むに連れて……否……女の言葉が烈しくなればなる程、室の中に充ち満ちていた殺気――間一髪を容れぬ危機は次第に遠退いて行った。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "船首にグングンのしかかって来る断崖絶壁の姿を間一髪の瀬戸際まで見せ付けられた連中の額には皆｜生汗が滲んだ。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "サアこの小便を避けて左右に道を開くか、何か咎め立てして喰て掛るか、爰が喧嘩の間一髪、いよ／＼掛て来れば五人でも十人でも投り出して殺して仕舞うと云う意気込が、先方の若武者共に分たか、何にも云わずに避けて通たと云う。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、仁科少佐がそう云うむずかしい、且つ危険な仕事に、間一髪と云う所で成功するには、いつも隠れた助力者があるのです。",
              "citation": {
                "source": "計略二重戦",
                "author": "少年密偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "森田思軒の「探偵ユーベル」、「間一髪」、原抱一庵の「女探偵」、徳冨蘆花の「外交奇譚」、黒岩涙香の「人外境」等。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
