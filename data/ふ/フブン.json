    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unwritten",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただ生来の不文のために我学界に礼を失するがごとき点があるかもしれないが、これについては単えに読者の寛容を祈る次第である。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし行文の間に少しでも臆断のにおいがあればそれは不文の結果である。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不文の中、ところどころ片仮名のページ、これ、わが身の被告、審判の庭、霏々たる雪におおわれ純白の鶴の雛一羽、やはり寒かろ、首筋ちぢめて童子の如く、甘えた語調、つぶらに澄める瞳、神をも恐れず、一点いつわらぬ陳述の心ゆえに、一字一字、目なれず綴りにくき煩瑣いとわず、かくは用いしものと知りたまえ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まだ、まだ、言いたいことがあるのですけれども、私の不文が貴下をして誤解させるのを恐れるのと、明日又かせがなければならぬ身の時間の都合で、今はこれをやめて雨天休業の時にでもゆっくり言わせて貰います。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不文、意をつくしませぬが、御判読下さいまし。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚、このたびは、『英雄文学』にいよいよ創作御執筆の由私の今月はじめの御注進、すこしは、お役に立ちましたことと存じ、以後も、ぬからず御報告申上べく、いつも、年がいなく騒ぎたて、私ひとり合点の不文、わけわからずとも、その辺よろしく御判読下さいまし。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "村人達はそれを聞いて、それはきっと例の狸だったろうと云って、其の行為を殊勝がったが、其の心が村人達をして狸には決して危害を加えまいという不文律をこしらえさせた。",
              "citation": {
                "source": "狸と俳人",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美津田氏は質直不文の人なれど、假名付の小説を能く讀みたり、其談話は一に記臆より出し故に、誤謬も多少有るべきと同時に、虚構潤色を加る事無しと知らる。",
              "citation": {
                "source": "秘魯國に漂著せる日本人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当を云うと編輯長以外の人間には、自分の書いた記事の内容を絶対に知らせないのが、新聞記者仲間の不文律なんだぜ、況んやその記事を取った筋道まで割って……」「イヤ。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来、不文律として存在していた書き手と編集者の原稿共有のルールが電子化で揺らぎ始めたと気づいたのは、何度か出版社相手に大立ち回りを演じてからだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "母方の御｜伯父は皆親王で実際の政治に携わることのできないのも不文律になっていたから、母宮をだけでも后の位に据えて置くことが若宮の強味になるであろうと思召して藤壺の宮を中宮に擬しておいでになった。",
              "citation": {
                "source": "源氏物語",
                "author": "紅葉賀",
                "note": "青空文庫"
              }
            },
            {
              "text": "則チ婦人ニ老親ヲ負擔セシメザルハ日本古來ノ不文律ニシテ同時ニ婦人々權ノ擁護ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "件のアントニウス尊者は紀州の徳本上人同様、不文の農家の出身で苦行専念でやり当てた異常の人物だ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日書物で読んでさも自分が煉り出したように、科学の学識のと誇る事どもも皆過去無数｜劫の間不文の衆人が徐々に観察し来った功績の積もった結果だから、読書しない人の言を軽んずべきでなく、未開半開人も驚くべき経験上の知識を持ち居る例多い。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もそれが村の不文律を裏切つた行為であるといふのを知らなかつた者である故、あたり前なら一先づ見逃さるべき筈だつたが、日頃から私の態度を目して「横風で生意気だ。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この言葉を浴せられた者は、手もなく一言の許に引きさがらざるを得ないといふ不文律が生ずるに至つたのである……。",
              "citation": {
                "source": "酒盗人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸時代には小説作者と狂言作者とのあいだに一種の不文律があって、非常に大当たりを取った小説は格別、普通は小説を劇化しない事になっていた。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もそれが村の不文律を裏切った行為であるというのを知らなかった者である故、あたり前なら一先ず見逃さるべきはずだったが、日頃から私の態度を目して「大風で生意気だ。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "異邦人のとりあつかひには多少の特別はあつたが、大体「Ｗ」大学の運動部では妻帯者は不文律的に存在しなかつた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "洛陽の酒徒は酒場に足を踏み入れると、先づ第一にバツカスの肖像画（或ひはイダーリア）に向つて脱帽をした後に、酒卓に就くといふのが古来からの不文律なのであつた。",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この新しい遊びは、次第に発展して自ずと様々な不文律が生ずるやうになつた。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは契約書にも明記されず、いわば不文律で、その額のごときも漁場主の一存に任せられているのだった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "文士だろうが不文士だろうが書いた事は書いた通り懸価のないところをかいたのである。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "天爵的に貴族となつた報に受る不文の刑罰である。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し右のような不文律がなければ、交際社会に出た許りの十七八の娘は、如何程危険に曝されなければならないか分りません。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちのことは子供仲間で解決つけて、大人の所へは持って行かないという不文律が支配しているのだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国の箇人的教育は、各種の箇性を重んじながら、其の功利主義の伝統的暗示、或は宣伝に依て、箇人的気質が、公衆の不文律に順応して行ける程度の寛和、或は弛緩を加えて居ります。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、まだ心得ておくべき、いろんな細かな不文律があつたのだ。",
              "citation": {
                "source": "飢ゑ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "教則の案は直ちに作って呈し、罰則は不文律となして、生徒に自力の徳教を誨えた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事にはじふぶんねんを入れ、ねだんもうんと安くしました。",
              "citation": {
                "source": "太一の靴は世界一",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
