[
  {
    "uuid": "76893182-7ad3-53d2-974e-a0f68d692556",
    "entry": "不文",
    "reading": {
      "primary": "ふぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞"
      ],
