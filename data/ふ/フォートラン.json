    "definitions": [
      {
        "index": 1,
        "gloss": "Fortran (programming language)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
