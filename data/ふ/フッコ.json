    "definitions": [
      {
        "index": 1,
        "gloss": "juvenile Japanese sea bass (usu. 2-3 years old and 30-60 cm in length)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ぼくは竿忠の三間、江戸前のフッコ竿を持って行ったが、重くってなかなか持ちきれない。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "フッコ釣りの早出に、舟宿へ行って泊まろうと、最終国電で酔って駅前までくると、非常警戒にぶつかった。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士劇場の自家用池で、二尺ぐらいの「フッコ」を釣ったことがある。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "池釣りで、フッコが釣れるのもおもしろい。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "中京ではフッコを「マダカ」という。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
