          "standard": [
            {
              "text": "国際司法裁判所は、国家間の領土問題を平和的に処理する紛争解決の場として機能している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "職場で発生した対人トラブルに対して、人事部が間に入って迅速な紛争解決を図った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "当事者同士の話し合いによる紛争解決が困難なため、第三者の調停委員に委ねることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "だが何かをしないことの言い訳に使っても、国際紛争解決の武力によらざる解決に立ち向かうジャンピング・ボードとして憲法九条を掲げようとする政治家は一人としていないのだな。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
