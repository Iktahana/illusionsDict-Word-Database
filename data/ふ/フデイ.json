        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "とうとうつかまって顔といわず着物といわずべとべとの腐泥を塗られてげらげら笑っている三十男の意気地なさをまざまざと眼底に刻みつけられたのは、誠に得難い教訓であった。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけで、もしも端れの一つに橋がなかったとすれば、その一劃は、腐泥のなかで、孤島のように泛びあがってしまうのだ。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔っているのは一時で、しらふでいるのは始終である。",
              "citation": {
                "source": "ひょっとこ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、しらふでいる時の平吉の方が、ほんとうの平吉のように思われるが、彼自身では妙にどっちとも云い兼ねる。",
              "citation": {
                "source": "ひょっとこ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが局長さんです」　と、奥の卓子の向ふでいま起ち上つた詰襟黒服の、なるほどお役人らしい一人を紹介してくれた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふでいふだけ出すわけぢやなからうが、人間はふと気前をみせたくなるものらしい。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "若旦那が鯱鉾立して喜ぶ話だと、見世であんなに、大きなせりふでいったじゃないか。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "その気になればしらふでいられる。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
