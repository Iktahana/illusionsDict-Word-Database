[
  {
    "uuid": "29ffe810-77d5-5ef7-97ef-83cfe4760b39",
    "entry": "普通に",
    "reading": {
      "primary": "ふつうに",
      "alternatives": [
        "フツーに"
      ],
      "is_heteronym": false
    },
    "grammar": {
