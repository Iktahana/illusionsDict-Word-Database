    "definitions": [
      {
        "index": 1,
        "gloss": "trapped with no way of escape",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
