[
  {
    "uuid": "1d313f11-f72a-5718-9e25-4dcdb63dc1b6",
    "entry": "深い",
    "reading": {
      "primary": "ふかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
