  {
    "uuid": "2280c7d6-3fa8-5fc8-b00b-3d3e2d984aa4",
    "entry": "府会",
    "reading": {
      "primary": "ふかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "prefectural assembly (in Kyoto or Osaka)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――政党出の府会議員――一雪の親だよ――その令嬢が、自分一人。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「せき込むなよ……という事も出来るし、亭主がまた髯を捻って、「先方御｜親父が、府会議員とごわすれば、直接に打附って見るも手廻しが早いでごわす。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "府会議員の邸と聞いたが、場処柄だろう、四枚格子の意気造り。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大久保知事は、遊廓問題について府会の十七人組の前で、二十八日迄に何とか考へると約束しながら、その英国の文豪と同じやうに何一つ考へなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小説の背景は、府会選挙に、労農党が勤労者の中から代表を立て、その応援の活動に空腹を忘れ、過労と不眠とをひきずって、私という女主人公も「髪の毛からは絶えず滴が落ち、ちゞみの浴衣をきた肩はぐっしょり濡れ」ながら働いた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "養子に行って、新井姓を名乗り、孝次という名であったが、これが秀才で、大阪谷町の薄病院の院長、大阪府会議長の薄恕一氏と、親友であり、早世して、非常に惜しまれたが、その為、この薄氏と親しくなり、殆ど育つか、育たぬか分らなかった私が、とにかく、四十三まで、生きて来られたのは、この人が居られたからである。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "南さんは私によく、「私の府会議員の叔父さんはおどけものですよ。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れが曾て東京府会の議員たるや、例に依りて放言高論動もすれば議場を悩殺せしめんとす然るに彼れは常に立憲大臣の心を以て、堂々たる議論を試みんとするの癖ありを抑へむとしたるに拘らず、彼れは傲然として飽くまで沼間と頡頏せむとせり※以て其抱負の凡ならざるを諒す可し。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が、それが果せる哉、多分にもれず家族主義的現代常識の所有者の集りである府会で問題になったという事件がある。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "府会議員の常識によると、個人主義が中心になっている市川氏の思想には、教育上不穏な個処が少なくないというのだそうだ。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又、某校長の懐中から部下の女教員から来た恋文が出たという話を披露した警視庁は、府会で、将来はこうした私行の暴露を慎む旨の、言質を取られている。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去よながいながい孤獨の影よその影を岩にひきずる冬の日の薄暗い濱邊に立つて意味のふかい人生を見る。",
              "citation": {
                "source": "眺望する",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い共同椅子森の中の小径にそうて、まつ白い共同椅子がならんでゐる、そこらはさむしい山の中で、たいそう緑のかげがふかい、あちらの森をすかしてみると、そこにもさみしい木立がみえて、上品な、まつしろな椅子の足がそろつてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことし、十二月下旬の或る霧のふかい夜に、この橋のたもとで異人の女の子がたくさんの乞食の群からひとり離れて佇んでいた。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、それだけのことであって、そのうえ女の子に就いてのふかい探索をして見ようとは思わない。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、校庭の砂山の陰に葉藏のおとなびた孤獨なすがたを見つけて、ひとしれずふかい溜息をついた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふかい朝霧の奧底に、海水がゆらゆらうごいてゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがある霧のふかい朝でした。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四）　八月のある霧のふかい晩でした。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれも霧のふかい時、度々山で遭ったことがある。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく意味ふかい一夜ではあつた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "×重荷おもくて唄うたふ　山頭火　　味取観音堂に於て松はみな枝垂れて南無観世音　耕畝久しぶりに掃く垣根の花が咲いてゐる　同ねむりふかい村を見おろし尿する　同（「三八九」第壱集　昭和六年二月二日発行）",
              "citation": {
                "source": "寝床〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の七夕夜景を見物して歩いた、提灯のほかげはまつたくうつくしい、親しみふかい日本美観である、なまじ近代風を加味したのはかへつて面白くない、それから河原へ行つた、たいへんな人出だ、果物店、氷店の羅列である、久しぶりに夜店風景を満喫した。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "小菊の姿にどこか哀れふかいところがあるので、石屋は色恋の沙汰を離れた気持で、附き合っているのだったが、それだけに小菊に人情も出て来るのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "小菊は遅くまで一晩話し、懐かしい浪の音を耳にしながら眠ったが、翌日は泳ぎ馴れた海を見に行き、馴染のふかい町の裏通りなど二人で見て歩き、山の観音へもお詣りして、山手の田圃なかの料理屋で、二人で銚子を取り食事をした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はその屋根屋根のしたの百万の一律な生活を思い、眼をつぶってふかい溜息を吐いたにちがいないのだ。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにやら罪ふかい結果が予想できるのであった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春としなれば山奧のふかい森の中でもくされた木株の中でもうごめくみみずのやうに私のたましひはぞくぞくとして菌を吹き出すたとへば毒だけ　へびだけ　べにひめぢのやうなものかかる菌の類はあやしげなる色香をはなちてひねもすさびしげに匂つてゐる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とざせる思想の底を割つてしづかにながれるいのちをかんずるあまりに憂鬱のなやみふかい沼の底からわづかに水のぬくめるやうにさしぐみはぢらひためらひきたれる春をかんずる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ながれてゐる哀傷の夢の影のふかいところで私はときがたい神祕をおもふ萬有の　生命の　本能の　孤獨なる永遠に永遠に孤獨なる　情緒のあまりに花やかなる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
