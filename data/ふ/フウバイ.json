          "literary": [
            {
              "text": "のみならず、開花期間もやっぱり煤煙が降り続いたので、風媒花の稲は滅茶滅茶だった。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる風媒花である。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹の花は皆風媒花に属すること他の禾本諸草の花に於けるが如し。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この様にこのススキの花は風媒花である。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソシテその結婚の月下氷人は風ダ、それでこんなのを風媒植物と称える。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風媒花というものは自分勝手な恋愛ができぬらしい。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
