[
  {
    "uuid": "280c38ae-9d83-556f-a247-402ba70a7056",
    "entry": "不悉",
    "reading": {
      "primary": "ふしつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Very Sincerely Yours",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "月や出でにし雪青み、　　　　をちこち犬の吠ゆるころ、舞ひを納めてひれふしつ、　　罪乞ふさまにみじろがず。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度だつて惡寒から熱、惡寒から熱といふしつきりなしのすきをねらつて――しかし今はもう惡寒はやみましたから御安心下さいまし――すきをねらつてといふよりもすきを掠奪して、よく手紙を書きます。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の母親は、二人ともつつましく行儀よく出来てゐる女同志で、自分の子たちもさういふしつけの宜い育て方をしましたので、二人の子達も子供らしい遊びもいたづらも相当に仕て居乍らよく子供に有がちな肉体的な暴露などはありませんでした。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことの愛の有様は、たとえば、みゆき、朝顔日記、めくらめっぽう雨の中、ふしつ、まろびつ、あと追うてゆく狂乱の姿である。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとに何といふしつつこいお天気でせうね。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常に無口で、穏かな無愛想を特徴とする主人に引きかへ、細君はやはり農家の出らしいが、早口にお世辞を云ひ、人の云ふことは半分も聴かず、決断のいることはみなこの細君の頭でといふしつかりもの。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "何といふしつとりと落着いた、真面目な女だらうと十吉は思ふ。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおりふしつぶさに申すべく候。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
