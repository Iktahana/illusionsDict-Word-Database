          "literary": [
            {
              "text": "久次郎どの如き言語道断の不埒者はもとより相手にはならない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "惣じてかかる場合、たといそれがしが其家譜代の郎党であって、忠義かねて知られたものにせよ、斯様の事を迂闊に云出さば、却って逆に不埒者に取って落され、辛き目に逢うは知れた事、世上に其｜例いくらも有り。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴様は警察の署長だな、署長ともあろう者が、その容は何事だ」「貴様は何人だ」「名を云う必要はない、その女を知っておる者だ」「では、貴様と、媾曳に来たところだな、この女は」「黙れ」「不埒者奴、貴様が黙れ」「何」　署長の右の手が動くと共に激しい音がして、壮い男はそのままに仰向けに倒れてしまった。",
              "citation": {
                "source": "警察署長",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに右近や左太夫などの不埒者のいるために、自分の勝利が、すべて不純の色彩を帯びるに至ったのだと思うと、彼は今右近と左太夫とに対し、旺然たる憎悪を感じ始めたのである。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなる替え難い浄財を尊き霊地に於てスリ取った不埒者匿うことが、何の慈悲じゃッ。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "上意にそむく不埒者、これが江戸に聞えなば島津七十三万石に傷がつき申そうぞ。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「不埒者たちめがっ。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻を盗んだ不埒者めがっ。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に、与市の家へは庄兵衛の使が来て、左様な不埒者の宿許へお冬を預けておくことは出来ぬというので、迎いの乗物にお冬を乗せて帰った。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その威厳におびやかされて不埒者の群れは喧嘩に負けた犬のように早々に逃げ帰った。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "神以て戀にあらずとは何處まで此父を袖になさんずる心ぞ、不埒者め。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、その腹黒い極悪な不埒者を馬蹄にかけたことは、私は善行だと思うねえ、君。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして不埒者の間ではそんな事は一層悪い事になるのだ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのここな不埒者様！",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、角右衛門はきびしく「これをその方は、誰の手から持って参った」「…………」「不埒者め。",
              "citation": {
                "source": "野槌の百",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大戦艦が一隻あれば不埒者をやっつけて、一カ月で片が付きますよ」「全くすごいお方だ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "年景はようやく気づいて、「ふッ、不埒者めッ。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく不埒者が心得違いをしたのでしょう。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふいに、「不埒者っ」　大きな声が風を割った。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「不埒者っ」　耳元の声に、あっと、びっくりして後ろへ手をやった時は、鬼藤次の背中は、もう地を摺って、何十尺もズルズル地上を引っ張られていた。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぐったわしはここにいる」「はい、いいえ……」「不埒者めがッ」　なんのこと、あべこべにまた叱られた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不埒者めが、はやく灯をつけい！",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不埒者の新九郎へ、かほどまでのお心づくし、徒やおろそかにお受けは致さぬ。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらが泥棒の手下になったら、おッ母さんが悲しむから、そんな者の屋敷へ、奉公はできない」「では、汝は茶わん屋捨次郎の家にいたことがあるのか」「どうして分ったかね」「茶わん屋へ押し入って、悪事をした渡辺天蔵は、いかにもわしの一族の者だが、わし自身は、そういう不埒者は捨ておかん。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウム、やはり例の賽銭荒しをする不埒者に相違なかろう」　武士はそういって、石神堂の中を検めた上、使いの者と最初の発見者へ向って、「よく知らせてくれた。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな不埒者は放ッてお置きになるがよろしい、聞けば、あの夜大事な神品を紛失したとか、不都合きわまる奴、すでに御隠家様のお耳にも這入って、放逐じゃとお怒りなされておる。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
