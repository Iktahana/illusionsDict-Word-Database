[
  {
    "uuid": "b5f772c0-ff60-514f-b718-d23bf3dcf5f4",
    "entry": "不可欠",
    "reading": {
      "primary": "ふかけつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
