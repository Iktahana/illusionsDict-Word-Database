        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私の口紅は街のフラッパーどもの額に支那流の卑しい装飾をつける。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "始め私は磨きの好い靴の先や洋装の裾のひらめきや、ずばずばしたもの云いに赫子を快活なフラッパーな文化的モダンガールだと思って好奇心を持った。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵のヴァンスも溌剌としたフラッパー〔おてんば娘〕に好かれそうなタイプでもなければ、ホームズやルパン型のジャイアントでもない。",
              "citation": {
                "source": "ヂユパンの癖とヴァンスの癖",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は思ふに、終戦後現れたフラッパーの中には案外この種の何も知らない女が相当数ゐるのではないかと考へてゐる。",
              "citation": {
                "source": "酒のあとさき",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "或日次の興行の稽古に取りかかった時、いつもならば亀子が得意でするフラッパーな娘の役割が千代子に振替えられた。",
              "citation": {
                "source": "心づくし",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一次大戦のために軍需工場で働いてとりあえず参政権において男性と対等となった女性たちは、資本主義の尖兵として、フラッパーにさせられてしまった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
