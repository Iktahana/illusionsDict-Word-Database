  {
    "uuid": "9bbde978-4e04-5100-9388-4ab3a33417f2",
    "entry": "ふけ",
    "reading": {
      "primary": "ふけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ending a round with less than 20 points",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お話したいことがあるのです」へんによそよそしい口調でそう言って鉛筆を取り直し、またスケッチにふけりはじめた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "問屋の菎蒻ぢやあるめいし、無價で蹈まれて間に合ふけえ』。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおかげで私は電車の中で難解の書物をゆっくり落ち付いて読みふける事ができる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "我武者羅に押通さうものなら、默つて聽いてはゐるが、『さういふけどなあ』とねちねちやつて來る。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒飮みといふものは醉つてつまらぬ事も言ふけれど、しかし、たいていは、このやうに罪の無いものである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし……物言ふけはひでない。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし白粉気のない顔の表情はどこかそこらの高等女学校生徒などと比べては年の割にふけて見えるのである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十三にしてはふけて見える。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『君はさういふけれど、人には好不好と云ふものがある、僕はかういふのが好きなのだから仕方が無いぢやないか』　と云ふならば、吾輩も一議なく石川君に同情して其歌を一種の創作と認むるに躊躇しないのである。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "又の年の秋、今日ぞこの頃など思ひ出る折しも、ある夜ふけて近き垣根のうちにさながらの声きこえ出ぬ。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が宿の大樹にはとまりてさへ鳴くものを、夜ふけ枕にこゝろし給へ。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の窓枠の中では、人は直立不動になつて何かを待つたり、物思ひにふけつたりする。",
              "citation": {
                "source": "窓",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は終日、彼女にあたえられた部屋で過去の瞑想にふけっているようであった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時から體が弱くて始終病床に臥せつたり、入院生活を送つたりした私は、十三四の頃から、病氣のなほりがけの徒然の時に、冒險小説などと一緒に、あの妙に好奇心を刺戟するやうな石版刷の毒々しい挿繪のある、外國の飜案物や花井お梅だの、五寸釘の虎吉だのと云つた實説物の安い探偵本を讀みふけつた。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜がふけるに従って、頭の上では、星が切れるように冴えかえった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺ゃ、まだ起られねえ」　晩が来ると、夜がふけるのを待たずに呉は出発した。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてただいろんな事を止め度もなく考えて、思いにふけったものです。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『もうよそう、あまりふけるから。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『そこで僕は今夜のような晩に独り夜ふけて燈に向かっているとこの生の孤立を感じて堪え難いほどの哀情を催して来る。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな空想にふけりながら自分は古来の日本画家の点呼をしているうちに、ひょっくり鳥羽僧正に逢着した。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜ふけに買物でもあるまい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜ふけに伺いまして、だしぬけにこんなことを申し上げるのも異なものでございますが、わたくしはこの御近所に居りますもので、昨晩不思議な夢を見ましたのでございます」「はあ」と、お徳も不思議そうに相手をいよいよ見つめた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが恐ろしさに、半分は夢中でそれからそれへと逃げ廻って、夜ふけを待って自分の家へこっそりと帰って来たらしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇三郎は家内のものに口止めをして、夜ふけを幸いに藤吉の死骸をおもてへ運んで、そっと江戸川へ捨てさせました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌女寿の家では夜がふけると、暗い稽古舞台の上で誰ともなしにとんとん足拍子を踏む音が微かに聞えるという薄気味の悪い噂が立った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "時候は盆前、娘の一周忌と、うまく道具が揃っているもんだから、夜ふけに水口からそっと忍び込んで、師匠を殺す、蛇をまき付ける。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは勿論幾日かの後に主人のあとを追ったが、その後も刑場あたりでは夜ふけに犬の悲しい啼き声がきこえるとかいう噂が伝えられて、通行の人々を恐れさせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めの三日は昼のうちに通っていたが、四日目からは奥の一と間で秘密の祈祷をうけることになって、夜ふけを待って通っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵から、夜ふけまで夜ッぴて立ちつくして、獲物は一匹もあがらなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
