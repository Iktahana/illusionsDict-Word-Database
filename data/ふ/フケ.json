[
  {
    "uuid": "369d0f73-73fe-5791-abf1-9931bdd17cdd",
    "entry": "老け",
    "reading": {
      "primary": "ふけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "aging",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "○ゾフィイは老けたる処女なり。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "令嬢には少し老けたる年配。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "時によっては、もっと老けて見え、場合によっては情熱的な壮年者にも見えるときもあった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オヤ好い月だね、田川さんお上がんなさいよ」という女は今年十九、歳には少し老けて見ゆる方なるがすらりとした姿の、気高い顔つき、髪は束髪に結んで身には洗曝の浴衣を着けて居る。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "水番というのか、銀杏返しに結った、年の老けた婦が、座蒲団を数だけ持って、先に立ってばたばた敷いてしまった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻と子のために、また多少は、俗世間への見栄のために、何もわからぬながら、ただ懸命に書いて、お金をもらって、いつとは無しに老けてしまった。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この写真は、甲府の武田神社で家内の弟が写してくれたものですが、さすがにもう、老けた顔になっていますね。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の寿命に相応わしい、嫁入り、子育て、老先の段取りなぞ地道に考えてもそれを別に年寄り染みた老け込みようとは自分でも覚えません。",
              "citation": {
                "source": "愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "姿も顔も窶れたから、ちと老けて見えるのであろうも知れぬ。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）髪はきれいに分け、まだはたち前なのに、三十にも見えるあの老けやうとネクタイの鼠縞。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "受話機を取ると、「もしもし、先生でいらっしゃいますか」　伊都子の声は電話でのせいか、老けて生真面目な声だった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十の声をきいてから永助の頬にはめきめき肉がついてふっくらとし、おまけに商売柄いつも剃り立ての鬚のあとが生々と青かったから、何か年より老けて見えていた。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十の持子は瞬間三十六の義枝より老けて見えた。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "年の割りに老けた若先生の近眼らしい眼から涙がポロリと落ちた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭を刈って顔を剃ったばかりなのに年が二つ位｜老けたような気がする。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほのぐらい電燈の下の青扇の顔は、おやと思ったほど老けて見えた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノンキ和尚の顔は、実は、お前の寝顔からヒントを得たのだ」「あなたの寝顔だって、ずいぶんお老けになりましてよ。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女盛りの妻の鏡子は、態と老けた髪かたちや身なりをして、老夫のお守りをしなければならなかった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し老けております」と云った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう五十ちかい筈なのに、少しも老けた気配が無い。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "英國の將校であるとも言はれ、名高い詩人であるとも言はれ、老けてゐるやうであるが、あれでまだ二十代だとも言はれ、軍事探偵であるとも言はれてゐた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国の将校であるとも言われ、名高い詩人であるとも言われ、老けているようであるが、あれでまだ二十代だとも言われ、軍事探偵であるとも言われていた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろ、急に老けた顔つきになりました。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私より一つ二つ年上だつた筈であるが、あまり老けてゐない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋がかりの下り口に、昨夜帳場に居た坊主頭の番頭と、女中｜頭か、それとも女房かと思う老けた婦と、もう一人の女中とが、といった形に顔を並べて、一団になってこなたを見た。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいに、老けて見えるほうでした。",
              "citation": {
                "source": "女類",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから私は五年間四国、九州と渡り歩き、めっきり老け込んでしまいました。",
              "citation": {
                "source": "貨幣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」急に老けた口調でそんな事を呟き、顔を伏せた。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お話したいことがあるのです」へんによそよそしい口調でそう言って鉛筆を取り直し、またスケッチにふけりはじめた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "問屋の菎蒻ぢやあるめいし、無價で蹈まれて間に合ふけえ』。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
