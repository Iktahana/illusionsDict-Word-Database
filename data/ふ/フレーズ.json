[
  {
    "uuid": "6260c52b-a28e-5f4b-b87f-f18d3493217a",
    "entry": "フレーズ",
    "reading": {
      "primary": "フレーズ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
