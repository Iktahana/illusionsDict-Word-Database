        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "凧のかげ夕方かけて読書かな夕立やかみなり走る隣ぐに沓かけや秋日にのびる馬の顔鯛の骨たたみにひらふ夜寒かな秋ふかき時計きざめり草の庵石垣に冬すみれ匂ひ別れけり　彼の俳句の風貌は、彼の人物と同じく粗剛で、田舎の手織木綿のやうに、極めて手触りがあらくゴツゴツしてゐる。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙万象の秋、人の心に食い込む秋思の傷みを咏じ尽して遺憾なく、かの芭蕉の名句「秋ふかき隣は何をする人ぞ」と双壁し、蕪村俳句中の一名句である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋ふかき隣は何をする人ぞ秋さびし手毎にむけや瓜茄子　芭蕉の心が傷んだものは、大宇宙の中に生存して孤独に弱々しく震えながら、葦のように生活している人間の果敢なさと悲しさだった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恩愛ふかき親に苦を増させて、我れは同じき地上に彷遑ん身の、取あやまちても天上は叶ひがたし。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "塔中秘事雪ふかきまぐさのはたけ、　　玉蜀黍畑｜漂雪は奔りて、丘裾の脱穀塔を、　　　　　　ぼうぼうとひらめき被ふ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代野蛮人といふ語の意義ふかきをおもふ。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑蔭朝の冷し肉は皿につめたくせりいはさかづきのふちにちちと鳴けり夏ふかきえにしだの葉影にかくれあづまやの籐椅子によりて二人なにをかたらむ。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅の花、常夏の花などにつけて、定基の母の歌をおこしたのに右衛門の返ししたのもあり、又右衛門の家に定基の母が宿って、夜ふかき月をながむるに虫の声のみして人皆寝しずまりたるに、「雲ゐにてながむるだにもあるものを袖にやどれる月を見るらむ」と老女の悲愴の感をのべたのがある。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのとがもないのに、わがいのちを断って見せるよりほかには意志表示の仕方を知らぬ怜悧なるがゆえに、慈愛ふかきがゆえに、一掬の清水ほど弱い、これら一むれの青年を、ふびんに思うよ。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三層の隅か、さは腐れたる黄金の縁の中、自鳴鐘の刻み……ものなべて悩ましさ、盲ひし少女のあたたかに匂ふかき感覚のゆめ、わかき日のその靄に音は響く、静こころなし。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものなべてさは妙に女の眼ざしあはれそが夢ふかき空色しつつ、にほやかになやましの思はうるむ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢ふかき黒髪の奥朱に喘ぐ紅玉ひとつ、これや、わが胸より落つるわかき血の燃る滴。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "色ふかき、ミラノのそらは日本のそれと似たれど、ここにして摘むによしなき素馨、海のあなたに接吻のかなしきもあり。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづこにかすずろげる春の暗示よ……陰影のそこここに、やや強く光｜劃りて息ふかき弧燈枯くさの園に歎けば、面黄なる病児幽かに照らされて迷ひわづらふ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十二年一月　　夜の官能湿潤ふかき藍色の夜の暗さ……酸のごとき星あかりさだかにはそれとわかねど濃く淡き溝渠の陰影に、青白き胞衣会社ほのかににほひ、※多く、而もみな閉したる真四角の煙艸工場の煙突の黒みより灰ばめる煤と湯気なびきちらぼふ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "湿潤ふかき藍色の夜の暗さ……かへりみすればいと黒く、はた、遠き橋のいくつのそのひとつ青うきしろひ、神経の衰弱にぞ絶間なく電車過ぎゆき、正面なる新橋の天鵝絨の空の深みにさまざまの電気燈の装飾、そを脱けて紫の弧燈にほやかにひとつ湿れる。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかはあれども、湿潤ふかき藍色の夜の暗さ……溝渠の闇の中病院の舟は消えゆき、青白き胞衣会社にほふあたりに、整はぬ鶯ぞしみらにも鳴きいでにける。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪縁のふかき恐怖もすすり泣けり。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に輪は点となり、うつくしき虫となり、光りつつ、熟視めつつ、その中の青く青く最も厚く光沢ふかき葉の中心にぢつと留まる。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒ふかき邪欲の谷に淫楽の蝮まとふ、はたや身は痺れとろけて断ちがたきほだしに悩む。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓地は薄黄の石だたみ、また、奥ふかき朴の門。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "微笑微笑はそよ風、かぎりなく果なきもの、奥ふかき湖のさざなみ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "築石や、棚畑や、ふかき昼を日の照り、時うつる、この片岨。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜ふかき墓地夜ふかき墓地に音して、ささとし、落つる花あり。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "築石や、棚畑や、ふかき晝を日の照り、時うつる、この片岨。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜ふかき野川の堰今朝もまた氷張りけり。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "風出でて山鳴ふかき日の暮は遥かに恋し海の汐鳴山上の黎明ひようひようと風吹きとほる山の秀は月かげ白し夜明けたらしも雪ふかき山の尾の上に啼く鶏の啼き応ふ鶏の声のしたしさ道のべの春きさらぎや多摩の山方、まだ寒き障子の内、人影の、手に織る機の、ていほろよ筬うつらしき。",
              "citation": {
                "source": "海阪",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "立枯並木の歌霜ふかき野川の堰、あはれよと今朝見に来れば、いつとなく水量涸れつつ、隙間なく氷張りけり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
