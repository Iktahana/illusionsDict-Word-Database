    "definitions": [
      {
        "index": 1,
        "gloss": "nightless gay quarters",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
