    "definitions": [
      {
        "index": 1,
        "gloss": "to run away (e.g. from work)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのおかげで私は電車の中で難解の書物をゆっくり落ち付いて読みふける事ができる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜がふけるに従って、頭の上では、星が切れるように冴えかえった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺ゃ、まだ起られねえ」　晩が来ると、夜がふけるのを待たずに呉は出発した。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『もうよそう、あまりふけるから。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌女寿の家では夜がふけると、暗い稽古舞台の上で誰ともなしにとんとん足拍子を踏む音が微かに聞えるという薄気味の悪い噂が立った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜ふけるまで隣の室で低い話し声が聞こえていました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィリアム・ジェームスの心理学の中に「音楽の享楽にふける事でさえも、その人が自分で演奏者であるか、あるいはその音楽を純理知的に受け入れるほどに音楽的の天賦を有するのでなければ、その人の人格をゆるめ弱めるという結果を生ずるだろう。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日の晩は雨でお流れになるかと思ったらみんな本館の大広間へ上がって夜ふけるまで踊り続けていた。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜のふけるに従って歌の表情が次第に生き生きした色彩を帯びて来た。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家事の手伝いも、花壇の手入れも、お琴の稽古も、弟の世話も、なんでも、みんな馬鹿らしく、父や母にかくれて、こっそり蓮葉な小説ばかり読みふけるようになりました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜がふけるとともにお客がぽつぽつ見えはじめた。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉藏は夜のふけるとともに、むつつりして來た。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに叔父さんもその希望が全くなくなったがために、ほとんど自棄を起こして酒も飲めば遊猟にもふける、どことなく自分までが狂気じみたふうになられた。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏になると裏の畑に縁台を持ち出して、そこで夜ふけるまで子供を肴にして酒をのんでいた。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸に一物ある夫婦は寝たふりをして夜のふけるのを待っていると、やがて子の刻の鐘がひびいた。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも僕の神経は過度に興奮してしまって、夜のふけるまで到底眠られなかった。",
              "citation": {
                "source": "河鹿",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は根気よく坐り込んで、夜のふけるのを待っていたが、やがて四ツ（午後十時）に近い頃までも彼らを驚かすような化け物は出なかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は暫らく私を見凝めるともなく、想いにふけるともなく捕えがたい視線をじっと釘づけにしていたが、やがていきなり歪んだ唇を痙攣させたかと思うと、「私の従兄弟が丁度お宅みたいなからだ恰好でしたけど、やっぱり肺でしたの」　膝を撫でながらいった。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人で夜のふけるのも忘れて話しあつた、愉快な一夜だつた、送つて街へ出かける、まるし食堂でビールを飲んで別れる。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれをながめながら、自分だけの思いにふけるのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "うろうろうろうろ読みふける。",
              "citation": {
                "source": "雌に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いにふける人たちは、これに気がつくこと、甚だおそい。",
              "citation": {
                "source": "女人創造",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいま、自分の創作年表とでも称すべき焼け残りの薄汚い手帳のペエジを繰りながら、さまざまの回想にふける。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思索にふけると称して、毛布にくるまって横たわり、いびきをかいている事あり。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん高級な読書の仕方は、鴎外でもジッドでも尾崎一雄でも、素直に読んで、そうして分相応にたのしみ、読み終えたら涼しげに古本屋へ持って行き、こんどは涙香の死美人と交換して来て、また、心ときめかせて読みふける。",
              "citation": {
                "source": "一歩前進二歩退却",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方がないので故｜郷に對して惜別の感慨にふけるといつたやうな目的で自轉車をひつぱり出した。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "久助君は、そんなことをくちに出していえば、ひとが一笑にふしてしまうことは知っていたので、ただじぶんひとりで空想にふけるだけであった。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども将軍家は、お破りになりながらも別段けはしいお顔をなさるわけではなく、例のやうに、白く光るお歯をちらと覗かせて美しくお笑ひになり、コノゴロ和歌ガワカツテ来マシタ　などとおつしやつて、またぼんやり物案じにふけるのでございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれ、きょうも高邁の瞑想にふけるか。",
              "citation": {
                "source": "失敗園",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七時三十分上野発の急行列車に乗つたのだが、夜のふけると共に、ひどく寒くなつて来た。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
