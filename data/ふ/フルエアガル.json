    "definitions": [
      {
        "index": 1,
        "gloss": "to tremble violently",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "葉子は新聞記者と聞くと、震え上がるほどいやな感じを受けた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時候も今日のように冬に入る初めでなく、陰暦の十一月ですから、筑波颪がまともに吹いて来て震え上がるほど寒い。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "熊手を拵えて売ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は隣の者にニャルラトホテプを見に行けと薦め、震え上がるのです。",
              "citation": {
                "source": "ニャルラトホテプ",
                "author": "NYARLATHOTEP",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉱山技術者として私は地質学をある程度知っており、これら石材は震え上がる位太古のものだということができます。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも震え上がる。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "震え上がるほどはにかみやだからね。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその水のつめたいのにふるえあがるように思いました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それですから、あなたとわたくしとが押掛けて行けば、こっちで何も云わなくっても、先方は脛に疵でふるえあがるんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれが拷問にかけられると、ふるえあがるから、吾等も白状するかと、ははははは。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "当てられて、織子、ふるえあがる）……熱も少しある。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺の子は馴れているからよかろうが、春があの水につかったら、いっぺんにふるえあがる。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャツ一枚でいるとふるえあがるようであった。",
              "citation": {
                "source": "八※岳登山記",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本だけではない、世界じゅうの人が、ふるえあがるような、おそろしいことになる。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、そうしてしばらく穴ぐらを見まわしているうちに、こんどは、いきなり背中につめたい水をかけられでもしたように、心の底からふるえあがるほどの、おそろしいことがおこりました。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、えたいのしれない、ふるえあがるような出来事でした。",
              "citation": {
                "source": "虎の牙",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京じゅうが、ふるえあがるような恐怖の仮面だ。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
