    "definitions": [
      {
        "index": 1,
        "gloss": "flexible-hours system",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
