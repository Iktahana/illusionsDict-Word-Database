        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "芭蕉の「菊の香や奈良には古き仏たち」と双絶する佳句であろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故にまた柚の花やゆかしき母屋の乾隅　と、古き先代の人が住んでる、昔々の懐かしい家の匂いを歌うのだった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに蕪村の俳句においては、すべてが魂の家郷を恋い、火の燃える炉辺を恋い、古き昔の子守歌と、母の懐袍を忍び泣くところの哀歌であった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに彼の抒情詩のリリシズムは、古き楽器の夜半に奏するセレネードで、侘しいオルゴールの音色に似ている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――郷土望景詩――家庭古き家の中に坐りて互に默しつつ語り合へり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古き家の中に坐りて脱るべき術もあらじかし。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "路上に行人は散らばり去り烈風は砂を卷けどもわが古き感情は叫びて止まず。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）わが家へと入りてみれば　　なごやかにうちまじりつつ秋の日の夕陽の丘か炊煙か　　　　われを暈めかすもののあり　　　　　　　　　　　　古き代の富みし館の　　　　　　　　　　カドリール　ゆらゆるスカーツ　　　　　　　　　　カドリール　ゆらゆるスカーツ　　　　　　何時の日か絶えんとはする　カドリール！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれに新しき衝動を与えるものは往々にして古き考えの余燼から産れ出るのである。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近の所謂「新しきもの」は、却つて大概この「古きもの」の半分の魅惑すらも有してゐない。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えらく、源叔父今はいかん、波の音ききつつ古き春の夜のこと思いて独り炉のかたわらに丸き目ふさぎてやあらん、あるいは幸助がことのみ思いつづけてやおらんと。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "よきあしきをいわず、ひたぶるに古きを守るは、学問の道には、いうかいなきわざなり。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（いな見よ東かれらこそ、　　　古き火薬を燃し了へぬ）うかべる雲をあざけりて、　　　ひとびと丘を奔せくだりけり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりかすかに舌打てば、　　ひとりは古きらしゃ鞄、黒きカードの面反りの、　　　わびしきものをとりいづる。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八重の雲遠くたゝへて、　　　西東はてをしらねば、白堊紀の古きわだつみ、　　　なほこゝにありわぶごとし。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩頸列西は箱ヶと毒ヶ森、　　　　　　　椀コ、南昌、東根の、古き岩頸の一列に、　　　　　　　氷霧あえかのまひるかな。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔古き勾当貞斎が〕古き勾当貞斎が、　　　　　　　いしぶみ低く垂れ覆ひ、雪の楓は暮れぞらに、　　　　　ひかり妖しく狎れにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔すゝきすがるゝ丘なみを〕すゝきすがるゝ丘なみを、　　にはかにわたる南かぜ、窪てふ窪はたちまちに、　　つめたき渦を噴きあげて、古きミネルヴァ神殿の、　　廃址のさまをなしたれば、ゲートルきりと頬かむりの、　　闘士嘉吉もしばらくは、萱のつぼけを負ひやめて、　　面あやしく立ちにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、安永中の続奥の細道には、――故将堂女体、甲胄を帯したる姿、いと珍らし、古き像にて、彩色の剥げて、下地なる胡粉の白く見えたるは。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古昔は水の清かりしをもて人の便とするところとなりて、住むもの自ら多かりけむ、この川筋には古き器物を出すこと多し。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "石浜神社は小社なれどもその古きをもて知られ、真先稲荷は社前に隅田川を控て、遥に上は水神の森鐘が淵のあたりより下は長堤十里白くして痕なき花の名所の向島を一望の中に収むるをもて名あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "茗渓より下○稲荷河岸は小船への乗り場揚り場として古き人の能く知るところにして、美倉橋下左衛門橋浅草橋柳橋附近には釣船網船その他の遊船宿多し。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ新しくて青き光失せぬ建仁寺籬折りまはしたる小さき坪の中に咲き出でたる、あるはまたよろづ黒みわたりたる古き大寺の書院の椽近く※ひこぼるゝなど、云ひがたき佳きおもむきあり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の後など古き茅屋の棟に咲ける、おもしろからずや。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "古き歌にいへるあやめはこれならずとかや。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゐのこ雲　蝶々雲は古き歌に見えたりや否や知らず、ゐのこ雲といへるは仲正の歌に見えたり。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそのような著しい地殻の古きずが現在の歪に対して時々過敏になりうるであろうと想像するのは単に無稽な空想とは言われないであろう。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その亭の庭にも草木茂み風ふき渡りてばうばうたれどもかのふるき待たれびとありやなしや。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゑせ歌人は、かゝる言葉のはたらきあるはたらきよりは、猶ふるき言葉のあたひ無きあたひを尊むべきものと思へるなるべし。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやしのなかにふるきりの、　つぶはだんだん大きくなり、　いまはしずくがポタリ」　霧がツイツイツイツイ降ってきて、あちこちの木からポタリッポタリッと雫の音がきこえてきました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
