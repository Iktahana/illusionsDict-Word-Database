    "definitions": [
      {
        "index": 1,
        "gloss": "(pent-up) anger",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
