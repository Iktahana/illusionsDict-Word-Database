[
  {
    "uuid": "f7d13df3-d7cb-552b-9758-264fdaf8ae71",
    "entry": "不図",
    "reading": {
      "primary": "ふと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
