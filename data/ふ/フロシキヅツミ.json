    "definitions": [
      {
        "index": 1,
        "gloss": "something wrapped in a furoshiki",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
