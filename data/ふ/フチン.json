[
  {
    "uuid": "4f7118ef-c406-530c-81b9-0cca8a1f6c55",
    "entry": "浮沈",
    "reading": {
      "primary": "ふちん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "floating and sinking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "リンカーンはたった三冊の書物によってかれの全性格を造り上げたという記事が強く自分を感動させたのであったが、この事実は書物の洪水の中に浮沈する現在の青少年への気付け薬になるかもしれない。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのしっかりした根本方針を握って浮沈の多い世の中に処して行きたい。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に浮沈室と機關室とは此艇の最も主要なる部分ではあるが、此事に就いては殘念ながら私の誓に對して一言も明言する事は出來ぬ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗り合いは再び地上の瀾に盪られて、浮沈の憂き目に遭いぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂イブセンの書いたもの抔は先ず吾人の一生の浮沈に関する様な非常な大問題をつらまえて来て其問題の解決がしてある。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一世の浮沈問題が持ち上がって来る。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うものは凡て是等の現象界の奥に自己の本体はあって、此流俗と浮沈するのは徹底に浮沈するのではない。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく冗談半分に浮沈して居るのである。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八年の永い間、逸作に倣ってわたくしは実家のいかな盛衰にもあらわな情を見せまいとし、父はまた、父の肩に剰る一家の浮沈に力足らず、わたくしの喜憂に同ずることが出来なかった。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どつちからいつても早く夫の性分のマニアを癒して、家庭的の常識人になつて貰ふことは一家の浮沈にも係る大事であつた。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一家の浮沈と云ったような場合ですからね。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生の浮沈というものは一向に測りがたいものではあるが、とにかく今の私は平穏である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "埋火をかき起して炉辺再びにぎはしく、少婦は我と車夫との為に新飯を炊ぎ、老婆は寝衣のまゝに我が傍にありて、一枚の渋団扇に清風をあほりつゝ、我が七年の浮沈を問へり。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "少婦も出で来り、当時の主人なる無口男も席に進みて、或は旧時の田花の今は已に寡婦になりしを語り、或は近家の興廃浮沈に説き及び、或は我が棲むところを問ひなどしつ、この夜の興味は抹すべからざる我生涯の幻夢なるべし。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五にして苦海に堕ち、それより浮沈隆替の跡は種々に異なれども、要するに色を売る歴史のみにして、恋を談ずる者にあらず。",
              "citation": {
                "source": "「伽羅枕」及び「新葉末集」",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文藝春秋」の愛読者諸君も此の仕事は仕事としては、僕が一世一代の仕事であり、文藝春秋社の浮沈の分るゝころでもあるから、ぜひ充分なる理解と声援との下に、小学生の子女弟妹のある方は、もれなく予約していたゞきたいと思ふ。",
              "citation": {
                "source": "小学生全集に就て（再び）",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛、閭里間に浮沈す。",
              "citation": {
                "source": "失うた帳面を記憶力で書き復した人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "品夫の一生の浮沈にかかわる事ですから……」　しかし黒木はどこまでも真面目な、無表情のうちにうなずいた。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十三　その物腰と風采は、人形町の頃よりも、三ツ四ツ年紀もたけ、※たさも、なお増りながら、やや人に馴れ、世に馴れて、その芥溜といえりし間、浮世のなみに浮沈みの、さすらいの消息の、ほぼ伝えらるるものがあったのである。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "家浮沈の問題たる前途の考えも、措き難い目前の仕事に逐われてはそのままになる。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一家浮沈の問題たる前途の考も措き難い目前の仕事に逐はれては其儘になる。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠に一家浮沈、親子四人の運命が手古奈の心一つで定まるのであるから、萬一にも心得違があつてはならないとの意を繰返された。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此度右衞門佐も自分も江戸に召されるからは、黒田家の浮沈に及ぶ事がないには限らぬ、さやうの場合には此書附を持つて江戸に出て、土井、井伊、酒井三閣老の中へ差し出されいと云つた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "恥を言はんければ解らんけれど、この借金は遊佐君には荷が勝過ぎてゐるので、利を入れるだけでも方が付かんのだから、長くこれを背負つてゐた日には、体も一所に沈没して了ふばかり、実に一身の浮沈に関る大事なので、僕等も非常に心配してゐるやうなものの、力が足らんで如何とも手の着けやうが無い。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうぢやらう、学士になるか、高利貸になるかと云ふ一身の浮沈の場合に、何等の相談も為んのみか、それなり失踪して了うたのは何処が親友なのか」　その常に慙ぢかつ悔る一事を責められては、癒えざる痍をも割るる心地して、彼は苦しげに容を歛め、声をも出さでゐたり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "前面には江ノ島の列島波間に浮沈し、手をのばさば、之を捫すべし。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾艘の小端艇岸邊に横はり、鳰點々蕁菜の間に浮沈す。",
              "citation": {
                "source": "白河の七日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
