        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「フォア、ピーク（おもての空気室――船の云わば浮嚢――）のガットを開けろ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、少しでも吐いたり、下したりする者があったら、皆フォアピークへ入れるんだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォアピークは、水火夫室の下の倉庫の、も一つ下にあった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "斜向うのイギリス銀行、ロイド・ナショナル・プロヴィンシアル・バンクの支店から出て来た髭の生えたプラスフォアのイギリス人が日当りの好さそうな卓を選んで席を取った。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「サモア史」の完結で、愈々、「デイヴィッド・バルフォア」に専念できる。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（尤も、割に良く読まれているというから不思議だが）「デイヴィッド・バルフォア」こそは「マァスタア・オヴ・バラントレエ」以来の作品となり得よう。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月××日「デイヴィッド・バルフォア」漸く快調。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月××日「デイヴィッド・バルフォア」漸く仕上。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「デイヴィッド・バルフォア」に就いては、大体満足。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「デイヴィッド・バルフォア」の校正刷、未だに送って来ない。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃彼のことを戯れにデイヴィ（バルフォア）と呼ぶことにしている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カトリオーナ」（デイヴィッド・バルフォアの改題）の方が不評で、あんな作品の方が売れるなどとは、皮肉だが、兎に角余り絶望しないで二番芽生を待つことにしよう。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "イン、ザ、ウィンドウ、イッツ、シャイニング、フォア、ミイ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お友達……フォア、ザ、ボーイ、シー、イズ、ロンギイン、ツウ、シイー……」頭を、コクリコクリとうなずきながら、「もう、ご飯食べないわよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それもキラいじゃないけど、ブラザース・フォアとか、キングストン・トリオとか」「ラジオで聴いたことある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "首吊りの話」　柾生は、ブラザーズ・フォアの〈｜七つの水仙〉と、ＰＰＭの〈パフ〉も好きな曲にあげた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "不安になった慶一は、となりのブラザーズ・フォア・ファンに、「なあ、いま、おれ、永遠が見えた」　と小声で話しかけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "待てよ、あとが〈アイ・ニード・ユー〉で、そのつぎが〈ザ・ナイト・ビフォア〉で、それから〈アナザー・ガール〉か……うん、ジョンのリードは前半ばっかだ」「でしょう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ナンバ・フォア、味噌汁スリイ願います。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『海苔まきフォア・六人！",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ずこの廊下あたりがフォアイエエになっている。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に英國では、この問題が尤も憂慮せられて、バルフォア（Balfour）やラクーペリ（Lacouperie）の如き學者は、前後してロンドンの『タイムス』紙上に、英國の外務省が支那政府に交渉して、この碑を英國博物館に引き取るべしといふ希望を披瀝した（39）。",
              "citation": {
                "source": "大秦景教流行中國碑に就いて",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした夕食後の一刻を、やはり新人の為、仲間はずれになっている、ＫＯのフォアァの補欠で、銀座ボオイの綽名のある、村川と、一等船客専用のＡ甲板を――Ａデッキを練習以外には使うな、などという規則が守られていたのは、初めの二三日でした。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時の彼は、非人間的と云うまでの禁欲主義者であり、或時の彼は力を讚美するドンフォアンである。",
              "citation": {
                "source": "日記",
                "author": "一九二〇年（大正九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "前首相バルフォアの如きは二、三種の哲学書を著している。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャバレのビッグ・フォアでしたよ、実はそのときは田川君が連れていってくれたんですがね」「わたくしもそうなんです」「え。",
              "citation": {
                "source": "千早館の迷路",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何がそうなんです」「田鶴子さんに初めて紹介されたのが、ビッグ・フォアだったんです。",
              "citation": {
                "source": "千早館の迷路",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
