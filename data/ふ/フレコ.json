    "definitions": [
      {
        "index": 1,
        "gloss": "friend code (number used to identify a user on Nintendo consoles)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
