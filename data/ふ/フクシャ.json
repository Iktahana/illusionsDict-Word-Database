[
  {
    "uuid": "6d83fd26-efc4-5cd4-8520-58095c545ae0",
    "entry": "伏射",
    "reading": {
      "primary": "ふくしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "shooting lying prone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "更に一人は漢江の辺に多くの高い棚を築き、上から伏射すれば敵は上る事が出来ないであろうと進言した。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本市街を過ぎる中に私の心を寒くしたのは、砲兵が野砲を挽いて行軍し、大街の要所要所に歩兵が伏射の形で銃を擬し、また各所で工兵が堅固な角材で鹿柴を組み立ててゐる事であつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、中隊長は直に、「伏せッ」　と命じたので、皆は伏射ちの構えして次の命令を待った。",
              "citation": {
                "source": "戦争雑記",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "×中隊ならびに、×中隊は全員が負傷の様子であります……」　中隊長は、近づき来る約一個中隊ばかりの黒影を見遣りながら、決心したらしく、「伏射の構え」を命じて、自分も指揮刀を握り直して伏した。",
              "citation": {
                "source": "戦争雑記",
                "author": "徳永直",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
