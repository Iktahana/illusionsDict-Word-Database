          "literary": [
            {
              "text": "そして何故、そんなうつけたやうな目ざしで、丈の高いフロックスの花のまはりを飛んでゐる一匹の蝶を見つめ出してゐるのか？",
              "citation": {
                "source": "或外國の公園で",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼の目はとうとう大きなフロックスの花のあたりを飛びまはつてゐる一匹の蝶を追ひはじめる。",
              "citation": {
                "source": "或外國の公園で",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はおうちでフロックスの花を買った。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブロアが窓の下にいて、庭師のクレッグが新種のフロックスを手入れしているかなあ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
