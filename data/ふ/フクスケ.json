    },
    "definitions": [
      {
        "index": 1,
        "gloss": "large-headed dwarf statue, bringer of good luck",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "煉瓦塀に春を発見した福助人形の影法師孤児の下駄が置き忘れてありました公園の入口ペンキのはげた立札心よ！",
              "citation": {
                "source": "（風船玉の衝突）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "福助座が見たいと思つた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "福助座は私がゐた当時の、金沢第一等の劇場であつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "このはかない行商の一人に頭蓋骨の異常に大きな福助のような子がいた。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と侍女は仔細らしく小声になり、「福助がもう来ます時分、ここにいらっしゃると見落しますよ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "団十郎、菊五郎、左団次は勿論、家橘、芝翫、高助、福助、秀調、海老蔵、小団次、松助に、大阪方の璃寛、右団次を加えたる大一座にて、俳優の共進会と称せらる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十年（丁亥）　一八八七○三月、中村福助の人気頂上に達し、新富、市村、千歳の三座かけ持ちにて出勤。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "団十郎、芝翫、福助、我童、権十郎、松之助ら出勤。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十三年（庚寅）　一八九〇○一月、団十郎は京都花見小路の祇園館に乗込み、大阪の鴈治郎、福助らと合同して開演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月一日、日本橋区久松町に新築中の明治座落成して、その舞台開きを行い、左団次、権十郎、小団次、米蔵、福助、団十郎ら出勤。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○七月、歌舞伎座にて菊五郎、福助らが「小猿七之助」を上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁慶は団十郎、義経は福助。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○五月、中村福助は養父の名を継ぎて五代目中村芝翫と改名し、歌舞伎座の中幕に「楼門」の石川五右衛門を勤む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○五月、大阪より高砂屋福助父子上京して、市村座出勤。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "神棚には福助が乗ツかゝツてゐて、箪笥の上には大きな招猫と、色が褪めて凋んだやうになつて見える造花の花籠とが乗りかツてゐた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "微塵棒を縦にして、前歯でへし折って噛りながら、縁台の前へにょっきりと、吹矢が当って出たような福助頭に向う顱巻。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、串戯じゃない――店ざらしの福助の置物という処が、硝子箱の菊慈童と早がわりをしているんだ。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、店の隅なる釣棚の高い処に、出額で下睨みをしながら、きょとりと円い目をして、くすりと笑う……大な、古い、張子の福助を見た。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "色は兀げたが、活きているようで、――（先には店頭にあったのだと後で聞いた）――息子は好男子なのに、……八郎の言った福助の意味も分ったが、どこに居ても、真夜中には、ふッと抜けて、屋の棟へちょんと乗って、ここの一家を守りでもしそうで、且つ何となく、不気味だった。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中仕切――本格子の板戸を隔てて立った首が、ちょうど棚の福助どのと合った時、失礼だが、私はその女房が化けたかと思った。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の迷と思ったが、実はお悦が八郎を引ぱたいた瞬間にも、舞台の端をちょこちょこと古い福助が駈けて通った。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「来た、来た、来た、また来た、煩い、煩いッてば、チョッ福助。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　八郎さんの奥さんに――いいえ、先生、それは大丈夫でしょうと思います……昔から、あの、店の、紅屋の福助の人形に邪魔をされますから。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞く処に従うと、紅屋の内儀の貞操は、かかって、おでこの古福助の煤の頭にある。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いうまでもなく、その御堂裏は浅草の中心で、軒を並べているものはことごとく見せ物小屋ばかり――福助小僧の見せ物があるかと思うと、玉ころがしにそら吹けやれ吹けの吹き矢があって、秩父の大蛇に八幡手品師、軽わざ乗りの看板があるかと思えば、その隣にはさるしばいの小屋が軒をつらねているといったぐあいでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝床の上にふいっと起き上がってね、福助の頭はどうしてあんなにでけえだろうな、とこんなにいうんですよ」「…………」「だから、あっしゃ少しかんしゃくが起きてね、まじめくさってバカげたことをいうな、たこの頭はもっとでけえじゃねえかといったら、かわいいやつでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫は太宰の息女｜雛鳥で、中村｜福助である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずかに生き残るものは福助の歌右衛門だけである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊五郎は藤吉郎と馬丁幸吉の二タ役をつとめ、家橘（羽左衛門の父）が大内蔵、福助（歌右衛門）が小染を勤め、これも役々の評判がよかった。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時は中幕に「鎌倉三代記」が出て、菊五郎の三浦、福助の時姫、芝翫の佐々木という顔揃いで、それも一つの呼び物となった為か、興行成績は頗る好かった。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
