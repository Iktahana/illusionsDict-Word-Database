[
  {
    "uuid": "729d1f0c-3250-5db8-938a-43c8e05b1648",
    "entry": "福助",
    "reading": {
      "primary": "ふくすけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
