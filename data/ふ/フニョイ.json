[
  {
    "uuid": "5fc67830-0751-5379-9433-c800fff42c3d",
    "entry": "不如意",
    "reading": {
      "primary": "ふにょい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
