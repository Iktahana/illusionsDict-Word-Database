    "definitions": [
      {
        "index": 1,
        "gloss": "sliced vegetables pickled in soy sauce",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
