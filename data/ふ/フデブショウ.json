    "definitions": [
      {
        "index": 1,
        "gloss": "poor correspondent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "筆不精の私は、未だにお礼状も何も差し上げていない仕末ですが、こないだの三宅島爆発では、さぞ難儀をなさったろうと思いながら、これまたれいの筆不精でお見舞い状も差し上げず、東京の作家というものは、ずいぶん義理知らずだと王様も呆れていらっしゃるだろうと思います。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が平生の筆不精を知っている私は、別にそれを怪しみもしなかった。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンは遠いし、おれは筆不精でね。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど悪筆の筆不精故、悪いとは思いながらついサボってしまいますのよ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "方向転換　筆不精なばかりでなしに、手紙などというものを書いたことのない健が、思い出して、フト七之助に手紙を書いた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし同氏はどっちかというと、筆不精の方に属している。",
              "citation": {
                "source": "探偵小説を作って貰い度い人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは筆不精ではないが、手紙不精で、親戚故舊に不沙汰ばかりしてゐるので、讀んで此に到つた時壽阿彌のコルレスポンダンスの範圍に驚かされた。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆不精な人であるのに海外の寂しい生活の行爲か、長い手紙であつた。",
              "citation": {
                "source": "永井荷風といふ男",
                "author": "生田葵山",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆不精の父をして書かしめた。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆不精の父様が長い手紙を、書ぎらひなはぼがあれだけ書いて下さる。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のお正月に景気を添える一助になるなら筆不精をおしても年賀状は大いに書くべきで、私も来年はそうしてみようかなぞと考えたりしたが、この考えが来年の正月まで持つかどうか怪しいものだ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁清の陶器は繊細な意匠において断然頭角を表わしているが、乾山は大まかな筆不精なズバッとした優美な意匠において、空前絶後の腕前を発揮していると言えよう。",
              "citation": {
                "source": "乾山の陶器",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、いろんなことがぶきつちようだし、よく物忘れはなさるし、筆不精で、どこへも手紙の返事はお出しにならないし……。",
              "citation": {
                "source": "雪だるまの幻想（ラジオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "文筆商売の人間は筆不精で、実用記事以外書けないから、時候見舞の返事は書けないのだよ」　と答えておいた。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思いながら私も長らく筆不精に過ぎた。",
              "citation": {
                "source": "思い出す職人",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしの筆不精がその原因かしら」　温室の出来たことを保がよろこんでいる気持は、伸子にも思いやられた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例によって筆不精ですからね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃になって、自分の生活事情や性格というものに及んでも考えますが、私は十年前の旅行のとき何と筆不精だったでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その悲惨な短命は老父に報告すべき筋合いでもなかったし、筆不精なわたくしは詳しい通知もしなかったのに、季節が偶々早春梅花の候であったためであろう。",
              "citation": {
                "source": "幽香嬰女伝",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の筆不精からであったが、一つは躯を悪くして生活が順調に行っていなかったので、つい便りをする気にならなかった。",
              "citation": {
                "source": "風貌",
                "author": "――太宰治のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその便りを太宰さんにしようと思いながら、筆不精からつい億劫にしていた。",
              "citation": {
                "source": "風貌",
                "author": "――太宰治のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "気不精、筆不精というものは仕方のないものである。",
              "citation": {
                "source": "風貌",
                "author": "――太宰治のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も雪子も姉ほどではないが手紙を書くことを大層がる方なので、いつもの筆不精をきめているのであろうし、それに、定まった自分の部屋と云うものがないのでは、落ち着いて物を書くことも出来ないであろうと思えもした。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の筆不精は君も知っている。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
