    "definitions": [
      {
        "index": 1,
        "gloss": "failure (e.g. of a bill, motion)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
