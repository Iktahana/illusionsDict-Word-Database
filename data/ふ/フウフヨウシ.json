    "definitions": [
      {
        "index": 1,
        "gloss": "adopting a married couple",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
