        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "所が、朝からの吹き降りで、日が暮れると警報の出た暴風雨である。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何にしろ、あの吹き降りに国境を見て来たんだからね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝からの吹き降りが夕暮時から小雨に変る。",
              "citation": {
                "source": "五月のはじめ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯台の光りが暗い空に閃光をまたゝかせて、今宵はまた急に春とも思へぬ霙まぢりの吹き降りである。",
              "citation": {
                "source": "痩身記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことを書いてゐるうちに、吹き降りの夜があけると、磯の方から出船の貝笛の音が聞えて来る。",
              "citation": {
                "source": "痩身記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして荷物があらかた片づいた所で、ある夜おそく、しかもびしょびしょと吹き降りのする寒い雨風のおりを選んで葉子は幌車に乗った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしい吹き降りになっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい吹き降りの中に夜が来た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも強い吹き降りであつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "地震日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その日は朝から雪で、午過ぎからは風が加わって吹き降りにかわっていた。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気は強い吹き降りの雨に満ちている。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒドイ吹き降りで一人もお客のない晩だったわ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雨を衝いて水門に駆けつけた雪太郎が、こんな花束が流れて来たと云つて、私に、全く私の知らぬ名前の花束を渡したが、私はそんなものを験める気分もなく、ぼんやりと窓に凭つて、爽烈な吹き降りの野末をひろく見渡してゐた。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "小畑が熊谷からやって来るという便があったが、運わるく日曜が激しい吹き降りなので、郁治と二人｜樋から雨滴れが滝のように落ちる暗い窓の下で暮らした。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は雲の切れめこそ見えるが、急に吹き降りの大粒な雨が落ちる。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、またおほ吹き降りがあつたが、第二のトンネルを通り拔けると、もう、石狩の國へ這入つたので、汽車は細いナラ、カシハ、ハンの木、松や清い小流れの間をそろ／＼とくだり出すのである。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい荒れと吹き降りじゃございませんか……。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、ひどい吹き降りになった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝からかなりひどい吹き降りである。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡は吹き降りの雨をじいつと眺めながら、ゆき子の泣き声を聞いてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆき子は外套をぬぎ、宿の褞袍を肩に引つかけて、吹き降りの廊下の外を眺めた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなところで、二日も泊つてゐるのは退屈だつたが、船が出ないのならば仕方がないと、富岡も廊下に出て、吹き降りの海上を眺めた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大忠岳へ着いた時は、相当の吹き降りになつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、あの吹き降りです。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が午頃からふり出した雨に風が加わって、宅の近くへ参りました時には、たたきつけるような吹き降りでございます。",
              "citation": {
                "source": "二つの手紙",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいにくの吹き降りで、不二見村の往還から寺の門まで行く路が、文字通りくつを没するほどぬかっていたが、その春雨にぬれた大覇王樹が、青い杓子をべたべたのばしながら、もの静かな庫裡を後ろにして、夏目先生の「草枕」の一節を思い出させたのは、今でも歴々と覚えている。",
              "citation": {
                "source": "樗牛の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい吹き降りである。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る大変吹き降りのする日に、学校から帰ると母の止めるのもきかずに合羽を着小さい奴傘を差して病院に出かけた。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝目ざめるとひどい吹き降りだった。",
              "citation": {
                "source": "石ころ路",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ可なり吹き降りの中を、お馨さんによく似た十四五、十一二の少女が、片手に足駄を提げ、頭から肩掛をかぶり、跣足で小学校に出かけて行く。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
