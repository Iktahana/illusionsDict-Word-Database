          "standard": [],
          "literary": [
            {
              "text": "また此外に矢張りこれも同級の男で野崎というのがありましたが、此野崎の家は明神前で袋物などをも商う傍、貸本屋を渡世にして居ました。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうものの並んでいる間に散点してまた実に昔のままの日本を代表する塩煎餅屋や袋物屋や芸者屋の立派に生存しているのもやはり印画記録の価値が充分にある。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家人は着物を着かえながら、お金は失礼ゆえ、そのうち私が東京へ出て袋物かなにかのお品を、と言ったが、私は、お金のほうがいいのだ、と言って、二円、家人に手渡した。",
              "citation": {
                "source": "めくら草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸利、丸上、山田屋等の袋物店に払う紙入、煙草入の代は莫大であった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "売薬や袋物を売ったり、下駄屋や差配人をして生活を営んでる傍ら小遣取りに小説を書いていたのを知っていた、今日でこそ渠等の名は幕府の御老中より高く聞えてるが其生存中は袋物屋の旦那であった、下駄屋さんであった、差配の凸凹爺であった。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠等が幅を利かすは本屋や遊里や一つ仲間の遊民に対する場合だけであって、社会的には袋物屋さん下駄屋さん差配さんたるより外仕方が無かったのである。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯うなると文人は袋物屋さんや下駄屋さんや差配人さんを理想とせずとも済む。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "小生は文学論をするツモリで無いから文学其物に就ては余り多くを云うを好まぬが、二十五年前には道楽であった文学が今日では職業となり、最早袋物屋さん下駄屋さん差配人さんを理想としないでも済むようになった事実を見て、職業としての文学が最う少し重くなければならぬ。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙入や銭入も決して袋物屋の出来合を使わないで、手近にあり合せた袋で間に合わしていた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "師匠の許へは米沢町の沢田という袋物屋から種々貿易向きの注文が来て、その方がなかなか多忙しくなる。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "脂土や石膏に心を惹かれたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、或る日、前に話した袋物屋の、米沢町の沢田銀次郎が訪ねて来ました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "牙彫りを排し木彫りに固執したはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらの袋物屋に賣つてゐるか。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝兼さんの他に、手数将棋の強かつた人に、京橋八丁堀の袋物屋の主人で中村といふ人がゐた。",
              "citation": {
                "source": "手数将棋",
                "author": "関根金次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう風の一家の事情｜故、その暫く前から奉公に出ていた袋物屋を暇取って兼松は家へ帰って来ました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "私の父祖のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "お庄は母親が、売るものと持って行くものとを、丹念に選り分けて、しまったり出したりしている傍に座り込んで、これまでに見たこともない小片や袋物、古い押し絵、珊瑚球のような物を、不思議そうに選り出しては弄っていた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の父親は袋物の職人で、家は新右衛門町の裏店にあった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――これ美味しいわね、どこの」「河村のんどっせ」　章子と東京の袋物の話など始めた女将の、大柄ななりに干からびたような反歯の顔を見ているうちに、ひろ子は或ることから一種のユーモアを感じおかしくなって来た。",
              "citation": {
                "source": "高台寺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四条通りには、袋物や古本の夜店がよう出ました。",
              "citation": {
                "source": "わが母を語る",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "又次の日には千登世と二人で造花や袋物の賃仕事を見つけようと芝や青山の方まで駈け廻つて、結局は失望して、さうして濕つぽい夜更けの風の吹いて來る暗い濠端の客の少い電車の中に互ひの肩と肩とを凭せ合つて引つ返して來るのであつた。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここがせんべの売りどころという、塩せんべの田丸屋や袋物屋の平野屋など有名である。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この帯安のほかに袋物専門の鈴仙商店と京橋の老舗玉井屋あたりの番頭なども根気よく未だに通いつめているようである。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、去来する思ひが――たとへば、袋物工場に通つてゐた母親が、夜も休まず石油の空箱を台にして（その箱の隅には小さな蜘蛛が綿屑みたいな巣をかけてゐた！",
              "citation": {
                "source": "釜ヶ崎",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天野さんの――化粧品問屋――×さんはおとなしく、金物問屋のおぬひちゃん、袋物問屋のおよしさんその他の人たちも醜いのはなかった。",
              "citation": {
                "source": "明治座今昔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "袋物商の娘だったので、袋ものをキチンとつくった。",
              "citation": {
                "source": "テンコツさん一家",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
