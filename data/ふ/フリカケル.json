[
  {
    "uuid": "12c15ff4-2b8a-5028-870a-f8f89baa57ac",
    "entry": "振りかける",
    "reading": {
      "primary": "ふりかける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
