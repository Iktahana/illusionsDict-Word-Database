        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "裸足で薊を踏んづける！",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に朝鮮人は親方、棒頭からも、同じ仲間の土方（日本人の）からも「踏んづける」ような待遇をうけていた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "著ている燕尾服が熊の毛色そのままで、袖も長ければズボンも長く、おまけに鰐足でドタバタと外輪に歩いて始終、他人の足を踏んづけるのだから、いよいよ熊そっくりということになる。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "チチコフはこの男が他人の足をよく踏んづける癖のあることを知っていたので、出来るだけ自分の足許に気をつけて、なるべく相手を先きに立たせるようにした。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありていに云えば、マニ教を蹴とばし、神様を踏んづける力が欲しかったのである。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "棒で打つ、足で踏んづける、靴で踏みにじる。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とイワン・ドミートリッチはそろそろだだを捏ねはじめた、「一歩あるけば、きっと紙屑を踏んづけるんだ。",
              "citation": {
                "source": "富籤",
                "author": "ВЫИГРЫШНЫЙ　БИЛЕТ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しかし踏んづける事もなかろう。",
              "citation": {
                "source": "夜の道づれ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時はまた、見物は闇の通路で、何かしらグニャグニャした大きなものを踏んづけるのである。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、彼女達には、自分達の父の死骸を踏んづけることが、どんなことかということすら分かっていない！",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、影はいって、エナメルのくつをはいた足をのばすと、学者の足もとに、むく犬のようにうずくまっているしんまいの影の腕に、力いっぱいふんづけるように、それをのせました。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、つい足でふんづけるまでにしながらみつけることができませんでした。",
              "citation": {
                "source": "しっかり者のすずの兵隊",
                "author": "DEN STANDHAFTIGE TINSOLDAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はなんだかいやな氣がして、その女から眼をそらしながら、ふとその眼を私がときどきふんづける小さな軟かなものの方へ持つて行くと、それが三鞭酒の栓らしいことを認めた。",
              "citation": {
                "source": "旅の繪",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "金殿玉楼では亭主関白の膳部のかたわらに女房が給仕に侍し、裏長屋ではガラッ八の野郎が女房お梅をふんづける。",
              "citation": {
                "source": "天皇陛下にさゝぐる言葉",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（さつきの紳士のやうに、犬の糞でもふんづけるといけませんよ。",
              "citation": {
                "source": "CARTE POSTALE",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもわず魚のようなものをふんづける。",
              "citation": {
                "source": "ルウベンスの偽画",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はなんだかいやな気がして、その女から眼をそらしながら、ふとその眼を私がときどきふんづける小さな軟かなものの方へ持って行くと、それが三鞭酒の栓らしいことを認めた。",
              "citation": {
                "source": "旅の絵",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "コウーラッ」　ドシン／＼とふんづける。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "（２）うそ泣きなのか　セイウチさん　　　子どもよりも　大食らいして　　　ぼくらはただの薬味かよ　　　ごめんなさい　ああ（セイウチうめく）　　　あ　こんにゃろめ　ああ　　　できるのは　ふんづけることだけ　座り込む二匹のカキ、そこへ三匹目が登場。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもはず魚のやうなものをふんづける。",
              "citation": {
                "source": "ルウベンスの僞畫",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お内儀といふ人もよい人だから、借金をふんづけるわけに行かない、きれいに片をつけたいといつたが、その金高は打木田の持つてゐる金の二倍も上の金だつた。",
              "citation": {
                "source": "汽車で逢つた女",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも同じコバルト行きの患者なのに押し退けて乗ってゆく奴なのだ、こんな病院の中にいてさえ先を争い、相手をふんづけることで神経の上にその影響を感じないということが、この男のしたたかな気性を知ることが出来る。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、さっきもいったように、おこじょを追っかける、熊の糞をふんづける……雪渓ですべることが恐怖よりも先ず哄笑を惹き起したような、ほがらかな健康に充ちた気持の一行だった。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんながいちどに、はんたいがわのドアのほうへおしよせたので、人と人とが、かさなりあい、おされて、倒れるもの、倒れた上を、ふんづけるもの、キャーッ、という女の悲鳴、子どもの泣き声、列車の中は、恐ろしいさわぎになりました。",
              "citation": {
                "source": "黄金豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、だから、そのでっかい足で、いろんなものを、ふんづけるはずじゃないかい。",
              "citation": {
                "source": "天空の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
