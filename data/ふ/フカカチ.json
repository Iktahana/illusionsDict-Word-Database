          "standard": [],
          "literary": [
            {
              "text": "世界市場では、結局足元を食い荒らされた互換勢力を引き込むリスクを承知でこの道を選んだ以上、日本ＩＢＭは気合いを込めた高付加価値マシンをぶつけてくるに違いない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡＭＤには低消費電力という付加価値もあるという話なので、ノートブックではこれが生きるかも知れない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "集積度の高い高付加価値の集積回路は、相変らずセラミックスが押さえていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
