        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "或ときイギリスのシェフィールドといふ町の警察へ、一人の泥棒未遂の犯人があげられました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ブラックスフィールド」？",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）早い話が、俺にデイヴィッド・カパァフィールドが書けるか、どうか、考えて見た。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国人で五十歳ぐらいの背の高い肥ったそしてあまり品のよくないブラムフィールド君が独唱をやると、その歌はだれでも知っているのだと見えて聴衆がみんないっしょに歌い出してせっかくの独唱はさんざんに押しつぶされてしまった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラムフィールドという名前がこの人とこの小事件とになんとなく調和していると思った。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の父はチェスタフィールドで学校長をしていて、そこで僕もすぐれた教育を受けました。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "サリィの方はペッカム、メイフィールド・プレイス三の下宿におります。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも「フィールド・オブ・ドリームズ」なんて映画を見たせいだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず、オレが何でここまで「フィールド・オブ・ドリームズ」にはまりこんだかからかたづけよう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フィールド・オブ・ドリームズ」のテーマを二十五字以内で述べよと言われたら、どう答えよう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八六五年板、シーフィールドの『夢の文献および奇事』二巻附録夢占字典にいわく、女がバシリスクを産むと男が夢みればその男に不吉だが、女がかかる夢を見れば大吉で、その女富み栄え衆人に愛され為すところ成就せざるなしと。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、それじゃあ、なんでお前さんはスプリングフィールドの一件でここにぶちこまれたっていうんだ。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "所長さん、スプリングフィールドになんて行ったことないですって。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんせ、スプリングフィールドが強く言いやがるもんだから、知事だってもうすぐで思いとどまるとこだったんだ。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "スプリングフィールドの一件で知り尽くしていた。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に更に偉大なる研究のフィールドがこれを緒としてひらけて来るであろうと思った。",
              "citation": {
                "source": "科学者と夜店商人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はその時、丈の高い色の黒い男と連立っていて、二人はエリジアン・フィールドの休憩茶屋へ行ったというのである。",
              "citation": {
                "source": "「マリー・ロオジェ事件」の研究",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰色のチェスターフィールドを脱いで、一振り振って投げた時はいつもよりよほど重く感じた。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロザリーは、英国のイボッツフィールドの教区長の末娘に生れました。",
              "citation": {
                "source": "「母の膝の上に」（紹介並短評）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンのパウンス伯母は、すぐイボッツフィールドに自身で来、ロザリーをあずかってロンドンで修業させてやることに定めました。",
              "citation": {
                "source": "「母の膝の上に」（紹介並短評）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は比類のない婦人事務家としてフィールド銀行に持っていた地位を惜しげもなくすて、子供達を自分で見て行く決心をしたのです。",
              "citation": {
                "source": "「母の膝の上に」（紹介並短評）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィールド銀行と云うものが、又ロザリーの心に這入って来ました。",
              "citation": {
                "source": "「母の膝の上に」（紹介並短評）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が天の命に背いたのでした」　彼女は、ドラの没くなった翌朝、フィールド銀行に辞職届をかきました。",
              "citation": {
                "source": "「母の膝の上に」（紹介並短評）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国では、マクドナルド労働党内閣は婦人労働大臣にミス・ボンフィールドを任命していた。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の婦人参政運動者をよろこばせた婦人労働大臣ミス・ボンフィールドはどうなっただろうか。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョウジ・エリオット、ジェーン・オースティン、マンスフィールドその他の作家を近い先輩としてもっているイギリスで、ウルフが婦人の生活と文学の問題を考えたとき、希望するのが、このような条件であるということは、現代のヨーロッパ「文明」が婦人にとってなおどういうものであるかということを深刻に考えさせる。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミス　コーフィールドに電話で歎願して、パリセードに行く。",
              "citation": {
                "source": "「黄銅時代」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Central Park を抜けてミス　コーフィールドまで歩き、彼女をつれて、Mrs Sho の処へ行き、部屋を見、かえりに二人でコスモポリタンクラブへ行く。",
              "citation": {
                "source": "「黄銅時代」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえりに、ベルギー人のオーツ（青木の仏語の先生）と四人でコーフィールドの家へ来て、話す。",
              "citation": {
                "source": "「黄銅時代」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミス　コーフィールドの意地悪。",
              "citation": {
                "source": "「黄銅時代」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
