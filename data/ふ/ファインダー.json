        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "少なくともオレはこうした手帳の電子化のコンセプトにのらないので（そんなものはパワーブックにメモリをぶち込んで、マルチファインダー下でハイパーカードを走らせればたくさんだ）、興味はない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんと書いてあるから」　高志は、ふたりのあいだにある、木のテーブルに両ひじをのせ、ファインダー越しにこたえる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けっこう、むずかしいもんだな」　カメラのグリップをにぎった山崎が、ファインダーをのぞくために曲げていた腰を伸ばした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "モニターの画像に納得したワラが、山崎をわきに押しやり、ファインダーをのぞきこむ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が二寸方形位の写真のファインダーを、自分で造って持っている事から、私は気附いたのであるが、彼は自然大の自然物よりも、此のファインダーの擦り硝子へ映る小さい影像の方に、何れ程愛着しているか分らない。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼の造った汚いファインダーを借りて、彼の姿を覗いた事がある。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本で開かれた「パーソナルコンピュータの未来像」におけるケイの講演によれば、このシステムはのちにリサとマッキントッシュのファインダーを開発したブルース・ホーンが、一五歳のときにパロアルト研究所で書いたものであるという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファインダーをのぞきながら盛んにその辺を歩きまわり、ピシとシャッターを動かして、　――｜よし！",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれが、回転するフィルムのふるえを頬に感じながらファインダーを覗く時、胸をうつ一種の吸引は、その新しき視線への崩るるごとき没入としも思われる。",
              "citation": {
                "source": "レンズとフィルム",
                "author": "――それも一つの性格である――",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれが回転するフィルムのふるえを頬に感じながら、ファインダーを覗く時、胸をうつ一種の吸引は、その新しき視線への崩るるごとき没入としも思われる。",
              "citation": {
                "source": "物理的集団的性格",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちに――伸子の見おろしている窓の側に横顔を見せて、金髪の若ものが、写真機を両手の間にもって、一心にファインダーをのぞいているところだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファインダーをのぞいている金髪の青年が、何か云って、右手で合図した。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファインダーをのぞきこんでいた青年は、しきりに苦心中らしかったが、遂に彼がその顔をあげて何かいうと、娘たちは、ひどく笑い出した。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォーカスをＴＣＬ方式オートの状態にし、後ろを振り返って可変ビューファインダーを覗き込むと、東京駅の赤レンガの部分だけがすっぽり画面に入っている。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "隼人は８ミリビデオカメラの可変ビューファインダーを覗き込んだ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ただそのポッチを押せばいいんです」　五郎はカメラを眼に持って行き、ファインダーの真中に丹尾を置いた。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コノ写真機ハレンズガ暗ク、レンジ・ファインダーガ付イテイナイノデ、目測デ写サナケレバナラズ、僕ノヨウナ未熟ナモノガ撮ッタノデハピンボケニナリヤスイ。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞之助も、席を捜している時間がないので、立っている人々の肩の間から覗いていたが、ふと気が付くと、一間ばかり離れたところに、見物人の最後列に立って、ライカを舞台の方に向けて、ファインダーに顔を押し着けている男のいるのが、板倉に紛れもなかった。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウクレレのかたわらに片膝をついた僕は、一眼レフのファインダーごしに、真上からウクレレを見下ろした。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファインダーの横長の視界の片側に正方形を想定し、その正方形の対角線上に、ウクレレの全長を収めてみた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェニファーは、興奮するとカメラのファインダーをのぞくのを忘れ、あたりを跳びまわる。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムーヴィ・カメラのファインダー・アイピースを目のなかに埋めこむようにして、僕は絶体絶命の悲鳴をあげた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファインダーから僕は目をはなした。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はファインダーから目を離した。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのままカメラを動かさずに見ていれば、彼のチューブ・ライディングのすべてが見える」　ラインハートは、ファインダーに目を押しつけていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファインダーから目を離して立ちあがり、僕に顔を向けたラインハートは、「なんというパフォーマンスなんだ！",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファインダーから目を離し、僕は上体をのばした。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "素晴らしいシークエンスが、ワン・ショットで撮れた」　僕はファインダーをのぞいていただけだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「今日のようで充分です」　写真機を手にした原田は、ファインダーごしに直子を見た。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
