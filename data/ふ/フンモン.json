          "literary": [
            {
              "text": "そのとたんである、どたんと足を投出す音といっしょに、千蔵の胃の噴門部のあたりでぷつんとなにかが千切れ、「ぶれい者」という叫びが口を衝いて出た。",
              "citation": {
                "source": "評釈勘忍記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウシや他の反芻動物ヒツジなどのこぶ胃（噴門洞）に住んでいる微生物はとくに活性が強かった。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
