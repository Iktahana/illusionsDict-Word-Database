[
  {
    "uuid": "4549086d-3822-5287-9654-5c21faa08597",
    "entry": "不敗",
    "reading": {
      "primary": "ふはい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
