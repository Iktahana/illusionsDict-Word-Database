[
  {
    "uuid": "dd7de401-e7fc-5347-82b9-5c57dfae9d16",
    "entry": "雰囲気",
    "reading": {
      "primary": "ふんいき",
      "alternatives": [
        "ふいんき"
      ],
      "is_heteronym": false
    },
    "grammar": {
