    "definitions": [
      {
        "index": 1,
        "gloss": "lightly (floating, drifting, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただ鏡がものを映し窓掛けが風にふわふわ動く。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日はやや西に傾いて赤とんぼの羽がきらきらと光り、風なきに風あるがごとくふわふわと飛んでいる、老人は目をしばたたいてそれをながめている、見るともなしに見ている。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれてから一度も寝たことのない衾や蒲団の柔か味が、却ってかれに異様の肌障りをあたえて、ふわふわと宙に浮いているような一種の不安を感じさせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "午頃の蔭もささぬ柳の葉に、ふわふわと柔い風が懸る。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが舞台へ懸る途端に、ふわふわと幕を落す。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたをあけて見ると腐ったような水の底に鉄釘の曲がったのや折れたのやそのほかいろいろの鉄くずがいっぱいはいっていて、それが、水酸化鉄であろうか、ふわふわした黄赤色の泥のようなものにおおわれていた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな場合になってしまうと、私は糸の切れた紙凧のようにふわふわ生家へ吹きもどされる。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザラメがみんな、ふわふわのお菓子になるねえ、だから火がよく燃えればいいんだよ。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　山男がこんなことをぼんやり考えていますと、その澄み切った碧いそらをふわふわうるんだ雲が、あてもなく東の方へ飛んで行きました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私とて同じこと、どこまで行っても真白でふわふわと、頼り無い白雲のなかに、眼も体もやすめようとする所もなく、疲れはてて仕舞った時、ひとりでに私の首が下を向き、翼をやすめるに屈竟な黒く落ち付いた土の底が、はっきり見えましたので、急いで茲まで降りて参りました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "処へ、ふわふわと橙色が露われた。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "〕（恁くして、一人一人、枝々より梟の呼び取る方に、ふわふわとおびき入れらる。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、」といいながら勇美子は立って、室を横ぎり、床柱に黒塗の手提の採集筒と一所にある白金巾の前懸を取って、襟へあてて、ふわふわと胸膝を包んだ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と考えが道草の蝶に誘われて、ふわふわと玉の緒が菜の花ぞいに伸びた処を、風もないのに、颯とばかり、横合から雪の腕、緋の襟で、つと爪尖を反らして足を踏伸ばした姿が、真黒な馬に乗って、蒼空を飜然と飛び、帽子の廂を掠めるばかり、大波を乗って、一跨ぎに紅の虹を躍り越えたものがある。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見た処でも、しょんぼりした脚にも気が入っているようですけれど、今しがたは、すっかり魂を抜き取られて、ふわふわ浮き上って、あのまま、鳥か、蝶々にでもなりそうですね。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　山男がこんなことをぼんやり考へてゐますと、その澄み切つた碧いそらをふわふわうるんだ雲が、あてもなく東の方へ飛んで行きました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザラメがみんな、ふわふわのお菓子になるねえ、だから火がよく燃えればいゝんだよ。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と大声に喚立つれば、ここの夫人も辟易して、休息所へふいと立つ時、「おっ、臭え、ふわふわ湯具を蹴出すない。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねつけ蜻蛉が、ふわふわと、その時立ったが、蚊帳に、ひき誘われたようにふわりと寄ると、思いなしか、中すいて、塔婆に映って、白粉をちらりと染めると、唇かと見えて、すっと糸を引くように、櫺子の丸窓を竹深く消えたのである。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "色をかえて、人あしの橋に乱るるとともに、低く包んだ朝霧を浮いて、ひらひらと散ったのは、黒い羽にふわふわと皆その霧を被った幾十百ともない、おびただしい、おなじかねつけ蜻蛉であった。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉱蔵　（ふわふわと軽く詰め寄り、コツコツと杖を叩いて）血迷うな！",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃い靄が、重り重り、汽車と諸ともに駈りながら、その百鬼夜行の、ふわふわと明けゆく空に、消際らしい顔で、硝子窓を覗いて、「もう！",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子は、半分気味の悪そうに狐に魅まれでもしたように掌に受けると――二人を、山裾のこの坂口まで、導いて、上へ指さしをした――その来た時とおんなじに妹の手を引いて、少しせき足にあの径を、何だか、ふわふわと浮いて行く。",
              "citation": {
                "source": "若菜のうち",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、紅また薄紅、うつくしい小さな天女の、水晶の翼は、きらきらと輝くのだけれど、もう冬で……遊びも闌に、恍惚したらしく、夢をうように、ふわふわと浮きつ、沈みつ、漾いつ。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆、咄嗟の間、ですが、その、廻っている乳が、ふわふわと浮いて、滑らかに白く、一列に並んだように思う……（心配しないでね。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふわふわと海月泳ぎに、船を浮かせながらゆっくり遣るべい。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "映る手なんざ、水へ突込んでるように、畝ったこの筋までが蒼白く透通って、各自の顔は、皆その熟した真桑瓜に目鼻がついたように黄色くなったのを、見合せて、呼吸を詰める、とふわふわと浮いて出て、その晩の座がしらという、一番強がった男の膝へ、ふッと乗ったことがあるんですね。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さしたての潮が澄んでいるから差し覗くとよく分かった――幼児の拳ほどで、ふわふわと泡を束ねた形。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「待てよ」　獲物を、と立って橋の詰へ寄って行く、とふわふわと着いて来て、板と蘆の根の行き逢った隅へ、足近く、ついと来たが、蟹の穴か、蘆の根か、ぶくぶく白泡が立ったのを、ひょい、と気なしに被ったらしい。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶えず続いて、音色は替っても、囃子は留まらず、行交う船脚は水に流れ、蜘蛛手に、角ぐむ蘆の根を潜って、消えるかとすれば、ふわふわと浮く。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
