[
  {
    "uuid": "952a5cd5-feac-5330-8ad7-b2ba5db70d88",
    "entry": "不退",
    "reading": {
      "primary": "ふたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
