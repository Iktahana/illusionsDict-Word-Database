[
  {
    "uuid": "eeb3a4c1-7e66-51f5-a5a7-e1a76f5d98ad",
    "entry": "憤慨",
    "reading": {
      "primary": "ふんがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
