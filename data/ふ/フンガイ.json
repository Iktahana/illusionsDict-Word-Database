      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "indignation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やさしくすれば、諛ふと取られ、ひどくすれば憤慨したとなる。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれを憤慨しているが、むしろ彼の真の怒りは基督教に向っていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより郷里の事情も知らぬではないがあまりに薄情だと思って一時はひどく憤慨し人非人のように罵ってもみた。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢瀉久孝博士をして「何デー」「何デー」「ナンデイ」「ナンデイ」「ナニヲ云ッテヤガルンデイ」、日の神の「日」という美しい言葉を持ちながら何を苦しんで「デー」などという紅毛の国のダミ言葉を使うのかと憤慨させるのも誠に道理がある。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧水氏はそれを憤慨してゐたけれども、あの粗野な風采と態度を考へ、僕はユーモラスの微笑を禁じ得なかつた。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の前席に向き合つてゐた尾崎喜八君が、突然何かのことで憤慨し始めた。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　が、彼は、軍隊の要領は心得ていたので、本当の自分の心持は、誰れにも喋らず、偽札に憤慨したという噂は、流れ拡がるにまかせて、知らん顔をしていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ、これらの作家の小説と並んでその傍に、二、三行で報道されている、××の仕打ちに憤慨して銃を自分の口にあてゝ足で引金を踏んで自殺したという兵卒の記事（明治二十八年一月中央新聞）の方が、はるかに深い暗示に富んでいる。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "脚気は戦地病であるが、一兵卒の死だって、もっとその原因を深く追求すれば、憤慨に値することに突きあたらざるを得ないのである。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」健二はひとりで憤慨する口吻になった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これではまるで土方か牛殺しと同等であると言って少しばかり憤慨したのであった。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "憤慨もまた度を越すと、滑稽に止揚するものらしい。",
              "citation": {
                "source": "『玩具』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は憤慨に堪えなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "村は、歓喜の頂上にある者も、憤慨せる者も、口惜しがっている者も、すべてが悉く高い崖の上から、深い谷間の底へ突き落されてしまった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑稽な話だけど、なんだかその窓口へ立つのが癪で憤慨していると、Ｏがまたその中へ入ってもう一つの窓口を占領してしまった。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばかめ、こんな爺さんを掴めえて、剣突もすさまじいや、なんだと思っていやがんでえ、こう指一本でも指してみろ、今じゃおいらが後見だ」　憤慨と、軽侮と、怨恨とを満たしたる、視線の赴くところ、麹町一番町英国公使館の土塀のあたりを、柳の木立ちに隠見して、角燈あり、南をさして行く。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここではワグネル物をたとえば四幕のものなら二幕ぐらいに切って演じたり、勝手な事をすると言ってひどく憤慨していました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中でいちばん年とった純下町型のＹどんは時々露骨に性的な話題を持ち出して若い文学少年たちから憤慨排斥された。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり言わば某陶工が帝展において金牌を獲たときにその作品に使われた陶土の採掘者が「あれはおれが骨折って掘ってやった土をそっくりそのまま使って、そうした金牌をせしめておきながら涼しい顔をしている」と言って憤慨するのと似たことが実際にしばしば起こるのである。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるなどというもののあるのはいったい不都合だと言って憤慨してみたところで世界じゅうのさるを絶滅することはむつかしい。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある友人は国辱中の大国辱だと言って憤慨している。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地駄太踏んで憤慨したが、当の相手は五、六丈上方に天険を控えて待構えている。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "▲憤慨また憤慨　脚下に轟々たる水声を聞き、雲に懸けたかと思わる、絶壁の中腹の危うき桟道を越えて行くことしばらくにして、右手に全山｜悉く岩石より成る山を見る。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにおいて将軍大いに憤慨し「こんな不親切極まる旅館へは宿らんでもよい。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四）変な駄洒落　憤慨ばかりが能ではあるまいから、一つ汽車中の駄洒落を御愛嬌に記そう。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩は敢て重い荷物を担がせられたから憤慨するのではないが、一国の生命は地方人士の朴直勤勉なる精神にありとさえいわれているのに、その地方人士の一部がかくも懦弱にして狡猾なる気風に向いつつあるのは、実に痛嘆すべき次第である。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "潰されたままにたいした憤慨もせずに平伏してゐざりよる。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と掏摸だになお憤慨の色を表わせり。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな行者などを信仰するのは間違っていると、要次郎は蔭でしきりに憤慨していたが、周囲の力に圧せられて、かれはおめおめそれに服従するのほかはなかった。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にふんがいにたえない。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
