    "definitions": [
      {
        "index": 1,
        "gloss": "two rooms",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "良いお天気で、幅二間程の、下高井戸駅通りは秋の日をうけて黄色く乾いてゐる。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ思いが、仲間の顔色に読まれる、飯を炊くのに、未だ時間がある、思い切って天幕から一、二間歩き出した、岩を二ツ三ツ飛び越えて、次第に爪先が上る、無辺無限の単調の線が、どこへ繋がって、どこへ懸っているのか、解らない……やはりあの空線の一つを辿っている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「家は腰高の塗骨障子を境にして居間と台所との二間のみなれど竹の濡縁の外には聊かなる小庭ありと覚しく、手水鉢のほとりより竹の板目には蔦をからませ、高く釣りたる棚の上には植木鉢を置きたるに、猶表側の見付を見れば入口の庇、戸袋、板目なぞも狭き処を皆それぞれに意匠して網代、船板、洒竹などを用ゐ云々」。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから遂に二間半程ある竹の棹の先に三四尺の糸を結びつけ、其糸の端に古釘の大きいやつをくゝりつけた。",
              "citation": {
                "source": "井戸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は民さん一寸御出でと無理に背戸へ引張って行って、二間梯子を二人で荷い出し、柿の木へ掛けたのを民子に抑えさせ、僕が登って柿を六個許りとる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　私はそのころ下宿屋住まいでしたが、なにぶん不自由で困りますからいろいろ人に頼んで、ついに田口という人の二階二間を借り、衣食いっさいのことを任すことにしました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "道幅二間ばかりの寂しい町で、（産婆）と書いた軒燈が二階造の家の前に点ている計りで、暗夜なら真闇黒な筋である。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "師匠の家にはお浚いの床があるだろう」　師匠の家は四畳半と六畳の二間で、奥の横六畳に二間の床があると松吉は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はやっともうあと二間ほどのところではじめてそれに気がついたらしく、立ち留った。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二間余りの間である。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその二間余りが尽きてしまった所は高い石崖の鼻であった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖は二間、それくらいであった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂の書附には故将堂とあり、大さ纔に二間四方許の小堂なり、本尊だに右の如くなれば、此小堂の破損はいふ迄もなし、やう／＼に縁にあがり見るに、内に仏とてもなく、唯婦人の甲胄して長刀を持ちたる木像二つを安置せり。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また二間ばかりの竿では、此処では鉤先が好い魚の廻るべきところに達しない。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し気の毒なような感じがせぬではなかったが、これが少年でなくて大人であったなら疾くに自分は言出すはずのことだったから、仕方がないと自分に決めて、　兄さん、済まないけれどもネ、お前の坐っているところを、右へでも左へでも宜いから、一間半か二間ばかり退いておくれでないか。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の竿では其処に坐っていても別に甲斐があるものでもないし、かえって二間ばかり左へ寄って、それ其処に小さい渦が出来ているあの渦の下端を釣った方が得がありそうに思うよ。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "二間だけの住居らしい。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二番と十三番のお二間になっております」「……ありがとう……」　教えられた通りに青年は二階へ上った。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "暢気な奴等だ」　電灯を消した八畳と十畳の二間をブッ通して寝床が五つ、一列に取ってある。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "松嶺院では階下にも広い座敷がいくつもありましたが、若し止宿者が来た時お互に迷惑になってはいけないと思って、孤立した二階の二間を借りました。",
              "citation": {
                "source": "●「或る女」巻頭のホイットマンの詩",
                "author": "\"Not till the sun excludes you, do I exclude you;",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は同宿人のゐないことが、つまり六畳と三畳二間きりのその二階が私一人のものであることが、どんなに嬉しかつたか知れはしない。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ羽目板だけれども、足数七八つ、二間ばかり奥へ入った処に、仇白くなって字が見える、………紙が歩行いた勘定だわねえ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二間三間、段々に次第に奧へ深く成ると……燈火の白き影ほのかにさして、目の前へ、颯と紅の簾が靡く、花の霞に入る心地。",
              "citation": {
                "source": "麥搗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "垣根の長さは十二間はたしかにあったでしょう。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つばかりの階段を上つた処が廻り縁になつて居て、中は四間の奥行二間許りの板敷がある。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "（少し離れて、もう少し、立った爪尖まで、全身がはっきり映るまで、）とさしずをされて、さあ……一間半、二間足らず離れたろうか。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "中二階の六疊を中にはさんで、梯子段が分れて二階が二間、八疊と十疊――ざつとこの間取りで、なかんづくその中二階の青すだれに、紫の總のしつとりした岐阜提灯が淺葱にすくのに、湯上りの浴衣がうつる。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪をおとして立つ鳥に、　　　妻がけはひのしるければ、仄かに笑まふたまゆらを、　　松は畳めり風のそら。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは雑朶の細枝のふたまたになって居る岐れめに何かの虫が附けた玉子から、至極｜巧に、中味の虫の子が脱け出したあとの、可愛い笛の様な音を立てる小さな穴の一つあいた、かやの紅さし指のあたま位いな、貝のように硬い滑かな、灰色に白い斑の付いた殻であった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と大酒飮んで、醉ふたまきれに「乃公なんかは近い内に大仕事があるのだ、其仕事の爲に今此港へ來て、明後晩にはまた此處を出發するのだが、其一件さへ首尾よく行けば、百や二百の目腐れ金はお前にもあげるよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
