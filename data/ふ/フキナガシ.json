  {
    "uuid": "d026464f-aae2-5c05-92f1-85c46e01286f",
    "entry": "吹き流し",
    "reading": {
      "primary": "ふきながし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
