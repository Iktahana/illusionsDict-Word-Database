[
  {
    "uuid": "e61f68b1-b46f-5d77-9d08-b9f61cbae4c0",
    "entry": "不賛成",
    "reading": {
      "primary": "ふさんせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
