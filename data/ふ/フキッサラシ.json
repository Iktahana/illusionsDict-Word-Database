        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "特に仕事を始めた当初は寒さの厳しい時期であり、作業内容も新興団地の構内ケーブルの配線と吹きっさらしでの作業であったため、寒さはこたえた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "放課後になると、これは子供より何よりも、校舎を汚されることだけが自分の馘と同じくらい怖ろしいと観念している使丁たちに階下の遊び場を追いまくられ、子供らは吹きっさらしの屋上運動場に逃げあがって行った。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "扁平足のはだしが、吹きっさらしの屋上にばたッばたッと不気味な音を立てていた。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "満州製の罐詰の底で寒そうに鳴る息子らの骨とかけがえのない娘たちの肉にまでかえて料った赤土まじりの草と、きびとひえの飯まで食わされる百姓と最大の安全をもつ黒字資本をおろした、吹きっさらしの監獄部屋のあるこのツアー国家に顔中うみ汁と吹き出ものだらけの赤ん坊が生まれた！",
              "citation": {
                "source": "餅の歌",
                "author": "――全農の林延造氏に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹きっさらしの海端で、ひょんな話をしかけるようだが、どのみち、宿の泊りで話せるようなことではない。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前様だってお顔は風に吹きっさらしだ。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹きっさらしのとこで学生は土の上へ座ってきく、こいつは参った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
