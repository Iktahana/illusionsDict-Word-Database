        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その通りを行き切つて、明るい旧通りへ出ると、そこから直ぐと近くにある、彼が三年前に屡々買つたり売つたりしてゐた古本屋に、チヨツと寄つてみようかといふ気が起つた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れて始めて両親を離れ、飛び立つ思ひなり、その秋の暮、寒い夜に丸太町橋際の古本屋で「ダダイスト新吉の詩」を読む。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　古本屋へ雑誌を持つて行くと、まづ大体一冊づつの値段を合計した値段を付ける。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "古本屋は法外の高価でそれを皆に売りつけて居た。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河岸の古本屋は軒竝みに箱をひろげてゐる。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、頭を洗つてサツパリして理髮屋を出ると、近所の古本屋二軒で暫く隙を潰した。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　司馬江漢の随筆というのを古本屋の店頭で見つけたので、買って来て読んでみた。",
              "citation": {
                "source": "断片（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古本屋と思って入った本屋は新しい本ばかりの店であった。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻の古本屋へまた逆に歩いて行った。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私が学校で要る教科書が買えなかったので、親仁が思切って、阿母の記念の錦絵を、古本屋に売ったのを、平さんが買戻して、蔵っといてくれた。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、祖母の話では、古本屋は、あの錦絵を五十銭から直を付け出して、しまいに七十五銭よりは出せぬと言う。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "古本屋は、今日この平吉の家に来る時通った、確か、あの湯屋から四、五軒手前にあったと思う。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一足先へ駈出して、見覚えた、古本屋の戸へ附着いたが、店も大戸も閉っていた。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱のような仕切戸から、眉の迫った、頬の膨れた、への字の口して、小鼻の筋から頤へかけて、べたりと薄髯の生えた、四角な顔を出したのは古本屋の亭主で。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、この平さんが、古本屋の店へ居直って、そして買戻してくれた錦絵である。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八雲氏の夫人が古本屋から掘り出して来たという「狂歌百物語」の中から気に入った四十八首を英訳したのが「ゴブリン・ポエトリー」という題で既刊の著書中に採録されている。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき古本屋から買って、電車の中で読んだばかりの新智識ですから、まだ記憶に残っているのですけど、あすになったら、僕は忘れてしまうでしょう。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は観念して、下の子を背負い、上の子の手を引き、古本屋に本を売りに出掛ける。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく……まだ五時だってえのに電燈を灯けなくちゃ物が見えねえなんて……店ん中に妖怪でも出そうで……もっとも古本屋なんて商売は、あんまり明るくちゃ工合が悪う御座いますナ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "法界節の文句通りに仕方がないからネエエ――てんで、月琴を担いで上海にでも渡って一旗上げようかテナ事で、御存じの美土代町の銀行の石段にアセチレンを付けて、道楽半分に買集めていた探偵小説の本だの教科書の貰い集めだのを並べたのが病み付きで、とうとう古本屋になっちまいましてね。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中で古本屋がイヤンなっちゃって、見よう見真似の落語家になったり、幇間になったりしましたが、やっぱり皮切りの商売がよろしいようで、人間迷っちゃ損で御座いますナ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ来て見ても、お客様が一人立っておいでになる古本屋なら、大丈夫立って行くものです。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいお道楽ですよマッタク……古本屋てものは元来、眼の見えない者が多いんだが、お前は割合によくわかるから、話相手になると仰言ってね……ヘヘヘ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "化粧品や売薬と、商品として見た書籍とを比較する場合に一つの大きな差別の目標となるのは、古本屋というものに対する古化粧品屋、古売薬屋の存在しないことである。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから十年の後高等学校在学中に熊本の通町の古本屋で仏語読本に鉛筆ですきまなしにかなの書き入れをしたのを見つけて来て独習をはじめた。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とその隣が古本屋で、行火の上へ、髯の伸びた痩せた頤を乗せて、平たく蹲った病人らしい陰気な男が、釣込まれたやら、「ふふふ、」　と寂しく笑う。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴雄だけではない、――いや鶴雄などはまだ良い方で、たいていの学生は新円生活に困っていて、内職に露店の古本屋を出したり、駅でキャンディーを売ったりする学生が多かったのだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑踏の中を些と古本屋の前に立停ツたり、小間物店や呉服店をチラと覗いて見たりして、毎のやうに日影町から春木町に出る。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治初年の、佳人之奇遇、経国美談などを、古本屋から捜して来て、ひとりで、くすくす笑いながら読んでいる。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "河堤の古本屋の箱屋台はすっかり黒い蓋をしめて、その背後に梢を見せている河岸の菩提樹の夕闇を細かく刻んだ葉は河上から風が来ると、飛び立つ遠い群鳥のように白い葉裏を見せて、ずっと河下まで風の筋通りにざわめきを見せて行く。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
