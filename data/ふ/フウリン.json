  {
    "uuid": "5f2120a9-c812-57f9-84a6-c92047c8d850",
    "entry": "楓林",
    "reading": {
      "primary": "ふうりん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
