    "definitions": [
      {
        "index": 1,
        "gloss": "to blow strongly and continuously",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "最後のクライマックスとして、荒野を吹きまくる砂風に乗じていわゆる「アジアのあらし」が襲来する場面がある。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハリケーンと言いたいくらいの凄い西風が、地響き立てて吹きまくる。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "桟橋にも、馬蹄形の街にも、その後ろなる山も、高原も、みな、美しく、厚い、雪で念入りにおおわれ、雪面を吹きまくる北海道の風はしびれるように痛かった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹き落ちる気配も見えないあらしは、果てもなく海上を吹きまくる。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹きまくる不良風　震災前、東京には各種の学校が、著しい増加の傾向を示した。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつものやうに久良は俺に送られて、風の吹きまくる畦道へ出た。",
              "citation": {
                "source": "木枯の吹くころ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々風があたりを吹きまくる、颱風が近づきつゝあるさうな。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓｜硝子をとおしてまだぼんやりと前の通りを見下ろしていた私は、吹きまくる蒙古風といっしょに奇妙な呼び声が揺れ上ってくるのに気がついた。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "mind you 私たちは現世紀を吹きまくる赤色｜颱風の中心にいるのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月頃まで家を揺って強風が吹きまくるので、瓦屋根には出来ない。",
              "citation": {
                "source": "夏遠き山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨春と冬との変りめ生暖い二月の天地を濡し吹きまくる颱風。",
              "citation": {
                "source": "海辺小曲（一九二三年二月――）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "周圍の山林を吹きまくる風が唯一の頼母しい物であつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十一月一日）旅空ほつかりと朝月がある夜をこめておちつけない葦の葉ずれのちかづく山の、とほざかる山の雑木紅葉の落葉吹きまくる風のよろよろあるく秋の山山ひきずる地下足袋のやぶれお山のぼりくだり何かおとしたやうな　十一月二日　快晴、行程八里、星越山麓、あさひや。",
              "citation": {
                "source": "四国遍路日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくそうだった、そしてそれを吹きまくる烈風、雨が横さまに簾のようになってそそいだ、私は天からたたきつけられたように感じた、むしろ痛快だった。",
              "citation": {
                "source": "四国遍路日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に入つてからまた雨となつた、風さへ加はつた、雨は悪くないけれど、風には困る、雨は身心を内に籠らせる、風は身心を外へ向はしめる、風は法衣を吹きまくるやうに、私自身をも吹きまくる、旅人に風はあまりに淋しい。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "風がふいた、笠どころか、からだまで吹きまくるほどの風だ、旅人をさびしがらせるよ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳩の胸のように平和な中欧の山国にも鋼鉄と鮮血の風が吹きまくる。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "」わあっと四囲いちめん水っぽい秋の夜風が吹きまくるようで、田部は、長火鉢の火箸を握った。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "落着のないクラスの生徒たちは、この風が吹きまくるとき、ことに騒々しかった。",
              "citation": {
                "source": "秋日記",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四町をかけて吹きまくるに、その中にこもれる家ども、大なるもちひさきも、一つとしてやぶれざるはなし。",
              "citation": {
                "source": "方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "穂高小屋附近は、唐沢岳の西側に沿って吹いてくる風が奥穂の岩壁にあたり跳ね返って、とても凄く吹きまくる。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風の吹きまくる所で性慾は起りはしない。",
              "citation": {
                "source": "無常の風",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "果てしもなく砂に溺れた私の食慾は、風のビンビン吹きまくる公園のベンチに転がるより仕ようがない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "果てしもなく砂に溺れた私の食慾は、風のビンビン吹きまくる公園のベンチに転ろがるより仕ようがない。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」わあつと四囲いちめん水つぽい秋の夜風が吹きまくるやうで、田部は、長火鉢の火箸を握つた。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "南伊豆の狭い海岸の天城颪の吹きまくる谷津の湯の湯船の中で女の私が乗馬訓を読まうなどとは思はなかつたとをかしいのであるが、しかし如何にもよい訓へだと感心してゐる趣きも見える。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ア、ほんと、凄いねッ」一郎は暫く驚いた顔で眺めていたが、吹きまくる烈風に、直ぐ顔が蒼ざめ、唇も紫色に変って行った。",
              "citation": {
                "source": "箱根の山",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀之介の方でも、とくにそのことを感付いていて、告白書が兄の手に渡るや否や、あとは大風が自分の方へ向って吹きまくるであろうこと、そして多分自分は放逐されるだろうと先の見透しをつけた。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "反乱は日本全土に波及して幕府は倒れ諸侯は各々勢力を争ひ混乱の嵐は吹きまくるが、九州を平定した切支丹は諸国に散在する信徒達に働きかけてその統一を次第にひろげて行くのである。",
              "citation": {
                "source": "わが血を追ふ人々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さくらちる富士がまつしろさくら咲いてまた逢うてゐる旅ごゝろかなしい風がふきまくるぼう／＼としてあるくいつしか春　　　（追加）　蘭竹かれ／″＼の風にふかれつゝ・鎌倉は松の木のよい月がのぼつた大仏さん異人さんさくら寺いちはやく山ふところのさくら一もと　　斎藤さんにまた逢ひませうと手を握る東京をうたふ。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
