    "definitions": [
      {
        "index": 1,
        "gloss": "material ejected during a volcanic eruption (cinders, scoria, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "火山の噴火に伴い、火口から数キロメートル離れた集落にも高温の噴石が飛来した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "登山中に突然の噴火に遭遇したため、私たちは近くの岩陰に身を隠して噴石をやり過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "気象庁は、大きな噴石に警戒するよう呼びかけるとともに、火口周辺への立ち入りを規制した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      }
