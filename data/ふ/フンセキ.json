          "literary": [
            {
              "text": "日本で馬糞石など俗称し、稀に馬糞中に見出す物で予も数個持ち居る。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち、自慢そうに持ち出したのは、ササラバサラと馬糞石だ。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬糞石は、馬の腹で固まった石灰質の玉、直径四寸ほどあった。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
