    "definitions": [
      {
        "index": 1,
        "gloss": "fire",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それがまただんだん横へ外れて、前のレンズの形を逆に〔繰〕り返し、たうたうすっとはなれて、サファイアは向ふへめぐり、黄いろのはこっちへ進み、また丁度さっきのやうな風になりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがまただんだん横へ外れて、前のレンズの形を逆に繰り返し、とうとうすっとはなれて、サファイアは向うへめぐり、黄いろのはこっちへ進み、また丁度さっきのような風になりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがまただんだん横へ外れて、前のレンズの形を逆にくり返し、とうとうすっとはなれて、サファイアは向こうへめぐり、黄いろのはこっちへ進み、またちょうどさっきのようなふうになりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "※７　青宝玉＝サファイアのこと。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はちすずめが水の中の青い魚のように、なめらかにぬれて光りながら、二人の頭の上をせわしく飛びめぐって、ザッ、ザ、ザ、ザザァザ、ザザァザ、ザザァ、ふらばふれふれ、ひでりあめ、トパァス、サファイア、ダイアモンド。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あられと思ったのはみんなダイアモンドやトパァスやサファイアだったのです。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「クソ、近くで買物できれば、こんなにあわてなくてすんだのに」　腹立たしげにいって、高志が〈ライト・マイ・ファイア〉を流していたラジオのスウィッチをきり、ナップザックにしまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "邦題は、楽曲のアイデンティファイアたりえないからである。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "気取って、金縁の椅子等を置いたのではなく、大きなやや古風なファイア・プレースでもあり、埋まってしまうような大椅子、長椅子があり、気持のよい出窓の下の作りつけ腰掛。",
              "citation": {
                "source": "書斎を中心にした家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、北原白秋が羊皮にサファイアやルビーをちりばめた豪華版の詩集を出す広告をしたことがあった。",
              "citation": {
                "source": "豪華版",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもう一つは、大きなファイア・プレェスの中でぼうぼうと音を立てて燃えてゐる火をいい氣持になつて見守つてゐると、知らない間にずんずん驚くほど速く時間が立つてしまふのです。",
              "citation": {
                "source": "七つの手紙",
                "author": "或女友達に",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひさしぶりに其處で夜を過ごすことにした、ファイア・プレェスのある廣間なんぞは、病中散らかしたまんまにして置いたもんだから、いかにも山小屋然となつてゐる。",
              "citation": {
                "source": "山日記　その二",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は無關心を裝つて、あかあかと燃やしたファイア・プレェスの前で、ほんの仕事の眞似、女房もかういふ山住みには大ぶ馴れて來たと見え、僕の傍で落着いた顏をして手紙を書いてゐる。",
              "citation": {
                "source": "山日記　その二",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまだっても、この手紙を書きながら、ファイア・プレェスに火を焚いているほどだ。",
              "citation": {
                "source": "卜居",
                "author": "津村信夫に",
                "note": "青空文庫"
              }
            },
            {
              "text": "――本当をいうと、こんな一番山奥の、それにこんな二人きりには少し大き過ぎて持てあまし気味の小屋を、他にいくつもあった手頃な小屋よりも私に特に選ばせたのは、実はこのファイア・プレェスの傍に二つ三つ無雑作にころがっていた古い樫の木の椅子（昔から私はこんな椅子をどんなに欲しがっていただろう！",
              "citation": {
                "source": "卜居",
                "author": "津村信夫に",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうすこし一しょに居て、こうやってファイア・プレェスの前で私がまだいくぶん独身者のように、ときどき一人ごとなど言いながら手紙を書き、女房が心もち物足りなそうな顔をして、編み物をしている傍で、ちょっとの間だけでも、こんな少し淋しすぎる一家｜団欒を賑わせていてくれたら好かりそうなものだのに。",
              "citation": {
                "source": "卜居",
                "author": "津村信夫に",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤や黄や紫や白や桃色の、艶やかな絹糸が、サファイアの指輪をはめたしなやかな白い指先に、やさしく戯れて、編台の上に、留針に刺されながら、単調だが微笑ましい模様を、形づくってゆく……。",
              "citation": {
                "source": "傷痕の背景",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "サブラソフの風景、マコフスキーの風俗画、ブルビエルのロシア的（碧、桃色、サファイア、ルビー的配色）神秘画、セーロフ（革命までの所謂貴婦人像、牡牛にのって少女が河をわたって居るきつい樺色と紺、白の配色）一寸面白い。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだアンプリファイアがないので音が小さくかなり神経がつかれる。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはボンファイアをした跡だわ……」妻はしきりに自分の女学生時代の事を思い出しているらしく、いくぶん上ずったような声で私に云った。",
              "citation": {
                "source": "晩夏",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ボンファイアって何だい？",
              "citation": {
                "source": "晩夏",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、ボンファイアを知っていらっしゃらなかったの？",
              "citation": {
                "source": "晩夏",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、ファイアーエンジンが通りました。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔第一巻　甦る〕〔第一章　時代〕イギリスの玉座には…………　　当時のイギリスの国王はジョージ三世（一七三八―一八二〇）、王妃はシャーロット・ソファイア（一七四四―一八一七）であった。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国ついでに、もう一つ米国の話を持ち出すと、私のいた大学、プリンストンの寄宿舎には、全部ではないが、オープンファイアプレースを持つ部屋が沢山あった。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭酸銅によって有毒になった茶は、アンモニア水によってすぐに美しいサファイア・ブルー色になる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "民芸では食っていけないので、ファイアンスの模造をはじめたが、予期以上にうまくいきそうなので、手本を追いこすくらいのところまでやってみるつもりでいる、とめざましく昂奮しだした。",
              "citation": {
                "source": "骨仏",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日本の磁器は硬度は出るのですが、どこか煤っぽくて、どうしてもファイアンスのような透明な白にならないんですね。",
              "citation": {
                "source": "骨仏",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファイアンスの白を追いこすことが出来れば、黒いチューリップや青いダリヤを完成したくらいのえらい騒ぎがおきるんです」「すると君がやっているのは、中世の錬金道士の仕事のようなものなんだね」　と皮肉ってやったが、まるで通じないで、「錬金道士か。",
              "citation": {
                "source": "骨仏",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
