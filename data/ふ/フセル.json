    "definitions": [
      {
        "index": 1,
        "gloss": "to lie down (and sleep)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すると、すぐそれを撫で臥せるように男の地声が力を張って参ります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "只時々その大柄なのには似合はず加減が悪いといつては臥せることがあつた。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいよさんは時々朝から臥せることがある。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "『親なしに臥せる旅人』と思ってください」　と言いながら、御簾のほうへからだを寄せる源氏に、典侍はいっそう昔が帰って来た気がして、今も好色女らしく、歯の少なくなった曲がった口もとも想像される声で、甘えかかろうとしていた。",
              "citation": {
                "source": "源氏物語",
                "author": "朝顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧を送り出でたる一人の女、土間に臥せる小犬を抱き起せば、犬は狎れて、その手を舐りながら、ねむたさに堪へでや又靜かに眠る。",
              "citation": {
                "source": "杉田の一夜",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍らに臥せる長男を呼び起せば、手を拍つて喜び勇む。",
              "citation": {
                "source": "沖の小島",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "男二人横臥せる間のしりへに、わづかに膝を容るゝばかりの餘地を求めて、顏を袖に埋めて俯す。",
              "citation": {
                "source": "房州紀行",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "女すこしばかり嘔きしが、遂にえ堪へで、横臥せる男の脛を枕にして臥す。",
              "citation": {
                "source": "房州紀行",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "（五月八日）　今になりて思ひ得たる事あり、これまで余が横臥せるにかかはらず割合に多くの食物を消化し得たるは咀嚼の力｜与つて多きに居りし事を。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "○病みて臥せる身には日和程嬉しきはなし。",
              "citation": {
                "source": "病牀瑣事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、「しなてるや片岡山に飯に飢えて臥せる旅びとあわれ親無し。",
              "citation": {
                "source": "夢殿",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "又（父イ）母が命つきて臥せるをもしらずして、いとけなき子のその乳房に吸ひつきつゝ、ふせるなどもありけり。",
              "citation": {
                "source": "方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も蒲團の頭の方を足の方より少々高くし、一面に少し坂になるように床を拵ひ、安樂に臥せる事、大によし。",
              "citation": {
                "source": "養生の心得",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで始皇は不面目を忍び、態※當時不滿を懷いて故山に歸臥せる王翦の宅を訪うて、再三その出征を懇願し、遂に楚を滅ぼしたことがある。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が最後に敬宗に信任された節度使の李逢吉は、崔發には年八十の老母があり、その老母が崔發の身を心配して、病褥に臥せる事實を告げ、孝道の爲に枉げて崔發を放免せんことを請ふと、敬宗はこの一言に感動して、即刻崔發を出獄させた。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らんとならば共に見よ、臥せる美神の肌のごとすべて微笑む入江をば。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四号は牛の背上に立ち、その又牛は僭越にも仰臥せる女を婬しつつあり。",
              "citation": {
                "source": "北京日記抄",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "房主たちをおし臥せるやうな氣持ちで、二重底のある語を語つてゐると思うてゐると、驅り立てられた情熱が、當代の學者たちを打ち臥せるやうな語氣を烈しく持つて來てゐた。",
              "citation": {
                "source": "死者の書　續篇（草稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖徳太子の歌に、「家にあらば妹が手｜纏かむ草枕旅に臥せるこの旅人あはれ」（巻三・四一五）があった。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "病と臥せる我の作略を面白しと感ずる者さえあろう。",
              "citation": {
                "source": "薤露行",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "上宮太子の「家ならば妹が手まかむ、草枕旅に臥せる、この旅人あはれ」という歌も、『紀』に録するところの、「しなてる片岡山に、飯に飢て臥せる、その旅人あはれ。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "親なしになれなりけめや、さすたけの君はやなき、飯に飢て臥せる、その旅人あはれ」という歌に比して、表現法が著しく新しい。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜十一時過ぎ、下女が便所に行かんとて廊下に出ずると、庭内に白色の怪物の横臥せるを認め、「化け物がいる」と叫んで逃げ込んだ。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿河の久能の山彙あるいは越後の弥彦のごとき海に面して横たわり臥せる山ではかりにまともに沖から吹き当てる風でも、この山の附近においては横に流れて浜に沿うた風となる。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの交響曲を愛する時には、それといっしょに臥せるような様子だった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に在らば　妹が手枕かむ　草枕　旅に臥せる　此の旅人あはれ　竜田山の死人をみてふとつぶやいた言葉に、おのずから調べが乗ったような御歌である。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "級照る　片岡山に　飯に飢て　臥せる　彼の旅人あはれ　親無に　汝生りけめや　剌竹の　君はや無き　飯に飢て　臥せる　彼の旅人あはれ　日本書紀によれば「十二月｜庚午朔、皇太子片岡に遊行ます。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に流言に憑いた鼠でも、オートバイなどで人もなげに駈し、溝の中で取つて倒し、組んで噛みふせる勇者が顯はれた。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士の父が、明治の初年に、同縣の友で好い位地を得てゐた某の世話で、月給十五圓の腰辨當を拜命して、東京に住むやうになつた時から、食ふ筈の肴を食はず、着る筈の着ものを着ずに、博士の學資を續けて、博士が其頃の貸費生といふものになりおふせる迄にしたのは、此母君の力である。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで想像して来ると小説に読みふけっていた人が、ほっとため息をしてばたんと書物をふせるように、葉子も何とはなく深いため息をしてはっきりと事務長を見た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
