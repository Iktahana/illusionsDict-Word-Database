[
  {
    "uuid": "966d42bb-4225-535c-8cf3-e55a090e0ea0",
    "entry": "不二",
    "reading": {
      "primary": "ふに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
