        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小さな切札を一枚もつてゐるから一回だけは防げるとしても、思へば風前の灯火である。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の運命は、依然として風前の灯であった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ生命は風前の灯である。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "覆面を取らぬ団員の生命は風前の灯にひとしかった。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "リーグニッツの不期戦は風前の灯火の感あった大王を救った。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、彼の云ったことが事実だとすれば、栖方の生命は風前の灯火だと梶は思った。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくＷに負けないであろう程の冷静、残忍さをもってＩの年齢を指折り数え得るようになった」「……………」「Ｔ子の運命は風前の灯火である。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "我我は文明を失ったが最後、それこそ風前の灯火のように覚束ない命を守らなければならぬ。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆村の命は、乱暴者のトラ十の前に、今や風前の灯同様である。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に山三郎の命の危いこと、風前の灯火のようでござります。",
              "citation": {
                "source": "松の操美人の生埋",
                "author": "侠骨今に馨く賊胆猶お腥し",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の生命は、風前の灯火だ。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて風前の灯のように危かった青竜王の生命は、僅かに死の一歩手前で助かった。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆村はいまや風前の灯であった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士の実験の材料に成りさがった大隅の運命は、風前の灯だった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、机博士の生命は風前の灯同様である。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "隊長テッド博士以下の救援隊の首脳部の心の痛みは、災害をちょくせつに身にうけてその生命もいまや風前の灯火どうようの第六号艇の乗組員三十名よりも、ずっとふかく大きかった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、テッド博士以下の救援隊員の生命は風前の灯である。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆村探偵の一命は、風前の灯火も同様です。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし地上攻撃をやるものとしたら、帆村と小浜の両人の生命は、いまや風前の灯火同様、じつにあぶないことになりました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "死地に乗り込んだ右衛門と共に二人の女の運命こそ、風前の灯より浮雲いではないか。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこのたびは、主上も都を捨てて、西国へお下りになるという重大な事態、一門の運命も今や風前の灯でございます。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第七巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "加十の運命たるやまさに風前の灯火なのである。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府の命はまさに風前の灯。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや、病の床に就いて風前の灯であられるのぞ。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "親子の縁は、これまでも薄く、これまでの身に知られるこの世の因縁も、風前の灯。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして南口の大隊の運命も風前の灯にひとしい。",
              "citation": {
                "source": "日の果て",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房なぞは今ではすっかり術を心得込んで家賃を負けさせようとの魂胆物凄く、年中菊の話ばかり持ち出して「大家の小父さん」なぞと甘ったれていたが、この小父貴が昔市長なんぞを務めたのが運の尽きとなって、今や半狂乱の私に遮二無二見当を付けられてまさに風前の灯火となっているのであった。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど私たちが飛び込んで行った時には風前の灯火は珍しくも書斎で何か調べ物でもしていたとみえて、頃は元禄十四年｜師走半ばの十四日に宝井｜其角が着ていたような妙ちきりんな十徳みたいなものを引っ掛けて私にネラわれているとも知らず、「おうおう！",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や全てが風前の灯火だ。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "――千浪は父の命が風前の灯と見るや、我を忘れて無手で白刃を遮ろうと躍りかかったが、横から別の若侍に蹴倒されてそこへ悶絶してしまった。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
