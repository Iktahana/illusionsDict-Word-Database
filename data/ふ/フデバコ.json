        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこには僕が考えていたとおり雑記帳や鉛筆箱とまじって見覚えのある絵具箱がしまってありました。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆箱のカチャカチャと鳴る音がいつまでも耳に残り、こんなことがあってから寿女は、途上で女の子を見付けると周章てて道をそらしたりした。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おねえさん　櫛、かんざしたけを　　　手袋六十五　　　鉛筆箱入り会田　　　　袋はつ　　　　襟小林　　　　しゃつ　国男さんその他のものは、もうそろって居るから、此で相すみ。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは風呂敷包みを解いた、中から歴史や地理や図画や筆箱などがでた、かれはそれらを一つ一つしらべると雑記帳の間から一封の手紙が落ちた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "お竜ちゃんは、そんな私をも見ているのだか見ていないのだか分からない位にしていたが、そのとき彼女の千代紙を張った鉛筆箱をあけるなり、誰にも気づかれないような素ばしっこさで、その中の短かい一本を私の方にそっと押しやった。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼が、筆箱のように上下にのびた。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「センセ、センセヤー」　がたがたと鞄の中で筆箱がなった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私は筆箱にはいっているちびた鉛筆を盗ろうと思った。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "背中や脇の下で筆箱を鳴らしながら、ほこりを立ててみんなは走りつづけた。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おーかんけ　おーかんけ」川下のほうへ遠のいていく唄声が聞えて来た、「おいなりさんのおーかんけ　おぞーにとおーあげ　おあげのだんからおっこって……」土堤の夏　私は大きな写生帳と鉛筆箱を抱え、経木の海岸帽子をかぶって、土堤の上を家のほうへと歩いていた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日私は学校の帰りみちに鞄から筆箱を落した。",
              "citation": {
                "source": "生い立ちの記",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの坊ちゃんが筆箱を落したのですが云々という台詞であった。",
              "citation": {
                "source": "生い立ちの記",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "交番に筆箱は届けてなかった。",
              "citation": {
                "source": "生い立ちの記",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
