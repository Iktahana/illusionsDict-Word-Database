        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大潮がムクムクと押し進み来て、汪々とさし進んで、見る見るうちに洲を呑んで渚を侵し、見渡す沖の方は中高に張り膨らんで、防ぎ止めることの出来ない勢いで押し寄せて来る状は、実に張る気の相である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵に自分が他愛なく酔い倒れてしまわなければ、このわざわいを未然に防ぎ止めることが出来たかも知れない。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな迫害も彼女の進む道を防ぎ止める事は出来なかつた。",
              "citation": {
                "source": "乞食の名誉",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、夫人は、息子の眼を防ぎ止めることに躍起になっている自分が、実は、それにかずけて良人を護っているのではなかろうか、と疑う。",
              "citation": {
                "source": "女心拾遺",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "逆に言へば、「をつとあぶない」と謂つた気分で、転倒を防ぎ止める動作と言ふ風にも説ける。",
              "citation": {
                "source": "戞々たり　車上の優人",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日読書会に出た青年が、明日バクチを打つかもしれないのを防ぎ止めるところに、指導青年の苦心があるのである。",
              "citation": {
                "source": "地方の青年についての報告",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "新日本の科学の建設には、まず流言蜚語の洪水を防ぎ止める必要がある。",
              "citation": {
                "source": "流言蜚語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな海嘯などは、到底人間の力で防ぎ止めることは出來ませんが、しかし、もし海岸に浴うて帶のように森林があれば、非常な速力でおし寄せてくる潮水の勢を殺ぎ、從つて慘害も少くなる道理です。",
              "citation": {
                "source": "森林と樹木と動物",
                "author": "本多靜六",
                "note": "青空文庫"
              }
            },
            {
              "text": "「警察で講じた対策なのでございまして、このむすような、特別に暑いお天気では、一般の健康状態にいろいろと不利益な故障が起こるかもしれませんので、それを義務どおりに、早いうちにふせぎとめるはずのものなのでございます。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
