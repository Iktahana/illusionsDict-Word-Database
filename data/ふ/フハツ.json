        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは「腐る」（不発）のがあると、危険だからであった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "通り風や、青い火や、幽霊になって現われて、鶴嘴の尖端を掴んだり、安全燈を消したり、爆発を不発にしたりする。",
              "citation": {
                "source": "斜坑",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "また文明人と野蛮人との区別もこの能力の発達不発達に比例すると思う。",
              "citation": {
                "source": "婦人と思想",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、どの方法も確実性と絶対不発見性とを具有しているものはなかった。",
              "citation": {
                "source": "蜘蛛",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで魚雷が不発のまま突き刺さったような恰好である。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこへいけば、まだ残っているはずですが、後の方になって、眼の前へどーんと一つ落ちてきた奴が、不発弾でしてね、トーチカの斜面を、ごろごろと転がりおちてきましたよ。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、いくら敵の爆弾にしろ、不発弾があるなんて、みっともないですね」「ばかをいえ。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "不発弾でなかったら、お前の生命は、とっくの昔になくなっているわけじゃないか。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "不発弾であったのが、どのくらい倖だか、わかりゃしない」「そういえば、そうですな。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "カモシカ中尉とモグラ一等下士とのおどろきを尻目に、不発爆弾の中から出てくるは出てくるは、あとからあとへと立ち現われて、しまいには、かれこれ十四五人の頭数になった。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして籠だけを、沼の中になげこんだの、であるが、その花籠がついに不発に終ったことは、みなさんも既に御存じのとおりである。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "射術にかけては、少年の間は勿論大人のアイヌの間にも有名なキクッタですから、大熊はその場に地響きさして、ぶつ仆れた――はずですが、不幸、ガチッと音がして、不発でした。",
              "citation": {
                "source": "熊捕り競争",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯大橋の、こっちから行くと左側の堤防に不発弾がおち、電車は大橋→渋谷間が五、六日止まり、その間歩かせられた。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「みんな不発弾だあ！",
              "citation": {
                "source": "文化村を襲つた子供",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二つの見解は、二十四日、二十五日の両日に於て、互いに追いつ抜かれつ、その勢いを競ったのであるが、いよいよ金博士警告の爆発予定日たる二十六日の朝になると、爆発論者は勿論のこと、昨日までの不発論者たちすら、一せいに荷物をまとめて、エディ・ホテル附近からどんどん避難を開始したのであった。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、皆、こっちへ戻れ、不発弾が、なに恐ろしい、戻れというのに……」　と、エディ・ホテルの前で、不発論を守って、逃げ行く不甲斐なき民衆を呼び戻しているのは例の咄々先生であった。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "爆弾が昼寝をしているわけでもありますまい」　爆撃機六機の落した爆弾は、ことごとく不発におわりました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは塔の頂上から五六メートル上に、不発の爆弾がたくさん同じ平面上にならんでいるのがちょうど傘をかぶったように見えるのです。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、二大国の対立が不発のままで続くことによって、その周辺の小国は、続々内乱化の危険があるようだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "野坂中尉と中西伍長",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚に積重ねてあった瀬戸物類は全部粉砕しましたが、幸いにそれは不発でした。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣家の庭に落ちたのも不発でした。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、不運にも不発なのです。",
              "citation": {
                "source": "熊狩名人",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は前日、修繕にやって置いた銃が鉄砲屋から届いたのを、そのまま試しをやらないで舁いで猟に出たために不発であったのです。",
              "citation": {
                "source": "熊狩名人",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これすなわち不発育の葉にしてこれを鱗葉と称す。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには萼はあるが花弁が不発育で雄蕊も僅かな数しか無くその中央に子房があり柱頭を有する。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "与匈奴結和親、而背約入盗、令辺備守、不発兵深入、悪煩百姓。",
              "citation": {
                "source": "奥州における御館藤原氏",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央公論、今月不発刊の旨、広告す。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると不発もあったが、そうでないのは大効果を現し、ボラ、コノシロ、鰺、サヨリ等々、別して前二者は一尺五寸以上の奴もあり、悪童どもは大饗宴を張ったことである。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といふはつきりした厳かな声がしました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふはつはつは、いつひつひ。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
