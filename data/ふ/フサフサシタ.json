        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "房房した亞麻色の髪を羊の毛のやうに縮らせた、小柄の、然し肉附の好い女。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして打ち顫ふ女の房房した後髪をしげしげと見まもつて居た。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "居留地に住んでいるおとうさんの友だちの西洋人がくれた犬で、耳の長い、尾のふさふさした大きな犬。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の二つのうずのしゅげの花はすっかりふさふさした銀毛の房にかわっていました。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふさふさした白い毛を朝風に吹かせながら児猿に乳を飲ませている者。",
              "citation": {
                "source": "猿ヶ島",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その竹の耳かきの一端には、ふさふさした兎の白い毛が附いていて、男は、その毛で自分の耳の中をくすぐり、目を細める。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "炉の上にはやはり血に染まった、長い、ふさふさした人間の灰色の髪の毛が二束ばかり、根元から引き抜かれたものらしい。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "炉の上には人間の灰色の髪の毛のふさふさした束――非常にふさふさした束――があった。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅いきれをかけた大きい島田｜髷が重そうに彼女の頭をおさえて、ふさふさした前髪にはさまれた鼈甲の櫛やかんざしが夜露に白く光っていた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞世の顔は今まで盛んな運動でもしていたように美しく活々と紅味がさして、ふさふさした髪の毛は少しもつれて汗ばんで額ぎわに粘りついていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふさふさした長い白髯を神々しく顔になびかせて、ひと目にそれと見える神官なのです。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "日ざしは、そのカーテンを通して射し入って、柔らかな光を、彼女のふさふさした金色の髪や、その清らかな首筋や、流れ下る肩の曲線や、優しい安らかな胸のあたりに、ふりそそいでいた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさんはその夕方、姫さんをそっとまくら元に呼び寄せて、やせ衰えた手で、姫さんのふさふさした髪の毛をさすりながら、「ほんとうに髪の毛が長くおなりだこと。",
              "citation": {
                "source": "鉢かつぎ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にまた昨日まで母親や女中に伴われて、クル／＼坊主にされに来た幼児や少年が、今日はすでに立派なハイカラな若紳士姿で、そのふさふさした漆黒の髪に流行の波を打たせに来るといったようなことも多いだろう。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヌは、家の中の煙突の下を、ふさふさしたしっぽで、きれいにお掃除をしました。",
              "citation": {
                "source": "金のくびかざり",
                "author": "小野浩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には、あの男のふさふさした長い髪に、私たちの櫛をさして置きましたから、どうかそれを御覧下さいまし。",
              "citation": {
                "source": "犬と笛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーサー君は、瞳の青い、金髪のふさふさした可愛い少年だ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "金色のふさふさしたたてがみをなでてやりました。",
              "citation": {
                "source": "銀の笛と金の毛皮",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "小麥色の引きしまった頬に、ふさふさした黒髪。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその先には毛のようなふさふさしたものがついていた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白い彼女の頬、やや光沢のあせた肉色のくちびる、下に垂れた長いまつげ、白い皮膚にきわだって見えるふさふさした金色の髪、それは静かな純潔と、精神の苦難とを示して、なんともいえない蠱惑の一面を現わしています。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "クラリモンド",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふさふさした髪の毛はみじかく切られていました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きなぎらぎら光る眼、ふさふさしたみごとな髯――それが生えるがままに伸びて、くっきりと高い鼻をいやが上にも浮彫し、まるで太古の神々の中の一人でもあるかのように見えるのである。",
              "citation": {
                "source": "沼畔小話集",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のたのしみは、午後、学校が終ってから、学校のそばですすりないている例の小川のほとりの、ふさふさしたクローバの上に、しばしば寝ころがって、マザーの恐ろしい話を熟読｜玩味することだった。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来私は猫が好きなのだが、ペルシヤ猫は何か暗いものを持つてゐるやうで親しめない、その立派な長い毛、短かい脚、すばらしくふさふさした長いしつぽ、野の物の荒い表情を持つ眼の光、……私には、ペルシヤ猫は人間とはまるで別な世界の独立したけもので、少し怖いのである。",
              "citation": {
                "source": "東北の家",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふさふさした穂が、風のために、波打っていました。",
              "citation": {
                "source": "戦争はぼくをおとなにした",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人はヤロスラーヴリから来たフィオーナという兵隊の女房で、その大柄な身丈といい、ふさふさした黒い渦まき髪といい、悩ましげな鳶色の眼のうえにさながら何か摩訶ふしぎなヴェールのように濃い睫毛がかぶさっているところといい、実になんとも素晴らしい派手な感じの女だった。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、こんどはとつぜん、フェジューシカがふさふさした毛におおわれて、楽しそうにほえながら、カシタンカのそばにあらわれた。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーストロフ　きれいな、毛のふさふさしたイタチですよ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
