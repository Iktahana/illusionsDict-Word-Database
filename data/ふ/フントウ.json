      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "strenuous effort",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "殊に文筆の上で国民指導の位置にある学者と文士と新聞雑誌記者とが民族意識に深く目覚めて、国語の純化に努力し、外来語の排撃に奮闘し、社会の趣味を高きへ導くことを心掛けなければならない。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒木又右衛門が三十余人を相手に奮闘するのを見て理屈抜きにおもしろいと思わない日本人は少ないであろう。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "我軍の戦術もよかったし、将卒も勇敢に奮闘した。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次はクジマがポケットへ子ねこをねじ込んだままで、今にも焼け落ちんばかりの屋根の上の奮闘。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時は嫉妬に燃える奮闘の場面に交錯して花火が狂奔したのでずいぶんうまく調和していたが、今度のではそういう効果はなかったようである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二マイルも離れた川から水路を掘り通して旱魃地に灌漑するという大奮闘の光景がこの映画のクライマックスになっているが、このへんの加速度的な編集ぶりはさすがにうまいと思われる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "論争するにしても、争闘するにしても、あるいは貧苦、煩悩を征服しようとしても、何か一定不変の信念を持たなかったなら、折角奮闘努力しようとする勇気も正当の勇気とならないで、蛮勇となり乱暴とさえなり終るのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年奮闘して何物をも贏ち得なかつた。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "正義の為に奮闘するものは如此迫害さる。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神田街頭に於ける、ヽヽヽヽヽの奮闘はあつばれ武者振勇しかつたぞ。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "（目撃者の話）――この乱闘現場の情景を目撃してゐた一人、大和農産工業津田氏（仮名）は重傷に屈せず検挙に挺身した同署員の奮闘ぶりを次のやうに語つた。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十人のものを相手に五分ほど奮闘したが、結局鼻血が出て、闘いは終った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "然ういふ俺も、其｜毒惡な空氣の中へ飛込んで奮闘しやうといふんだが、武裝は充分かな？",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの町内のある地主の子息は、工科出の地質学者であったが、召集されるとすぐ、深くも思い決した体で、心を後に残さないように、日頃愛用していたライカアやレコオドを残らず叩き壊し、潔く征途に上ったものだったが、一ト月の後にはノモンハンで挺身奮闘して斃れてしまった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "奮闘も差別も自然の法則であるといふ事を忘れた。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんは、孤軍奮闘の形だ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二箇月の旅興行に於ける僕の奮闘が、認められた結果らしい。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "心機一転ということもあるから、朗かに奮闘的な気持ちになれるよう、思い切って生活を革新するとか、強い刺撃を与えて心境を変化させるとか、妻自身｜確信と元気を持って助勢するがいい。",
              "citation": {
                "source": "良人教育十四種",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十人ほど相手に奮闘したが、結局無暴だった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこそ遼陽占領日軍奮闘の石版画の額などを掲げて安心しているのであろう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ他なし、幾十年もしくは幾百年幾千年の因襲的法則をもって個人の権能を束縛する社会に対して、我と我が天地を造らむとする人は、勢いまず奮闘の態度を採り侵略の行動に出なければならぬ。",
              "citation": {
                "source": "初めて見たる小樽",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "漠北からの使者が来て李陵の軍の健在を伝えたとき、さすがは名将｜李広の孫と李陵の孤軍奮闘を讃えたのもまた同じ連中ではないのか。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つはいわゆる、出世――名声地位を得ることを一生の目的として奮闘する生き方である。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともコンナ風に話して参りますと、何のことはないお伽話みたような筋道になってしまいますが、併し、そこまで来る間の私共の辛苦｜艱難と、それから後の孤軍奮闘的生活といったら、優にロビンソン・クルーソー以上の奇談を綴るに足るものがあったのですよ。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに悪くてもなるべく、敵に手数をかけさすべく奮闘すべきである。",
              "citation": {
                "source": "将棋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十六日早朝、乃木はまた先陣として高瀬に向ったが、再三の敗北を残念に想い、兵を励まして奮闘した。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "重昌は忠茂の孤軍奮闘するを危んで、退軍を命ずるが、土民軍に軽くあしらわれた怒りは収らず、なかなか服しようとはせず、軍使三度到って漸く帰陣した。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "『太平記』は正行の奮闘は詳説するくせに、此等の諸軍の動静を閑却して居るが、師泰なんか四条畷戦後、北畠軍に大いに進軍を防遏されて居るのである。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、私おおいに奮闘してみるつもり。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやじのヴァン・デル・ヴェルドは、ふんとうそぶいて、ぼんやり首を振りながら、ジンの酒杯を傾けていた。",
              "citation": {
                "source": "ロウモン街の自殺ホテル",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
