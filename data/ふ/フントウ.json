[
  {
    "uuid": "8c550bdd-61f3-58c5-8abf-4106eae9db7b",
    "entry": "奮闘",
    "reading": {
      "primary": "ふんとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
