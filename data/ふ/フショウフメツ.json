[
  {
    "uuid": "071e6084-636e-5f70-8181-73f185530a0e",
    "entry": "不生不滅",
    "reading": {
      "primary": "ふしょうふめつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
