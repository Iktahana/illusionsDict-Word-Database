  {
    "uuid": "c7ff6abc-5e88-5a95-b295-b219929f5b58",
    "entry": "不鮮明",
    "reading": {
      "primary": "ふせんめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
