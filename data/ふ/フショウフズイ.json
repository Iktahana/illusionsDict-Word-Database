    "definitions": [
      {
        "index": 1,
        "gloss": "a wife should do her husband's bidding",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
