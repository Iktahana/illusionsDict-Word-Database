[
  {
    "uuid": "025ea507-8c6e-5b13-84e0-1ed2b9e598fb",
    "entry": "不浄",
    "reading": {
      "primary": "ふじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞-の形容詞",
