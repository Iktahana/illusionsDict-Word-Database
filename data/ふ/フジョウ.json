      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unclean",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今川家御朱印（天文二十四年）にも、村山室中で魚を商なってはならぬとか、不浄の者の出入を止めろとか禁制があって、それには、この村山なる事を明示している。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の反対理由は、我々の日常使用している言語の大部分は外来語であるから今更、外来語を不浄扱いして排斥しないでもよかろうというのである。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "要は資料がどれだけよくこなされているか、不浄なものがどれだけ洗われているかにあった。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が下の御不浄に降りて行ったら、トシちゃんが、お銚子を持って階段の上り口に立っていて、「あのかた、どなた？",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやになりますよ、ダダダダダと降りてそのまま御不浄に飛び込んで扉をピシャリッでしょう。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と僕は笑いをこらえながら、「しかし、御不浄へ行く前でよかった。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御不浄から出て来た足では、たまらない。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御不浄にばかり行ってるじゃないか。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しかし、僕のいつわらざる実感を言えば、君はいつでもたったいま御不浄から出て来ましたって顔をしているが、……」「まあ、ひどい。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "イクラ不浄役人でもチットは和歌の稽古でもして置け。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "不浄よけの金襴の切にくるんだ、たけ三寸ばかり、黒塗の小さな御厨子を捧げ出して、袈裟を机に折り、その上へ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の西北の隅に、異様に醜怪の、不浄のものが、とぐろを巻いてひそんで在るようで、机に向って仕事をしていながらも、どうも、潔白の精進が、できないような不安な、うしろ髪ひかれる思いで、やりきれないのである。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう、台所の不浄のものを、きれいに掃除して、そうしてあすから、潔白の精進をはじめようと、ひそかに計画して、むりやりＮ君にも酒をすすめて、私も大いに呑んだ。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御父君右大将さまと御同様に、まことに敬神の念のお篤いお方でございましたから、御大患後の不浄の身を以て御参詣などは思ひもよらぬ事、身心の潔くなるのをお待ちになつてお参りしようと三年の間、御遠慮をしてゐただけの話で、まことに単純な、また、至極もつともの事ではございませぬか。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちど御不浄に立った。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「母は、御不浄を一ばん綺麗にお掃除していました。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御不浄に立ったときのことと、それから、少女の微笑と、二つだけ、それだけは、あとになっても、はっきり思い出すことができるのだけれど、そのほかのことは、さっぱり覚えていないのである。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ともあらうものが、そんな不浄なお金を受け取ると思ふか。",
              "citation": {
                "source": "清貧譚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャッチョコ張って、御不浄の戸を閉めるのにも気をつけて、口をきゅっと引きしめ、伏眼で廊下を歩き、郵便屋さんにもいい笑い声を使ってしとやかに応対するのですけれど、あたしは、やっぱり、だめなの。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御不浄へ行って来たのである。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗円　諸法空相、不生不滅、不垢不浄、不増不減。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸子は其多数が比々として表白しつゝある不浄と敗亡と乱倫とを如何せんとするや。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これで後の回向も頼みます」「では、すぐ御膳をさしあげますから、それをおあがりになったら、不浄な心を出さないようにお休みなさいませ、好い時刻にお起し申します」と、主翁はこう云いながら手を鳴らして婢を呼んで膳を急がした。",
              "citation": {
                "source": "立山の亡者宿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから成るべくわたくしに附添うようにして遊びの判らない仕方は手伝って教えて呉れたり、お不浄場へも自分で連れて行って裾を捲って呉れたり親切にして呉れます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁に戸棚があり、縁側に御不浄場も取付けてあります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "畏くもうつくしき夕かな、悲しき馬は微妙端厳なるその馬は見るまに不浄の五体より光を放ち仏の如き眩ゆさにしばしわななく。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か能く浄不浄の苦闘を竟極し得たるものぞ。",
              "citation": {
                "source": "心機妙変を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "唖唖として一声、――これよ凶鳥の不浄の烏。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "美玉を愛蔵する者がその珠の表面に不浄なるものの影の映るのさえ避けたい類なのであろう。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来で俄かに腹痛を催した私が、急いで傍にあった大きな建物の門をくぐって不浄場を借りようとすると、庭を掃いていた老人の門番が「何の用です？",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
