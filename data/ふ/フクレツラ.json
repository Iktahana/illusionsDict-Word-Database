    "definitions": [
      {
        "index": 1,
        "gloss": "sulky look (often with puffed cheeks)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
