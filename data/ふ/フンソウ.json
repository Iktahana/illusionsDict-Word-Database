[
  {
    "uuid": "dfac5b99-03ed-5c01-91cd-26e841dce4ff",
    "entry": "紛争",
    "reading": {
      "primary": "ふんそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
