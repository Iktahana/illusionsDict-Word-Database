[
  {
    "uuid": "ef8acb58-1486-5091-9eb3-a98f8914652d",
    "entry": "不語",
    "reading": {
      "primary": "ふご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
