    "definitions": [
      {
        "index": 1,
        "gloss": "lidded pottery or receptacle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "父の前には見なれた徳利と、塩辛のはいった蓋物とが据えられて、父は器用な手酌で酒を飲んだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでお盆の上の蓋物のつまみを取って開けて見る。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくみは鼠入らずを開けて、いろんな鑵や蓋物なぞを開けて見た。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何にもお構ひをいたしませんのでございますから……」と、おくみは極り悪く挨拶をして、後から、いつもの蓋物の、切昆布の佃煮を小さいものに分けたのと、胡瓜のお漬物とを持つて来てお盆から移した。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　それから暫く經つて、何かかこひの食物を小だしした蓋物を持つて、お園が倉から出て來て見ると、二人は金時のやうにまつ赤な顏をして、話の調子もひどくはづんてゐた。",
              "citation": {
                "source": "醉ひたる商人",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢には新しい藁灰などが入れられて、机の端には猪口や蓋物がおかれてあった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜おそく笹村は蓋物を提げて下宿へ還って行った。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お銀は笹村のために、鶏と松茸などを蓋物に盛った。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄面皮な甥は、すこしばかり目が出ると、今戸の浜金の蓋物をぶるさげたりして、唐桟のすっきりしたみなりで、膝を細く、キリッと座って、かまぼこにうにをつけながら、御機嫌で一杯いただいていた。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "蕎麦屋の利久",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つはアフリカの器らしい厚手の水指と、支那の慶磁の白い湯呑、それに日本物では紫野の茶碗、その横に朝鮮の鶏龍の蓋物の鉢が一つ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "高麗の水差、鶏龍の蓋物、万暦の皿、粉挽の鉢、と、ここのはすべて、人が器物を観賞するという配列ではなく、器物がその前に立った人物の価値を見届けるという風だった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃太郎の蓋物　拾五銭。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃太郎の蓋物　　　拾五銭。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、其皿について、仰向いてゐるとするのと、頭の頂に伏せられてゐると言ふのと、上下二枚の皿が合さつて蓋物の様になつてゐる、と説くものとがある。",
              "citation": {
                "source": "河童の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "下田の金さん処のは、餡は黒砂糖だが、手奇麗で、小奇麗な蓋物に入れてよこす。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほ、ある墓からは漆器でつくつた化粧箱が出て、その箱の中には紅と白粉を入れた小さな蓋物が入れてありましたが、その頃の人も、かういふ道具でお化粧をしたことがわかります。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「これが、あっしどもの口伝なんでございまして、葉の合口へ少々ふりこんでやりますと、不思議に生気がつきます」「おお、そうか、わけのないことだ……いま持って来てやる」　出て行ったと思うと、またすぐ戻って来て、「叔父が書見の合間に舐める氷砂糖が、この蓋物に入っている。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "稲荷の使",
                "note": "青空文庫"
              }
            },
            {
              "text": "……蓋物の横についている」「へえ」「お次ぎはなんだ」「………」　顎十郎は、懐手をしたまま不得要領な顔をしていたが、フンと鼻で笑って、「お次ぎは……俺の命か」　職人は、たちまち人がちがったような凄惨な面つきになって、「ちッ、痴だと思って、油断したばっかりに！",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "稲荷の使",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そういうぐあいに、丼や蓋物を持った面々が四列つなぎになって並んでいるのを、かきわけるようにして前へ泳ぎだし、番衆に押しもどされてすごすご後列へもどって行くが、すぐまた出てきて逆上したように、お氷を、お氷をとあえぐ、四十二三の浪人ていの男。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "氷献上",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷室の前では、氷見の役人が十人ばかり金杓子を持って待っていて、順々に差しだす丼や蓋物におあまりの氷をすくっては盛りこんでやる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "氷献上",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中は、空らになつた皿や蓋物を傍から片付け、一々箸を取り換へて、お酌もせずに引込んでしまふ。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸器、黒釉の薬煎や蓋物、または大きな水甕など、買わないわけにはゆかない。",
              "citation": {
                "source": "全羅紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手に何か小さい壺蓋物を持ち彼女は何心なく台所の様子を見に来たのに違いなかった。",
              "citation": {
                "source": "黄昏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちと、老人組の方へも、お話しにおいで下され」「いや、これは失礼」　と、伝右衛門が、真面目にうけて、田作の蓋物を持って立ったので、二間とも、くずれるように笑った。",
              "citation": {
                "source": "べんがら炬燵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おすみは酒の壜と、蓋物を持って土間の奥から出て来た。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は手招きをし、少年が近よってゆくと、持っている酒の壜と蓋物を脇へ置き、すばやく少年を抱いて接吻をした。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に椀だとか木皿だとか高坏だとか、または蓋物や印籠の如きものなど、全く見分けのつかないものさえあります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋物で黒地に白の打刷毛を施したものがありますが、他の窯には見当らない特色を示します。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年も逢はずにゐては、どのやうに思ひ合ふたものでも、たよりなう思ふのは當り前ぢやな……。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、いまさら人を好きになつて、自分のすべてを掻き乱されるつて厭なのよ‥‥」　女の露骨な本心を打ちあけられて、直吉は、里子の心に似通ふたものが、自分にもあるやうな気がした。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
