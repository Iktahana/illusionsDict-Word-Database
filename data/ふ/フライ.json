      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "deep-fried food",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "フライイング犯した罰として、他の選手よりは一米うしろの地点から走らなければならない。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの場合に、外国人に好評される日本の者は、真の純粋の日本ではなく、彼等のフジヤマやゲイシヤガールの概念性に、矛盾なく調和して入り得る程度の、テンプラフライ式の似而非日本である。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処に僕はゐて、お魚フライにレモンの汁をしたたか掛けて、これから食べようとしてゐたのです。",
              "citation": {
                "source": "夜汽車の食堂",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が美味しい美味しいと、そのお魚フライを食べてゐると、やがてツカツカと、白い大きい※ーレをかぶり、青い洋服に薄い焦茶のストッキングをはいた、大きなアメリカの小母さんが這入つて来ました。",
              "citation": {
                "source": "夜汽車の食堂",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙料理は上等のバタでフライにしてトマトケチャップをかけて食べる。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて御馳走だが、その晩は、鱒のフライ、若生蕈と称ふる、焼麩に似たのを、てんこ盛の椀。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鱒の塩やき、小蝦のフライ、玉子焼、鱒と芙萸の葛かけの椀。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶然｜丸善から取り寄せた「近世美術」を見たら、その中にロージャー・フライという人がこの花を主題にして描いた水彩があったのでそれがわかった。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんならこれから火を起してフライにしてあげましょうか。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれにでもいちばんに邪魔になるのはあのささらでこするような、またフライパンのたぎるような雑音である。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって僕は歌劇の舞台以外おしろいをべったり塗って西洋人のなかをしゃなしゃな歩く沢山のマダム・バッタフライの複製には飽き飽きしているんだ。",
              "citation": {
                "source": "オペラの帰途",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "渇の止まると共に次には飢の苦、あゝ此樣な事と知つたら、昨夜海中に飛込む時に、「ビスケツト」の一鑵位いは衣袋にして來るのだつたにと、今更悔んでも仕方がない、斯うなると昨夜の暖な「スープ」や、狐色の「フライ」や、蒸氣のホカ／＼と立つて居る「チツキンロース」などが、食道の邊にむかついて來る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんならこれから火を起してフライにしてあげませうか。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八幡樣の門前の一寸したカフエーで落合つて……いまでも覺えてゐる、谷崎さんは、かきのフライを、おかはりつき、俗にこみで誂へた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらかじめ考えて置いたのだろう、迷わずにすっと連れて行って下すったのは、冬の夜に適わしい道頓堀のかき舟で、酢がきやお雑炊や、フライまでいただいた。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "珈琲、ケーキ、イチゴミルク、エビフライ、オムレツ……。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "フズーズボンチとちがうわい」　と、次郎は叱りつけたが、ふと、ためいきをついて、「――しかし、珈琲も美味かったぜ」「わいはあんなにがいもンより、エビフライの方がええ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしには、おなべも、フライパンもないのよ」「なあに、ちゃんと持ってますだ」と、のろまのハンスが言いました。",
              "citation": {
                "source": "のろまのハンス",
                "author": "――むかしばなしの再話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の眼の前には巨大なフライトホイールが、黒い虹のようにピカピカと微笑している。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二匹は、それでもフライにしてもらって晩ごはんの時に食べたが、大きいお皿に小指くらいの「かけら」が二つころがっている様を見たら、かれは余りの恥ずかしさに、立腹したそうである。",
              "citation": {
                "source": "令嬢アユ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、宿でフライにしてもらって食べたそうだが、浮かぬ気持であったそうである。",
              "citation": {
                "source": "令嬢アユ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "病友はまたずっと溯った幼時の思い出を懐しもうとするのか、フライパンで文字焼を焼かせたり、炮烙で焼芋を作らせたりした。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸ごとフライにするのだ。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ま夜中のころ、宿屋のまどを、中からおしあけて、こうもりのように、ひらりととびおりた人かげを、銀のフライパンのようなお月さんは、高いところから見たのでありました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉七は牡蠣のフライをたのんだ。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンコーのフライを作れ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "果してお客さんのお気に召すかどうか、待て、アンコーのフライとそれから、卵味噌のカヤキを差し上げろ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿迦佗樹が感覺があるの、フライトラツプが自ら食物を取るの、含羞草が感情的に動くの、或植物は漸々に自己の所在地を變更して、歩行するが如き觀をなすのと云つたところで、それは物理生理の然らしむるので、心理の然らしむるのでは無いやうである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "※高等女学校のスチユデント、　腰にはバンドの輝きて、　右手に持つはテキストブツク、　左手にシルクアンブレラア、　髪にはバツタアフライ、ホワイトリボン……」　自分は亦此処にも日本らしいからぬメロデイを聞いておやおやと思つたのある。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな「髪結新三」的情調へあんなべらぼうなバツタアフライ、ホワイトリボンが這入つて来てたまるものか。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
