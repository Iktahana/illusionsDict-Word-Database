        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いろいろな音程が相次いで「進行」して始めて一つの旋律一つの節回しができ、そうすることによってそこにほとんど無際限な変化の自由が生ずるのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらかじめ打ち込んでおいたメロディーをマックがやたらテンポを上げたり下げたりと、ちょっと聞いただけではさっぱり節回しのわからない形で再生し、解答者が曲名をあてにかかる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに節回しがあれでなかなか込み入っているんで、どうしてもうまくいかん。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年はその不思議な節回しに耳を傾けつゝ、何かしら自失したように、呆然と立っていた。",
              "citation": {
                "source": "ラ氏の笛",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の謡い方が、まるで無我夢中で、少々節回しなどはどうあろうと、一向構わず、堂々とやっているには呆れる、と松篁なども言っているそうです。",
              "citation": {
                "source": "苦楽",
                "author": "ある人の問いに答えて――絵を作る時の作家の心境について私はこう考えています。",
                "note": "青空文庫"
              }
            },
            {
              "text": "沙金はよく、その節回しがおかしいと言って、手を打って笑った。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "土志と変わって非常に大きな声で物にもよるだろうが唄い振り、節回しが頗る粋だ。",
              "citation": {
                "source": "美音会",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "八五郎もそんな時は心得たもので、鼻唄の節回しを研究したり、あの娘のことを考えたり、平次の邪魔にならぬ程度に良い道連れになってヒョコヒョコと縋いて来るのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリストフは、飾りたてた発声法をもってる大仰な甘ったるい節回しのイタリー歌劇を重んじなかったが、それらの詩劇をもまた同様に重んじなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "中音も野卑なら、歌の節回しも下品であった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊かな声をはりあげ、大人っぽい節回しで歌っている。",
              "citation": {
                "source": "赤いステッキ",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく聞けば箱根から先には珍しい薗八節である、何ともいえぬ渋い節回し、※……様を待つ夜の窓の笹　　　露のけはいもあさましや　　　　　麻の葉染めの小掻巻――　こっちが部屋をぬけだすのと同時に、符牒を合せたように唄いだす相手。",
              "citation": {
                "source": "暗がりの乙松",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇帝も、宮中のお役人たちも、みんなほかのシナ人たちも、そのさいくどりの歌の、クルック、クルック、という、こまかいふしまわしのところまでのこらずおぼえこんでしまいました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こういうなりのジョニイは、大股に昇るような足どりで、膝を少し曲げ加減に、ブラットシュトレエムとおれとにはさまって歩きながら、持前の優雅なふしまわしで、その頃盛んにはやっていた「小さい海女さん」という俗謡を歌った。",
              "citation": {
                "source": "なぐり合い",
                "author": "WIE JAPPE UND DO ESCOBAR SICH PRUGELTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのふしまわし自体が当然時代性を持っているから、歌風に適不適があるのはやむを得ない。",
              "citation": {
                "source": "歌詞とその曲",
                "author": "信時潔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふしまわしというものの殆んどない、ごく単調な、色彩の乏しい曲である。",
              "citation": {
                "source": "いさましい話",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
