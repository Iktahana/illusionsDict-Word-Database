[
  {
    "uuid": "7b1d784d-f10b-589f-b9e8-ed964d55b570",
    "entry": "不義",
    "reading": {
      "primary": "ふぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
