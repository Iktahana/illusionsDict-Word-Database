    "definitions": [
      {
        "index": 1,
        "gloss": "prefectural assembly member (in Osaka or Kyoto Prefectures)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
