    "definitions": [
      {
        "index": 1,
        "gloss": "to ignore (a fault, misstep, issue, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
