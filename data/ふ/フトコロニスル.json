          "literary": [
            {
              "text": "ただ三十円を懐にすることだけは忘れなかった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "中味を棄てて輪廓だけを畳み込むのは、天保銭を脊負う代りに紙幣を懐にすると同じく小さな人間として軽便だからである。",
              "citation": {
                "source": "イズムの功過",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "豈陽に忠孝を説き、陰に爆弾を懐にする超偽善的恐怖主義者ならむや。",
              "citation": {
                "source": "文部省の仮名遣改定案について",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ三拾円を懐にする事だけは忘なかつた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を迎へて子の如く、子より愛し、更に其穿つた沓をとつて懐にするまでの民俗の残つたのも、壬生氏選定の古風が行はれずなつて後、世間の婿取りの普通の形となつてしまつた訣である。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "余はみずから黄金を懐にするよりもこれを懐にするの敵国を征服するをもってむしろ栄光となすなり」と。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに家茂はそんなものを懐にする人ではなかった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は静かにその連判状を懐にすると平然として煙草をくゆあした。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴をふところにする色情狂もある。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
