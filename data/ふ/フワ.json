[
  {
    "uuid": "74a16721-0923-5e08-999d-5498cc93c6cc",
    "entry": "不和",
    "reading": {
      "primary": "ふわ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
