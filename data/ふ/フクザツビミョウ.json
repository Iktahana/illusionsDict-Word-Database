    },
    "definitions": [
      {
        "index": 1,
        "gloss": "complex and subtle (delicate)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その怪物の透明な肢体の各部がいろいろ複雑微妙な運動をしている。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「胃の腑」と「詩」との間にはまだだれも知らないような複雑微妙の多様な関係がかくされているのではないかと思われる。",
              "citation": {
                "source": "詩と官能",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故に或る詩は本物として感じられ、或る韻文は非詩として感じられるかということは、実に言語の語意や音韻に於ける組み合せの、複雑微妙なる関係にかかっている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中立諸国の者たちには、実に複雑微妙な外交的術策を用いなければいけない。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、それだのに、周さんたちは革命思想の急先鋒だから、一面親切、一面監視だの、複雑微妙な外交手腕だの、そんな事、あんまりだと思うんです。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "−−−−−−−−−−−−−−−−−−−−−−−−−−石崎光瑤論　石崎光瑤氏の画的経歴くらゐ、複雑微妙なものはまたとあるまい。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十歳を越して作家生活に入った漱石の豊富さと限界とは極めて複雑微妙な矛盾をも包含して輝きわたったのだと思う。",
              "citation": {
                "source": "漱石の「行人」について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "忌憚なく云えば、石原氏がナチとソ連の科学政策をその現実の本質につき入って比較する力を欠いておられる事実なども、社会悪が最も複雑微妙な作用としてあらわれて来ているところの科学精神における一つの決定的マイナスなのである。",
              "citation": {
                "source": "作家のみた科学者の文学的活動",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "個的財布の中の円が百分の一の価値になってきたという事実につながって、Ａ氏Ｂ夫人の個的経験がいかに複雑微妙に個的であろうとも、このような異常な金の価値変化を正常になおすためには、個的経験の主張の範囲ではなんの方策も立て得ない。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モナ・リザは、彼女の良人に、レオナルド・ダ・ヴィンチとの間に生まれたような複雑微妙な諧調を感じていただろうか、おそらくそうではなかったろう。",
              "citation": {
                "source": "女性の歴史",
                "author": "――文学にそって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋愛は複雑微妙だから、それを方程式にして示すことは出来ないが、今考えると僕らのその時の恋愛はさ程ロマンティックなものでもなく、また純な自然なものでもなかったようだ。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ彼等は平凡な人生の複雑微妙、世のつねのすがたの面白さ、深さを理解することを求めるのである。",
              "citation": {
                "source": "日記と自叙伝",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "最悪な人民経済の事情から女性は家庭からどしどしはたき出されているのに、生活を求めて女性がたたかってゆく社会では、昔ながらの封建性が克服されていないばかりか、数年前には知られなかった複雑微妙な堕落のモメントが、女性の一歩一歩に用意されてある。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第十五巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、僕等にもしこの用意がなかった日には、前例の二つに現われている、複雑微妙な技巧に慣れた眼で、必ずや錯覚を起すに違いないのだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、彼の演出こそは、他の誰れ彼れが「戯曲」を「書く」ことをも含めた、一層複雑微妙な精神と肉体との活動を意味するのかも知れない。",
              "citation": {
                "source": "岩田豊雄と私",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この擽ったいというやつは、なかなか複雑微妙な感情でして、私はいったいあなたから嫌われてるのか好かれてるのか、戸惑いさせられますよ。",
              "citation": {
                "source": "未亡人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体「女」といふ言葉は、古来、複雑微妙な語感をもち、時と場合で、その響き方がいろいろに変るのであるが、この「女らしさ」にしても、なにかさういふ捕捉しがたい模糊とした感覚のなかにその正体をつきとめなければならぬ厄介さがある。",
              "citation": {
                "source": "「女らしさ」について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "複雑微妙な都市生活の裏面では、人間が社会から離脱して、羞恥なき行為も行はれるであらう。",
              "citation": {
                "source": "都市文化の危機",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "袁世凱と結ぶか、孫文の思想を支持するか、これは仲々複雑微妙な問題なのだ。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも人間の品位とは、これを気品と云つてもいゝのですが、一言にしては云ひ尽しがたい複雑微妙な要素から成つてゐるものです。",
              "citation": {
                "source": "文化とは",
                "author": "――力としての文化　第一話",
                "note": "青空文庫"
              }
            },
            {
              "text": "まづ、人間の心理、または行為としてこれをみる時に、恋愛は複雑微妙な変化に富み、濃淡色とりどりの多彩な絵巻物となり、時には波瀾をきはめた劇的情景を繰りひろげるのに反して、結婚は、殆ど常に恋愛の終局と考へられ、或は単に「家を持つ」ための便宜手段であるかの如くみられがちであります。",
              "citation": {
                "source": "青年の夢と憂欝",
                "author": "――力としての文化　第五話",
                "note": "青空文庫"
              }
            },
            {
              "text": "コッテリと複雑微妙、実にうまい食べ物だ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治御一新の理想と現実――この二つのものの複雑微妙な展きは決してそう順調に成し就げられて行ったものではなかった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "何十という色分けした地域が、複雑微妙な形に、互いに入り乱れている。",
              "citation": {
                "source": "映画『人類の歴史』",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その関係がなかなか複雑微妙みたいな形をとっているから、ウッカリしていると、見えそこなう事だってある。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "複雑微妙であって、いちがいには言えない。",
              "citation": {
                "source": "清水幾太郎さんへの手紙",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は若い女のひとは沢山知っているけれども、夫婦の生活が複雑微妙であることを知りぬいているので――最もよい場合を知り、わるい場合を目撃しつつあるので――仲人をやることは大役すぎます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も複雑微妙な生活的蓄積の上での決定的な選択と評価とが心と体とを貫き流れているからこそ、好きという一言に、全生活の歴史の方向がかかっているのだと信じます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃ひらく頁には、希望という句もあるのですが、それは非常にユニークなもので、何というのかしら、希望の先駆、それは人が希望と呼んでいるそういうものになるのだろうかというような極めて複雑微妙な格調のものです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この娘と、七兵衛との間には、言うに言われぬ複雑微妙なものがある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
