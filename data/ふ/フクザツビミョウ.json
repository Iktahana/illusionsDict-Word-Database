[
  {
    "uuid": "4d84b805-2180-58df-9fd9-2311020a1794",
    "entry": "複雑微妙",
    "reading": {
      "primary": "ふくざつびみょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
