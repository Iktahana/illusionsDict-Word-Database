        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だれにでもいちばんに邪魔になるのはあのささらでこするような、またフライパンのたぎるような雑音である。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしには、おなべも、フライパンもないのよ」「なあに、ちゃんと持ってますだ」と、のろまのハンスが言いました。",
              "citation": {
                "source": "のろまのハンス",
                "author": "――むかしばなしの再話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "病友はまたずっと溯った幼時の思い出を懐しもうとするのか、フライパンで文字焼を焼かせたり、炮烙で焼芋を作らせたりした。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ま夜中のころ、宿屋のまどを、中からおしあけて、こうもりのように、ひらりととびおりた人かげを、銀のフライパンのようなお月さんは、高いところから見たのでありました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "当今僕はまた東京に移つてアパートに住んで居り、酒などを飲むので一向菓子は喰ひたくなかつたが、斯うして夜更まで机に向つてゐる折など、フライパンひとつで仲々巧みに細君がつくるヘースティ・プディングやライス・ワツフルは至極便利であり、隣室の人になどもその製法を教へてやるのであつた。",
              "citation": {
                "source": "ライス・ワッフルの友",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『これは失敗た、フライパンを、火にかけたまま来てしまつたぞ。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "フライパンや紅茶沸かしは云うまでもない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれたばかりの嬰児の四肢をもぎとって煮え立つフライパンの中へ投げこむほど惨忍にもなります。",
              "citation": {
                "source": "オパール色の手紙",
                "author": "――ある女の日記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "小隊長は、フライパンを振つてゐる水夫の様子を凝つと見守つてゐて、いよいよ肉が焼けた頃合を見はからつて、「突撃！",
              "citation": {
                "source": "船の中の鼠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に棚の上にかくれてゐた工兵隊が、フライパンの上に飛び降りて、煙りのたつてゐる焼肉をさつさつと占領して行つてしまふのです。",
              "citation": {
                "source": "船の中の鼠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "町は、ここから見ると、フライパンの上にそっくり載りそうな程に小さく愛らしく見えた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "別にめりけん粉を卵と水でゆるすぎない様にといたものを拵えて、フライパンにバタをぬってめりけん粉をといたものを少し流し込んでうすい皮をつくります。",
              "citation": {
                "source": "十八番料理集",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「力の及ぶ範囲で、やつてるンでせう‥‥」　政子は、すゐとんがきらひなので、電気コンロに、フライパンをかけて、粉を焼いてゐる。",
              "citation": {
                "source": "愛する人達",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理番が毎日新聞紙を使いますので……フライパンを拭いたり何かして、あとを焚付にしてしまいますので……」「外国で発行したものかどうかお前には解らないだろうなあ」「わかりません」「西洋のポンチ絵が載っていやしなかったかい」「さあ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台の上の寝具は洗い晒した金巾と天竺木綿で、戸棚の中には小桶とフライパン、その他の台所用具が二つ三つきちんと並んでいる。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この書は、技法そのものについて、例えば新らしき芸術を作るには砂糖幾｜瓦、メリケン粉、塩何｜匁、フライパンに入れて、といった風の調理法を説かなかった。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はただフライパンの臭ひと洗濯物の反射と窓の下を通る自動車の爆音の中にぼんやりしてゐる。",
              "citation": {
                "source": "不器用な天使",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを長くでも平たくでも手で好きな形に丸めてフライパンでバターを入れて焼きますが上等にすればその外に玉子を湯の中へ割って落して半熟に湯煮て肉の上へ載せて別にブラウンソースをかけて出します。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鍋　と　おやかん　と　フライパン　の　けんくわ村山籌子　よう子ちやんはお台所が大好きでした。",
              "citation": {
                "source": "お鍋　と　おやかん　と　フライパン　の　けんくわ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにお母さんはお鍋と、おやかんと、フライパンを火にかけて、お庭へ出てゆきました。",
              "citation": {
                "source": "お鍋　と　おやかん　と　フライパン　の　けんくわ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」出ない声をはり上げて、フライパンまでが歌ひ出しました。",
              "citation": {
                "source": "お鍋　と　おやかん　と　フライパン　の　けんくわ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブク、ブク、シユツ、シユツ　パク、パク、パク　グツ、グツ、グタ、グタ　チリ、ピチ、チリ　お鍋とおやかんとフライパンはめいめい夢中になつて歌つてゐるうちに、さあ、大変、みんなガバンガバンと煮えくりかへつてしまひました。",
              "citation": {
                "source": "お鍋　と　おやかん　と　フライパン　の　けんくわ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音をききつけて、お母さんは大あわてにあわてて、台所へかけこんで、お鍋とおやかんとフライパンを火から引きずり下しました。",
              "citation": {
                "source": "お鍋　と　おやかん　と　フライパン　の　けんくわ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鍋とおやかんとフライパンのけんかはこれでおしまひになりました。",
              "citation": {
                "source": "お鍋　と　おやかん　と　フライパン　の　けんくわ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よう子ちやん、こんどから、お鍋や、おやかんやフライパンがブツブツ言ひ出したらお母さんにすぐ知らさなくちやいけませんよ。",
              "citation": {
                "source": "お鍋　と　おやかん　と　フライパン　の　けんくわ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鍋とおやかんにけんかをしかけたフライパンが悪いのよ。",
              "citation": {
                "source": "お鍋　と　おやかん　と　フライパン　の　けんくわ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
