        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小男の叔父よりもすこし背が低くて、二重まぶたの大きな眼が純然たる茶色で、眉が非常に細長くて、まん丸い顔の下に今一つ丸まっちい腮が重なっていた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり充血したその目はふだんよりも大きくなって、二重まぶたになっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろは西洋かぶれの流行から一般の美意識は二重まぶたを好むようであるが、あまりはつきりした二重まぶたは精神的な陰翳が感じられなく甘いばかりで無味乾燥なものである。",
              "citation": {
                "source": "顔の美について",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋的な深みや味は一重まぶたもしくははつきりしない二重まぶたにあり、長く眺めて飽きないのはやはりこの種の顔である。",
              "citation": {
                "source": "顔の美について",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろばかな人間が手術をして一重まぶたから二重まぶたに転向する例があるが、もつたいない話である。",
              "citation": {
                "source": "顔の美について",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふくれた二重まぶたは上下にひき開けられていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "二重まぶたに相違ない。",
              "citation": {
                "source": "怪しの館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「白」は桃色の膚がなまめかしく、高い鼻、赤くて薄いくちびる、二重まぶたの目が女のように優しく、ふっくらとして、しかもよく締まったしりからももの線が、うっとりするほど美しかった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "太いけれど薄いまゆの下の二重まぶたの大きな目が敏捷に動いた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆたかな顔、弓なりの眉、ながい睫毛のしたにある二重まぶたのすずしい眼、端正な鼻、二枚のはなびらのような唇、わたしが画家であったならば、生命をかけてでもかきたいと思うようなうつくしい顔です。",
              "citation": {
                "source": "人魚",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸い目は二重まぶたで、小さな鼻が、高からず低からず、すっきりと抜けている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀ぶちの眼鏡の奥で、二重まぶたの目が意外にやさしい。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼科では、ひとえまぶたを、ふたえまぶたにする手術は、てがるにできます。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
