    "definitions": [
      {
        "index": 1,
        "gloss": "injured soldier",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "宿州の激戦に依る負傷兵は、その儘、戦場に遺棄された。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "癒る見込のない負傷兵は片づけッちまえ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "埋められる負傷兵は、「可哀そうだと思って下され！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "負傷兵は、どの病室にも、いっぱいにあふれていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大砲をうつとき、片脚をぷんとうしろへ挙げる艦は、この前のニダナトラの戦役での負傷兵で、音がまだ脚の神経にひびくのです。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご承知でもございましょうが、この温泉が今日のように、世間に広く知られるようになりましたのは、日清戦争以後のことで、戦争の当時陸軍の負傷兵をここへ送って来ましたので、あの湯は切創その他に特効があるという噂がにわかに広まったのでございます。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時にその負傷兵を見舞の人たちも続々ここへ集まって来ましたので、いよいよ温泉の名が高くなりました。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが負傷兵であることは、その白い服装をみてすぐに判りました。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "つもりつもった疲労と負傷とが相まって、私は衰弱しきってしまい、そのため、おびただしい数の負傷兵と一緒にペシャワールの基地病院へ後送された。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "負傷兵の後送されて來るのに遭ふ。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常な負傷兵は皆機關砲でやられて居た。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "負傷兵を收容するのは夜間のことであるから夜になつて運ばれて來るものは想像の外であつた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "テントの外にある負傷兵は毛布も無ければ外套もない。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院の廊下に吊るされた籠の中の駒鳥は、朝早くから鳴きしきって、負傷兵たちの夢を破っていた。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに、その頃からワルシャワの街には、負傷兵がみち溢れた。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "負傷兵を載せた無蓋の馬車が、ワルシャワの大通りに続いていた。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに彼がラウカの戦線で味方の負傷兵と重砲とを救った語は、ほとんど全軍に知れた話である。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵の捨てて遁げた汚い洋館の板敷き、八畳くらいの室に、病兵、負傷兵が十五人、衰頽と不潔と叫喚と重苦しい空気と、それにすさまじい蠅の群集、よく二十日も辛抱していた。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この戦役におけるイギリス負傷兵の状況の酸鼻が、しばしば議会の問題となり、世界の注目がそこにあつめられた。",
              "citation": {
                "source": "フロレンス・ナイチンゲールの生涯",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動会の余興の折に、赤十字の真似をし、私たちは負傷兵になり、政子姉や藤子姉は四、五級上だから看護婦に扮装して、繃帯を巻いてくれた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中の停車場で負傷兵を満載した列車にも逢った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦地の方から送られて来たそれらの負傷兵は白耳義方面の戦いの激しさを事実に於いて語って見せていた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "働き盛りの男子は皆｜畠や牧場を去り、馬は徴発され、小屋も空しくなり、陶器の工場も閉され、商家も多く休み、中学や商業学校の校舎まで戦地の方から送られて来る負傷兵のための収容所となっていた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十二年の役の直後に、他の負傷兵と一しょにコペイキン大尉も故国へ送還されてきたのです。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その頃はまだ負傷兵を救済する何等の法令も定まっていなかったのでしょう。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
