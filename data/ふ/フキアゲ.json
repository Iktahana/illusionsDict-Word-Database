[
  {
    "uuid": "13dbae3f-49d9-50bf-8cab-18a775343442",
    "entry": "吹き上げ",
    "reading": {
      "primary": "ふきあげ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
