        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "がウェリントンはそこに赴援せずして、全援兵としてただ近衛の他の四個中隊とブルンスウィックの一隊とだけをつかわすに止めておくことができたのである。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兵船をすすめ、治利を救え」　水路――兵船団は赴援にいそいだ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "当然、歴城の兵をひきいて、韋康を赴援すべきであったが、その滅亡の早かったため、兵をととのえて馳けつけるに間に合わなかったものである。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "偽使者とは夢にも気づかず、崔諒は兵を集めて赴援の準備をしていると、二日の後、またまた、一使者が来て城門へ告げた。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間がもつともつとふえんことにや。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことなら段別なんぞふえん方がよかつた、とはつきり口に出して云つてゐる者さへゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "余はむしろ新華族新博士の益ふえん事を望むなり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドストイェフスキーの考えかたをふえんすれば「現代は個々の精神が彼の時代におけるような循環的混沌の中に上下していられないほど、精神の闘争力の源泉としての調和、性の一致を求め必要として来ている。",
              "citation": {
                "source": "ツワイク「三人の巨匠」",
                "author": "――ドストイェフスキーの部（偉大な統一の破壊者、永遠の分裂者としての）――",
                "note": "青空文庫"
              }
            },
            {
              "text": "抑※のはじまりは『昼夜随筆』の中にある、今日の文学としての三二―三七頃までの概観と、次はそれをふえんしてかいた百枚の未発表の昭和十二年までの文学史と、その上にあれがあるのですから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまでも文学をはなれず、古典のよみかたもおのずから会得しつつ作者とその時代もわかり、そこからひろくふえんされたものの感じかたに導かれるというのもわるくないでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
