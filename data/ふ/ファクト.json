        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "実ににくらしくマター・オブ・ファクト。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂ベア、ファクトというものは、通常ベア、赤裸と思われている。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ファクトが精神のリズムに貫かれているとき、其はそのものとして完璧の脈動にうっている。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ六十年間位も何のわき目もふらずにやっております結果、その永い間に植物につきいろいろな「ファクト」をのみ込んではいますが、決して決して成功したなどという大それた考えはした事がありません。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "「論文」という名義にひきずられてただの学術論文めいたものが書かれたり、そうかと思うと「科学」の名にかくれて、科学セクション式に仕切りに仕切られたベア・ファクトが出ていたり、一体思想はどこへ行ったかと云いたくなるだろう。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、また後からせかせかしたことを非難するなら、詰り彼の、マター・オブ・ファクトな性格を持ち出さなければならないだろう。",
              "citation": {
                "source": "我に叛く",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スメドレイの従軍記と全くちがって、事務的に（マタ・オヴ・ファクト的に）数字や人名など表記して居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファクトリー・ホワイトね。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄光ロードレース・クラブで使っている一流のファクトリーが、整備をひきうけてくれた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
