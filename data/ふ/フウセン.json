    },
    "definitions": [
      {
        "index": 1,
        "gloss": "balloon (toy or decoration)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかもガードを一つ距てて、淀橋の向ふに二幸や三越のビルヂングが壘立し、空には青い廣告風船があがつて居る。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊園地にて遊園地の午後なりき樂隊は空に轟き※轉木馬の目まぐるしく艶めく紅のごむ風船群集の上を飛び行けり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎なり虎なり午後なり廣告風船は高く揚りて薄暮に迫る都會の空高層建築の上に遠く坐りて汝は旗の如くに飢ゑたるかな。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もういつぺん母親に連れられて　　祭の日には風船玉が買つてもらひたい、　　空は青く、すべてのものはまぶしくかゞやかしかつた……　　忌はしい憶ひ出よ、　　去れ！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンポアンから　ゆらゆらと風船でも飛ばしたい麗かさだ。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにちゃんと一つ風船が浮いている。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二室三室と移って行くうちに、始めの緊張した心持は孔のあいた風船玉のようにしぼみ縮んで行く。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはぜつたいぜつめいだ、おれは病気の風船のりみたいに、いつも憔悴した方角で、ふらふらふらふらあるいてゐるのだ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人情紙風船」が山中貞雄の遺作ではチトサビシイ。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "五回に一回くらいは風船に旗を吊したものや、相撲や兵隊などの人形の出るのがあった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風船玉ぐらいだったとか、電球の大きさだったとかいうのが普通である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南側の壁には、紙の風船玉がひとつ、くつついてゐた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "南側の壁には、紙の風船玉がひとつ、くっついていた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たうとう狼をたべてから二十五日めに狸はからだがゴム風船のやうにふくらんでそれからボローンと鳴って裂けてしまった。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば人形の首が脱け落ちたり風船玉のようなものが思いがけなく破裂したり、棚のものが落ちて来たりした時のがその例である。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが生徒に腹を立ててどなりつけるのではなくて、いったいどうして生徒がそういう不都合をあえてするかということに関する反省と自責を基調とする合理的な訓戒であったのだから、元来始めから悪いにきまっている生徒らは、針でさされた風船玉のように小さくなってしまった。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "※まことに人生、一瞬の夢、　　　　ゴム風船の、美しさかな。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『やア、大佐の叔父さんが、風船で救けに來たんだよ／＼。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "彌次郎が其の時代には夢にも室氣枕の事などは思ふまい、と其處等を※すと、又一人々々が、風船を頭に括つて、ふはり／＼と浮いて居る形もある。",
              "citation": {
                "source": "大阪まで",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（風船なんて危いものはもっての外だ――）と云って、年寄の父はいくら私が強請んでも乗らしてくれなかった。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以後「風船」は私の最も大きな願望の一つとなった。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十年も過ぎて、乗物の風船が、再び現われた。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "風船は、併しちっとも人気がなかった。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれで、それをば幸いに、殆ど自分がその風船の主ででもあるかのように、寛いだ気持で空の楽しい一時間を費すことが出来た。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "――正直なところ、なんだってそう毎日々々、こんな風船に乗りにいらっしゃるのだか、あたしにはもうすっかり考えようがなくなってしまったわ。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どうも、西洋人ともあろうものが、しかもあの年輩をして、風船なぞへ乗って楽しむなんて、なかなか信じ難い話だ。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　その翌日も、私は西洋人と一緒に風船へ乗った。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると最早や私一個の風船に対するあどけない興味なぞは心の隅に追い込められてしまった。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍事探偵なぞと云うものは、内気なツルゲエネフのような顔をしていたり、またそんな子供の運動帽子みたいな色彩をした風船に乗っていたりするものではない――と私は、心のうちでひそかにくやんだことであった。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野の山の青空に風船が浮かんで、その下に散りかけた桜の花が煤けた古綿のように汚ならしく見えました。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
