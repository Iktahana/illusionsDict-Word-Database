  {
    "uuid": "5df41f72-094d-575c-a6b9-31086e52d42f",
    "entry": "風選",
    "reading": {
      "primary": "ふうせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wind winnowing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こめだわらの　上に、だいこくさまを　かざって、青や　赤の　ふうせんだまが　いくつも　ついて　いました。",
              "citation": {
                "source": "はつゆめ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユウ子ちゃんが、うちのにわであそんでいますと、赤いゴムふうせんが、空からふわふわとおちてきました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかの子どもが、ふうせんの糸をはなして、空へとび上がったのが、力が弱くなっておちてきたのでしょう。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユウ子ちゃんがそう思って、赤いふうせんをじっと見ていますと、やがてそれは、すぐ目の前のじめんにおちました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふうせんには糸がついていて、その糸のはしに、白いものがくくりつけてあります。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "空を見上げると、せいどうのまじんは、ふうせんのように、高く高くとんでいきます。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、ふうせんだったのです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに、せいどうのまじんのふうせんです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのたびに、まじんのふうせんは、ぐらっぐらっとゆれるのです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビニールのまじんのふうせんは、ガスがぬけ、ぺっちゃんこになって、そこにひっかかっていました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あっ、このくびはふうせんだ」　ぽけっとこぞうは、ごむふうせんをふくらまして、じぶんのかわりにしておいたのです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのふうせんは、にんげんのかおのかたちをしていて、にんげんのようないろがぬってあったのです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、大きなふうせんだったのです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十めんそうは、こんなときのよういに、くさむらの中に、ふうせんと、すいそガスのポンプをかくしておいたのです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから、手下が、ふうせんにガスをいれていたのです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大ふうせんは、ふわふわと、そらたかくのぼっていきます。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふうせんは、かぜにふかれてりくのほうへとんでいくので、みんなは、ランチでりくにもどり、れんらくしておいたけいさつのじどうしゃにのって、おいかけました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふうせんは、にしへにしへとながされて、よこはまのまちをとおりこしました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふうせんは、だんだんしぼんで、そのかんのんさまの上におちていきます。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜空を、まるいふうせんが、ユラユラとのぼっていたのです。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きなふうせんから、つながさがり、そのつなに、赤い布でつくった透、明、怪、人という大文字がむすびつけてあります。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "アドバルーンは、塔の屋根から、つなで空にういていたのですが、四十面相はそのつなを切って、赤い布の大文字にすがりつき、大ふうせんのとびさるままに、身をまかせたのです。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどガスをつめたばかりで、大ふうせんは、はちきれんばかりに、ふくらんでいます。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "探照灯の白いひかりが、それを追っかけ、まるいふうせんは銀色に光っています。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、あの大ふうせんが、野球のボールのように、小さくなってしまいました。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかはふうせんがしなびてくるのです。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "やあ、銀色に光ってらあ、あれ、広告ふうせんだよ。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　みんながガヤガヤ言っているあいだに、その銀色の大ふうせんは、風におくられて、グングンちかづいてきました。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、まっ黒な人間のさがったふうせんが、とんできたのが、ふしぎでしかたがありませんでした。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
