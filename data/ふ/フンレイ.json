    },
    "definitions": [
      {
        "index": 1,
        "gloss": "strenuous efforts",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "余、甚だ然りと答へ、ともに奮励して大いに為すあらんことを誓ひき」と。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自信力の発動は奮励となり、健闘となり、発展となる。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "加ふるに当時遼東半島還附の遺恨問題あり、心ある国民は臥薪甞胆の意気燃ゆるが如く、何時かは世界第一等国民となつて、彼等を見返し呉れんと奮励努力せしが故に、十年の歳月甚だ長からずと雖も、其間に日本の国力は驚くべき発展を為せしなり。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "願くば諸君と相共に国家の為に奮励努力せむ。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると大博士はそれをちょっと見て、一言か二言質問をして、それから白墨でえりへ、「合」とか、「再来」とか、「奮励」とか書くのでした。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私は天寿の許す限り趙州の顰にならつて奮励する心組でゐる。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "遂げ難き相思益志気を奮励す。",
              "citation": {
                "source": "熱意",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その時はまだその時で、一層奮励の筆をもって、補いをつけることが出来ると、覚悟した。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く放棄されたこの家はただ僕一人の奮励いかんにあるのだが、第一に胸に浮ぶ問題は、「この月末をどうしよう？",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "直接の努力は当面の努力で、事に当たって奮励努力する時のそれである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして気が張ればいよいよ、その道・その教・その学に奮励精進させるから、益々その自覚の核心を強固にして長養する。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "中年作家の奮励を望まずにはゐられない。",
              "citation": {
                "source": "三月の創作",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　何を出すのかと弥吉が眺めてゐると、喜太郎は「是為奮励努力記念也」と大書した箱から昔の反纏をとり出して、斯様な意見を与へられたとのことである。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さはれ木枯吹きすさむ夜半、幸多き友の多くを思ひては、またもこの里のさすがにさびしきかな、ままよ万事かからんのみ、奮励一｜番飛び出でんかの思ひなきにあらねど、また静かにわが身の運命を思へば……、ああしばしはかくてありなん。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "銃後にある忠勇なる国民諸君も、十分沈着元気に協力一致せられて、防護に警備に、はたまたその業につくされ、もって暴戻なる外国Ｓ国軍の反撃に奮励していただきたい。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ予習復習の奮励が教室でめき／＼と眼に立つ成績を挙げるのを楽しみにした。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "緊張した力を張りつづけて、来年は大いに奮励する、したいのである。",
              "citation": {
                "source": "日記",
                "author": "一九二〇年（大正九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち各地に於て日夜前条の御趣旨を演説し、また諸藩の重臣と会して朝旨を誤解せざると共に王事に奮励すべきことを勧めしが、加賀国大聖寺に到る間に於て、寺院及び民家より軍資を献納したるもの参万金に達せり。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の友人が地方に巡回して農民に勧めるときに、お前たちの仕事は実に国家的の事業であって、昔から農は国の本というたくらいであるから、いかに苦しくも、いかに利益が薄くとも、国家のために奮励せよと説いて歩いた。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの意味は、多分農民みずからが奮励して、農業を利益あるようにせよという意味であったろうけれども、普通農民の耳に入ったときは、やはり昔のごとく強制的に労働をして、ただお上に運上を収める道具になるだけのことであるという観念を与えた。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "省て退歩せる点あらばさらに理想に向かって奮励努力一番し、かくしてつねに若い心持ちで向上する。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "べこ大いに奮励一番して彼女を人にしてやらなければ愛した甲斐ないと思う。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間私はほんとうに奮励努力しなければなりません。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "真志保は運よからず中学へははいられませんでしたが無事高等二年に昇級、孜々として奮励勉学に余念ない様子で御座います。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "文作の折角の奮励努力も、気の毒ながら楚々たる美女との交渉を発展させることはできなかった模様である。",
              "citation": {
                "source": "正午の殺人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "先月、というと、一月のことだが、その月末ごろに、三流どこのあまりハヤラないダンスホールがダンサー各員一そう奮励努力せよ、そこで週間の売上げナンバーワンからテンまでに勲章を授与した。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居にしても、映画にしても、彼等の御機嫌をとるよりも、彼等とともにお互いに自らを顧みて、奮励一番、改革をなすべき時である。",
              "citation": {
                "source": "アーニイ・パイルの前に立ちて",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　まだ築地本願寺側の僑居にあった時、わたしは大に奮励して長篇の小説に筆をつけたことがあった。",
              "citation": {
                "source": "十日の菊",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧華族の中には自ら高く止まって、新華族と伍するのを快しとせぬものがあるかもしれぬが、それはむしろ彼らの瘠我慢で、偶然、貴族の家に生れ合わしたという幸運と、自己の奮励努力によって贏ち得た爵位と、その価値いずれにあるかは、識者を俟たずして明らかなところである。",
              "citation": {
                "source": "「特殊部落」と云う名称について",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この奮励努力によって贏ち得たものは、その実質が正にその爵位に相当するものである。",
              "citation": {
                "source": "「特殊部落」と云う名称について",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
