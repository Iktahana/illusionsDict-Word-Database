    "definitions": [
      {
        "index": 1,
        "gloss": "bracing oneself up to action, being inspired by something",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
