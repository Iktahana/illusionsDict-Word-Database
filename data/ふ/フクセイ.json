    },
    "definitions": [
      {
        "index": 1,
        "gloss": "reproduction",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "壁をみるとユトリロの風景の複製と、誰のだか知れない裸かの女三人が浅瀬でボートに乗移らうとしてゐる絵とが掛かつてゐる。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "トーキーの場合には、実際の音の音色は決してそのままに記録され複製されない。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでは主に廻折格子を写真で複製する実験をやったのである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの絵は自分の眼にはただ一種の空虚な複製品としか思われなかった。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまには複製でない本当の原本と思われる絵を見出して愉快を感じる事もあったが、ややもすればその独創的な点がもうそろそろ一種の安心したような、これでいいといったようなおさまり方に変化するのを認めて失望した。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "複製の技術としての絵画はとうの昔に科学の圧迫を受けて滅亡してしまった。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう絵を見るよりも私はうちで複製の広重か江戸名所の絵でも一枚一枚見ている方が遥かに面白く気持が好いのである。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の画家が比較的近年になって、むしろこうした絵画に絵画本来の使命があるということを発見するようになったのは、従来の客観的分析的絵画が科学的複製技術の進歩に脅かされて窮地に立った際、偶然日本の浮世絵などから活路を暗示されたためだという説もあるようである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして芝居の複製に過ぎないようなトーキーもやはり失敗であるとしか思われない。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "言うまでもなく独立な芸術としての有声映画の目的は、やはり他にすでにあるものの複製ではなくて、むしろ現実にはないものを創造するのでなければなるまい。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには映画は舞台演劇の複製という不純分子を漸次に排除して影と声との交響楽か連句のようなものになって行くべきではないかと思われるのである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学時代には、油絵といえば、先生のかいたもの以外には石版色刷りの複製品しか見た事はなかった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの国の有名な画廊にある名画の複製や、アラビアンナイトとデカメロンの豪華版や、愛書家の涎を流しそうな、芸術のための芸術と思われる書物が並んでいて、これにはちょっと意外な感じもした。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それの草稿が遺族の手もとにそのままに保存されていたのを同氏没後満三十年の今日記念のためにという心持ちでそっくりそれを複製して、これに原文のテキストと並行した小泉一雄氏の邦文解説を加えさらに装幀の意匠を凝らしてきわめて異彩ある限定版として刊行したものだそうである。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんといってもこの本でいちばんおもしろいものはやはりこの原稿の複製写真である。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "複製原稿で最もおもしろいと思うのは、詩稿のわきに描き添えられたいろいろの化け物のスケッチであろう。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三色写真が絵画の複製術として物足りないごとく、蓄音機は名曲のすぐれた演奏の再現器として物足りないものである。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋人の書いた、浮世絵に関する若干の書物のさし絵、それも大部分は安っぽい網目版の複製について、多少の観察をしたのと、展覧会や収集家のうちで少数の本物を少し念入りにながめたくらいのものである。",
              "citation": {
                "source": "浮世絵の曲線",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし映画が単なる複製の技術としてのただの活動写真というだけの境界から脱却して、それ自身の独自な領域を自覚するようになり、創作の新しいミリューとして発見されると同時に行なわれはじめた映画制作の方法がすなわちこのモンタージュである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たびたびどうも、複製をお送り下すつて難有う」「地霊…………アスタ・ニールズン」彼はニールズンを好きで、数枚その肖顔を描いてる男である。",
              "citation": {
                "source": "散歩生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって僕は歌劇の舞台以外おしろいをべったり塗って西洋人のなかをしゃなしゃな歩く沢山のマダム・バッタフライの複製には飽き飽きしているんだ。",
              "citation": {
                "source": "オペラの帰途",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上記のライセンスに従って、訳者に断りなく自由に利用・複製・再配布することができます。",
              "citation": {
                "source": "はだかの王さま",
                "author": "THE EMPEROR'S NEW SUIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年深良一知の顔だけの拡大写真が幾枚となく複製された。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ん坊を抱き取つて、あやしながら其の顏に見入る眼差に至つては、子供一般に對して婦人の有つ愛情とは全く別な激しさを以て爛々と燃え、複製を通じて原畫を想像しようとする畫家の眼と雖も、到底この熱烈さには及ぶまい。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーガンの複製を見てをるだけだ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの、ほんの僅か一部の、朧げな複製があとに残るにすぎないんだ。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁に掛けられたあくどい色の複製どもも、今はもう見るのも厭だ。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーガンの複製を見ておるだけだ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
