        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔くもにつらなるでこぼこがらす〕宮沢賢治くもにつらなるでこぼこがらす杜のかなたを赤き電車のせはしき往来べつ甲めがねのメフェスト",
              "citation": {
                "source": "〔くもにつらなるでこぼこがらす〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝肉祭の花祭りも、レマンの湖畔モントルーの、ナルツィセン・フェスト Narcisen-Fest ほどに興をひかない。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、そのマニフェスト（？",
              "citation": {
                "source": "プルウスト雜記",
                "author": "神西清に",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュルレアリズムというのは、前大戦後にとびだした畸型児であるが、文学の方ではアンドレ・ブルトンなどが旗持ちで、彼はシュルレアリズムのマニフェスト（宣言）というものを書いている。",
              "citation": {
                "source": "安吾巷談",
                "author": "教祖展覧会",
                "note": "青空文庫"
              }
            },
            {
              "text": "このマニフェストというのはコケオドシの実にツマラヌものであった。",
              "citation": {
                "source": "安吾巷談",
                "author": "教祖展覧会",
                "note": "青空文庫"
              }
            },
            {
              "text": "オペラ座へ〈ファウスト〉を見に行ったとき、メフェストが出てきたら、びっくりして坐ったままで pipi（おしっこ）をしちゃったんだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "未明、船すでにハンメルフェスト港内にあり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "余はさきに北極海観光のときに、世界中最北の市街ハンメルフェストに寄航せしが、今またこの最南の市街に上陸するを得たり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "マニフェストの著者が「国家としての国家」と云ったのは無論イデー的乃至無的な菩薩国のことでなくて、イギリスやフランスやドイツのことだった。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は彼自身をメィフェストやヨブに擬えようと無意識のうちに考えていたのであったと思えば興味がないでもなかったが、却って肉体的の憂鬱を感じさせられる方が遙かに多かった。",
              "citation": {
                "source": "あめんちあ",
                "author": "富ノ沢麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、ベシェール・フェスト――クリスマスを祝って贈物をする日――のことが思いかえされた。",
              "citation": {
                "source": "秘密礼拜式",
                "author": "アルジャナン・ブラックウッド",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
