    "definitions": [
      {
        "index": 1,
        "gloss": "unfit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "寧ろこれは、此の詩観が大体の結着をみた当時、即ち今より十三年ばかり前に書けばよかつたのであるが、当時は青春で一杯であつて、論文を纏めるなぞといふ気持には不向きであつた。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その不合理不経済なところにポエトリーはあるが現代には少し不向きである。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしパイプ道楽は自分のような不精者には不向きである。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの宗教と科学とは両立しないという議論なぞは、少くとも仏教には不向きなのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに、彼はあまりに江戸歌舞伎式の芸風であるために、明治の初年はともあれ、明治末期または大正昭和の大劇場には不向きの俳優となって仕舞ったらしい。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに、ロマンティストは速成教師として最も不向きなのでしょう。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしておよそ商家に育つて自分くらゐ商売に不向きな性質の人間はないと悟つた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもわたくしは、いよ／＼ものに思い耽って、たゞ愛想に微笑するくらいでいますと、老人は、この手でわたくしの興味を牽くことは不向きと思ったか、今度は話し口を変えて来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが遺憾なことに、こうした局面打開策は、そうした元気旺盛な、精力の強い人にして初めて出来る事で、何回となく死に損ねた、見かけ倒おしの私には全然不向きな更生法なのです。",
              "citation": {
                "source": "スランプ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　どうせ、実生活には不向きな姉である。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、「俳諧」のほうにはどうも不向きらしい。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はあの男は小柄で悲劇には不向きだと腹のなかで言っていたじゃないか」　これはまさしく私の考えていたことだった。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "年は二十一で、五、六年まえから尾張屋の厄介になってやっぱり店の仕事を手伝っているんですが、どっちかというと孱弱い方で、米屋のような力仕事には不向きなので、遊び半分にぶらぶらしているようでした」「尾張屋には死んだ娘と主人のほかに誰がいる」と、半七は又｜訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵は悪紙に描きなぐった泥画であるゆえ、田舎のお大尽や成金やお大名の座敷の床の間を飾るには不向きであるが、悪紙悪墨の中に燦めく奔放無礙の稀有の健腕が金屏風や錦襴表装のピカピカ光った画を睥睨威圧するは、丁度｜墨染の麻の衣の禅匠が役者のような緋の衣の坊さんを大喝して三十棒を啗わすようなものである。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちと古風でござりまするが、それがお不向きでござりましたら、こちらが真巻きにぬり重籐、お隣が日輪、月輪、はずれが節巻きに村重籐。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る一つの天才しか持たぬ青年、又は生れ付き学問に不向きなタチの少年は、いつも成績不良の汚名を受けて、学校や家庭から冷遇される。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、相手が女で極めてデリケートな手腕を要するので、明治生れの、九州育ちの、しかも長男が七つにもなる記者にとっては不向きであった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとて「牡丹燈籠」「塩原多助」のたぐいはこの一座に不向きであるので、団十郎や左団次に出来そうな物という注文から、この「西洋話」が選抜されたものらしい。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあやめという人は、背も高く、柄も大きく、女形に不向きでありながら、その音声といい、身のこなしといい、不思議に女らしい俳優であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええとそれだから奥村氏には、ちと不向きでございますなあ」「ははあさようでございますかな」――だが正雪にはわからないらしい「いやむしろこれはこういった方がよろしい。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "来て見て私は木曾の風景が日本画向きのものであって洋画の写生の材料としては不向きだということを知りまして少し失望はしましたけれど、それでも私は毎日のようにカンヴァスを提げては出かけました。",
              "citation": {
                "source": "温室の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "せりふの多い映画は不向きであるから、極力せりふを少なくし、動きを多くし、あたうべくんば活劇風のものを作れと。",
              "citation": {
                "source": "映画と民族性",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「作品はいいんだが、新聞の読みものとしては、柄が少し悪いし、楽屋落ちも多いから、一般の読者には不向きかも知れない。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のお話でよく訳は分りましたが、どうも私はそういう学校というような所へ出て教師の役をつとめるなどということは私には不向きだと思います。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "学校へ奉職した前後のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔もたいして美人という方ではなく、色が浅黒く、服装はいつも薄汚なく、女のみだしなみを人並以上に欠いていた彼女はどこからみても恋愛の相手には不向きだった。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊３　カリャーキン、ウォロキータ　カリャーキンにはがにまた、ウォロキータには愚図の意味が含まれていて、どちらも凡そ逐電には不向きな名前であるが、それをここでは反語的に皮肉っているのである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体我々はどうも会議というものには不向きな国民である。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父は矢代の生れた日に亡くなり、その家にいた祖母だけは彼はまだ記憶していたが、その二つの家の一つを売り父の家へ叔父一家の移り棲んだ顛末を瞭らかにすることは、若い矢代に不向きと気附いた様子も見え、浄瑠璃の老婆は怜悧にすぐ話を外に反らすのだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の言葉はきたないから詩には不向きだと云うひともあるけれど、随分もったいない話で、私は欧洲にいて日本の言葉の美しさ、日本の詩や歌の美しさを識りました。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧風熱は沸騰して、十二年の九月には、外国役者の一座、英、米、仏人混合の一座をかけたりしたが、言葉がわからないので一般には不向きで不入りだったという、種々の経緯はあったが、新富座は劇道人の向上にはたいした役割をもった。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
