          "literary": [
            {
              "text": "風致地区になっているので、やたらに家も畑もつくらせず、自然の草道が切りひらかれた雑木林の間に遠く消えている。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに市民農園というのがあって、風致地区で空気が軽やかでいいのですが、そこの芝生へ坐って、さてやれと、おべん当をたべました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこは風致地区なのです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
