  {
    "uuid": "61a648f4-d3bb-5c6d-84c5-8172586eedc7",
    "entry": "楓",
    "reading": {
      "primary": "ふう",
      "alternatives": [
        "フウ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Formosan sweetgum (Liquidambar formosana)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こんな事を始めて気づいて驚いている私の鼻の先に突き出た楓の小枝の一つ一つの先端には、ルビーやガーネットのように輝く新芽がもうだいぶ芽らしい形をしてふくらんでいた。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人の家にありたきは、梅櫻松楓、それよりは金銀米錢ぞかし、庭山にまさりて庭藏の眺め、」と書いてある。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "猟師は楓の細木を伐り朴し、枝葉を払わないままで、柱を立て、私たちの用意して来た、二畳敷ほどな油紙二枚を、人字形に懸けて、家根を作る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも飽き足らずに今度は垣の反対側の楓樹までも触手をのばしてわたりを付けた。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその蔓の端は茂った楓の大小の枝の間から糸のように長く垂れさがって、もう少しでその下の紅蜀葵の頭に届きそうである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青楓論と題しながら遂に一種の頌辞のようなものになってしまった。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝生の庭の處處には櫻や檜葉や楓などが立つてゐた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "端書の面の五分の四くらいまで書くと、もう何も書く事がなくなったので、万年筆を握ったまま、しばらくぼんやり、縁側の手欄越しに庭の楓樹の梢を眺めていた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣りの古い墓とのあいだには大きい楓が枝をかざして、秋の蝉が枯れ枯れに鳴いていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔古き勾当貞斎が〕古き勾当貞斎が、　　　　　　　いしぶみ低く垂れ覆ひ、雪の楓は暮れぞらに、　　　　　ひかり妖しく狎れにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "差し出ている楓の枝が見えた。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の人達の湯にはまた溪ぎわへ出る拱門型に刳った出口がその厚い壁の横側にあいていて、湯に漬って眺めていると、そのアーチ型の空間を眼の高さにたかまって白い瀬のたぎりが見え、溪ぎわから差し出ている楓の枝が見え、ときには弾丸のように擦過して行く川烏の姿が見えた。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途中にたった一軒だけ人家があって、楓のような木が幻燈のように光を浴びている。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな昂奮は楓の肌を見てさえ起こった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　楓樹の肌が冷えていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たい楓の肌を見ていると、ひぜんのようについている蘚の模様が美しく見えた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり楓の樹の下である。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして茣蓙を敷くやいなやすぐその上へ跳び込んで、着物ぐるみじかに地面の上へ転がれる自由を楽しんだりする」そんなことを思いながら彼はすぐにも頬ぺたを楓の肌につけて冷やしてみたいような衝動を感じた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "睛、沁芳の泉、楓露の茗四つのものを捧げ、嘔心の文を念じつ祭りしといへるものがたりいとをかし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん自分の中学時代、それもよほど後のほうかと思うころに、父が東京の友人に頼んで「大杯」という種類の楓の苗木をたくさんに取り寄せ、それを邸内のあちこちに植えつけた。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅に染め出でし楓の葉末に凝る露は朝日を受けねど空の光を映して玉のごとし。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時｜青年の目に入りしはかれが立てる橋に程近き楓の木陰にうずくまりて物洗いいたる女の姿なり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年が落とせし楓の葉、流れて少女の手もと近く漂いゆくを、少女見てしばし流れ去るを打ちまもりしが急に手を伸ばして摘まみ、皿にのせて傍らに置きぬ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "由なき戯れとは思いつつも、少女がかれに気づかぬを興あることに思いしか、はた真白の皿に紅の木の葉拾いのせしふるまいのみやびて見えつるか、青年はまた楓の葉を一つ摘みて水に投げたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺骸は有り合わせのうちでいちばんきれいなチョコレートのあき箱を選んでそれに収め、庭の奥の楓の陰に埋めて形ばかりの墓石をのせた。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに砂糖楓の幹にナイフで傷をつけると、見る／＼血液のやうに樹液が滴り落ちる。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は躊躇しては居られぬ塲合、私は突如眞裸になつて海中へ跳込んだ、隨分覺束ない事だが、泳ぎながらに、端艇をだん／″＼と島の方へ押して行かんとの考、艇中からは日出雄少年、楓のやうな手で頻りに波を掻分けて居る、此樣事で、舟は動くか動かぬか、其遲緩さ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "いけ花は、あやめ、姫百合、青楓。",
              "citation": {
                "source": "祭のこと",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しぐれは、いまのまに歇んで、薄日がさす……楓の小枝に殘つた、五葉ばかり、もみぢのぬれ色は美しい。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店の横にも、見上るばかりの槐榎の暗い影が樅楓を薄く交えて、藍緑の流に群青の瀬のあるごとき、たらたら上りの径がある。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
