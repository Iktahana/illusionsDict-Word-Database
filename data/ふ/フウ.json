[
  {
    "uuid": "6caa0988-501d-5f8f-8bf9-2734cf0cc081",
    "entry": "封",
    "reading": {
      "primary": "ふう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "seal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "眩しいような瓦斯燈の下に所狭く並べた絵具や手帳や封筒が美しい。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今になって考えてみるとそのおかげでかえって自分の頭の中には父の言葉で描かれた封建時代の捕鯨の光景がかなり鮮明な影像となって四十年後の今日もまだ保存されているのである。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何者とも知れぬ権威の命令で、自分は未来｜永劫この闇の中に封じ込められてしまったのだと思う。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "安都玉村の素封家、輿水善重氏の宅で小休みする。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "コムプレッサーでは、ゲージは九十封度に昇っていた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "激しい労働生活で節くれ立った彼の愛すべき掌へ、私は故国から来た親愛なる手紙の封書の切手を何枚もはがして乗せてやりました。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（わかもののスールダッタは、洞に封ぜられてゐるチャーナタ老龍の歌をぬすみ聞いて、それを今日歌の競べにうたひ、古い詩人のアルタを東の國に去らせた。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは千年の昔はじめて風と雲とを得たとき己の力を試みるために人々の不幸を來したために龍王の（數字分空白）から十萬年この窟に封ぜられて陸と水との境を見張らせられたのだ。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "左りながら折ふし地方遊説などゝて三｜月半年のお留守もあり、湯治塲あるきの夫れと異なれば、此時には甘ゆる事もならで、唯徒らの御文通、互ひの封のうち人には見せられぬ事多かるべし。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこの場合、「いき」の質料因と形相因との関係が、うすものの透かしによる異性への通路開放と、うすものの覆いによる通路封鎖として表現されている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小指は高くゝりの覚」で貸借の争議を示談させるために借り方の男の両手の小指をくくり合せて封印し、貸し方の男には常住坐臥不断に片手に十露盤を持つべしと命じて迷惑させるのも心理的である。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "北斎漫画を見る時に封建時代の社会の不思議な心理を教えられる。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日まで封じを解かざりしは、我れながら心強しと誇りたる浅はかさよ。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が心は清めるか濁れるか」　封じ目ときて取出せば一尋あまりに筆のあやもなく、有難き事の数々、辱じけなき事の山々、思ふ、恋ふ、忘れがたし、血の涙、胸の炎、これ等の文字を縦横に散らして、文字はやがて耳の脇に恐しき声もて※くぞかし。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い包紙やボール函や封筒なども棄てずに取っておいて使った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから朝飯まで書斎で書信の開封。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在のアメリカでチューインガムがどれだけ流行しているかは知らないが、映画などの中に時々これが現われるし、モーリス・シュヴァリエー主演のチューインガムを主題とした映画が昨年あたり東京で封切されたくらいであるから、おそらく今でも相当の命脈を保っているものと考えてさしつかえはないであろう。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウードジョーンスという人が一昨年の暮にインド洋から空瓶を数個海中に投じ、その中に手紙を封入して誰でもこれを拾うた人はその場所と時日を通知するように依頼してあった。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃ある人が金剛石を真空管内に封入し、これに強い陰極線を当ててみたところが、金剛石は摂氏二千度近く熱せられ真黒な骸炭に変化したそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから暫らくして或日突然、恩地氏から一封の書留小包が届いた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（中略）開封と云う町は想像以上に立派なところで、何でも町の有力者が支那軍の隊長に何万かの金を与えて軍隊を町から撤退させたので町も余り荒れてないそうです。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "読んだっていいだろう」　と源兵衛、封を切って読み始める。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "封を破って金子を紙入れに収めて、　せせら笑って、立ち去った。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "古顏の生徒が勝手に開封して「シヤンだな」など云つて頁をまくる。",
              "citation": {
                "source": "青空同人印象記（大正十五年六月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし馴染になった顔にたまたま小初は相手をしてやると、「へえ、へえ、済みません」　お客にするように封建的な揉み手をして礼をいう。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、妾は急に何ものかに封じられているような可笑しさを覚えて、寝床に顔を埋めて笑い転げました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会の建物の死面に女達は浮気な影をうつして、唇の封臘をとると一人の女が青褪めた朋輩に話しかけた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが、浮気の道を封ずることは男の特権だからな。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "所で私といふ無意識家は、自分が幸福であるか不幸であるかは知らないといへばいへるといふふうなのだ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで私はといへば、まもなくすれば行く手の空に吸はれて了ふのだといふふうな気持で、群集といふ伴奏附きで泳いでゐるやうなものなのである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
