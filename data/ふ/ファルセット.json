        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この曲は、柾生のきれいなファルセットを生かすために選んだものだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "スピーカーから、ブライアンのファルセットが流れてきたのを、慶一は意識の片隅で聴いていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "知り合いの誰もが彼の声とは分からない恐慌のファルセットで。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "その呪文はファルセットとなり、ペンギンのギャーギャー声と綯い交ぜになって谺を返した。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
