[
  {
    "uuid": "d215aa58-aa51-53ba-954d-ad047197f9f0",
    "entry": "付近",
    "reading": {
      "primary": "ふきん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
