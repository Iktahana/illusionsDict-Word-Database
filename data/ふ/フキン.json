  {
    "uuid": "8bd0af7b-a8af-5460-a001-d987b0c97076",
    "entry": "斧斤",
    "reading": {
      "primary": "ふきん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "axe",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "斧斤入らざること幾百千年、老樹しげりて天を刺す。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "又古來斧斤を入れない所の深山を一萬町も濫伐させて、水源を涸すことをさせると云ふは、是は智慧が無いのではない惡意である。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本開始以來斧斤を入れない山と云ふものは、木の根で網の如く絡んで居て、落ちようとする土砂を木の根で固く抑へて居り、崩れかゝる巖石を木の根で固く支へて居る。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "白河の関址と申すところは、一の広袤ある丘陵を成し、樹木｜鬱蒼として、古来｜斧斤を入れざるものあり、巨大なる山桜のさるをがせを垂れたるもの、花の頃ぞさこそと思はれ申候。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りしな、林檎はよくよくふきんで拭いて艶を出すこと、水蜜桃には手を触れぬこと、いったいに果物は埃を嫌うゆえ始終はたきをかけることなど念押して行った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りしな、林檎はよくよくふきんで拭いて艶を出すこと、水密桃には手を触れぬこと、果物は埃をきらうゆえ始終｜掃塵をかけることなど念押して行った。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いふきんと象牙のはしとをだいじに持っておって、それは人に手をつけさせない。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大地図は、国ざかいふきんのくわしい図面でした。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを○子は拭き　その上につやふきんをかけ　そして　腰をおろして　変っていく隣家の庭の様子を見下すのであった。",
              "citation": {
                "source": "窓からの風景（六月――）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ清浄｜無垢な白い新しい茶筅と麻ふきんが著しい対比をなしているのを除いては、新しく得られたらしい物はすべて厳禁せられている。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "匪賊の首領は、玄王のふいを襲って、その城をのっとりましたが、負傷した玄王を人質にとって、金銀廟の中におしこめ、自分は玄王に仕えてる者だ、と、勝手にいって、ふきんの土地を治め、やがてはその王になるつもりでした。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "縞になったのを平気で持ち出すのは、仕事をするのに目を使わないからで、水気の多いふきんでふいたら、次にかわいたふきんでよくふかなければならないというところに気のつかないのは、頭をつかっていない証拠だと思います。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ソ、そうなんです、そのお艶ちゃんに私」　半分ばかり開けてある台所の戸口から思わずグググッと身体を差し入れてきて、「逢わせてください、ねえ小母さん、後生だねえ、ちょいと大急ぎで」「あの、引っ越しましてございますよ」　また気の毒そうに婆さん言った、膝の上へ置いたお皿を急いでふきんで拭きはじめながら。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "おほりの　へりのあたりで　あおばえが　ぶんぶん　いったり、　１ぴきの　ちいさな　おばさんねずみが　ジャムのびん　ふきんの　ごみを　あさったり　していました。",
              "citation": {
                "source": "ばにばにきょうだいのはなし",
                "author": "THE TALE OF THE FLOPSY BUNNIES",
                "note": "青空文庫"
              }
            },
            {
              "text": "モペットちゃん、　じぶんの　あたまを　ふきんで　くるんで、　だんろのまえに　おすわりします。",
              "citation": {
                "source": "モペットちゃんのものがたり",
                "author": "THE STORY OF MISS MOPPET",
                "note": "青空文庫"
              }
            },
            {
              "text": "モペットちゃんは　そのあたまに　つめを　あてがい、　ふきんに　あけてあった　あなから　ねずみを　にらみました。",
              "citation": {
                "source": "モペットちゃんのものがたり",
                "author": "THE STORY OF MISS MOPPET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねずみを　ふきんで　くるんで　むすんで、　ボールみたいに　あちこち　ほうりなげて。",
              "citation": {
                "source": "モペットちゃんのものがたり",
                "author": "THE STORY OF MISS MOPPET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが　ふきんに　あながあったのを　すっかり　わすれていた　モペットちゃん。",
              "citation": {
                "source": "モペットちゃんのものがたり",
                "author": "THE STORY OF MISS MOPPET",
                "note": "青空文庫"
              }
            },
            {
              "text": "おねずみおばさんは　ふきんを　てに、　うしろから　いまの　ゆかに　ついた　しめった　おおきな　あしあとを　ふきとっていきます。",
              "citation": {
                "source": "おねずみおばさんのはなし",
                "author": "THE TALE OF MRS. TITTLEMOUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "木挽町汐留（いまの新橋のふきん）にある奥平やしきにいきますと、鉄砲洲（築地）にある中やしきの長屋をかしてくれるということでした。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一回のテスト潜水で、深度は二十メートルふきんと測定されているのに、二十メートルまでもぐってみても、底らしいものは、ぜんぜん見えない。",
              "citation": {
                "source": "海底の散歩",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠相がふきんを取って茶碗をみがく音だけが低く部屋に流れて、泰軒は困ったように腕ぐみをした。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、これでお拭きよ」　ポンと投げて渡したふきんが、右近の顔に当たる。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると、鼻を低くして、ふきんの土地を嗅ぎはじめた。",
              "citation": {
                "source": "予謀殺人",
                "author": "A CASE OF PREMEDITATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そのネガティヴをもって、私たちはその日の夕方、ロンドンへ帰ったのであるが、ソーンダイクは駅まで見送ってきた警部にこういった――「犯人はプラットを殺したあと、すぐ手を洗ったはずですから、ふきんの池や溝や小川のようなところを歩いてみて、並木道にあったと同じ足跡があるかどうか調べてごらんなさい。",
              "citation": {
                "source": "予謀殺人",
                "author": "A CASE OF PREMEDITATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹の卵はぬれふきんで包み、塩湯に入れると、あわつぶのようにばらばらになる。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿の葉も鮭もあらかじめ乾いたふきんで十分に水気を拭き取っておく。",
              "citation": {
                "source": "陰翳礼讃",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家とてふきんには一軒もないのですから、家から裸のままできたとも思われないのです。",
              "citation": {
                "source": "人魚",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "このふきんの警戒にあたっていた巡査が、今の呼びこを聞きつけて、道化師のゆくてに立ちふさがってくれたのです。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
