[
  {
    "uuid": "a4b3c65a-d309-52ef-8064-ebe854af43d8",
    "entry": "夫君",
    "reading": {
      "primary": "ふくん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
