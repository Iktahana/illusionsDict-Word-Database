        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "激しい労働生活で節くれ立った彼の愛すべき掌へ、私は故国から来た親愛なる手紙の封書の切手を何枚もはがして乗せてやりました。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今朝来たばかりの封書の口を引っぺがしてぬすみ見した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の部屋に這入らうとするところに小使が來て、彼れの兄の腦貧血はもう囘復して先刻家に歸つたと云つて兄が書き殘したといふ封書を渡した。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三度同じことを繰り返してゐるうちに、やつと取り出した一通の封書。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "封書、葉書、御意ノ召スガママニ御染筆ネガイ上候。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉稿、本日別封書留にてお送りいたしました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の上に置いてある彼が不在中に来た封書や葉書を手早く調べた。",
              "citation": {
                "source": "節操",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中に一通｜差出人の姓名の書いてない封書があつた。",
              "citation": {
                "source": "節操",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、売れても売れなくても、必ず四十円の固定給は支給する云々の条件に、申し分がなく、郵便屋がこぼすくらい照会の封書や葉書が来た。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘密会、密封書、暗夜の急ぎ路。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売人なみや」　褒められたと思ったので、「帯封書きはえらいですね」と、微笑しながらお愛想にそう言うと、「明日からほかの仕事してもらうぜ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "月給はろて帯封書いて貰てたらうちの損や。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなり帯封書きだったのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ庭から郵便配達が這入って来て、嘉三郎の膝のところへ、一通の封書をぽんと投げて行った。",
              "citation": {
                "source": "栗の花の咲くころ",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉三郎は髭を剃るのをやめて封書を取り上げた。",
              "citation": {
                "source": "栗の花の咲くころ",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから紙片の上には、数字と倶楽部の名と友人の名を封書したものがあったが、これから推測してみると、彼は死の直前までは、骨牌の損益を計算していたに相違ないと思われるのであった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日――一八八三年三月でした――外国切手のある封書が大佐の皿の前に置かれたのです。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの封書の消印を挙げていくと？",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の上にみ篶子からの絵はがきと妹からの封書がきてる。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "四（封書――宛名、麹町区丸ビル七階Ｎ……法律事務所内弁護士法学士Ｙ・Ｔ……宛）　前略、亡父の「署名」に関する御問合せの御手紙拝見いたしました。",
              "citation": {
                "source": "初夏通信",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "五（封書――宛名　神奈川県足柄上郡関本村、瀬川岩太郎）　御無沙汰いたしました。",
              "citation": {
                "source": "初夏通信",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを取り調べると、豐後國日田にゐる徳川家の目附役竹中｜采女正に宛てた、栗山大膳利章の封書を懷中してゐた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "封書の目方を計つて投函するためには二里の山坂を越えた駅の郵便局へ赴かなければならなかつた。",
              "citation": {
                "source": "水車小屋の日誌",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどもいささか思い定むるよし心中にあれば頑として屈せず、他の好意をば無になして辞して帰るやいなや、直ちに三里ほど隔たれる湯の川温泉というに到り、しこうして封書を友人に送り、此地に来れる由を報じおきぬ。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて郵船会社からあてられた江戸川紙の大きな封書が現われ出た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "封書の中の長い手紙――あれが、そんなにもこの俺を悲しみの底に突き落したのか、俺はその文字を読むで一刻前泣いたのだつた――そんな予猶らしい洞ろさが私の意識をキヨトンと覆つてゐた。",
              "citation": {
                "source": "痴想",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから續いて追々と各自に無事を知らせる通知が來たが、中に横濱の高梨武雄君からの封書で（前略）以上の人みな無事、唯だ一人金子花城君のみ今以て行衞不明です。",
              "citation": {
                "source": "樹木とその葉",
                "author": "地震日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂ　イヤ、それだけは封書だつた、さうだ。",
              "citation": {
                "source": "ハガキ運動",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は一｜體、滅多に封書といふものを書かない。",
              "citation": {
                "source": "ハガキ運動",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
