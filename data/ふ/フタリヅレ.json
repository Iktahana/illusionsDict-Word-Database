        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "向うから幸福な二人連れが来てすれちがう。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣りに言葉｜訛り奇妙なる二人連れの饒舌もいびきの音に変って、向うのせなあが追分を歌い始むれば甲板に誰れの持て来たものか轡虫の鳴き出したるなど面白し。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝへ新に入り来りし二人連れはいずれ新婚旅行と見らるゝ御出立。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々仲間でその支柱の仕方が果してどれだけ有効であろうかといったようなことを話し合っていたら、通りかかった人足風の二人連れが「アア、それですか、僕達がやったんですよ」と云い捨てて通り抜けた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "年若い芸者を二人連れた若旦那の一組がコーヒーをのんでいる。",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年奥さんと二人連れで道をあるいていた時だった。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "並んで立っていた若い会社員風の二人連れが話しているのを、聞くともなく聞いていると、毎朝同じ時刻に乗る人がみんなそれぞれ乗り込む車の位置に自ずからきまりがあると見えて、同じ顔が同じところにいつでも寄り合うようだと云っていた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽々園で車を降りて入場しようとすると、向うから来る酔っぱらいの二人連れが何かしら不機嫌でいきなり出入口のターンパイクを引っこ抜いて投げ出して行った。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "往路に若い男女の二人連れが自分たちの一行を追い越して浅間のほうへ登って行った。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "春も闌の遅桜、早桃が見渡す限りの筑紫野の村々に咲き乱れて、吾れ勝ちに揚る揚雲雀も長閑な博多東中洲の野菜畑の間を縫うて行く異様な二人連れがあった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　ある日乗り合わせた丸の内の電車で、向かい側に腰をかけた中年の男女二人連れがあった。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし電車の二人連れについては、われわれは「その前」と「その前々」のシーンに関する予備知識を持たないのであるから、従って「その次」のシーンに対する好奇心も起こらない。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊び女を二人連れた下町風の伊達者が通常「詩人の隅」と呼ばれる壁寄椅子の隅に陣地を占め白葡萄酒を飲み乍ら料理の来るのを待っている。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、先生も欲と二人連れ、帰れば一晩ゆっくり遊べるという寸法だから、馬の尻を叩くは叩くは、「ハイヨウハイヨウ、ピシッ」　初めの一里ばかりは馬君風を斫って駆けたが、次第に暗くはなるし、山路の事とて路は素敵に悪るい。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "初卯の日、母様が腰元を二人連れて、市の卯辰の方の天神様へお参んなすって、晩方帰っていらっしゃった。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボーイが二人連れだと思ったのであろう。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その数日前のことだが、ぼくのいる宿に泊った若い女の二人連れが心中した。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈屋さんが二人連れでやつてきたが、お気の毒様、庵には電燈もありません。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、入ると直ぐに、二三日前に小野と妻とが二人連れで矢張りそこの小屋へ同じ映画を観に来たことを思い出したので、三十分と経たない中に出てしまいました。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし共ばかりでは、淋しくて困りますから、Ｂさんに願って、お二人連れでいらっしゃいませんか。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客は私と商人のパリロ氏と牧場主のラメツ氏と医師のフェリラ氏とそしてその他に全く得体の知れぬ二人連れの男女が乗っていた。",
              "citation": {
                "source": "薔薇の女",
                "author": "渡邊温",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さん達が結婚後二人連れで、僕を見舞に来てくれる度毎に、睦しい夫婦仲を見せつけられて、僕のさもしい情慾は愈々残酷に鞭うたれた。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか赤ん坊になって生れ故郷へ帰ったような気持ちになってボンヤリ立っていると向うから綺麗な舞い妓が二人連れ立って来た。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は腹が立ちましたけれども、折角いい事を教えてくれたのですから、御礼を云ってここを出まして、それから二人連れでエッチラオッチラ一里ばかり歩いてその村に来ますと、成る程、村中は大変な騒ぎで、今が祭りの最中です。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると歩調を合せて歩いている自分等二人連れのゆるい靴音までが平凡に堪えないものになって新吉の耳に響いた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスマスのお祭りの、紙の三角帽をかぶり、ルパンのように顔の上半分を覆いかくしている黒の仮面をつけた男と、それから三十四、五の痩せ型の綺麗な奥さんと二人連れの客が見えまして、男のひとは、私どもには後向きに、土間の隅の椅子に腰を下しましたが、私はその人がお店にはいってくると直ぐに、誰だか解りました。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又此の蝦蟆賣りに限りて、十二三、四五｜位なのが、きまつて二人連れにて歩くなり。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "よつて怪しからぬ二人連れを、畜生、蝦蟆賣め、と言ふ。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女のとぎすまされた聴覚に別な男性らしい二人連れの近づいて来る音をも聞き分けた。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "加奈子はじき近くのベンチに眼を戻すと、其処に若い男の二人連れを発見した。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
