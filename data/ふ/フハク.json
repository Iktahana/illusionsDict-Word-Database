[
  {
    "uuid": "81bf7280-49e5-5ffa-8e50-4137557467fa",
    "entry": "浮薄",
    "reading": {
      "primary": "ふはく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "frivolous",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "即ち「侏儒の言葉」は、江戸ツ子的浮薄な皮肉とイロニイとで、人生を単に機智的に揶揄したもので、パスカルやニイチエのアフオリズムに見る如き、真の打ち込んだ人生熱情や生活体感が何処にもない。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし先ず大抵の絵は少し永く見ていると直にそれほどの魅力はなくなる、そして往々一種の堪え難い浮薄な厭味が鼻につく場合も少なくない。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴雄は、学校の先輩であるこの若い作家を、これまで尊敬していたけれど、会っていると、復校願を出すと云ってみたり、「君、恋人あるの」　と、変なことをきいたり、鼻糞をほじったり、軽佻浮薄な男のように感じられてならなかった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはは……」　小田の分類によると、三高出身者には、軽佻浮薄派（さしずめ小田がその代表）と、重厚派の二種類あるが、吉井は、「重厚派と見られることを最もいやがっている所の重厚派」であるだけに、ねちねちした口調で、ポツリポツリ語りだした。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "え、へ、へ、……」　小田はペシャリと額をたたいて、例の軽佻浮薄なる笑いを笑うと、「――ところで、昨日のつづきをきこうじゃないか」「つづき……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吉はふと眉を翳らせて、それが癖の放心しているような虚ろな眼をあげて、きょとんと白い雨足を見ていたが、一つの気分に永く閉じこもることの出来ない信吉はすぐ軽佻浮薄な笑い声にふくませて、「僕は雨男ですね、旅行するときっと雨が降るんですよ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうの作者が一体どこにいるのか、わからなくしてしまおうとさえ思いましたが、調子に乗って浮薄な才能を振り廻していると、とんでも無い目に遭います。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、「足が大地を離れている」「腰がふらついている」「浮薄な陶酔に溺れている」等。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長塚君はたまたま「満韓ところどころ」の一回を見て余の浮薄を憤ったのだろうが、同じ余の手になった外のものに偶然眼を触れたら、或は反対の感を起すかも知れない。",
              "citation": {
                "source": "『土』に就て",
                "author": "――長塚節著『土』序――",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮薄な言動は、つつしみなさい。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、佐助を喜ばしたのは、師もまた洒落るか、さればわれもまた洒落よう、軽佻と言うならば言え、浮薄と嗤うならば嗤え、吹けば飛ぶよな駄洒落ぐらい、誰はばかって慎もうや、洒落は礼に反するなどと書いた未だ書も見ずという浩然の気が、天のはしたなく湧いて来たことであった。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "義理何とかは三年寿命が縮むと来てやがらア」　パイを並べながら、もう軽佻浮薄な口を利いている、このとりとめなさは一体何であろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "レヴュの女優の科白廻しなども、軽佻浮薄めいているからいけないというのではない。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "白き猫膝に抱けばわが思ひ音なく暮れて病む心地する　この浮薄と衒気とを省みると、何が音なく暮れてだ、何が病む心地するだろうと赤面する。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の人心は実に浮薄です。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯の千載一遇の好機会に当り、同胞にして若し悠久の光栄を計らず、徒らに一時の旗鼓の勝利と浮薄なる外人の称讃に幻惑するが如き挙に出でしめば、吾人は乃ち伯叔と共に余生を山谷の蕨草に托し候はむかな。",
              "citation": {
                "source": "渋民村より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時アまたお前の厭な芸者にでもなるよりほかアなかろうぜ」「そりゃア、あたいも考えてまさア、ね」「そのくらいなら、初めから思いきって、おれの言う通りになってくれよ」　田島の声は、見ず転芸者を馬鹿にしているような句調ながら、まんざら全く浮薄の調子ではなかった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると、浮薄な吉弥のことなどは全く厭になってしまった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、陵は友のためにその妻の浮薄をいたく憤った。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場の人気ほど浮薄なるものなし。",
              "citation": {
                "source": "我が馬券哲学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど面を公衆の前に曝すことを憚らず、浮薄なる貴公子を戀ひ慕へるなど、われはいかなる詞もて評すべきを知らぬながら、その人のおん身の妻とならざりしをば喜ぶなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がそこですぐさま向う見ずに跳びこんでいった無分別な愚行の渦は、自分の過去の月日の泡だけを除いてすべてを洗い去り、堅実な、または真面目な印象は一つ残らずさっさとのみこみ、以前の生涯の全く浮薄なものだけしか記憶に残さなかったのだ。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来矢野は意志の力が強く天品詩人的な男だから、浮薄な名誉心などに動かされる質ではないけれど、み篶子ゆえには世俗的の名誉も求めねばならないような気がしているのも事実である。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "長塚君はたまたま「滿韓ところ／″＼」の一囘を見て余の浮薄を憤つたのだらうが、同じ余の手になつた外のものに偶然眼を觸れたら、或は反對の感を起すかも知れない。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し現在多くの繪畫は誇張に伴ふ浮薄と虚僞との惡感を催さしむるのであります。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が今日ここにお話しいたしましたデンマークとダルガスとにかんする事柄は大いに軽佻浮薄の経世家を警むべきであります。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "人情の浮薄さ東西古今別なきを思って、微笑まるるのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮薄・雑駁・ごまかし・いいかげん・ふまじめ・懶惰などと云うのは皆忠の反対で、それ等は全て堕落、醜悪の原因となるものである。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
