[
  {
    "uuid": "32d94783-abd1-5db3-a9e3-329fccc752c2",
    "entry": "副業",
    "reading": {
      "primary": "ふくぎょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
