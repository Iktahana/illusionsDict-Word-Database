[
  {
    "uuid": "b812878d-e274-547a-a4a9-844e912fe1b5",
    "entry": "振り替える",
    "reading": {
      "primary": "ふりかえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to change (e.g. a bill)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "後の方でダーダーと云う者があるからふりかえると、五、六｜間後の畔道の分れた処の石橋の上に馬が立っている。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすい幌の中でふりかえる。",
              "citation": {
                "source": "めくら草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人間の心で、虎としての己の残虐な行のあとを見、己の運命をふりかえる時が、最も情なく、恐しく、憤ろしい。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにを思いついたか、ふいとうしろをふりかえると、気味のわるいほどにもおちついて、変なときに変なことを、ひょっくりと命じました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど、そうか」　ふりかえると、いまだに青ざめながらうち震えている女中に問いかけました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "主水之介は打ち笑みながらふりかえると、襖のあわいから血走った目をのぞかせて、いざとなったら躍り出そうと身構えていた京弥へ静かに命じました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "押し返しめされいッ」　　　　　　　一六　ハッとふりかえると、いつの間に迫ったか、いる！",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "押し返しめされいッ」一六　ハッとふりかえると、いつの間に迫ったか、いる！",
              "citation": {
                "source": "旗本退屈男",
                "author": "第十一話　千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "何者かうしろに人のけはいをでもかぎ知ったごとくに、突然右門がぴたりと歩みをとめて、そこの小陰につと身を潜めましたものでしたから、伝六も気がついてふりかえると、かれらを追うようにして道具屋の店から姿を現わした者は、塗りげたにおこそずきんの、まぎれもなき彼女でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あごをなでなでぎろりと小娘のほうをふりかえると、名人のさえまさった声が飛んでいきました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "血も熱も冷えきってしまった人のように、よろよろと歩いていたお駒が、一瞬にさっと身をかわして、きっとなりながらふりかえると、「おいたはおよしなさいませ……」　涼しい声で嫣然と笑いながら、またゆっくりとうなだれて、とぼとぼと表へ消えました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一がふりかえると、令子は知子にうなずいていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　高志の力に逆らって、慶一が柾生をふりかえる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ワラが高志のほうにふりかえる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワラ、あけてやれ」　ふたりがふりかえると、山崎が窓に顔をべったりくっつけて、ブタのような顔をして、ンーと、うなっていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "本気にしてるぞ」「もー、アホどもがー」「慶一」　という声で、慶一がふりかえると、高志が前方を指さしていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこの荷物を運ぶのを手伝ってあげなさい」　といわれて、慶一がふりかえると、大きなタータンチェックのバッグと、ギターの黒いハードケースがおかれていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おどろいて、慶一がふりかえると、片桐は慶一の手からギター・ケースをもぎとり、さきに出ていった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあ、高志とワラを誘おうよ」　と、外に出て服部をふりかえる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、校舎にむかって歩きだしていたワラと山崎が、どうしたんだ、という顔でふりかえる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ふりかえると、三メートルほどむこうで、高志がニヤニヤしながら、立ち泳ぎをしていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくが出ます」　慶一は背後の柱をふりかえる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　という声でふりかえると、メタルフレームの眼鏡をかけた、みごとに丸い顔をした男が、女といっしょに笑いかけていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オシャベリ姫は、猫が本当に牢屋の外へ連れて行ってくれるのか知らんと変に思いながら、真暗な中で時々ふりかえる猫の眼を目あてにしてソロリソロリとあるき出しますと、不思議にも狭いと思った牢屋は大変に広くて、どこまで行っても突き当りません。",
              "citation": {
                "source": "オシャベリ姫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台を下りるとき枕許をふりかえると、枕も夥しい血で赤黒く汚れていた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふりかえると、フランク大尉であった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の判断に従って果して誤りはないか、大丈夫だろうか、そこが不安というわけで、一旦は否定してそこからはもう自分の生活感情が舟出してしまっている筈の女の歴史の旧の港をふりかえるのである。",
              "citation": {
                "source": "女の歴史",
                "author": "――そこにある判断と責任の姿――",
                "note": "青空文庫"
              }
            },
            {
              "text": "失策った――と思ってふりかえると、氏は書き終えたらしい手紙を四角な封筒に入れ、その端の糊を嘗め嘗め封をしているところだった。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
