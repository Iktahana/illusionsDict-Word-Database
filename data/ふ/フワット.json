    "definitions": [
      {
        "index": 1,
        "gloss": "floatingly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もったいぶって、ぽたんと落ちるのもあるし、せっかちに、痩せたまま落ちるのもあるし、気取って、ぴちゃんと高い音たてて落ちるのもあるし、つまらなそうに、ふわっと風まかせに落ちるのもあるし、――」　Ｋも、私も、くたくたに疲れていた。",
              "citation": {
                "source": "秋風記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぱらぱら骨がほどけていって、急にふわっと軽くなる。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふわっと温いホットケーキの一切が口にはいる時のあの感触が唾気を催すほど、想い出されるのだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二人はふわっとうかび上がって、空の向こうの、ずっと遠いところにある光の中の方へ、高く高くのぼっていきました。",
              "citation": {
                "source": "マッチ売りの少女",
                "author": "THE LITTLE MATCH-SELLER",
                "note": "青空文庫"
              }
            },
            {
              "text": "決意してしまえば、元々好きなことなんだから、とたんに、わがからだはもうふわっと空に浮んだようだった……。",
              "citation": {
                "source": "三重宙返りの記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうなすったの、三等機関士さん」「からだが急にふわっと軽くなった。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしも、からだがふわっと軽くなりました。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると怪物の身体がふわっと宙に浮いて、足が岩の上を放れた。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "月世界で、あのちょっと跳ねると、ふわっと飛んでしまう身軽さを知っている風間と木曾はびっくりしてしまった。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら、私の髪はごわごわしていて、耳がかくれる頃までのばしたものだが、彼女のように、ふわっと波うってはいなかったのだ。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若冲の図は大抵｜精緻な彩色ものが多いが、この鶴は世間に気兼なしの一筆がきで、一本足ですらりと立った上に、卵形の胴がふわっと乗かっている様子は、はなはだ吾意を得て、飄逸の趣は、長い嘴のさきまで籠っている。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものの二｜丁ばかりも進んだ所が姫の御修行の場所で、床一面に何やらふわっとした、柔かい敷物が敷きつめられて居り、そして正面の棚見たいにできた凹所が神床で、一つの円い御神鏡がキチンと据えられて居るばかり、他には何一つ装飾らしいものは見当りませんでした。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある宮女は、しばらく休息しようと、女王の病室を出て階下の廊下までくると、影のようなものが、ふわっと彼女をかすめて、女王愛玩の甲冑のなかにはいるのを見た。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、出しぬけにこれというわけもないのに、わたしが歩きまわるか本を読むかしている時など、静かにふわっとわたしの部屋へ入って来て、戸口のところに立ちどまり、片手を背中へ廻し、片足をちょっとうしろへ引いて、じっとわたしを見つめにかかる。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すばらしい気合で、直衛の躯はすっとんだかとみえたが、すっとんだのは岡倉自身で、直衛はふわっと左へよけたまま向き直り、岡倉が「まいった」と叫んだ。",
              "citation": {
                "source": "改訂御定法",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき家ぜんたいが宙に浮いた、ふわっと、まるで宙へ浮きあがるように感じられ、柱や梁がぶきみにきしみ、大きく揺れたと思うと、家は西側の方へ、ずずっと三尺ばかり傾いた、そちら側の土台が落ちたのであろう、積んであった家具や箱などが音をたてて転げだし、抱き合っている二人も倒れそうになった。",
              "citation": {
                "source": "暴風雨の中",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は新たにパンを、ふわっと空中に放りあげるようにして犬に与えた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い紙はかすかな風を起こして、スウッと顔の上を通りすぎたかと思うと、ベッドの毛布の上に、ふわっと落ちたのです。",
              "citation": {
                "source": "大金塊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あっ、がいこつだ」　ふわっと、一つのがいこつがあらわれて、コツコツと、ほねのおとをさせながらおどりだしました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「下りの急行」　という彼女の言葉に重なって、はずれた襖がふわっと倒れてくるのを、ふたりは見た。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙がふわっと舞台に漂った。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりは、穴のふちをまたいで、すべるように、ふわっと船の中にはいっていきました。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰のまわりがふわっと大きくふくれて、ひだのおおいスカートが、床にひきずっています。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあたまのうえを、ふわっと、白くながれてゆくマグネの煙が、島崎の化身のように。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
