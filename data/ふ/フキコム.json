    "definitions": [
      {
        "index": 1,
        "gloss": "to blow in (of wind, rain, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これに聯関して起る問題は科学の基礎や方法に関する事柄を初学者に吹き込む事の可否である。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その娘が大きくなって恋をする、といったような甘い通俗的な人情映画であるが、しかし映画的の取扱いがわりにさらさらとして見ていて気持のいい、何かしら美しい健全なものを観客の胸に吹き込むところがある。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがあの貧弱な会場の建築と対照して、そしてその中に陳列された美しいものに対するある予感を吹き込む。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで蒸熱かった此｜一室へ冷たい夜風が、音もなく吹き込むと「夜風に当ると悪いでしょうよ、私は宜いからお閉めなさいよ、」と客なる少女、少年の病気を気にする。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "法律の条文を暗記させるように教え込むべきものではなくて、自然の不思議への憧憬を吹き込む事が第一義ではあるまいか。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以前から先輩の読み物であった坪内氏の「当世書生気質」なども当時の田舎の中学生にはやはり一つの新しい夢を吹き込むものであった。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯げは、縁の下や垣根のすきまから冷たい風が吹き込むたびに、横になびいてはまた立ち上ります。",
              "citation": {
                "source": "茶わんの湯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "息を吹き込むとヒョロヒョロと象の鼻のように伸びるおもちゃも売っている。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "会場を出るとさわやかな初夏の風が上野の森の若葉を渡って、今さらのように生きていることの喜びをしみじみと人の胸に吹き込むように思われた。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芋虫などは人間に対して直接にはなんらの危害を与えるものでもなし、考えようではなかなかかわいいまた美しい小動物であるのに、どうしてこれが、この虫に対しては比較にならぬほど大きくて強い人間にこうした畏怖に似た感情を吹き込むかがどうしてもわからない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ蝋管に声を吹き込む段となって、文学士は吹き込みラッパをその美髯の間に見える紅いくちびるに押し当てて器械の制動機をゆるめた。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように無生の人形に魂を吹き込む芸術が人形使いの手先にばかりあるわけではない。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっと雪が吹き込む）（あさ）（低く、きっぱりと）清蔵さん、お待ちなさい。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪が間断なく吹き込む。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "一個の有能の男子がいのちを籠めて息を吹き込むのであるから。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の関係筋ではかの女と精神肉体ともに悉く交渉を打切られてしまったわたしは、ただ親切という管に於て、たゞかの女の最上無上の幸福に努力するということだけに於て、わたしの肺臓は満腔の力を吹き込むのを許されるのだった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸一先生の柔和にして毅然たる人物は、これ等の教訓を兒童の心に吹き込むに適して居たのです。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "扇風機の前で胸をひろげていたマダムの想出も、雨戸の隙間から吹き込む師走の風に首をすくめながらでは、色気も悩ましさもなく、古い写真のように色あせていた。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのｒの喉音や語尾の自然な音韻が紛れもないドイツの生粋の気分を旅客の耳に吹き込むものであった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、「五十銭均一」という言葉には何かしら現代の一般民衆に親しみと気楽さを吹き込むあるものがあるのではないかという気がする。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このページェントが非常時の東京市民にわが海軍の偉容を示して、心強さと頼もしさを吹き込むという効果を持ったであろうという事には少しの疑いはない。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "讀むともなく開いた表紙の折目の蔭になつた隙間に口に含んだ煙草の煙を吹き込むと雜誌の向側から直ぐ眞白な濃い煙がさアつと机のおもて一面に擴がつて出た。",
              "citation": {
                "source": "樹木とその葉",
                "author": "虻と蟻と蝉と",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四章　インターネットが吹き込む電子本の命　小さなステージに上がり、話し始めて間もなく気づいたのは、壇上の私めがけて走る幾筋かの光る視線でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかの戸の隙間から風が吹き込む音ででもあるだろうか。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかここいらの隙間から風が吹き込むのだわ。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも障子の紙かなんかの破れた処から吹き込むようだねえ。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつてアイルランド人に聞いたは、かの国で最も強く臭う烟草の烟を、驢の鼻へ吹き込むと、眼を細うし気が遠くなった顔付して、静まりおり、極めて好物らしいと。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "シワその志を感じ風神ナラダして真言を彼女の耳に吹き込ませたに、ナラダこれをその子宮に吹き込む。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "リット少将はそれをまぎらすためか、潮風のふきこむ窓から首を出して、暗い外をのぞいた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "点呼命令　全速三十五ノットの烈風がふきこむ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
