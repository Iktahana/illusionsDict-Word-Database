[
  {
    "uuid": "24a61bf0-71f3-5dc1-8edf-7117fec11dba",
    "entry": "二股",
    "reading": {
      "primary": "ふたまた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "seeing two people (i.e. romantically) at the same time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鳥か、獣か、それともやっぱり土蜘蛛の類かと、訪ねると、……その頃六十ばかりだった織次の祖母さんが、「あれはの、二股坂の庄屋殿じゃ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二股坂と言うのは、山奥で、可怪い伝説が少くない。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　その時は何んの心もなく、件の二股を仰いだが、此処に来て、昔の小屋の前を通ると、あの、蜘蛛大名が庄屋をすると、可怪しく胸に響くのであった。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　立淀んだ織次の耳には、それが二股から遠く伝わる、ものの谺のように聞えた。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二股坂の狸は恐れる。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が許を離れてもの、蜘蛛男に買われさっしゃるな、二股坂へ行くまいぞ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今頃はもう二股を半分越したろう、と小窓に頬杖を支いて嘲笑った。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――織次は、飛脚に買去られたと言う大勢の姉様が、ぶらぶらと甘干の柿のように、樹の枝に吊下げられて、上げつ下ろしつ、二股坂で苛まれるのを、目のあたりに見るように思った。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、頭に火皿をのせ、手に二股の杖をついて、その書物をネフェルカプターの墓所へ返して行ったことである。",
              "citation": {
                "source": "セトナ皇子（仮題）",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその外廓をウロウロしている変格の二股武士に向って大きな声で宣告しつつ在る。",
              "citation": {
                "source": "探偵小説の真使命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勢の二股武士、変格探偵小説家の群れは、これに対して一言も答え得ない。",
              "citation": {
                "source": "探偵小説の真使命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本でも聖天に縁祖また夫婦和合を祈り、二股大根を供う（一八九六年板クルックの『北印度俗教および民俗』一巻一一一頁。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "大白森一帶の連山の中には、小白森あり、鎌房山あり、二股山あり。",
              "citation": {
                "source": "阿武隈川水源の仙境",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう経歴の人間であるだけに、二股侍というではないが、自分の主人以外、羽振りのよい諸大名にこすり付いて何かの利徳を得ようとする卑しい心がある。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉地はやはり二股かけて自分を愛しているのだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の二股になった所で左に行こうとすると、闇をすかしていた仁右衛門は吼えるように「右さ行くだ」と厳命した。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると二股になった。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之、久しく日支両帝国の間に介在していたので、自然｜二股膏薬主義を取らなければならないようになったのである。",
              "citation": {
                "source": "沖縄人の最大欠点",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "法　　二股かけたもの共の大方は、蛙の叔母だとやら「あひる」のやれ「いとこ」だとやら申すのが可笑しい事でのう。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "終点から、細い川沿いに、車掌の教えてくれた通り進んだが、程なく二股道に出た。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "動坂を下りて、ずっとゆくと、二股になった道があって、そこに赤い紙をどっさり貼りつけられた古い地蔵さんの立っている辻堂があった。",
              "citation": {
                "source": "田端の汽車そのほか",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "終点から川について教わった通り行ったが、二股道にかかり、さてどちらに行ってよいか判らない。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵又分兵二股木古内。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一戸の記に、「春日東二艦矢不来富川の陣を砲撃し、別に二股をも攻」むと云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "去廿九日｜木子内及｜二股之賊敗走、官軍大野有川迄進撃相成候由。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸ひ此処に松の枯木が、二股に枝を伸ばしてゐる。",
              "citation": {
                "source": "往生絵巻",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "二股大根の岐れ目に沁みこむ夕暮どきの裾寒さ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お抱えらしい御紋付の……」「占めたっ」　と云うなり吾輩は、階子段を二股に飛び降りて靴を穿いた。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから二股の鋸を突込んで、左右の肋骨を切り除けた若林博士は、取出した背骨を縦に真二つに切り開いただけで、ロクに検査もせずに、もとの処に当てがいまして、太い針でブスブスと縫い合せてしまいました。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは雑朶の細枝のふたまたになって居る岐れめに何かの虫が附けた玉子から、至極｜巧に、中味の虫の子が脱け出したあとの、可愛い笛の様な音を立てる小さな穴の一つあいた、かやの紅さし指のあたま位いな、貝のように硬い滑かな、灰色に白い斑の付いた殻であった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
