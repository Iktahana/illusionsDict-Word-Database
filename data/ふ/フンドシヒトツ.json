    "definitions": [
      {
        "index": 1,
        "gloss": "(wearing) a loincloth alone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……と……駐在所の入口になっている硝子戸が内側からガタガタと開いて、色の黒い、人相の悪い顔に、無精鬚を蓬々と生した、越中褌一つの逞ましい小男が半身を現わした。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "見事に赤銅色をした逞しい男が、眞赤な褌一つで漕いで來る。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍に、褌一つの島民少年を連れてゐる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "見事に赤銅色をした逞しい男が、真赤な褌一つで漕いで来る。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍に、褌一つの島民少年を連れている。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "百人ほどの寮生はいずれも赤い褌一つの裸で、鐘や金盥や太鼓をそれぞれ持っていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "貪るように啜っていると、社長が褌一つの裸で二階から降りて来て、「こない日が射し込んで来よったら、毛利君かなわんやろ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "社長は褌一つだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "社の創立当時のことだがね、丁度夏だったもんで、奴さん褌一つで駆けずりまわる――のはおかしいか。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "駆けずりまわるときはさすがに洋服は着込んでいたらしいが、さて社で記事を書くときは褌一つだったんだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――というわけで、問題はけりがついたが、ともかく美人の秘書の前で汚れた褌一つで平気でいるところを見ると、奴さん女には全然興味がないと見てまあ差支えないだろう？",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘次は洗ひ曝しの襦袢を褌一つの裸へ引つ掛て、船頭が被るやうな藺草の編笠へ麻の紐を附けて居る。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもの犢鼻褌一つの上に、印半纏をはおつた男が繰つてゐるのであらう。",
              "citation": {
                "source": "身上話",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ますます気持が滅入っちまわあ」　大山は、半纏を脱いで、褌一つになって、隅っこの暗いところへ、這って行ってゴロリと横になった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに、越中褌一つで、その前ごをキチンと三角にして、すっぱだかで菜園の中に立っている姿が、今も私の目の前に浮ぶ。",
              "citation": {
                "source": "私の父",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃江戸川｜畔に住んでいた私は偶然｜川畔を散策いていると、流れを下りて来る川舟に犢鼻褌一つで元気に棹をさしてるのが眉山で、吉原通いの山谷堀でも下る了簡で、胡座をかきつつ好い気持になってるのが中村花痩であった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃の少年は、夏はたいてい褌一つで歩いたものであるから。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "土方は皆褌一つで働いていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると又、突然褌一つで蚊帳の外に跳び出したが、自分の荷物は寢る時の儘で壁側にある。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言ふと、東儀氏はあの牛のやうな大きな眼をぐりぐりさせて、「人間も犢鼻褌一つで、子供の枕もとで蚊を焼いて歩くやうになつちや、もうから意気地もない。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "・つかれた脚を湯が待つてゐた・雲がいそいでよい月にする　七月十八日晴れて暑い、ぢつとしてゐて汗がにじみでる、湯あがりの暑さは、裸体になることの嫌いな私でも、褌一つにならずにはゐられない。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし江戸ッ児にはただその雄大なる姿を賞するのみでは承知が出来ず、どうしても素裸の褌一つになり、飛下する水に五体を打たせねばジッとしていられぬ性とて、高雄山なるは浴みもされるが、金刀比羅の滝、独鈷の滝など、見るが主なるはさばかりに好んで足を向けない。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかくして、浴後の褌一つに、冬をも暑がってホッホッという太息、見れば全身｜宛ら茹蛸のようだ。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "柴田常庵という肥え太った医師は、越中褌一つを身に着けたばかりで、「棚の達磨」を踊った。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　貧弱な徳利一本、猪口一箇を置いた塗りの剥げた茶餉台の前に、褌一つの真つ裸のまゝ仰向けに寝ころび、骨と皮に痩せ細つた毛臑の上に片つ方の毛臑を載せて、伸びた口髭をグイ／＼引つ張り／＼詩を考へてゐた狂詩人は、私が問ふと矢にはに跳ね起き顎を前方に突き出し唇を尖らせて、「凡人の子袋から産れたといふことさ。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "で腹を出して、鉢巻をして、中には褌一つのも居たよ。",
              "citation": {
                "source": "俺の記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんの肌抜ぎも咎めなければ、となりのお父さんの褌一つなのも当り前なのだ、真に天真爛漫、更けるほど話ははずむ。",
              "citation": {
                "source": "流れた唾き",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤褌一つのモイ族が、二三羽のインコを籠に入れて、遊歩道で売つてゐたのを、富岡は思ひ出した。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺だってこの二重マントの下は褌一つの素っ裸体なんだぞ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてとうとうしまいには、越中褌一つの主人が、赤い湯もじ一つの下女と相撲をとり始める所になった。",
              "citation": {
                "source": "将軍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
