    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to raise (esp. overhead)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども狡猾なるブルジョアジーは、うまい、美しげな大義名分を振りかざす。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "短剣引き抜き、振りかざすと見るより早く、自分自身の左の頬を切り裂いた。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊吹虎尾、振りかざす手の怒、空になつた心臟にしがみつく蝮、自害した人。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう連中の振りかざす大義名分に恐じ怖れて、徳川御宗家を見捨てるという法があろうか。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が、押えようとした瞬間、玄白斎は、戒刀を振りかざすと、凝視めていた一点へ、斬りつけた――二人が「危いっ」　と、絶叫した。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "高木は、刀を提げたまま、じっと、立っていたが、四ツ本が、人々の背後へ入って、陰険な眼で、睨んでいるのを見ると「出ろっ、四ツ本、卑怯者っ」　と、叫んで、刀を振りかざすが早いか、飛びかかった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、君もキリスト教徒と同じく、救済という『予定』を振りかざす、一宗教家にすぎない。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "先に立った足健康の従者が高く振りかざす松火の光で、崎嶇たる山骨を僅に照らし、人馬物言わず真向きに走る。",
              "citation": {
                "source": "稚子法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自ら主義を振りかざす必要は勿論ありませんが、現在の演劇をどういふ方向に導いて行かうといふ努力さへ判然と示されてゐないのであります。",
              "citation": {
                "source": "演劇一般講話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを取り押えようとする者との間に大立廻りが始まったが、右の手に刀、左手に勧進帳振りかざす文覚は、あたかも両刀を操るように見える。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "月はもう落ちて、路地の中は眞つ暗ですが、捕物陣の振りかざす提灯のあかりが、何時の間にやらこの一角に集まつて、平次はまさに舞臺の脚光を浴びて立つた姿でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鼬小僧の正体",
                "note": "青空文庫"
              }
            },
            {
              "text": "道徳や倫理をファシズム支配が振りかざすことは、大変賢明なことだ、風俗風紀は勿論道徳や倫理にぞくすのだが、ファシズムによると一切の思想・科学・哲学・芸術・其の他が又道徳なのだ。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "その限り「ヒューマニズム」を振りかざすことが日本文化の伝統を振り翳すことと原則上反対の態度であることを忘れてはならぬのだ。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "タリシュオスの子エケポ，ロス、トロイア軍の先陣の中にすぐれし勇將を、アーンチロコス先づ斃す、馬尾の冠毛振りかざす甲の天邊打碎き、鋭刄凄く骨に入り、其額上を貫けば一命亡び死の暗は忽ち彼の目を蔽ひ、　460亂軍中にどうと伏し塔の倒るる見る如し。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイナイアース、メネラオス二將互に相面し、戰望み鋭刄の槍をおのおの振りかざす、アーンチロコス進み來て王にまちかく並び立つ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイア，ス即ち眞つ先きに長き冠毛振りかざす其敵將の甲突けば覘違はず鋭刄の　10槍は骨まで深く入り、暗黒彼の目を蔽ふ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見た、も一つの小猿は負けない気で、少女の頭髪から櫛を抜き取って振りかざす。",
              "citation": {
                "source": "大菩薩峠",
                "author": "甲源一刀流の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は猛り狂う人々を押しとどめようとするもののように、ときどき手を振りかざすのであった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしドミトリイは、両手を振りかざすと共に、いきなり老人の両の鬢に残っているまばらな髪をひっつかんで、ぐいと引き寄せざま、激しい地響きを立てて床に投げとばした。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "高くこれを振りかざすように……」　それにしても、長老のことばは、ここに記したよりも、すなわち、アリョーシャが後に書きとどめたよりも、ずっと切れ切れなものであった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同二組に分れて、叢の両方の端から始めたのだが、相川青年は司法主任の組に加わり、強力な手提電燈を振りかざす刑事のうしろから、まるで彼自身、日頃あこがれの探偵にでもなった気持で、猟奇心に燃えながら、ついて行った。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ護りの侍どもが振りかざす松明のみがいぶって行く。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、内へ躍り込んでゆき、かっと、薄刃の斧を振りかざすやいな、羅真人のあたまをめがけ、その脳天から真二つにたちわってしまった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれ、どうするか見ておれよ」　言うなり腰の長刀を抜いて、その朱い手に振りかざすや否、まことに、殺しかねまじき形相で、くわッと月江をにらみつける。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "血眼な数多の人間どもと、振りかざす白刃を揶揄して、すこぶる皮肉きわまるものは、人なく水に流れてゆくその空舟――。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼らは大酒に酔いつぶれたように自制を失ってしまい、反対派の学者のふりかざす邪剣のもとに集まり、大河が氾濫して小さな藁屋に襲いかかるがごとく押し寄せてきて、私の名誉を傷つけ、幸福をうばい、あまつさえ彼らの利害には何の関係もないはずの私の片腕を折り、左眼をつぶしてしまったのである。",
              "citation": {
                "source": "放送された遺言",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "正義をふりかざす事も喜劇。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふりかざすとこれもまた一種の理由になる。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがにそれを表向きふりかざすわけにも行かないので、あれやこれや持って廻って言い廻しているが、心底をわれば、君はそういうけれども、案外こんな作品が受けやしないかというサモしい性根が本心だ。",
              "citation": {
                "source": "青い絨毯",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "永井荷風先生も似たような立場であるが、もしも荷風先生が伴侶を定める場合にも、たぶん正妻とか女房なぞと大ダンビラをふりかざすような言い方よりも、侍女を求めるというような心境であろうと思う。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その六　暗い哉　東洋よ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
