          "literary": [
            {
              "text": "ちょっと、ファズを貸してくれないか」　シールドのジャックをアンプに差しこみながら、広岡がいった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと接触がおかしいんだ」　慶一がファズ・ボックスと、黒いストレート・コードを広岡にわたした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな音になるのかな」　慶一は、広岡からファズをとりもどして、アンプにつないだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "広岡がじぶんのギターを教壇に寝かせ、ヤマハのセミアコ・ベースをファズにつなぎ、テニスシューズでフット・スウィッチをゆっくりと踏み、四本の開放弦を鳴らした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギターにファズをかけたのと大差のない音だし、へたをすると、音がブチブチ途切れたりする。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一は、ファズのアジャストメントを動かしてみる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファズを手にした人間は、どうしても〈サティスファクション〉のリフを弾かずにはいられない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
