    "definitions": [
      {
        "index": 1,
        "gloss": "withering of vegetation in winter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この村の人は猿なり冬木立　田も畠も凍りついた冬枯れの貧しい寒村。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れ少年の日は、常に麥笛を鳴らして此所を過ぎ、長き煉瓦の塀を※りて、果なき憂愁にさびしみしが、崖を下りて河原に立てば、冬枯れの木立の中に、悲しき懲役の人人、看守に引かれて石を運び、利根川の淺き川瀬を速くせり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧解剖学教室、生理学教室の廃墟には冬枯れの雑草ががらがらに干からびて哀れである。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "広々した畑地に霜解けを踏んで、冬枯れの木立の上に高い蒼空を流れる雲でも見ながら、当もなく歩いていたいと思う。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本画部から受けた灰色の合成的印象をもって洋画部へはいって行くと、冬枯れの野から温室の熱帯樹林へはいって行くような気持がするのは私ばかりではあるまい。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よにもさびしい私の人格が、おほきな声で見知らぬ友をよんで居る、わたしの卑屈な不思議な人格が、鴉のやうなみすぼらしい様子をして、人気のない冬枯れの椅子の片隅にふるえて居る。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎のあぜみちに坐つてゐると、おほなみのやうな土壌の重みが、わたしの心をくらくする、土壌のくさつたにほひが私の皮膚をくろずませる、冬枯れのさびしい自然が私の生活をくるしくする。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よにもさびしい私の人格がおほきな聲で見知らぬ友を呼んでゐるわたしの卑屈で不思議な人格が鴉のやうなみすぼらしい樣子をして人氣のない冬枯れの椅子の片隅にふるへて居る。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした農家の裏山には、小高い冬枯れの墓丘があつて、彼等の家族の長い歴史が、あまたの白骨と共に眠つてゐる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其三　頃は十月の末、ところは荒凉たる境なれば、見渡す限りの景色いともの淋しく、冬枯れ野辺を吹きすさむ風｜蕭と聳えし彼峯ならめ、さては此あたりにこそ御墓はあるべけれと、ひそかに心を配る折しも、見る／＼千仭の谷底より霧漠し初め、空やゝ暗くなりしばかりなり。",
              "citation": {
                "source": "二日物語",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "川向うは石川原から冬枯れの雑木が生い茂り、その褐色が起伏するのへ松林が混ると、地層はだん／＼に高みを増し、松山続きとなると、川と平行して川下へ下る大きな尾根の丘陵にまでその松林は届いています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "金粉の靄おだやかな冬枯れはてて、おだやかな眺めの冬、柔かな日あたりの冬、冬はまだ渓の向うにある。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の家は冬枯れの野のようだとつくづくそう思う。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして木立ちの代わりに安価な八つ手や丁子のようなものを垣根のすそに植え、それを遠い地平線を限る常緑樹林の代用として冬枯れの荒涼を緩和するほかはなかった。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風もなく、冬枯れの牧場には空気がうらうらと陽炎めいていた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道行の二人連れ、さしずめ清元か常磐津の出語りで『落人の為かや今は冬枯れて』とか云いそうな場面です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "「愛ねえさんうれしいわねえ」　貞世は勝ち誇るもののごとく、縁側の柱によりかかってじっと冬枯れの庭を見つめている姉の肩に手をかけながらより添った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芒がなびき、楢の葉が冬枯れて風に鳴る。",
              "citation": {
                "source": "樹木とその葉",
                "author": "自然の息自然の聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "日をひと日わが行く野辺のをちこちに冬枯れはてて森ぞ見えたる落葉松は痩せてかぼそく白樺は冬枯れてただに真白かりけり　二里あまり歩いてこの野のはづれ、市場といふへ来た。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地が高いだけ、冬枯れはてた木立の間に見るだけに、その姿がいかにも佗しいものに眺められた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして四邊の樹木は全く一葉をとゞめず冬枯れてゐる。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地が高いだけ、冬枯れはてた木立の間に見るだけに、その姿がいかにも侘しいものに眺められた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして四辺の樹木は全く一葉をとどめず冬枯れている。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈍い太陽が冬枯れの練兵場の上にあった。",
              "citation": {
                "source": "三人",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "川のふちを、弓なりに迂回しながら冬枯れの裏山を指して脚速く遡つてゐた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻布の曹洞宗の大学林から早稲田の自由な文学社会にはいったかれには、冬枯れの山から緑葉の野に出たような気がした。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "心にはかくと思ひ定めたれど、さすがに冬枯れの野は淋しきかな。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて定家の『拾遺愚草』を点検して「霜冴ゆるあしたの原のふゆがれに一花さけるやまとなでしこ」の一首を発見した時、尚白の句と比較すると、数歩を譲らなければなるまいと老えたことがあった。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            }
          ]
        }
