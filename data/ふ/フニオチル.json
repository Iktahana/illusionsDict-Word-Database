    "definitions": [
      {
        "index": 1,
        "gloss": "to understand",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "如何なる人が何と云っても自分の腑に落ちるまでは決して鵜呑みにしないという事である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし読者のうちでこの謎の意味を自分の腑に落ちるようにはっきり解説してくれる人があったら有難いと思うのである。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、美濃の国中で評判の寺々を歴訪して師家と名の付く老僧たちに会い、疑いのあることは問い、修業の方針を教えられたりしたが、どれも腑に落ちるものはなかった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたから伺ったところがどうせこう年を取りますと腑に落ちる気づかいはございません。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この話の方が青谷君の腑に落ちるでしょうから」「君は誰です？",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "同志の人達は、彼とは係りなしに話しているのに、彼が横合からその言葉尻を捕えて腑に落ちるまで問い訊さねばおかないので、大事な話を台なしにされることがよくありました。",
              "citation": {
                "source": "ある男の堕落",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「然し、父上――母様、もう少し詳しく、腑に落ちるようにお話しなされては」　と、小太郎が取りなした。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "腑に落ちるなどと謂ふより反撥したといつた方がいいかも知れない。",
              "citation": {
                "source": "念珠集",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "五歳になつてはじめてキンテイサマ、テンシサマの記憶がよみがへつてくる、といふ従来の習慣が残つて居り、四歳ではまだその記憶が残らないといふ従来の習慣に本づき、兄のその時の年齢を満で算へて直ぐ腑に落ちるやうになるまでには、五年や十年はかかるだらうといふのは、そんな事柄にも関聯してゐるのである。",
              "citation": {
                "source": "孫",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は女に理窟を聞かせるのを、男の恥のように思う癖があるので、むずかしい事はなるべく控えたが、何しろこういう問題について、できるだけ本人の自由を許さないのは親の義務に背くのも同然だという意味を、昔風の彼女の腑に落ちるように砕いて説明した。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなったら君にも腑に落ちる筈だ。",
              "citation": {
                "source": "別れの辞",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今日まで、かういふ考へ方から、「演劇の本質」について、何か自分の腑に落ちるやうな理論を編み出さうと努力したが、これはなかなか困難な事業で、嘗て、やや独断的に樹てた「心理的リズム」説の如きも、それだけではなんのことかわからぬといふ人も出て来て、実はいろいろと苦心をしてゐたのである。",
              "citation": {
                "source": "演劇論の一方向",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この前の、資金のことや、商売のやり方のことなども、そっくり腑に落ちるし、こんどの話は、一層胸にこたえました。",
              "citation": {
                "source": "霊感",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっくりと彼女の腑に落ちる事を云ってやりたかったが、その言葉が見付からなかった。",
              "citation": {
                "source": "或る男の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなってはじめて万法帰一が腑に落ちるではないか。",
              "citation": {
                "source": "良寛の書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "』答『それも悪いとは申さぬが、しかし一｜升の桝には一｜升の分量しか入らぬ道理で、そなたの器量が大きくならぬ限り、いかにあせってもすべてが腑に落ちるという訳には参らぬ。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、俺は曲者はどうして入つて、何うして逃出したか、腑に落ちるまで調べ度い。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "八千兩異変",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく腑に落ちるやうに筋道を立てて話して見ようと思ふが――」「親分さん――」　三五郎は泳ぐやうな手付きをして、膝を立て直しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "百足屋殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした国営的大企業の、戦車の響きのような資本流通過程を目の前にして見ると、小市民のポケットをねらう街頭義金の悲愴な叫びも、何故甲高く弱々しいものであるかが腑に落ちるだろう。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度も三度もその五六字を往来して、ようよう訳が腑に落ちると、また次の五六字へ辛うじて進行する。",
              "citation": {
                "source": "三郎爺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "腑に落ちなければ、腑に落ちるまで考えるよりないだろう。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "後備の陸軍少將で――もう死にました」「そう………」私にこの男の人がらがいくらか腑に落ちるような氣がしてきた。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはよく腑に落ちるように話そうと思い、妻の手を取って引き留めようと努力しました。",
              "citation": {
                "source": "クロイツェル・ソナタ",
                "author": "KREITSEROVA SONATA",
                "note": "青空文庫"
              }
            },
            {
              "text": "『幻想曲』はショパンの作品中のエヴェレストで、その演奏は極めて困難なものであり、実演でもレコードでも、私はかつて腑に落ちる表現に接したことがないが、コルトーのレコードを得て、多年の溜飲を下げたことだけは事実である。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく腑に落ちる死刑である。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きさまにゃ、どうして眠白が敬四郎どのをさらってきたかわかるまいから、ふにおちるように締めあげてみなよ」　命令があったものでしたから、伝六はにわかに強くなると、ぎゅうぎゅうとくくしあげながら責めたてました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
