[
  {
    "uuid": "6fd4fce1-469b-5888-b14b-532bf144011a",
    "entry": "賦税",
    "reading": {
      "primary": "ふぜい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
