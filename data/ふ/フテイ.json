      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unsettled",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一、一切は、不定だ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "不定で在り方は、一定だ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜というものが二十四時間ごとに繰返されるからよいが、約五十年に一度、しかも不定期に突然に夜が廻り合せてくるのであったら、その時に如何なる事柄が起るであろうか。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この差は数秒あるいは数分の不定なる週期をもって急激に変化するを見出すべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気の抵抗や、風の横圧や、周囲の物体より起る不定な影響を除去した時に始めて厳密に適用さるべきものである。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後は、茲のアパート、あちらの貸家と、彼の一所不定の生活が始まった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし外界は不定である。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあのろうそくの炎の不定なゆらぎはあらゆるものの陰影に生きた脈動を与えるので、このグロテスクな影人形の舞踊にはいっそう幻想的な雰囲気が付きまとっていて、幼いわれわれのファンタジーを一種不思議な世界へ誘うのであった。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すばしこく枝移りする小鳥のような不定さは私をいらだたせた。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この困難を切り抜けるために持ち出された一つの今から見て奇抜な考えは、この元子のおのおのはその直線的並行落下の途中で、ある不定な時、不定な場所において、おりおり、きわめて少しその経路を曲げるというのである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まではなるべくなら避けたく思った統計的不定の渾沌の闇の中に、統計的にのみ再現的な事実と方則とを求めるように余儀なくされたのである。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで政治家、軍人、実業家、ファシスト、マルキシスト、テロリスト、いずれもこんな不定な未来の事は問題にしていない。",
              "citation": {
                "source": "ロプ・ノールその他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人々は大概、いわゆる居所不明、もしくは不定な連中であるから文公の今夜の行く先など気にしないのも無理はない。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "無常迅速、流転してやまざる環境に支配された人生の不定感は一方では外来の仏教思想に豊かな沃土を供給し、また一方では俳諧のさびしおりを発育させたのであろう。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由詩とは何ぞや、無韻詩とは何ぞや、不定形律の詩とは何ぞや。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不定形律の詩は決して本然の状態に見出せない。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無韻律の不定形律――即ち散文形式――は、詩のために自由を許すものでなくして、却つて不自由を強ひるものである。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の説に依れば、詩の發育の歴史は、原始の單純素樸なる自然定律の時代から、未來の複雜にして高遠なる新定律の形式に移るべきで、自由詩はこの中間に於ける過渡期の不定形律にすぎない。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち前に言った通りに、日本詩の歴史は自由詩（不定形な散文律）に始まっている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に人界不定のならひ、是非も無き御事とは申せ、想ひ奉るもいとかしこし。",
              "citation": {
                "source": "二日物語",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "小生ただいま居所不定、（近くアパアトを捜す予定）だから御通信はすべて社｜宛に下さる様。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは名を喜助と言って、三十歳ばかりになる、住所不定の男である。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころの汽車の時間は不定でしたし、乗客も無我夢中で運ばれて行くのでしたが、午後に名古屋を出た列車が木曽路へ入る頃にはもう暮れかかっていました。",
              "citation": {
                "source": "指輪一つ",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にも貴様の云う通り人間は老少｜不定。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に物質確定の世界と生命の不定世界との間にそびえていた万里の鉄壁の一部がいよいよ破れ始める日の幻を心に描くことさえできるような気がしたのである。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり神職もなく、財産、社地も定まらざる廃社同前のもの、また一時流行、運命不定の淫祠、小祠の類を除き、その他在来の神社を確立せしめんと力めたるもののごとし。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しその創立がいつの事であつたかと云ふことは、己も遺憾ながら或る不定の断案を以て答へるより外無い。",
              "citation": {
                "source": "十三時",
                "author": "THE DEVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学も経験もともに、浮び上がる期間が不定であって、また当然そうでなければならない、ということを示しているのだよ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとでも、じぶんたちのふていさいなことをわらわれたりすると、春吉君はつきとばされたように感じる。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お嫁に行って、妾になって、まだその上に女優を欲張ろうとは、お前も随分ふてい奴、さ」「そうとも、さ、こんなにふとったからだだもの、かせげるだけかせぐん、さ、ね」「じゃア、もう、僕は手を引こう」と、僕は坐り直した。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            }
          ]
        }
