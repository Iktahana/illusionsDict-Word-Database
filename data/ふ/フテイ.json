  {
    "uuid": "ca511181-0303-5bbc-8762-b1477ae0f204",
    "entry": "不定",
    "reading": {
      "primary": "ふてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
