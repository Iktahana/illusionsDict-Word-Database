[
  {
    "uuid": "f939a47c-fa2e-5c50-90c2-d7f5bbe9fcae",
    "entry": "不敏",
    "reading": {
      "primary": "ふびん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "形容動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "slowness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その点彼女に不敏なところがあるようだ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがある場合には不敏なものの方に強味がある。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が不敏を顧みずここに二、三の問題を提起して批判を仰ぐ所因もまたこれに外ならず。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "推理の誤謬や不備があればそれは不敏のいたすところである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この心を通じさして貰い度い、それが潜在しながら世俗不敏なものが途中いろ／＼の思わぬ作略をした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもし商人が資本をおろし財利を謀るように、お佐代さんが労苦と忍耐とを夫に提供して、まだ報酬を得ぬうちに亡くなったのだと言うなら、わたくしは不敏にしてそれに同意することが出来ない。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この通り零落れてをる僕が気毒と思ふなら、君の為に艱されてをる人才の多くを一層｜不敏と思うて遣れ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう思つて俺は不敏だ！",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "我輩不敏といへども奴等よりはまだ高潔な心をもつとる。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来ノ殺害目的者ニ対シテハ、殺害ノ予告ノミヲシテ方法及ビ期日ヲセザリシ為メ普通月並ナル脅迫状位ニ思フテ覚梧（死ノ）モセズ、遺言モセズ、不意ニ我党ノ手ニ掛リ、卑怯ナル不敏ナル最後トナリシ者アリシニ付キカク明ラカニセリ。",
              "citation": {
                "source": "編輯室より（一九一三年六月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが何たる不敏だ、今では月と日とを拜んだりするものとなつてしまつた。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわたくしは不敏にしてこれを知らない。",
              "citation": {
                "source": "空車",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の新陣営の作者たちの作品に、どれだけの性格が、性格の横顔が、描き出されているか、不敏にして私は知らない。",
              "citation": {
                "source": "性格を求む",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ不敏にして、これらの人々に対して感謝の意を表する能はざるを遺憾とするのみ。",
              "citation": {
                "source": "『文学論』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "不敏な僕はその後へ何が出て来るのか、まだ覚れなかった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者不敏と雖ども自ら僭して詩人と爲すの愚を學ぶものに非ず。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "足掛け二年、正味十七ヶ月ばかりでしたが、僕と家内とは、不敏ながら誠心誠意、お役に立ちたいと心掛けて来ました。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、兼実は藤右衛門尉重経を使として法然に、「浄土の法門年頃お教えを承りましたが、不敏にしてまだまだ心腑に収め難いものが多くございます。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "不敏の至りであるが、私はなぜ軽犯罪にひッかかるのだか合点がゆかなかったが、人に教えてもらってワケがわかった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなふうにして、どうにかこうにか本歌の心は読めて来ましたが、現在はこの二十年間の習得によって、不敏ながら自得するところがありまして、我儘放題に、意の欲するところに従い、所謂個性を生かしていけるようになり、漸く自分のものが出来かけたような気がしてまいりました。",
              "citation": {
                "source": "陶器鑑賞について",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも余輩不敏、そのしかるを暁る能わず、ただちに同誌翌月号においてこれが答弁を掲載せしが、今に至りてなおその再諭を得る能わず。",
              "citation": {
                "source": "武士を夷ということの考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "宣光不敏ニシテ唯負荷ノ任ニ堪ヘザルコトヲ懼ル。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれも、不敏ながら、村の名誉職を勤めてゐる身だ。",
              "citation": {
                "source": "ここに弟あり",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、不敏なる私は、その時、猿猴栄次について、何ら識っているところがなかった。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでこういう焦眉の急を要する問題について、科学者側から、何らかの具体的な提案が為されたという話は、不敏にして、未だ知らない。",
              "citation": {
                "source": "動力革命と日本の科学者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "國家の爲に私情を割く、篤麿不敏と雖も已むべきに非るを知ればなりと。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "国家の為に私情を割く、篤麿不敏と雖も已むべきに非るを知ればなりと。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校のおつとめからお帰りになって、隣りのお部屋で、私たちの話を立聞きして、ふびんに思い、厳酷の父としては一世一代の狂言したのではなかろうか、と思うことも、ございますが、まさか、そんなこともないでしょうね。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の者が、夏をよろこび海へ行こうか、山へ行こうかなど、はしゃいで言っているのを見ると、ふびんに思う。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "畜生ふびんのゆえをもって、人はこれを甘やかしているからいけないのだ。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
