    "definitions": [
      {
        "index": 1,
        "gloss": "wind and waves",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "姑は「姑」を宣伝し、嫁は「嫁」を宣伝するために、一家に風波が立つ。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お君には流れるように無事平穏な日々であったが、それらの日々は豹一にとっては日毎に小さな風波を立てゝいた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐藤理学士の奥州産業総説に曰く、「撃てば則ち草に匿れ、追へば即ち山に入つた蝦夷族の版図たりし奥州、山岳重畳して到るところ天然の障壁をなし、以て交通を阻害してゐる奥州、風波高く海運不便なる日本海と、北上山脈にさへぎられて発達しない鋸歯状の岬湾の多い太平洋とに包まれた奥州。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして段々と風波が募って、定基の妻が日に日に虐められるようになっては、右衛門に対して援を求めるように何等かのことをしたかも知れない。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "住職はいたって慈悲深い男であったが、ある風波の激しい日、難船でもありはしないかと思って外へ出てみた。",
              "citation": {
                "source": "義猫の塚",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで住職は山をかけおりて漁師の家へ往って、「可哀そうだから、たすけてやってくれ」　と云ったが、風波が激しいので何人一人舟を出そうとする者がなかった。",
              "citation": {
                "source": "義猫の塚",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時によると朝出かけて夜遅くまで帰らないことがあって、家庭に風波が起った。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その船が不幸にも航海中に風波の難に会って、半難船の姿になって、横み荷の半分以上を流失した。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士の方でも、奧さんが母君に聞えるやうに、母君の聲の小言を言ふのを、甚だ不都合だとは思つてゐるが、それを咎めれば、風波が起る。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は自分が思っている程自分ではなく、今から八十五年前北海の風波や海霧に苦しみながら、干潮の時だけ姿を見せる・此の魔の岬と、実際に戦ったことがあるのだ、と、確かにそう思えて来る。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宛もよし、九月｜晦日は、俄かに暴風雨が起って、風波が高く、湖のような宮島瀬戸も白浪が立騒いだ。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "微な風波の音が南風気のある生温かい空気の中に滲んで聞えるばかりで他に何の物音もしなかつた。",
              "citation": {
                "source": "海異志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南風気を含んで風波が磯際の砂に戯れる音ばかりで他には依然として何の物音も聞えなかつた。",
              "citation": {
                "source": "海異志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風波に駭きし叫號の聲は神に謝する祈祷の歌となり、この歌又變じて歡呼となる。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど六とせ目の年の末には、早く多少の風波の我生涯の海の面に噪ぎ立つを見たり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "風波は我｜筵の爲めに歌舞す。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "美服美粧して渡るときは、たちまちに風波が起った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、この河を渡るとき、風波の難に逢わない者は醜婦であるということになるので、いかなる醜婦もわざと衣服や化粧を壊して渡るのもおかしい。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから丁度十年になりまして、自分としてはなんの過失もないつもりで居りますのに、夫は昨年から更に盧氏の娘を娶りましたので、家内に風波が絶えません。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "此のお袋が今日まで家内に風波を起さないのはおとなしく我慢をして居るからなので、嘗ては怨みがましいことをいつたことは無かつたのである。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其船が不幸にも航海中に風波の難に逢つて、半難船の姿になつて、積荷の半分以上を流出した。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろ、折々は三千雄の夜泊りするやうなこともあつたが、夫婦の間にはいさゝかな風波も立つためしもなかつた。",
              "citation": {
                "source": "滝のある村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「帝王の深宮に育ちたまい、もろもろの歓楽に驕りたまいしが、絶大の愛を心に持ちたまい、慈悲をあまねく日本国じゅうに垂れたまい、不幸なる者を救いたまえること数を知らず、今何の報いにて風波の牲となりたまわん。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが風波の害のあった際に何を言って来たのでしょう」　と言って訳がわからないふうであった。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "海上風波の難に遭へる時、若干の油を取りて航路に澆げば、浪は奇くも忽ち鎮りて、船は九死を出づべしとよ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "であるから、家内に大した風波の起らう筈もないが、家庭らしい温みも到底見出し得ない。",
              "citation": {
                "source": "一家",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、彼の声も、風波の音にせかれて、遠くへひびきそうにもなかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日まで何等の秘密も風波もなく暮して来ました妻子に、突然に、思いがけなく棄てられた私は、ただ途方に暮れるばかりです。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗いたらたらとした海の上には風波の波頭が船の左右にあたって、海蛇のように幾条かの銀鼠の光を走らした。",
              "citation": {
                "source": "幽霊の自筆",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これほどの大先生が俺達の村に居てくれゝば、竜巻村にはやがて一切の風波が絶えて、絶世のユートピアが現出するだらう。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
