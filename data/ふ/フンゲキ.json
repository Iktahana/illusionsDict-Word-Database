[
  {
    "uuid": "0aac0b35-54ac-5d03-9efc-0bb2c64f2115",
    "entry": "憤激",
    "reading": {
      "primary": "ふんげき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
