    "definitions": [
      {
        "index": 1,
        "gloss": "payment made via bank deposit transfer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "隙さず、この不気味な和郎を、女房から押隔てて、荷を真中へ振込むと、流眄に一｜睨み、直ぐ、急足になるあとから、和郎は、のそのそ――大な影を引いて続く。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那、つきました」と言うと、竿をまた元へ戻して狙ったところへ振込むという訳であります。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉は全敗に終らせたくない意地から、舟を今日までかかったことのない場処へ持って行って、「かし」を決めるのに慎重な態度を取りながら、やがて、　「旦那、竿は一本にして、みよしの真正面へ巧く振込んで下さい」と申しました。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "客は合点して、「あいよ」とその言葉通りに実に巧く振込みましたが、心中では気乗薄であったことも争えませんでした。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでもそこらで、鮨を撮んで、笹巻の笹だけ袂へ入れて振込めば、立ちどころに仙台様。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "譲吉は、最初高商の秀才と云う振込みで、近藤家の世話になる事になったのだが、譲吉は秀才でないばかりか、可なり怠惰者に近い方であった。",
              "citation": {
                "source": "大島が出来る話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "真ニ二千年来ノ一人――」　二千年来ノ一人……というところにばかに調子を振込んで道庵が力み返り、「中古ニ隠士｜徳本ナルモノアリ、甲斐ノ人也――」　そこで案を一つ打って、すまし返りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その分の費用は、当方から一部、口座振込にてお支払いいたします。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "南米で大金儲けをして帰った、成金紳士里見重之という振込みだ。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙を全部読み、請求書や振込書類の束をいらついて脇に押しやった。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いでそれをつかんで、口の中へ、はふりこみました。",
              "citation": {
                "source": "お姫さまと猟師",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫂は嫂で、何をぼんやりしていたものか満貫をふりこみました。",
              "citation": {
                "source": "赤耀館事件の真相",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるじの妻はらたてゝ、いかに福一、兎角どのゝ鬼のはなししてをられしに鬼かとおもひて皆きもをひやせり、めでたきとしの夜に盲が窓よりふりこみしはいまはしき事なり、とく／＼いでゆけとてしたゝかにしかりければ、あるじ、さなしかり給ひぞ、福一いかにして窓よりおちいりしぞ、いためし所はなきかといふ。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "山犬ども」　ふたりが、奮迅するのを見、助右衛門の部下も、みな、小具足姿の身軽で、槍をふりこみ、長刀をかざし、面を冒して、逆攻めをくわせた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
