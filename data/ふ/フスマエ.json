    "definitions": [
      {
        "index": 1,
        "gloss": "images drawn or painted on fusuma",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
