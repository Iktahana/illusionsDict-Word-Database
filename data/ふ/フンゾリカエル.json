          "literary": [
            {
              "text": "傲然とふんぞり返るような、成金風の湯治階級の男なぞであったら、堪らないと思った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "傲然とふんぞり返るやうな、成金風の湯治階級の男なぞであつたら、堪らないと思つた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふんぞり返る、後脚で立って見せる、悪罵を飛ばす、難癖をつける……この難癖が附きものなんだ、奴隷根性という奴さ。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　昇汞水に手を浸しそれを叮嚀に拭いた学校医は、椅子にふんぞりかえるとその顎で子供を呼んだ。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もこの男はまるでソファーにふんぞりかえるように坐って、腕組みをして煙草をふかして威張り返って天井を睨みながら、甚だ自卑的なことをまくしつづけていたのである。",
              "citation": {
                "source": "青い絨毯",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふんぞりかえる　１のひめ　こっちを　にらんで　さしず　「おはじめなさい」おしとやかにも　２のひめの　おのぞみは　「すっからかんな　おはなしが　あるといいな！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            }
          ]
        }
