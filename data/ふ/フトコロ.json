    "definitions": [
      {
        "index": 1,
        "gloss": "inside the breast of one's clothing (esp. kimono)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "扨、現代が芸術にとつて、好都合な時代でないといふことは、漠然と乍ら、既に誰人の胸にも抱懐されてゐる所である。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この懐かしい遺風は今後とも決して忘られはしないであらうけれども、今後とも発展しさうには思はれない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を見合せれば「神」や「義務」の話をする叔母を除いては、その夏休みは優に懐かしい夏休みであつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故ならば『愛の詩集』を懐中にした彼の現実には、あまりに重厚で静謐な中年者の姿を思はせるものがあつたからである。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿体ないほどありがたいことでした』と、その追懐談の中で沁々と語っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人と結婚して間もない頃、雨でずぶ濡れになった小猫を拾って帰り、その泥だらけのままの猫を懐中に入れて、長い間やさしく暖めていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり五年前、船橋に住んでいた頃の事であるが、くるしまぎれに市川まで、何のあてもなく出かけていって、それから懐中の本を売り、そのお金で映画を見た。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの大好きな魯迅先生は、所謂「革命」に依る民衆の幸福の可能性を懐疑し、まず民衆の啓蒙に着眼しました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぐい稀な特質だ」「しどろもどろの看板」「懐疑説の破綻と来るね。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その声にともかくも好感を懐いた人達の或者は、感傷的な道徳家となり、他の或者は批評主義派になつてしまつた。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄が懐手をしながら入院患者に顔を匿す様にして裏庭に出てみると、耕二が独楽を廻してゐた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は父に隠れて喫つてゐた煙草が懐にあつたので、それが御飯の時若しか転んで出でもすると不可ないと思つてそれを書斎に持つて行つて本棚の後に投げて置いた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴロンと横向きになつて、書棚に並んだ本を手で横撫でしながら、私は私の前途がいかにもいらだたしいもののやうな感じを懐いた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は外を見ると明るい日光が急に懐しくなつて来たので裏に出た。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "えいツ、なるままだと、肚を決めるこそ人間本懐なのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もかも再会に懐しむ、あの貞順な奥さんも昔の喜びに笑ひいでる。",
              "citation": {
                "source": "秋の日曜",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句の咏嘆しているものは、時間の遠い彼岸における、心の故郷に対する追懐であり、春の長閑な日和の中で、夢見心地に聴く子守唄の思い出である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの恋人は、過去にも実在した如く、現在にも実在し、時間と空間の彼岸において、永遠に悩ましく、恋しく、追懐深く慕われるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで「妹」という古語を使ったのは、それが現在の恋人でなく、過去の幼な友達であったところの、追懐を心象しているためであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "句の前書には「琴心挑美人」とあり、支那の故事を寓意させてあるけれども、文字の字義とは関係なく、琴の古風な情緒が、昔のなつかしい追懐をそそるという意味で使ったのだろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分作者は、こうした動物の印象からして、その昔死別れた彼の幼ない可憐な妹（蕪村にそうした妹があったかどうか、実の伝記としては不明であるが）もしくは昔の小さな恋人を追懐して、思慕と恋愛との交錯した情緒を感じ、悲痛な咏嘆をしたのであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句の詩情には、古い故郷の家を思わせるような、あるいは昔の祖母や昔の家人の、懐かしい愛情を追懐させるような、遠い時間への侘しいノスタルジアがある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水茎の岡の館に妹と我と寝ての朝の霜の降りはも」という古今集の歌と、どこか共通の情趣があり、没落した情緒への侘しい追懐を感じさせる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな、平凡な、退屈な村であって、しかも何となく懐かしく、記憶の藤棚の日蔭の下で、永く夢みるような村である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "更衣母なん藤原氏なんめり　平安朝の文化に対して、蕪村は特殊の懐古的｜憧憬と郷愁とを持っていた。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした平安朝懐古の句は、他にも沢山作っているので、参考のため、次に数句を提出しよう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉における木曾義仲の崇拝や、戦国時代への特殊な歴史的懐古趣味を、一方蕪村の平安朝懐古趣味と比較する時、両者の異なる詩人的気質が、おのずから分明して来るであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古都の床しい風流であり、ここにも蕪村の平安朝懐古趣味が、ほのかに郷愁の影を曳いてる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとどまる所を知らず――といふところです、をつホホホホ……」そして彼が上り口に腰掛けようとするのを見ると、「ま、まあ、お上んなさい」と云つた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり言へば聴者は、それを旋律の美しさに於て聴かないで、歌詞の面白さに於て聴き、真の音楽的陶酔とはちがふところの、別の散文化の興味で聴くからである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
