[
  {
    "uuid": "7c0d19c5-3041-5b51-b0cc-0974a0b04612",
    "entry": "不随",
    "reading": {
      "primary": "ふずい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "paralysis",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新しき男といふのは文学青年で、――尠くもその頃まで――本を読むと自分をその本の著者のやうに思ひ做す、かの智的不随児であつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "メーヌ・ドゥ・ビランは、生来の盲人に色彩の何たるかを説明すべき方法がないと同様に、生来の不随者として自発的動作をしたことのない者に努力の何たるかを言語をもって悟らしむる方法はないといっている｛１｝。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸にして露西亜はレーニンの奇蹟的な偉業とアンナ・スラビナの半身不随によって、過去タレルキンの饒舌、私に遺伝してしまった。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "一足二足進み寄るのを見ると足も片方不随であるらしい。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はおぬいの十二の時に脊髄結核にかかって、しまいには半身｜不随になったので、床にばかりついていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年半も半身不随になつて、どつと臥つたなりであつたから、小さな床屋の世帯としては、手にあまる重荷だつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯を呑むにさえ、人の手かりたりしを、情なき一座の親方の、身の代取りて、その半不随の身を売りぬ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに客のあるときは別ですが、客の無いときは半身不随の老主人が寝椅子に横たわって眼をまじ／＼さしているのを見かけます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうとっくに死んでいたおきみ婆さんと同じようにお歯黒に染めていたその婆さんは、もと髪結いをしていて、その家の軒には「おめかし処」と父の筆で書いた行灯が掛っていたのだが、二三年前から婆さんの右の手が不随になってしまったので、髪結いもよしてしまったらしい。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "物を盗みに人の家に這入るときには、神経の刺戟が不随意に腸の蠕動を起すことがある。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は僕の妻を半身不随の動物としか思えないのだ。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄無意識に働かしていた不随意筋を、一々意志を以て動かさねばならないのだから。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一言語が不随意で思ったことの三分一も言えず先方のいうこともどれだけわかったかわからないかさえわからないからわざわざ危険を冒して近よることもないと思ったのである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分に親戚や知人の家に中気でからだの不随な老人がいて、よくかんしゃくをおこしているのを見た。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶対に動くまいと思いこんでいた不随意筋がピクッと動いたので自分でもびっくりした。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "親父のよい辰も半身不随のくせに、やはり勝負をしていたのでございます。",
              "citation": {
                "source": "蜘蛛の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる年早々、Ｉ総監が半身不随に罹った旨が報ぜられた。",
              "citation": {
                "source": "外務大臣の死",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鉄道という筋肉が不随意筋を動かしたと仮定しても、それは知れている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "歳の暮頃から全身が不随になって、口もきかなかった。",
              "citation": {
                "source": "私の子供時分",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻子珍宝及王位、臨命終時不随者というので御釈迦様はすました者だけれど、なかなかそうは覚悟しても居ないから凡夫の御台様や御姫様はさぞ泣きどおしで居られるであろう。",
              "citation": {
                "source": "墓",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る友への消息に先日来、私は足部神経痛で、多少の起居不自由を感じます、いつそ歩行不随意になればよいと思ひます、さうなれば、しぜんしようことなしに身心が落ちつきませう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故あらゆる分野で婦人を封建的、奴隷的文化に封じこめて置くことに成功しさえすれば、それはとりもなおさず解放に向って闘うプロレタリアート・農民を半身不随に陥らせたと全く同じことだという事実を、彼らは狡猾に知りぬいているのである。",
              "citation": {
                "source": "婦人雑誌の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内戦時代のたたかいの結果、失明し全身不随となった若いオストロフスキーが、同志と家族にたすけられつつ、その生涯の終りに「鋼鉄はいかに鍛えられたか」という長篇小説をのこした。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこの十数年来リョウマチのために半身不随のようになってるのである。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻子珍宝及王位、臨命終時不随者といふので御釈迦様はすました者だけれど、なか／＼さうは覚悟しても居ないから凡夫の御台様や御姫様はさぞ泣きどほしで居られるであらう。",
              "citation": {
                "source": "墓",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "七年間、半身不随でおりましたが、亡くなるまで頭はしっかりしておりました。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
