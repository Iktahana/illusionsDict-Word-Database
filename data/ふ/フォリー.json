        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "パリの下宿はオペラの近くであって、自分の借りていた部屋の窓から首を出して右を見ると一、二町先の突きあたりにフォリー・ベルジェアの玄関が見えた。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前側が大きな弓型の道路で岸の中央に、海に突出して八角の建物のカジノ・ド・フォリーが夢の竜宮のように青ばむ夜を、赤々と灯を水に照りかえしている。",
              "citation": {
                "source": "モルガンお雪",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝塚の可愛いいレヴィウから、カジノ・フォリー、プペ・ダンサントと進み、北村富子一座などというエロ・ダンスへ移り、アパッシュ・ダンスを観た。",
              "citation": {
                "source": "恐しき通夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その流行はアメリカにうつって大規模なジーグフリード・フォリーズなどを生んでいる。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォリー・ベルジュール座とオペラ座とモンマルトルとサン・クルーとを見たことがあるので、パリー全体を知ってると称していた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台けい古、「ロッパと兵隊」を、キチンと立ち、終ると「フォリース　春の大放送」此の方は、堀井・上山任せ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "東宝劇場、「宝塚フォリース」だけ見る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、題も「ロッパ・フォリース」と定め、上山と合作する。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "上山・鈴木が宿へ来て正月の「ロッパ・フォリース」の案を相談する。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四が「ロッパフォリース」後半がいけなかった、特別出演のあきれたぼういずが、まあ／＼受けてゐるが、タップの稲葉や歌の豊島珠江は一つも手がとれない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フォリース」の作・編曲の鈴木静一もしきりにクサってゐる、井田一郎の指揮がクサリの大きな原因だ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ロッパフォリース」何うもいけない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ロッパフォリース」の歌が気に入らず、ハネてから鈴木静一速製のをけい古する。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ロッパフォリース」は、あきれたぼういずの楽屋入りがおくれ、そこを抜いたので、着換へが間に合はぬやら、いろ／＼ゴタついてしまひ、稽古のし直しだと怒る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フォリース」では、昨夜けい古した「ハリキリ」を歌ひ、「豪快」を引込める。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ロッパフォリース」トン／＼と運ぶやうになり、「ハリキリ歌」あまり受けもしないが、まあいゝとしよう。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フォリース」音楽がはづまないのでワーッと盛り上らない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フォリース」の「ハリキリ歌」は、手をとるとこ迄は行かないがまあいゝとしよう。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フォリース」豊島珠江がトチリ、歌を久米夏子が代った、久米中々行ける。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フォリース」のハリキリボーイ歌は漸く手が来るやうになった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フォリース」では、マイクロフォンが故障で声が通らなくなっちまふし、何かといけない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フォリース」の歌も、受けるといふ自信なしにヘラ／＼笑ひ乍ら出るのは、いとも辛い。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フォリース」の歌、ハリキリのコントやっとコツが掴めて来た。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "技芸賞とナロー賞は、「松の一番」の月野恵子、「遠山」の久米夏子、「フォリース」の加川・兎のダンスチーム、リヅムガールス四名に出た。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴木静一・山田伸吉を呼び、正月のフォリース打ち合せする。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
