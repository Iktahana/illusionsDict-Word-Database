        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "奴は凱歌の喇叭を吹き鳴らして、後れたる人力車を麾きつつ、踏み段の上に躍れり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "前は竹縁にて、切株の踏み段あり。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お妙は藁草履を持ち来りて踏み段に直せば、弥三郎は草履を穿いて出る。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、電車の踏み段の棒にやろうとした手を、引っ込めながら云った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その踏み段に足をかけることが、何だか行方知らぬ運命の岐路へ、一歩を踏み出すように不安だった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七は沓脱へはいって、揚げ板になっている踏み段を手拭で拭きながら腰をかけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、電車の踏み段の棒にやらうとした手を、引つ込めながら云つた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その踏み段に足をかけることが、何だか行方知らぬ運命の岐路へ、一歩を踏み出すやうに不安だつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "止むを得ず義雄はどこへでもかの女を押し込むつもりで、或客車の踏み段へ片足をあげると、かの女は立ちどまつたまま、「あたい、そんな窮窟なところ厭だ、わ」とすねて見せた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人の乗客は、傾く踏み段に気をつけて農婦の傍へ乗り始めた。",
              "citation": {
                "source": "蠅",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車の踏み段をおろす音がきこえた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "スペードの女王",
                "note": "青空文庫"
              }
            },
            {
              "text": "タヌは番台の前で徳利の酒を出したり入れたりし、コン吉は入口の踏み段に腰を掛け、伊太利小笛を吹いて呼び込みをしていた。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "タラノ音頭　――コルシカ島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "客車の踏み段の上で、二人は抱擁し合った。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段で息が切れて、その踏み段に腰をおろさなければならなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかでもない、不意に馬車の踏み段のそばへ地主のマクシーモフが現われたのである。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時はいつも、コゼットが踏み段の戸を開く音が街路から聞かれるのだった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "コゼットとふたりでいる時、街路から見られもしないように、踏み段のそばの奥まった所に彼らは隠れて、そこに腰をおろし、話をする代わりに、ただ樹木の枝をながめながら、互いに何度も手を握りしめるだけで満足することが多かった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は藪の間を通りぬけ、踏み段のそばの奥まった所まで行った。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから踏み段の上にすわり、心は情愛と決意とに満ち、胸の奥で自分の愛を祝福し、コゼットが出発してしまった今となってはもはや死ぬのほかはないと自ら言った。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏み段の数が多ければ多いほど、そのてっぺんには高さと誉れがある。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "お通夜から帰ったのが午前二時か三時頃で、踏み段を越えてドラムガニョールの農場に入ると、横に白猫がいるのが見えました。",
              "citation": {
                "source": "ドラムガニョールの白い猫",
                "author": "Ｊ. Ｓ. レ・ファニュ　J.S.Le Fanu",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は戸口の踏み段の所で立ち止まり、煙草に火をつけ、帽子を目深に引き、今夜は暖かいのに襟を立てた。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、正面扉が開いて、まばゆい光で、中の大広間が見え、最前面で女が、戸口の踏み段に立っていた。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏み段に立った時、警部補が闇からぬっと現れた。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も出ませんよ」　一瞬不意を突かれて、ベンウッド医師が踏み段をはずし、警部補に覆いかぶさって、首を絞めた。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全を確認し、道路へ急ぎ、踏み段に腰掛けて考えた。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと車の音が聞こえているから」　ヴィラが車を降りて歩いて行くと、踏み段の先に堂々たる玄関があった。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
