    "definitions": [
      {
        "index": 1,
        "gloss": "unpromoted (piece)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして尠くとも家の者のためには私の不成績は私の頭の悪いことであつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうのは成効であるか不成効であるか、それは自分等には分からない。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "粒の粗い今のゼラチン乾板ではおそらく不成効であったであろうが、タンニン、蛋白、塩化コロジオンを使う古い方法が丁度適当であったのである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「世界の一億年」と名づける映画はまだ見ないが、成効不成効は別問題として、製作者の意図はやはりこの「時の器械」をねらったものであろう。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自身番へ引っ立てられた時、かれは狂女を粧ってその場を逃がれる積りであるらしかったが、あとから彼の男と庄太とが大きい黒犬の死骸を引き摺って来たので、かれの狂言は結局不成功に終った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは僕だの斉藤君だの行かないので旅行が不成立になると云ってしきりに責めた。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大噐｜不成なのか、大噐｜既成なのか、そんな事は先生の問題ではなくなったのであろう。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで事相の成不成、機縁の熟不熟は別として一切が成熟するのである。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに私の恋の成立不成立は、チャンスに依らず、徹頭徹尾、私自身の意志に依るのである。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の前の壁には、純次自身の下手糞な手跡で「精神一到何事不成陽気発所金石亦透」と半紙に書いて貼ってあった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……好男子、惜しむらくは兵法を知らず……まあいい、もう行け」「僕も人見君といっしょに君を送ろう」「酔不成歓惨欲別か……柿江、貴様ははじめから黙ったまま爪ばかり噛んでいやがるな……皆な聞け、あいつは偽善者だ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外、当時の同級生には今の美術学校長正木直彦、専門学務局長の福原鐐二郎、外国語学校の水野繁太郎氏などがあって、それ等の人はなかなか出来る方であったが、私達遊び仲間の連中は総て不成績で、漸次、是等の諸氏と席の方が遠ざかるばかりであった。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀久太郎は強いことは強いが、後に至って慶長の三年、越後の上杉景勝の国替のあとへ四十五万石（或は七十万石）の大封を受けて入ったが、上杉に陰で糸を牽かれて起った一揆の為に大に手古摺らされて困った不成績を示した男である。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "突騎襲撃の不成功に終つた翌年の春、良兼は手を出すことも出来無くなつてゐるし、貞盛も為すこと無く居ねばならぬので、かくては果てじと、貞盛は京｜上りを企てた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "進み進んで、出来る、出来ない、成就不成就の紙｜一重の危い境に臨んで奮うのが芸術では無いでしょうか。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大器不成なのか、大器｜既成なのか、そんな事は先生の問題では無くなつたのであらう。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶因狂疾成殊類　　災患相仍不可逃今日爪牙誰敢敵　　當時聲跡共相高我爲異物蓬茅下　　君已乘※氣勢豪此夕溪山對明月　　不成長嘯但成※　時に、殘月、光冷やかに、白露は地に滋く、樹間を渡る冷風は既に曉の近きを告げてゐた。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶因狂疾成殊類　災患相仍不可逃　　　今日爪牙誰敢敵　当時声跡共相高　　　我為異物蓬茅下　君已乗※気勢豪　　　此夕渓山対明月　不成長嘯但成※　時に、残月、光｜冷やかに、白露は地に滋く、樹間を渡る冷風は既に暁の近きを告げていた。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら壁は腐った」　以上二話とも、あまり意気込んで程度を越した考えは、却って不成績を招くという道理の譬え話になるようである。",
              "citation": {
                "source": "愚かな男の話",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは更に進んで、かれらと桐沢氏との関係などを問いきわめようと試みたが、それは不成功に終った。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが成功して幾度も取りに来るのか、あるいは不成功のために幾度もさがしに来るのか、それは判らない。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "志士としては成功、不成功なぞは徹頭徹尾問題にしていなかった翁の、徹底的に清廉、明快であった生涯に対して、今すこし幅広い寛容と、今すこし人間味の深い同情心とを以て、敬意を払い得る人の在りや無しやを問いたいために云うのである。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "捜索は不成功である。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の不成績を少しく恥ぢて一奮發して見る氣に成つた時のことだが、惡友を避ける爲めに在の百姓家の一間を借りて居た。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "講演の不成功に落胆せずにポウはその草稿を書き直して間もなくプトナム出版社を訪れ、「極めて重要な件について、プトナム氏と会談したい。",
              "citation": {
                "source": "『ユリイカ』挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一切不成功に終つて彼は、寝た。",
              "citation": {
                "source": "鸚鵡のゐる部屋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは六兵衛の不成功を責めた。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪萩原朔太郎青くしなへる我が指のリキユールグラスにふるるとき生れつきとは思へども侘しく見ゆる爪形をさしも憎しと思ふなり",
              "citation": {
                "source": "爪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああかくてもこの故郷に育ちて父母のめぐみ戀しやと歌ふなり。",
              "citation": {
                "source": "秋日行語",
                "author": "〔菊もうららに〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "」さう云ふなり良子は、走つて台所と物置との間の、狭い通路に這入つてしまつた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
