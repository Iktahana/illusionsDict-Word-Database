        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "甲子の山へ到りて楓葉の景見ざらむは、堂に至りて室に入らざるが如し』とは、白河樂翁公の記せる所也。",
              "citation": {
                "source": "阿武隈川水源の仙境",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "樂翁公の口眞似すれば、甲子の楓葉見て甲子の瀧見ざるは、堂に上りて未だ室に入らざるが如しとも云ふべきかとて、白河風士記に據り、宿の人々に聞きたゞして、あまねく甲子の瀧を探りぬ。",
              "citation": {
                "source": "阿武隈川水源の仙境",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "上流に燃ゆるが如き楓葉あり。",
              "citation": {
                "source": "碓氷峠",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときの狂言は一番目「清正誠忠録」、二番目「花盛劇楓葉」で、中幕には改名披露として「曾我の対面」を出し、梅幸の十郎、菊五郎の五郎、栄三郎の八幡三郎で、団十郎が工藤を勤めた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "往路には霞亭が「楓葉為塵梅未開、非君誰肯顧蒿莱」と云つて迎へた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "日暮東塘正落潮、孤篷泊處雨蕭蕭、疎鐘夜火寒山寺、記過呉楓第幾橋、楓葉蕭條水驛空、離居千里恨難囘、十年舊約江南夢、獨聽寒山夜半鐘王漁洋も寒山寺の夜半の鐘声を聞いたのである。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十九日京洛之新緑、美無加、散歩途上口占東山春色絶纖塵　　東山の春色纖塵を絶つ、楊柳青青楓葉新　　楊柳青々楓葉新たなり。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い楓葉につつまれたる白布の滝が静かに落ち、その周囲は雲煙を以てぼかされた。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学生じみた感慨に耽ければ、楓葉荻花瑟瑟の秋に、江州の司馬白楽天が、青袗を沾した琵琶の曲は、斯の如きものがあったかも知れない。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "楓葉荻花秋瑟瑟などと云う、洒落れた趣は何処にもない。",
              "citation": {
                "source": "長江游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに人間の一生は春の花、秋の楓葉、朝露、夕電、古人すでにいッたが、今になッてますますさとる。",
              "citation": {
                "source": "初恋",
                "author": "矢崎嵯峨の舎",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車のきく北野の終点まで行って、そこから俥で洛西の郊外の方に出ると、そこらの別荘づくりの庭に立っている楓葉が美しい秋の日を浴びて真紅に燃えているのなどが目についた。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "楓葉荻花秋は瑟々たる刀禰河あたりの渡船で摺れちがう処などは、殊に妙であろう。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "楓葉少しく霜に染む。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭前の楓葉錦の如し。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに、余はその返礼としてヒマラヤより楓葉を持ち帰り、左の歌を書して氏に贈る。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかんずく猩々木の各所に繁生して、霜後の楓葉よりも赤し。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝ごとに霜が強くなり、神山の頂きが薄ッすらと白くなったと思うと、満山の楓葉が飛落し、一夜のうちに稜々たる山骨が露呈してしまった。",
              "citation": {
                "source": "湖畔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは提げてきた正宗の罎を口につけて喇叭飲みしながら潯陽江頭｜夜送客、楓葉荻花秋瑟々と酔いの発するままにこえを挙げて吟じた。",
              "citation": {
                "source": "蘆刈",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葦は葦の仲間を呼び、揚子江の“三覇”一｜荘に会すること潯陽江頭　夜　客を送る楓葉　荻花　秋索々――　これは白楽天の詩「琵琶行」のはじめの句だが、いまの宋江の身は、そんな哀婉なる旅情の懐古に浸りうるどころではなかった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "潯陽江頭　夜　客を送れば楓葉　荻花　秋索々たり主人は馬より下り　客は船にあり酒をあげて飲まんとするに管絃なし酔うて歓をなさず　惨として将に別れんとす別るるとき　茫々　江は月を浸せり忽ち聞く水上琵琶の声「……ああ」宋江は、ついに涙をたれた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
