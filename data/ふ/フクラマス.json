    "definitions": [
      {
        "index": 1,
        "gloss": "to swell",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――そして私は、それら二つの帆を、ひとつ息でもつて、膨らますことができたといふ事のうちに限りない恩寵を認めます。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨は浴るようだし、恐さは恐し、ぶるぶる顫えると、親仁が、強いぞ強いぞ、と言って、私の衣類を一丸げにして、懐中を膨らますと、紐を解いて、笠を一文字に冠ったです。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、夏だ――」　老舗の日除は、埃を払い、ペンキの禿げた喫茶店はせっせとお化粧をする――若い青年たちは、又、近く来るであろう別荘のお嬢さんに、その厚い胸板を膨らますのである。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "路傍にある松林の中へ入って、清らかな小川を前に、四人の少年は各自の胃袋をはちきれそうになるまで膨らますことができた。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は笑はない、小鼻を膨らますのである。",
              "citation": {
                "source": "劇作家としてのルナアル",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は小鼻を膨らますのである。",
              "citation": {
                "source": "ジュウル・ルナアル",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "雄鶏は見得をきり、羽を膨らます。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女らの喉をしめつけるやうなフツトライトのなかで、彼女らは兩手を頭のうしろに組み合せながら、胸を出來るだけ膨らますのである。",
              "citation": {
                "source": "水族館",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○台南産業館陳列の顔水竜氏指導作品の三角｜藺のスリッパー　もっと先きのところを膨らますといいね。",
              "citation": {
                "source": "台湾の民藝について",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで女の芸人には一向綽名を奉らず、ただひとり、橘之助門下の花橘、十七、八の小娘で下ぶくれの顔立ちから口元のむっとした工合で「ウサギ」、客にいわれると踊りながら一層口元を膨らます。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宰といふ縣會議員はない、と頬ふくらますひともあらうが、私は、いつはりを言はぬ。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏がきて、期待で胸をふくらますようなこともなければ、クリスマスの浮き立つような華やかさもない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "たたみこむと、わずか一メートル立方の箱の中にらくにはいってしまうが、取り出してふくらますと、すばらしくでかいものになる。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "器械がまわり、時間がたつにつれ、足の先に腰が現われ、それからその先に胴中やら、胸やら肩やら、そしてあの醜い首やらがむくむくと、まるで畳んであったゴム風船をふくらますように現われてきたではないか。",
              "citation": {
                "source": "宇宙女囚第一号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さわやかな初夏の憶いが風になって僕の袂をふくらます。",
              "citation": {
                "source": "魚の序文",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私がバスケットから、お弁当を出すと、お婆さんはニコニコして、玉子焼きを口にふくらます。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、きみは下腹に力がないぞ、胸のところをへこまして下腹をふくらますようにせい」「はい」　先生はつぎのクラモウのへそを押した。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "かすかに酒の匂いのこもった芳ばしい呼吸、時おり胸をふくらますあの呼吸は、どこへ行ったのか。",
              "citation": {
                "source": "復讐",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから釣り人は河豚が釣れると憎しみのあまり、骨も砕けよと渾身の力で舷か、岩角へ叩きつけるのだが、河豚は腹をふくらますだけでけろりとしている。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はなかなかの健啖家で、痩せほそってはいたものの、大蛇のように胃袋をふくらますことができたのだ。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度ゴムで拵へた枕をふくらますやうに、僕は今このの腹の中は実に想像の出来ないほど伸縮自在だからね。",
              "citation": {
                "source": "鰐",
                "author": "ドストエウスキー　Fyodor Mikhailovich Dostoevski",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふるえ、ゆらぎ、はためくすべてのもの、照りわたった夏の日、風の夜、流れる光、星のきらめき、雨風、小鳥の歌、虫の羽音、樹々のそよぎ、好ましい声やいとわしい声、ふだん聞きなれている、炉の音、戸の音、夜の静けさのうちに動脈をふくらます血液の音、ありとあらゆるものが、みな音楽である。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "ロマン・ローラン",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺をふくらますのさえ、百斤の重さを上げるような気がしてくる。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "萎びた内容をもつ者は言葉でもってそれをふくらますのでございます。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに我々の霊魂がこのわらうべき遊戯を大きくふくらますかを。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼らの心を自由独立の精神をもってふくらますことを望んだでしょう。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "エアー・コンプレッサーなら、この人形をふくらますくらい、またたくうちですからね。",
              "citation": {
                "source": "虎の牙",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
