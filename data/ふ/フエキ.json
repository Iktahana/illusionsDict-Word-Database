[
  {
    "uuid": "c49c6589-4d91-5c65-ad1c-2de323cd351e",
    "entry": "不易",
    "reading": {
      "primary": "ふえき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
