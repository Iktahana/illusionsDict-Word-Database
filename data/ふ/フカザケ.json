    "definitions": [
      {
        "index": 1,
        "gloss": "heavy drinking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "深酒の上に、急に海へ入ったもんですから、血が留ってしまったんでしょう。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "若いうちの深酒で主人は心臓を弱くして居る。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――生憎妖婆は前の晩に深酒をして、寝るときにスイッチをひねっておくことを忘れたので、ラジオ体操が放送されていても彼の妖婆には聞えなかった。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "司馬温公、五字あり、云ふ、煙曲香尋篆、盃深酒過花と。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――どうも、調子がいけない」　前々日の深酒や雪風の中を歩いたのが影響したのであらうか、「高等乞食」は、珍しく不精鬚を延ばして、床についてゐた。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "深酒をした夜など与平の気持ちは乱れて、かっと眼を開いているまつの前でも与平は千穂子に泣くようにしてあやまるのである。",
              "citation": {
                "source": "河沙魚",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "深酒に酔って、しばらくごうごうといびきをたてて眠ると、夜中になって、与平は本能的に何かを求めた。",
              "citation": {
                "source": "河沙魚",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫歯が出来たし、胃が弱くなって、深酒をすると、翌る日は一日台なしになってしまう。",
              "citation": {
                "source": "生活",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の夜の深酒がたゝつて、何時までも頭が痛く、胃も重かつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃から殊に、Ｂ君の深酒が、時には自暴自棄かと思われるほどの深酒が初まったとのことである。",
              "citation": {
                "source": "必要以上のもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "深酒の翌朝の早起は、自分自身に對しても負嫌で押通す三田のならはしだつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々は他所で食事を濟ませて來る事もあるし、夜更に戸を叩くやうな事もあつて、そんな時には屹度深酒の香がしたが、別段足下もふらつかずに、さつさと二階に上つて行く。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "深酒と睡眠不足で、頭も上らない程疲れて居た。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風に吹かれてゐる間は、すつかり醉もさめた氣でゐたが、横になつて見ると深酒の名殘は蒸暑く胸から上に押上げて來た。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、堅く天地神明に誓いをたてて御婦人を追い廻しても、悟らざること甚しく、恋いこがれ、邪推し、千々に乱れて、あげくには深酒に浮身をやつす哀れなキリギリスにすぎなかった。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の心は連日の深酒と荒淫で晴れ間のない空の如くに陰鬱であつた。",
              "citation": {
                "source": "我鬼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "深酒に酔ひ痴れ、荒淫に身を投げ沈鬱の底に重い魂が沈んでゐた。",
              "citation": {
                "source": "我鬼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は大した深酒ものまず、道楽もせず、一種の学究者でして、生活が華やかでない代りに、至って真面目だったのです。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴らにつけられ初めてから或る晩、私は虚勢を張るために深酒をのんで、一二度行ったことのある円窓の家へ、ひょっこりはいっていった。",
              "citation": {
                "source": "都会の幽気",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "白羊の眼が悪くなったのは、たぶんこんな深酒が祟っているのだろう。",
              "citation": {
                "source": "ヒウザン会とパンの会",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その深酒や、不規則な生活が原因だつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜかというと、深酒すると、必ず吐く。",
              "citation": {
                "source": "わが工夫せるオジヤ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度血を吐いたのは、深酒というよりも、ウイスキーをストレートで飲む習慣が夏からつづいて、その結果であったと思う。",
              "citation": {
                "source": "わが工夫せるオジヤ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂暴に深酒をするやうになつた。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は親友として、なぜそう深酒をするのか、なぜ身分不相応な暮らしをして借金ばかりするのか、なぜ遊んでばかりいて本を読まぬのか、なぜそう教養がなく無知なのか――などと一とおりの苦言は呈して見た。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顔色の蒼いのは深酒の宿酔のせいか。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十一　稲妻は見たり",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、自分は今相変らずの深酒をしているけれど、この頃はマント一件、焼鳥一件のようなああいうヘマは決して師匠の前で見せていない。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい深酒ばかりしては囃子哀しい法善寺横丁の花月や紅梅亭へ、連夜のようにかよいつめて、せめてもの憂さを、亡き枝雀や枝太郎や春團治の高座高座に晴らしていた。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日私は読者と共に旧稿を再読して見て文壇と家庭とに指標を見失ひ、深酒を煽つては端席の高座に、文士くづれの落語家として出演してゐた時代の落莫たる己の姿をあはれ憫然なりしものよと云つた風な感情を以ておもひ泛べないわけには行かない。",
              "citation": {
                "source": "滝野川貧寒",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
