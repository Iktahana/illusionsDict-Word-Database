    "definitions": [
      {
        "index": 1,
        "gloss": "to tread down so as to harden (soil, snow, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鬼・天狗・巨人などが出て、四方或は五方を踏み固める。",
              "citation": {
                "source": "根子の番楽・金砂の田楽",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダムが戸口まで送ってきて、小首をかしげて見送ってくれる眼付を、岸本は背中に感じて、拳をにぎりしめながら、大地を踏み固めるような気持を足先にこめて大股に歩いた。",
              "citation": {
                "source": "田舎者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸した豆を藺で囲んで、丸い枠を上から穿めて、二尺ばかりの高さになった時、クーリーはたちまちこの靴のまま枠の中に這入って、ぐんぐん豆を踏み固める。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "西田哲学を西田学派にまで踏み固めることは、田辺元博士のみ許される尊敬すべき努力であるように見える。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは橋畔や道辻なれば通行人が多いので、絶えず屍体の上を踏み固めるので、凶霊が発散することが出来ぬと云う信仰から来たのである。",
              "citation": {
                "source": "屍体と民俗",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはこうした場所ならばたえず人馬の往来があるので、死霊が発散せぬよう踏み固めると信じたからである。",
              "citation": {
                "source": "本朝変態葬礼史",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
