[
  {
    "uuid": "fd4be23c-1661-5419-ae0c-fe7f99fbff86",
    "entry": "襖",
    "reading": {
      "primary": "ふすま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
