    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fusuma",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は万策尽きた気持で、襖をへだてた小坂家の控室に顔を出した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　耕二には、父の少しでも能く目の当る所をといふので、父の居間と襖一重隔てた三畳の間が与へられてあつた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんなこと言ひやがる」と思つた兄は一寸調子外れをした、兄は父の居間との境の襖の方に目を移した。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "耕二はそれは言はれるとスツト立つて襖の方に行きかけた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――耕二はそのガシヤガシヤの手を襖の把手に手を掛けた儘、此方を向いて口をムツチリさせてゐた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "耕二のなめらかな頭の影が、真白な襖の面へ茫然浮き出てゐた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」耕二はさう言ふなり襖を開けた儘で床の方へ行つた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "中で一番威張れる者が、その赤らんだ薄い皮膚の眼蓋の上にロイド眼鏡を掛けて、彼女が襖を開くや愛相よく「今晩は」と言つた時、彼女は漸く何だか嬉しくなつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "起き上つてあたりを見廻してゐると、すつと襖があいて、身長二尺くらゐのお人形さんが出て來て、「あら、おめざめ？",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "襖があいて、お鈴さんがお酒のおかはりと、別な肴を持つて來る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は茶の間の四畳半と工房が座敷の中に仕切って拵えてある十二畳の客座敷との襖を開けると、そこの敷居の上に立った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分で襖を張り替えてそれに書や画もかく。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポアッソニエの大通はもう五色の光の槍襖を八方から突出していた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「手は金銀に桂二枚」　「金銀に桂二枚と……ウー」　「へえ、親分」　また児分が襖の処へ来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "金銀に桂二枚か金銀に桂二枚と」　「へえ親分へ」　児分が襖の処へ次郎長を案内して来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝廊下　障子破れて、襖が倒れて、五六人の黒い影が組んづほぐれつ段梯子を折り重って転がり落ちる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "児分、襖の外から、　「親分、石松兄哥が帰って参りました」　「そうか、帰ったか」　と次郎長、紺久に、　「帰って来ました」　「じゃ、次郎長どん、儂はお暇しよう。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝棚倉宅　三次は襖や障子等手当り次第に投げては振り廻し大乱闘。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、ある部屋の襖を開くと、　縛られて居るおきよの後姿。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "襖の所で大吉振り返って五郎蔵に、Ｔ「じゃが、親分　いかい御熱心？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、襖慌ただしく開いて留守番の児分、Ｔ「大変だ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "座敷へ上って――　次の室の襖ガラリ開いて二人共アッと叫んだ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　襖の処で乳母や番頭がオロオロ顔である。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へ近侍が襖を開いて、Ｔ「雲霧主膳と仰しゃる方が」　で左衛門と七兵衛顔見合わせた。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）左衛門の宅　七兵衛が襖の外で聞き耳立てる。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室の襖を開いて左衛門と七兵衛が覗く。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "左衛門が右手を上げると、　襖を開いて数十の捕方。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の話しぶりはきわめて卒直であるものの今宵初めてこの宿舎で出合って、何かの口緒から、二口三口｜襖越しの話があって、あまりのさびしさに六番の客から押しかけて来て、名刺の交換が済むや、酒を命じ、談話に実が入って来るや、いつしか丁寧な言葉とぞんざいな言葉とを半混ぜに使うようになったものに違いない。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は襖に背をもたせて御伽噺の本を眼鏡でたどっていた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　待構へてゐた二人の侍は押取刀で矢庭に襖をあけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
