        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "中隊長は、不満げに、彼を睨んだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "報告に、息せき息せき引っかえすたびに、中隊長は、不満げに、腹立たしそうな声で何か欠点を見つけてどなりつけた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と多少不満げに口を尖らして尋ねました。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が同居人の方をうかがうと、不満げな顔をしていたので、私の方だけでも平静を繕おうとつとめた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉目三郎の不満げな態度がそれを代表していた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇のなかで、疲れた眼をあげて不満げに高倉を見たが、むろんそんな表情は見えなかった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　八重子は不満げに、トランプとハナの札をいじくった。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フム」　今泉はかすかに鼻のあたりを不満げにふくらませた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、考へてちやうだいよ、なんか……」五　幾島は気勢をそがれてやゝ不満げであつたけれども、屈託のない素子の調子にまた釣りこまれて、「考へるつたつて、具体的なことは、当事者でなくつちやわからないから……。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一人の首斬り人がいれば裁判所全体のかわりをすることでしょうよ」「そう一般的な言いかたをしちゃいけません」と、画家は不満げに言った。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は不満げにコートのある方へ足を向けて行った。",
              "citation": {
                "source": "愉快な教室",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と彼は不満げな調子で尋ねた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "小柄な女羊飼いは喜びの声を上げたが、やがて眼が冷ややかになり、不満げであった。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその誰かじゃないよ、私はね」ゴリオ爺さんが少し不満げに言った。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "不満げに聞いていた。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "不満げにバタンと扉を閉じたので、これ以降、話は聞けそうにない。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
