        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "言葉は普通でも内容には沸々と熱いものが沸いている。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭壇の上には、黒牛の皮で作られたおそろしく大きな釜が置かれて、その釜の中には熱湯が、火の気も無いのに、沸々と煮えたぎって吹きこぼれるばかりの勢いでありました。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "流レ、澱ミテ淵、怒リテハ沸々ノ瀬、懸リテハ滝、果ハ、ミナ一。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "急湍は叫喚し怒号し、白く沸々と煮えたぎって跳奔している始末なので、よほどの大声でなければ、何を言っても聞えないのです。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸し熱い、激しく臭う、沸々沸々沸々とした何かが、階上に充ち満ちていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "沸々沸々と、瓦斯の立つ痘痕の面、これがあの丸太の、美女の胴体とは。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "沸々、沸々、沸々々々………沸。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "余屡ば木履を奪いたる、窩氣は沸々聲の聲ありて、噴氣と共に泥土の上騰するもの、時に或は數尺ならむとす。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋は沸々として煮立つと突き上げられて居た蓋が自ら鍋と平らにさがる。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋は更に沸々として汁のとばしりが四方に飛ぶ。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴を穿てばどこからでも沸々として其清冽な水が湧いて出るといふのである。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "内の燈火は常より鮮に主が晩酌の喫台を照し、火鉢に架けたる鍋の物は沸々と薫じて、はや一銚子更へたるに、未だ狂女の音容はあらず。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……沸々として涌き出づる泉の微温が潺湲と胸に滾れたかと思ふと、愚かな五体は徐ろに無何有の郷に溶けて行つた。",
              "citation": {
                "source": "坂道の孤独参昧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処等一面の岩の裂目や石の下から沸々と白い煙を噴き出しているのであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、娘や後家や歌妓や遊女などに、相対した時には、かつふつ懐いた事のないような、不思議な物狂わしい情熱が、彼の心と身体とを、沸々燃やし始めたのである。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思うと、瑠璃子は、女ながらにその小さい胸に、相手の卑怯を憤る熱い血が、沸々と声を立てゝ、煮え立つように思った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "』それが、青年の心に、沸々と湧き立っている云い分であった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、そこに二三分間待ったが、心の底から沸々と湧き上っている感情の嵐は、彼を一分もじっとさせていなかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "上品な顔立ちをもち、心もち青白い皮膚の下に、なにかしら情熱が静かに、だがすこやかに沸々と泡を立てているといったようにみえる。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう思ふと、瑠璃子は、女ながらにその小さい胸に、相手の卑怯を憤る熱い血が、沸々と声を立てゝ、煮え立つやうに思つた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "』それが、青年の心に、沸々と湧き立つてゐる云ひ分であつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、そこに二三分間待つたが、心の底から沸々と湧き上つてゐる感情の嵐は、彼を一分もぢつとさせてゐなかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "光りにすかして見ると湿気地の薄い水の表面には瘴気の泡が蟹の呼吸のやうに沸々としてゐた。",
              "citation": {
                "source": "籔のほとり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど当時のわたしは、そんなものは何一つわかりもせず、また、自分の中に沸々とたぎっているすべてのもののうち、どの一つだって、それと名ざすだけの力はなかったろう。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふつふつ、ふつふつ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むくつけき犬の入り来て、　　ふつふつと釜はたぎれど、額青き林光文は、　　　　　　そばだちてまじろぎもせず。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中ではふつふつとわらつてまた叫んでゐます。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから英国ばかりぢやない、十二月ころ兵営へ行つてみると、おい、あかりをけしてこいと上等兵殿に云はれて新兵が電燈をふつふつと吹いて消さうとしてゐるのが毎年五人や六人はある。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬二頭が、鼻あらしを霜夜にふつふつと吹いて曳く囃子屋台を真中に、磽※たる石ころ路を、坂なりに、大師｜道のいろはの辻のあたりから、次第さがりに人なだれを打って来た。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となく賑かな様子が、七輪に、晩のお菜でもふつふつ煮えていようという、豆腐屋さ――ん、と町方ならば呼ぶ声のしそうな様子で。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
