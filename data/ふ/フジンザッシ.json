    "definitions": [
      {
        "index": 1,
        "gloss": "ladies' magazine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
