        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ジイドの描いたジュネヴィエヴという十八歳の娘は、（未完の告白）平俗偽善な小市民的父親の「良俗」に反抗し、抗議せずにいられない情熱から、自分の独立を、自分の不服従を、女性だけがなし得る出産という行為で、明らかにする欲求から結婚もせず、恋愛からでもなく、子供を持とうとする。",
              "citation": {
                "source": "未開の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒムラー内相のことはデーニッツ新総統が不服従の烙印を捺し、ヒムラー氏の対米英休戦申入れを許さずとしたとある。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも尚裏切者を血祭にあげる、人情まことに憐むべしであるけれども、いはゞ降伏に対する不満の意、不服従の表現と認められても仕方がない。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の兵士が、不服従と上官侮辱で処刑されるから、立ち会ってほしい、と。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "司令官は、命令不服従と上官侮辱とのために宣告を下された一人の兵士の刑の執行に立ち会うようにとすすめたのだった。",
              "citation": {
                "source": "流刑地で",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは初めから不服従と反感を示し、わざと彼を怒らせ、困惑させるようにふるまうのであった。",
              "citation": {
                "source": "いさましい話",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "役所のほうもまず文句はない、下役はよく働いてくれるし、郡代たちにも反感を示したり、不服従なまねをするような者はいない。",
              "citation": {
                "source": "霜柱",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "反戦運動をおこなっている人たちの多くが、軍務不服従を実行するのとおなじくらいの危険をおかしているのだという事実を、あなたに知ってほしい。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その命ずるところはあのとおり混沌として不定であるから、ある意味では、不服従をも、解釈、実施、遵守における誤謬をも、あらかじめ許しているようなものである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
