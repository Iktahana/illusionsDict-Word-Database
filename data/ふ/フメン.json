    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sheet music",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
