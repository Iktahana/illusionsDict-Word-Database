[
  {
    "uuid": "58302941-813e-57d6-b6f0-d66d2e5eae13",
    "entry": "譜面",
    "reading": {
      "primary": "ふめん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
