        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一八四五年にカールは、ベルギー政府とプロシヤ政府連合の追放政策から自身を守るためにプロシヤの国籍から離脱した。",
              "citation": {
                "source": "カール・マルクスとその夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ全農東京府連の××村支部へ指導をもとめて来た。",
              "citation": {
                "source": "共同耕作",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して殆んど涙にあふれんとする眼を擧げて牧師を見た。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村は葉子の激しく泣いたのを見てから、こらえこらえていた感情がさらに嵩じたものか、涙をあふれんばかり目がしらにためて、厚ぼったい口びるを震わせながら、痛々しげに葉子の顔つきを見入って突っ立った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇怪な実在をつかんで発狂することのないように、彼はあらかじめあらゆる想像をたくましうして今ふれんとする世界からの刺戟にそなえたのであった。",
              "citation": {
                "source": "放送された遺言",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その長所と欠点とにおいて、著者は全く自己の真心を披瀝しており、読者の人間性の皮膚にじかにふれんとする情熱を示している。",
              "citation": {
                "source": "新島繁著『社会運動思想史』書評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そのただの水が、どうしてこの部屋のこの靴の片っぽにこんなにあふれんばかりに存在することになったのか？",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ナモサダルマブフンダリカサス――トラのりふれんが時々きこえて来る。",
              "citation": {
                "source": "惰眠洞妄語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは濡れた衣服を着た人間が、この計器にふれんばかりの近くにすすみよったことを示すものなのです。",
              "citation": {
                "source": "赤耀館事件の真相",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "またずっと下にあった氷原が、手にふれんばかりの近さに盛りあがっている。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あまり鳥が美しいので、つかまえる手がにぶったか、指先が、尾にふれんとした瞬間、急に鳥は、おどろいて飛び立ちました。",
              "citation": {
                "source": "心の芽",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤手空拳の人間力と、自然とのたたかい――あふれんばかりの大河をはさんで、木材や石をかついだ烏帽子水干の人たちが、蟻のように右往左往する場面を想像してください。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどくよごれて……」　男はぎろりとおかみさんをにらみ、きっぱりと、「ふれんでもらいたいね。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、引き続きて文部大臣より過分の賛辞を賜るの栄を得、その喜びまた、まさにあふれんとするばかりでありました。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "』しかく念じてアキリュウス立てば、恐怖を抱く敵、近くに來り彼の膝ふれんとしつゝ飽く迄も、　65無慚の死滅暗黒の運命逃れ去らんとす。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "――愛情が満ちて今にもあふれんとしてるのが感ぜられるような、聴衆の沈黙もある。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はただ少しの小｜競合いを期待してるばかりであって、将に水が堤にあふれんとする瞬間を老練な眼で見守っていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば、有り余るほどいっぱいの歓喜と、あふれんばかりの至福が訪れる。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯茶もなく、ぽそぽそと、舌つづみ打っている姿には、行く末は誰が肌ふれん紅の花――などという色も香もない。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔には歓喜とあふれんばかりの思い出が現れた。",
              "citation": {
                "source": "親友たち",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            },
            {
              "text": "タビストック・ストリート沿いの一軒の酒屋、ド派手な正面に明かりが輝き、怪しく光るガラス窓があふれんばかりの笑顔を振りまき、あくどい客引きをしているように見える。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "各銀行の事務所は払い戻された金貨があふれんばかり。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
