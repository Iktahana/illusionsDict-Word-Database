    "definitions": [
      {
        "index": 1,
        "gloss": "to trample underfoot",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このりつぱな尊げな和尚さんが、酒によつてゐて、米を踏みにじるやうなことをしたとは、とても思へませんでした。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏みにじりたいだけ踏みにじるがいい。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうするのだ、おい、野郎、媽あを叩き出すか、俺だちの義侠心を踏みにじるか」　襖がずらりと啓いて定七が出て来た。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋の始めにはいつでも女性が祭り上げられていて、ある機会を絶頂に男性が突然女性を踏みにじるという事を直覚のように知っていた葉子は、どの男に対しても、自分との関係の絶頂がどこにあるかを見ぬいていて、そこに来かかると情け容赦もなくその男を振り捨ててしまった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏みにじるとも、斬りきざむとも、存分にせられい！",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "横行してゐるものはそれでなければ、土足で踏みにじるやうなやり方で現實を割り切つて見せてゐる一つの勢力だつた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "網代の笠に夕日を負うて立ち去る瀧口入道が後姿、頭陀の袋に麻衣、鐵鉢を掌に捧げて、八つ目のわらんづ踏みにじる、形は枯木の如くなれども、息ある間は血もあり涙もあり。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、さうした人間たちはいつも土足で僕の頭のなかを踏みにじるのだ。",
              "citation": {
                "source": "災厄の日",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、一つにまとめた開拓への昂い意志は、悪い条件に出逢うたびに、ひきおろされ、ひン曲げられ――今や踏みにじるのも止むを得ないと彼らの顔色が叫んでいた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "六尺幅のところ横に散らばって、一鍬々々、踏みにじるように進んでいる彼らの身体は、流れるような汗に濡れ、照りつける陽にむんむんとむれていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはおまへに負けない、わたしはおまへを取入れよう、おまへに騎つて行かう、太陽の使、真昼の霊、涙と影を踏みにじる力者。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二には、物の道理を踏みにじることだ。",
              "citation": {
                "source": "憑きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、人生の美しい夢を踏みにじるもののように思われました。",
              "citation": {
                "source": "食慾",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "動きのとれなくなった愛欲関係になおひかれて相互の運命を破局に導き、世法の威厳を踏みにじるのはたとい同情すべきであっても、正しいことではない。",
              "citation": {
                "source": "人生における離合について",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心をもみくちやに踏みにじる恋情に縋りついてゐなかつたら、私は到底生き永らへてゐられないのだ。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、踏みにじる音がする。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "編輯長は踏みにじる人だ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのわたしの願いを踏みにじる気かね？",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那は植松のような家に生まれながら、どうしてそんなひそかな戯れ事の秘密を知ったろうと思われるほどの人で、そのお粂の驚きは彼女がささげようとする身を無慙にも踏みにじるようなものであり、ただ旦那が情にもろいとかなんとかの言葉で片づけてしまえないものであったという。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、何かを踏みにじるような気持で、わざと大きな足音を立てて階段を下りていった。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "源頼朝が征夷大将軍として、天下の政権を掌握するようになりましては、その侍たる鎌倉武士らは、相変らず家人という国法上では賤民の名称を有しながら、事実は大名小名となり、国法上良民であるはずの百姓らを、脚下に踏みにじるほどの高い身分となりました。",
              "citation": {
                "source": "融和問題に関する歴史的考察",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その操をむざんにも踏みにじる職員。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "（粗暴で狂激で血を以て彩られたその動作と躍進よ、あらゆるカピタリズムとティラヌイの跳梁の上に、踏みにじる傍若無人の足どりよ、うち振る白い剣の閃めきよ、怒号する口よ。",
              "citation": {
                "source": "騒擾の上に",
                "author": "百田宗治",
                "note": "青空文庫"
              }
            },
            {
              "text": "棒で打つ、足で踏んづける、靴で踏みにじる。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは地球を踏みにじるほど大きくなりはしないかと心配した。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊丸　……（しばらく默つて立つていたが、やがて二歩ばかり前に出て、片足をあげ、女の頭髮の歩道にはみ出した部分を下駄でガリガリガリと踏みにじる）御橋　（それを見ていたが）ふむ。",
              "citation": {
                "source": "夜の道づれ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（更に腰のへんを三つ四つとけりつけ、つづいて首のところを、踏みにじる）やい、立って、かかって来て見ろ！",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙太がヒョロヒョロとなるところを刑吏と喜平が散々蹴倒し踏みにじる。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しいので評判だつた年増も、死の苦しみにすつかり變貌して、まことに見る影もなく、その上額や頬や首筋のあたりに、得體の知れない摺り剥きと皮下出血があり、更に少しばかり泥のついて居るのは、曲者は憎しみの餘り、死骸の頭から顏のあたりを、踏みにじるかどうかしたとしか思へません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "敵持ち",
                "note": "青空文庫"
              }
            },
            {
              "text": "・投げ与へられた一銭のひかりだ・馬がふみにじる草は花ざかり朝一杯、昼一杯、晩一杯、一杯一杯また一杯で一杯になつてしまふのだらう。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
