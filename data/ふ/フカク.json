    "definitions": [
      {
        "index": 1,
        "gloss": "failure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どうせ、批評家に言わせると、大愚作なのだろうが、私は前後不覚に泣いたのである。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京方面の商人が前後不覚でマルセーユからベニスあたりまで寝ているなんてことはあり得ないことですからね。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま李鄭の部屋で前後不覚になってしまっていたのではないだろうか？",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "めずらしく支那内地に戦争がなかったので銀需要の思惑は、これらの悪材料のために前後不覚となり惨落となった。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "頑固親爺が不幸むすこを折檻するときでも、こらえこらえた怒りを動作に移してなぐりつける瞬間に不覚の涙をぽろぽろとこぼすのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は不覚にも、鏡の中で少女に笑いかけてしまった。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなかの柄であって、われは彼の眉間の皺に不覚ながら威圧を感じた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒田藩には、これほどに思い切った荒療治をなさる知恵者がお出でにならぬものと見限っておりましたのが私の不覚……お蔭で襟半と蔵元屋の御両家、千秋万楽と祈り上げておりました私の楽しみも、茶々苦茶羅になってしまいました。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々はそわそわし初めた、ただ今井の叔父さんは前後不覚の体である。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "親指の股に仕事｜疣のはいった巌丈な手が、不覚にも心持ち戦えるのを感じた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……科学のために一身を献げようとするものに何んという不覚なことだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし下枝等の死したらんには、悔いても及ばぬ一世の不覚、我三日月の名折なり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、不意に襲われると云うことが已に不覚だよ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言いながら、道子は不覚にも涙を落し、「あ、こんなに取り乱したりして、きっと口答試問ではねられてしまうわ。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……安心満腹、前後不覚、よい雨の夜のよい眠だつた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "前後不覚になつて、どうして寝床にはいつたやら、いつ寝たやら、一切合切不明なり、しかも些の不都合なし、善哉々々。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お雄坊の前なんかで不覚の泪を流すのは辛かったので、それに陽ざしもそろそろ赤くなって来ていたし、思い諦めて江の島遊園地を引き上げました。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも、むしろ幸子の夫である僕が、彼の犯罪を悉く知っているばかりでなく、彼が不覚にも成し遂げなかった目的を、代って果してやったと、打ち明けた方が、余程効果のある趣向ではないだろうか……」　旻は低い呻き声をあげた。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子はわがままが利くようになったので、一つのことを拒みつづけながらも、時には不覚を取ることもあり、彼女の体も目立つほど大人になって来た。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとマユミも亦マユミで、何だかわからないまま両親の吩付けを固く守って、一知が時折コッソリと泣いて頼むのも聞かずに、一度も鍵を外してやらなかったので、一知は悩ましさの余りに昼の間じゅう死に物狂いに働いて、日が暮れると同時に前後不覚に眠るより他に自ら慰める方法が無くなった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "前後不覚になりました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三浦君は、ことしの十二月、大学を卒業して、すぐに故郷へ帰り徴兵検査を受けたが、極度の近視眼のために、不覚にも丙種であった。",
              "citation": {
                "source": "律子と貞子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔いどれたならば足がふらつき思わぬ不覚をとることもあろう。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう思ふといぢらしくなつて、その文反古の上に、不覚の涙さへこぼした。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に、不覚でありました。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不覚にも私は、ずるずる幹づたいに滑り落ちた。",
              "citation": {
                "source": "猿ヶ島",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の物笑い、一期の不覚。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏を一羽ひねりつぶして煮て骨ごとばりばり食って力をつけて、その夜のうちに鰐口の家へたずねて行き、さきほどは腹が痛かったので思わぬ不覚をとったが、今度は負けぬ、庭先で一番やって見よう、と申し出た。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたい、大長者から嫁をもらったのが、わしの不覚。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔雲ふかく　山裳を曳けば〕宮沢賢治雲ふかく山裳を曳けばきみ遠く去るにかも似ん丘群に日射し萌ゆればきみ来り訪ふにも似たり",
              "citation": {
                "source": "〔雲ふかく　山裳を曳けば〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
