[
  {
    "uuid": "bfcd369c-aac5-51bf-918e-00808e3207c8",
    "entry": "不体裁",
    "reading": {
      "primary": "ふていさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
