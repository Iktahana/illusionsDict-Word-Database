[
  {
    "uuid": "9c856f96-c0ca-5a66-8bd8-115b33ec941b",
    "entry": "腹囲",
    "reading": {
      "primary": "ふくい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "girth of the abdomen",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "清潔、整然、金色の光を放ち、ふくいくたる香気が発するくらい。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柚子を見つけて一つもぐ、香気ふくいくとして身にしみる、豆腐が欲しいな。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、Ｎさんに裏の柚子をもいでもらつた、柚味噌をこしらへた、香気ふくいくとして身心さわやかになつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "石を拾ふついでに、白粉罎を拾うた、クラブ美の素といふレツテルが貼つてあつた、洗つても洗つてもふくいくとしてにほふ、なまめかしい、なやましいにほひだ、しかし酒の香ほどは好きでない、むろん嫌いではない、しばらくならば（これは印肉入にする）。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "然ニ誠になげくべき事ハながとの国に軍初り、後月より六度の戦に日本｜甚利すくなく、あきれはてたる事ハ、其長州でたゝかいたる船を江戸でしふくいたし又長州でたゝかい申候。",
              "citation": {
                "source": "手紙",
                "author": "文久三年六月二十九日　坂本乙女あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩きながら、女子美術の生徒のむらさきの袴の色の方が、ふくいくとしていると考える。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いそつゝじの花は頬をよせると、ふくいくとした匂ひをはなつて、姿に似ず何時までも匂ひが浸みて來る。",
              "citation": {
                "source": "摩周湖紀行",
                "author": "――北海道の旅より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "部落中にふくいくとしたいそつゝじの花が咲いて、淺い枯れたやうな河床から湯が吹きこぼれてゐた。",
              "citation": {
                "source": "摩周湖紀行",
                "author": "――北海道の旅より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今宵のご酒には、――」と誰かが云った、「ふくいくとした味がありますのう」「まことに――」と横のものが応じた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は薔薇と睡蓮のふくいくと香る花束。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「福音」（「ふくいん」と読む）とは、キリストによってもたらされた「さいわいな音ずれ」である。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩集をまもりつづけて来た美名が未だに、ふくいくとして匂いこぼれている所以である。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "憩っていると手の中に　やがて夜毎に新しく　一茎の薔薇がほころび初め　濃き紅に　ふくいくたるは何故だろう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "えちぜんの　くには、いまの　ふくいけん　です。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくし、これはとおもいまして、お肩をもんでおりました手をやすめて、「はゞかりながら、おさっし申しあげております」と、おぼえずへいふくいたしました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまあよいといたしまして、わたくしまでがおめしにあずかりましたので、おざしきのそとのいたじきにかしこまってへいふくいたしますと、「おゝ、坊主、おれのこえをおぼえているか」と、いきなりおことばがかゝりました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
