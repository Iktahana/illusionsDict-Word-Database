        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本のホテルでは、頼めば、あなたやあなたの連れに、船や鉄道の切符を買ってきてくれて、その上、停車場や船着き場まで見送ってくれます。",
              "citation": {
                "source": "手紙",
                "author": "一八九三年七月二二日付　チェンバレン　宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "油屋のおしゆんさんと云ふのが美しい娘だから見てゐらつしやいと云はれたが、めんどくさくて船着き場の店で用をたしてしまひました。",
              "citation": {
                "source": "大島行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新潟の花街で名うての、庄内屋の養女だった静枝までが、船着き場へ迎いに並んだほど、九女八の乗り込みは人気があったのだが、それも、会津屋おあいといった芸妓が、市川流の踊りの師匠で、市川とねと名のっていたから、同門の誼みで、華々しく迎えたのだった。",
              "citation": {
                "source": "市川九女八",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼんやりと船着き場で待つてゐる間に歩いたらば次ぎの船着き場まで行つてしまへさうなのんびりした一錢蒸氣と、どこまで讀んで行つても一體何を論じようとしてゐるのかさつぱりわからないやうな、のんびりしたエッセイと。",
              "citation": {
                "source": "春淺き日に",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "古びた船着き場の屋並のなかに白く屹立していた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある朝、作事場の下、――船着き場の川上に浮べておいた筈の筏が見えなくなっていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一船おくらした船着き場のものに向ってにぎにぎしく言葉を残し、あの風呂敷包みをたかくさしあげた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆船から汽船、木造から鉄づくりの巨船に――と、日ごとに外国型の海運に転じていた近海航路には、砂を吐きだし積みあげて、いよいよ遠浅になったイシカリ河口の船着き場は、役には立たないのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "船着き場が見つかって海賊たちが無言で岩の上に立った時、夜は月のひかりに黄ろく、くろ土はやわらかい白い光に被われて長い影が静かな青さに流れた。",
              "citation": {
                "source": "剣のうた",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの船着き場も、そうであるように、街はにぎやかでした。",
              "citation": {
                "source": "お父さんの見た人形",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと船着き場の町へ、おまえを売るつもりだったろう。",
              "citation": {
                "source": "生きた人形",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを遂に船着き場所の富江まで運び、汽船と汽車とで東京へ持ってきて、上野公園内の博物館にうえたが、その後遂に枯死してしまった。",
              "citation": {
                "source": "若き日の思い出",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小父さんが、ああして、薬の箱を負って、諸国を歩いていた時分に、もっと南の船着き場で、外国から渡ってきた、草の種子を手にいれました。",
              "citation": {
                "source": "二番めの娘",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦しい旅路を続けて、どうやら薩摩潟に着き、薩摩から鬼界ヶ島へ渡る商人船の船着き場で、この土地に見慣れぬ有王の風体を怪しむ者がいて、着ている物をはぎとられて調べられたが、元結の中に隠した姫の手紙は、うまい具合に見つからなかったので、どうやら事なきを得たのであった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所の噂や、八五郎の見聞したことを綜合すると、昨夜｜亥刻半（十一時）過ぎ、町内の夜講歸りが二三人、無駄話をし乍ら通ると、平右衞門町の路地の奧、町の者が船着き場にしてゐる形ばかりの棧橋の手前に、何やら倒れてゐる者があつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "父の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「向島の土手で、菊屋の同勢の跡をつけ廻した人間があるにしても、菊屋の同勢が船で兩國へ着いて、直ぐ引返すとは氣が付くまい」「心得た者なら、先へ廻つて兩國の船着き場で待つて、橋へ一緒に引返す術もありますよ」　八五郎はもう一つ智惠を絞りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "花見の果て",
                "note": "青空文庫"
              }
            },
            {
              "text": "調べて見ると、これが、今の南支那、臺灣から日本の沿海を荒し廻つた、拔け荷（密輸入）扱ひの一味で、和蘭人や葡萄牙人から、雜貨藥種を仕入れては日本へ持歸り、それを金に代へるかたはら、船着き場で少年少女を誘拐し、それを支那から、南洋へ連れて行つては、良い値で賣り飛ばして居たのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "和蘭カルタ",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所の噂や、八五郎の見聞きしたことを綜合すると、ゆうべ亥刻半（十一時）過ぎ、町内の夜講帰りが二三人、無駄話をしながら通ると、平右衛門町の路地の奥、町の者が船着き場にしている形ばかりの桟橋の手前に、何やら倒れている者があったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "父の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "御禁制品だから容易には手に入るまいが、これだけ持って行って、江戸中の船着き場をあさってみてくれ」　平次はお静を呼んで財布を出させると、中から小粒を一っ掴み、二三両もあろうと思うほどへ、小判を二枚添えて、ガラッ八に渡しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "和蘭カルタ",
                "note": "青空文庫"
              }
            },
            {
              "text": "調べてみると、これが、今（昭和十年当時）の南支那、台湾から日本の沿海を荒らし廻った、抜け荷（密輸入）扱いの一味で、和蘭人や葡萄牙人から、雑貨薬種を仕入れては日本へ持帰り、それを金に代えるかたわら、船着き場で少年少女を誘拐し、それを支那から、南洋へ連れて行っては、良い値で売り飛ばしていたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "和蘭カルタ",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根付き船着き場もある」　グリーンバムはポプラーからハマースミスまで直行した。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の端っこにある屋根付き船着き場に、整備され、係留してある。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "船着き場の桟橋に建てられたアーチは、歓送迎門の額をかかげたまま、緑の杉の葉は焦茶色に変わってしまった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "留さんは篠咲の船着き場の近くに、漁師の物置を改造したものであるが、一戸建の家を借りていた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏になるとね、俺の仲間のナヴェというやつといっしょにグラシエールに行って、船着き場で泳ぎ回り、オーステルリッツ橋の前でまっ裸で筏の上を駆け回り、洗濯女らをからかってやるんだ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎は船着き場だから宜しくないところが発達しているが、稲佐は殊に宜しくないところさ」　と渡辺さんは対岸を擯斥した。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
