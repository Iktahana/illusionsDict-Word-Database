          "literary": [
            {
              "text": "城壁の周囲三十支那里、磚瓦をもって畳み重ね、壁の上には半町ごとに厳しい扶壁が作られている。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長髪賊の乱の時初めて備えられた大砲が、扶壁に残ってはいるけれど、ほとんど使用に堪えないまでに青黒く砲身が錆びている。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分ほどのぼると、扶壁のついた暗い入口に行きあたった。",
              "citation": {
                "source": "泡沫の記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "国まもる寺のゆくすゑ照さなむ万代ふへきこれのともし火大正十一年歳次壬戌十一日箒庵　高橋義雄撰并書",
              "citation": {
                "source": "高橋箒庵氏の書道観",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸上にては使用者之を荷ひ、水上にては使用者是に乘る、誠に輕便なる物と云ふへきなり。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
