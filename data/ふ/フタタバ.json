    "definitions": [
      {
        "index": 1,
        "gloss": "two bunches",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "坪五円にゃ、安いとて売れるせに、やっぱし、二束三文で、買えるだけ買うといて、うまいことをやった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "材木の間から革包を取出し、難なく座敷に持運んで見ると、他の二束も同じく百円束、都合三百円の金高が入っていたのである。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "助手は根元で無造作に結へてある元結を切つて、兩耳の後ろと旋毛の邊にかけて前頭部と後頭部の髮を二束に分けた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初会社側では相場が分らぬまゝに、二束三文で売り渡した。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小兵といふ条、十二束三伏、弓はつよし、鏑は浦響くほどに長鳴して、過たず扇の要ぎは一寸ばかり置いて、ひいふつとぞ射切つたる。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売といっても家財を店先に並べて古道具屋を出す位で、それも一般家庭に役立つ物は少く、已むを得ず二束三文に売り飛ばすと、あとは商品を仕入れる余裕がないから、屑屋同様になって店を仕舞うという有様であった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "河童横町は昔河童が棲んでいたといわれ、忌われて二束三文だったそこの土地を材木屋の先代が買い取って、借家を建て、今はきびしく高い家賃も取るから金が出来て、河童は材木屋だと蔭口きかれていたが、妾が何人もいて若い生血を吸うからという意味もあるらしかった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その足許を見て二束三文で買いとってやるのだと、随分前から安二郎は此の商売をやりたがっていたのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "精巧な彫刻の施された二束の薔薇には、その蕾や花として無数の真珠と青光りのダイヤが鏤められ、その両尖端の五六枚の葉先が、何の意味もなく、その素晴らしく大きな青光りのダイヤを支えているのだった。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもほんの暫くでいやになり、二束三文で全てを賣り拂つた金で大盡遊びを續け、金が盡きると或る炭鑛の鑛夫になつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "置かば立派で神威を増し、伐らば二束三文の神林を、ことごとく一時に伐り尽させたところが、思うほどに売れず、多くは焚料とするか空しく白蟻を肥やして、基本金に何の加うることなき所多し。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "炉の上にはやはり血に染まった、長い、ふさふさした人間の灰色の髪の毛が二束ばかり、根元から引き抜かれたものらしい。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに維新後、漢医法｜癈れて一向この果売れず、黴だらけになって詮方なきところから、大阪でも東京でも辻商人にその効能を面白く弁じさせ、二束三文で売らせてもさっぱり捌けなんだと聞く。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "住居は住居で、葉子の洋行後には、両親の死後何かに尽力したという親類の某が、二束三文で譲り受ける事に親族会議で決まってしまった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、この売るということが、お話しのほかで、買い手もないといった頃、その頃の堂々たる大名、旗本の家屋敷、あるいは豪商大家の寮とか別荘とかいうものでも、いざ、売り払うとなると二束三文、貰ってもしようがないと貰い手もない時節であるから、この蠑螺堂を、壊し屋が買った値段も想像されます。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "本所五ツ目の羅漢寺のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "気味のわるいところをお目にかけてやるから、てめえのその二束三文のおしゃべり虫ゃ油で殺して、黙ってついてきな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何かの参考のために諸新聞や雑誌を切り抜いて保存して置いたもので、自分自身の書いたものは二束に過ぎないばかりか、戯曲や小説のたぐいは一つもない、すべてが随筆めいた雑文ばかりである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知でもございましょうが、明治初年の書画骨董ときたらほんとうの捨て売りで、菊池容斎や渡辺崋山の名画が一円五十銭か二円ぐらいで古道具屋の店ざらしになっている時節でしたから、歌麿も抱一上人もあったものでございません、みんな二束三文に売払ってしまったのでございます。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが今日、二束三文で買えるのです。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何かの参考のために諸新聞や雑誌を切抜いて保存しておいたもので、自分自身の書いたものは二束に過ぎないばかりか、戯曲や小説のたぐいは一つもない、すべてが随筆めいた雑文ばかりである。",
              "citation": {
                "source": "十番雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良や、京都などでは特にそれが甚かった中に、あの興福寺の塔などが二束三文で売り物に出たけれども、誰も買い手がなかったというような滑稽な話がある位です。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "神仏混淆廃止改革されたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "町人たちは、束にした割木を運んで來て、一つの穴に二束の割でおいて※るのだつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手には、持たせられた花を二束ずつ持ちあげたまま、むきな、真面目極る顔を心持うな垂れて、のろのろ歩く。",
              "citation": {
                "source": "粗末な花束",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "圭一郎は郷里の家の大きな茅葺屋根の、爐間の三十疊もあるやうなだゝつ廣い百姓家を病的に嫌つて、それを二束三文に賣り拂ひ、近代的のこ瀟洒した家に建て替へようと強請んで、その都度父をどんなに悲しませたかしれない。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "文吾は攫つた二束のじんきをば、母の直ぐ側へ投げて、忍び足に寺へ立ち戻つたが、七つ過ぎに家へ歸つて、今度は大びらに入ると、母はまだ神棚の前に坐つてゐた。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもついにはその華奢な指を伸べて、一束四銭の札が立っている葱の山を指さすと、「さすらい」の歌でもうたうような声で、「あれを二束下さいな。",
              "citation": {
                "source": "葱",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪を綺麗にまん中から割って、忘れな草の簪をさした、鼻の少し上を向いているお君さんは、クリイム色の肩掛をちょいと顋でおさえたまま、片手に二束八銭の葱を下げて立っている。",
              "citation": {
                "source": "葱",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
