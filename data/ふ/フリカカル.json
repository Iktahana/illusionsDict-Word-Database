        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "むかし戦国時代、飛騨の国司、姉小路秀綱卿が、いくさに負けて、夫人や姫君と共に、落ちのびるところを、追手に殺されたという、執念の谷に、執念ぶかい焼岳の煙が靡き、灰が降りかかるのである。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "木屑は極めて細かく、極めて軽く、材木の一処から湧くようになって、肩にも胸にも膝の上にも降りかかる。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "優しい柔かな声が、思いなしか、ちらちらと雪の降りかかるようで、再び悚然として息を引く。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い夕立の降りかかる山、川、かなしく死ねるように思われた。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡す青葉、今日しとしと、窓の緑に降りかかる雨の中を、雲は白鷺の飛ぶごとく、ちらちらと来ては山の腹を後に走る。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "温めて上げるわ」　紀久子は敬二郎の死骸を抱いて、降りかかる火の粉を浴びながらその窓の下に行って叫んだ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ男の身体に外傷はなく、顔の歪んだ形相は、降りかかるおのれの定めを直前に悟ったものと見える。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にこれは直接に自分の身の上に降りかかる大事件であるので、かれは無道の父に対するよりも、更に強い不満を感じた。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その紙の糸が寮長に降りかかる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ堪まらなくなって、お客人は寝床からそっとひと足降りかかると、鬼もまた、棺の中からひと足踏み出す。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "バリバリと何ものとも知れず降りかかる。",
              "citation": {
                "source": "放送された遺言",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "欅の古樹に降りかかる雨の脚、それが実に長く、限りない空から限りなく降っているとしか思われない。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を洗おうとして雨戸を一枚あけると、縁側に置いた洋燈がくっきりと闇を照らして、ぬれた南天の葉に雨の降りかかるのが光って見えた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はどよめいている唐人どもを掻き退けて、兜の上に降りかかる火の粉の雨をくぐりながら、台の上へまっしぐらに駈けあがって行った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "物音とてはしんしんと耳の痛む静けさと、時には娯楽室からかすかに上るミヌエットと、患者の咳と、花壇の中で花瓣の上に降りかかる忍びやかな噴水の音ぐらいにすぎなかった。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういうことでもこの淵に障るとその家の屋根に雨が降りかかるので、これはその美しかった娘のわが屋へのなにかの心遣いであろうというのである。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "」かう云つて、昇は目を轉じ、自分の庭の松や萩に雪のおほびらがどん／＼降りかかるのを見てゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼は身に降りかかるものに対して身構えるように、じっと頑な気持で畳の上に蹲っていた。",
              "citation": {
                "source": "冬日記",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨は容赦なしに降りかかる。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は不愉快で、この少将のために姫君の身に災難も降りかかることになったと、だれよりも愛する子のことであったから、反感ばかりがその男に持たれて、気を入れた世話などはできなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その白く抜けた額に、軽がると降りかかるウエーヴされた断髪は、まるで海草のように生々しく、うつくしく見えた。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の帳が降りかかると、再びその姿は見えはじめ、湖面に影像を落して、その後ろには陰影が顫へながらついて行く。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たい霜も降る、しぐれもわびしく降りかかる。",
              "citation": {
                "source": "一世お鯉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "華奢な街家を外に見て、地にへばりつく憂き身には、風も邪慳に吹きつける、雨もはげしく降りかかる。",
              "citation": {
                "source": "妄動",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯れた蓬の細茎を風の吹くよな三味線に曲弾の音のはらはらと螽斯の雨が降りかかる。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母がこと、亡き姉のこと、伯母がこと、あれや、其れ、とりとめもない事ながら、片時は黄金の雨が降りかかる。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、私には何となく、挙動不審の影があらわれて、あらぬ疑いさえ被り、とんでもない大難が、この身にふりかかるかもわからない。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はつと思つて空を凝視める、光が蜂蜜の如にキラキラとふりかかる。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の枝のこずえの葉は、落ちて中の枝にかかり、中の枝の落ちた葉は下の枝にふりかかる。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、それが人にふりかかると、それがみんな虱になって取り付くのである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
