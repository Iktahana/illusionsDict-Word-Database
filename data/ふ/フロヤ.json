        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "下宿から風呂屋までは一町に足らぬ。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京市民の顔の緊張がやや弛んで見える場所がある、それは外でもない風呂屋である。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　防空演習の夜にとうとうおしまいまで燈火を消さなかったのが近所の風呂屋である。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も電燈を消さなかったのは風呂屋の主人であるが、それを消させなかったのは浴客である。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂屋の主人は意外な機会に変った英雄主義を発揮して見せた訳である。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう云へば、大概の阿片窟には阿片吸飮を世話する若い女がゐること、日本の徳川時代の或る種の風呂屋の湯女の如く無論その正體は賣笑婦なのだ。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅のすぐ向う側に風呂屋が建つことになって、昨日から取毀しが始まった。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂屋の隣りの天ぷら屋はまだ起きていた。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早く隣りの風呂屋で風呂の栓を打ちこむ音も乾いた響きをたてゝ、人々の軟らかな夢をゆり動かした。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝からぶつッとして居た力三は、夕方になつてそつと姉を風呂屋と店との小路に呼び込んだ。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬屋の隣に風呂屋があつた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂屋の隣に床屋があつた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでは、まるで、風呂屋のペンキ画である。",
              "citation": {
                "source": "富士に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、まるで、風呂屋のペンキ画だ。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八橋一面の杜若は、風呂屋へ進上の祝だろう。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば、本町の風呂屋ぢや、湯が沸いた、湯がわいた、と此のぐあひなり。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまはんも知ってる通り、うちは子供が一人も出けへんし、それにまた、わしもそうやが、うちの家内と来たら、よその子供が抱きとうて、うちに風呂があるのに、わざわざ風呂屋へ行きよるくらい子供が好きやし、まえまえから、養子を貰う肚をきめてたんや。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「近所の風呂屋で下足番してました」　ありていに答えた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂屋も代替りをしなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　宅の前に風呂屋ができて、いろいろな迷惑を感ずることがある。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一には、宅へ始めて尋ねて来る人にはこの風呂屋の高い煙突を目当てにして来るように教えるとわかりが早い。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三には、この風呂屋ができてから門前に近く新たに消火栓が設けられた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして室内は余り大きくなかつたが、明るい一室を、或る風呂屋の二階にみつけた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮方より人に呼ばれける（風呂屋女に仇名を付けて猿というは垢をかくという意となり）とあり。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "正徳元年板｜其碩の『傾城禁短気』に「この津の橋々に隠れなき名題の呂州（風呂屋女を指す）猿女上人」、一向宗の顕如に猿をいいかけたり。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "十口坊、先日風呂屋にて卒倒したりとて、一滴も口にせず。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "六三郎は或る出入り場の仕事から帰って来て、それから近所の風呂屋へ行った。",
              "citation": {
                "source": "心中浪華の春雨",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "濡れた手拭をさげて風呂屋の門を出るころには、細かい雨がひたいにはらはらと落ちて来た。",
              "citation": {
                "source": "心中浪華の春雨",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　日清戦争の頃から湯屋を風呂屋という人がだんだんに殖えて来たのを見ても、東京の湯屋の変遷が窺い知られる。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
