      {
        "index": 1,
        "gloss": "elegant appreciation of nature through artistic pursuits such as poetry, painting and calligraphy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
