    "definitions": [
      {
        "index": 1,
        "gloss": "entertaining people by serving tea (esp. in the Obaku school of Zen)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "先日、京都の普茶料理を喰べながら、この逸話を思い出した。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "普茶料理に昔のおもかげがある。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄檗普茶のその謂われから入る。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの裁判の判決を聞いて、幸徳は管野とともに、新橋の富貴亭といふ普茶料理で、靜かな別離の宴を催してくれました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は坊主の学校で坊主の学問を学んだから、そのころ坊主の食べ物に興味をもって、オーバクの普茶料理などというものをわざわざ京都や宇治へ食べに行ったりした。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "地圖でみると、ちやうど普茶料理の雲水の眞東にあたる。",
              "citation": {
                "source": "露伴忌",
                "author": "心猿",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程、万福寺の斎堂（食堂）は堂々たるものであり、その普茶料理は天下に名高いものである。",
              "citation": {
                "source": "日本文化私観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら普茶料理が坊主めいて宜かろうと思って、世話人の僕が計らった。",
              "citation": {
                "source": "妻の秘密筥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅葉と目こすりなます普茶料理に見せた健啖　紅葉山人の逸話は、その一党の小波、水蔭の諸兄の健筆で、細大すでに世に知らるるにもかかわらず、そのお余りを少々。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十二年の四、五月頃、白金瑞聖寺に普茶料理の会があって紅葉氏も出席、例の話上手に一座の中心となって大いに気勢を挙げた。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼すぎ、女房・清と東も共に、川口・三益と子供を誘ひ、一休庵で久々普茶料理を食ったが、味が落ちて、たんのうせず。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄バク普茶料理の一休庵では、酒を磐若湯といふ、そこでビールは、磐若サイダーとでも言ふかね、とからかふと給仕女の曰く、「泡磐若」と申しますと来たので大笑ひ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二夫婦で、一休庵へ行き、久々で普茶料理。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "普茶料理、今日は二人前食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一休庵へ、普茶料理を食ひに行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二時近く一休庵へ普茶料理を食ひに出かける。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "普茶料理、僕だけ二人前とって平げる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "花井は、沼津行きとやらで出発し、残る五人で、一休庵迄出かけ、普茶料理を食べる、例によって僕だけ二人前食べる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "普茶料理も一昨日の今日では一向うまくなかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "久々普茶料理を二人前食った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
