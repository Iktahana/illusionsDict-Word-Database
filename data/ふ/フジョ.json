[
  {
    "uuid": "60907449-387e-523f-b5c3-d9fde620399b",
    "entry": "婦女",
    "reading": {
      "primary": "ふじょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
