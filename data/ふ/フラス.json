[
  {
    "uuid": "e4a35afc-b224-5e7e-af7d-a3f183e1b03e",
    "entry": "降らす",
    "reading": {
      "primary": "ふらす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
