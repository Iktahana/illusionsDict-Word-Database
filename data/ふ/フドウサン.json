[
  {
    "uuid": "88fed6bc-4b5b-5ce1-95dd-119d52871df5",
    "entry": "不動産",
    "reading": {
      "primary": "ふどうさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
