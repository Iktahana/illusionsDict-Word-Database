    "definitions": [
      {
        "index": 1,
        "gloss": "I'll write again soon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
