        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この親不孝者どもが！",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみの　えゝ、卑怯者……　不孝者……。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "不孝者をどうぞお許し下さい。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いたる侍　不孝者奴！",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳吉の命が助かったことだけがせめてもの慰めだったが、しかし、親不孝者だという気持は矢張りチクチク胸を刺して来た。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかして切り抜けたい、独になりたい、そればつかりに俺は思はず血で血を洗ふやうな残虐な暴君にもなつた、罪人にもなつた、親不孝者にもなつた。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを苦に病んで母親も死ぬる……というような事で、親不孝者の標本は私で御座います。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "親不孝者と見る人々の目を背中に感じながら、白い布を取って今更の死水を唇につけるなど、蝶子は勢一杯に振舞った。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "佃島には先生、不孝者を持って多いこと苦労をする婆さんが一人ね、弁天様の傍に吝な掛茶屋を出して細々と暮しています、子に肖ない恐しい堅気なんで。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばかばかしい、てめいのしてる事が大の淫奔じゃねいか、親不孝者めが、そのままにしちゃおけねい」　とにかく明日の事という事でこの夜はおしまいになった。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく親は有難い、お前のような不孝者にも掘り出し物をさせてくれるとからかわれて、庄太はあたまを掻いて帰った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして親不孝のイソクソキには『お前の不孝者には、一生涯腐つた木を突ついて、虫をお喰べなさい。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して人の子たる道ではない、さぞ不孝者と阿父さん始阿母さんもさう思つてお在でせう」「さうは思ひはしないよ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくしも不孝者で、若い時には阿母をさんざん泣かせましたよ」　それが半七の懺悔であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、不孝ならば先ず不孝として、その不孝者には誰がしたか。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "『お前は父親を罪人にした不孝者だ。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分に母を慕ふが如き心の動くさへ私は、異様な冷汗を絞らるゝ思ひであり、決して当り前の口を利いたこともない白々しさで、もう三四年あまりも親の姿に接する折もなく、不孝者のそしりさへ平気で享け流してゐるにも係はらず、やはり心の一隅には絶ち難い血のつながりから、そんなにも尤もらしい夢などを見るものか！",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはそんな不孝者になりたくはございません。",
              "citation": {
                "source": "俳諧師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この寒さ不孝者｜奴が居りどころ　といった、愛の涙もほしいのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "不孝者奴と罵りつつ、もうないぞよと意見しつつ、なおもわが子をば、慈愛の懐に抱いてくれる親の情けは、否定しつつ、肯定しているのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "おきん　ええ、この不孝者めが！",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ、この親不孝者を、先へ突いて殺して下されませ。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめてもの腹｜癒せに、不孝者が、磔柱の上で、苦しむのを見せて下さりませ。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一字書くと、松岡先生の顔が浮び、一行すゝむと怖ろしい生徒監の姿が見えたり、そして自分は母に対して何といふ酷い不孝者なのだらう、などゝ思つて情けなくなつたり、無味な虚文は立所に行き詰つたりしながら、しどろもどろに、苦し紛れに背すじに汗を流して書いたのである。",
              "citation": {
                "source": "貧しき日録",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＧとＫのことを、先程一寸誌したが、中学の頃のあの自称正義党の連中は、長じて揃ひも揃つて親不孝者になつたが、今では大抵何かに収つた。",
              "citation": {
                "source": "貧しき日録",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「この親不孝者奴！",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の第十七回忌、ひとりさびしく読経し回向する、私はほんたうに不孝者であることを痛感した。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏前にかしこまつて、焼香諷経、母よ、不孝者を赦して下さい。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はまた、老いた父親が自分の身代わりとなって死ぬことを望んだ親不孝者です。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
