        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "酔つた視線の中の敵とは、彼の足の脹脛を目がけて土埃りをあげ、頸毛をふくらませて突進してくる一羽の牝鶏であつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "血を見ると、腰から脹脛にかけての神經がざわざわして來るのが駿介の平常だつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "有本老人はじめ「あツ、痛い、先生にはかなはん」と、後につゞく二三人もばた／＼負けて脹脛をさすつてゐるのを、私とＡさんとは上框に腰掛けて見てゐた。",
              "citation": {
                "source": "足相撲",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "畜生犬め、それと見るなり、初めはおれの脹脛に咬みつきをつたが、紙束をおれに取りあげられてしまつたと感づくと、いやに哀れつぽい金切聲をたてたり、おべつかを使つたりしはじめたけれど、おれは構はず、『へん、お氣の毒さま、あばよ！",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、友染の湯もじの下から、細い脹脛の折れかゞみの邊りまでを見せて、土間から直ぐに納戸への近道をして、高い上り口を一跨ぎにした。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二弾は脹脛の筋肉を少し切り裂いて引違えただけだった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "八幡の阪で、誰やら脹脛を後から窃と押す者がある。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬籠の駅長時代には百里の道を平気で踏んだほどの健脚とも思われないような、変わり果てた父の脹脛が、その時半蔵の手に触れた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とそのうちで殊に脹脛の露出したのが我らにバットとボールの借用を申込んだ。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我らは本場仕込みのバッチングを拝見することを無上の光栄として早速それを手渡しすると我らからそれを受取ったその脹脛の露出した人は、それを他の一人の人の前に持って行った。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "にんじんは、蒼ざめ、腕を組み、そして首を縮め、もう腰のへんが熱く、脹脛があらかじめひりひり痛い。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の目は既に美保子が縁側に上る時、その脹脛に白い力瘤が入るのを知っている。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身にしても、少し道が登りになると脚がだるくなつて来るし、又いそいで歩くやうな時は脹脛が硬ばつてしまふのであるから、車馬の通行の劇しい所を歩く時などは危険だと感じるのである。",
              "citation": {
                "source": "椿子物語",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "足バカリジャナイ、コヽノ脹脛ダッテフックラシタ肉ガナクナッチマッテ、労働者ノ脚ノヨウナグリ／＼ガ出来ルワ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日ハ唇ダケデナクッテモイヽ、舌ヲ着ケテモイヽ」予ハ七月二十八日ト同ジ姿勢デ、彼女ノ脹脛ノ同ジ位置ヲ唇デ吸ッタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソノマヽズル／＼ト脹脛カラ踵マデ下リテ行ク。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "重イノハ脹脛ヤ踝ノ上アタリモヒドイガ、足ノ裏ガ一番ヒドイ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふくらはぎや腕のふくらみの處は老人のそれのやうにたるんで、觸つてみるとよごれた皮膚がまるで乾干びた木の葉のやうにかさかさしてゐた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つめたい血が、せわしくかわす、ふくらはぎに、ぽた／＼流れかかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり暑いので耳たぶへ水をつけたり、ぬれ手ぬぐいで臑や、ふくらはぎや、足のうらを冷却したりする安直な納涼法の研究をしたこともあった。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、ご自由に――」　ひどく鉄火なことばつきで、わるびれもせずにのっそりと、白いふくらはぎを見せながら上がってきたものは、三十がらみの、見るからに油ぎった中｜年増でありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、その赤色にまつわりからんで、雪なす羽二重はだのむっちりとしたふくらはぎが、神秘の殿堂はそこにあるといわぬばかりに、ちらりとさしのぞいたのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "はゝあ、あの犬をぢやらしたのは、きつと、ミスのふくらはぎです。",
              "citation": {
                "source": "青い顔かけの勇士",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちんのいときり歯は、ミスのふくらはぎとおもふあたりへ、がくりとかみつきました。",
              "citation": {
                "source": "青い顔かけの勇士",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一は、ふくらはぎが、猛烈にかゆいのに気がついた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "バカ、死んじゃえ、と知子が高志のふくらはぎでも蹴ったらしく、カウンターの下の板で大きな音がし、高志が顔をしかめて脚に手をやる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "またまた飛びおりた三吉猿、ふくらはぎを引っかいた。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たくりあげた裾の下にあらはにのぞかれる兩のふくらはぎには靜脈瘤が青くふくらみ、蛇のやうにまがりくねつてゐた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふくらはぎの半分を包むブーツは、上部にふかふかした褐色の毛皮を施されていて、風采から醸し出される強引な豪華さを完璧なものにしていた。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顔は何処か正月に見た獅子舞いの獅子の顔に似ているところもあったが、吉を見て笑う時の頬の肉や殊に鼻のふくらはぎまでが、人間のようにびくびくと動いていた。",
              "citation": {
                "source": "笑われた子",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
