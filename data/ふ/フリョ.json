[
  {
    "uuid": "2b2e9d29-69bc-59a3-9b30-c8492d63a26c",
    "entry": "不慮",
    "reading": {
      "primary": "ふりょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unforeseen",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大きいつらをしやがつて、いつたい、なんだと思つてゐるんだ等と、不慮の攻撃を受ける事もあるものである。",
              "citation": {
                "source": "容貌",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれこれするうちに翌年の春になり、六蔵の身の上に不慮の災難が起こりました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そういう事もありませんが、なにしろ不慮の災難だからあきらめるよりいたしかたがありませんよ……」「けれど、なぜ鳥のまねなんぞしたのでございましょう。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれが今度の不慮の死に関する一つの暗示ででもあったような気がしてならない。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年経ち、お君が二十四、豹一が六つの年の暮、金助は不慮の災難であっけなく死んでしまった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その父が、あんな不慮の心臓病とやらで、突然おなくなりになったものですから、あの子は、もう、どうしていいか、わからなくなったのでしょう。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きいつらをしやがって、いったい、なんだと思っているんだ等と、不慮の攻撃を受ける事もあるものである。",
              "citation": {
                "source": "容貌",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、実に不慮の事件が突発した。",
              "citation": {
                "source": "鉄面皮",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙って聞いているうちに、自分の肩にだんだん不慮の責任が覆いかぶさって来るようで、不安なやら、不愉快なやら、たまらぬのである。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年経ち、お君が二十四、子供が六つの年の暮、金助は不慮の災難であっけなく死んでしまった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は四十五、六歳の、いかにも質朴らしい男で、日に焼けている頬をいよいよ赧らめながら、この不慮の出来事に就いて自分はまったくなんにも知らないと吶りながらに釈明した。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御辺の行跡何とも無分別候、行末何になるべき覚悟に哉……弓馬は男の業也器用も不器用も不入候可稽古事也、国を治む文武二道なくては更に叶べからず候、……其上君子｜重ずんば則威あらず義元事は不慮の為進退軽々しき心持候。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫れ天馬は大逆不慮の際、急を遠国に報ずる為め聊か用うるに足る丈である。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　五年経ち、お君が二十四、子供が六つの年の暮、金助は不慮の災難であっけなく死んでしまった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのいたましい変事の記憶がまだ世人の記憶に新しいのに、今度はまた新しい皇帝が皇后とスイッツルの湖畔をドライブしていたとき、不慮の事故を起こして、そのために若く美しいアストリード皇后陛下はその場で崩御され皇帝も負傷され、ただうしろの座席に乗っかっていた運転手だけが不思議にかすり傷一つ負わなかった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが此不慮此不幸の全範圍を感ぜしは、酒店の人の罵り噪ぎつゝ走り寄りアヌンチヤタと媼との我前に來るを見し時なりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "よって蜀山も彼処へゆき、その無事に火を避けしや否をとうに、主答えて、おのおの無事なり、さわれ不慮なる急火にして、家財は大半失いぬ、そはとまれかくもあれ、店にありつる帳を焼きつ。",
              "citation": {
                "source": "失うた帳面を記憶力で書き復した人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年の冬不慮に出火ありて、かの家城も類火にあい、難儀の中の小屋掛けへ、道春見舞に来たられ、（中略）まずはおのおの怪我もせず立ち退かるること珍重なり、して財宝は残りしか。",
              "citation": {
                "source": "失うた帳面を記憶力で書き復した人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "みじかい冬の日がもう暮れかかる頃になって、其月の弟子たちがだんだんに寄って来たが、かれらは不慮の出来事におどろき呆れているばかりで、どの人の口からも何かの手がかりになるような新らしい材料をあたえてくれなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "附添さへある賓の身にして、賤きものに遇はるる手代｜風情と、しかもその邸内の径に相見て、万一不慮の事などあらば、我等夫婦は抑や幾許り恥辱を受くるならん。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の妻は又、やがてはかかる不慮の事の夫の身にも出で来るべきを思過して、若しさるべからんには如何にか為べき、この悲しさ、この口惜しさ、この心細さにては止まじと思ふに就けて、空可恐く胸の打騒ぐを禁め得ず。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "如此き輩を出入せしむる鴫沢の家は、終に不慮の禍を招くに至らんも知るべからざるを、と彼は心中｜遽に懼を生じて、さては彼の恨深く言を容れざるを幸に、今日は一先立還りて、尚ほ一層の探索と一番の熟考とを遂げて後、来る可くは再び来らんも晩からず、と失望の裏別に幾分の得るところあるを私に喜べり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は三日の後には退院すべき手筈なりければ、今は全く癒えて務を執るをも妨げざれど、事の極めて不慮なると、急激なると、瑣小ならざるとに心惑のみせられて、病後の身を以てこれに当らんはいと苦かりけるを、尽瘁して万端を処理しつつ、ひたすら直道の帰京を待てり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何とも不慮な事で、申上げやうもございません」「はい。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "責は勿論記者にあることで何ともお詫びの申しようもありませんが、不慮のことゝていたしかたなく、どうぞお許し下さい。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、王は何か極めて不慮な出来事に出会つてその驚愕の余りに、肺と肝との位置が転倒して、その日上夜間断なく泣き暮して居たが為に、肝の下に位する涙袋なるものが枯れてしまつたのである。",
              "citation": {
                "source": "闘戦勝仏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だん／＼蝋色に、白んで行く、不幸な青年の面をじっと見詰めていると、信一郎の心も、青年の不慮の横死を悼む心で一杯になって、ほた／＼と、涙が流れて止まらなかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、白昼の、かほど、けざやかな太陽の下の遭遇でなかったならば、彼はそれを不慮の死を遂げた青年の亡霊と思い過ったかも知れなかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕なども、兄弟の愛などは、今までそんなに感じなかったのですが、兄を不慮に失ってから、肉親と云うものの尊さが、分ったように思うのです。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょうひょうふりょう、りょうふりょう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
