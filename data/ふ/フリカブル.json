[
  {
    "uuid": "b1c01023-c4ec-504c-a8ff-1500f8f017f4",
    "entry": "振りかぶる",
    "reading": {
      "primary": "ふりかぶる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-自動詞"
