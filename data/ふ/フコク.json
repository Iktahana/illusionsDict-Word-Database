    "definitions": [
      {
        "index": 1,
        "gloss": "edict",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところが、丁度その豚の、殺される前の月になって、一つの布告がその国の、王から発令されていた。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは家畜｜撲殺同意調印法といい、誰でも、家畜を殺そうというものは、その家畜から死亡｜承諾書を受け取ること、又その承諾証書には家畜の調印を要すると、こう云う布告だったのだ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「帝国・米英に宣戦を布告す」という活字の大きいこと。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "国中の人間はこのお布告を見ると大騒ぎをして、お祝いの支度を始めました。",
              "citation": {
                "source": "犬の王様",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵より投げたる一個の石は宣戦の布告である。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "本日これから、この広間に群臣を集めて重大の布告をいたします。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうの布告の式には、王妃も列席してないと、具合がわるい。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下に布告して、朕が意を知らしめよ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親興の妻子の居処を知らして来た者には、褒美の金をやる」　という布告をだした。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく新しい道具を売り始めた堀井父子にとって、創業直後の八月一日に宣戦が布告された日清戦争は、強い追い風となりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ホームコンピューター』の虚妄を現実に変えるＡＭＤ３８６互換チップの宣戦布告『Ｔｈｅ　ＣＯＭＰＵＴＥＲ』から「Ｗｉｎｄｏｗｓ３・０は流行るか」という、いまさらなにをとぼけているかといいたくなる座談会のお座敷がかかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてまた布告書等に奉勅云々の語を付し、畏れ多くも　天皇陛下に罪状を附せんとするは、そもまた何事ぞや。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはある意味の宣戦布告に近かった。",
              "citation": {
                "source": "青木の出京",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "細川家の陣中へも、総攻めの布告が来た。",
              "citation": {
                "source": "恩を返す話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユゴオの『クロムウエル』の序文は、この文学革命の烽火であり、宣戦の布告であつた。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "村同志の人々も皆その婚礼の日が来るのを楽しみにして今か今かと待ちかねていましたが、最早その日まで三週間しかないという時になって、大変な御布告が藍丸王の御言葉だといってこの湖の岸に伝わりました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その御布告はこうでした。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰でもよい、王様のためにこの鏡を取りに行く者は無いか」　この御布告を、美留藻と香潮が住んでいる村の間の、丁度中程に在る魚市場で、役人が大勢の人々を集めて申し渡した時に真先に――「それは妾が取って参りましょう」　と願い出たものは誰あろう、水潜りにかけては村一番と評判の美留藻でした。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを聞いた役人は躍り上らんばかりに喜んで、今までこの湖のふちをぐるりと布告てまわったが、まだ二人のような勇ましい青年と少女は一人も居なかったと賞め千切りましたが、とにかくそれでは今から直ぐに支度をして、明日にも取りに行くようにと申し渡して、やがて都の方へ帰りました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからも一ツは国中に布告を出して、「今度藍丸王様がお妃を御迎え遊ばすに就ては、国中で一番の美しい利口な女を御撰みになる事になった。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから第二の御布告は銅の板に書きまして、馬乗の上手な四人の兵士に渡して、四方の国々の王宮へ即座に出発させました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが紅矢はこの間から父の用事で、北の加美足国へ参いっておりましたが、今日帰って参りますと、今朝王様があのような御布告をお出し遊ばして、他の国々からお后をお選みになるという事を聞いて、妹思いの事で御座いますから、夢かとばかり驚きまして、直ぐに王様の御布告が本当かどうか伺いに参いるので御座います。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしその濃紅姫とやらを后に為たいと思うならば、最前国中に布告さした通りに、今日から一週間の後に、国々の女と一所に宮中へ差し出せ。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この度の王様の御布告を家来の蟹奴から承りまして、御恥かしながら海の底から、はるばると御目見得に参ったもので御座います。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論それは公式のものではないが、当局の達示によって自警団員が夜間婦人の外出を禁ずる旨を布告てまわった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その筋の宣伝や布告が日に増し民衆的になり、言文一致に近づいて、債券のまき上げ方？",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昔、江戸市中のお布告だの掟書なぞいうものは、みんな人民にわかり易い文句ばかりで書いてあった。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治維新後、新政府の権威を見せるために、又は人民を煙に捲いてドンドン改革をして行くためには、法令でも、布告でも、何でも、漢語と片仮名で塗りかためて人民の前につき立てて、内幕をのぞかれないようにする必要があった。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ふと私は、あの地震の時に、横浜では、警察でも市役所でも戸籍の原簿が焼けてしまったので、その管下の人はすぐ戸籍をとどけ出るようにという布告が出ているということをききこんだのでございます。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
