    "definitions": [
      {
        "index": 1,
        "gloss": "happiness and good fortune",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
