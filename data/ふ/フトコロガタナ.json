        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昔の女は、常に懐刀を離さずに、それで自分の操を守ったものだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、イスラエルのお町、手文庫をあけると懐刀を出した。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葵散らしの懐刀である。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の女は、常に懐刀を離さずに、それで自分の操を守つたものだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "農商務大臣と製鉄所長官の首を一度に絞めて、前内閣を引っくり返した堅田検事総長から、懐刀と頼まれている斎木検事正のお耳に、この話が這入ったとなると問題だろう。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "用意をして来た懐刀を、帯へ差したまま柄を握り、見現わされたら女ながらも、切り捲くってやろうと構えている。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小褄を取ると嗜の懐刀、懐中へ入れるのも忙しく、後に続いて走り出た。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はい、それではこの妾も」云うと同時に娘の民弥はグッと懐中へ手を入れたが、キラリと抜いたは懐刀である。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、一方この時分、民弥は懐刀を振りかざし、玄女の行手へ突っ立っていた。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人形をお返し下さいまし」　言葉は優しいが態度は強く、厭と云ったら用捨しない、懐刀で一｜揮、片付けてやろうと、決心しながら詰め寄せた。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……オヤオヤ見受ければまだお若い、無邪気な娘さんでありながら、物騒千万懐刀などを、振り冠って何となされるやら、ほほうそれでは腕ずくで、人形を取ろうとなされるので？",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち長目の懐刀である。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち玄女が懐刀を抜き、同じく頭上へ振り冠ったのである。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "血を流すのは厭だけれど、切り散らさなければならないだろう」　そこで一躍右へ飛び、ヒューッと懐刀を打ち振った。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐刀をまたもや一揮した。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッ、ハッ、ハッと大息を吐き、疲労て萎る両足を、グッと構えて姿勢を正し、振り冠った懐刀月光に顫わせ、ムーッと香具師共を睨み付けた。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右近丸の持った血染めの太刀、民弥の持った血染めの懐刀、走るに連れて月光を弾き、凄じくキラキラ反射する。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘八を向うへ突き倒し、その手を帯へ差し入れたが、抜いて握ったは嗜みの懐刀、振り冠ると凜々しく叱咤した。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　壁を背後にピッタリと背負い、褄を片手にキリキリと取り上げ、振り冠った懐刀に波を打たせ、荒くれ男の十数人を、睨んだ様子というものは、若くて美しい娘だけに、凄くもあれば立派でもあった。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず懐刀を奪い取られ、続いて足を攫われた。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「来やがれ来やがれ、叩っ切って見せる」　そこで懐刀を振り廻したが、疲労てはいるし敵は大勢、到底勝目はなさそうであった。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、一方では猿若少年が、二三人の人買を相手にして、懐刀を縦横に揮っている。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御弊に仕込まれた懐刀らしい。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐刀仕込みの御弊である。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしなみの懐刀を握りしめたところの、廻国風の娘であった。",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もしものことがあろうものなら、潔よく自害をいたします」　九燿の星の紋所の付いた、懐刀をお紅は秋安に示して、そういうことを云ったりした。",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「九燿の紋の付いた懐刀だ！",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐刀で自害をしたのである。",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日まで殿下のご寵愛を、一人占めにして占めていられた方だ、そのお方が懐刀で自害された。",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「織江殿、どうやら田沼の手の者が駕籠につきましたようにござりますぞ」「はい」　と織江は駕籠の中で、帰る時特に冬次郎から、手渡された長目の懐刀の柄を、砕かんばかりに握りしめたが、「いずれそうあろうと存じました。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
