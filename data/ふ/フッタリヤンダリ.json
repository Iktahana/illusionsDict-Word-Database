        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蕭条とした秋雨が降ったり止んだりしている夕ぐれだった。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨は降ったり止んだり、折々日がぱっと照り出すかと思うと、また急に雲が重く重って来たりする。",
              "citation": {
                "source": "木曾御嶽の両面",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "百日紅の花の上に、雨が降ったり止んだりしている。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日もやはり雨が降ったり止んだりして蒸暑い。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど五月雨が降ったり止んだりいつもうっとうしい空のころで、夜になるとまっくらで、月も星も見えません。",
              "citation": {
                "source": "鵺",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ステッキ一本の余は、降ったり止んだりする危げな空を眺め行く。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋雨の降ったり止んだり淋しい日であった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　九月になると、すこし荒れ模様の雨が何度となく降ったり止んだりしていたが、そのうちにそれは殆んど小止みなしに降り続き出した。",
              "citation": {
                "source": "風立ちぬ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "降ったり止んだりする雨は、かなり激しく往還を荒して幾条もの小流れが道の左右に付いて、中央に二本通っている車の轍の跡の溝には、茶色の泥水がゴッゴッと云って流れて行った。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜から降ったり止んだりしていた雨が、この時分になって、だんだん大降りになってきた。",
              "citation": {
                "source": "大菩薩峠",
                "author": "竜神の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "二百二十日に当る翌十日も、雨はまだ余勢を見せて降ったり止んだりしていた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふったりやんだりしている。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
