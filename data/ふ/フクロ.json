        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "停車場のガードをくぐつて坂を登ると、暗い煤ぼけた古道具や、安物の足袋など店に竝べた、昔の宿場そつくりの町がある。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまの背広服のほかに、学生服を着たり、菜葉服を着たり、あるときには角帯に白足袋という恰好で私を狼狽させ赤面させた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の目算では、身丈は五尺七寸、体重は十五貫、足袋は十一文、年齢は断じて三十まえだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "和服に、絹の白手袋、銀のにぎりのステツキである。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前日、新宿の百貨店へ行って結納のおきまりの品々一式を買い求め、帰りに本屋へ立寄って礼法全書を覗いて、結納の礼式、口上などを調べて、さて、当日は袴をはき、紋附羽織と白｜足袋は風呂敷に包んで持って家を出た。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小坂家の玄関に於いて颯っと羽織を着換え、紺足袋をすらりと脱ぎ捨て白足袋をきちんと履いて水際立ったお使者振りを示そうという魂胆であったが、これは完全に失敗した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ったまま、紺足袋を脱いで、白足袋にはき換えようとしたのだが、足が汗ばんでいるので、するりとはいらぬ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うむ、とりきんで足袋を引っぱったら、私はからだの重心を失い、醜くよろめいた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分、十分、私は足袋と悪戦苦闘を続けた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は足袋のために、もうへとへとであった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思慮分別の深い結納のお使者は、ひどく酔いました、これは、ひどく酔いました、と言いながら、紋附羽織と白足袋をまた風呂敷に包んで持って、どうやら無事に、会津藩士の邸宅から脱れ出ることが出来たのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今な奥さん、坊ちやが隣り下駄屋から――あれ何言ふか、野球手袋な、あれお主婦さに出して貰ふ彼方駆けたで。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "足袋裸足で痛痛しい、胸が開張けて、雪の肌が白百合の匂ひ、島田の根が外れて忙しい呼吸である。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸袋のすぐ横に、便所の窓の磨硝子から朧な光のさすのに眼をうつすと、痩せたやもりが一疋、雨に迷う蚊を吸うとてか、窓の片側に黒いくの字を画いていた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気立ての優しいよい娘であったが、可哀相にお袋が邪慳で、せっかく夫婦仲のよかった養子を離縁した。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "清らかになまめかしい白足袋も一足落ちている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不折の家は二つ並んだ袋町の一方のいちばん奥にあって「上根岸四十番不折」としてある。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の袋町に○印をして「浅井」とあるのは浅井｜忠氏の家であろう。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この袋町への入口の両脇に「ユヤ」「床屋」としてある。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて状袋にでも入れて「正岡子規自筆根岸地図」とでも誌しておかないと自分が死んだあとでは、紙屑になってしまうだろうと思う。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰ってから現在の東京の地図を出して上根岸の部分を物色したが、図が不正確なせいか鶯横町も分らないし、子規自筆地図にある二つの袋町も見えない。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼瞼に蔽いかかって来る氷袋を直しながら、障子のガラス越しに小春の空を見る。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し眠りたいと思うて寝返りをすると、額の氷袋の氷がカチカチと鳴って袋は額をはなれる。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は氷袋を気にして時々さわってみるが、始終無言である。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしい闇、恐ろしい命と身を悶えた拍子に、氷袋がすべって眼がさめた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またいふ、東郷大將とふたり外遊の折、乃木、かならずその國一のホテルに宿り、手袋、煙草、すべて一流のものをのみ用ゐた。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はＴ君に貧しい慰問袋を送りました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "精養軒は美味いのであり、おふくろのオムレツは不美味いのである？",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、何処の国にもおふくろのオムレツみたいに、それがゲエテ、ダンテとばかり輝かしくはないまでも、納得の行く詩人といふものはゐるものである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の事は何時か又具体的に詳しく書かうと思つてゐるが、斯の如き飜訳界の偏頗ぶりも、向後追々改まつてゆくとすれば、今度はおふくろのオムレツの番となることだらうと思ふのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
