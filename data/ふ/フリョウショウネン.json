    "definitions": [
      {
        "index": 1,
        "gloss": "juvenile delinquent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
