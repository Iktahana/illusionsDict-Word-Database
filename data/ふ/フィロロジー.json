          "literary": [
            {
              "text": "又文献学（フィロロジー）的考察を現代へ適用するということが歴史的研究であるとも限らない。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来東洋では「文学」（フィロロジーと訳すべきもの）とはこの教学伝承の文化技術と文化イデーとのことであり、所謂学者とは正にかかる教学や文化の文字官僚に準じるものを云う。",
              "citation": {
                "source": "日本文化の特殊性",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "又訳者がフィロロジーを文献学と訳した一つの小さな見識にも敬意を払っていい。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
