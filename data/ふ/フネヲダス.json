    "definitions": [
      {
        "index": 1,
        "gloss": "to take out a boat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さらば、仕方なし、舟の計畫はやめて徒歩せむとて、勘定もすまし、茶代とらせなどするほどに、また報じて曰く、『網打の男來りければ、頼みて舟を出すことにせり』と。",
              "citation": {
                "source": "赤城山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "大丈夫かと問へば、舟子笑つて曰く、大丈夫なればこそ舟を出す也。",
              "citation": {
                "source": "北條より一ノ宮へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "客が何と云はうが、彼と云はうが、如何ばかりの黄金をふりまかうが、舟を出すべからざる時には、出し申さずと、子供扱ひにせられて、覺えず頭を掻く。",
              "citation": {
                "source": "北條より一ノ宮へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "盂蘭盆の晩に舟を出すとか出さないとかいうのは、もちろん迷信に相違ないが、海亀の群れがなぜその舟を沈めに来たのか、それは判らない。",
              "citation": {
                "source": "海亀",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今日は、あんな理由で部屋を飛び出したのであるが、常々七郎丸は仕事に行く時にはこれを着けて行くと好いということを主張していたので、僕もさっきこの身装のテレ臭さの余り娘にああいってしまったのではあったが、勿論、今直ぐ舟を出すからと聞けばこのまま出発するに違いないのである。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "船宿の女房は越後上布に唐繻子の引かけ帶ですらりと立つたものごしが、柳のやうで、柳橋の上に舟をもやつて、これから花火舟を出す間を、梅村屋の二階で潮時を待つてゐるのだつた。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りかかりの漫遊客が、季節かまわず舟を出すことはよくありました。",
              "citation": {
                "source": "画舫",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち舟を出すのである。",
              "citation": {
                "source": "青鱚脚立釣",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "満足な舟着場もなく、白波が高くたかく寄せてくる砂の上から数人の男たちが舟を出す景。",
              "citation": {
                "source": "アラン島",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）の幽霊やな」と助け舟を出すので救はれたいかけや、「大分、お前、話、分るな」とおだてると、「さうか、そない、分るか。",
              "citation": {
                "source": "初代桂春団治研究",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして向う岸へ舟を出すため、仲間を起しに行く。",
              "citation": {
                "source": "追放されて",
                "author": "В　ССЫЛКЕ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれが管理してやつてもいいぜ」「ははあ、管理を頼むかな、ひとつ」　カリヤルが、艀舟を出すといふ。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の向う岸の水音を聞いただけで、舟を出すやうな晩ではなかつたし、川の中の子供を何の苦もなく救ひ上げたくせに、突き飛ばして甚内橋を渡つて此方へ逃げて來た人間を見ないのはをかしい」「――」「あの時は、お越を擧げようかと思つたが、どうも證擔がアヤフヤだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "受難の通人",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の向う岸の水音を聞いただけで、舟を出すような晩ではなかったし、川の中の子供を何の苦もなく救い上げたくせに、突飛ばして甚内橋を渡ってこっちへ逃げて来た人間を見ないのはおかしい」「…………」「あの時は、お越を挙げようかと思ったが、どうも証拠がアヤフヤだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "受難の通人",
                "note": "青空文庫"
              }
            },
            {
              "text": "底が拔けるやうな大雨が、夜になつても續きましたよ」　八五郎は、お葉のために助け舟を出すのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美少年國",
                "note": "青空文庫"
              }
            },
            {
              "text": "二百あまりの家と云う家はずらり西側に並んで、向う岸との間は先ず隅田川位、おおいと呼べば応と答えて渡守が舟を出す位だが、東側は唯もう山と畠で持切って、それから向うへは波の上一里半、麻生天王崎の大松も、女扇の絵に画く子日の松位にしか見えない。",
              "citation": {
                "source": "漁師の娘",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣友同志が集まって、釣りテングのはなしをしているので、夜を明かすといったほうがいいね」「今でも夜中に舟を出すのですか」「昔は機械がなくて手こぎだから早く出たが、今でも夜中の三時ごろには舟を出す。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸い餌があったので、八時半に舟を出す。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "八時、雨が小やみになったので舟を出す。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひどい道だ」と、Ｋは男に助け舟を出すようにいった。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体何艘舟を出すつもりなのだろうと言ったのである。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、つい眼のさきの丹波島の渡し場だって、舟を出すまいではないか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい、貴様たち、人を責める前に、なぜ自ら顧みることをせんのだ、かように両岸に人が溢れて舟を待って焦れおるのに、貴様たち一向舟を出すことなさん、緩怠至極じゃ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――つまり岡さまの助力で「ちづか」を開業したのであるが、今でも舟は三｜艘あり、客に求められれば舟を出すこともできる。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに習って群集のうちからも、纜を解いて舟を出す者がいた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "２、近い内に諸戸屋敷の傭人達が、何かの荷物を積んで、舟を出す筈だ。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸戸が先日「近い内に諸戸屋敷の傭人達が、荷物を積んで、舟を出す筈だ」と書いたのはこれだなと思った。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
