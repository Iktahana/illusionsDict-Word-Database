    "definitions": [
      {
        "index": 1,
        "gloss": "to shake off (e.g. rain from an umbrella)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
