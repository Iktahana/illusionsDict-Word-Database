    },
    "definitions": [
      {
        "index": 1,
        "gloss": "immovable",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "此の日｜偶然○○不動の縁日。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしく不動の形の中にだが、また恐ろしく憔れてゐる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "プトレミー派の学者は地球を不動と考えて、太陽は勿論其の他の遊星も皆その周囲を運行するものと考えた。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に◇思潮界の大權威者であり、且つ詩壇評論のオーソリチイであつた上田敏博士が、これに最大級の讚辭をあたへたことは、一躍して白秋氏を文壇の巨星にし、名詩集の定評を不動にした。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の窓枠の中では、人は直立不動になつて何かを待つたり、物思ひにふけつたりする。",
              "citation": {
                "source": "窓",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "中根はあわてて無格好な不動の姿勢をとつたが、その顏には、それが癖の間の拔けたニヤニヤ笑ひを浮べてゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金刀比羅宮、男山八幡宮、天照皇大神宮、不動明王、妙法蓮華経、水天宮。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんたうにそのいるかのかたちの〔〕おかしいこと二つのひれを丁度両手をさげて不動の姿勢をとったやうな風にして水の中から飛び出して来てうやうや〔しく〕頭を下にして不動の姿勢のまゝまた水の中へくぐって行くのでした。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は、不動産をより多く持っている人間を羨んだ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに鉢の底面からは相当離れた所に固定しているコップは不動であるから、そこで相互間の週期的の摩擦運動が起こり、そのためにちょうど弓でクラドニ板をこする場合に似た事がらが生ずるのであるらしい。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが国で年々火災のために灰と煙になってしまう動産不動産の価格は実に二億円を超過している。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから年号と年数と干支とを併記して或る特定の年を確実不動に指定するという手堅い方法にはやはりそれだけの長所があるのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてうやうやしく直立不動の姿勢を取り、それから両肩をすぼめておいて両方の手のひらをぱっと開いて前方に向け、首を傾けてじっと自分の顔を見つめるという表情法の実演をして見せてくれた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうにそのいるかのかたちのおかしいことは、二つのひれをちょうど両手をさげて不動の姿勢をとったようなふうにして水の中から飛び出して来て、うやうやしく頭を下にして不動の姿勢のまままた水の中へくぐって行くのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しくまっ黒な砲艦の烏は、そのあいだ中、みんなといっしょに、不動の姿勢をとって列びながら、始終きらきらきらきら涙をこぼしました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんたうにそのいるかのかたちのをかしいことは、二つのひれを丁度兩手をさげて不動の姿勢をとつたやうな風にして水の中から飛び出して來て、うやうやしく頭を下にして不動の姿勢のまままた水の中へくぐつて行くのでした。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯爵家の不動産が担保に這入りかけているという事実を、意外な方面からチラリと聞き出したのは、その頃の事であった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは夜の九時頃になると、養母は其居間に籠って了い、不動明王を一心不乱に拝むことで、口に何ごとか念じつゝ床の間にかけた火炎の像の前に礼拝して十時となり十一時となり、時には夜半過に及ぶのです、居間の中、沈欝いで居た晩は殊にこれが激しいようでした。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "変って居るのは唯々何時もの通り夜になると不動様を拝むことだけで、僕等もこれは最早見慣れて居るから強て気にもかゝりませんでした。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "此事の有った後は母の神経に益々異常を起し、不動明王を拝むばかりでなく、僕などは名も知らぬ神符を幾枚となく何処からか貰って来て、自分の居間の所々に貼つけたものです。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして更に妙なのは、これまで自分だけで勝手に信じて居たのが、僕を見て驚ろいた後は、僕に向っても不動を信じろというので、僕が何故信じなければならぬかと聞くと、『たゞ黙って信じてお呉れ。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』という母の言葉を里子も傍で聞て居ましたが、呆れて、『妙ねえ母上、不動様が如何して母上と信造さんとには関係があって私には無いのでしょう。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『だって無理だわ、信造さんに不動様を信仰しろなんて、今時の人にそんなことを勧たって……』『そんなら頼みません！",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と母は怒って了ったので、僕は言葉を柔げ、『イヤ私だって不動様を信じないとは限りません。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私が不動様を一心に念ずると其怨霊がだん／＼消て無なります。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　それで僕に不動様を信じろと勧めるのです。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "総ての事が里子には怪しき謎で、彼はたゞ惑いに惑うばかり、遂には母と同じく怨霊を信ずるようになり、今も横浜の宅で母と共に不動明王に祈念を凝して居るのです。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀧へかゝるにはふどうオ／＼と尻を引いて呶鳴りながらかゝるのだと柘植氏が教へる。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがては死ななければならないといふどうにもならない生理の嘆きがかもしだす焦躁のあらはれのやうな思ひがする。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "せつないけれども又なつかしい人生の絢は、要するに死ななければならないといふどうにもならない生理の嘆きがひらいた花園だと思ふてゐる。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
