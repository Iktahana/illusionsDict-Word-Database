[
  {
    "uuid": "38cfa56a-3499-51e3-9c70-3e492ff44b26",
    "entry": "敷設",
    "reading": {
      "primary": "ふせつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "laying (a railroad, pipes, naval mines, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（明治四十年十月二十二日『東京朝日新聞』）　　　　　　　　　二十四　　　　　　水雷破壊器の発明　今度米国政府のためにアンリ・スタンフィーバンという仏国人が敷設水雷を破壊する器械を発明し、実地の試験をしたが好結果を得たという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学的発明も、化学工業も、鉄道敷設も、電信も道路の開通も、すべてが、資本主義の下にあっては、戦争準備の目標に向って集中されている。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば夫人が座の傍、肩掛、頭巾などを引掛けた、衣桁の際には、萌黄の緞子の夏衾、高く、柔かに敷設けて、総附の塗枕、枕頭には蒔絵ものの煙草盆、鼻紙台も差置いた、上に香炉を飾って、呼鈴まで行届き、次の間の片隅には棚を飾って、略式ながら、薄茶の道具一通。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬返しからそこを經て中禪寺へケーブルカー敷設の企てがある。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぢやね、君等の方の鐵道敷設問題は？",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夏演習林へ林道敷設の実習に行った時の事である。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は奥羽本線敷設の当時に、鉄板製の低い煙突を幾本も立てて、七年間に亘って黒い煙を流したのだった。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二期は、陸羽線敷設の当時、九年間に亘った。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一期第二期は何れも鉄道敷設の工事材料を目的に焼いたのだった。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように、由字・可字を小学的に理解すれば、この章の趣旨は自然と明白であり、聖人が民を導き教化するのに礼楽政教を用いた理由が、例えば歩きやすい平坦な道路を敷設して、人に自からその道路を歩かせるようなことなのだということが分る。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "却説一昨年岡崎邦輔君の紹介である人が予に尋ねられたは、何とかいう鉄道は鬼門に向いて敷設され居るとて一向乗客少ない。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁夫の仲間には、北海道の奥地の開墾地や、鉄道敷設の土工部屋へ「蛸」に売られたことのあるものや、各地を食いつめた「渡り者」や、酒だけ飲めば何もかもなく、ただそれでいいものなどがいた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「国道開たく工事」「灌漑工事」「鉄道敷設」「築港埋立」「新鉱発掘」「開墾」「積取人夫」「鰊取り」――殆んど、そのどれかを皆はしてきていた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「国道開たく」「鉄道敷設」の土工部屋では、虱より無雑作に土方がタタき殺された。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽炎が白熱した炎のように、ユラユラ立って、粗雑に敷設されたトロッコのレールが、鰻のように歪んで見えた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊のいる原始林を伐り開いて鉄道を敷設した。",
              "citation": {
                "source": "北海道の「俊寛」",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱海線の敷設がいよ／＼開始されたのである。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "遍歴原民喜　植民地を殖すのだとか、鉄道を敷設するのだとか云ふ譬喩で、新しく友達を作ることを彼は説明するのであった。",
              "citation": {
                "source": "遍歴",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう何年来となく舅達の話材の中心なので樽野も朧気に概要を知らされたのだが、Ｙ村の海岸一帯を埋め立てゝ鉄道を敷設し、港となし、温泉町を建てるといふ計劃なのだつた。",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの土地の鉄道敷設や採鉱や農業に、中国人が他の人種に先だって、どれほど活動したかというようなことは、今は誰も忘れてしまって恩恵を感じなくなっておりますが、世の中の識者は、世界はたしかに中国人を中心にして廻転しているということぐらいは知っていますよ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰊建網は長さ四十間にわたって海底に敷設する箱形の網である。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからもしも網を敷設する海底が、岩礁や、貝や、その他の障害物によって凹凸がはげしければ、波のまにまにゆれうごく敷網はその障害物にふれてたちまち傷つき破れざるをえないのだ。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "善かさもないものはただちに悪と、固定された、ただふたすじのみちが、もし、特定のものの便宜のために日本の人民の理性の上に敷設されるなら、それは、人を生き埋めにした上につくられた滑走路のようなものになるだろう。",
              "citation": {
                "source": "地球はまわる",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に九州地方は、鉄道を敷設するのは早かったし、農業改良技術を取り入れたり、またいくつかの産業では科学技術を採用もしている。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは村の後背地にある水田と森を越えて低い丘の縁に沿って敷設された。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜風」「荷車」「敷設列車」などで平林たい子は自伝的な作品から農民生活・労働生活を描く作品にうつったのであった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道で馬車鐵道の敷設されているのはこの旭川町だが、その鐵道によつて、師團裏なる新高臺の近所へ行き、その高臺の紅葉を遠望しながら、近文の舊土人部落を徘徊して見た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふせつぱつまつたわななきが、二人のゆがめられた愛慾をあふりたてた。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらハみな／＼しよふがわるいニつき、京よりうつてを諸藩へおふせつけられ候ものなり。",
              "citation": {
                "source": "続　手紙",
                "author": "坂本乙女、春猪あて（推定、文久三年秋頃）",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて彼等の作品には、常に 〔Ah ! Seigneur, donnezmoi la force et le courage/ De contempler mon coeur et mon corps sans de'gou^t !〕 と云ふせつぱつまつた嘆声が、瘴気の如く纏綿してゐた。",
              "citation": {
                "source": "あの頃の自分の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
