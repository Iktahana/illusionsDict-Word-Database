    "definitions": [
      {
        "index": 1,
        "gloss": "the unobtainable (that which cannot be known)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "金剛経にある過去｜心は不可得なりといふ意義にも通ずるかも知れない。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "シヨウスキーやレーマンが否宥克立幾何學を唱ふるも、唱へ得て畢竟不可得なるにあらずやである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧陽修のある大官のことを記した文章の中に『願為尋常無間之人又不可得』と書いてあるのを覚えてゐるが、実際伊藤公や桂公は、豪い人になつたことを、悔いてゐたかも知れないのである。",
              "citation": {
                "source": "生滅の心理",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "從郡至倭より旁國遠絶、不可得詳に至る一節。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生の外に出で、人生を望み見て、人生を思議する時、人生は遂に不可得なり。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "即今如是如是、自己を求めて不可得、因縁無我、空寂。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "心といっても主観的意識をいうのでなく、内亦不可得であり、無といっても、有に対する相対的無をいうのではない。",
              "citation": {
                "source": "絶対矛盾的自己同一",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝湯――殊に温泉――は何ともいへない心持だ、湯壺にぢとしてゐる時は無何有郷の遊び人だ、不可得、無所得、ぼうばくとしてナムカラタンノウトラヤヤ……。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "正法眼蔵啓迪「心不可得」の巻拝読。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の如き人心の「タブラ、ラザ」は、われその心理上に不可得なることを知ると雖、こゝには姑くその存在を認めて、これを有したりとおもへる逍遙子が上を評して見む。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒の講ずべき書を此中に求めむことは、殆ど不可得である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その留守に私は道元の「心不可得」の部を読む。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "自女王國以北、其戸數道里可略載、其餘旁國、遠絶不可得詳、次有斯馬國、（中略）次有奴國、此女王境界所盡、其南有狗奴國、男子爲王、其官有狗古智卑狗、不屬女王、（中略）女王國東渡海千餘里、復有國、皆倭種、又有侏儒國、在其南、人長三四尺、去女王四千餘里、又有裸國黒齒國、復在其東南、船行一年可至。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "然若其形状、則不可得而知。",
              "citation": {
                "source": "靈魂一元論",
                "author": "西周",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後さる温泉場で退屈だから、宿の本を借りて読んで見たらいろいろ下らない御経の文句が並べてあったなかに、心は三世にわたって不可得なりとあった。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三世にわたるなんてえのは、大袈裟な法螺だろうが、不可得と云うのは、こんな事を云うんじゃなかろうかと思う。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "神形相資するは、またなおかくのごとし」と）（『弘明集』）広弘明集云、若形即是神、神即是形、二者相資理無偏謝、則神亡之日、形亦応消、而今有知之神亡、無知之形在此、則神本非形、形本非神、不可得強令如一也、云云。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "この著者……和田不可得といふ著者の、さきの高野山の管長、和田性海さんといふ大徳だといふことを、ぼくは、勿論そのときはまだ知らなかつた。",
              "citation": {
                "source": "にはかへんろ記",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自女王國以北、其戸數道里可略載、其餘旁國遠絶不可得詳。",
              "citation": {
                "source": "魏志倭人傳",
                "author": "陳壽",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
