    "definitions": [
      {
        "index": 1,
        "gloss": "to include (in a group or scope)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本の山岳は、日本アルプスあたりでは、大洋より来る湿気を含める風が当って、降雪量は充分であるが、融ける分量の方が積る分量より多いのであるから、氷河という現象を作らない。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが内容の如何と云ふことでなく、技巧の上手下手と云ふことでもなくて、既成創作が含める生命の分量如何に就て、必ず著しい物足らなさを気づいて来るに違ひ無いと思ふのである。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕立雨の今や来たらんといふやうなる時、天の半を一面に蔽ひて、十万の大兵野を占めたる如く動かすべくもあらぬさまに黒みわたり、しかも其中に風を含みたりと覚しく、今や動ぎ出さんとする風情、まことに一敗の後の将卒必死を期してこと／″＼く静まりかへつたるが中に勃々として抑ふべからざる殺気を含めるが如し。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "雙眼涙を含める蒼ざめた顔を月はまともに照らす。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし弘法大師における灌頂は、伝教大師における戒壇ほど主力なものではなくて、弘法大師の得意とするところは、あらゆる真、善、美、の形式をまず人々に与えて、理想の匂いを感覚より浸み込ませ、現実に含める理想の価値をところを換えず即座に見出させようとする教法であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういう心になるまでには、私を教えるために、毎日、毎晩、見る者、聞くものについて、母様がどんなに苦労をなすって、丁寧に深切に、飽かないで、熱心に、懇に噛んで含めるようになすったかも知れはしない。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "説法が旨いで、因果を含めるに可いわい。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三曲の演奏にアンコールを許したり、裸体彫像に生花を配したり、ずいぶん突飛なことも彼によって示唆されたが、椅子テーブルの点茶式や、洋食を緩和して懐石の献立中に含めることや、そのときまで、一部の間にしか企てられていなかった方法を一般に流布せしめる椽の下の力持とはなった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "唾液は水なり、ムチンの存在によつて粘きも、其実は弱アルカリ性の水にして、酵素のプチアリンを含めるのみ。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち頽廢の意趣感情を含めるものを目睹耳聞する場合には、同じく頽廢的になり、奮激緊張の意趣感情を含めるものを睹聞する場合には、同じく奮激緊張せんとするのであり、幽玄の作品や樂曲に接しては、又同じく幽玄の心緒を動かされ、輕佻淫靡の作品や樂曲に接しては、又同じく輕佻淫靡の心を唆り立てられるのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と因果を含めるようにいわれて、枝の鴉も頷き顔。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしかういふ心になるまでには、私を教へるために毎日、毎晩、見る者、聞くものについて、母様がどんなに苦労をなすつて、丁寧に親切に飽かないで、熱心に、懇に噛むで含めるやうになすつたかも知れはしない。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは紗の面布のようにすぐ近く唇にすすって含めるし遠くは想いを海王星の果てまでも運んで呉れる。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴿の面をもてる者に蛇の心あり、美はしき果実に怖ろしき毒を含めることあり、洞に近けば※蛇蟄し、林に入れば猛獣遊ぶ。",
              "citation": {
                "source": "哀詞序",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この青く清らにて物問いたげに愁いを含める目の、半ば露を宿せる長き睫毛に掩われたるは、何故に一顧したるのみにて、用心深きわが心の底までは徹したるか。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その羞を含める姿は故の如くなりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "西牟婁郡三川豊川村は山嶽重畳、一村の行程高野山を含める伊都郡に等しと称す。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と蝶吉の項を抱いて口移しに噛んで含めるように、自分の赤心を語るため、今まで久しい間、時に触れ、折に当って、動かされた、至憐至愛の情の切なるを、ここに打明けて語ったのである。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "名をなつかしみ、尋ねし人、妾宅と覚しきに、世にも婀娜なる娘の、糸竹の浮きたるふしなく、情も恋も江戸紫や、色香いろはの手習して、小机に打凭れ、紅筆を含める状を、垣間見てこそ頷きけれ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間と云うものの総ての上について噛んで含める様に教えた様であった。",
              "citation": {
                "source": "正岡子規君",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この青く清らにて物問ひたげに愁を含める目の、半ば露を宿せる長き睫毛に掩はれたるは、何故に一顧したるのみにて、用心深き我心の底までは徹したるか。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは病毒のために身体の腐蝕するをいい、あるいは死が近く臨むといい、あるいはその跡悉く絶たるるという、まことに毒を含める強き皮肉である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに毒を含める嘲笑の語である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "噛んで含めるやうに、色々の方面から、解いてきかしても、どうしても理解しない場合、これは彼女達ばかりとはいへまい、男達の場合にも『不意に襲ふもの』があれば、いつぺんに何もかも判つてしまふものらしい。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "笛あふげば高き松が枝に琴かけ鳴らす、をゆびに紅をさしぐみて、ふくめる琴をかきならす、ああ　かき鳴らすひとづま琴の音にもつれぶき、いみじき笛は天にあり。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔さき立つ名誉村長は〕さき立つ名誉村長は、　　　寒煙毒をふくめるを、豪気によりて受けつけず。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまここで、いちいち諸君に噛んでふくめるように説明してお聞かせすればいいのかも知れないが、そんな事に努力を傾注していると、君たちからイヤな色気を示されたりして、太宰もサロンに迎えられ、むざんやミイラにされてしまうおそれが多分にあるので、私はこれ以上の奉仕はごめんこうむる。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "病みあがりの、しかして快く熱したるわが頬に、雨をふくめる夜風の爽かなりしかな。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方パーソナルコンピューターに関しては一九七八年三月、インテルの８ビット・マイクロコンピューターにベーシックと呼ばれるコンピューター言語（バカな機械に作業の進め方を、噛んでふくめるように指示するための言葉だ）を乗せた試作機を開発。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、なんにも云わずにこれから一緒に行けと、苦労人の紋七は噛んでふくめるように云い聞かせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            }
          ]
        }
