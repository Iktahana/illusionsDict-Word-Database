    "definitions": [
      {
        "index": 1,
        "gloss": "fan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "詩人がその空想の中で画くような、ファンタスチックな夢の国は、現実の地球上にあるはずがない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十米レエスならば、まず今世紀、かれの記録を破るものはあるまい、とファン囁き、選手自身もひそかにそれを許していた、かの俊敏はやぶさの如き太宰治とやらいう若い作家の、これが再生の姿であろうか。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は芥川君と芭蕉論を闘わし、一も二もなくやッつけてしまったのだが、今では僕も芭蕉ファンの一人であり、或る点で蕪村よりも好きである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "重兵衛さんは自分の心にファンタジーの翼を授け、自分の現実世界の可能性の牢獄を爆破してくれた人であった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ファンネルの烟を追っていた火夫が、烟の先に私を見付けて、デッキから呶鳴った。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、例えばコンスタンタン・ギイやドガアやファン・ドンゲンの絵が果して「いき」の有するニュアンスを具有しているであろうか。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを製作する監督、またそれを享楽する映画ファンの忍耐心の強いのは驚嘆すべきものである。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一座に限らず芝居の面白味の半分は端役の力であることは誰でも知っているらしいが、しかし誰も端役のファンになって騒ぐ人はないようである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばファン・デル・ワール等の理論に従えば、ガス体の圧を与うればその体積には三種の可能価ある事となる。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、子供の時に唱歌をやったと同じように、時々ピアノの鍵盤の前に坐って即興的のファンタジーをやるのが人知れぬ楽しみの一つだそうである。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の映画ファンの中の堅実な分子の中から総理大臣文部大臣以下各局長が輩出する時代が来て始めて私の夢は実現されるかもしれない。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人としての自分にはベラスケズのインファンタ、マリア、マルゲリタよりもこの方がいい。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞踊場で未来の墓誌銘に現代の道徳を刻んだ同志と、レムブルグ美容院の舞踊場の楽隊の奏でる哀悼歌に合唱して、米良は柩車のように螺旋をえがいて踊りながら、彼は絶えず東支那海の電信夫がもたらす秘密結社の女シイ・ファン・ユウの恋の便りを受取った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "シイ・ファン・ユウが早朝天津から香港に向けて出発する知らせであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は陳子文の死によって北京の秘密結社において自分と彼とシイ・ファン・ユウとの恋愛の共同事業も、陳子文が過去の東洋の虚無主義の祭壇に生還したのを感じて、陳子文の古い伝統の礼譲に敬礼するのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は再び寝床の中にもぐると、今一度シイ・ファン・ユウの電報を開いて読むのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一通は上海の同士から、一通はシイ・ファン・ユウから香港行を中止した電文であった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "××府の女、六朝の血を衝けた彼女達の北方軍閥に対する憎悪は、南方の組織に関わらずその力によって北方軍閥の倒壊をまって自己を擁力しようとする陰謀、シイ・ファン・ユウも目的をそこにもっていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "シイ・ファン・ユウが米良に身を委せるときは、彼女は自分の演じているお芝居に有頂天になっているときであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚したが図星の外れたシイ・ファン・ユウは最近東京に来て米良に会った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "シイ・ファン・ユウが寝床に黄色い蝋のような肉体を投げ出して、　――メラ、貴方に何ができるものか、いまでは妾はプロレタリアの結束はいつか絶対のものとなるときがあると思うのだけど、そのとき妾達はやっぱり不幸なのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "云い終ると支那の女の小さい足がカーテンのように閉まって米良もシイ・ファン・ユウも物を考えることをよしたのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
