[
  {
    "uuid": "53b76b6c-bda7-55ef-b50a-bb7c26a3c3ad",
    "entry": "不備",
    "reading": {
      "primary": "ふび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
