[
  {
    "uuid": "f447b1cd-22a7-55ff-9084-d44e76ec4c04",
    "entry": "塞ぐ",
    "reading": {
      "primary": "ふさぐ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ガ行",
        "動詞-他動詞"
