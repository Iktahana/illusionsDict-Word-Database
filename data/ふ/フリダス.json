[
  {
    "uuid": "a51c4e1f-a375-5866-858c-a314b2855867",
    "entry": "降り出す",
    "reading": {
      "primary": "ふりだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
