    "definitions": [
      {
        "index": 1,
        "gloss": "perpetual youth and longevity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
