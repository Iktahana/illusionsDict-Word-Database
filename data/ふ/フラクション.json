          "standard": [],
          "literary": [
            {
              "text": "一九一二年、プラーグでボルシェビキの特別の党指導部が成立して以来、特に議会フラクションの指導に忽ち現われた如く、党の独自的指導は強まった。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひろ子は、自分たちの託児所でのそういう経験を、数ヵ月前から持たれるようになっていたフラクションの会合で話した。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "のし紙50　Ｙへやるお礼のしゃぼん30円×７＝210　竹のいい耳かき１円　脱脂綿20十三日（水）　きのうの『読売』に国鉄のフラクションの頭の方が全部箇有名詞を並べてかいてあった。",
              "citation": {
                "source": "日記",
                "author": "一九四七年（昭和二十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂小五郎以下の長藩フラクションは、島津三郎の兵卒東下を機会に、雄藩改良派ブロック中で争われた薩長両藩主の支配競争を利用もし、永井雅楽にたいするテロまで準備して、藩論を獲得。",
              "citation": {
                "source": "尊攘戦略史",
                "author": "服部之総",
                "note": "青空文庫"
              }
            }
          ]
        }
