        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すべて貧困の家に育ち、肉親の愛にめぐまれずして家庭的、環境的の不遇に成長した人々は、そのかつて充たされなかった心の飢餓を、他の何物にも増して熱情するため、後に彼が一家の主人となった場合、その妻子の忠実な保護者となり、家庭を楽園化することに熱心である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "不遇を尊敬したことがなかったか。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村は不遇の詩人であった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての天才は不遇でない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ純粋の詩人だけは、その天才に正比例して、常に必ず不遇である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に就中蕪村の如く、文化が彼の芸術と逆流しているところの、一の「悪しき時代」に生れた者は、特に救いがたく不遇である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の別の句愚に耐えよと窓を暗くす竹の雪　もこれとやや同想であり、生活の不遇から多少ニヒリスチックになった、悲壮な自嘲的感慨を汲むべきである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時流に超越した人の不遇思うべしである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規は世の中をうまく渡って行く芸術家や学者に対する反感を抱くと同時に、また自分に親しい芸術家や学者が世の中をうまく渡る事が出来なくて不遇に苦しんでいるのを歯痒く思っていたかのように私には感ぜられる。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の観察したシャスタを、漢文者流の口調を借りて、人間本位で言うならば、とかくに不遇の山水である。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年七月二十日『東京朝日新聞』）　　　　　　　　　八十八　　　　　　科学者の不遇　科学者が世界の文明に貢献し自国の栄誉を高めつつあるにもかかわらず一般に不遇であるのは何処も同じと見える。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「科学研究の重要な事は誰も認めているが何かの場合にはとかく不遇になりがちである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉親の愛さへも知らないほど、不遇な逆境に育つた彼が、少年の時から夢に描いてこがれたものは、和氣藹々たる家庭生活の實現だつた。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがどこまでも自分を社會的に不遇にする。",
              "citation": {
                "source": "大船驛で",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "報いられる事薄かつた明治時代の文人の中でも、緑雨は恐らくその不遇なるものの隨一人だつたであらう。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このひとり者が翁の不遇の原因をなしたのか、不遇がひとり者の原因であったのか、これをわかつことはできない。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "善人で、酒もしいては飲まず、これという道楽もなく、出入交際の人々には義理を堅くしていて、そしてついに不遇で、いつもまごまごして安定の所を得ず今日が日に及んだ翁の運命は、不思議な事としか思えない。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる不遇の人です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの人も筆を揃えて、江戸歌舞伎式の俳優の最後の一人であると伝えているが晩年の源之助は寄る年波と共に不遇の位地に置かれて、その本領をあまりに発揮していなかった。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の眼からは不遇のように見えても、本人はそれに甘んじていたのかも知れない。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "立役と違って、女形は年を取ってはいけませんと、梅幸は述懐していたが、源之助も女形であるために晩年の不遇が更に色濃く眺められたらしい。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はＳは両親も兄弟も親戚もない、不遇な男であることを想い出した。",
              "citation": {
                "source": "面会",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、「山椒魚」に接して、私は埋もれたる無名不遇の天才を発見したと思って興奮したのである。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる詩人的な文学者は――小説家でも思想家でも――日本に於ては不遇であった。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことから、この詩人の文壇的地位は甚だ不遇で、折角の稀有な鬼才さへも、殆んど詩壇的に認められないで死んでしまつた。",
              "citation": {
                "source": "名前の話",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗右衛門の両親は、その不遇の為めに早世した。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不遇で病弱で、長く桂子に物質的補助をうけてゐる画家であつた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不遇傲岸に見える小布施は、案外、時流に神経質で、十六七年も前桂子と同門で矢来町のＹ――先生の画室に預けられてゐた時分から、逐次独立するまで、後期印象派、ダヾ、表現派、新古典、超現実派と、およそ日本で尖端的に見える画風は魁けしてこれを取り入れ、通俗派の方面にぶつかつて行つた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆あさんが暫くあふぐうちに、爺いさんは讀みさした本を置いて話をし出す。",
              "citation": {
                "source": "ぢいさんばあさん",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
