[
  {
    "uuid": "5c32a5d3-b27c-5ff5-b941-8d0814e292c4",
    "entry": "紛々",
    "reading": {
      "primary": "ふんぷん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
