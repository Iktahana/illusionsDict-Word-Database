    "definitions": [
      {
        "index": 1,
        "gloss": "unkindness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんな大事なことを一言も僕に教えてくれなかったというのは不親切だ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の女中も、不親切だ。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人や子供達にはケンケンして不親切であったが、清三に金を送りに行った時だけは、何故か為吉にも割合親切だった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不親切ではないがそのことを言うのが彼自身｜怖ろしいので言えずにいるのじゃないかなど思う。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオ放送と似た禁令があるかもしれないが、読者の要求に対しては不親切であると思われる。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肝心の要訣がぼかしてある場合が多いのは著者の故意か不親切かひとり合点かわからない。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャメラが一町とは動いていない場合に、面画は何千里の遠方にあるか想像もできないようなひとり合点の編集ぶりは不親切である。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の田舎｜老爺もこの事を知らなかったため横暴なる赤馬車に虐められているのであるが、いかに山の中とはいえ、かくのごとき不親切極まる営業振りは聞捨てにならぬ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにおいて将軍大いに憤慨し「こんな不親切極まる旅館へは宿らんでもよい。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとく一般旅客に不親切なる旅館は、一刻も早く滅亡すべし。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "望雲館、大東館の不親切なるに反し、一井旅館は極めて親切にしてくれた。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅館の不親切、呆れたものだ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に裏の畑には芋も大根もあるのに、それを掘るのが面倒なのか、高い缶詰を売付けようとするのか、不親切も甚しいので、未醒子大いに腹を立て、「止せ止せ、こんな家の厄介になるな」と、一行は尻をたたいてこの家を出たが、婆さん一向平気なもの、振向いてもみない。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し彼奴が不親切な奴で、金を貰いながら其儘どこへか行って了ったら何うだろう。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ロシヤの医科大学の女学生が、或晩の事、何の学科やらの、」というような頗る不親切な記述があったばかりで、他はどの頁をひっくり返してみても、地理的なことはなんにも書かれてありません。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時心のうちでは、随分「土」に比べると詰らないものも公けにされる今日だから、出来るなら何時か書物に纏めて置いたら作者の為に好かろうと思ったが、不親切な余は其日が過ぎると、又「土」の事を丸で忘れて仕舞った。",
              "citation": {
                "source": "『土』に就て",
                "author": "――長塚節著『土』序――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうすこしアッサリしていて、不親切や害をする質の男ではなさそうです。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、不親切な医者かも知れません。",
              "citation": {
                "source": "正直ノオト",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不親切で、気がきかない。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一しょになって心配してやらねば不親切だといってヒガむし、そうかといって心配すればキリが無いし、仕末に悪い。",
              "citation": {
                "source": "良人教育十四種",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して舎中の諸君には不親切の限りを尽した。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "不親切で、ちっとも私達を見に帰って来ない父親ですがね。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "人事僅かに至らぬところあるが為に、幾百千の人が、一通りならぬ苦しみをすることを思うと、かくのごとき実務的の仕事に、ただ形ばかりの仕事をして、平気な人の不親切を嘆息せぬ訳にゆかないのである。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての商人はみな不親切に思われる。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そしてそれ以来彼は寝食を忘れて作画に没頭し勿論僕の方が不親切で彼の方が親切で従順であるばかりでなしに、どんな不愉快も僕に与へない。",
              "citation": {
                "source": "朝居の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時心のうちでは、隨分「土」に比べると詰らないものも公けにされる今日だから、出來るなら何時か書物に纏めて置いたら作者の爲に好からうと思つたが、不親切な余は其日が過ぎると、又「土」の事を丸で忘れて仕舞つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "つくし殿には、ていねいに摩擦してあげるのかも知れないが、僕には、いつでも粗末で不親切だ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「君は君の夫人に対して不親切だといふ評判を聞いたぞ。",
              "citation": {
                "source": "素書",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりは学ぶことの不徹底・不親切が、経典書籍の中に明白な答えがあっても之を捉えることが出来ず、無暗に書籍を漁り文章の闇に光を当て探し求めるのである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人のしんせつ、ふしんせつ、頭脳のよさわるさ、――道をたづねるとき、あまりによくわかる。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
