        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be given the cold shoulder",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だから振られるんだ、遊女持てのしない小道具だ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころころ表情の変わる顔がさっと曇り、首が振られる。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚じつと見て居るとその燈は輪状に或は上下に打振られる。",
              "citation": {
                "source": "殺人行者",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　忽ち村長は斯様な花々しい賛同の叫びと宙に振られる拳の旗に包囲されました。",
              "citation": {
                "source": "馬上の春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もそっと二枚目の返事をせんと、奥州に振られるぞ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "十歳の昔のころ祖母のお伴で屡々歌舞伎芝居を見に行くのであつたが、女に振られる悪侍やお殿様が「えゝツ、これほど云うても聞きわけもない、斯うなるからは可愛さあまつて憎さが百倍――」などゝ唸つて眼玉をむき出すのだが、いつの時でもその心持や顔つきが腑に落ちなかつた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "知つた人の影にも遇はないのは私にとつては幸ひだつたが、せめて知合ひの茶屋の行衛を往来の人を捉へて訊ねて見ると空しく言下に首を振られる。",
              "citation": {
                "source": "鱗雲",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内顔に先に立って墓地の方へ通って行こうとする年とった寺男、閼伽桶と樒の葉、子供等の手に振られる赤い紙に巻かれた線香の煙、何一つとして岸本の沈思を誘わないものは無かった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭の平和をすっかり攪乱する」と、大きい暖い頭を振られる。",
              "citation": {
                "source": "二つの家を繋ぐ回想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話局に新設や付け替えを申し込むと、まず電電公社から元請けに仕事がまわされ、そこから下請けの作業グループに仕事が割り振られる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "振られる鉢巻の下では、白と黒との眼玉が振り子のやうに。",
              "citation": {
                "source": "頭ならびに腹",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しく編成された軍隊の動きが活溌になっていくにつれて、炎天に振られる旗の数が街から街へ急激に増して来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分一人で、葉子の方のブランコへ飛移る時、左程でもないが、帰りの場合、葉子に足を掴まれて、逆様に吊された儘、大きく振られると、記憶とか思考とか、そういった精神的能力は、悉く振り棄てられて仕舞うのだ。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だがねえ、どういふわけで僕がさういふ役を振られるのか、それがわからない。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は振られるのを悦ぶのが流行りましたものですが、今なら何のくらい怒るか知れません。",
              "citation": {
                "source": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "author": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の入口で待っていた老女が何かたずねても、王子はただ悲しそうに頭を振られるのみでした。",
              "citation": {
                "source": "お月様の唄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、牛は勇猛ではあるが、愚鈍にできてるので、折角ピカドルを馬ごと突き倒しながら、第二の突きを入れる前に、駆け寄って来たテュロに赤い合羽を振られると、その方へ気を取られ、すぐその合羽の方へ突っかかって行く。",
              "citation": {
                "source": "闘牛",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女に振られるのも無理はないやね。",
              "citation": {
                "source": "訣れも愉し",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "コポオの下で、主として装置の考案を担当する演出助手のやうな仕事をつづけてゐた彼は、時たま、演し物によつて役を振られることがあるくらゐで、コポオの信任は相当厚かつたけれども、俳優としての実力は、まだ十分に発揮してゐなかつた。",
              "citation": {
                "source": "ルイ・ジュウヴェの魅力",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如く浜町のあそびは芸者買の半分にも足らざるほどにしてしかも振られるといふ事なければ流行ること夥しく、遂に芸者組合より苦情出で内々その筋へ歎願密告せしかば大正五年四月の頃より時の警視総監西久保某といへる人命令を部下の角袖に伝へてどしどし市中の白首を召捕りけり。",
              "citation": {
                "source": "桑中喜語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "女に振られる役が　　　いやだと云ふんぢやないんだ。",
              "citation": {
                "source": "是名優哉（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "所詮は仕出しにやゝ優る役を振られるくらゐのことであつたらうが、しかも彼らはそれを以て満足し、幸福に一生をおくつたであらうか。",
              "citation": {
                "source": "異版　浅草燈籠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "船が出帆すると、教授夫妻はいつまでも寒い甲板に立って帽を振りハンケチを振られるのが望まれたのでした。",
              "citation": {
                "source": "アインシュタイン教授をわが国に迎えて",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となく遠廻しに痛振られるような気もした。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ところが、どういうものか、先生は、たいへんに悪党振られる。",
              "citation": {
                "source": "犂氏の友情",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "女に振られるといふことはその瞬間から女が二倍の縹緻を發展してくるものだからであつた。",
              "citation": {
                "source": "はるあはれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔは大阪の道頓堀のＮ座に出勤していた、もとより目立つ役を振られる身分ではなかったが、俳優であるが故に――多分そうだったろうと思うのだが、カフエーの女給をいつの間にか手に入れて喜んでいた。",
              "citation": {
                "source": "幽霊を見る人を見る",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "振られるには振られたけど、こいでやつぱし私はまだあの人を好きなんだわねえ。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この網受けに割振られるものは、まず槍の使い方を習わせられるのを常例とする。",
              "citation": {
                "source": "大菩薩峠",
                "author": "間の山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "金が無くなると女にふられるって意味、じゃあ無いんだ。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
