[
  {
    "uuid": "75bf20d9-1327-5f5a-bc64-45ab77715ebc",
    "entry": "振られる",
    "reading": {
      "primary": "ふられる",
      "alternatives": [
        "フラれる"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
