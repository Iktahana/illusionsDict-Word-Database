    "definitions": [
      {
        "index": 1,
        "gloss": "Fukushima (city, prefecture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
