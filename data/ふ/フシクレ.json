    "definitions": [
      {
        "index": 1,
        "gloss": "knotty wood or tree",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "八は節榑立つた不器用な指で、此の玉を捩つて開けたのである。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファウスト己は足の草臥れぬ間は、この節榑立った杖一本で沢山だ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時にステパンは節榑立つた拳を握り固めて夫人の顔の前で振つた。",
              "citation": {
                "source": "パアテル・セルギウス",
                "author": "VATER SERGIUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨセフはそのわが子の躯を、その勤勉な性質を語り顔な大きな節榑立った掌に受けた。",
              "citation": {
                "source": "聖家族",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　年寄りはそれは御苦労なこったという顔をしてうなずいて、その節榑立った指さきで、もとの同僚の遺児の頬を不憫そうに撫でた。",
              "citation": {
                "source": "夕張の宿",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "読む人々も、恁くては筋骨の逞しく、膝節手ふしもふしくれ立ちたる、がんまの娘を想像せずや。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふしくれだった黒い大きい右手には、先刻の菖蒲の花束を持っている。",
              "citation": {
                "source": "令嬢アユ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大の男が、あんな小さい弓を、ふしくれ立った手でひねくりまわし、百発百中の腕前になってみたところで、どろぼうに襲われて射ようとしても、どろぼうが笑い出しますし、さかなを引く猫にあてても描はかゆいとも思やしません。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "読む人々も、かくては筋骨｜逞しく、膝節手ふしもふしくれ立ちたる、がんまの娘を想像せずや。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "凌霄はふしくれ立つた松の幹でも構はずに絡みかゝる。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふしくれだつたそのからだは、ちようど、うすつぺらな石炭袋へ石炭をぎゆう／＼つめこんだやうなかつこうです。",
              "citation": {
                "source": "青い顔かけの勇士",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争中は自分のようなものにも徴用ということがあって、センバンを握り、手もふしくれて、油にまみれて働いた、国にお務めをした、というような、落ちついて澄んだ心のうかゞわれることが、タド／＼しい文字で綴られており、今、宗十郎門下にいて、青年歌舞伎にでているから、見物してくれ、と書いてあった。",
              "citation": {
                "source": "死と影",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬめらかなる玉は、すべり安く、ふしくれだちし手には、あまりに痛ましく、たへがたく――すべり落つるも、ことわりなり。",
              "citation": {
                "source": "かの日の歌【三】",
                "author": "漢那浪笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い、ふしくれ立ったくるみの木が一本、そこにあったが、その樹蔭で、よく小さいヨハンネスが、低い木椅子に腰かけてくるみをかじっていると、フリイデマン夫人と、もう今は大きくなった三人姉妹とが、灰色の帆布でできた天幕の中に集っていた。",
              "citation": {
                "source": "小フリイデマン氏",
                "author": "DER KLEINE HERR FRIEDEMANN",
                "note": "青空文庫"
              }
            },
            {
              "text": "身もだえするごとく右肩を内側にひきしめ、全身の筋肉がふしくれだってそのまま凝結したようにみえる。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈の低い、ふしくれだった頑丈なその幹と枝ぶりはゴッホの筆触を思わせた。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだつきは、がっしりとふしくれだっているのに、頭は小さくて、しかも、とってもおだやかな、やさしそうな顔つきをしているのです。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの痩せ細った脛は、ふしくれだった膝は、両方ぶつかりあった。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い顔が紫色に変って、ふしくれ立っていた。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いまのままでは」　急に、又四郎のからだが、ふしくれ立った。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
