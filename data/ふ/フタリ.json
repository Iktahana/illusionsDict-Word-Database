        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まひる利根川のほとりを歩めば、二人歩めばしばなくつぐみ、つぐみの鳴くに感じたるわが友のしんじつは尚深けれども、いまもわが身の身うちよりもえいづる、永日の嘆きはいやさらにときがたし、まことに故郷の春はさびしく、ここらへて山際の雪消ゆるを見ず。",
              "citation": {
                "source": "利根川の岸邊より",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔こんにやくの〕宮沢賢治こんにやくのす枯れの茎をとらんとて水こぼこぼと鳴るひぐれまぢかの笹はらを兄弟二人わけ行きにけり",
              "citation": {
                "source": "〔こんにやくの〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔鷺はひかりのそらに餓ゑ〕宮沢賢治鷺はひかりのそらに餓ゑ羊歯にはそゝぐきりさめをあしきテノールうちなして二人の紳士　森を来る",
              "citation": {
                "source": "〔鷺はひかりのそらに餓ゑ〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔甘藍の球は弾けて〕宮沢賢治甘藍の球は弾けて青ぞらに白雲の房呑屋より二人の馬丁よろめきてあらはれ出づる",
              "citation": {
                "source": "〔甘藍の球は弾けて〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、件の青年をＡとし、相手の青年をＢとするとして、二人の交游がどんな有様を呈するであらうか、以下そのことを誌してみたい。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お二人とも、憂鬱さうねえ」と女給が云ふ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕達は今卒業して、二人ともそれぞれの郷里に帰つてゆく。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ積めるに決つてゐると、腹の立つてゐる矢先ではあり「えゝこなひだ府の何とか課長さんの引越が一台で出来たといふ新聞の記事を見ましたよ」と、僕は二人の間に立ちはだかるやうに云つたのだつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局僕一人が引越の手伝ひ人であり、その弱々しい、事実またちよく／＼大病を患ふその叔母と僕との二人だけが引越万端のことをするのだとすると、まづまづ僕一人が大部分のことをしなければならない。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が枡に足を蹈み込んだばかりに、肥つた四十年配の女が二人、飛び込んで来て、「ああよかつた、端ッこでもあつてこそよございました、もう五分早ければよございました、惜しいことをしました、私は今朝から一服もしません、ええでも一幕見てから一服することにいたしませう」なぞと、イキセキ切つて云ふのであつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の肥つた女達は、私のや私の前の男のネクタイを見ながら、「まあ勉強しますわねえ、八十銭であんな物まで附けるのですものねえ……ええェ」と云つた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人共大変に歌舞伎通のやうである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへやつて来た五十くらゐの女が、いきなりその二人に向つて、「わたしや勧進帳はだい嫌ひ、眠くなつちやつた」と云つた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し私共二人が、互にその思想や主張の上で自己を押し立てようとするならば、私共はとくに血を流すやうな争論を繰返して居なければならなかつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙吉ト新美ノ二人ガ、子供ヲ大事ニ気ヲ附ケマス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙吉ハ二人ヲ大事ニシテクレマス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚十数年、ヘルン既に五十｜歳を過ぎ、二人の男児と一人の女児の親となってる晩年の手紙である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "人跡絶えた山道には、人力車の通う術もなかったので、二人の若い男女は、互に助け合いながら、蔦葛の這う細道を、幾時間となくさまよい歩いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日二人は、例によって睦じく連れそいながら、牛込辺の売邸を探しに歩いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の仲の好い成人が、子供の片言のようなことをしゃべり合って、何時間もの長い間、笑ったり戯れたりしている風景こそ、おそらく真にフェアリイランド的であったろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『だれにも解らない二人だけの言葉で、だれにも解らない二人だけの秘密や楽しみやを、愛人同士で語り合っている時である』と。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ家の中に住んでる家族の者にさえも、ほとんど全く解らない不思議な言葉で、何時間も倦きずに睦じく語り合ってた二人の男女こそ、この世における最も理想的に幸福な夫婦であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての恋する人々は、自分等以外に全く人影のない離れ小島の無人島で、心行くまで二人だけの生活をし、二人だけの会話をしたいと願うのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の愛人同士は、周囲に多くの人々が住んでる環境に居て、しかも無人島に居る二人だけの会話を会話し、二人だけの生活を自由に享楽していたのであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその悲哀の意味を知ってるものは、世界にただ二人の、妻と良人よりなかったのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中が二人、書生が一人、老僕が一人、他に抱車夫が一人という大家族であったので、家も相当に広く、間数がいくつもあって廊下続きになっていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君と僕とは、文壇でいちばんよく似た二人の詩人だ。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよ兄は手に水桃をささげもち、いつさんにきみがかたへにしたひよる、この東京の日くれどき、兄の戀魚は青らみてゆきて、日毎にいたみしたたり、いまいきもたえだえ、あい子よ、ふたり哀しき日のしたに、ひとしれず草木の種を研ぐとても、さびしきはげに我等の素脚ならずや。",
              "citation": {
                "source": "幼き妹に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頗る言いにくい話であるが、彼とふたりで遊び歩いていると勘定はすべて彼が払う。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑中休暇がすんであたふたと上京したら、馬場の海賊熱はいよいよあがっていて、やがて私にもそのまま感染し、ふたり寄ると触ると Le Pirate についての、はなやかな空想を、いやいや、具体的なプランについて語り合ったのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
