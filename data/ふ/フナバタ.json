    "definitions": [
      {
        "index": 1,
        "gloss": "side of a boat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そよりとも風のない日で、秋の暑さは大川の水にも残っているらしく、向う河岸から漕ぎもどして来る渡し船にも、白い扇や手拭が乗合のひたいにかざされて、女の児の絵日傘が紅い影を船端の波にゆらゆらと浮かべていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "指端を弄して低き音の縷のごときを引くことしばし、突然中止して船端より下りた。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と春枝夫人は此時淋しき笑を浮べて、日出雄少年と共にずつと船端へ行つて、鐵欄に凭れて遙かなる埠頭の方を眺めつゝ『日出雄や、あの向ふに見える高い山を覺えておいでかえ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "噎ぶのを堪え、涙を飲み落す秀江のけはい――案外、早くそれが納って、船端で水を掬う音がした。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高谷君はさらにそれを船端へくくり付けて、一種の曳き舟のようにして堤のきわまで曳きよせてもらった。",
              "citation": {
                "source": "麻畑の一夜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜兵衛は度胸を据えて引き上げさせると、かれは潮水に濡れたままで船端に坐り込んで、だしぬけに何か食わせろと云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "盥の中の三艘の舟は忙がしさうに走り、折々船端を打ちつけ合つて、盥の岸に停つた、夜店の玩具売りの男は、一刻も安息をゆるさないといつたふうに、指で邪険に舟を岸から突き離した。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "過ぎし屋島のたたかいに、風流を好む平家の殿ばらは、船に扇のまとを立てさせ、官女あまたある中にも、この玉虫が選みいだされ、船端に立って檜扇をかざし、敵をまねいて射よという。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯の少ないここらの町はだんだんに薄暗く暮れて来て、栗の立木も唯ひと固まりの暗い影を作るようになりましたが、空と水とはまだ暮れそうな気色もみえないので、水明かりのする船端には名も知れない羽虫の群れが飛び違っています。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯の少いここらの町はだんだん薄暗く暮れて来て、栗の立木も唯一と固まりの暗い影を作るようになりましたが、空と水とはまだ暮れそうな気色もみえないので、水明りのする船端には名も知れない羽虫の群が飛び違っています。",
              "citation": {
                "source": "栗の花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "船端から身をのり出すようにして、声を限りに叫んだ。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲板に上り著くと同時に痰が出たから船端の水の流れて居る処へ何心なく吐くと痰ではなかった、血であった。",
              "citation": {
                "source": "病",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は船端に立つたまま、鼠色に輝いた川の上を見渡し、確か広重も描いてゐた河童のことを思ひ出した。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は船端に立ったまま、鼠色に輝いた川の上を見渡し、確か広重も描いていた河童のことを思い出した。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは船端から、やつと掛声をして磯へ飛び下りた。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは船端から、やっと掛声をして磯へ飛び下りた。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "船端には、先刻、街で見付けたと同じやうな土が一ぱい、苫の中にも多分それが積み込んであることでせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "捕物仁義",
                "note": "青空文庫"
              }
            },
            {
              "text": "船端には、先刻、街で見付けたと同じような土が一ぱい、苫の中にも多分それが積み込んであることでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "捕物仁義",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな風にするんだと言いながら、彼はまくりあげて船端にしゃがんで見せた。",
              "citation": {
                "source": "ダルマ船日記",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、この世界の生活者達は、老若男女、夜であろうがひるまだろうが、僕みたいな者が物珍らしく見ていようが、生理のためには、悠々と船端にしゃがんでいる彼等である。",
              "citation": {
                "source": "ダルマ船日記",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は一度立ち上がって、船端から小便をした。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "四山環翠、一水澄碧の湖上に輕艇を駛らすれば、凉風｜面を撲つて、白波ふなばたに碎くるさま、もとより爽快の好い心持である。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ゴルドンはふなばたから下を見おろしていった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "市の人々は、涙ながらに少年たちの追善をやっているとき、富士男はサクラ号のふなばたに立って、きっと泡だつ怒濤をみつめていた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一同はふなばたに立って、富士男のすがたをみつめた、富士男はみごとに抜き手をきって泳ぎだした。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてふなばた近く、富士男のからだがあらわれた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず縄梯子を右のふなばたにかけたので、幼年組は先をあらそうて梯子をおり、ひさしぶりで、陸地をふむうれしさに、貝を拾ったり、海草を集めたりして、のどかな唄とともに、活気が急に全員の顔によみがえった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふなばたに砕ける波と、はるかなる海鳴りと、浜でたたく浪の音が別々に聞き分けられた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "トゥーンの湖を渡る旅人の、眉にせまるアーベントベルクの黒木の森の上に、朝の日に燃えては、水底に眠る魚鱗の夢を破るかと、かっと中空にきらめく時、心無き旅人も、ちり気だつまでぞっとして、ふなばたにのり出して、じっと見つめる一座の山岳のあったのを忘れまい、彼のグロース・シュレックホルンである。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹見は、身軽にふなばたに立って、近づく平靖号を、じっと見下ろしていた。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
