        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "勝坊の頭を撫で乍ら商人に向って、Ｔ「自分で落しときァがって巫山戯るねえ！",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも真面目な勤勉な市民が羽目をはずして怠け巫山戯る日であった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田島は勿論、こんな女が自分の傍に居るのを知ってもイベットが何とも思わないことを知って居た、それよりもイベットの子供らしいとはいえ態と自分にからかって他の男に巫山戯る様子にいくらかの嫉妬を感じた。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何うか――」「御勘弁を――」「巫山戯るなっ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、外出の仕度をさせるのに、おしもをわざわざ奥の居間へ呼ぶのも巫山戯るためかと疑い、夜分、寝室で頭を揉ませているのさえ不安な思いで、時折りお春を覗かせにやる。",
              "citation": {
                "source": "女心拾遺",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "底野　　巫山戯るない。",
              "citation": {
                "source": "運を主義にまかす男",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜は汽車の中で、同行の南日君と赤羽から一緒に乗り込んだ越後女の一隊が、終夜声自慢の謡を歌うやら笑うやら巫山戯るやら、一方ならぬ騒々しさで、夜風の涼しいにも拘らず、少しも眠ることが出来なかった。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "綺麗なのは皮一重だが、あの内儀は心の底からの貞女だ」「大層｜悟りやがつたな、八」「へツ／＼、先づざつと斯んなもんで」「巫山戯るなよ、馬鹿野郎。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "十手の道",
                "note": "青空文庫"
              }
            },
            {
              "text": "お常の茶屋を覗いたことも、綱吉がお常に巫山戯るのを見たことも、學寮の角を通つたことも、何の蟠りもなく話して退ける調子は、身に暗いところのある人間とは、何うしても受取れません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美女を洗ひ出す",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠啼きや、巫山戯る騷しい叫び聲などがした。",
              "citation": {
                "source": "蒼白き巣窟",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "綺麗なのは皮一重だが、あの内儀は心の底からの貞女だ」「たいそう悟りやがったな、八」「へッへッ、まずざっとこんなもんで」「巫山戯るなよ、馬鹿野郎。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "十手の道",
                "note": "青空文庫"
              }
            },
            {
              "text": "お常の茶屋を覗いたことも、綱吉がお常に巫山戯るのを見たことも、学寮の角を通ったことも、何の蟠りもなく話して退ける調子は、身に暗いところのある人間とは、どうしても受取れません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "美女を洗い出す",
                "note": "青空文庫"
              }
            },
            {
              "text": "その悧巧な、快活に巫山戯るさまは総ての人に面白がられた。",
              "citation": {
                "source": "或る少女の死まで",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "シロは永く見なかった姉の顔を見ると、急に元気づいて前足を折って巫山戯るようにして高く高く吠えた。",
              "citation": {
                "source": "幼年時代",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは機械｜鋸が木を挽く音」「ふざけるの、よしよ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みちはだんだんのぼりになりつひにはすっかり坂になりましたので楢夫はたびたび膝に手をつっぱって「うんうん」とふざけるやうにしながらのぼりました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿者はね、ふざける事は真面目でないと信じているんです。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "松吉には、おとなになるというのは、ふざけるのをやめて、まじめになる約束のように思われました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくふざけるポチだったのにもうふざけるなんて、そんなことはちっともしなくなった。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふざけるのにも程がある。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と周三はふざける。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "松吉には、大人になるといふのは、ふざけるのをやめて、まじめになる約束のやうに思はれました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも余が閲覧室へ這入ると隣室に居る館員が、無暗に大きな声で話をする、笑う、ふざける。",
              "citation": {
                "source": "入社の辞",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふざけるのも、いい加減にし給え。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふざけるのも、いい加減にし給え。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "児はふざけるだけふざけた。",
              "citation": {
                "source": "前妻の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草寺の天井の絵の天人が、蓮華の盥で、肌脱ぎの化粧をしながら、「こウ雲助どう、こんたア、きょう下界へでさっしゃるなら、京橋の仙女香を、とって来ておくんなんし、これサ乙女や、なによウふざけるのだ、きりきりきょうでえをだしておかねえか。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙にお客あしらいで、私をばお大事のもののようにして、その癖ふざけるから、皆が種々なこと云うんじゃアあるまいかね。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ飲むの、そんなに飲んでて、」「ふざけるない、」　お幸ちやんは笑ひながらまた暖簾をくぐつたが、今度出て来た時には右の手に料理の皿を持ち、左の手に口を切つたビールのビンを持つてゐた。",
              "citation": {
                "source": "蛾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふざけるない、この野郎」　双子も負けてはいなかった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
