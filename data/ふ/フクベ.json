        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "瓠子汎濫の敗に似たる有り。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓠子は即ち瓠子口にして、黄河の水を塞ぐの処、濮陽県の南に在り。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢武帝の時、黄河大に漲り、瓠子を決して、鉅野に注ぎ、淮泗に通じたることあり。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも霧が深うなってめいりました」　高さ四、五｜丈も、周囲二町もあろうと見える瓠なりな小島の北岸へ舟をつけた。",
              "citation": {
                "source": "河口湖",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓠の頭は東にむいている。",
              "citation": {
                "source": "河口湖",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "盤瓠　高辛氏の時代に、王宮にいる老婦人が久しく耳の疾にかかって医師の治療を受けると、医師はその耳から大きな繭のごとき虫を取り出した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婦人が去った後、瓠の籬でかこって盤をかぶせて置くと、虫は俄かに変じて犬となった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬の毛皮には五色の文があるので、これを宮中に養うこととし、瓠と盤とにちなんで盤瓠と名づけていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて盤瓠は一人の首をくわえて王宮に来た。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たとい敵の首を取って来たにしても、盤瓠は畜類であるから、これに官禄を与えることも出来ず、姫君を賜わることも出来ず、どうにも致し方はありますまい」　それを聞いて少女は王に申し上げた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "盤瓠がその首を取って来て、国のために害を除いたのは、天の命ずるところで、犬の知恵ばかりではありますまい。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "盤瓠が死んだ後、少女は王城へ帰ってそれを語ったので、王は使いをやってその子ども達を迎い取らせたが、その時には雨風の祟りもなかった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには去年の秋形がいびつだからといつて、たつた一つ取り残しておいた小さな瓠が、引き拗られたままの蔓と一緒に棚にしがみついてゐて、折柄の風にその不相応に大きな尻を振つてゐるのだつた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてたつたひとりで棚にぶらさがつてゐる瓠の姿をいつまでもいつまでも見つめてゐた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　といつて、瓠を一つ贈つたものだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "許由は悦んでそれを受け、口移しに水を飲みをはると、そのまま瓠をそこらの樹にかけておいた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓠は風にゆられてからからと鳴つた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、たつた一言いつたかと思ふと、ついと立ち上りざま、瓠を樹の枝から取りはづして、そこらに投げ捨ててしまつた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自らの心をさうした大自然の深みと脈搏相通ずる辺においてゐる者にとつては、枝にかけた瓠の調子に乗つて、風に戯れる騒がしさは、彼が持前のほんの一寸した軽はずみに過ぎないにしても、冥想の静けさを邪魔だてするものとして、二度とこの剽軽者にそんな機会を与へないやうに、彼を枝から取おろしたものに相違ない。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　風が吹く度に瓠はまだからからと鳴つてゐる。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓠には瓠の楽しみがある。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓠もそこまではもう追ひかけて来なかつた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実においても、「尚」王家の数代前の御主「※王」など言ふ御人は、離宮で作つた瓠を、那覇の市で売らしめた。",
              "citation": {
                "source": "沖縄を憶ふ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "中古以後、相撲の節会に、左方の力士は葵花、右方の力士は瓠花を頭へ挿して出たが、瓠は水に縁のあるものだつたので、水の神の所属の標らしく、葵は、それに対立する神の一類を示したのだと思はれる。",
              "citation": {
                "source": "草相撲の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代君主の姓から、卵からと言ふより瓠から出たと解せられてゐるのもある。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "中古以後、秋の相撲節に、左方の力士は葵花、右方は瓠花を頭へ挿して出た。",
              "citation": {
                "source": "河童の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それでも猶あの人の頬は引締つて、丁度内側から吸ひふくべでもかけたやうに、肉がこけて見える。",
              "citation": {
                "source": "脱殼",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりひさご、なりにかまはず、すゞむべい　　　　　　　　風のふくべの木蔭たづねて　これを見て、わたしは再び糸瓜の棚が恋しくなったが、その頃はもう麹町の旧宅地へ戻っていたので、市内の庭には糸瓜を栽えるほどの余地をあたえられなかった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりひさご、なりにかまはず、すゞむべい　　　　　　　　風のふくべの木蔭たづねて　これを見て、わたしは再びへちまの棚が恋しくなったが、その頃はもう麹町の旧宅地へ戻っていたので、市内の庭にはへちまを栽えるほどの余地をあたえられなかった。",
              "citation": {
                "source": "我家の園芸",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "へ私は神田八丁堀二丁目五十五番地ふくべ屋呑助と申します、どうかお見知りおかれて御別懇に願います。",
              "citation": {
                "source": "煩悶",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
