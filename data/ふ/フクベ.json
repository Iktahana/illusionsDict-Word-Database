      {
        "index": 1,
        "gloss": "Lagenaria siceraria var. gourda (variety of bottle gourd)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
