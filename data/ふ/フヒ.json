        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鈴木校長が檢事局につれて行かれて、そのつぎに來たのは、戸澤とかいふひとであつた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この、シメノンたらいふひと。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おる」「をる」「とほる」「あふひ」の「お」「を」「ほ」「ふ」は、今日では皆同じオの音であります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "われには机のしたで調べるノオトもなければ、互ひに小聲で相談し合ふひとりの友人もないのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ　この春夜のやうになまぬるくべにいろのあでやかな着物をきてさまよふひとよ妹のやうにやさしいひとよそれは墓場の月でもない　燐でもない　影でもない　眞理でもないさうしてただなんといふ悲しさだらう。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ　この春夜のやうになまぬるくべにいろのあでやかな着物をきてさまよふひとよ妹のやうにやさしいひとよ。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄蔵は、何といふひどいことをするのか、と思つて金ちやんを睨んだ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何といふひねくれたいけない心だらう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "母子の如く往き交ふひろ子との縁の繋がり始まりを今もなほ若蔦の勢よき芽立ちに楽しく顧る為めであらうか。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕のスケツチをいちまい二十圓くらゐで、何枚でも買つて呉れるといふひとがあるのです。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い陰鬱な御性格であつたと言ふひともあるでせうし、また、底にやつぱり源家の強い気象を持つて居られたと言ふひともございませう。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五年といふひどく永い年月、ひた隠しに隠してゐたところを見ると、さすが傲慢不遜の名匠も、くろうと政治家の無意識な軽蔑の眼つきにやられて、それこそ骨のずいまでこたへたものがあつたのであらうと、そぞろ同情の念の胸にせまり来るを覚えるのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「越野たけといふひと、どこにゐるか、ご存じぢやありませんか。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水に揺れあふ風のかげ、花はこもらふひつじぐさ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "みぎはには黄の一重、とろろあふひ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正元年九月人食ふひとこはそもいづくの空なるや、はた何時なりや、誰なるや、人食ふ人ら背も矮くひそと声せず、身じろがず。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さし向ふひがしの峰の。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻に死なれたあとずつとやもめ暮しの父の身の廻りのことを、一切やつて来たといふひとである。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の身体の外に　私を囲んで暖く香よくにほふひと私は　ささやく　おまへにまた一度――はかなさよ　ああ　このひとときとともにとどまれうつろふものよ　美しさとともに滅びゆけ！",
              "citation": {
                "source": "優しき歌",
                "author": "立原道造",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒山といふひゞきの方が、明瞭であるためか、習慣のためか、いかにもおかくの風貌風姿に適はしくて親しみが多いやうにおもつて居りましたが、やがて、おんどるなのかおんどりなのか判然としないのも気にならなくなりました。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "はかなしや人のかざせるあふひ故神のしるしの今日を待ちける注連を張っておいでになるのですもの。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまで若返りたいのであろうと醜く思った源氏は皮肉に、かざしける心ぞ仇に思ほゆる八十氏人になべてあふひを　と書いてやると、恥ずかしく思った女からまた歌が来た。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、伊勢貞丈、武士、厩の神を知りたる人少なしとて、『諸社根元記』と『扶桑略記』より延喜天徳頃｜左右馬寮に坐せし、生馬の神、保馬の神を挙げ、『書紀』の保食神牛馬を生じたるよりこの二神号を帯びたのだろといった（『あふひづくり』上）、この二神は猴でなかろう。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「Ｇ港の手前で、このしけに逢へば、無論そこに碇を下したらうけれども、かういふひどいしけになつたのは、夜半過ぎからだから、Ｇ港からずつと向うに行つてから打突つたんではないかな？",
              "citation": {
                "source": "島の唄",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　どこかの訛の取れない言葉で、あれこれと話して、さういふひよわいお子さんが、お母さまなしに、不自由ばかりして来られたのだから、この人がだれよりもお可哀さうでならないと言ひながら、口を少し開いて、睫毛の長い目を閉つてゐられる坊ちやんの寝顔を見守つた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしてまた、さういふひどい傷我なんかしたんだらう。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十九あはれ、人妻、ふたつなきフランチエスカの物語かたらふひまもみどり兒は聲を立てつつ、かたはらを匍ひもてありく、君はまた、たださりげなし。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
