        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "遂不害（卷六十九、趙孝傳）と見えて居る。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "二六一　人若し諦と法と不害と禁戒と柔善とあれば、彼こそ已に垢を吐きたる聰き長老と謂はる。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            },
            {
              "text": "三〇〇　瞿曇の弟子は恆に善く醒めて覺る、彼等の意は晝も夜も不害を樂ふ。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            },
            {
              "text": "申不害は（三九）京人也。",
              "citation": {
                "source": "國譯史記列傳",
                "author": "老莊申韓列傳第三",
                "note": "青空文庫"
              }
            },
            {
              "text": "染屋をよすならきちんとやめてしまふがいゝ。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あんなに始終つけて置かないのは、〔この間、原稿数枚なし〕永久におまへたちは地を這ふがいい。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつと何かかゝうと思ふがいやになつたからやめ。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなさう言つて笑ふがいい。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "買ひたいものが、あるなら、宿へさう言ふがいい。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だ残念に思ふがいづれ大成してその責を果したいと思ふ。",
              "citation": {
                "source": "黒檜",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿田彦神は、その後、伊勢の阿坂というところに住んでいましたが、あるときりょうに出て、ひらふがいという大きな貝に手をはさまれ、とうとうそれなり海の中へ引き入れられて、おぼれ死にに死んでしまいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまりふがいないものだから、ポータブルという冗談としか思えない名前の付いた小錦クンを見かけるたびにオレはいつもこの野郎をぶんなぐってやっていたのだが、こいつを徹底的なダイエットに追い込んだのは『ダイナブック』をはじめとする一群の絞り上げられたＤＯＳマシンからの圧力だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "出雲崎へつける位なら一層寺泊の方がよからうといふと運賃が十五圓ばかり狂ふがいゝや仕方がねえと胡麻鹽頭のフケを掻き落しながら博勞がいつた。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ何とでも思ふがいゝさ。",
              "citation": {
                "source": "爪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう一刻もかうしては居られないし、約束を破つておれだけで東京へ行くわけにも行かないしするから、これから三人で村長の家までおしかけることに仕様――」といふがいなやＹは、もう自動車に飛び乗つた。",
              "citation": {
                "source": "ブロンズまで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふがいなく思召すでしょうが、私はこうして静かにあなたへ御孝養がしたいのです」　と帝はお慰めになったのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は皮肉を言いながらも自分のふがいなさをつくづく思い知らねばならなかった。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……といっておめおめとその策略に乗ってしまったわたしはなんというふがいない女だったのだろう。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ふがいなや後をも振り向かずに、窓側へ駈け寄ると、耳から引出した金箍棒を二三遍ビュービューと唸らせた、かと見れば忽ち掌に飛雲を起し、と天につらなる白雲へ飛び乗つて、雲程万里鵬の勢ひで南の方麒麟山の空へ駆つた。",
              "citation": {
                "source": "闘戦勝仏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何とでも云ふがいゝさ、僕は自慢ではなく、たゞ単に自らの傑れた力量を自覚したまでなのさ。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何とでも云ふがいゝさ。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と仙二郎の父親が云ふがいなや二人はまつしぐらに駈け出した。",
              "citation": {
                "source": "鞭撻",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ふがいなや彼の胸ぐらへ飛びついた。",
              "citation": {
                "source": "眠い一日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ腹の中で、これしきの女の言う事を、明瞭に批評しえないのは、男児としてふがいないことだと、いたく赤面した。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だつて、斯うなんだもの――」　と云ふがいなや、非常な速やかさで、ぱつと、一瞬間、それを脱ぐ眞似をした。",
              "citation": {
                "source": "痴日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と云ふがいなや、側車に腰をかけた。",
              "citation": {
                "source": "センチメンタル・ドライヴ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母ですら愛想を尽かすに、親なればこそ子なればこそ、ふがいないと云ッて愚痴をも溢さず茶断までして子を励ます、その親心を汲分けては難有泪に暮れそうなもの、トサ文三自分にも思ッたが、どうしたものか感涙も流れず、唯｜何となくお勢の帰りが待遠しい。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さうだ、じゆんはおつ母さんを手傳ふがいい。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が安穩な生の享樂を退け得ぬ限り昔ながらの價値に從ふがいい。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「燒いてしまふがいいや。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
