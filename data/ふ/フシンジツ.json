        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして自分に対するいろいろな彼の不信実を探し索めたりしはじめた。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そして、ゴーリキイの話の中に織り交る、すべての余計な不信実なものを切り去るのであった。",
              "citation": {
                "source": "マクシム・ゴーリキイの発展の特質",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そしてゴーリキイの話の中に織り交るすべての余計な不信実なものを切り去るのであった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫がよくって、不信実で、卑怯で、あとでおきまりの痛悔の祷を唱えさえすればどんなひどい罪でもキレイにつぐなわれると思い込んでいるのですものね。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫がよくつて、不信実で、卑怯で、後でおきまりの痛悔の祷を唱へさへすればどんな恐ろしい地獄の罪でもキレイに賠はれると思ひ込んでゐるのですものね。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "高貴の人々にたいする彼の考えは、この不信実によって深く害された。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方の娘はその不信実さに腹をたてた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "左党の反対は卑劣にして不信実である。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
