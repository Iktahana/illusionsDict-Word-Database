    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to step forward",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "世界の尽きる時が来ても、一寸もこの闇の外に踏み出すことは出来ぬ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして兩腕をひろげて一歩足を踏み出すと、ゆらゆらと氣持よく落下します。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島も氣をとり直して、兩腕をひろげ、魚の掛橋の外に一歩、足を踏み出すと、すつと下に氣持よく吸ひ込まれ、頬が微風に吹かれてゐるやうに涼しく、やがてあたりが、緑の樹蔭のやうな色合ひになり、琴の音もいよいよ近くに聞えて來たと思ふうちに、龜と並んで正殿の階段の前に立つてゐた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せっかく、救けて頂いたようなものの、行先の覚束なさ、途中の難儀、もう一足も踏み出す勇気はございません。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、また、汽車で品川へ戻り、そこから道中｜双六のように一足一足、上りに向って足を踏み出すのである。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの疑問以上に立ち入る事は科学者の領域以外に踏み出すと思う。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると後者はその債務を果たすまでその円以外に踏み出す事が出来ない。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "既にして一歩を踏み出す。",
              "citation": {
                "source": "室生犀星君の飛躍",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一歩を敢然と踏み出すためには、われわれは悪魔を呼ばなければならないだろう。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの天来の閃光なしには彼らは一歩も踏み出す事はできない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしルクレチウスなしにいかなる科学の部門でも未知の領域に一歩も踏み出すことは困難であろう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母に言うことができないとすれば、お幸と二人で土地を逃げる他に仕方がないと一度は逃亡の仕度をして武の家に出かけましたが、それもイザとなって踏み出すことができませんでした。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしなめらかな毛髪や顔や肉体の輪郭を基調とした線の音楽としてのほとんど唯一の形式は、やはり古い浮世絵の領域を踏み出す事は困難に思われる。",
              "citation": {
                "source": "浮世絵の曲線",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそこをくぐることによって、もしそうでなかったら決して生涯見ることのなかったはずの珍しく新しい国を遍歴する第一歩を踏み出すことができるのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蘆の根を、折れた葉が網に組み合せた、裏づたいの畦路へ入ろうと思って、やがて踏み出す、とまたきりりりりと鳴いた。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして両腕をひろげて一歩足を踏み出すと、ゆらゆらと気持よく落下します。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島も気をとり直して、両腕をひろげ、魚の掛橋の外に一歩、足を踏み出すと、すつと下に気持よく吸ひ込まれ、頬が微風に吹かれてゐるやうに涼しく、やがてあたりが、緑の樹陰のやうな色合ひになり、琴の音もいよいよ近くに聞えて来たと思ふうちに、亀と並んで正殿の階段の前に立つてゐた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから先へ踏み出すときは、「僕には親しみが持てない土地です。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "張りついたやうに揃つた隊列を横から見ると一つ躯幹になつたが五六本の赭黒い足を力強く一時に踏み出す。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "割栗石の鋪石へ一歩靴を踏み出す。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男が、いま演劇の世界に第一歩を踏み出すに当って、まずい答案を書いたなら、一生消えない汚点をしるす事になる。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の運びの途中にぴょんと弾ね上げる腰付や、威張ったように踏み出す細脛の所作なぞも見せて行きます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後れがちなのを親分に叱られながら、亭主の男乞食がとき／″＼ぴょんと弾上る腰付や威張ったように細腰を踏み出す例の歩き方を、しくりかえし、とくりかえしてついて行きます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子はそのあとの線路をハイハードルのコツで大きく高く跳ね越えて丁度踏み出す加奈子の靴尖に踏み立つ。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女神は、その岩にさえぎられて、それより先へは一足も踏み出すことができないものですから、恨めしそうに岩をにらみつけながら、「わが夫の神よ、それではこのしかえしに、日本じゅうの人を一日に千人ずつ絞め殺してゆきますから、そう思っていらっしゃいまし」とおっしゃいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しそれ丈では、人間は永遠に因襲の範圍内に囚はれてゐて、一歩もそれより外に踏み出すことは出來ないのですね。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　吉弥は片足を一歩踏み出すと同時に、あごをもよほど憎らしそうに突き出して、くやしがった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しかし又、そうかといってこの青年に、「何故その宝石を僕に見せたんですか」　なぞと質問をするのは、私に接近しかけている危険な運命の方へ、一歩を踏み出すことになりそうな予感がします。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、賢三郎はこれまでの書斎の生活を離れ、若い工場主として実生活への第一歩を踏み出すことになった。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐怖の木の寝台から牢獄の石の床に足を踏み出すとすぐ、あの地獄のような恐ろしい機械の運動がぴったりと止り、なにか眼に見えない力でするすると天井の上に引き上げられるのを私は見た。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
