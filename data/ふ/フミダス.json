[
  {
    "uuid": "7135d601-e6d8-59f0-822a-7997bc5cab69",
    "entry": "踏み出す",
    "reading": {
      "primary": "ふみだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-自動詞",
