    "definitions": [
      {
        "index": 1,
        "gloss": "imprudent fellow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
