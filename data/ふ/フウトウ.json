[
  {
    "uuid": "9d848b29-b06c-5a06-b1bf-4880e7678f41",
    "entry": "封筒",
    "reading": {
      "primary": "ふうとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "envelope",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "眩しいような瓦斯燈の下に所狭く並べた絵具や手帳や封筒が美しい。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い包紙やボール函や封筒なども棄てずに取っておいて使った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　伝令は封筒を出した。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あの封筒に這入ったもの一ツが、梶を反対の方向にねじ向けてしまった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルファベットを操る間絶えず胸に描いていた美しい、魅力のある内地が、あの封筒一ツに覆がえされてしまった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "封筒の表書をすませると、彼はそんな國、そんな町が一體存在したのかどうかも疑はしかつた。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "封筒に裏書はしなかつた。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっさに、うまい嘘も思いつかず、私は隣室の家の者には一言も、何も言わず、二重廻しを羽織って、それから机の引出しを掻きまわし、お金はあまり無かったので、けさ雑誌社から送られて来たばかりの小為替を三枚、その封筒のまま二重廻しのポケットにねじ込み、外に出た。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "封筒、三十一銭などの買い物をして帰った。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と大森は封筒へあて名を書きながら言った。",
              "citation": {
                "source": "疲労",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "園が手紙を取りだした時、星野とだけ書いてある封筒の裏が上になっていたので、名宛人が誰であるかはもとより判りようはずがないのに、園の顔にはふとある混乱が浮んだようにも思え、少しもそんなことがないようにも清逸には思えた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "表に「三隅ぬい様」、裏に「星野」とばかり書いてあるその封筒は、滑らかな西洋紙の触覚を手に伝えて、膚ぬくみになっていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "封筒の片隅を指先で小さくむしっておいて、結いたての日本髪（ごくありきたりの髷だったが、何という名だか園は知らなかった）の根にさした銀の平打の簪を抜いて、その脚でするすると一方を切り開いた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "読み終ると、おぬいさんは折れていたところで手紙を前どおりに二つに折って、それを掌の間に挾んでしばらくの間膝の上に乗せて伏眼になっていたが、やがて封筒に添えてそれを机の上に戻した。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして桃いろの封筒へ入れて、岩手｜郡西根山、山男｜殿と上書きをして、三｜銭の切手をはって、スポンと郵便函へ投げ込みました。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "菫色の横封筒……いや、どうも、その癖、言う事は古い。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近来はどこの温泉旅館にも机、硯、書翰箋、封筒、電報用紙のたぐいは備えつけてあるが、そんなものは一切ない。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて涙を拭いて、封筒の裏を見ると、佐藤正助とある。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると旻の生前使っていた書物机の中から、一通の粗末なハトロン紙の封筒に入った手紙のようなものが出て来た。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、その母親として仕えていたのは、実は子供の時から可愛がられていた情婦に過ぎないのであったが、最近に至って有名な箱師のお玉という、これも変態的な素質を持った毒婦が、模範兵士の新聞記事を見て、大胆にも原籍本名を明記した封筒に、長々しい感激の手紙と、五拾円也の為替を入れて聯隊長宛に送って来た。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は黙って立って、六畳間の机の引出しから稿料のはいっている封筒を取り出し、袂につっ込んで、それから原稿用紙と辞典を黒い風呂敷に包み、物体でないみたいに、ふわりと外に出る。",
              "citation": {
                "source": "桜桃",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもどんどんやるべしと存候　　　　　　　　　　四四〇　明治三十九年十月二十六日　午後三時―四時　本郷區駒込千駄木町五十七番地より本郷區彌生町三番地小林第一支店鈴木三重吉へ　［封筒表左側下に「第一信」とあり］　君の夜中にかいた手紙は今朝十一時頃よんだ。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "草々　　　　　　　　十月二十六日夏目金之助　　　　　鈴木三重吉樣　　　　　　　　　　四四一　明治三十九年十月二十六日　（時間不明）　本郷區駒込千駄木町五十七番地より本郷區彌生町三番地小林第一支店鈴木三重吉へ　［封筒表中央下に「第二信」とあり］　只一つ君に教訓したき事がある。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベッシェール夫人のところで火をつけた二本目の煙草を挟んだ左の手に右の手を手伝わせて妻からの手紙の封筒を切った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "但馬さんは、来る度毎に私を、こっそり廊下へ呼び出して、どうぞ、よろしく、ときまったように真面目に言ってお辞儀をし、白い角封筒を、私の帯の間につっ込んで下さるのでした。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、いつでも知らん顔をして居りますし、私だって、すぐその角封筒の中味を調べるような卑しい事は致しませんでした。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうは合格通知を封筒のまま仏壇にあげて、兄さんと二人で、お父さんに報告をした。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（帯の間から、白い角封筒を出し、歩いて野中教師の傍に寄り）先生、黙って、ね、何もおっしゃらずに、黙って、受け取って頂戴！",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊代さん、まあいいから、その封筒はそちらへ引込めて下さい。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊代、封筒を持てあまして、それを、傍の学童の机の上にそっと置く。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
