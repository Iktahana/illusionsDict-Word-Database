[
  {
    "uuid": "d49fae68-7ac6-510d-85cb-64fb97ffbe6c",
    "entry": "伏線",
    "reading": {
      "primary": "ふくせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "foreshadowing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こう言って後に論ぜんとする霊魂非不滅論の伏線をおいている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "事件的には縁がない代わりに心理的の伏線になるのである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時間のち、同じところで二十枚のばいきんだらけのくしゃくしゃ汚き紙片、できるだけむぞうさに手交して、宅のサラリイ前借りしたのよ、と小さく笑った萱野さんの、にっくき嘘、そんな端々にまで、私の燃ゆる瞳の火を消そうと警戒の伏線、私はそれを悲しく思った。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "技術の伏線的で的確な点では独立随一の技術家であらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "これぞというトリックなしに最後まで読者にサスペンスをもたせることができれば、それに越したことはないが、現実の事件にはそうした場合はほとんどないから、まず多少の伏線を示しておいて、最後にトリックであっと言わせるということが多くの場合必要になってくる。",
              "citation": {
                "source": "現下文壇と探偵小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "この話は話の内容には何の伏線もないので、どんなに読者が考えたって、わかりっこはないのである。",
              "citation": {
                "source": "現下文壇と探偵小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　彼の作品にはわざとらしい伏線がない。",
              "citation": {
                "source": "ヴアン・ダインの作風",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、第一頁から犯人があがるまで全体が伏線のようなもので、どの一頁、どの一行、登場人物のどんな一言一行でも、漫然と読んでいるわけにはゆかない。",
              "citation": {
                "source": "ヴアン・ダインの作風",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪過は即ち結果に対する源因を言ふなり、末路に対する伏線を言ふなり。",
              "citation": {
                "source": "罪過論",
                "author": "石橋忍月",
                "note": "青空文庫"
              }
            },
            {
              "text": "此伏線此源因は如何にして発表せしむべきや。",
              "citation": {
                "source": "罪過論",
                "author": "石橋忍月",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れ彼が無惨の死に終りし動力なり、源因なり、伏線なり。",
              "citation": {
                "source": "罪過論",
                "author": "石橋忍月",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリストテレスの罪過を広意に敷延すれば即ち結果に対する原因なり、末路に対する伏線なり（復た其不幸に終ると幸福に終るとを問はず）。",
              "citation": {
                "source": "罪過論",
                "author": "石橋忍月",
                "note": "青空文庫"
              }
            },
            {
              "text": "なめくじという妙な動物の不思議な習性についての最初の説明はそれ自身で面白いのみならず、それがこの作品の伏線として役だっているのだから、無駄のない書き方だといわねばならぬ。",
              "citation": {
                "source": "新人の諸作一括",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも「愛用の卓子を汚す」ということは、なかなかハデな伏線材料であるから、そういうハデな材料はもっとハデに生かさなければ面白くない。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや、この全篇を通じて探偵小説らしい伏線は、この卓子を汚すということだけなのであるから、それが生きんようでは探偵小説にならない。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "列挙せられた新聞紙の記事は所謂この物語の第二の伏線とも見るべきものであって、第一の伏線たるマリー失踪前後の記述と相まちて、この長い物語の美しい「あや」を形っているのである。",
              "citation": {
                "source": "「マリー・ロオジェ事件」の研究",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　参木は突然げらげら笑い出した山口の顔を見ていると、彼は腹の中に隠れていた伏線を感じて恐くなった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの際は常識以上に溯って研究する必要を認めませんから、これから出立するつもりでありますが、今申した我と云うものについて一言弁じて後の伏線を張っておきたいと思います。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏線に伏線が重なりもつれ合う、そして読者が五里霧中になる。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つがもつれると、他が少しほぐれ、そして又その上に伏線が重なる、といった具合に、常にある部分の期待と期待につらなる不安――サスペンスを持たせるためには、トリックが重要な役割をする。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "小壺の沖中の、身投げが、実朝が、公暁の手を借りて自滅の本意を達する、といふ周到な作者の伏線になつて居よう、とは思ひもかけませんでした。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この部分から少年指揮官の家が北軍側についていることがわかり、これが伏線になっています。",
              "citation": {
                "source": "チカモーガ",
                "author": "Ａ. ビアス　A.Bierce",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しその真理は真理としておいて、君があの時いったことは、みな、今日の伏線だったんだね。",
              "citation": {
                "source": "碑文",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その点よく御了解を得たい」　と、巧みにことわりを述べて、伏線とした。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏線のやうなものが必要なのである。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃア、ま、このことは他言は絶対無用だぜ」　法本はこう日野に念をおしたそうですが、以上はまア法本一流の伏線、小細工と申すものです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に気になるのは、或ることを云ふため、或ることが起るために、絶えず見え透いた準備的伏線が張つてあることで、少し物わかりのいゝ見物は見物の方が先へ行つて待つてゐます。",
              "citation": {
                "source": "懐かし味気なし",
                "author": "五年振で見る故国の芝居",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ疑念もさることながらこの婦人の例の如く淡々とした歯切れのよい語調の裏には、最も繊細な叡智によつて包まれた微妙な揶揄が、私の野暮な疑念に向つて已にその複雑な伏線をふせてゐるやうにすら思はれたのだつた。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
