    "definitions": [
      {
        "index": 1,
        "gloss": "floppy (disk)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "文字だけの電子本なら、どんなに分量が多くても一般的に使われているフロッピーディスク一枚に、まず余裕を持っておさまります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "まとめて買えば、フロッピーディスクは今、四十円はしません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さて読んでみようか」とパッケージを開き、私は中から取り出したフロッピーディスクを小さなコンピューターに差し込みました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブックを開く際は、まずフロッピーディスクをマシンに差し込みます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "標準的に使われているフロッピーディスクの容量は、一・四メガバイトです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "広く使われるようになってきたＣＤ―ＲＯＭならさらに、フロッピーディスクの五百倍近い六百五十メガバイトまで入ります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に、たくさんの本をフロッピーディスクやＣＤ―ＲＯＭのような小さなメディアにおさめられる点。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "音やグラフィックスや文章による注釈を付けた彼の作品が、フロッピーディスクに収められました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字による解説や楽譜と、実際の演奏を緊密に連携させ、クラシック音楽を構造的に理解させようとする『ベートーヴェン交響曲第九番』は、フロッピーディスクと音楽ＣＤの組み合わせからなっていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "フロッピーディスクの五百倍近い容量を持つＣＤ―ＲＯＭが使えるとなると、電子出版物でも動画や音にころうという意識が強まりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえフロッピーディスクが常識のあいだは、動画を入れたいなどとははなから考えもしません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "新旧の原稿に写真を組み込んでいくと、すでにその時点で、一枚のフロッピーディスクにはとてもおさまらなくなっていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当初ボイジャーは、フロッピーディスクにおさめたエキスパンドブックをどんどん出していきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ＭＯＰ』と言う雑誌を買ってくると、「インタラクティブ・マルチメディアの可能性」と題したインタビュー原稿がエキスパンドブックに仕立てられ、付録のフロッピーディスクに入っていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一は、フロッピーディスクなりＣＤ―ＲＯＭなりに書き込んだブックの販売代行です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "五万八千円の一太郎と九万八千円の１―２―３が何でまた記者発表の机におかれているのかと思ったら、「たかだか原価二千〜三千円のソフトにこんな値段を付けるなんて、馬鹿げた高売りだ」と宣言するやマニュアルとフロッピー・ディスクを記者の目の前にほうり投げて、「写真取ってね」ときたもんね。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＣカードの採用でフロッピーディスクの駆動装置を外し、現状のノートブック型をもう一つ絞り上げるのは当然考えられるところ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネットワークが栄え、フロッピーディスクを媒体とする電子雑誌が誕生し、出版業界ではフロッピーで原稿を納める芸当が可能となった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "メモリを五百十二キロバイトに拡張した第二世代機に、プリンターと外部フロッピーディスク・ドライブ一台をくっつけたバンドル特価（言うまでもなくアップル用語で、特別に高いという意味だ）は、百万円を越えていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "てなうちにフロッピーディスクとＣＰ／Ｍが現われて、アプリケーションが商品になった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コード化の作業をライターにやらせれば、これまで印刷屋が受け持っていた作業のなにがしかを省くことができると出版社が気づいてからは、フロッピーディスクで渡すか電話回線で原稿を送るかになった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在、フロッピーディスクやＣＤ‐ＲＯＭのかたちで流通している電子本は、「エキスパンドブック」を先頭に、これまでの紙と活字の本のかたちをできるだけ忠実に模倣しようとつとめている。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "エド・ロバーツは一九七五年の秋には、フロッピーディスクをアルテアで使えるようにしようと考えはじめていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方大型コンピューターやミニコンピューターで使われているフロッピーディスクが使えれば、読み書きの効率が大きく改善できることは明らかだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしそのためには単にアルテアにフロッピーディスクの駆動装置（ドライブ）がつながるようにするだけではなく、情報の読み書きの管理を受け持つソフトウエアを用意しておく必要があった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アレンはかねてから、フロッピーディスクドライブの管理機能をベーシックに持たせるように、ゲイツに注文を出していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが当初は高嶺の花だったフロッピーディスクをパーソナルコンピューターでも使おうとしはじめたころから、ユーザーは基本ソフトを意識しはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
