      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "aimlessly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ふらふらっとして実際崖から落っこちそうな気持になる。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "テエブルに並べられたビイル瓶が六本になれば、日本酒の徳利が十本になれば、私は思い出したようにふらっと立ちあがり、お会計、とひくく呟くのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとカン蛙の載った木の葉がガサリと鳴り、カン蛙はふらふらっと一寸ばかりめり込みました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土神は何とも云へずさびしくてそれにむしゃくしゃして仕方ないのでふらっと自分の祠を出ました。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとカン蛙の載った木の葉がガサリと鳴り、カン蛙はふらふらっと一寸ばかりのめり込みました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土神は何とも云えずさびしくてそれにむしゃくしゃして仕方ないのでふらっと自分の祠を出ました。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとかっこうはどしんと頭を叩かれたようにふらふらっとしてそれからまたさっきのように「かっこうかっこうかっこうかっかっかっかっかっ」と云ってやめました。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがの歩哨もとうとうねむさにふらっとします。",
              "citation": {
                "source": "ありときのこ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "急にふらふらっと眩暈がした咄嗟に、こんな夫婦と隣り合ったとは、なんという因果なことだろうという気持が、情けなく胸へ落ちた。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同がそんなことをしているうちに、ベン・プライスがふらっと入ってきて、肘をついて、木の柵の間から、さりげなく中をうかがっていた。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "途端にふらふらっとしてしまった。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んだかしら、あたしもそのせいか、ときどきふらふらっと、眼暈いするみたいに行きたくなることがあるの。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来心って――つい、ふらふらっと、出来心だ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、手を折るなんて――」「ふらふらっと、出来心じゃ」　小藤次の顔が、さっと赤くなると「何っ」　と、叫んだ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをじっと見下ろしていると、ふらふらっと奇妙な衝動に駆られて、慌てて赤石沢側へ向きなおった。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んでもないようにふらっと出かけていって、お墓まいりだけをして、ふらっと帰ってくる。",
              "citation": {
                "source": "花を持てる女",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふらふらっと迷いこむ、ただそいだけのことでさあ。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟の血を見て、ふらふらっとなったからである。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変わらず蒼白い顔に、不得要領の笑みを浮かべて、ふらっと懐手をしたまんま。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "と刀を凝視めると、またふらふらっとなって、真っ向から播磨守に二の太刀を浴びせる。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来が風のような先生で、空の下、地の上ならば、どこでも自分の家と心得ているのですから、到るところへふらっと現われるのは、当然で。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのチョビ安が、ある日ふらっと、例によってところてん売りにでかけたきり、とんがり長屋へ帰ってまいりませんから、お美夜ちゃんはたいへんな悲観と心配。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月のある夕ぐれ、ふらっと亀島町の薬種問屋近江屋の前に立って、鈴を振るような声で例のよしこのくずしを唄い出したというだけで、はたしてどこから来てどこへ帰るのか、またはどういう身分の女がなにが動機でこうも浅間しく気が狂ったのか、それらのことはいっさいわからなかった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "お茶漬音頭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なんでも、ボーイの話では、そのモダン・ガールがふらっとはいってきたのは、ちょうど十時頃で、そのすこし以前から、南風太郎と小頭と二人で、もう始めていたということだった。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "お先供はどこまでも、宮川べりをのぼりつくすかと見れば、国分寺通りの四角へ来て、火の番の拍子木を聞くと急に右へ折れて花岡の方へと真向きに行く――ここをふらっと行き尽せば灘田圃だ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく居る模様　少し経って、ムーアが当該のカフェにふらっと入った。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物係クラクストンが部屋の片隅からベイヘムの方へふらっと歩いた。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瞬ふらっと倒れそうになり、両手を握り、気を張った。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "無腰だし、手拭を持ってふらっと出た恰好であるが、その眼つきと歩きぶりは前をゆく秀之進を覘っていた。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
