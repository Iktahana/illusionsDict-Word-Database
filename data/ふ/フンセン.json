[
  {
    "uuid": "36c99bd5-5b29-536c-a672-b5d4fabfc903",
    "entry": "奮戦",
    "reading": {
      "primary": "ふんせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
