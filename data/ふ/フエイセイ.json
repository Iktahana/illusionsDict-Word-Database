    "definitions": [
      {
        "index": 1,
        "gloss": "unsanitary condition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
