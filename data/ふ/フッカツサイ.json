        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "主な仕事は毎年復活祭の前の土曜の午後六回の講演をするのと、その外に一回金曜の晩専門的な研究結果の講演をするだけであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十一日　きょうは復活祭だという。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯には小羊の乗った復活祭のお菓子が出る。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（私は一五四八年の復活祭の前夜バジル神学校の寄宿舎で彼と食卓を囲んだ。",
              "citation": {
                "source": "痴酔記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日は復活祭で御座いますから、何卒あと二三の質問を御許し願ひたいものです。",
              "citation": {
                "source": "痴酔記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "復活祭の節、キリスト教徒が鶏卵を食い相｜贈遺するに付いて、諸他の習俗、歌唄、諺話、欧州に多いが、要するに天の卵より雛の生まれ出るにキリストの復活を比べ、兼ねて春日の優に到ると作物の豊饒を祝うたのだ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "また受苦週（耶蘇復活祭の前週）の間、鼠、蛇等有害動物の名を言わず、これを言わば年中その家にそんな物が群集すると伝う（一八七〇年板ロイドの『瑞典小農生活』二三〇頁、二五一頁）。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "復活祭にキリストを祭るにただ一羊を牲するに、魔王の祭祀には三十羊を牲す。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "三大節、歌留多会、豆撒き、彼岸、釈迦まつり、雛と幟の節句、七夕の類、クリスマス、復活祭、弥撒祭なぞと世界的である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "天が彼女に、ふだんは焦茶いろの細かい襞をとつた婦人服を身に著け、復活祭と自分の命名日には赤いカシミヤのショールを纒ふやうに運命づけたのは、大きなあやまりであつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "復活祭前に新調胴衣を着たと言うて、或裁縫師と掴み合ひ、新しい靴に古い紐を附けをったと言うて、誰某とも爭論み合うた。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "代助は面白さうに、二三日｜前自分の観に行つた、ニコライの復活祭の話をした。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は生活上世渡りの経験よりも、復活祭当夜の経験の方が、人生に於て有意義なものと考へてゐる。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の復活祭までにはその仕事が出来上るであろうと云った私の言葉を聴いて、カンテル氏は本屋らしくもこの書物の名を（多少は違っていたが）すでにライプチッヒ書籍市場の目録に載せている。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで原稿はきっと復活祭（翌三月）まで手許に置かねばならぬであろう」。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば復活祭に間に合うように出版出来るであろう。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただモスコウまで何日、あるいは何十日かかるか、それはひとえに時の運とそうして汽車の感情によるのだから、復活祭に乗込んでＸマスの前夜に着くかも知れない。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい先ごろも復活祭の式の最中に各会堂へ共産党員があばれこみ、口笛に合わしてだんすをはじめ礼拝を妨害した事件があったという。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "復活祭から十月までの毎日曜日と祭日が正規の闘牛日だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十四　復活祭も近づいて来ていた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十九「国の方で炬燵にでもあたっている人は羨ましいなんて、よくそんな話を君にしましたっけが、もうそれでもパアク（復活祭）が来るように成りましたね」　こう岸本は岡に言って、やがて連立って下宿を出た。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "復活祭・降誕祭は、反宗教宣伝の日となり、クレムリンの外壁にあった辻堂などもとりはらわれた。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "逸話は、いかにもこの国風な復活祭の卵のように色つきで、或る者のは白、或るもののは緑、或る者のは真赤だ。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大会堂に信者が溢れて、復活祭でも行われる時は壮観であろう。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに復活祭やニコラウス様の日に生れるのは、別段に難有いのだからね。",
              "citation": {
                "source": "聖ニコラウスの夜",
                "author": "SANKT NIKOLAUS BEI DEN SCHIFFERN",
                "note": "青空文庫"
              }
            },
            {
              "text": "（註）Whitsuntide は四月初旬に當る基督復活祭五十日後に行はれ、詳しく云へば聖靈降臨祭と譯すべきものなり。",
              "citation": {
                "source": "アーサー王物語",
                "author": "KING ARTHUR'S ROUND TABLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "可愛い倅はごく内気な律儀者で、こないだの復活祭の休暇には、彼女の許へ帰省していた。",
              "citation": {
                "source": "情状酌量",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは恰度こちらの息子さんが復活祭の休暇で帰っていたときのことなんだからね」　それを聞くと、フランソアズ婆さんはすっくと起ちあがった。",
              "citation": {
                "source": "情状酌量",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "神父は、バサウリュークが復活祭にさへお寺へ顔出しをせぬのを知ると、少し窘めて彼に懺悔をさせようと思ひついたものぢや。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして復活祭の前の晩になると、神様がその樹をつたつて地上へ降りていらつしやるんだつて。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
