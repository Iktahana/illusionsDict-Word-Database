  {
    "uuid": "f4127e85-7d27-5b46-8058-1c578759a975",
    "entry": "複葉",
    "reading": {
      "primary": "ふくよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
