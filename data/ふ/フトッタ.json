        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は、めきめき太った。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死なないばかりか、少し太った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと神戸の元町のボントン・バーにいた、肥太った女がひどく酔って悪臭を放っていた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "でっぷり太った大隊長が浅黒い男の傍に立っていた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果、肥え太ったブルジョアジーは、どんな政策をとってくるか？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから瀬川の鉄橋のたもとから髪の長いせいの低い太った人が出て来ます。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめの中は一廻も太ったように思われて痒さが耐らなかったが、しまいにはげっそり痩せたと感じられてずきずき痛んでならぬ、その上を容赦なく歩行く内にも入交りに襲いおった。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうですが、……」　呼びかけられた烏は中年の、太った紳士である。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろに二人、でっぷり太った男が立っているでしょう？",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、ひどく太ったものです。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄地セルの華奢な背広を着た太った姿が、血みどろになって倒れて居るのを、二人の水夫が茫然立って見て居た。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "税務署長がまた見掛けの太ったざっくばらんらしい男でいかにも正直らしくみんなが怒るかも知れないなんといふことは気にもとめずどんどん云ひたいことを云ひました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんなかに坐っている太った男は、最近めっきり流行して来た劇作家兼演出家の、横沢太郎氏にちがいない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるまる太ったいい子です。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十五、六くらいの太った百姓女である。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭教師のほうは、二十七八の、白く太った、落ちついている女性で、ロイド眼鏡を掛けていた。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三木は不在であったが、小さく太った老母がいた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるまると白く太った美男の、肩を力一杯ゆすってやって、なまけもの！",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな綺麗な男となら、わたしはいつでも一緒に死んであげるのにさ』とでっぷり太った四十くらいの、吹出物だらけの女中がいって、皆を笑わせていました。",
              "citation": {
                "source": "貨幣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに太った氷屋の老婆がおどおどして立っていた。",
              "citation": {
                "source": "変災序記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中は、その太った躯を揉みこなすように、も一つ腰を屈めながら、「それに、あの、お出先へお迎いに行くのなら、御朋輩の方に、御自分の事をお知らせ申さないように、内証でと、くれぐれも、お託けでございましたものですから。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は患者、生気を抜いた野菜のように徒らにぶくぶく太った二十五六の年頃の女で、ぼけた芒の穂のような光のにぶい腫れぼったい眼で微かに加奈子を見た薄気味悪さ。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪を櫛巻にした小さい頭の下に太った顔の附いているのが、いかにも不釣合である。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "八畳の奥は障子なしにすぐに居間であって、そこには、ちゃぶ台を据えて、そのそばに年の割合いにはあたまの禿げ過ぎた男と、でッぷり太った四十前後の女とが、酒をすませて、御飯を喰っている。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "太った身体をよちよちさせて、駈け上って来た旧い顔の女中に、もどかしげに、「南條先生は、何時に発った！",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "経を読んでる間は近寄れないが、もう追っつけ黎明に近い、坊主ももう睡ったに相違ない、睡っていたらお前達にも、彼の太った旨そうな奴を啖わしてやる、何人か往って容子を見て来い」　一つの首が合点合点して舞いあがり、蝙蝠のように家の方へ飛んで往ったが、間もなくあわただしく飛び帰って来た。",
              "citation": {
                "source": "轆轤首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊子の太った足も、場末の閑散な冬のレヴュ小屋で見れば、赤く寒肌立って、かえって見ている方が悲しくうらぶれてしまう。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが泊に着くと、大形の浴衣に変って、帯広解で焼酎をちびりちびり遣りながら、旅籠屋の女のふとった膝へ脛を上げようという輩じゃ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき、すすけた古い型のバスが、ふとった図体をゆすぶりゆすぶり走って通る。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と小さく叫んで、ふとったおじいさんを指さします。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
