      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "daring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「えへへ、」と龜は不敵に笑ひ、「せつかく助けてやつたは恐れいる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、あの不敵な少年は、全で解らなかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "大胆不敵な彼も、多数の前には恐怖した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」は、強情不敵な奴。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "法螺吹で、頭のいいことは無類で、礼儀知らずで、大酒呑で、間歇的な勉強家で、脱線の名人で、不敵な道楽者……ガンベはそういう男だったのだから、少なくとも人が彼をそう見ていることを知っていたから。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯見る、海蛇丸の船首よりは、閃々と流るゝ流星の如き爆發信號が揚つた、此信號は他船の注意を喚起する夜間信號、彼れ大膽不敵なる海賊船は、今や何故か其信號を揚げて、我が帝國軍艦の視線を惹かんとして居るのである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "すねた顔色、ふてた図体、そして、身軽な旅人の笠捌きで、出女の中を伸歩行く、白徒の不敵らしさ。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはそもそもいかにしてかかる不敵の振舞をなせしかを疑いぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその拷問はなるべく笞打と石抱きとにとどめておく方針であるから、先ず笞打を行い、それでも屈伏しないものに対しては更に石抱きを行うのであるが、あまり続けさまに拷問を加えると落命する虞があるので、よくよく不敵の奴と認めないかぎりは、同時に二つの拷問を加えないことになっていた。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを本紙の記事によって知った警察当局では、極秘裡に彼女の所在を厳探中であったが、あくまでも大胆不敵なお玉は、その中を潜って西村と関係を結んだらしく、すっかり西村を丸め込んでしまった揚句、二人で自動車に同乗して、贋の母親を嘲弄しに行ったのが一昨日曜の午前中の事であったという。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えへへ、」と亀は不敵に笑ひ、「せつかく助けてやつたは恐れいる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等の親分剛毅な慧捷の視線でもつてもとより不敵の彼れが合圖をした「やい子分の奴ら！",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより不敵で豪膽な奴らはぬけ目のない計畫から勇敢から、快活から、押へきれない欲情から自由に空をきる鳥のやうだ。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより大膽不敵な奴で計畫し、遂行し、豫言し、思考し、創見する。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は大胆不敵になり、無謀にもただ一人、門を乗り越えて敵の大軍中に跳び降りた。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――」　これは詩人クローデルが大胆不敵にいひ除けた、「主は現代の停車場にも、劇場にもある」といつた、韻致カソリシズムの象徴かと桂子は想ふ。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」男みたいに不敵に笑った。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本より此の異僧道衍は、死生禍福の岐に惑うが如き未達の者にはあらず、膽に毛も生いたるべき不敵の逸物なれば、さきに燕王を勧めて事を起さしめんとしける時、燕王、彼は天子なり、民心の彼に向うを奈何、とありけるに、昂然として答えて、臣は天道を知る、何ぞ民心を論ぜん、と云いけるほどの豪傑なり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "――鶏の声を聞きながら、大胆不敵な鼾で、すやすやと寝たのである。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ドアをぴたとしめて、青年の顔をちらと見て、不敵に笑い、「うまい！",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手拍子拍つやう、腰の麻袋をはた／＼と敲いたが、鬼に向つて臀を掻く、大胆不敵の状が見えた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はあれほど世話になった花子夫人の玄関へ御礼の言葉一ついい掛けるでもなく、それこそ不敵な面構えをして、さっさと歩き去りました。",
              "citation": {
                "source": "おせっかい夫人",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな可愛いい子が……」　煙草や飴玉をひそかに留置場へ持ってはいっている大胆不敵さに、陽子は驚いたのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェームスジョイスなどこの紋切型を破ろうとして大胆不敵な「ユリシイズ」を書いたが（「……」と彼は言った）などという月並みな文章がやはりはいっていて、何から何まで小説の約束から逸れるというわけには参らなかったようだ。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお久美と申しまするは、まだ二十歳かそこらの美形と承りましたが、世にも珍らしい不敵者で、この評判を承りますると殊の外気の毒がりまして、お相手のお名前は妾が存じておりまする。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯山に出でた謙信は、善光寺にも止らず、大胆不敵にも敵の堅城たる海津城の後方をグルリと廻り、海津城の西方十八町にある妻女山（西条山ともかく）に向った。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "正に大胆不敵の振舞で敵も味方も驚いた。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」酔っぱらっている故もあろうが、姉を姉とも思わぬ不敵な妹に、新子は暗然となって、もう口が利けなくなった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "役人達は怪量を不敵な曲者として捕え、翌日｜白洲へ引き出した。",
              "citation": {
                "source": "轆轤首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞で廣告して取り消してやらうかと云つたら御免と云ふてきました。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
