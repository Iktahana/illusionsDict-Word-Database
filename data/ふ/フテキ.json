[
  {
    "uuid": "9a267e7e-d2ad-5fda-a72f-681d038165d2",
    "entry": "不敵",
    "reading": {
      "primary": "ふてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
