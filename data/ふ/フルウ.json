[
  {
    "uuid": "ac463d54-7ade-5b60-bd36-b543fb706605",
    "entry": "震う",
    "reading": {
      "primary": "ふるう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-自動詞"
      ],
