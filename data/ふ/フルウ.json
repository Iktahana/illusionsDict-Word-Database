      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to shiver",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "川は、底を傾けて、水を震うので、森の中まで、吹雨が迷い込んで、満山の樹梢を湿す。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぬいさんの家から遠ざかるにしたがって、小刻みに震う前髪がだんだんはっきりと眼につきだして、とうとうそのまま歩きつづけてはいられなくなったからだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空ざまに目も恍惚、紐を結えた頤の震うが見えたり。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おののき震うと同じ状なり。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……天麩羅とも、蕎麦とも、焼芋とも、芬と塩煎餅の香しさがコンガリと鼻を突いて、袋を持った手がガチガチと震う。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　真蒼になって、身体のぶるぶると震う一樹の袖を取った、私の手を、その帷子が、落葉、いや、茸のような触感で衝いた。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐怖と、恥羞に震う身は、人膚の温かさ、唇の燃ゆるさえ、清く涼しい月の前の母君の有様に、懐しさが劣らずなって、振切りもせず、また猶予う。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう捻平に声懸けられて、わずかに顔を振上げながら、きりきりと一まず閉じると、その扇を畳むに連れて、今まで、濶と瞳を張って見据えていた眼を、次第に塞いだ弥次郎兵衛は、ものも言わず、火鉢のふちに、ぶるぶると震う指を、と支えた態の、巻莨から、音もしないで、ほろほろと灰がこぼれる。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、膚が透く、心が映る、美しい女の身の震う影が隈なく衣の柳条に搦んで揺れた。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "舳艫相銜みて、金鼓大に震う。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "見霽へ上る、この男坂の百四段も、見たばかりで、もうもう慄然とする慄然とする、」　と重そうな頭を掉って、顔を横向きに杖を上げると、尖がぶるぶる震う。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　ぶるぶる震うと、夫人はふいと衾を出て、胸を圧えて、熟と見据えた目に、閨の内をとしたようで、まだ覚めやらぬ夢に、菫咲く春の野をうごとく、裳も畳に漾ったが、ややあって、はじめてその怪い扱帯の我を纏えるに心着いたか、あ、と忍び音に、魘された、目の美しい蝶の顔は、俯向けに菫の中へ落ちた。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅馬数字も風の硝子窓のぶるぶると震うのに釣られて、波を揺って見える。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍女の膝にて、袖を見、背を見、手を見つつ、わななき震う。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここは駄目ですよ、どこかへまいりましょう」　家内が私に言いかけた時、また地が震うて来た。",
              "citation": {
                "source": "変災序記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元慶四年十月の地震は、京都と出雲が震い、同年十二月には、京都付近が震うた。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちで七年十月には伊勢国に大地震があって、京都の地も震うた。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月四日の地震は、その日に東海、東山の両道が震い、翌日になって、南海、西海、山陽、山陰の四道が震うたが、海に沿うた国には海嘯があった。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "件の油煙で真黒で、ぽっと灯の赤いランプの下に畏って、動くたびに、ぶるぶると畳の震う処は天変に対し、謹んで、日蝕を拝むがごとく、少なからず肝を冷しながら、「旅はこれだから可いんです。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "嚔もならず、苦り切って衝立っておりますると、蝙蝠は翼を返して、斜に低う夜着の綴糸も震うばかり、何も知らないですやすやと寐ている、お雪の寝姿の周囲をば、ぐるり、ぐるり、ぐるりと三度。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩は上大須の村に泊ると、夜中から山も震うような大あらしになった。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆はかすみ目をしばたたいて我々を見ると、震う荒れた手で懐をまさぐりながら立っていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "『類函』に虎能く人気を識る、いまだ百歩に至らざるに伏して※ゆれば声山谷に震う、須臾して奮い躍りて人を搏つ、人勇ある者動かざれば虎止って坐り逡巡耳を弭れて去ると。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "息が発奮んで、身内が震う処から、取ったのを放してくれない指の先へ、ぱっと火がついたように、ト胸へ来たのは、やあ！",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　樹島は肩の震うばかり胸にこたえた。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪も揺めき蒲団も震うばかりであるから、仔細は知らず、七兵衛はさこそとばかり、「どうした、え、姉やどうした。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢にも逢いたい母様と、取詰めて手も足も震う身を、その婆さんと別仕立の乗合腕車。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　大阪の大歓迎　大阪梅田｜停車場に着きけるに、出迎えの人々実に狂するばかり、我々同志の無事出獄を祝して万歳の声天地も震うばかりなり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お金はまだ降っているかしらと思って、耳を澄まして聞いているが、折々風がごうと鳴って、庭木の枝に積もった雪のなだれ落ちる音らしい音がする外には、只方々の戸がことこと震うように鳴るばかりで、まだ降っているのだか、もう歇んでいるのだか分からない。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "御城の杉の梢は丁度この絵と同じようなさびた色をして、お濠の石崖の上には葉をふるうた椋の大木が、枯菰の中のつめたい水に影を落している。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
