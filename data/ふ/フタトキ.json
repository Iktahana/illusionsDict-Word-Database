    "definitions": [
      {
        "index": 1,
        "gloss": "fairly long period of time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それで何時も目が覚めるのは、大抵午後の二時頃だ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは、ふたりながら死んだように黙って呑んでいたのであるが、二時間くらいたってから、馬場はそろそろしゃべりはじめた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "読書は夜中、朝寝て正午頃起きて、それより夜の十二時頃迄歩くなり。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日何もしないで煙草ばかり吹かして寝たり起きたり四畳半に転がっている事もあれば、朝から出かけて夜の二時頃まで帰らぬ事がある。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく十二時となりて、プラットフォームに出でんとすればこの次のなりとてつきかえされし、重ね／＼の失敗なりける。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことを繰返し繰返し十二時過ぎても眠られないで待っている。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと出帆したのが十二時半頃。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は、また速達で校正刷が來て、十二時ちかくまで、それにかかつてゐた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生憎時計を見ると、かれこれ午後二時に近い、空気も稀薄になり始めて、絶頂まで、遅々たる足取りでは、今夜中にホテルまで、戻り得られるか否かも、覚束ないので、ここから下山することにした。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼んで置いたので、翌くる朝午前二時に起してくれたが、大裾野は鼻を摘まれても解らないほど、闇黒がどこまでも拡がっているので、少なからず頭を悩ました。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の二時頃であった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時間や三時間で、死んで臭くなりゃ、酒あ一日で出来らあ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前五時、午前九時、正午十二時、午後三時、午後六時には取入口から水路、発電所、堰堤と、各所から凄じい発破の轟音が起った。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時間は二分とはなかった、が彼には二時間にも思えた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ状態が一時間二時間三時間と經過しても一向に變りがない。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "假に、一人宛て百囘の音を寄與するとして、百五十で一萬五千囘、此れを假に午後二時から五時迄の三時間、即ち一萬八百秒に割當てると毎一秒間に平均一囘よりは少し多くなる勘定である。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此處で畫架を立てゝ二時間餘りを無心に過した。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして日の暮れる迄働いておいて朝はもう二時頃から起きて大根の車の後押をして市場へ出るのであらう。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで日本のような、世界的に有名な地震国の小学校では少なくも毎年一回ずつ一時間や二時間くらい地震津浪に関する特別講演があっても決して不思議はないであろうと思われる。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大晦日の夜の十二時過ぎ、障子のあんまりひどく破れているのに気がついて、外套の頭巾をひっかぶり、皿一枚をさげて森川町へ五厘の糊を買いに行ったりした。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは『二時間目事件。",
              "citation": {
                "source": "ある男の死",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新学期がはじまつてから二ヶ月程後のある日、朝から二時間目の歴史の時間に起つたこと。",
              "citation": {
                "source": "ある男の死",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その先生が、或る日、つまり新学期がはじまつて二ヶ月程してからの六月始めの朝から二時間目の歴史の時間に。",
              "citation": {
                "source": "ある男の死",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時間目事件が学校内の雑多な評判のなかからすつかり消えた頃、神経衰弱で東北の方へ転地して居た溝口先生が、なくなられたと学校へ聞えて来ました。",
              "citation": {
                "source": "ある男の死",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が何故か生徒間では、こはいものにさはりでもするやうに、二時間目事件を口にするものはありませんでした。",
              "citation": {
                "source": "ある男の死",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそういう考えを裁くために、東京から汽車で二時間ほどで行ける海岸の旅館へ来た。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その正面の青じろい時計はかっきり第二時を示しその振子は風もなくなり汽車もうごかずしづかなしづかな野原のなかにカチッカチッと正しく時を刻んで行くのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "車室の中はスティームで暖かく、わづかの乘客たちも大てい睡り、もう十二時を過ぎてゐました。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　午前十二時　る、る、る、る、る、る、る、る、る、る、る。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後の二時頃になった。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
