[
  {
    "uuid": "0f988b5b-49d1-597d-b35e-5702737d3a0a",
    "entry": "吹き鳴らす",
    "reading": {
      "primary": "ふきならす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
