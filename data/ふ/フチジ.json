    "definitions": [
      {
        "index": 1,
        "gloss": "prefectural governor (of Osaka or Kyoto)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
