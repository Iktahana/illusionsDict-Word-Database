    },
    "definitions": [
      {
        "index": 1,
        "gloss": "frame",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "田園の外れは花畑らしく緑色の框のフレームも見えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それというのはこの木は寮の座敷の硝子戸のすぐ外に在って、硝子戸は、その角から曲る茶室の羽目板もろとも南の陽を内懐に挟み溜め、ちょうどこの木に対して片箱フレームの作用をするからでもありましょうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フレームも見えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑の一部にある金蓮花はほとんど苅り取られ、園の苗床に冠せてある葭簀や、フレームの天井は明るみ切って、既に夏になり切っている。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とすれば手作りの受注開発がもっぱらだったメインフレーム用のソフトもパッケージ化されるはずだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一九七二年、メインフレーム用パッケージ・ソフトの販売と保守、教育にあたるアシストを設立。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "量産効果に背を向けてマイクロコンピューターを使わないメインフレームの類は、ごく一部の例外を除いて今後のコンピューター環境に加わる資格を持たない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダウンサイジングと呼ばれる戦場でメインフレームは誰に破れたのか　父と母はもはや、永続的に共同生活を維持していく状態にないと初めて知らされたのは、オレが小学校四年生の時だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するにＡＣＥがやりたいのは、ＧＵＩを備え、これまでメインフレームを中心に組み上げられてきた大規模なネットワークを引き継ぐ速い機械を作るという話だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "量産化できる部品としての頭脳を実現したマイクロコンピューターは、メインフレームやミニコンピューターの足場にひたひたとコスト切り下げの圧力の波を送り込んできた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "不況も加わってＭＩＳ部門に予算圧縮の圧力がかかり、メインフレーム中心のメーカーは従来のスタイルは通らないと白旗を上げた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダウンサイジングと書かれた白旗を掲げてメインフレームの陣地から両手を上げて出てきた連中は、彼らの流儀と彼らの文化を再び、マイクロコンピューター上に築こうとしている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の連中は、フレームの外から、からかい半分で見物している。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　という声でふりかえると、メタルフレームの眼鏡をかけた、みごとに丸い顔をした男が、女といっしょに笑いかけていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは通信機器の修理室らしく、ごたごたとフレームが置かれ、リノリウムの床の上には電纜や工具類が散らばっていた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "局長は、そのフレームの一つの前まで来ると立停って、指した。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今、この映写幕の上に映像がぴったりと停るだろうが、そうしたら君は、そこにうつっているものが何であるか、いい当ててみたまえ」　局長はそういうと、フレームの横に中腰になって、目盛盤をしずかにうごかしていった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾家のフレームぢや屹度桃が咲いたに違ひない。",
              "citation": {
                "source": "くもり日つゞき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮮やかな形のうちに清い渋みをたたえたライラック色の花弁は、水のように日を燦かすフレームの中で、無邪気な、やや憂いを帯びた蝶が、音を立てず群れ遊ぶように見えた。",
              "citation": {
                "source": "小景",
                "author": "――ふるき市街の回想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間もお医者さんが、なるたけ家でも病院にいるときのように規則立てて暮させなけりゃいけないっていってでしたよ」　始めの目論見と違って、平庭のまま芝生が出来たり、南を向いてフレームが出来たりした。",
              "citation": {
                "source": "牡丹",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほっそりとやせ、ワイヤーフレームの眼鏡をかけたゲイツは、青年というよりも少年といった方が似つかわしい。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのメインフレームの覇者が、オフィスコンピューターによるアメリカ進出の障害となってきたパーソナルコンピューターの市場に、ついに乗り出してきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後も超越瞑想に未練を残しつつ、ＩＢＭのメインフレームに悪態をつきながらプログラミングの経験を積んでいたが、やがて退屈な七〇年代の推移に飽き飽きして心理学の博士課程への進学を考えはじめるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大規模なメインフレーム用のＯＳ開発に取り組んでいても、古山は「何から何まで分かっていたい」という気持ちをなかなか拭いきれなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★従来メインフレームやオフィスコンピューターの端末装置は、もっぱら文字だけを画面に表示してきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで「あなた自身はどのようなバックグラウンドを持っているのか」と問うと、「これまでは企業のデータ処理部門でメインフレームのおもりをしてきたのだけれど、将来は必ずパーソナルレベルでコンピューターが使われるようになると思って、ここの店長になった」のだという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アムダール社製のＩＢＭ互換のメインフレームを使った、日本とは桁外れのＣＡＤシステムを利用して現地で作業を進めた松本は、十一月いっぱいでゲート★数二〇〇〇規模のＣＲＴコントローラーの設計を仕上げてしまった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
