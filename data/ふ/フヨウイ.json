    "definitions": [
      {
        "index": 1,
        "gloss": "unprepared",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただかえってこんな思わぬ不用意の瞬間に閃光のごとくそれを感じるだけであろうかと思われる。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれまで、私の性格、體質などに就いて、ずゐぶん誇張されて言ひ傳へられ、たしかに私にも不用意な點があつて、明かにそれは私のいたらぬところであつたけれど、あらぬ傳説が一部の人たちに信じ込まれてゐた樣子で、たいへん評判がわるかつた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ特に私が宇都野さんに望む所は、時々はもう少し不用意な、読みっ放しの云わばもっとそつのある歌をよんで見せて頂きたいと思う事である。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのにこれに備うる事もせず、また強い地震の後には津浪の来る恐れがあるというくらいの見やすい道理もわきまえずに、うかうかしているというのはそもそも不用意千万なことである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "森のまた、帰る方の道には、腕関節からはすかいに切り落された手や、足の這入った靴が片方だけ、白い雪の上に不用意に落されてあった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲のアメリカン・シチズンスの不用意な表情姿態の上に反映したフーヴァーのほうがはるかに多くフーヴァーその人を物語るのである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不用意に取って来た一草一木を机上に置いて一時間のあいだ無言で児童といっしょにひねくり回したり虫めがねで見たりするほうが場合によってははるかに有効な理科教育になるということもありはしないか。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不用意にもらす言葉こそ、ほんたうらしいものをふくんでゐるのだ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不用意の隙を覗って転々、人に取り憑き、取り憑いたら一度は人を恋のように※かせてみる。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不用意に女は後を向いた。",
              "citation": {
                "source": "窓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは着物の綻びから不用意に現している白い肌のように愛らしくもあった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ短時日でも隣人として朝夕の不用意のうちにその人の多方面を見ることは、主客、友人として特定時間内に何年逢って居るよりも何程か多くその人の表裏全幅を知悉し得ると云えよう。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、通常の客や友人同志の知らない「不用意の氏」を随分｜観た。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者あるいは、諸作家の書簡集を読み、そこに作家の不用意きわまる素顔を発見したつもりで得々としているかも知れないが、彼等がそこでいみじくも、掴まされたものはこの作家もまた一日に三度三度のめしを食べた、あの作家もまた房事を好んだ、等々の平俗な生活記録にすぎない。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そう不用意に言ってしまって、ひやとした。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "木版師はそんな不用意の部分をも丹念に板に刻んだ。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでやはり不用意に写して置いた庭の万年青の写生画一枚を上げた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿に外套を預けて来たのが、不用意だったと思うばかり、小県は、幾度も襟を引合わせ、引合わせしたそうである。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝶ちゃんが歩き疲れて、胸を張って佇むとき、不用意に腰を後に淡く張るあの姿勢などによって蝶ちゃんが既に老境に入って枯れ錆びた後の老女の姿の美しさでも自分は既に味わい取っているのである。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田島は少し狼狽えて不用意に云って仕舞った。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうなると雀は不用意な言葉によつて全然殺されて了つてゐる。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロダンの不用意な問は幸にもこの腹藁を破ってしまった。",
              "citation": {
                "source": "花子",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外へ出て探そうにも、家の前はすぐ深山になっていて不用意には探せない。",
              "citation": {
                "source": "美女を盗む鬼神",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "内外の古典、写実……純正、立体、超現実に致るまでのあらゆる風派の味と力が用意、不用意の中に取り入れられております。",
              "citation": {
                "source": "挿絵と闘った話",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚籠を担いで川までお供して行く途中の長い長い田圃道の徒然なままに翁と雑談をしながら何気なく質問をすると、翁は上機嫌なままに大事な口伝や秘伝を不用意に洩らすことがあった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "原稿の締め切りに迫った催促のはがきを受け取ってから、全く不用意に机の前へすわって、それから大急ぎで何か書く種を捜すというような場合も多かった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の掃除をするとかで、涼しい縁側に暫らく母の床の移されてゐた間に不用意に私は生れたのであつたさうだ。",
              "citation": {
                "source": "たべものの木",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほどに彼女の恨みの籠った手紙を、お直が不用意に取り落したと聞いて、お紋はむやみに怒った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に当夜刃傷のみぎり、相手の神崎を取り逃がしたるは不用意の致し方とあって、厳しいお咎めを受けた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めその前の縁の格子が上げたままになっていたのを、不用意だといって紀伊守がしかって、今は皆戸がおろされてしまったので、その室の灯影が、襖子の隙間から赤くこちらへさしていた。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
