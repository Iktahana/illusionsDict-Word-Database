[
  {
    "uuid": "f367967a-fa24-5f94-a5ac-5e9ab99b16df",
    "entry": "伏在",
    "reading": {
      "primary": "ふくざい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
