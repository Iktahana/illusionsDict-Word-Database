    "definitions": [
      {
        "index": 1,
        "gloss": "insanity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は窓際に倚って風狂というものが存在した古い時代のことを思った。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家内ひっそりと、八角時計の時を刻む音ばかり外は物すごき風狂えり。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "（風狂文章）　古人がすでに言いきっている。",
              "citation": {
                "source": "草と虫とそして",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "その推敲の苦みこそは何にも替へがたい我が無上の楽みであり、我自らの風狂をまた如何ともしがたいのである。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "心は安く、気はかろし、揺れ揺れ、帆綱よ、空高く……　私の今度の航海は必ずしも物の哀れの歌枕でも世の寂栞を追い求むる風狂子のそれでもなかった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "花には花に弄せられざるもの誰ぞ、月には月に翫ばれざるもの誰ぞ、風狂も亦た一種の変調子、風狂も亦た一種の変調子なりとせば、人間いかにして変調子ならざる事を得む。",
              "citation": {
                "source": "富嶽の詩神を思ふ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "琵琶滝を過ぎ、かねて聞く狂人の様を一見し、かつは己れも平生の風狂を療治せばやの願ありければ、折れて其処に下るに、聞きしに違はず男女の狂人の態、見るもなか／＼に凄くあはれなり。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この四季の里は俳名｜馬好と号した常に馬を楽んだ風狂の伯楽が初めて営んだものだそうであった。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三町をも超える大盤石を掘貫こうという風狂人じゃ、はははは」と、嗤うものは、まだよかった。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "古人等には風狂の説があつて、この世のさびしさの中にも笑ふことを教へて呉れる。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "風狂私語辻潤▼自分は風狂人の一種だ。",
              "citation": {
                "source": "風狂私語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅がなつかしくもある、秋風が吹きはじめると、風狂の心、片雲の思が起つてくる、……しかし、私は落ちついてゐる、もう落ちついてもよい年である。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の風狂は芝居に見るやうに洒脱とか趣味とか云ふものではない。",
              "citation": {
                "source": "続芭蕉雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼には彼の家族は勿論、彼の命をも賭した風狂である。",
              "citation": {
                "source": "続芭蕉雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼の風狂はこの句の中にも見えると思つてゐる。",
              "citation": {
                "source": "続芭蕉雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "惟然の風狂を喜ぶものは、――就中軽妙を喜ぶものは何とでも勝手に感服して善い。",
              "citation": {
                "source": "続芭蕉雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し彼の風狂を「とり乱してゐる」と言ふ批評家でもあれば、僕はこの批評家に敬意を表することを吝まないであらう。",
              "citation": {
                "source": "続芭蕉雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかづち怒り風狂ひ山河もどよみ震ふとき天潯高く傾けて下界に注ぐ雨の脚やめば名殘の空遠く泛ぶ七いろ虹のはし。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "江陵去りて行先は武昌夏口の秋の陣一｜葉輕く棹さして三寸の舌呉に説けば見よ大江の風狂ひ焔亂れて姦雄の雄圖碎けぬ波あらく。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩せて尖った顔で、執拗に僕を小高いところから見下している眼つきには、風狂者によくある嶮しさのうちに一脈滑稽じみたところがある。",
              "citation": {
                "source": "石ころ路",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "辭讓之心偏、民或有奔亡風狂者。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "辭讓の心偏すれば、民或は奔亡風狂する者有り。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへ行くにも矢立てを腰にさして胸に浮かぶ発句を書き留めることを忘れないようなところは、風狂を生命とする奇人伝中の人である。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "さびしさに浮かれる風狂の士か。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "門札を持って行かれたも、単なる風狂に相違ない。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えばひょんな風狂人もあったものでございます。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人の風狂には、何か胸にわだかまっているものが迸出を求めて身悶えしているといった趣がある。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "思へばひよんな風狂人もあつたものでございます。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
