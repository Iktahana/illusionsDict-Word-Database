    "definitions": [
      {
        "index": 1,
        "gloss": "to lie face down",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "とある谷を下つた處で、曲りくねつた道路と、其の道傍に榛の木が三四本眞黄に染まつたのを主題にして、稍複雜な地形に起伏する色々の畑地を畫布の中へ取り入れた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワッと泣き伏す雪枝の姿。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "典六「御助勢申すとも」　雪枝「有難う存じます」と其の場に嬉し泣きに泣き伏す。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "感極まってワッと泣き伏す。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "君江も、Ｔ「長七さん」　と嬉しそうに抱き付いて泣き伏す。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹は寄って母親の胸に泣き伏す。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（令嬢の膝の上に俯伏す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の下なる七つ森のその三つなり、　　白々として起伏するもの。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……園は、ぎよつとして、突伏すばかりに火尖を嘗めるが如く吹消した。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァイオリンの音の、起伏するのを受けて、山彦の答えるように、かすかな、セロのような音が響いて来る。",
              "citation": {
                "source": "秋の歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく私のすがたを見つめているうちに、私には面皰もあり、足もあり、幽霊でないということが判って、父は憤怒の鬼と化し、母は泣き伏す。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある谷を下った所で、曲がりくねった道路と、その道ばたに榛の木が三四本まっ黄に染まったのを主題にして、やや複雑な地形に起伏するいろいろの畑地を画布の中へ取り入れた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣き伏すところなどでも肩の運動一つでその表情の特徴が立派に表現される。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前達が、お前達の世界へ行って、もしそこで欲しいものや、願いごとを思い付いたら、お前達は、空を仰ぐか地に伏すかして、熱心に、私の名を呼んで祈るがよい。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月、あっと云って俯伏す。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人はヤッシと艪柄を取って、丸裸の小腰を据え、圧すほどに突伏すよう、引くほどに仰反るよう、ただそこばかり海が動いて、舳を揺り上げ、揺り下すを面白そうに。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　わッとまた忍び音に、身悶えして突伏すのである。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "車夫の提灯が露地口を、薄黄色に覗くに引かれて、葛木はつかつかと出て、飜然と乗ると、楫を上げる、背に重量が掛って、前へ突伏すがごとく、胸に抱いた人形の顔を熟と視た。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "慌しくまうつむけに平伏す）ははッ、大権現様、御免なされ下さりませ、御免なされ下さりませ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お沢はうなだれ伏す。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）お沢　（崩折れて、倒れ伏す。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（一同ものも言い得ず、ぬかずき伏す。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月の日盛りの空はぼうとして、起伏する駿州の丘陵が薄い霞の中から、初夏の姿をあらはして居る。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月の日盛りの空はぼうとして、起伏する駿州の丘陵が霞の中から、初夏の姿をあらはして居る。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御帰館――」と叫ぶにつれ、老婦人｜衝と出でて、式台に成らせたまえば、一同眼の覚めたる心地して、万歳を哄と唱え、左右にずらりと平伏するを、見向もせで、足疾に仏室の内、隔の障子を閉切りたまいぬ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが枯れ立ち、倒れ伏す、河岸、入江に、わけて寒月の光り冴えて、剃刀の刃の如くこぼるゝ時、大空は遙に蘆葦雜草の八萬坪を透通つて、洲崎の海、永代浦から、蒼波品川に連つて、皎々として凍る時よ。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "穗たで露草みだれ伏す。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しきりもない小屋内が、然らぬだに、おびえる處、一齊に突伏す騷ぎ。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お百合｜背を捻じて面を伏す。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "撫子　（鬢に手をあて、悄れて伏す）旦那様、済みません。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
