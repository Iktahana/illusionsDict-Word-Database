  {
    "uuid": "7d3b5418-c190-5fbb-82dd-8c584541db62",
    "entry": "俯す",
    "reading": {
      "primary": "ふす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-す"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to lower (one's head, gaze, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "が、明日の糧にも気心を配る女房の顔を見れば、釜貞も人間、只暗澹として首を俯する他はなかつた。",
              "citation": {
                "source": "名工出世譚",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは日ごとに公苑に往き戲園に入り、又心安からぬまゝに寺院を尋ねて、聖母の足の下に俯することあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "（足手を硬直し、突伸べ、ぐにゃぐにゃと真俯向けに草に俯す。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大洗祠前、海水浴旅館、波に俯す。",
              "citation": {
                "source": "常磐の山水",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "玩具のくゝり猿の如き樣して、水に俯する母の背に負はれたる赤兒、泣いてやまざるも、母は之を懷くひまなし。",
              "citation": {
                "source": "常磐の山水",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "千葉氏代々の城址にして、千葉第一の遊覽地、老松參差として、千葉の市街に俯す。",
              "citation": {
                "source": "千葉夜行記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏山は風邪の心地なりとて、一隅に身をちゞめ、羽衣は船暈の氣味なりとて、座に俯す。",
              "citation": {
                "source": "房州紀行",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "男二人横臥せる間のしりへに、わづかに膝を容るゝばかりの餘地を求めて、顏を袖に埋めて俯す。",
              "citation": {
                "source": "房州紀行",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺は、山を負ひ、山門怒濤に俯す。",
              "citation": {
                "source": "房州の一夏",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "伽藍堂々、山に據り、海に俯す。",
              "citation": {
                "source": "北條より一ノ宮へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の女は青畳の上に俯すように身をかがめたり、また仰向きに反り身になったりして、鈴と扇とを品よくあしらった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄に倚って俯すとき広き両岸の青を極めつくして、始めて石垣に至る。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊ヂュウカリオーンは次の牲、肱の筋肉合ふところ、其腕をうつ青銅のアキルリュウスの槍凄し、彼は空しく腕を垂れ死の運命を覺悟して、　480敵の迫るを迎へ待つ、敵は利劍を打ち揮ひ、兜のまゝに其頭、打つて落せば背骨より、脊髓溢れほとばしり、屍は大地に倒れ俯す。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "うち俯すぎて、兜の頂辺を射られるな。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊ふすべをするため、ジヨチウ菊を燃したばかりだといふので、部屋の中には煙が残つてゐた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで居て、彼の使ふすべての金が、一錢のムダもなく利用されてる。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして巴里でも、私は人々の間でどんなにか孤獨だつたでせう、そして私の出會ふすべての人々から、いつも知らん顏をされて居ましたことか。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "武は上がってふすまをあけると、座敷のまん中で叔父叔母さし向かいの囲碁最中！",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦のふすまを二升とね、阿麻仁を二合、それから玉蜀黍の粉を、五合を水でこねて、団子にこさえて一日に、二度か三度ぐらいに分けて、肥育器にかけて呉れ給え。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからだって毎日麦のふすま二升阿麻仁二合と玉蜀黍の、粉五合ずつやるんだぞ、さあいい加減に判をつけ、さあつかないか。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってこの下宿の帳場に坐っていつもいつも同じように長い煙管をふすべている主婦ともガラス障子越しの御馴染になって、友の居ると居ないにかかわらず自由に階段を上るのを許されていた。",
              "citation": {
                "source": "雪ちゃん",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたらあんなに弱いおばあさまがだまったままで、いやというほどぼくをはらいのけたのでぼくはふすまのところまでけし飛ばされた。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手がぼくの手を引いて、ぼくの部屋の方に行ったが、あけっぱなしになっているふすまの所から火が見えたら、おかあさんはいきなり「あれえ」といって、ぼくの手をふりはなすなり、その部屋に飛びこもうとした。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬鑵に水を入れかへたり、きふすを洗つたり、其の他、一々は云はないけれど、男一人でゐるとなると、却々忙しいものである。",
              "citation": {
                "source": "散歩生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その月の出の正面にかざつて、もと手のかゝらぬお團子だけは堆く、さあ、成金、小判を積んで較べて見ろと、飾るのだけれど、ふすまは外れる。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、杉野の家で、早午飯に二人で牛肉なべをつゝいて居ると、ふすま越に（お相伴）といふ聲がしたと思ひな。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上れ、二階へと、マツチを手探りでランプを點けるのに馴れて居るから、いきなり先へ立つて、すぐの階子段を上つて、ふすまを開けると、むツと打つ煙に目のくらむより先に、机の前に、眞紅な毛氈敷いたかと、戸袋に、雛の幻があるやうに、夢心地に成つたのは、一はゞ一面の火であつた。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふすま一重茶の室で、濱野さんの聲がするので、よく、この雪に、と思ひながら、ひよいと起きて、ふらりと出た。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄關境のふすまを開けたが、矢張り息がこもる。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒餅でも出す氣だつたか、家内が立つて、この時、はじめて、座敷の方のふすまを開けた、……と思ふと、ひし／＼と疊にくひ込んで、そのくせ飛ぶやうな音を立てて、「水、水……」何と、立つと、もう／＼として、八疊は黒い吹雪。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
