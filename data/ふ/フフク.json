[
  {
    "uuid": "7f313f06-08d9-5c1c-bcc8-97f08f5bd6b8",
    "entry": "不服",
    "reading": {
      "primary": "ふふく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "形容動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dissatisfaction",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこでＢはＡに不服を唱へ出す。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「瀬川さんだったら、大隅君にも不服は無い筈です。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「毎日々々、何か一言不服かなにか言はないことがない。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だから不服な僕を追つ放して下さいつてのですよ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれはいま娘の涙を手に弄んでいるのではあるまいか」　すると、娘がいったことであのときは不服のあまり胸に受けつけなかった意味のことが、まざまざと暗んじ返されてく来るのだった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老母が縁もゆかりもない人間を拾って来て、不服らしいところもあった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで野口氏が之れに不平し、最後に「萩原君の見る所にも不服である」といふ意味を述べられた時私は先輩に對する愛と自責で、自ら激動した感情を押へることが出來なくなつた。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……つまり、売笑婦の蠱惑を戦場の地域に例えるのに、現今として誰一人、不服はない筈だ。",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」為吉は不服そうだった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、おしかは不服も云わなかった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼ばかりではなかった、彼と同じ不服と反抗を抱いている兵卒は多かった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不服でむか／＼してやりきれなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜日に働かなければならない不服を、のどの奥へ呑み下して、看護卒は、営内靴で廊下や病室をがた／＼とびまわった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」じいさんは不服そうに云った。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　露顕した時の恐怖と、親爺への不服が忘れられない幹太郎は、あとから、すゞに訊いた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　俊は、嫂を去なしてしまったことに不服を持っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その不服の対照は母だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　僕は、猪口才げなと云われたのが不服でならなかった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼等は、不服と、腹立たしさの持って行きどころがなかった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、不服があるなら、今すぐ警察へ突き出す。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし色艶つけて書いてみたが、もし不服あったら、その個所だけ特別に訂正してあげてもいい。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そう口を尖らせて不服を言うと、佐吉さんはにこにこ笑い、「誰も本気に聞いちゃ居ません。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの純粋な園にならおぬいさんが与えられても俺には不服はない。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お前は一審で懲役一年に処せられたが、その判決が不服だと云ふので控訴したのか。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どこが不服だと云ふのだ。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "之が不服だと云ふのだな。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうして不服だと云ふのだ。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は判決に不服であつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "モデル娘は「だって、こちらが仰しゃるんですもの」と不服そうにいった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、もうひとりがふふくらしくいいました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
