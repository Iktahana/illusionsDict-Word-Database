  {
    "uuid": "a3bf855b-b539-5799-b376-b36fac890179",
    "entry": "風俗壊乱",
    "reading": {
      "primary": "ふうぞくかいらん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
