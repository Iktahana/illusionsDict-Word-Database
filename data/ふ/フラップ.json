        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あ、そうだ」　慶一は、ヒップポケットのフラップのボタンをはずし、四つに折り畳んだ紙をとりだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "翼の表面からフラップにつながり、果ては風圧でちりぢりに吹飛ぶらしい。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくにむけて笑顔で歩きながら、バッグからガムのケースを出してフラップを開き、ケースの口をぼくにむけて差し出した。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "封筒のフラップにつけてある糊を舌で湿らせた彼女は、フラップを閉じた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "フラップを糊づけして、愛子に宛てる手紙は完成した。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「銅像関係の資料は、こちら」　そう言った野中サチは、茶色の大きな封筒を取り上げ、紐がかけてあるフラップを開き、なかのものをテーブルに出した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
