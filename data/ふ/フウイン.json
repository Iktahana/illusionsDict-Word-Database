    },
    "definitions": [
      {
        "index": 1,
        "gloss": "seal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「小指は高くゝりの覚」で貸借の争議を示談させるために借り方の男の両手の小指をくくり合せて封印し、貸し方の男には常住坐臥不断に片手に十露盤を持つべしと命じて迷惑させるのも心理的である。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は豚小屋に封印をつけて、豚を柵から出して、百姓が勝手に売買することを許さなくするためにやって来たのである。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、二十分ばかりかゝって、初めての封印をして、彼等は外に出た。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日かゝって、三人の役人は、結局、柵に固く栓をして、初めから豚を出さなかった、二三の小屋にのみ封印して、疲れ切って帰って行った。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　二週間ほどたって、或る日、健二が残飯桶をかついで丘の坂路を登っていると、彼の足音を聞きつけて、封印を附けられた宇一の小屋から二十匹ばかりが急に揃って、割れるような呻きを発して、騒ぎだした。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、それを封印をして本国大学に送ってもらいたいというようなことを厳粛な口調で話していた。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は、主人の竹三郎が封印をするばかりにした「快上快」の一と箱と、乳鉢、天秤等と共に、引っぱって行かれてしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり今の伊兵衛どのは御養子で御座いますが、何を申すにも黒田様の御封印付のお金預りという大層もない結構な御身分……」「へえへえ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "御封印付のお納戸金を扱うておるほどの店じゃけに、万に一つも家柄に疵が付いてはならぬ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "封印したビイドロ瓶の中味をば外から舐って、塩か砂糖か当てよという注文じゃけになあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「樽にみんな封印しろ。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗人でも封印のついたものは切らんと言います。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「封印がしてまっさかいな」　男はにやにやした。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "取り敢へず、武具類を土蔵に収めて封印して主人喜右衛門を壬生の屯所に引致して、拷問したところ、驚く可き陰謀が発見されたのである。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "「升屋の土蔵の封印を破つて、武具を奪ひ去つた者がある！",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "みるみるうちに楼閣も倉庫も、一様に封印してしまった。",
              "citation": {
                "source": "続黄梁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく目立ったＤ――の花押のある、大きな黒い封印があって、細かな女の筆蹟でＤ――大臣へ宛てたものだった。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "このほうは封印が大きくて、黒く、Ｄ――の花押があるし、あのほうは封印が小さくて、赤く、Ｓ――公爵家の紋章がある。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕には、その手紙が手袋みたいに裏返しにされ、ふたたび宛名が書かれ、封印がしなおされたことは明らかだった。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは僕が家で念入りに用意してきていたものなんだ、――パンでこさえた封印で造作もなくＤ――の花押をまねてね。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "跨いで越すに、足を挙ぐるまでもなかったけれども、路に着けた封印は、そう無雑作には破れなかった。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に案ずるまでもない、同町の軒並び二町ばかり洲崎の方へ寄った角に、浅草紙、束藁、懐炉灰、蚊遣香などの荒物、烟草も封印なしの一銭五厘二銭玉、ぱいれっと、ひーろーぐらいな処を商う店がある、真中が抜裏の路地になって合角に格子戸｜造の仕舞家が一軒。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっさに思ったことが、『あれは、回路上オレの頭の中にはいっているもの以外いらねエ』（笑）」　だが自らの才能を思う存分ふるって計算機の設計に取り組んだ池田は後に、コンピューターの開発にあたって自由な発想を封印するという最も池田らしからぬ選択を行なった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "では自らの独創によって富士通のコンピューターを立ち上げながら、標準に向かう風を読んで独創を封印したこの人物は、この事件を体験したとすれば次に何をなすべきと考えたろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "役員は、差押証書をかいただけで、品物は封印もしないで、私達に預けたまゝで、帰つて行つた。",
              "citation": {
                "source": "差押へられる話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘密の封印を解くような興奮と恐怖とで、オズ／＼表紙を開いて見た。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "住んでいる家に、執達吏が、ドヤ／＼と踏み込んで来て家財道具に、封印をベタ／＼と付ける。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃまになるとおっしゃるならば、あごをはずしてでも、口に封印してでもめえりますがね、ものにゃけじめってえものがあるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "封印を破って、少しずつ少しずつ、気長にひとりで運んだのでござります」「ほほう、そうか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
