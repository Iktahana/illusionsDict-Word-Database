[
  {
    "uuid": "b818b30b-0e2d-5b9d-90c4-c64acbb00a09",
    "entry": "封印",
    "reading": {
      "primary": "ふういん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
