[
  {
    "uuid": "8930bfa0-5d90-512c-8093-c8ffcb176661",
    "entry": "不作",
    "reading": {
      "primary": "ふさく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
