    "definitions": [
      {
        "index": 1,
        "gloss": "seed leaves (of a dicot)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
