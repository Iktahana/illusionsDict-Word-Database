        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "其姿が土手の下へ隱れた時おふさも往來を横ぎつて走つた。",
              "citation": {
                "source": "おふさ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が泣けばおふさも譯を知らないなりに私のために涙ぐんだ。",
              "citation": {
                "source": "金魚",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は長安の貴女楊氏です、人を怨むなどといふさもしい事は知りません。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "福島正則の如きまで禁を承知で家康と婚を結ばうとする、いはんや黒田如水などはわざわざ九州から出ばつてきて家康を護衛する、名目は三成の天下の野望を封ずるためとあるのだが、それはうはべだけのことで内実は家康の天下を見越してすこしも先に忠勤を見せようといふさもしい心掛けだ。",
              "citation": {
                "source": "家康",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランプの光射す程は、樫、ふさもじ、小さな孟宗竹の葉が一々緑玉に光って、ヒラ／＼キラ／＼躍って居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて、朋子の「あら……」といふさも意外らしい叫び声。",
              "citation": {
                "source": "驟雨（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪洞をその左右に、蚊遣りを焚かせ、正四郎もふさも浴衣にくつろいで坐った。",
              "citation": {
                "source": "その木戸を通って",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹こはしてるときいたから見舞でもあり、伝言もありしが、実は、今夜のスポムサーにといふさもしき心からかも分らない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤く濁った瀬田川の水に、石山寺の残んの花もこれ限りのように流され、藤茶屋の藤のふさも砕け、山吹も散っていた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
