    "definitions": [
      {
        "index": 1,
        "gloss": "to raise (a sword, fist, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と大刀振り上げる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上で太刀逆手に振り上げる五郎蔵。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等に手を振り上げるのは兄弟中で事實私一人だつた。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて顔を振り上げる。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々の立止まるを見るや、彼等はなおも猛烈に土砂石塊を浴せかけんと、鶴嘴を振り上げる。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして鞭を振り上げると、花房はふた足三足ぐいぐいと足掻きをして、鞭を食う前に起き上がった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには彼女の体に手を振り上げるまでになった。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の槌を振り上げるころに漸く槌音が聞こえる。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り上げる時、鍬の刄は陽に白くきらりと光る。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "門野が隣の梧桐の天辺迄｜水にして御目にかけると云つて、手桶の底を振り上げる拍子に、滑つて尻持を突いた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "刀を抜いておどしますと、犬はなおなおはげしく狂い回って、りょうしの振り上げる刀の下をくぐって、いきなりその胸に飛びつきました。",
              "citation": {
                "source": "忠義な犬",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれを振り上げるが早いか、彼の襟くび目がけて※も透れと突き立てました。",
              "citation": {
                "source": "無駄骨",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはその小刀を振り上げると、もう一｜度夫にかう云ひました。",
              "citation": {
                "source": "藪の中",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはその小刀を振り上げると、もう一度夫にこう云いました。",
              "citation": {
                "source": "藪の中",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「作業はじめえ――」　大佐の号令一下、機械は「ごォーッごォーッ」と獣が咆えるような声を立て、職工が振り上げる鉄槌の、鋼鉄を打つ音が、ガンガン岩の壁にこだまして鳴りひびき、青白い電気の火花がパチパチ散り、高熱炉の中では、本多鋼鉄が真紅に焼けただれて、「じゅッじゅッ」とすさまじい音を立てはじめた。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　錆ごえを、ふりしぼるのもあれば、金切ごえを振り上げる女もあり、すぐに、かつぎ上げるようにして、一行を、二階に押し上げる。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "門野が隣の梧桐の天辺まで水にして御目にかけると云って、手桶の底を振り上げる拍子に、滑って尻持を突いた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、鉄棒でも振り上げるようにそれを振り上げ、その刄の方で釣師の頭をひと撃ちで割った。",
              "citation": {
                "source": "狂人日記",
                "author": "ギィ・ドゥ・モオパッサン　Guy de Maupassant",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ハイッ」「ハイッ、先生」「ハイッ」　振り上げる幼い手の林――　だが、その林のところどころは抜けている。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼　　（ヘチマコロンの瓶を受け取り、そいつを振り上げるが急にぐつたりと椅子に倚りかゝり）こんなもの、ぶつけたつて、しようがないや……。",
              "citation": {
                "source": "かんしやく玉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、おじいさんは、百｜姓が毎日手に力をいれて、田や圃で、くわを振り上げるようすを思って、独り言をしました。",
              "citation": {
                "source": "おじいさんとくわ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「岩山の人達でございますの」最初の乙女がすぐ答えたが、小さい拳を振り上げると、岩山に向かって打ち振った。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り上げる鍬の刃先がキラリキラリと光る向うには、秩父の山々が美しく聳えている。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルピック夫人は茨の枝を振り上げる。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみつを打とうと藤吉が腕を振り上げると、「親分、奴はもう白状したのも同然、失礼ながらお手が過ぎやせんか。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "三つの足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "富田が『ドス』を振り上げると、七輪に暖まつて居た内山が飛んで来て、『兄キ、何にするんや……まアそんなに怒らんでも善いぢやないか』と、懐刀をもぎ取つた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "――女に向って出刀を振り上げる。",
              "citation": {
                "source": "撮影所殺人事件",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "短刀を振り上げるたびに、刃に月の光があたってキラキラと物凄く光る。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "その朱房を長く取つて『御用ツ』と振り上げると、燃え立つやうな朱房が、顏を斜にかすつて、サツと宙に舞ひます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "盜まれた十手",
                "note": "青空文庫"
              }
            },
            {
              "text": "――児戯に類した点や、わざとらしい感激や、言葉身振り態度の仰々しい虚偽などに、彼はいかにも恥ずかしい気がして、管絃楽を指揮しながらも時々、指揮棒を振り上げる力がなくなるほどだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
