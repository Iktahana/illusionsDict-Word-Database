        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あれきっと双子のお星さまのお宮だよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「双子のお星さまのお宮って何だい。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "双子のお星さまが何したっての。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "双子のお星さまが野原へ遊びにでてからすと喧嘩したんだろう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはチュンセ童子とポウセ童子という双子のお星さまの住んでいる小さな水精のお宮です。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがこの双子のお星様の役目でした。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "双子の星は一生けん命手まねでそれを押えました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　双子のお星様たちは悦んでつめたい水晶のような流れを浴び、匂のいい青光りのうすものの衣を着け新らしい白光りの沓をはきました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　双子のお星様たちは笛を吹きはじめました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "双子の星　二（天の川の西の岸に小さな小さな二つの青い星が見えます。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはチュンセ童子とポウセ童子という双子のお星様でめいめい水精でできた小さなお宮に住んでいます。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがこの双子のお星様たちの役目でした。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、双子の青星。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか曇った晩あの双子を少し旅させてやって呉れってな。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ今日、王様のご命令で双子の青星は旅に出ます。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この双子のお星様はどこ迄でも一緒に落ちようとしたのです。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして双子のお星さまだちは海蛇の王さまの前に導かれました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "双子のお星さまはめいめいのお宮に昇りました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれきっと双子のお星さまのお宮だよ」男の子がいきなり窓の外をさして叫びました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「双子のお星さまのお宮ってなんだい」「あたし前になんべんもお母さんから聞いたわ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "双子のお星さまが何をしたっての」「ぼくも知ってらい。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "双子のお星さまが野原へ遊びにでて、からすと喧嘩したんだろう」「そうじゃないわよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」双子の声が又聞えた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "行く手の峰を越して見え出した双子山は絹のような雲が纏いつき、しばらくしてまたきれいに解け去り萌黄色の山肌が青空からくっきり刻み出されている。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では、夕月ごろまでに、それなるふたごの兄弟を巧みに誘い合わせて、なるべく薄着の水じたくをご用意しながら向島の水神へお越しめされい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "と――待つ間ほどなく、はるか土手向こうにちいさく姿を見せたものは、紛れなきふたごの兄弟波沼要介と欣一郎に、可憐な少女百合江でありましたから、すばやく右門は杉弥を伴ってそこの葦叢に身を潜めると、命ずるごとくにいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "（＊ANTEREGAN の畜生はふたごころ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、ふたごの兄弟が、人違いのために苦しむという『まちがいつづき』に多少似ている脚本であった。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふたごでない、姉さんも妹さんも勤めていないと、ほんとかね。",
              "citation": {
                "source": "小さき花にも",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは訣らないが、それを訣るやうに、「秋葱のいやふたごもりを思ふべし」と説明した、と書いてあります。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
