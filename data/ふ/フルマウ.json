    "definitions": [
      {
        "index": 1,
        "gloss": "to behave",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "リゼットは鋸楽師の左の腕に縋っておぼこらしく振舞うのであった。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "因襲なんぞから得来った智識を自分に応用せずに、初めて人間として生れて来たもののように振舞うのですね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし結局、彼はそんな人びとから我が儘だ剛情だと言われる以外のやり方で、物事を振舞うすべを知らなかったのだ。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "与二は政元の下で先度の功に因りて大に威を振ったが、兄を討ったので世の用いも悪く、三好筑前守はまた六郎の補佐の臣として六郎の権威と利益とのためには与二の思うがままにもさせず振舞うので、与二は面白くなくなった。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、卒直なんてものはね、他人にさながら神経のないもののように振舞う事です。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は激しく掃除に立振舞ううち橘屋からの手紙を床に取落したのを朋輩に拾われてもついに気が付かなかったのだった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、どうして時には私の兄のようにさえ振舞うこの子への「母のなげき」だけが斯う完全に発達しているのだろう。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幡随院長兵衛じゃ、酒を振舞うて銭を取るか。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は滞在客らしく宿の人々とも親しみ深く振舞うていた。",
              "citation": {
                "source": "遍路の正月",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "（お坊ちゃま、お坊ちゃま、）　と大声で呼び懸けて、（手巾が落ちました、）と知らせたそうでありますが、件の土器殿も、餌は振舞う気で、粋な後姿を見送っていたものと見えますよ。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "余の事にしくしく泣き出すと、こりゃ餒うて口も利けぬな、商売品で銭を噛ませるようじゃけれど、一つ振舞うて遣ろかいと、汚い土間に縁台を並べた、狭ッくるしい暗い隅の、苔の生えた桶の中から、豆腐を半挺、皺手に白く積んで、そりゃそりゃと、頬辺の処へ突出してくれたですが、どうしてこれが食べられますか。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と教えし賢者の言葉のままに、振舞うた我の愚かさよ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）裏切者なら、裏切者らしく振舞うがいい。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏切者なら、裏切者らしく振舞うがいい。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その修学旅行は、中学生の彼等にとって、かなりな小遣いを持たせられて、家から離れて自由に振舞うことの出来た殆ど最初の機会であった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢遊病者のように幽幻に彼女が振舞うのにワルトンは暫らく見とれた。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろの経験からついて来る人間に手がかりを与えないのは却ってそれに気を奪われない事だということを加奈子は心得ているので何気なく振舞う為めに続いて町並を点検して行く。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡田の空想の領分に折々この女が闖入して来て、次第に我物顔に立ち振舞うようになる。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "家も人も滅ぶべく死すべき時到らば、潔く振舞うこそよけれ、何条汚く生き延びることを計らんやと。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう、美沢が思った途端、水銀のように変化の早い彼女はもうそれと悟って、美沢の警戒を柔らげるように、たちまち子供らしく無邪気に振舞うのであった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "……おおん、あの、朝顔以来、内でこれの出たのはそうですなあ、大掃除の時、出入りの車夫に振舞うたばかりですよ。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "魂魄この土に留まって、浄閑寺にお参詣をする私への礼心、無縁の信女達の総代に麹町の宝物を稲荷町までお遣わしで、私に一杯振舞うてくれる気、と、早や、手前勝手。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何の苦もなくいわば余分の収入として得たるものとはいえ、万という金を惜しげもなく散じて、僕らでいうと妻子と十日の間もあい離れているのはひじょうな苦痛である独居のさびしみを、何の苦もないありさまに振舞うている。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人が無事に箱根を越せば、その夜の宿で山祝いをするのが当時の習いであるので、本来ならば主人の市之助から供の二人に三百文ずつの祝儀をやって、ほかに酒でも振舞うべきであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "山祝いの夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "飢えた人に食事を振舞うぐらいの事は、貧者もまた之を良くすることが出来る事である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "和訓の意味に拠る時は、学問は先人の言行に倣って、我もそう有りたいと願い求め、そう成れるように振舞うのが即ちこれである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お身たちは誰に許されて我が物顔に振舞うぞ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、それをいわない以上、京子が村川の愛を信じ、愛を受けたものとして、振舞うことに一言も文句はいえないのである。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "男らしく真剣に振舞う方が欲しいのよ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵は、その日の訪問客を引き止めて、華美に晩餐を振舞う瑠璃子であったが、その日は何うしたのか、夕方が近づくと皆客を帰してしまって、美奈子とたった二人｜限り、小さい食堂で、平日のように差し向いに食卓に就いた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
