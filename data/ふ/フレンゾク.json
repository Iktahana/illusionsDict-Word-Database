[
  {
    "uuid": "2161b4a9-5581-5e6b-bf24-d4823760e037",
    "entry": "不連続",
    "reading": {
      "primary": "ふれんぞく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
