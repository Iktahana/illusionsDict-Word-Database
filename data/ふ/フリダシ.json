    "definitions": [
      {
        "index": 1,
        "gloss": "shaking (something) out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "バビプによって手術された近代女のヴァルバ、マルセル・ウェーブによって美の典型を指示した化粧術、最もきわどいエルンスト・フルウ氏の子宮除去法、知人の政府委員はメイ・フレデリックの美顔術によってマルクス学の国家理論さえ見下す約束手形を振り出した。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを振り出しに第三第四の街を歩いた。",
              "citation": {
                "source": "太郎と街",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "粉にしたコーヒーをさらし木綿の小袋にほんのひとつまみちょっぴり入れたのを熱い牛乳の中に浸して、漢方の風邪薬のように振り出し絞り出すのである。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　風邪をひいて軽い咳が止まらないようなとき昔流の振り出し薬を飲むと存外よくきく事がある。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、この振り出し薬の香をかぐと昔の郷里の家の長火鉢の引き出しが忽然として記憶の水準面に出現する。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "抜目のない興行師はそれを芝居に仕組んで名古屋を振り出しに地方の町をうって廻った。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り出した手先の見当にあたって右のは利根川、左のは渡良瀬川、憂いも辛さも無いさまでたゞくね／＼と流れています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはサヴォイ・ホテルの酒場主任が出張して世界の新流行のカクテールを混合筒から振り出して紹介する。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの室こそは俺たちの、冒険史の振り出しだったろうがな。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度振り出したサイの目は、すんでしまったもので、いまはまったく過去のことであり、それが未来にだけ属しているサイの目に影響をあたえうるとは思われない。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋久の嫁のお節は十日ほど前から風邪を引いたような気味で、すこし頭痛がするなどと云っていたが、医者に診て貰うほどの事でもないので、買い薬の振り出しなどを飲んでいるうちに、二十九日の朝から何だか様子が変って来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "治六はじっと俯向いて聴いていたが、やがて肌に着けていた鬱金木綿の胴巻から三両の金を振り出して亭主の前にならべた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子に誤って、接吻という恋愛の約束手形を振り出したことは、恐ろしい間違いに違いなかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "内藤新宿へもどって、いろはからまた出直すんだから、急いで駕籠を仕立てな」　飛ばして行きついたところは、そもそもの振り出しのあのお下屋敷です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五の年父にわかれてから、近所の町を振り出しに、ありとあらゆる労働をして諸国を渡りあるき、地震の年に東京へ出て、今の××鉄工場の職工になったのだ。",
              "citation": {
                "source": "私はかうして死んだ！",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者はこの辺で長い前置きを停めて、まず白昼の銀座街を振り出しのＲ事件第一景について筆をすすめてゆこうと思う。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると老人は所剥げのした白粉の顔を急に横に振り出した。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロイド・ジョウジの一家族は土曜日のキャンヌのレディ・ブウトの晩餐会を振り出しに、舞踏と招待とリセプションとが十五分おきに全旅程を埋めつくしていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その後世界一の大富豪となった、付き合った実感からすれば「むだな金はいっさい使わない」人物が、個人的に振り出した小切手のせめてコピーでもとっておかなかったことを、鈴木氏は今、非常に残念に思っているという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでさっそく打ち出の小槌を振って、そこへ食べきれないほどのごちそうを振り出して、お姫さまと二人で仲よく食べました。",
              "citation": {
                "source": "一寸法師",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、それからなおしばらくして、一人の巡査が、傍らに例の＊戟を立てかけたまま、角型の煙草入れからタコだらけの拳の上へ嗅ぎ煙草を振り出しているところへ、どすんとつき当たった時、初めて少しばかり人心地がついたが、それも巡査に「こら、何だって人の鼻面へぶつかってくるんだ？",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが半布を振り出した。",
              "citation": {
                "source": "月世界跋渉記",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼等が頭を集めてゐる金屬製の容器類から、匂ひのよいクリームや、仁丹を彼等の掌へ振り出して見せてやつた。",
              "citation": {
                "source": "北京の生活",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「因業な恥知らずのお茶飲みで、二十年間も食事を薄くするにただこの魔力ある植物の振り出しをもってした。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は頭を振り出した。",
              "citation": {
                "source": "頭ならびに腹",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼は直ぐまた頭を振り出した。",
              "citation": {
                "source": "頭ならびに腹",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルルは片手を久慈の肩に廻し自分も振り出した賽の目を見て、「あら、明日は雨だわ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はサンミシェルを振り出しに河を越え、グランブルヴァールからサンマルタンの方へと坂を登っていったとき、久慈は突然矢代に訊ねた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "東海道にやちつと差しがあつて、路は悪いが甲州街道を身延まで出にやなら無えから、忘れもし無え、極月の十一日、四谷の荒木町を振り出しに、とうとう旅鴉に身をやつしたが、なりは手前も知つてた通り、結城紬の二枚重ねに一本｜独銛の博多の帯、道中差をぶつこんでの、革色の半合羽に菅笠をかぶつてゐたと思ひねえ。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを振り出しにして、佐世保、久留米、下関、門司、戸畑、折尾と言った順に、四年の間に、七度も学校をかわって、私には親しい友達が一人も出来なかった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
