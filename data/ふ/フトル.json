    "definitions": [
      {
        "index": 1,
        "gloss": "to put on weight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その結果、肥え太るのは、ブルジョアだけだぞ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、このように老い朽ちて、あとを頂く御菩薩の粒も、五つ七つと、算えるようになったれども、生あるものは浅間しゅうての、蘆の茂るを見るにつけても、稲の太るが嬉しゅうてなりませぬ、はい、はい。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る間に太る額の蒼筋、癇癪持の頭痛｜病にて、中年以来｜丸髷に結いしこと無き難物なれば、何かはもって堪るべき。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大工のせがれがショパンにあこがれ、だんだん横に太るばかりで、脚気を病み、顔は蟹の甲羅の如く真四角、髪の毛は、海の風に靡かすどころか、頭のてっぺんが禿げて来ました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず千六は賭博にも勝れた天才を持っていたらしく、相手の手の中を見破って、そいつを逆に利用する手がトテモ鮮やかでスゴかったので仲間の交際ではいつも花形になったばかりでなく、その身代は太るばかり。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "年々やめしいのままに鶴のひな育ちゆくらしあわれ　太るも　　　　　　（元旦試作）　モルヒネ　アトロモール　ナルコポン　パントポン　パビナアル　パンオピン　アトロピン　プライドとは何だ、プライドとは。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、前年予植物同士相好き嫌いする説をロンドンで出し大いに注意を惹いたが、その後｜彼方よりの来信を見るに、綿羊は常に鹿の蕃殖を妨げ、山羊を牛舎に飼えば、牛、常に息災で肥え太る由一汎に信ぜらるという。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "獏一番にこれを見付け、樹下に落る果実を飽くまで食って肥え太る。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "「トモ子、おまえ、いまにブクブクに太るぞ」　トモ子は、イーだ、と鼻をクシャクシャにし、長いひものついた、巾着の親玉のようなバッグをふりまわし、高志を一撃した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍らしい働き手で、酒男と一緒に倉に入つてせつせと稼いだから、身代は太る一方だつたが、太るだけの物は道修繕、橋普請といつたやうな公共事業に費して少しも惜まなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらで子供がうよ／＼、よく泣く児だ、泣いて太るのだらう！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで普通の人は、身代は太るほどよく、身体も肥るほどよいように思っているけれども、しかしそは大きな間違いで、財産でもからだでもあまり太り過ぎてはどうせろくな事はないのである。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "札差し稼業はもとよりそういう放埒な、または貧乏な武士があって太るのだ。",
              "citation": {
                "source": "お墓のすげかえ",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧記の記者の語を借りれば、「頭身の毛も太る」ように感じたのである。",
              "citation": {
                "source": "羅生門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "舊記の記者の語を借りれば、「頭身の毛も太る」やうに感じたのである。",
              "citation": {
                "source": "羅生門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……月が重なりや、お腹が太る、どしようぞいな……ぢや。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか、養蚕から、養鶏から何から何まで、今の後家さんのお八代さんが、たった一人で算盤を弾かっしゃるので、身代は太るばかり……何十万か、何百万かわからぬと申しますが、豪いもので御座います。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しそれにしても、作者の「鷲」はまたどこかで美しく肥え太ることを妨げないだろう。",
              "citation": {
                "source": "「紋章」の「私」",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、健康で大丈夫な他人は秋風によって食慾を増し、馬も、人も、女も、肥太るという話である。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "時として、何故とも知らずホッと洩らした溜息の引き去るあとに耳を澄ますと、朝も闌けた篁の懶い沈黙から、筍の幽かに幽かに太る気配が聴かれたやうに思はれて了ふ。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "マネキン　そうじゃないの、太ることを計算にはいれてなかった筈よ。",
              "citation": {
                "source": "鋏と布と型",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マネキン　太ることを考えなかったのが誤算でしょう。",
              "citation": {
                "source": "鋏と布と型",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「この僕のは太るんじゃない、腫れ上がったのさ」と彼は答えた、「蜜蜂に刺られたもんでね。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある松は何十年もはりがねでしばられたまま、伸びればしんを折られ、幹ばかり太るようなしつけで生き続けていた。",
              "citation": {
                "source": "生涯の垣根",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "太るのも疲れるのも淫楽の結果に違ひない。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでなくても汗掻きの私はいよ／＼太る一方なので、顔や手足や鼻の頭がネバネバニチヤニチヤする。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つく／″＼武士は嫌だ――と、潔ぎよく兩刀を捨て、鳥越に世帶を持つて、貯の小金を融通し、利潤が積つてかなりの身代を作りましたが、今から三年前他界、世帶はそのまゝ總領の宗太郎が繼いで僅か三年の間乍ら、酒や女はもとより、あらゆる道樂と縁の無いのが仕合せで、身代は太るばかりでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "双生兒の呪",
                "note": "青空文庫"
              }
            },
            {
              "text": "つくづく武士は嫌だ――と、潔く両刀を捨て、鳥越に世帯を持って、貯えの小金を融通し、利潤が積ってかなりの身代を作りましたが、今から三年前他界、世帯はそのまま総領の宗太郎が継いで僅か三年の間ながら、酒や女はもとより、あらゆる道楽と縁のないのが仕合せで、身代は太るばかりでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "双生児の呪",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が、何でも久米正雄夫人自身の懷姙中の運勢の素晴しかつたことは今でも鎌倉猛者連の語り草になつてゐるくらゐださうだが、懷に入つてふとるといふ八卦でもあらうか？",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長さアが何日も云ふとるだ、癖がつくだで乞食が來たら、何ねエな奴でも追拂つてしまへツて。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
