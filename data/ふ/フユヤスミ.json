        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "病後の冬休みにはイタリアへ転地し、フロレンス近くのバルフォーア家の別荘に落着いた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか三年の冬休みに修善寺へ行ってレーリーの『音響』を読んだ。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等学校時代のある冬休みに大牟田炭坑を見学に行った時のことである。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、大作家になる望みを失い、一日いっぱい溜息ばかり吐いていたし、このままでいてはついには気が狂って了うかも知れぬと思い、せっかくの冬休みをどうにか有効に送りたい心もあって、その温泉行を決意したのであった。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬休みで故郷へ歸つてゐたのだが、葉藏のことを聞き、すぐ急行列車で飛んで來たのであつた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生時代の冬休みに、東海道を往復するのに、ほとんどいつでも伊吹山付近で雪を見ない事はなかった。",
              "citation": {
                "source": "伊吹山の句について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもあなたは夏休みにも冬休みにも一こう村へ帰って来ないで、そのうちにあなたが、あなたの学校の先生で小説家でもある島田哲郎と結婚したという事を聞きました。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "「煉瓦場は、冬休みがとっても長くて、いいもんだな。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鶴治は小学校の尋常一年生で、二週間の冬休みがあった。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冬休みなんか、なんぼ長くたって、糞の役にもなんねえ。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この冬休みには帰って来いと、まるで熊本にいた当時と同様な命令がある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「このごろッて……この冬休みになってからですか」「ええ」　雪子は笑ってみせた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "講演を聽いた冬休みに親の傍へ歸つたとき、一週間ほど、それを眞似したのである。",
              "citation": {
                "source": "書翰",
                "author": "大正十二、三年（推定）　横光君子宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和元年から二年への冬休みは、安房の日蓮聖人の聖蹟で整頓した頭を以て、とにかく概略の講義案を作成した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "麹町の学校を辞すると間もなく、牛込の下宿も畳んで、冬休みらしい顔付で僅かの荷物と書籍とを田辺の門の内へ運んだ。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は学校の冬休みを利用し、はるばる彼を尋ねて行った。",
              "citation": {
                "source": "彼",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "此冬休みには帰つて来いと、丸で熊本にゐた当時と同様な命令がある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の冬休みに、令嬢は父の任地へ帰らなかつた。",
              "citation": {
                "source": "傲慢な眼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "家内は、明日から冬休みに入るのであるから友達の家へ遊びに寄ったか、それとも自分の里方である学校から一里ばかり離れた村の方へ行ったか、あるいは妹の嫁ぎ先の家へまわったかも知れない。",
              "citation": {
                "source": "盗難",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "事によったら冬休みに遊びに行きますから待っていて下さい」明はおようや初枝に寂しいほほ笑みを浮べて見せながら、そんな事を約束した。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう冬休みになっていても、この山麓地方はあまりスポルティフではないので、乗客は僕たちのほかはみんな土地の人たちらしかった。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬休みが始まると同時に私はその学校もよしてしまった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう冬休みも近づいてゐた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、私には学期試験がやってきたし、ついで冬休みとなり、またお正月となった。",
              "citation": {
                "source": "或る女の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにまた学期試験となり、冬休みとなった。",
              "citation": {
                "source": "或る女の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冬休みに旅でもするの。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "余はその前年の冬休みにもその年の夏休みにも帰省した。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "七八年前の冬休みに、兔を一匹｜需めて、弟と交互に擔いで、勤め先から歸省したことが、ふと彼れの心に浮んだ。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時頃私の脳底に烙き付けられた秩父山の美しい色彩の印象は、年と共に鮮かさを加えて、其後冬休みに帰省する毎に鎌を腰にさして林の中を一日ほづき歩いては帰りに山を見るのが楽しみの一となった。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は近所の子供たちまでも避けて、冬休みのあひだぢゆう、頭痛がするといつて寝床のなかで暮らしたり、そつと起き出したかと思ふと、縁側で日向ぼつこをしたりして暮らした。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
