        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "富士通がいかにして大型コンピューター事業を成功させるに至ったか、その中心的な役割を担った人物を追う番組の制作に関わることになり、この年の春にはアメリカ西海岸の取材に出かけました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士通が出しているＦＭ　ＴＯＷＮＳというパーソナルコンピューターの新機種発表会に、危うく遅れかけたからだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがＦＭ　ＴＯＷＮＳにおいて富士通がやりたかったことの味噌は、「コンピューターの手を借りて自らの思うところをより鮮やかに表現する」という、新しい世界の開拓だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "デビュー間もないＦＭ　ＴＯＷＮＳをいじくり回し、ＴＯＷＮＳ　ＧＥＡＲの目指すものに納得したオレは、となりで電源を入れっぱなしにしておいたマッキントッシュに目をやったとたん、富士通の新しいマシンが使いこなしの流儀を決めるウインドウ環境を持っていないことに気づいた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊関澤義専務取締役はその後、一九九〇年六月に富士通の社長となった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがいうまでもなく富士通が本当にやりたかったことは、日本電気に制圧されたパーソナルコンピューター市場に足場を築いて日本一のコンピューター・メーカーの面目を施し、この分野でもがっぽりもうけることだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士通は新規まきなおしのＴＯＷＮＳで、画像と音の魅力を売り物に、基本的には独力でこの目的を果たそうとした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "新社長となった関澤さんが旗を振っていたＴＯＷＮＳを、富士通はその後も可愛い子ちゃんを動員して根性で囃し続けたが、やはり苦戦は免れなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題のウインドウ環境に関しては、一九九二年の四月になって、富士通はＴＯＷＮＳ用にマイクロソフトのＷｉｎｄｏｗｓマルチメディア拡張版を出した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし世界に向けた富士通の提案としてではなく、あくまで標準の流れにのったマシンとして。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど冒頭で客のつかみにかかったトッテン社長は、「富士通さんに低価格というテーマを盗まれ、彼らが示した一円の九千七百倍という立場に追い込まれたアシストのソフトは、もう低価格とは呼べないだろう」といきなりこうだもの。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "千百万円の予算が組まれていた広島市水道局の地図情報システムの基本設計を、富士通が一円で落札したという例のあれですよあれ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下の富士通がそこまで踏み切った今となっては、アシストの九千七百円のアプリケーションは『低』価格というよりはむしろその本質を正しく示す『正』価格ソフトと呼ぶべきだろうとトッテン社長はいきなりくすぐりをかました。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その東芝が、ＩＢＭ互換路線をとって富士通、日立が業績を伸ばすのを横目で睨みながらあくまで独自アーキテクチャ路線を貫き、ついに大型からの撤退発表に追い込まれるのが一九七八年二月。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本サンは、東芝、富士通を初めとする各社に製品をＯＥＭ供給し、ＣＴＣ（伊藤忠テクノサイエンス）をはじめとする代理店経由の流れを加えた間接の販売ルートに、売り上げの約九十パーセントを負っている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このマーク・キャンター、富士通との提携を発表するに当たっては右手を握ってラッパを作り「トラタタッタタ〜」と壇上でイントロを入れて稀代のパフォーマーぶりを発揮。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで前者を取ったのが富士通のＦＭＲ―ＣＡＲＤで、後者を選んだのが日電のＰＣ―９８ＨＡ（みんな、覚えてるか？",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "松下電器のマシンが富士通のＦＭＲ互換であることを考えれば、健全な好奇心を持つものはこっちでも動くのではないかと考える。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "膨大な費用をかけてＴＲＯＮ仕様のマイクロコンピューターを開発した、富士通、日立、三菱電機。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "松下のＰａｎａｃｏｍ　Ｍと富士通のＦＭＲは互換なのだから、こいつ向けにＯＳだけ売ってくれないのかとお願いしてみたが、これも予定していないとのことであった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士通のコンピューター開発史をたどるとき、池田さんの強烈な個性はいやがおうでも目に焼きついてくる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士電機製造（現富士電機）の電話、通信機器部門を受け継いで同社が富士通信機器製造として設立されたのが、一九三五年。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗戦後、頼みの電話設備の需要が一九四九年からのドッジ・ラインに基づくデフレ政策によって急減する中、富士通は従業員の大幅な削減を余儀なくされた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗戦翌年の一九四六年、東京工業大学電気工学科を卒業して富士通に入り、電話のダイヤルのメカニズムに関する解析で数学的な才能を着目されていた池田は、開発の第一歩から作業を担った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした中でも、一九五五年に開発部隊が見舞われた火事の思い出に関する池田自身の言葉は、彼の才能が富士通のコンピューター事業の立ち上げにとってどれほどの重みを持っていたかを雄弁に物語っている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士通の専務となっていた池田は通産省からの働き掛けに対し、ＩＢＭ互換のアーキテクチャを共有するという条件で、同社についで業界二位のポジションを占めている日立となら提携するとした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＢＭの環境を標準として受け入れるこの選択によって、富士通は大型分野において唯一同社に対抗する勢力となった日本企業のリーダーの座を確保した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士通の鬼才、池田敏雄は自らの才能を押し殺すようにＩＢＭ互換路線を選んだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "では自らの独創によって富士通のコンピューターを立ち上げながら、標準に向かう風を読んで独創を封印したこの人物は、この事件を体験したとすれば次に何をなすべきと考えたろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本情報処理開発協会、マイクロプロセッサ応用研究チームと名乗る一行は、慶応大学の高橋秀俊教授をはじめ、日立、富士通、そして日本電気のまともな〈大人〉たちばかりからなっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
