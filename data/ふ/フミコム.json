[
  {
    "uuid": "e1793233-8319-563d-abf1-14f3a7963ee5",
    "entry": "踏み込む",
    "reading": {
      "primary": "ふみこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to step into (e.g. someone else's territory)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "要太郎の指をさす通りにグサ／＼と下駄の踏み込む畔を伝って土手へ上ると、精の足元からまた一羽飛び出して高く舞い上がった。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへみだりに踏み込むことは出来ないので、半七が一応の念を押すと、良助はうなずいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さていよいよ猟場に踏み込むと、猟場は全く崎の極端に近い山で雑草｜荊棘生い茂った山の尾の谷である。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "会場へ一歩、足を踏み込むときは、私は、鼻じろむほどに緊張していた。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっさに、うまい嘘も思い浮ばず、「あちこち、あちこち」　と言い、「皆、めしはすんだのか」　などと、必死のごまかしの質問を発し、二重まわしを脱いで、部屋に一歩踏み込むと、箪笥の上からラジオの声。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神南と堀口は先刻探険に来て、妖婆の姿がもう見えないことを承知していたが、それでもこの横町へ踏み込むと、幾分か緊張した気分にならないわけにはいかなかった。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "街路の人道から入り口へ踏み込むとすぐ右側に石のベンチのようなものがいくつか並んでいるだけで、狭い低い暗い部屋というだけであった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその反対に、そうであってほしいのですが、その住人があなたが来ると知らされ、昨日は踏み込む前に出て行ったのだとすれば、今はもう戻っているので、解決も楽になるでしょう。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "座敷は両側とも雨戸を閉めて、蚊帳が一パイに釣ってあるので、化物屋敷のように暗い上に、黴臭いような、小便臭いような臭気が、足を踏み込むと同時にムッとした。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイズの縮小に関しては、ブラインド・タッチ可能な線でおさめるか、今一歩小型化に踏み込むかが選択のポイントとして残る。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "内容に踏み込むことはレビューの狙いからは外れるだろうが、作品はすっとぼけたゴキゲンな宇宙オトギ話だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "小三の話を聞いて、文字吉の正体も判りましたから、小三を連れて引っ返して、無理に文字吉の家へ踏み込むと、奥の四畳半に岩蔵が寝ていました」「文字吉はどうしました」「文字吉は二階にいました」と、老人はその光景を思い泛かべるように顔をしかめた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "笄橋を渡って、いわゆる渋谷へ踏み込むと、普陀山長谷寺の表門が眼の前にそびえていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "住職も弟子たちもみんな悪い人間ではなかったのですが、いったん悪い方へ踏み込むと、もう抜き差しが出来なくなって、だんだん深淵に落ちて行く。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳も怒って、門を叩き破って踏み込むと、前に言ったような始末であるので、彼はいよいよ怒った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや暫くして、女が出て来て※の一行を招いたので、すぐに武器をたずさえて踏み込むと、一頭の大きい白猿が四足を牀にくくられていて、一行を見るや慌て騒いで、しきりに身をもがいても動くことが出来ず、いたずらに電光のような眼を輝かすばかりであった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし戸を打ち破って踏み込むだけの勇気もなかった。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "西片町の通は往来が絶えて、傘を打つ点滴も聞えず、ぬかるみに踏み込む足駄も響かない。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一足｜室の中に踏み込むと、同時に、悪臭と、暑い重たい空気とが以前通りに立ちこめていた。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、やっぱり酒の店などに一歩足を踏み込むと駄目である。",
              "citation": {
                "source": "作家の手帖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした不用心な時に男も女もあやまった運命へ踏み込むものだと思って源氏は静かに縁側へ上がって中をのぞいた。",
              "citation": {
                "source": "源氏物語",
                "author": "花宴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてさつぱり具体的な日本解明に、足を踏み込むことも出来ず、その醜態のクライマックスを示してゐた時、今事変は本格化した。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな奴等は盗人も同様、あさ寝も昼寝もめずらしくないので、手先は雨戸をこじ明けて踏み込むと、虎七は煎餅蒲団の上に大きい口をあいて蹈んぞり返っていた。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "閾のきしむ雨戸をこじ明けて、水口から踏み込むと、半七は先ず第一の獲物を発見した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして式台を上って、玄関に一足踏み込むと、「この畳は？",
              "citation": {
                "source": "吉良上野の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚、記者の見たところに依れば、良心の鋭いというよりも、気の小さい者が、一朝の刺戟で大胆な自暴自棄的境界に踏み込むことはあり得る。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あゝ、俺は実に悩ましい、この次に此処に踏み込む俺の唯一の目的は、あゝしてあの行灯の下で……」　そんなことを唸つて恰で生体ないかのやうな酔つ払ひ見たいな村井を滝本が漸く引つ張つて、渡り廊下の処まで来ると、雪洞をかゝげて飛んで来た百合子に突き当つた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、向ひ側の馬賊の縄張りに踏み込むために、何だかうら寒い感の夜店通りを素通りしてゐる時、不図傍の露店で、非常な能弁を弄して往く人の脚を止めてゐるのがあつたので覗いて見ると達磨が梯子を転落する玩具だつた。",
              "citation": {
                "source": "日本橋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この寺ではかねて供養に用いる諸道具を別室に蔵めてあったので、賊はその室の戸を打ち毀して踏み込むと、忽ちに法衣を入れてある革籠のなかから幾万匹の蜜蜂が飛び出した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神後記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、彼は勇気を出して、草むらの中へふみこむと、両手でその玉をぎゅっとつかもうと――。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
