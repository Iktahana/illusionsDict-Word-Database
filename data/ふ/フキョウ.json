[
  {
    "uuid": "f4a3fd48-1658-5a0d-b5c5-808f055a33d9",
    "entry": "不況",
    "reading": {
      "primary": "ふきょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(economic) depression",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だが、やがてこの国にも不況が来た。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨今の上海投機の気まぐれで、銀塊相場を有史以来の崩壊に導いた、その余波のためにこの輸出綿花事務所は不況のどん底にいた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "北浜界隈も、支那財界の大混乱のために、対支商談は不況のどん底に陥ってしまった。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき株主によって提唱された他の重大な欠損理由は不況のため高級品の販売絶無となる。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、近頃の田舎の生活ぶりを見聞すると、却って都会より不安、不況、餓死せんばかりの地方がかなり沢山あるようです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界のいずれの国でも、地方はその産物を都会に売って経済を保持して行くのですから、都会におけるその産物の需要如何によって、田舎は富みもし、また不況にもなるわけです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は娘のいる窓や店の者に向って、始めのうちは頻りに世間の不況、自分の職業の彫金の需要されないことなどを鹿爪らしく述べ、従って勘定も払えなかった言訳を吃々と述べる。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界的不況時代にせめてロンドンでの鉄の贅沢だった。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと既にこの時世界の不況は大英の財界にも押し寄せて来て、彼の顧問会社の脈搏不整はこの偉れた財政家に騎士時代の革財布を丹念に繕うような閑道楽を許さなくなってもいた。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつは頭がよくって、何でもはっきり割り切ろうとしていたからなあ」「そうだ、ここのように純粋の軍需品会社でもなく、平和になればまた早速に不況になる惧れのあるような会社は見込みがないって言ってたよ」　山岸は辺りへ聞えよがしに言った。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこの不況険悪の時勢に於て無用｜不廉の事を起し一時の名聞を求むるものとして一笑に附する人士が在ったならば、それは余りにも心なき人々として吾々は怨まざるを得ない。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今一つは少々さもしいお話ですが、流石の炭坑王、谷山家の財政が、その当時の炭界不況と、支配人の不正行為のために、殆んど危機に瀕する打撃を受けていたことでした。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも業界の算盤勘定は堅調だったものが、ここに来て日本のメーカーは厳しい不況に直面させられている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "不況も加わってＭＩＳ部門に予算圧縮の圧力がかかり、メインフレーム中心のメーカーは従来のスタイルは通らないと白旗を上げた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "云ウマデモナク最近ノ不況ハドシ／＼失業者ヲ街頭ニ投ゲ出シテ居リ、ソレハ全く見ルニ忍ビナイモノサエアルノデス。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近戦争の危機がせまっていると見えて、官営の軍器工場では、この不況にも不拘、こっそり人をふやしてるらしい。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "大劇場は歌舞伎座をはじめ、皆そのような不況に陥り、歌舞伎座のごときは創立十五周年という名のもとに、十一月、特に値安興行をこころみるような始末であったが、そのあいだに立って人気隆々たるものは独り本郷座の新派劇だけであった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "インテリゲンツィアの勤労者階級化の傾向はこれに応じて必然に生じたのであり、更に一九二九年の恐慌以後今日に至る一般の不況は、益々深刻にこの社会的現象を展開させている。",
              "citation": {
                "source": "全体主義への吟味",
                "author": "――今日の民衆、知識人への課題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は不況時代で就職は難しいと一般に考えられていますが、しかし、誠意をもって、たましいを打ちこんで自分の職務に尽そうとしている人は少ない。",
              "citation": {
                "source": "「市の無料産院」と「身の上相談」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不況な農村のありあまった労力が現金にかえられるところに、親のよろこびもあるであろう。",
              "citation": {
                "source": "新しい婦人の職場と任務",
                "author": "――明日の婦人へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年からの不況は何しろ、一般の生活にこたえて来ている。",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、さもこの世界的（ソヴェト同盟をのぞいて）不況がそれで救われでもするように、われわれ搾られているものの利権、生命線がそこにありでもするようにジャンジャン満蒙事件をアジリまわす。",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうギャップが現実にあるから舟橋聖一・田村泰次郎がこの不況にトップをきって売れているのです。",
              "citation": {
                "source": "平和運動と文学者",
                "author": "――一九四八年十二月二十五日、新日本文学会主催「文芸講演会」における講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろの出版不況で、文芸雑誌のいくつかが廃刊した。",
              "citation": {
                "source": "しかし昔にはかえらない",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "出版不況は、戦後の浮草的出版業を淘汰したと同時に、同人雑誌の活溌化をみちびき出している。",
              "citation": {
                "source": "しかし昔にはかえらない",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、兄の商売もひどく不況らしかった。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、兄の商売もひどく不況らしかつた。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "前年十月に勃発した第四次中東戦争をきっかけとした石油ショックにより、日本経済は大きな不況に見舞われ、この嵐の中でマイクロコンピューターを生んだビジコン社は倒産に追い込まれる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この不況下、半導体の需要が急激に落ち込む中で、他のメーカーは設備投資を抑えたのに対し、日電は生産ラインの強化を敢行。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "武者は（むさ）侍は（さぶらい）牛車は（ぎっしゃ）不孝は（ふきょう）禿は（かぶろ）敬白は（けいびゃく）――といった類がそれである。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
