      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "getting deeply involved",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "音楽は好きであったが深入りはしなかった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生君がまたその通りで、よく僕の惡口や皮肉を言ひ、時としては必要のない意地惡さへするのであるが、その意地惡がいかにも子供の意地惡らしく、むしろ意地惡されることによつて、友情への深入りを感じさせるほどである。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故郷の風景は舊の通りである、然し自分は最早以前の少年ではない、自分はたゞ幾歳かの年を増したばかりでなく、幸か不幸か、人生の問題になやまされ、生死の問題に深入りし、等しく自然に對しても以前の心には全く趣を變へて居たのである。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "故郷の風景は旧の通りである、しかし自分は最早以前の少年ではない、自分はただ幾歳かの年を増したばかりでなく、幸か不幸か、人生の問題になやまされ、生死の問題に深入りし、等しく自然に対しても以前の心には全く趣を変えていたのである。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、もう少し深入りして訊きてえことがあるんだが、師匠はどうせここへはいるつもりなんだろうから、おれ達も附き合ってもう一度引っ返そうじゃあねえか」「でも、それじゃあんまりお気の毒ですから」「なに、構わねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はもう深入りしてこの児の家の事情を問うことを差控えるのを至当の礼儀のように思った。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころから漱石先生に俳句を作ることを教わったが、それとてもたいして深入りをしたわけではなかった。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして金を掴めば掴むほど、そうした堕落層の裏面に深入りして行った。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会の風教を乱すような邪教｜淫祠、いかがわしい医療方法や薬剤、科学の仮面をかぶった非科学的無価値の発明や発見、そういうものに世人の多くが迷わされて深入りしない前にそれらの真価を探求したい。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんべん読んでもおもしろく、読めば読むほどおもしろみの深入りする書物もある。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんなに話を深入りさしてもいいのかい」　わたくしは、多少後悔に噛まれながら「すみません」と言った。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、交際も餘り深入りすること無しに淡※と淺い川の水が清く流るゝやうに濟ませて行くといふ人であつた。",
              "citation": {
                "source": "淡島寒月のこと",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら信じようと思つても、「さうかな」の信仰より深入りは出來ない。",
              "citation": {
                "source": "海から歸る日",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "卵塔場へ、深入りはしないからよかったけれど、今のを聞いては、足がすくんで動かれないよ。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして葛岡にしろわたくしにしろ、先生を動揺さした害人であり、従って先生に頼っているこの家の家族たちに取っても亦、私たちは迷惑な存在であるとこの弟は思っていながら、しかし事の経緯がこゝまで深入りした以上、私たちをたゞ憎み去るのも不得策である。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり深入りするとまあ身の破滅というたちの女でしょうな。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私は深入りして訊いた。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を瞑つた様な積りで生活といふものゝ中へ深入りして行く気持は、時として恰度痒い腫物を自分でメスを執つて切開する様な快感を伴ふ事もあつた。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を瞑ったようなつもりで生活というものの中へ深入りしていく気持は、時としてちょうど痒い腫物を自分でメスを執って切開するような快感を伴うこともあった。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉弥を一夕友人に紹介したが、もう、その時は僕が深入りし過ぎていて、女優問題を相談するよりも、二人ののろけを見せたように友人に見えたのだろう。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく西洋人の仕事を矢鱈に崇拝して、唯物個人主義的な観念に深入りして行った。",
              "citation": {
                "source": "路傍の木乃伊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "モット尖鋭な肉慾や露骨な犯罪心理に深入りする趣味を、日本人に逆照して見せた。",
              "citation": {
                "source": "探偵小説の真使命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "モット尖鋭な肉慾や、変態心理や、モット露骨な犯罪心理、病的幻覚錯覚に深入りし礼讃する趣味、傾向を日本人に逆照して見せた。",
              "citation": {
                "source": "甲賀三郎氏に答う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に政党屋流にも堕せず、玄洋社流にも共鳴しなかった彼、杉山其日庵主は、単身｜孤往、明治後半期の政界の裡面にグングンと深入りして行った。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一旦、彼に接して、彼の生活に深入りしてみると、その両戦役前後に於ける朝野の巨頭連は皆、彼の深交があった事がわかる。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに一種の詭弁か又は思い違いの深入りしたものに過ぎぬ。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　圭子の母は、長女が芝居の研究会にはいっていることは知っていたが、まさか舞台に出るまで深入りしているとは、知らなかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "美和子などにどうされる前川氏だとは思い得なかったが、しかし自分の方が、美和子に刺戟されて、前川氏とこれ以上、深入りすることの方が、恐ろしかった……。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "左膳も、相手の熱心さにつられて、ついつい深入りをした。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもかういふことは音韻の転訛といふことによりてつぶされるから、さう／＼ふかいりはすまい。",
              "citation": {
                "source": "用言の発展",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
