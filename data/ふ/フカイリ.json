[
  {
    "uuid": "5d558341-0392-58d9-817a-34aab128021b",
    "entry": "深入り",
    "reading": {
      "primary": "ふかいり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
