    "definitions": [
      {
        "index": 1,
        "gloss": "thickened eyebrows",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
