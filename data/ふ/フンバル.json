        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "コンクールを受けた連中はいずれもうやうやしく審査員に頭を下げ、そして両足をそろえて、つつましく弾くのだったが、寿子はつんとぎこちない頭の下げ方をして、そしていきなり股をひらいて、大きく踏ん張ると、身体を揺り動かしながら、弾き出すのだった。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすれば、第二の人がたとい忍び足で近づいていっても、突き落とすときには両脚を踏ん張るのが至当であります。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いとも強いとも、どんなにおれは強いんだと老婆はますます両足を踏ん張ると、腹もお臍もみな表わして人間がみたらそれこそおかしい態となりました。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど袋が小さい上にトテモ丈夫に出来ているので、噛み付こうにも噛み付けないし、力一パイ足を踏ん張ると首の骨が折れそうになるし、その苦しさったらなかったわ。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやに神経を尖らせて注意深く周囲を眺めながら、多少足を踏ん張る如く力強く歩いている彼女は、大概子供を連れているか、あるいは近くの木の根や草むらに幼児を隠している。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "うんと踏ん張る幾世の金剛力に、岩は自然と擦り減って、引き懸けて行く足の裏を、安々と受ける段々もある。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に流派は数あるが、足を前後に開かずに、左右へ踏ん張るというような、そんな構えのある筈がない。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭で綱引きと来るか」　自分も、竿を構えて、足を踏ん張る。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓は後へふんばる牛のやうだつた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆらりとして倒れそうになるのを、片手を石柱にかけ足をふんばると、案外に腰掛工合はよかった。",
              "citation": {
                "source": "椿の花の赤",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは、いくらだつてふんばるよ。",
              "citation": {
                "source": "長閑なる反目（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふんばる処ぢやふん張るよ。",
              "citation": {
                "source": "留守（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロボはその喉に食いついたなり、身を沈め、うんとふんばると、牝牛は、角を地についてまっさかさまに大きくとんぼ返りに倒れる。",
              "citation": {
                "source": "動物物語　狼の王ロボ",
                "author": "アーネスト・トムソン・シートン",
                "note": "青空文庫"
              }
            }
          ]
        }
