[
  {
    "uuid": "6df365de-dadc-5467-8268-794612392f91",
    "entry": "風土",
    "reading": {
      "primary": "ふうど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
