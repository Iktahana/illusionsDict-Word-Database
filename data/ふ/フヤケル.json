    "definitions": [
      {
        "index": 1,
        "gloss": "to swell up (by soaking in or absorbing a liquid)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……天秤かついだ己が形が、何でございますかね、天狗様の下男が清水を汲みに山一つ彼方へといった体で、我ながら、余り世間離れがした心細さに、（ほっ、）　と云ったが、声も、ふやける。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためにまた明日どこかへ押し流されていったら、流れ止まったところで、ふやけるのもよし、ねじ切って棄てるなら、棄てられるのもよし……。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は愛の水に浸して、三日三晩の長きに渉ってもふやける気色を見せぬ。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂に漬かるとどんなに皮膚の綺麗な女でも、一時は肌が茹り過ぎて、指の先などが赤くふやけるものですが、やがて体が適当な温度に冷やされると、始めて蝋が固まったように透き徹って来る。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
