        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ふつうのパンフレットです」「すぐそんなことを言うからな。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主義に於ても、内容に於ても、殆んど全然『感情』を標準にしたところのパンフレットが続々として後から後から刊行された。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」……　最後にジミーは、一人のボルシェビイキの猶太人からリーフレットを受取って、それを二日のうちに全部まいてしまった。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ赭ら顔の白髪の元気のよさそうなおじいさんが、かなづちを持ってよこの室から顔〔以下原稿数枚なし〕が、桃いろの紙に刷られた小さなパンフレットを、十枚ばかり持って入って来ました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私はパンフレットを手にとりました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地学博士も黄いろなパンフレットを読んでしまって少し変な顔をしていました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからだまってお互のパンフレットをとりかえました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色なパンフレットには斯う書いてあったのです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、」その人はあわただしく茶いろのパンフレットをよこしました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度のパンフレットはどれもかなりしっかりしてるね。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのパンフレットを私たちはせわしく読みました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり今朝のパンフレットの話などが多かったのでしょう。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今朝私どもがみなさんにさしあげて置いた五六枚のパンフレットはどなたも大抵お読み下すった事と思う。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私たちは大急ぎで銘々一つずつパンフレットも作り自働車などまで雇ってそれを撒きちらしましたが実は、なあに、一向あなた方が菜っ葉や何かばかりお上がりになろうと痛くもかゆくもないのです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しまあやりかけた事ですからこれからも一度あのパンフレットを銘々一人ずつご説明して苦しいご返答を伺おうと思います。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で私のおたずね致したいことはパンフレットにもありました通り動物がかあいそうだからたべないとあなた方は仰っしゃるが動物というものは一種の器械です。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝のパンフレットで見ましても生物は一つの大きな連続であると申されました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲々あのパンフレットにある豚のように愉快には行かないのであります。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンフレットにも書いて置いた通りそれは人類の勝手に設けた分類に過ぎない。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ然しながら不肖私の語ではない、実にシカゴ畜産組合の肉食宣伝のパンフレット中に今朝拝見したものである。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今朝のパンフレットから考えてきっとあれは動物学者だろうと考えたのです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが恰度その頃から、葛飾は同盟の展覧会やらパンフレットの発刊などに忙殺されて家に落着いている時よりも同盟本部につめ切っていることの方が多くなった。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の夕刊が二枚と、『探偵小説全集』が一冊と、『南京鼠の合理的長命法』と云うパンフレットと、古い帝国ホテル舞踏会の案内状が一枚出て来たばかりでした。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は所謂「同志」に紹介せられ、パンフレットを一部買わされ、そうして上座のひどい醜い顔の青年から、マルクス経済学の講義を受けました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日のために特に刷つた赤字のビラやパンフレット、この日の見物に売捌かうと抱へて来た労働新聞を傍列の赤シャツや黒ヅボンが両側の人波へさあさあと撒く。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コナンドイル未亡人からとどいた神秘主義実験報告のパンフレット。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同人誌や機関誌、パンフレットなど、活版で刷ると高くつく少部数の印刷物が、育ってきた高い技術に支えられて謄写版で作られるようになりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づいていくと、とても聡明そうで、それでいて柔らかな微笑みを浮かべた女性が、パンフレットを手渡してくれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "会場でパンフレットを手渡してくれたのは、創立メンバーの一人である鎌田純子さんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "評価記事を書き、萩野さんのインタビュー記事を読み、マックワールドエキスポで鎌田さんからパンフレットを受け取って言葉を交わすという一連の体験を通じて、私の胸の中では、そんな思いが、まだ言葉にはならないままに育ちはじめていたのだと思います。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
