    },
    "definitions": [
      {
        "index": 1,
        "gloss": "silence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし学者は初め不言裡に「かくのごとき風なき時は」という前提をなしいたるなり。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた実際において、そういう中川べりに遊行したり寝転んだりして魚を釣ったり、魚の来ぬ時は拙な歌の一句半句でも釣り得てから帰って、美しい甘い軽微の疲労から誘われる淡い清らな夢に入ることが、翌朝のすがすがしい眼覚めといきいきした力とになることを、自然｜不言不語に悟らされていた。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからは、不言実行、という事にしましょう。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの日、藤野先生が、ひとりごとのようにしておっしゃった「不言実行」の意味がわかったような気がした。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように誰にも知られず人生の片隅においてひそかに不言実行せられている小善こそ、この世のまことの宝玉ではなかろうかと思った。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上擧の例に照らせば、不言の裏に予が意は自ら明らかであるが、之はまさに一切の美なるもの用有るものに對しては助長の念を懷くべく、決して剋殺の事をなすべからざるものである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも、不言実行には、かなわない。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女体の不言実行の愛とは、何を意味するか。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不言実行とは、暴力のことだ。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤羽｜停車場の婆さんの挙動と金貨を頂かせた奥方の所為とは不言不語の内に線を引いてそれがお米の身に結ばれるというような事でもあるだろうと、聞きながら推したに、五百円が失せたというのは思いがけない極であった。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで窓の格子を隔てた覚束ない不言の交際が爰に新しい 〔e'poque〕 に入ったのを、この上もなく嬉しく思って、幾度も繰り返しては、その時の岡田の様子を想像に画いて見るのであった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時の翁の崇拝者は、不言不語の中に皆しかく信じていたものである。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁も亦、不言不語の間にこの事を覚悟し満足していたらしい事が、その生涯を通じた志業の裡に認められる。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち「捨身成仏」が芸道の根本精神でなければならぬ……というのが翁自身のモットーであり、数々の訓戒に含まれている不言不語の点睛であったらしい。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この道理は小謡の一節、囃子の一クサリ、舞の一と手を習っても、直に不言不語の裡にうなずかれる。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "能楽二百番――もしくは一曲の中に繰返される定型の、ドレ一つとして同一の表現をしていない事が、不言不語の中にわかって来る。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "寡読家の余が「たけくらべ」を読んだのも、「不言不語」を読んだのも、此の文庫のたまものである。",
              "citation": {
                "source": "余話（秘められた箱）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝の幸を知るものは、唯だ不言の夜あるのみ、唯だ起伏の波あるのみ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるをその懷かしき夫の聲の終に應ずることなく、可憐の女子の獨り不言の海に對して口は復た歌ふこと能はず、目は空しく沙上の髑髏を見、耳は徒らに岸打浪の音を聞きて、暮色の漸く死せる古都を掩ふを覺えしこと又幾度ぞ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "日夜悪念去らず、妄執に繋縛さるる者の企て及ぶべからざる、いわゆる不言して名教中の楽土に安心し得る者なり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも人心慰安、思慮清浄を求むるに不言不筆の感化力に須たざるべからざるを知悉すればなり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "その土地の光景、風俗、草木の色などを不言の間に聞き得る事なり。",
              "citation": {
                "source": "遠野の奇聞",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房思わず吹き出して、「ほほほほほ、」　狐床の火の玉小僧、馬琴の所謂、きはだを甞めたる唖のごとく、喟然として不言。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その清浄な膚をもって、緋の紋綸子の、長襦袢で、高髷という、その艶麗な姿をもって、行燈にかえに来た雇の女に目まじろがない、その任侠な気をもって、すべてを愛吉に与えてその晩……」「…………」丹平黙然として少時不言。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "上挙の例に照らせば不言の裏に私の心は自然に明らかであるが、まさに一切の美なるもの用あるものに対しては助長の念を懐くべきであり、決して剋殺の事を為すべきではないのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "『嬉遊笑覧』に『遠碧軒随筆』を引いて、庚申の三猿はもと天台大師三大部の中、止観の空仮中の三諦を、不見、不聴、不言に比したるを猿に表して伝教大師三猿を創めたという。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしなべての男女もまた、社会のこの不言不語の強圧に対して柔順である。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "関ヶ原の戦から後は、牢人調べや女の通行がやかましいと聞いていたが、烏丸家からもらって来た手形がものをいって、ここも難なく通り、両側の関所茶屋から眺められながら牛に揺られて来ると、「ふげんて、なんだろう。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お通さん、ふげんて何のこったい？",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――牛に乗ったふげんみたいじゃのう……ってね」「普賢菩薩のことでしょう」「普賢菩薩のことか。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
