          "literary": [
            {
              "text": "白糸はすでにその身は釜中の魚たることを覚悟せり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かはたまるべき、荊州の兵は、釜中の魚みたいにただ逃げ争って蜀兵の殺戮にたいし、手向う意志も失っていた。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛮軍は釜中の魚みたいに右往左往して抗戦の術を知らなかった。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――釜中の魚はまさに煮られる如く逃げまどった。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
