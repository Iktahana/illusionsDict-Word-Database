[
  {
    "uuid": "02b734d2-bebb-578b-a046-443ada6dce41",
    "entry": "副食",
    "reading": {
      "primary": "ふくしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
