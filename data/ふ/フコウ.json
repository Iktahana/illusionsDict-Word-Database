    },
    "definitions": [
      {
        "index": 1,
        "gloss": "undutifulness to one's parents",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この親不孝者どもが！",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「石松の奴が今に帰るかと思って……」　「そうかい……妾もね、あんな親不孝な伜だけれど、今夜の様に何時までも帰りが遅いと、つい心配になってね」　「おばさん、まあお這入ンなさいよ」　「有難う。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに、自分は、こんな不孝をして悪人となってしまった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "走り書きの短い手紙で、よんどころない訳があって死にますから先立つ不孝はゆるしてくださいというようなことが書いてあったので、おふくろはまたびっくりして、すぐにその書置をつかんで私のところへ飛んで来ました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の事で、こんな騒ぎになって、私ほど悪い不孝な娘は無いという気がしました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しお政さんなんぞは幸福さ、いくら親に不孝な男でも女房だけは可愛がるからね。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "不孝の子であるように言われてみると甚どくそれが気にかかる。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "――父の病気に対する『愛なき恐れ』、金に対する不安、母の辛苦、不孝のために失われたる親子の愛情、学業に対する不忠実、このようなものが入り乱れている頭には、この大芝居の忠臣蔵もおもしろいはずはない。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お年よりに愚痴を聞かせれば、なお不孝。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一色氣があつて世を憚らず、親不孝を顧みざる輩は、男女で相乘をしたものである。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の親のかたきを眼の前に置きながら、おめおめと見てゐるやうな不孝ものに、姉と呼ばるゝおぼえはない。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみの　えゝ、卑怯者……　不孝者……。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "軈がては親は子に對つて、不孝なるやくざ者と罵る、子は親に對つて、無｜慈悲な驅だと毒吐く。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "不孝者をどうぞお許し下さい。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何もしなかつたどころか、父上母上に不孝をした。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は今夜ただ、気持を取直す工夫だけをしなさい」　逸作は、もしこのことで不孝の罰が当るようだったら俺が引受けるなどと冗談のように言って、それから女中に命じて雛妓かの子を聘することを命じた。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、五十五の男が母の前に額をつけ、不孝、この上なしと、詫びたのだつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父上、母上、きょうまでの不孝の罪はゆるして下さい。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の家は、この五、六年、私の不孝ばかりでは無く、他の事でも、不仕合せの連続の様子なのである。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殷答えて曰く、進香は皇考禁あり、遵う者は孝たり、遵わざる者は不孝たり、とて使者の耳鼻を割き、峻厳の語をもて斥く。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ、姦通にも事情はある、親不孝でも理窟を云う。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが親不孝のはじめ。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉さん、僕は親不孝だろうか。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いたる侍　只今｜其方の母御はな……え、思ふだに涙が雫れるわ……其方の不孝をう、怨み、怨み死にに死んでおぢやつたのぢや。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いたる侍　不孝者奴！",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋ふこうなって、色づいて、そしてひらりひらりと落ちる葉もまたうつくしい。",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "林平さんはラッパをどんなふしでふこうかまよいました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はひったくるようにその手紙を取って、すぐ五、六寸破いて櫛をふこうとして見ると、細かい女の字で白紙の闇をたどるといったように、細長くひょろひょろとなにか書いてあるのに気がついた。",
              "citation": {
                "source": "手紙",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じっとして」　首だけねじ曲げてうしろを見ると、きまじめな表情を泛かべ、令子が慶一の濡れた躰をふこうとしているところだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんならわしを、さかなの眼となぜ言やった」「そのように見ゆるから言うたのじゃ」　二人が喧嘩腰になって口から泡をふこうとするのを、翁は又かというように笑いながらしずめた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
