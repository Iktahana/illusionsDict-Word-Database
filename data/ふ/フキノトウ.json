    "definitions": [
      {
        "index": 1,
        "gloss": "edible flower bud of a giant butterbur plant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三時頃の薄い日影が庭半分にさしていて、梅の下には蕗の薹が丈高くのびて白い花が見えた。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "神農像に饌ささぐと、　　　　学士はつみぬ蕗の薹。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "濕地には水芭蕉の青々とした廣葉が枯葦の間から、谷間には蕗の薹や福壽草が腐つた蕗の葉を蹴破つて、ずん／＼と延びて行く。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほろ苦き中に味あり蕗の薹　この句は父性愛の譬えとして好適の句だと思います。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花屋さんがもう、菜の花を売つてゐる、八百屋には蕗の薹。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし胴の肥り方の可憐で、貴重品の感じがするところは、譬えば蕗の薹といったような、草の芽株に属するたちの品かともおもえる。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "路傍にはもう蕗の薹などが芽を出していました。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕗の薹は其の苦味を以ての故か知らぬが、慥に多少の藥餌的效能を有する。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "石垣の草には、蕗の薹も萌えていよう。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕗の薹いづらにふふむ。",
              "citation": {
                "source": "風隠集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕗の薹新らしき蕗の薹かな。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蕗の薹、一つ刺し、二つ刺し、竹の小串に三つ刺して、さて味噌つけて、火に焼きて、あな苦さよと一つ食べ、あなうまさよと二つ食べ、あないつくしと三つ食べて、さてさびしやと我ゐたり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "よき湿りかくて湿らば、竹煮草、葛、蕗の薹ややややにすずろき出でむ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "土かづく黄の福寿さう、蕗の薹、萎へ葉の霜の苺や、裏藪の小すみれもまだ、※枝べのつくつくしまだ、日あたりの枯れし芝生の、下萠えもまだ。",
              "citation": {
                "source": "篁",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕗の薹　新らしき蕗の薹かな。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蕗の薹一つ刺し、二つ刺し、竹の小串に三つ刺して、さて味噌つけて、火に焼きて、あな苦さよと一つ食べ、あなうまさよと二つ食べ、あないつくしと三つ食べて、さてさびしやと我ゐたり。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯れ芝の中に花さく蕗の薹を見いでて、何となしに物の哀れを感じ侍る。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車のほこり浴びても蕗の薹（昭和三年四月、渋柿）　　　　　　　＊　公園劇場で「サーカス」という芝居を見た。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　珊瑚樹垣の根には蕗の薹が無邪気に伸びて花を咲きかけている。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕗の薹を温灰焼にして食えば苦いには違い無い、しかし中々佳い味だ。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　春さきに勝手口の空地に顔を出しているものに、山椒と蕗の薹とがある。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕗の薹は辛辣な皮肉家だけに、絶えず苦笑をしている。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "巧みな皮肉も、度を過ごすと少しあくどくなるように、蕗の薹の苦い風味を好む人も、もし分量が過ぎると、口をゆがめ、顔を顰めないわけにはゆかなくなる。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは八瀬の蕗の薹で、わしが自分で煮つけたものだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私というものも、つまりは八瀬の蕗の薹と同じように、先生にとって一つの肴に過ぎなかったのだ――たしかにそうだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "と頭を掻きながら窓のそばを離れて、蕗の薹を探し始めた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "みるとはたけにはいっぱいふきのとうがでていました。",
              "citation": {
                "source": "落とした一銭銅貨",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "銅貨のあるところを雀におしえたのはこのふきのとうだったのでしょう。",
              "citation": {
                "source": "落とした一銭銅貨",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "年をとるにしたがって、みょうが、とうがらし、しょうが、ふきのとうが好きになるように、茶の木が、茶の花が好きになる。",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・こんなにつかれて日照雨ふる・うらからはいればふきのとう・ほろにがいのも春くさいふきのとうですね（緑平居）　誰も来ない月はさせどもふくらうなけど　利かなくなつた手は投げだしておく日向　げそりと暮れて年とつた　二月廿八日片手の生活、むしろ半分の生活がはじまる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
