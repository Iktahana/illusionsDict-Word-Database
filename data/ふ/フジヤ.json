    "definitions": [
      {
        "index": 1,
        "gloss": "Fujiya (Japanese confectionary maker)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうしてウェルズの短編「壁の扉」の幻覚を思い出しながら、この次にいついかなる思いもかけぬ時と場所で再びこの童女像にめぐり会うであろうかという可能性を、さじの先でかき回しながら一杯の不二家のコーヒーをすするのである。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、不二家はこっち？",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田では三省堂を出てから夜店の古本を見て十銭でエジソン伝など掘出し、あすこの不二家へよってコーヒーとお菓子をたべ、バスで高田の馬場までかえりました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三四年（昭和九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "不二家のお菓子が食べたい、と真弓が言へば、その時の彼の気分と真弓の頼みかたとに依つて、仮令雨がひどくても気もちよく横浜まで（その時分まだ長谷の通には不二家の支店はなかつた。",
              "citation": {
                "source": "水と砂",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして※月か不二家で、ゆっくり昼飯を食べて、珈琲をのんで、銀座をぶらぶらして、三時頃にまた理研へ帰って来られた。",
              "citation": {
                "source": "寺田先生と銀座",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから銀座へ行って不二家へ入り込む。",
              "citation": {
                "source": "恩師",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「不二商事に不二家と来ている。",
              "citation": {
                "source": "恩師",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえりには、『日日』へよって、細君が随筆をかいた稿料をとって、三人で不二家で食事をして、私は現代ドイツ音楽の夕へまわりました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「申兼ねるが、不二家のチョコレートを十円丈け明日直ぐ送ってくれ給え」「はい／＼」「冗談じゃないよ。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「不二家のチョコレートを十円今日直ぐ送ってやって下さい」「そんなに何うするの？",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢張り不二家がお互の負担にならなくて宜しい。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミートパイは、八重洲口の不二家でも売っているが、これはアメリカ式で、ゴツイもの。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "服部哲雄から電話、二時半に心斉橋の不二家に行くと、土屋伍一と稲葉などが偶然来て、つまらない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊水で銀のライター（十五円）一つ買ひ、不二家でホットケーキ食べる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "不二家でクッキー三円包ませる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "不二家で軽く食事して、座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼休み、奥村・徳山と銀座の不二家へ行って食事する。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "不二家のサンドイッチを食ったのみ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "天六下りたところで伊志井寛に逢ひ、不二家でホットケーキなど食ひ、中座の花柳を訪問する。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "不二家で食事、マカロニが国産品でまづかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタッフの相談をきくと今夜発で伊東へロケとか言ってる、休養がほしいから、滝村に予定を変へ一日休ましてくれるよう、その代り今夜滝村をサービスすると話し、さう定り、上山と銀座へ出て、不二家で昼食し、本社へ寄り、那波と座員の月給問題につき研究、文ビルへ行き、六月の旅の、打合せ、配役決定、連名つくり。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時半、不二家の二階で徳山と待ち合せる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "『だつて人殺しだつて言ふじやアないか』とこちらの一人が言ひました。",
              "citation": {
                "source": "夜の赤坂",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして午後になつてから、今朝出て行くとき、木山が預けて行つた金を若竹へ環しに行かうと思つて、静枝が病気見舞ひにわざ／＼持つて来てくれた、ふじやの菓子を抱へて、暫くぶりで外へ出て見た。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋際にふじやという大きな料理屋があって河原に板橋を渡して仲居さん達がお客のおあつらえのお料理を入りかわり立ちかわり運んでゆくのです。",
              "citation": {
                "source": "京の夏景色",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の通りにいけば、國が亡びると言ふじやない、亡びた。",
              "citation": {
                "source": "亡國に至るを知らざれば之れ即ち亡國の儀に付質問",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜花の美は百花を圧して、ふじやまや歌麿北斎と共に世界的となり、ワシントンの空にさえ咲き匂う時代となった。",
              "citation": {
                "source": "桜花を詠める句",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによると伯爵夫人は一週間ほど前から箱根のふじやホテルに滞在中であったが、一昨夜深更に帰宅して、玄関を上るや人事不省に陥り、そのまま息を引き取ったというのだ。",
              "citation": {
                "source": "鉄の処女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "屍体は帝大の方で解剖することになっています』　なお二三の新聞は夫人が投宿していたふじやホテルの支配人の談として、『伯爵夫人は昨日の午後、伯爵からお電話があって、途中までお迎えに来ていらっしゃるからと仰しゃって、お元気にお出ましになりました。",
              "citation": {
                "source": "鉄の処女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふじやホテルに電話をかけたのは私でした。",
              "citation": {
                "source": "鉄の処女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
