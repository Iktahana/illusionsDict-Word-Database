    "definitions": [
      {
        "index": 1,
        "gloss": "indisposition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "○七月、明治天皇御不例に付き、各劇場は二十日頃より相前後して休場。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日、壬午、陰、申剋、将軍家俄かに御不例、頗る御火急の気有り、仍つて戌剋、御所の南庭に於て、属星祭を行はる。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日、癸未、晴、寅剋御不例御減、御夢想の告厳重と云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日、甲午、晴、鶴岳宮放生会、将軍家聊か御不例に依りて御出無し。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿七日、丙午、晴、将軍家御不例の後、始めて鶴岳八幡宮に詣で給ふ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "憚り多き事ながら、殿こそは御一門の柱石、天下萬民の望みの集まる所、吾れ人｜諸共に御運の程の久しかれと祈らぬ者はあらざるに、何事にて御在するぞ、聊かの御不例に忌まはしき御身の後を仰せ置かるゝとは。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "但当時君上御不例、大君殊之外御案じ被遊候に付、御容体申上之為め、御参府前被差立候事。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同書に「御出張先より御不例被為在候」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "太守様は御不例の所を、押して長髪のまま大阪へお越になり、直ちにフランス軍艦へ御挨拶にお出になって、そのまま御帰国なされた。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧一　今度の御不例は大事ありますまいか。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに少し御不例ゆえまた日をかえていらしたらどうかと申しました。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "御不例の初めのころ、今度はどうも御回復のほどもおぼつかなく思われたので、弟子衆が相談してね。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれども御舎弟様御不例に就きまして、小梅のお中屋敷にいらしって、お下屋敷はひっそり致して居りますが、例年の事で、大して賑かな祭と申す方ではないが、ちら／＼町人どもがお庭拝見にまいります。",
              "citation": {
                "source": "菊模様皿山奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇陛下｜御不例の発表があった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "后の御悩が、嵯峨帝の御不例といふ事になつてゐる。",
              "citation": {
                "source": "愛護若",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「公方様、御不例御座遊ばされ候ところ、御養生かなわせられず、去る二十日｜卯の上刻、大坂表において薨御遊ばされ候。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ステファン五世の不例を口実にして、機動演習の延期を命令し同時に軍司令部と参謀本部の方略的乖離を計画して、これに成功しました。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "明神樣の境内で土地のやくざが大喧嘩を始めた時、年が若くて一本調子で、酬いられない苦勞をするのを、一番男らしい仕事と思ひ込んで居た岩松は、房五郎の分まで罪を背負ひ込んで、三宅島へ流されたのは四年前の夏、上樣御不例やら、勤向の神妙さやらで、許されて江戸に歸つたのは、ツイ半年ばかり前のことだつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "人形の誘惑",
                "note": "青空文庫"
              }
            },
            {
              "text": "明神様の境内で土地のやくざが大喧嘩を始めた時、年が若くて一本調子で、酬いられない苦労をするのを、一番男らしい仕事と思い込んでいた岩松は、房五郎の分まで罪を背負込んで、三宅島へ流されたのは四年前の夏、上様御不例やら、勤向きの神妙さやらで、許されて江戸に帰ったのは、ツイ半年ばかり前のことだったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人形の誘惑",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナリン太子殿下横浜御出航以来御不例｜予テ船医ニ於テ流行性｜脳脊髄膜炎ト診断船中ニ於テ御加療中ノ処病勢御険悪発熱三十九度五分｜囈言アラセラレ、嘔吐数回嗜眠状態ニアラセラルル旨イキトス号船長ヨリノ無電ニ接ス。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨年の春、大手の外濠でお目にかかりましたな」　と万太郎も将軍家とは思いながら、急に元の友人的な調子を改めることができないで言うと、「そうそう」と、吉宗はそれにふさわしく快活に相槌を打って、「あれは先将軍の御不例で、身が柳営に馳けつける日であった。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天子、ご不例久しきにわたっておったが、今日ついに、嘉徳殿において、崩御あそばされた」「…………」　何進がそういい終っても、ややしばらくの間、会議の席は寂として、声を発する者もなかった。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お二た方、ごゆるりと」　――執権御不例　と一般にまで、高時の病が公にされたのは、かなり日を経てからだった。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "――当然な幕府要路の関心が、「こは、捨ておけず」　となって、俄に、御不例と公表したのは、手おくれにせよ、一般の疑惑をとくに、多少の効はなくもなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ときに、執権どのの御不例もだいぶお久しいようですが」　義貞が、静かな口調で、訊ねたのである。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "山路の上、有年川を越える難儀もあるが、朝立てば、やがて早や播州側の登り道へさしかかっているはず、こうしてはいられまい」「いやまだ、お急ぎにはおよびません」「なんで」「またも帝のご不例か、前日の疲れか、同勢は今朝まだ有年の山寺を出てはおりませぬ」「はてな？",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "きけばお上にも御不例とか」「いや、お熱もさがって、今日はややおよろしい方なのです」「おかぜですな」　清高は一歩、本堂のうちへ入って、坐る所をさがすかのように見まわした。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝の左右の人々は、「お上には、ご不例である。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "垂玉の乳房ただ淡雪のごとく含むと舌にきえて触るるものなく、すずしき唾のみぞあふれいでたる。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といふれいの芭蕉翁の行脚の掟にしたがつたわけであるが、しかし、他のもつと重大な箇条には見事にそむいてしまつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
