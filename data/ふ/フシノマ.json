    "definitions": [
      {
        "index": 1,
        "gloss": "space between two nodes (on bamboo, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "Ｘ町のそばには鮎のいる瀬川が流れて季節の間は相当｜賑った。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生憎と今は季節の間になっているので……。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｘ町のそばには鮎のゐる瀬川が流れて季節の間は相当｜賑つた。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その季節の間はしたがって、教室の中も薄暗かった。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯十九章を見るに、二十二節と二十三節の間に何らの間隔もないが、実はこの間に一の休止（pause）を置いて読むべきものであろう。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夏臘」という字と、「有漏」という字が、節の間を往ったり来たりする。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "白く粉をふいた青竹の節節の間を、ゆれ過ぎてゆく釣竿の一団の中に、私の子供も一人混っている。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界はこの季節の間、北に向つて進むかぎり、どこまで行つても白いもののほか見るよしもない寂寞とした、單調な、人間にとつて極限までも無力なる死の擴がりである。",
              "citation": {
                "source": "地方主義篇",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が此処へ通つたのは丁度一冬の間、秋の終りから春にならうとする寒い一季節の間であつた。",
              "citation": {
                "source": "母",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が此処へ通ったのは丁度一冬の間、秋の終りから春になろうとする寒い一季節の間であった。",
              "citation": {
                "source": "母",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その第一七小節から五小節の間は右手が六つの十六分音符を叩く間に左手は四つの十六分音符を叩く。",
              "citation": {
                "source": "音楽界の迷信",
                "author": "兼常清佐",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは木虱のゐる季節の間ずつと、云ひ換へれば、一年のうちの少くとも半分の間は、繰り返す。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節の間も季節外も我々はこれからの救済について大量に説教してきて、州報告、公衆衛生雑誌、医学雑誌を一杯にした。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の短祷の諳誦、聖書のある節の講話、それに續いて聖書の句節の間の間伸のした朗讀が一時間位行はれた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "信者たちは、この四旬節の間に絶えず断食を行った。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "がそれに加えて彼をこの地に釘づけにするような事件が、この四旬節の間に、次から次へと起って来たのである。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "四旬節の間に、一人の年若い助任司祭がディーニュにきて大会堂で説教をしたことがあった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "さい前のお話では、その大蠍は関節と関節の間に可成の隙間があって、押えつけると随分小さくなり相だという事でしたね。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
