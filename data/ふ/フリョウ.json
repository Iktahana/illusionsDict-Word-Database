[
  {
    "uuid": "93ec7a69-9a25-5d72-9572-86fce4bea711",
    "entry": "不良",
    "reading": {
      "primary": "ふりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
