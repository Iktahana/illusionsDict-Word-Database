        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もう一週間になるが不猟で、三頭しか取れない。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今夜みたいに不猟なことはねえ。",
              "citation": {
                "source": "鬼退治",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日はことの外不猟だったせいか、家光は恐ろしく不機嫌で、近習達とろくろく口も利きません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金色の処女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょうひょうふりょう、りょうふりょう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　りょうりょうふりょうと笛が鳴る。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　笛の音いろは一色に、りょうりょうふりょうと鳴っている。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
