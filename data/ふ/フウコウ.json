    "definitions": [
      {
        "index": 1,
        "gloss": "(beautiful) scenery",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
