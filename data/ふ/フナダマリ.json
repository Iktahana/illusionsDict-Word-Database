    "definitions": [
      {
        "index": 1,
        "gloss": "moorage (esp. for small boats)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
