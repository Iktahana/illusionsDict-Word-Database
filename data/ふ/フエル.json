    "definitions": [
      {
        "index": 1,
        "gloss": "to increase",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これは基督の再臨の兆だというので、お詣りが増える。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "減るどころか事によると少し増えるかも知れません。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎も角あのぜにさしのお銭の、増えることが出来たのだから。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「川も春になると、雪解で水かさが増えるでええのう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでも営業している手前どうせ税の増えることばかりだ。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏人の多い町で、よくよく金に困って、質草もなくただ利子に追われている質札ばかり増えるのを持て余している者がちょっとやそっとの数ではあるまい。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかい、知識が一つ増えるたびに、前に覚えたものを忘れることになるのだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "数の少ないうちは、壁をくり貫いて作った戸棚や櫃におさめられていたものが、次第に冊数が増えると図書室が設けられるようになります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この問いに答えられずに消えていくソフトは、ますます増えるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方こっちでは、タイム・シェアリングで気分は独り占めと言っても、仕事は増える一方、プログラマーも増える一方でぶら下がる端末も増えてくる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "露伴先生を原作で読む人が一人でも増えることを願っています。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天気の時より病人が増えるだろう」と自分も気のなさそうに返事をした。",
              "citation": {
                "source": "初秋の一日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "男のテューターも四人増えるぞ」　そりゃ、そうだろう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道の産米がそれで一躍鰻上りに増えるのだった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに近頃また日増に註文が増えるといふのは、何も連中は体裁をつくる仕儀ばかりぢやなくつて、脛に傷持つ方々が意外の数だといふんです。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "港へ着くと噂をきいたあちこちの鼠が集つて来て、王様のために働きたいと申し込んで来るので、兵士の数は見る見るうちに増えるばかりです。",
              "citation": {
                "source": "船の中の鼠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに近頃また日増に註文が増えるというのは、何も連中は体裁をつくる仕儀ばかりじゃなくって、脛に傷持つ方々が意外の数だというんです。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月が過ぎて齡が一つ増えると、もううかうか出来なかった。",
              "citation": {
                "source": "焔",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩いて行くに従って路の上に含有される人間の密度が多くなって来たが、それは益々増える一方で、軈てのこと科学者は人間の群から圧迫せられてどうにも動けなくなった時、彼自身が縁日の夜店の真唯中に在ることを発見した。",
              "citation": {
                "source": "科学者と夜店商人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "生業は奪はれ、税金は高くなり、諸式は騰り、増えるのは小供許り。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "生業は奪はれ、税金は高くなり、諸式は騰り、増えるのは子供許り。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の末からとるたびに百目二百目ずつ増える。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが中身にはいっさい触れようとせず、美辞麗句を連ねてマイクロコンピューターの素晴らしさを謳い上げたり、表に現われている機能だけを気まぐれにつまみ食いしたような記事ばかりが増えるのが気になった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "開発の経緯を明らかにするとともに、筆者に抗議した一文を十月号に寄せた石田は、今後は「オリジナルなソフトウエアを開発する人が増えることを祈ってやまない」と原稿を締めくくった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それも千鶴子一人がどうやら嗅ぎつけたらしい以外には、塩野も由吉もまだ知らず、席は料理の数が増えるにつれ賑やかになっていった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "途方に暮れて惘然して居れば尚増える借金だ。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「張る」「ふえる」「腫るる」などもｈまたはｆにｒの結合したものである。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし私のいうように「ヌ」が二類にわかれず、「ノ」が二類にわかれているとすれば、ア段とウ段とには全くなくなり、オ段はふえることになりますが、オ段は特に多いのであって、『古事記』にのみ二類に分れているのも「モ」であって、オ段に属します。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが武の母は石井翁の細君の妹だけに、この無為主義をあやぶみ、姉は盲従してこそおれ、女はやっぱり女、石井さんの隠居仕事で二十五円の上に十円ふえるならどのくらい楽と思うか知れないと、武をして石井翁を説き落とさすつもりでいるのである。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "近来は鉄筋コンクリートの住宅も次第にふえるようである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
