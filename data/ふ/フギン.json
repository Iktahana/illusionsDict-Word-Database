        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "午前午後の作務、日中｜諷経、念経、夜座も、日常の生活になってしまった。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝課諷経に随喜する。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏前にかしこまつて、焼香諷経、母よ、不孝者を赦して下さい。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "水をたゞようて桐一葉・夕焼うつくしい旅路もをはり　　　　□・青葉ふかくいち高い樹のアンテナ・ゆふべのラヂオの泣きたうなつた　七月十一日四時前に起きた、掃除して、湯にはいつて、朝課諷経してゐるうちに、やうやく夜が明けた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩課諷経の最中に誰だか来たけはいを感じたが、そのまゝ続ける、すんでから出てみると、農学校の給仕君が、樹明君からの贈物だといつて、木炭一俵を持参してゐる、かたじけなく頂戴、時雨のなかを帰つてゆく彼に頭をさげた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝課諷経は食後にして、大根おろしに納豆で食べる、朝飯はいちばんうまい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "日中諷経は修證義、その語句が身にしみる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩課諷経は普門品にする、偈頌の後半部はまつたくうれしい、身心がのび／＼するやうだつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "で代々清僧が住職に成つて、丁度｜禅寺か何かの様に瀟洒した大寺で、加之に檀家の無いのが諷経や葬式の煩ひが無くて気｜楽であつた。",
              "citation": {
                "source": "蓬生",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほどなく経文を暗んじて諷経に唱和し、また作法を覚えて朝夜の坐禅に加はり、敢て三十棒を怖れなかつた。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "参禅の三摩地を味ひ、諷経念誦の法悦を知つてゐたので、和尚の遷化して後も、団九郎は閑山寺を去らなかつた。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎の坐禅諷経を封じて、山陰へ木の芽をとらせに走らせ、又、屡々蕎麦を打たせた。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝早くの洗面さえもが、この人には道を修めることで、法鼓、諷経等の朝課の勤めも、払暁に自ら鐘楼に上って大鐘をつき鳴らすことも、その日その日をみたして行こうとする修道の心からであった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "御公儀御法会の時、於京都九品派の出家諷経に出座ある時、御不（布）施物の外に施行下さるゝ由、総て施行は乞食非人に被下事也。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほどなく経文を暗んじて諷経に唱和し、また作法を覚えて朝夜の坐禅に加わり、敢て三十棒を怖れなかった。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "参禅の三摩地を味い、諷経｜念誦の法悦を知っていたので、和尚の遷化して後も、団九郎は閑山寺を去らなかった。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎の坐禅諷経を封じて、山陰へ木の芽をとらせに走らせ、又、屡※蕎麦を打たせた。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "十刹の僧ども経を捧げ諷経をなせり。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
