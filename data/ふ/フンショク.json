    "definitions": [
      {
        "index": 1,
        "gloss": "embellishment (e.g. of a story)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "生れたばかりの赤ん坊の足の裏と同じやうにやはらかくて綺麗なのに違ひない、と思へば、これといふ目立つた粉飾一つも施してゐない乙姫のからだが、いよいよ眞の氣品を有してゐるものの如く、奧ゆかしく思はれて來た。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩は茲で、アラヽギ諸同人に忠告を試みたい、我諸同人の歌は、概して形式を重じ過ぎた粉飾の過ぎた弊が多いやうであるから、石川君の歌などの、とんと形式に拘泥しない、粉飾の少しもないやうな歌風を見て、自己省察の料に供すべきである。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い民謡と、新民謡新流行歌とを対比する様に、現代人の言葉には非常に粉飾が多いが、昔の人の言葉には余分のものがない。",
              "citation": {
                "source": "気まま者の日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノラは一階のマーケットで彼女のエロチシズムと薄鼠色の蠱惑で商品を粉飾した。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "清長型、国貞型、ガルボ型、ディートリヒ型、入江型、夏川型等いろいろさまざまな日本婦人に可能な容貌の類型の標本を見学するには、こうした一様なユニフォームを着けた、そうしてまだ粉飾や媚態によって自然を隠蔽しない生地の相貌の収集され展観されている場所にしくものはないようである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は一見仲よく暮らしているように見えながら、親子は親子で、夫婦は夫婦で相喰み、不潔物に発生する黴菌や寄生虫のように、女の血を吸ってあるく人種もあって、はかない人情で緩和され、繊弱い情緒で粉飾された平和の裡にも、生存の闘争はいつ止むべしとも見えないのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れたばかりの赤ん坊の足の裏と同じやうにやはらかくて綺麗なのに違ひない、と思へば、これといふ目立つた粉飾一つも施してゐない乙姫のからだが、いよいよ真の気品を有してゐるものの如く、奥ゆかしく思はれて来た。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は浙江省の紹興に生れ、あの辺は東洋のヴェニスと呼ばれて、近くには有名な西湖もあり、外国の人がたいへん多くやって来て、口々に絶讃するのですが、僕たちから見ると、あの風景には、生活の粉飾が多すぎて感心しません。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の歴史の粉飾、と言ったらいいでしょうか。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "粉飾するのみが仮装ではないのである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一奇男児なる道也、其粉飾を脱し去れば、凡々たる遊冶郎。",
              "citation": {
                "source": "「伽羅枕」及び「新葉末集」",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題点は事実の骨組みだけを抜き出すこと――すなわち否定できない純然たる事実の骨子を粉飾まみれの論説報道から取り出すにある。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡の残した貞世の枕もとの花束だけが、そしておそらくは（自分では見えないけれども）これほどの忙しさの間にも自分を粉飾するのを忘れずにいる葉子自身がいかにも浮薄なたよりないものだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この關係は、ルナチャルスキーの場合ですら、粉飾され、婉曲に言いあらわされ過ぎていると私は思うのであるが、若しこの關係が明白になれば、プロレタリア文學の存在理由が少しでも薄弱になると思うなら、それは甚だしい誤解である。",
              "citation": {
                "source": "政治的價値と藝術的價値　マルクス主義文學理論の再吟味",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、あらゆる夢や粉飾を退けて、一元的唯物論の立場から諸々の自然現象を洞察しようとする堅い意志を持つた理論家であつた。",
              "citation": {
                "source": "ゾイラス",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上がすべての臆説を排除し、出来るだけ粉飾を加えないで述べた事件の骨子だ。",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "粉飾なくていいではありませんか。",
              "citation": {
                "source": "「女人芸術」か「女人大衆」かの批判について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本文学の歴史において一つの画期を示したこの自我の転落は、当事者たちの主観から、未来を語る率直悲痛な堕落としては示されず、何か世紀の偉観の彗星ででもあるかのような粉飾と擬装の下に提示され、そこから、文学的随筆的批評というようなものも生じた次第なのである。",
              "citation": {
                "source": "文学精神と批判精神",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かにそれは葉村氏の理解に信頼して、庸三の個人的に洩らした微かな憎悪の言葉が、粉飾と誇張に彩られたもので、むしろ葉村氏の心持で忖度された庸三の憎悪を、彼に代わって彼女に投げつけているようなものであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "モデルがはっきり誰であるとも示すこともできないように、彼女一流の想念の花で粉飾されてあった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では良妻賢母という言葉によっては既に新しい刺戟を与えられないが、服飾や愛の技巧の研究に女が公然と物を云うようになると同時に、そういう趣味的な面を通じて、案外な程度に、復古へ誘いこまれ、性的な交渉では女が受身という点が粉飾的に強調されている。",
              "citation": {
                "source": "日本の秋色",
                "author": "――世相寸評――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきおい陳腐な本質の粉飾としての形式主義に、芸術至上主義に堕さざるを得ない。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつれた体に粉飾してアクセントをつけたとして、それがよいセンスだろうか。",
              "citation": {
                "source": "衣服と婦人の生活",
                "author": "――誰がために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その美しさにしろたのしさにしろ、その民族或いはその人々が実際には半ば奴隷の立場に甘んじていて、自分の民族の独立や世界の平和のために良心的な何の発言も行動もなし得ないほど無気力であったなら、その固有の服装が優美であり、みものになるという事実が、卑屈の粉飾以外の何ものでもないことになる。",
              "citation": {
                "source": "この三つのことば",
                "author": "――わたしたちは・平和を・欲している――",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想から別にされて理解された文化は、国民的粉飾でなければ、行政の一手段にしか過ぎないだろう。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "五ヵ月後、彼が遂に死んだ時も、母はこの濁世に生きるには余り清純であった息子の霊界への飛翔という風に、現実の敗北を粉飾してその心にうけとったのであった。",
              "citation": {
                "source": "母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、この插話がもし実際あったことなら、本当の面白さは後から粉飾された小天使めいた解釈とは別のところにあると思われる。",
              "citation": {
                "source": "フロレンス・ナイチンゲールの生涯",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦女奴隷の上に悲しくも粉飾された町人の自由と人間性との表示でした。",
              "citation": {
                "source": "一九四六年の文壇",
                "author": "――新日本文学会における一般報告――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
