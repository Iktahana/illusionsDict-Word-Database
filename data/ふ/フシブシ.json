          "standard": [],
          "literary": [
            {
              "text": "（Ｆ・Ｏ）　＝（Ｆ・Ｉ）夜の町　惨々な目に遭って節々の痛みに足を引き摺り乍ら帰って来る典六。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車に揺られて、節々が痛む上に、半分寐惚けて、停車場に降りた。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる過去へのあこがれと、未来への希望とがその樅の小枝の節々につるされた色さまざまの飾り物の中からのぞいているのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という言葉の節々、其声音、其眼元、其顔色は実に大なる秘密、痛しい秘密を包んで居るように思われた。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は水車場を立ち出でてそのまま街の方へと足を転しつ、節々空を打ち仰ぎたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "発句すなわち今の俳句はやはり連歌時代からこれらの枝の節々を飾る花実のごときものであった。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また感謝と恍惚が身体の節々まで浸み通り、皮膚さえ匂わしく感じられるのです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "掴みかかり度いのを堪えて彼等は指の節々を撫で折って手をしなやかにした。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜に鳴く蟲の黒い影が、世を怨む女の瞳の如く、蘆の折葉の節々は、卒堵婆に、浮ばない戒名を刺青したか、と明るく映る。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑ってみれば、疑える節々が思い当らないでもなかったのです。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜も楓も桃も、次ぎ次ぎに季節々々の盛りを見せた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬は繊細｜執拗に編み交り、捲いては縒れ戻る枝や蔓枝だけが残り、原始時代の大｜匍足類の神経か骨が渇化して跡をとゞめてゐるやうで、節々に吸盤らしい刺立ちもあり、私の皮膚を寒気立たした。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから先はもう死んだ気になってしまって打たれていたが、余りいつまでも打たれている中に障えることの出来ない怒が勃然として骨々節々の中から起って来たので、もうこれまでと源三は抵抗しようとしかけた時、自分の気息が切れたと見えて叔母は突き放って免した。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して潮は節々月々に少しづゝ遞減遞増して、春に於て晝間の大高潮大低潮を爲し、秋に於て夜間の大高潮大低潮を爲し、春秋晝夜を以て一年の一大回環を爲し遂ぐるのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "島山さんが喜ばないのに、こうして節々おいでなさるんです。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、姉姫様の御心づくし、節々は御閲読の儀をお勧め申まするので。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝、彼が母屋の中央の贅沢な呉蓙の上で醒を覚ます時は、身体は終夜の労働にぐったりと疲れ、節々がズキズキと痛むのである。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸すやうに温い――また柔かな頸に圧されるやうに重い春の午後の空気のうちに、自分は夢みるやうに、一種の軽い疲労を感じながら、耳に来る節々に少さき時への聯想、まだ残つてゐる昔の空想を一々結びつけてゐた。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "及ばない力がたゆみの感じを身体の中へ押し戻しますと、恍惚とした甘さが骨の節々にまでも浸み亘ります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はと竦む節々の凍る音。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "機構が稍々大きく、歌ふものとしての整斉を節々句々或は字脚、アクセントの上に必要とし、相当に複雑してゐるので、眼を瞑つてただ心頭に案配し調律することは容易でなかつた。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰でも知っている通りサナダ虫は一｜丈も二丈もある上に、短かい節々のつながりが非常に切れ易いので、全部を引出し終るにはナカナカ時間がかかる。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "節々は、垢切に捲かれた膏薬で折り曲げもならぬほどであった。",
              "citation": {
                "source": "蜜柑",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲中には間何の縁故もなき曲より取りたる、可笑しき節々を高く、作譜者と姫とは之に連れて歌ひたるが、忽ち旨し／＼、場びらきの樂は畢りぬ、いざ幕を開けよといふとき幕閉づ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "野葡萄の蔓の節々についた珠のやうな芽の美しさなどはまつたく言葉には現はせない。",
              "citation": {
                "source": "庭さきの森の春",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "路はその雑木の中に出つ入りつ、糸を引いて枝折にした形に入る……赤土の隙間なく、凹に蔭ある、樹の下闇の鰭爪の跡、馬は節々通うらしいが、処がら、竜の鱗を踏むと思えば、鼈の足痕を辿るよとも疑われた。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし鉛の固まりを呑んだような倦怠感や節々の痛みは、いつまでも付いて回りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "人畜を挙げて避難する場合に臨んでも、なお濡るるを恐れておった卑怯者も、一度溝にはまって全身水に漬っては戦士が傷ついて血を見たにも等しいものか、ここに始めて精神の興奮絶頂に達し猛然たる勇気は四肢の節々に振動した。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人畜を擧げて避難する場合に臨んでも、猶濡るゝを恐れて居つた卑怯者も、一度溝にはまつて全身水に漬つては戰士が傷ついて血を見たにも等しいものか、茲に始めて精神の興奮絶頂に達し、猛然たる勇氣は四肢の節々に振動した。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして潮は節々月々に少しずつ次第に減り次第に増して、春には昼間の大高潮・大低潮となり、秋には夜間の大高潮・大低潮となり、春秋昼夜を以って一年の一大｜回環をするのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
