      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unlawful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "此三円の財貨を被告が不法に窃取したために、郵便局長が調べ、警察が調べ、検事局が調べ、一審裁判所が調べ、今又控訴裁判所が調べた。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く責任能力ある人が為した不法行為。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども之を古制に比すれば封境過大にして、諸王又｜率ね驕逸不法なり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "臣又願わくは陛下｜益々親親の礼を隆んにし、歳時伏臘、使問絶えず、賢者は詔を下して褒賞し、不法者は初犯は之を宥し、再犯は之を赦し、三｜犯改めざれば、則ち太廟に告げて、地を削り、之を廃処せんに、豈服順せざる者あらんやと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏四月｜西平侯沐晟、岷王梗の不法の事を奏す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "高師直に取っては臣下の妻妾は皆自己の妻妾であったから、師直の家来達は、御主人も好いけれど女房の召上げは困ると云ったというが、武田信玄になると自分はそんな不法行為をしなかったけれども「命令雑婚」を行わせたらしく想われる。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯のごとく汝らも外は正しく見ゆれども、内は偽善と不法とにて満つるなり。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、弱者と見て傲り、群集を頼み、旅先を茶にして、彼ら観光団の俗悪者は不法を不法と思わず、無礼のありったけを尽したに相違ない。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "不法監禁だぞ畜生……ドウスルカ見ろ……龍代の阿魔……。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "役人が勝手に人民から税を取り立てるのは不法である。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくトリヴェリアン先生があなたに、私の部屋にけしからん不法侵入があったとお伝えでしょう。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のしたことは初めから訴えられる要素がないけれど、あなたがその扉を閉めている限り、常にあなたは暴行の脅迫と不法拘束で訴えられるおそれがある。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "拙見をもってすれば、従来神恩を戴き神社の蔭で衣食し来たりし無数の神職のうち、合祀の不法を諤議せるは、全国にただ一人あるのみ。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "役所や大学のデータベースに、パーソナルコンピューターを使って不法にアクセスを試みるコンピューター犯罪。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一九九二年五月になって本筋の著作権侵害の訴訟に対し、連邦地裁陪審は「ＡＭＤが８０２８７互換コプロセッサーにインテルのマイクロコードを利用したのは不法である」との判断を下した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "不法の云いがかりをすると、容赦しないぞ」　この時、露路の口から忍ぶようにはいって来る足音がきこえたので、半七はあわてて井戸側のかげに身をかくすと、一人の男があたりを見まわしながら、小左衛門の家の格子をそっとあけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "左様な不法を働いて、君はたとい我を懼れずと誇るとも、省みて君のこころに恥じないであろうか。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "禍害なるかな、偽善なる学者、外は人に正しく見ゆれども、内は偽善と不法とにて満つるなり。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本的經濟組織ノ爲ニ國内ニ不法ナル土地兼併が行ハレテ、大多數國民ガ其生活基礎タル土地ヲ奪取セラレツツアルヲ見ルトキ、國家ハ當然ニ土地兼併者ノ自由ヲ制限スベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地ノ國際的分配ニ於テ不法過多ナル所有者ノ存在スルコトニ革命的理論ヲ擴張セズシテハ、言論行動一瞥ノ價値ナシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "國家ハ又國家自身ノ發達ノ結果他ニ不法ノ大領士ヲ獨占シテ人類共存ノ天道ヲ無視スル者ニ對シテ戰爭ヲ開始スルノ權利ヲ有ス。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが為に慰めらるるとにはあらねど、その行へる残忍酷薄の人の道に欠けたるを知らざるにあらぬ貫一は、職業の性質既に不法なればこれを営むの非道なるは必然の理にて、己の為すところは都ての同業者の為すところにて、己一人の残刻なるにあらず、高利貸なる者は、世間一様に如此く残刻ならざるべからずと念へるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ウッカリ当局者が滑らした口吻に由ると不法殺人であって、殺されたものは支那人や朝鮮人でないのは明言するというのだ。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、支那人でも朝鮮人でもないものを殺した不法殺人で戒厳軍司令官初め二、三の重職が解職され、一、二の軍憲が司法へ廻されたというこの日の突発事件はヨモヤとは思うがドウも大杉と関聯しているらしいというのが安成の憶測であった。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度二葉亭は居合わしたので不法を詰ってかれこれ押問答をすると、無法にも二、三人の巡査が一度に二葉亭に躍り蒐って戸外へ突飛ばし、四の五のいわさず拘引して留置｜檻へ投げ込んでしまった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、てつきりこの奴と睨んだだけで、外に證據もないことであるから、係の警察官も持て餘した揚句、不法な拷問を試みた。",
              "citation": {
                "source": "女",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤバいよ」　いまや、空き部屋への「不法侵入」は、高志の専売特許ではなくなっていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんな不法な、無茶な話があるか。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "古事記や日本紀や風土記などの元の形も、出来たか出来なかつたかと言ふ古代は、かういふほうとした気分を持たない人には、しん底までは納得がいかないであらう。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふくろふほう、ほう、ごろすけほう、ほう、なに鳥でせうかと誰かがいふとあれはふくろふだとみんな耳をかたむけるほう、ほう、ごろすけ、ほう、ほう、田端の奧の入梅深いばんにはほう、ほう、ごろすけほうと啼く。",
              "citation": {
                "source": "星より來れる者",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
