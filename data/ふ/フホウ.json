[
  {
    "uuid": "bb6663e5-3434-5d7c-af66-2db621437576",
    "entry": "不法",
    "reading": {
      "primary": "ふほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
