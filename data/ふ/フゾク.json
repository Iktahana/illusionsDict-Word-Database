          "literary": [
            {
              "text": "ふぞくした襦袢でも、下布でも、みんな竪長、横長、角型であるから、たち屑も出ないが、裁ち、縫ふのが楽であると共に、着るのも楽だ。",
              "citation": {
                "source": "きもの",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "内にいれ、二人か三人かででかけ｜万※一の時ハ、グワンとやいて、とふぞくの金玉までひきたくり申候。",
              "citation": {
                "source": "手紙",
                "author": "文久三年六月二十九日　坂本乙女あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふぞくした繻絆でも、下布でも、みんな堅長、横長、角型であるから、たち屑も出ないが、裁ち、縫ふのが樂であると共に、着るのも樂だ。",
              "citation": {
                "source": "きもの",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには、ふぞくの小さい金物があるのです。",
              "citation": {
                "source": "おれは二十面相だ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
