    "definitions": [
      {
        "index": 1,
        "gloss": "to appear uneasy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
