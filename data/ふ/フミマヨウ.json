    "definitions": [
      {
        "index": 1,
        "gloss": "to lose one's way",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "愛子はいまにきっと自分以上に恐ろしい道に踏み迷う女だと葉子は思った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道に踏み迷うたとかいう話じゃが、どこへの旅の途中じゃ」「………」「怖うはない、いち夜はおろか、ふた夜三夜でも、そなたが気ままな程に宿をとらせて進ぜるぞ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "重景は語を續けて、『事の始めはくだくだしければ言はず、何れ若氣の春の駒、止めても止まらぬ戀路をば行衞も知らず踏み迷うて、窶す憂身も誰れ故とこそ思ひけめ。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「われ三十路半ばにして道に踏み迷う。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "林学士は斯く云うた、北見、釧路、十勝に跨る針葉樹の処女林には、アイヌを連れた技師技手すら、踏み迷うて途方に暮るゝことがある、其様な時には峰を攀じ、峰に秀ずる蝦夷松椴松の百尺もある梢に猿の如く攀じ上り、展望して方向をきめるのです、と。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "折しも五郎兵衛は踊りの師匠の娘と恋に落ち、漁色の余裕を喪失して真の闇路を踏み迷う身となった。",
              "citation": {
                "source": "露の答",
                "author": "ぬばたまのなにかと人の問ひしとき露とこたへて消なましものを",
                "note": "青空文庫"
              }
            },
            {
              "text": "流石に正成もハッとしたが、「これは大将御内の者でござるが、道に踏み迷うてかくの通り」　と、早速に云い放して足を早めた。",
              "citation": {
                "source": "赤坂城の謀略",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで次に、おそらく何か他のものを不用意に私と思い違いしないように、かくてまたこのすべてのうち最も確実で最も明証的であると私の主張する認識においてさえ踏み迷うことがないように、注意しなければならない。",
              "citation": {
                "source": "省察",
                "author": "MEDITATIONES",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間の猛獣と薬草　それから数々の山及び猛獣の棲んで居る山際を通り、あるいは一歩を誤れば数千仞下の谷間の鬼となってしまわにゃあならぬ所を沢山進んで行きましたけれども、案内者がありますから道に踏み迷うような気遣いはございません。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは碧梧桐が常に新を欲して踏み迷うた感があるのを残念に思って言った言葉である。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして男の装いしたる有様こそ怪しけれ」　ことさらにいうとも思えないほどの自然な調子、朗々たる音吐で、雅文体の問答をしかけられましたので、捕えられた男装の婦人は、「はい、小仏より上野原へまいる途中、駕籠を見失い、道に踏み迷うてこれへまいりました」　面を伏せて柔順に答えました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "このまま途を踏み迷うとすれば、あるいは此処にいる兵隊と同じ運命をたどることになるのかも知れなかった。",
              "citation": {
                "source": "日の果て",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは仏子にあるまじい心病にとりつかれ恥かしい迷路を幾日も踏み迷うていた、犯さねどすでに心は汚罪を冒したに等しい。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "分け入れば分け入るほど、踏み迷うばかりです。",
              "citation": {
                "source": "剣の四君子",
                "author": "柳生石舟斎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆくすえ再び名聞や利欲の争いに踏み迷うなよ。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれにはまいあがる力はなくて、ふみまよう力だけしかないからだ。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の理性は一朝あの一般共通の大道を見失うと、たちまちにして幾千という小みちの間にふみまようのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
