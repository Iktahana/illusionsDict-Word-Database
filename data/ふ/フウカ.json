  {
    "uuid": "866c398f-c660-5a50-b59e-056124e752fa",
    "entry": "富家",
    "reading": {
      "primary": "ふうか",
      "alternatives": [
        "ふか"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wealthy family",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼の幸福は、決して暖衣飽食して富家に飼われ養われて居る生活のなかには感じられなかったのです。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の幸福は、決して暖衣飽食して富家に飼われ養われている生活のなかには感じられなかったのです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いた歳よりはずつと大きく見える少女で、富家の子で榮養も好いのであらうが狂女の病的に發達しませた體躯の工合ひが十四、五歳位にも見える。",
              "citation": {
                "source": "狂童女の戀",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "物騒な代の富家大家は、家の内に上り下りを多くしたものであるが、それは勝手知らぬ者の潜入｜闖入を不利ならしむる設けであった。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ幾百戸の富家、豪商、一｜度づゝ、此復讐に遭はざるはなかりし。",
              "citation": {
                "source": "蛇くひ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "扇折の住みし家は空しくなり、角より押廻せる富家の持地となりて、黒き板塀建て廻されぬ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥蔵を建て増し、地所を買い添えて、山城河岸を代表する富家にしたのはこの伊兵衛である。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来誰も彼も往きて遊び散策し、清浄の空気を吸い、春花秋月を愛賞し得たる神社の趾が、一朝富家の独占に帰するを見て、誰かこれを怡ばん。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一人は富家の出であった。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "租界ニ逃居シテ財産ノ安固ヲ計ル現時支那官僚富家ノ例。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜前伏羲を断わった隣の富家の婦聞いて大いに羨むと、数月の後伏羲また村へ来た、かの婦｜強いて自宅へ迎え取り食を供し、夜中自室へ蝋燭｜点し通夜仕事すると見せ掛け、翌朝｜予て拵え置いた襦袢を呈し、食を供えて送り出すと、伏羲前度のごとく祝した。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわくマルサスのバラセ町へ貧僧来り、富家に宿を求めると、主婦無情で亭主｜慳貪の由言って謝絶した。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "『出曜経』八に無厭足とて名から大強慾な竜王が己を祀りて富を求むる婆羅門を使い富家の財をことごとく地下に没入せしに、富家の主人竜泉に至りわが財宝は正道もて獲たればみだりに竜に取らるべきにあらずとて、金を泉に投ずるに水皆湧き熱し竜王懼れ金を出して皆｜還したとあり。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "この謡に猩々が霊泉を酒肆の孝子に授けた由を作ってより、猩々は日本で無性に目出たがられ、桜井秀君は『蔭涼軒日録』に、延徳三年泉堺の富家へ猩々に化けて入り込み財宝を取り尽した夜盗の記事を見出された。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "王すなわち太子の商品を没収し、従者象馬に乗って去り、太子一人無銭で置き去られ、やむをえず最下民同然、腰巻一つで富家に奉公す。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "富家の多き町の鎭守とて、凝つた構造也。",
              "citation": {
                "source": "春の郊外",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の間に何十人何百人の事業家、致富家、名士、学者が起ったり仆れたりしたか解らぬ。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "筋の多いふかし芋、麦飯の結塊、腹の減いた時には、富家の子を騙して、銭を盗み出させて、二十銭の銅貨に駄菓子を山ほど買って食った。",
              "citation": {
                "source": "ネギ一束",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、その家は若いロマンティストたちの反撥をそそる権門富家ではなくて、親しみやすくつつましい市井の住居で、若い女の一葉が筆ひとつにたよって此世を過してゆこうとしている境遇も、その人々の心をひきつけてゆくものであったにちがいない。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "くみは富家の懐子で、性質が温和であった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで天保の飢饉になつても、天保七年五月十二日に大阪の貧民が米屋と富家とを襲撃し、同月十八日には江戸の貧民も同じ暴動をした。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして富家と米商とが其資本を運転して、買占其他の策を施し、貧民の膏血を涸らして自ら肥えるのを見てゐる。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯盲目な暴力を以て富家と米商とに反抗するのである。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝同＝　同婦人は、姪の浜なる実家に、近き親戚の尠き旨を洩らせるが、田舎の富家には往々にして此の如く血縁的に孤立せる家系あり。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の清い、石川河の磧に近く庵室をしつらえさせて、昔物語の姫君のように、下げ髪に几帳を立て、そこに冥想し、読書するという富家の女は、石の上露子とも石河の夕千鳥とも名乗って、一人静かに箏を掻きならす上手の名があった。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は、よく今でも云うが「大野の植村と云うたら、大和の人で、知らん人あれへんで」　という自慢は、本当らしく、一族には、富家が相当にある。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "お神が麦酒など取り、松島遊覧かたがた来たのだと言って、前借がどのくらい残っているか、いくらお金が入用か、この土地の習慣はどんなふうかなどと訊き、三味線もちょっと弾かせてみた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう私の命の旦夕に迫っておりますことはどこからとなくお耳にはいっているでしょうが、どんなふうかともお尋ねくださいませんことはもっともなことですが、私としては悲しゅうございます。",
              "citation": {
                "source": "源氏物語",
                "author": "柏木",
                "note": "青空文庫"
              }
            },
            {
              "text": "外套にくるまって、火鉢に噛りついていると、どんなふうかと案じて来てくれながら、そうではないような様子に、「おお寒い寒い。",
              "citation": {
                "source": "遠藤（岩野）清子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　だから、父の気もちがどんなふうかは、よく知っていた。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            }
          ]
        }
