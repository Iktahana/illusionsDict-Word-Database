  {
    "uuid": "b3e4b795-9fa0-598b-8f7d-630e1504c04e",
    "entry": "フカシ",
    "reading": {
      "primary": "フカシ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fib",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "フカシイモ、ウドン、ゴカイ、ムキミ、ミミズ、サナギを飴糟にて練りたるもの、などを用ゐる。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボンコチヤンハフカフカシタアタタカイベツドノ中ニハイリマシタケレド、ドウニモヘンテコデ、ネムレマセンデシタ。",
              "citation": {
                "source": "バウシ　ノ　ユクヘ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フカシてもらっているうちに、潜水病は二日ぐらいで治りましたが、まだ治らぬ、手と膝が痺れていると偽って、畑中を殺す機会を狙っていたのです。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "フカシモンゴメ　米穀調製の際に出來る粗質の碎け米を越後蒲原地方では又フカシモン米とも謂ふ。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "フカシモンゴメ　米穀調製の際にできる粗質の砕け米を越後蒲原地方ではまたフカシモン米ともいう。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から野ゴイ釣りの餌は、フカシ芋の角切りと決まっている。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音をなつかしんで波子は、耳もとでお手玉をついていたが、やがて、高くつきあげて、サイジョウザンハ　キリフカシチクマノカワハ　ナミアラシハルカニキコユル　モノオトハサカマクミズカ　ツワモノカ　それはいたいけな少女の声だった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
