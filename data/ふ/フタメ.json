[
  {
    "uuid": "7f4e5b46-f824-5d35-85b0-7bd6936f224e",
    "entry": "二目",
    "reading": {
      "primary": "ふため",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "for a second time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "展覧会によっては、殊に日本画の展覧会などでは、とても二目と見る気のしない絵が随分あるが、二科会などでは、そんなのはあまり多くは出会わないようである。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八蔵は泰助に恨あれば、その頭蓋骨は砕かれけん髪の毛に黒血｜凝りつきて、頬より胸に鮮血迸り眼を塞ぎ歯を切り、二目とは見られぬ様にて、死しおれるにもかかわらず。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ二目三目より、本因坊膏汗を流し、額に湯煙を立てながら、得たる祕法を試むるに、僅少十餘子を盤に布くや、忽ち敗けたり。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「然うすると、矢張り、あの、二目とは見られねえのよ。",
              "citation": {
                "source": "鑑定",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか、薄気味の悪いような、横柄で、傲慢で、人を舐めて、一切心得た様子をする、檀那寺の坊主、巫女などと同じ様子で、頼む人から一目置かれた、また本人二目も三目も置かせる気。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか、いつでも二目も三目も置いているはずだ）始終生活と関係のある親類というものも、ある。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃酒を好む者、いかにその精神、吝嗇卑小になりつつあるか、一升の配給酒の瓶に十五等分の目盛を附し、毎日、きっちり一目盛ずつ飲み、たまに度を過して二目盛飲んだ時には、すなわち一目盛分の水を埋合せ、瓶を横ざまに抱えて震動を与え、酒と水、両者の化合｜醗酵を企てるなど、まことに失笑を禁じ得ない。",
              "citation": {
                "source": "禁酒の心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは二目と見られない物凄い顔であった。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、四五年前、直木と打ったとき、自分は二目しか置かなかった。",
              "citation": {
                "source": "碁の手直り表",
                "author": "菊地寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うんと多くて、二目でしょうよ」　僧が云った。",
              "citation": {
                "source": "竈の中の顔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吟味の結果は僧が云ったように三左衛門が二目の負けとなっていた。",
              "citation": {
                "source": "竈の中の顔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝負の結果は僧が二目の負けとなった。",
              "citation": {
                "source": "竈の中の顔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな顔かと問えば、只食い附きそうな顔をしていたから、二目と見ずに逃げて這入ったと云う。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "啓吉や久野も、いつの間にか、青木には一目も二目も置いていた。",
              "citation": {
                "source": "祝盃",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その百姓に対して、彼は一目も二目も置いたような卑下した態度を取っている。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎三郎ももう隠す訳にも行かなくなって、盤の上の一目二目の争いから、分別盛りの侍がおとなげない刃物｜三昧をしたと思うな、家のため、親類縁者のためには、どうしても甥一人を殺すよりほかはないのだという自分の決心を明かして聞かせた。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目｜丈は、ごまかしが利くが二目見るともう鼻に付く美しさであった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目見て美しく、二目見て美しく、見直せば見直す毎に蘇って来る美しさを持っていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代わりに、それは不器量な、二目とは見られぬような若い女が乗った。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父甥が内輪同士の勝負に、一目二目のあらそひから、理不盡の刀傷沙汰は、日ごろの叔父樣にも似合はぬこと。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目｜丈は、ごまかしが利くが二目見るともう鼻に付く美しさであつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目見て美しく、二目見て美しく、見直せば見直す毎に蘇つて来る美しさを持つてゐた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「正直に申しあげますると、殿様のお顔は痘瘡の痕が見苦しく目立つていらつしやる上にお眼の内が鋭いので、御機嫌の悪い時は二目と拝まれないやうに存じまする。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもさも勿体振って、いやに反身になって、人を軽蔑したような目付をしながら、意気揚々と灰色の馬に跨った様は――いやもう小癪に触って、二目と見られたものじゃない、とまあ、源は思うのでした。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その左官が黒のよごれた詰襟の洋服と、破れ靴で流れ歩いているんだが、それは全く二目と見られた態ではない！",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧都様はお若い時からたいへん碁がお好きで、自信たっぷりでいらっしゃいましたところがね、尼奥様は碁聖上人になって自慢をしようとは思いませんが、あなたの碁には負けないでしょうとお言いになりまして、勝負をお始めになりますと、そのとおりに僧都様が二目お負けになりました。",
              "citation": {
                "source": "源氏物語",
                "author": "手習",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、娘が王宮へ伴れて行かれた翌朝、王様はその娘と話をしようとして、娘の室に来ますと、驚いた事には、その娘の顔は一夜の中に腫物だらけとなつて、二目と見られない女となつてゐました。",
              "citation": {
                "source": "三つの指環",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に詩人といふためには、彼の作品は（その二三のものを除いて）あまりに客觀的、合理觀的、非情熱的、常識主義的でありすぎる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとめ見て、私はあわてふためいて眼をそらした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "HA の H をサイレントとし、A の母音を主語に連結してしまふために、自然にかうした言語の簡潔化が行はれるのである。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
