    "definitions": [
      {
        "index": 1,
        "gloss": "with a whiff",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あれももう私は、ごめんです）あなたも作家、私も作家、けれども今まで一度も逢った事は無し、またお互いにその作品を一度も読んだ事のない者どうしが、ふっとした事で、こうして長い手紙を交換する。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はふっと、太宰の顔を好きに思った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "福見や河野が洋行する話や、桜井が内務省の参事官で幅を利かせているような話が出ると竹村君は気の乗らぬ返辞をしてふっと話題を転ずるのであった。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで惜しいところで映画はふっと消滅してしまった。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論治る事はきっと治ると思ってみたが、ふっと二、三年前肺炎で死んだ姪の事を思い出す。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛ぶんだぞ霧の中をきいっとふっとんでやるんだなどと頭の奥で叫んでゐた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　霧がふっと切れました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの灯のあるものは点ったと思うとパチ／＼／＼とせわしなく瞬きをしてふっと消える。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時ふっと気がついた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふっとした拍子に貝原と小初は探り会う眼を合せた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はふっと自分の服装を見た。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見ているうちに、（木ペン樺の木に沢山あるじゃ）キッコはふっとこう思いました。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ふっと一郎は思ひ出しました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして交る交るふっふっと息をそこへ吹き込みました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "タネリはおもわず、やっと柔らかになりかけた藤蔓を、そこらへふっと吐いてしまって、その西風のゴスケといっしょに、大きな声で云いました。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこんどはふっと吐き出してみましたら、ようやく叫べるようになりました。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝子のやつめ、かってに注文して強くしてもらっているのじゃないかな」そんなことがふっと思えた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして詰らない時には、ふっと思い出してみるがいい。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "傘をがさりと掛けて、提灯をふっと消す、と蝋燭の匂が立って、家中仏壇の薫がした。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、ふっと私は、闇屋になろうかしらと思いました。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふっと眼をさましまして、おしっこ、と私は申しましたのでございます。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふっと気がついたら、そのような五里霧中の、山なのか、野原なのか、街頭なのか、それさえ何もわからない、ただ身のまわりに不愉快な殺気だけがひしひしと感じられ、とにかく、これは進まなければならぬ。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふっと気がついたときには、白髪の老人になっていた。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この愚僧は、たいへんおしゃれで、喫茶店へ行く途中、ふっと、指輪をはめて出るのを忘れて来たことに気がつき、躊躇なくくるりと廻れ右して家へ引きかえし、そうしてきちんと指輪をはめて、出直し、やあ、お待ちどおさま、と澄ましていました。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　僕たちは、その日から、ふっと河岸をかえた。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人の花物語という小説、」言いかけて、ふっと口を噤んだ。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手をすかしたり、なだめたり、もちろんちょいちょい威したりしながら話をすすめ、ああよい頃おいだなと見てとったなら、何かしら意味ふかげな一言とともにふっとおのが姿を掻き消す。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何もそんな、めんどうな事をしなくても、いやになったら、ふっとそれっきりあわなけれあいいじゃないの。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十間ほどふっとんだ。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただふっとそんな気がしただけの事で、もし間違ったら、彼におわびの仕様も無いほど失礼な質問をしてしまった事になる。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
