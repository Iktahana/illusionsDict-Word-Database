    "definitions": [
      {
        "index": 1,
        "gloss": "second week's memorial services",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "母のお豊はむしろ我が子をすすめて出してやるほどであったが、久次郎の参詣が初めの一七日が過ぎて更に二七日となり、又もや三七日となり、四七日とつづくようになったので、店の番頭どもは少し不安を感じて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に二七日、三七日、四七日と祈りつづけても、やはりその験のあらわれないのは甚だ不思議に思っていたところが、今になってその仔細が初めて判った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、二七日の夜、追悼浄瑠璃会が同じく天牛書店二階でひらかれたとき、豹一を連れて会場に姿を見せたお君は、校長が語った「新口村」の梅川のさわり、金より大事な忠兵衛さんで、パチ／＼と音高く拍手した。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小三郎は養父の二七日の日になって法事をしたところで、翌朝六つ時分になって庖厨に火を焼く者があった。",
              "citation": {
                "source": "四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "折入ってお願いは、相叶うことならば、お台所の隅、お玄関の端になりとも、一七日、二七日、お差置きを願いたい。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、二七日の夜、追悼浄瑠璃大会が同じく日本橋クラブの二階広間で開かれると、お君は赤ん坊を連れて姿を見せ、校長が語った「紙治」のサワリで、ぱちぱちと音高く拍手した。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の母親が亡くなりましてから、明日で二七日になりますのでございます。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすで二七日になるというのは、この女の事である。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉沢も一緒に行こうなどと言っていたのであるが、親戚の老人が死んだので、その二七日や三七日の仏事に参列するために、ここで旅行することはむずかしいと言った。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、二七日の夜、追悼浄瑠璃大会が校長の肝いりで同じく日本橋クラブの二階でひらかれると、お君は赤ん坊を連れて姿を見せ、どっさりの校長が語った「紙治」のサワリで、パチパチと音高く拍手した。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもそれから二三日目の夕食の時でしたが、顔を赤くしながら……妾はこのあいだ御養父様の二七日の晩に、妾の身の上とソックリのコルシカ人の娘の話を読んで心から感心してしまった。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、もう二三日すると二七日が来るから、事に依ると敬吾が帰って来るかも知れぬが……というのがお神さんの話の概要であった。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お朝の二七日は七月七日であったが、その日はあたかも七夕の夜にあたるというので、六日の逮夜に尾張屋の主人喜左衛門は親類共と寺まいりに行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに其の話はだんだん進行するらしい形跡がみえて、二七日の前日におかんが松倉町の三河屋へ使にゆくと、そこでもそんな噂を聞かされたので、彼女はもう落ち着いていられなくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "数うれば早し、きょうはその二七日なり。",
              "citation": {
                "source": "父の墓",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「昨日で二七日です」　警部は暫く黙って考えた。",
              "citation": {
                "source": "謎の咬傷",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが昨日二七日の法事がすむと、夕方活動写真でも見て来ようと言って出かけ、十二時頃帰宅したそうである。",
              "citation": {
                "source": "謎の咬傷",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "二七日の晩に兇行を演ずるつもりで初七日の法事が済むなり、その特別な歯附釘抜の製造に取りかかった。",
              "citation": {
                "source": "謎の咬傷",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりの姉を喪うて二七日の法事もすまぬうちに、尾道から今ひとりの姉の病気篤しとの電話がかかって、父はあわただしく尾道に参りました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一燈園では私の亡き二人の姉のために二七日と四七日の法事を営んで下さった由、天香さんから便りがありました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九一七年四月）（『大阪毎日新聞』一九一七年二月二七日―三月四日）",
              "citation": {
                "source": "選挙に対する婦人の希望",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二七日の頃から、順造は心身の疲憊に圧倒されながら、漸くはっきりと周囲を意識しだした。",
              "citation": {
                "source": "幻の彼方",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "第拾弐章　　　　　　　（一）　二七日が済む、直に丑松は姫子沢を発つことにした。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬込の彼の家に泊つてゐて、二七日が過ぎてから私は毀された家を見に行つた。",
              "citation": {
                "source": "池を掘る",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて一七日二七日と過ぎゆくほども、お糸は人の妻となりし身の、心ばかりの精進も我が心には任せぬを憾み、せめてはと夫の家の仏壇へともす光も母への供養、手向くる水も一ツを増してわづかに心を慰むるのみ。",
              "citation": {
                "source": "心の鬼",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「産経新聞」一九五九年二月二七日）",
              "citation": {
                "source": "沖縄帰郷始末記",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「東京新聞」一九五四年一二月二七日）",
              "citation": {
                "source": "声をあげて泣く",
                "author": "――私の処女出版",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分」「どうだ、八」「居ませんよ、二人共」「何處へ行つたんだ」「坊つちやんの二七日の逮夜だし、今日はお富さんが引揚げて來ると言ふんで、手傳ひ旁々、河内屋へ行つて、泊り込んださうですよ、多分飮みつぶれたことでせう」「行つて見よう」　平次の頭は馬場要夫婦で一パイでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "碁敵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分」「どうだ、八」「居ませんよ、二人とも」「どこへ行ったんだ」「坊っちゃんの二七日の逮夜だし、今日はお富さんが引揚げて来ると言うんで、手伝い旁々、河内屋へ行って、泊り込んだそうですよ、多分飲みつぶれたことでしょう」「行ってみよう」　平次の頭は馬場要夫婦でいっぱいでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "碁敵",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ二七日を過ぎたばかりの森閑とした家の中に、竦むようにしてお恵さんは炬燵に当っていた。",
              "citation": {
                "source": "加護",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
