        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ジョージ卿が観客席で返し馬を見て、ちょっと不安顔になった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルコニーで煙草を吸っている総督はいつもより不安顔で青白い。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "見過ごさなかったのはフェンウィックの不安顔だ。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが二人は全てを注意深く見ており、フェンウィックの不安顔に気づき、上気した息さえ聞こえる気がした。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "話しぶりからきみを知っていそうだよ」　メイの青白い不安顔に、笑いみたいなものがちらついた。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに都の辻とても」　と、みな不安顔してきかないのだった。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
