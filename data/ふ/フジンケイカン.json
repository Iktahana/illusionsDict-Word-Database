        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "命令によって働いている婦人警官の小田春代という女なんですわ。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "血腥い事件や狡猾な葛藤が、毎日の新聞紙を賑わしており、それからまた、婦人警官だの警察予備隊だの、更には、世界各地から集まってくる軍備だとか戦争とかの報道。",
              "citation": {
                "source": "広場のベンチ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダリア嬢も気の毒でしたが、婦人警官に渡して少しひどいところまで、残る隈なく調べ、繃帯もすっかり取外させるし、眼鏡もとられて眼瞼もひっくりかえしてみるというところまでやったんですが、何の得るところもありません」「ダリア嬢の眼はどうです」「ますますひどいようですよ。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒船時代に於ける開港場長崎の丸山の女性が、今日の世態風俗に照り合して元公爵夫人に似ているか、映画女優に似ているか、女事務員に似ているか、婦人警官に似ているか、女学生に似ているか、と云えば、そのどれよりもパンパンに似ているらしく思われるが、そんな思弁は長崎では通用しないね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "長崎チャンポン――九州の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　というプラカードをかかげて銀座や皇居前を行進しても、婦人警官に襟首をつかんで堀の中へ叩きこまれるようなこともないかも知れん。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "年配の司法主任が、知的な顔をした婦人警官を連れて調室に入ってきた。",
              "citation": {
                "source": "母子像",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人警官が机の上の書類をひきよせた。",
              "citation": {
                "source": "母子像",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生は長いあいだ本人を見ていらしたのですから、おっしゃるような子供だったのでしょう」　婦人警官が慰めるような調子でいった。",
              "citation": {
                "source": "母子像",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどの事件はどういうことだったのか、よく聞いてみたいと思うのですが……気のついたこともありますから」「かまいませんよ、どうぞ……いまご案内します」　どうぞ、こちらから、と婦人警官が左手の扉を指した。",
              "citation": {
                "source": "母子像",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸顔の婦人警官がふたり、乗っていた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくを見て停止し、助手席の婦人警官が、さきへいきなさい、と片手で合図した。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転している婦人警官が、しきりにぼくのほうに顔をむける。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は科学者兼婦人警官で、どちらの職業においても有能だった。",
              "citation": {
                "source": "いえ、いえ、ラゴーフにはもう！",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            },
            {
              "text": "「上司である保安局員、立派な経歴を持つ婦人警官だ、この局員がもう一人のソヴィエト科学者から下らぬ岡惚れの件で非難を被っている。",
              "citation": {
                "source": "いえ、いえ、ラゴーフにはもう！",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
