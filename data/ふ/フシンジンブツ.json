          "literary": [
            {
              "text": "もう一つの方は、隣りの県の知事から来た報告で、その筋の追跡を免れて逃亡中の強盗犯人があるから、もし貴県に、身分証明書及び旅券を所持せざる不審人物が姿を見せたら、猶予なく逮捕して戴きたいというのであった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの男を、不審人物として逮捕するのです。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「不審人物として警察に引き渡しますよ。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと大都市では不審人物がポンダ通りをうろついているのを誰か見ているでしょう。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
