[
  {
    "uuid": "fa9c0dd8-bf32-5144-bf34-5738aacef690",
    "entry": "伏水",
    "reading": {
      "primary": "ふくすい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "water gone underground (to emerge as a spring)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "気候の次に重要なものは土地の起伏水陸の交錯による地形的地理的要素である。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "故ニ今夜伏水ニ下り明朝上京と存付候間、吉井への状一封今夜中、何卒御遣しの程｜奉希。",
              "citation": {
                "source": "手紙",
                "author": "文久三年七月八日か　村田巳三郎あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "其ひをニ隣家の家をたゝき破り、うしろの町ニ出候て、薩の伏水屋鋪ニ引取申候。",
              "citation": {
                "source": "手紙",
                "author": "慶応二年二月六日　木戸孝允あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして活板字がたり不申ざれバ、其不足の字ハ御手許より御頼か、又ハ伏水ニて御相談、以前の板木師ニ御申付可被成下奉頼候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年五月十一日　秋山某あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時実に歎ずべきハ伏水にとりのがしし浪人の取落セし書面を以て、朝廷にもぢいて論にかけ、ついに会津人陽明家をなじり此郷御立腹など在之候よし、したしく聞申たり。",
              "citation": {
                "source": "続　手紙",
                "author": "幕閣要人あてか（推定、慶応二年三月）",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼浪人「其人」ハ伏水の事位ニてハ決して幕をうらみ申よしなし。",
              "citation": {
                "source": "続　手紙",
                "author": "幕閣要人あてか（推定、慶応二年三月）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから大久手細久手へ掛り、御嶽伏水といふ処を通りまして、太田の渡しを渡って、太田の宿の加納屋という木賃宿に泊ります。",
              "citation": {
                "source": "敵討札所の霊験",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "婢あり別れを惜みて伏水に至る。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔評〕伏水戰を開き、砲聲大内に聞え、愈｜激しく愈｜近づく。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿三日夜　伏水ニ下ル二時過ル頃―――廿四日朝　邸ニ入ル。",
              "citation": {
                "source": "坂本龍馬手帳摘要",
                "author": "坂本龍馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月小廿九日夜　伏水邸ニ下リ乗船。",
              "citation": {
                "source": "坂本龍馬手帳摘要",
                "author": "坂本龍馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "自宅製の梅酒一壺をたづさへて、早朝に伏水莊を訪うたわけである。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏水莊は、多摩川べりの崖にのぞみ、むかし、伏見宮の休み茶席だつたが、いまは農家と隣りし、農具やツイ肥にかこまれ、翁の居室は、四疊半一つにすぎない。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡田敬・伏水修両監督と助手、こっちから上山と堀井で、打合せする、二月一日開始、月一杯にあげる予定である。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡田敬や伏水の考へた筋では何うもいけないが、さりとてこっちにもいゝ知恵がない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三島の宿の撮影してると、伏水が大変な事が起ったさうだと言ふ、今朝四時六時の間に、五・一五事件以来の重大な暗殺事件あり、首相蔵相等五六人、軍部の手に殺されたと言ふ、その後流言ヒ語しきり、何処迄本当か分らず、無気味な気持のまゝ、撮影を続ける。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
