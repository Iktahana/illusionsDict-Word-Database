        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鍋はあるとした上でも、これだけのものを沸騰させ煮つめるだけの「燃料」を自分は貯えてあるだろうか。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃更に発表したところによれば、この溶液を熱して沸騰しつつある時に用いる方がよいそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寝巻姿のバルザック像がサロンに出品されると世論は沸騰して、ロダン後援会の人々でさえ呆然としてしまったのだそうです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の人気が沸騰するにしたがって、ために暑気は加わるばかしだ。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の時節――勤王討幕の議論が沸騰している今の時節では、仮りにも京都の公家にゆかりがあるという者、それは厳重に詮議しなければならない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "惨酷な情報で、群衆の熱情をあおり立てる、その沸騰する有様を、夢中に想像していた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれが沸騰せし心の海、今は春の霞める波平らかに貴嬢はただ愛らしき、あわれなる少女富子の姿となりてこれに映れるのみ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯の沸騰るを待つ間は煙草をパクパク吹していたが「どう痛むんだ」　返事がないので、磯は丸く凸起った布団を少時く熟と視ていたが「オイどう痛むんだイ」　相変らず返事がないので磯は黙って了った。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中湯が沸騰て来たから例の通り氷のように冷た飯へ白湯を注けて沢庵をバリバリ、待ち兼た風に食い初めた。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞直に衝騰る勢が、何か壓力に支へられて、横にも靡かず、ムツクラ／＼、恰で沸騰でもするやうに、濃黒になツてゐた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふっと呪文が、とぎれた、と同時に釜の中の沸騰の音も、ぴたりと止みましたので、王子は涙を流しながら少し頭を挙げて、不審そうに祭壇を見た時、嗚呼、「ラプンツェル、出ておいで。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "スクリュウに捲き上げられ沸騰し飛散する騒騒の迸沫は、海水の黒の中で、鷲のように鮮やかに感ぜられ、ひろい澪は、大きい螺旋がはじけたように、幾重にも細かい柔軟の波線をひろげている。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして彼の、かねてからの文芸愛好の情に油をそそいで燃えあがらせた悪戯者として、あの一枚の幻燈の画片を云々するよりは、むしろ、日本の当時の青年たちの間に沸騰していた文芸熱を挙げたほうが、もっと近道なのではあるまいかとさえ私には思われる。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の身体を作上げている、あらゆる元素どもが、彼の皮膚の下で、物凄く（ちょうど、後世の化学者が、試験管の中で試みる実験のように）泡立ち、煮えかえり、その沸騰がしばらくして静まった後は、すっかり以前の性質と変ってしまったように思われた。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "級中は忽ち沸騰した。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから攘夷論が沸騰して浪士らが横行する。",
              "citation": {
                "source": "鯉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、その場の人気の沸騰に囚われず、頭を冷徹に保ち、ひそかに馬の実力を考うべし。",
              "citation": {
                "source": "我が馬券哲学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大名の中での攘夷論の第一人者は、水戸の徳川｜斉昭で、嘉永六年六月にアメリカの提督ペルリが軍艦四隻を率ゐて浦賀に入港し、国論が沸騰したときに、大砲七十四門を幕府に献じて世人を驚かせた人である。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内は開国論と攘夷論とで沸騰した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻が抱き上げて顋の下や耳のまわりをかいてやると、胸のあたりで物の沸騰するような音を立てた。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "令嬢と私との間に沸騰している恍惚感であった。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私と令嬢との間には、お互いがそれを言葉では云わないだけに、恋愛者同士の恍惚感が次第に激しく沸騰して来るのであった。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼もまた、沸騰するような心臓の動悸のために苛立っていて、判断力を失っているのだった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の全身はその婦人の指の恍惚感に沸騰した。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所では薬缶の沸騰する音がし、大きな黒猫が籠のなかで背中を丸めているだけで、以前の女の影はどこにも見えませんでした。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホースの尖端からは、沸騰点に近い熱湯がほとばしり出たが、それがデッキを五尺流れるうちには凍るのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の沸騰したものは油を容れる。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "油の沸騰したものは水を容れない。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前の彼女は炭酸の利いた清涼飲料水のやうに、肉体も心も、沸騰してゐました、声はかん高く天井に跳ねかへり、足はちつともじつとしてゐませんでした、それがいまはすつかり気のぬけたサイダーのやうに、ぼんやりとだらしのない甘味だけがのこつたやうな姿でした。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀井勝一郎について青酸加里はもう買へなくなつたあなたたちのロマン派に辛子を売る店がない十銭もつたら珈排店に入つてぬるいコーヒーでも飲んで仲間と論ずるさそれともプレンソーダをのんでかすかな沸騰を味ふかね、仲間割れをするのにはいまがいゝ潮どきだ、まごまごするとハマグリに笑はれるだらう。",
              "citation": {
                "source": "小熊秀雄全集-12",
                "author": "詩集（11）文壇諷刺詩篇",
                "note": "青空文庫"
              }
            }
          ]
        }
