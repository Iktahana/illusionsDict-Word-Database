        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おきれいなのが三人ばかりと、私たち、揃つて、前津の田畝あたりを、冬霧の薄紫にそゞろ歩きして、一寸した茶屋へ憩んだ時だ。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園は冬霧に埋もれていた。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の燈も冬霧に埋もれていた。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という町の冬霧だ。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしやと思って武兵衛と数馬は登って来た方を見返って見たが、冬霧｜朧ろに径を閉ざして煙りのように立ち迷うばかり、生物の影さえ一つもない。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
