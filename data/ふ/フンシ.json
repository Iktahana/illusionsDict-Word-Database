    },
    "definitions": [
      {
        "index": 1,
        "gloss": "decapitating oneself",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やがて賊にふんした団長が、銀紙をはったキラキラした大太刀をひっつかんで出てきました。",
              "citation": {
                "source": "正坊とクロ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "新一郎君は、まさかうそとは思わなかったので、ついていって、まだぬれている牛市場の草をふみわけふみわけ、すみからすみまでさがしたが、牛のふんしか落ちてなかったそうである。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "円遊のふんした太鼓持は、太鼓持になった円遊だからおもしろいので、小さんのやる太鼓持は、小さんを離れた太鼓持だからおもしろい。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎は広田先生のうちで西洋のなんとかいう名優のふんしたハムレットの写真を見たことがある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろなかわった射げきをうけてみだれにみだれ、高ふんしにしぬいた若者の心は今にも狂いそうになって居る。",
              "citation": {
                "source": "死に対して",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の肉体は、だんだん焼かれる魚のようにこうふんして来る。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "捜査にあたってばらばらになって、自分の好き勝手をすると、成績があがらないでしょう」「そうだ、そうだ」　と、二宮少年がこうふんして叫んだ。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから外国人にふんしてやる場合、特に大事な事は、その外国人のいろんな個人的な条件と同時に、その国籍乃至民族が何人かという事であつて、この国籍或は民族の問題は翻訳劇の場合はどの外国人も一緒にしない事、地方的な雰囲気を出すためばかりではなく、人間として、脚本の人物をほんとに活かすためですね。",
              "citation": {
                "source": "俳優と現代人の生活（対話５）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうふんしては、いけません」「はなしてください。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の眉、蕾の口、つんと通った鼻筋に黒みがちの瞳、江戸じゅうの遊里岡場所をあさっても、これだけの綺麗首はたくさんあるまいと思われるほど、名代の女形が権八にふんしたような、実にどうも優にやさしい美男。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえはえらくこうふんしてるよ」　ホールが一｜心になだめた。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客様に決しておあいにならないように発熱は話して疲れたところから、少しずつこうふんして生じるのだと彼女は言った。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄田　そうかね、ハハ、まあまあ、いいさ、こうふんしたもうな、ハハ、ただわしは、どっちが本音だよと言ってるまでだよ。",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃は一向｜流行らないが、探偵劇というものも悪くないね、この怪美人には座頭の百面相役者がふんした。",
              "citation": {
                "source": "百面相役者",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれを出むかえた青年は村上の弟子らしいのですが、その弟子が、すこしも、うたがっていないところをみると、これはもう、明智の役にふんした村上に、ちがいありません。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "明智探偵にふんした村上時雄は、書きぬきを読みおわると、鏡にむかって、ちょっと顔をなおしてから、ひとりで部屋を出て、うすぐらい廊下を、舞台へおりる階段のほうへ、歩いていきます。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん、これも俳優がふんした中村係長です。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳優のふんした中村係長と、ほんものの中村係長とが、こうして舞台のまんなかで、顔をあわせました。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにも、ふんしつしたものはありません。",
              "citation": {
                "source": "おれは二十面相だ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛾次郎はすばらしくこうふんしてしまった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とつぜん、龍太郎がこうふんした口調で、「お家の行事もいまは徳川に奉行されて、御岳の神前に武田菱の幕一はり見えませぬ」　と、つよくいった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、ひとりごとにこうふんしている。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
