      "source": "JMdict, Aozora-Crawler, Illusions-Core",
      "updated_at": "2026-03-22T12:50:57Z"
    }
  },
  {
    "uuid": "36550de4-4a99-5322-abb9-37681bbc09c5",
    "entry": "不食",
    "reading": {
      "primary": "ふしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fasting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かく不埒千万な野干も七日不食十善を念じ兜率天に生まれたと『未曾有経』に出づ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "」『論語（衛霊公三十）』と、孔先生の優れた知恵や人徳を以って、不寝・不食の苦思を積んでも、「自ら省みて益無し」と言われるのに、凡庸の分際で、少しばかりの苦労を敢えてして、その功益の有ることを願っても、それ何の道理が有って功を遂げ益を得られよう。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは『一日不作一日不食』でなくて『食べたら働かなければならない』である、今日の雨中行乞などは、まさにそれだ（働かなければ食へないのはホントウだ、働らいても食へないのはウソだ）。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺有禅僧、観有道士、並守清不食葷、頗見古風不廃。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が菅茶山翁遺稿の序に曰く嗚呼吾先友海内数公、既漸凋落、独有翁在、猶碩菓之不食、而今復如此、吾将誰望哉、と。",
              "citation": {
                "source": "頼襄を論ず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "食は麥飯を少々づつ、其外｜鷄等格別｜膏氣之なきものを食用にいたし、成丈米抔は勿論五穀を不食樣との事に御座候。",
              "citation": {
                "source": "遺牘",
                "author": "西郷隆盛",
                "note": "青空文庫"
              }
            },
            {
              "text": "九五　朝而不食、則晝而饑。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文に曰く、「南方有池、池中有水、水中有魚、三頭九尾、不食人間五穀、唯食瘧鬼。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "倭地温暖、冬夏食生菜、皆徒跣、有屋室、父母兄弟臥息異處、以朱丹塗其身體、如中國用粉也、食飮用蝨、衣服垢汚、不食肉、不近婦人、如喪人、名之爲持衰、若行者吉善、共顧其生口財物、若有疾病、遭暴害、便欲殺之、謂其持衰不謹。",
              "citation": {
                "source": "魏志倭人傳",
                "author": "陳壽",
                "note": "青空文庫"
              }
            },
            {
              "text": "不眠と不食と激情とは、彼をもまた幻覚の状態に陥らしていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一日不作一日不食」というた百丈の精神は経済的であったか、今日の所謂る共産主義者の心持であったかどうか、それはわからぬとしても、日日の作務普請によりて、禅の力を実地の上に鍛錬することは、禅堂の特色である。",
              "citation": {
                "source": "僧堂教育論",
                "author": "――禅僧の友人に与う――",
                "note": "青空文庫"
              }
