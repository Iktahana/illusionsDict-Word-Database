        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "設計図を拵えて来て院長室で二人きりで相談しなければだめだと考へた。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カムパネルラ、また僕たち二人きりになったねえ、どこまでもどこまでも一諸に行かう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜町近くなる頃には他の乗客はもうみんな下りてしまって、その少女と自分と二人きりになってしまった。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も勿論愉快が溢れる……、宇宙間にただ二人きり居るような心持にお互になったのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」Ｓ＝茶店　店に腰かけた源兵衛爺さん、　お静が、　「ね、お父っつあん、兄さん昨日妾に、お静お前、お父っつあんと二人きりで暮せるかって訊いてたわ」　「何んだって……」　「冗談だわね、きっと」　「石松の奴本当にやくざになる気かな」　「なりはしないと思うわ、兄さんあんな事云って見ただけなのよ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "借家を探しに行った父親の敬蔵が帰って来て雨上りの水泳場で父娘二人きりの夕飯が始まった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "年取った鮮人と、私とが二人きりで、部屋の中に残された。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その奉納物は親子二人きりの相談で、店の者共にはよく判らないのであるが、ひと月あまりのあいだに二、三百両を運び込んだらしいと番頭どもは睨んでいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "清吉は、台所で、妻と二人きりになると、「ひとつ山を伐ろう。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カムパネルラ、また僕たち二人きりになったねえ、どこまでもどこまでも一緒に行こう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家にいて、母と二人きりで黙って縫物をしていると、一ばん楽な気持でした。",
              "citation": {
                "source": "待つ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくと二人きりになったら、そりゃ、いくら食べてもかまわないけど、ひとの前では、まずお茶一ぱいくらいのところにしてもらいたい。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カムパネルラ、また僕たち二人きりになったねえ、どこまでもどこまでもいっしょに行こう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カムパネルラ、また僕たち二人きりになつたねえ、どこまでもどこまでも一緒に行かう。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のとこなんか二人きりだから幾干も入用ア仕ない。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ余り情ないと私は思うわ」涙を袖で拭て「お前さんだって立派な職人じゃないか、それに唯た二人きりの生活だよ。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人きりになると彼女はかえって心のぎごちなさを感じないようにも見えた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "客の少ない晩で、二階にゐるのは、私と友達と二人きりであつた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、静かなこの家は夫妻二人きり。",
              "citation": {
                "source": "餅",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの顔がはっきり見える」「あなたもよ」「ええ、とうとう、僕たち二人きりですね」「まあ、青白い火が燃えてますわ。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「唯た二つ……」「だつて彼家は二人きりだからさ。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺殿と二人きりで、雨のさみしさ、行燈の薄寒さに、心細う、果敢ないにつけまして、小児衆を欲しがるお方の、お心を察しますで、のう、子産石も一つ一つ、信心して進じます。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "婚約してから式を挙げるまで三月、その間何度かあの人と会い、一緒にお芝居へ行ったり、お食事をしたりしたが、そのはじめて二人きりでお会いした日のことはいまも忘れられない。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "十　小郷と二人きりの部屋へ入れられて、鈴子はもう何もかも諦めていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに、裸の娘と深夜の部屋に二人きりでいるという条件は、この際決定的なものであった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親一人を味方と考え、母親と二人きりの時初めて気持が落ちつくという風であったから、母親をまもるという生意気さを本能的にもっていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私はそれから何かと面倒な田舎を捨てて、あなたと二人きりでこの都へ出て来ました。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそうして毎日々々二人きりでさし向いの為事をしている中に、何方から云い出すともなく、小野と美代子はつい過ちを犯してしまったのである。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しばらく海水浴にでも行って、二人きりで暮そうじゃないか。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん問う人も義理で問うのであるから深くは問いもせぬけれど、妻はたまらなくなって、「今夜わたしはあなたとふたりきりでこの子の番をしたい」　といいだす。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
