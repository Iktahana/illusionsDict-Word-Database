          "standard": [],
          "literary": [
            {
              "text": "六九　何人にも知られざる或人　ベンサムが「フラグメント・オン・ガヴァーンメント」の第一版を出した時、故らに匿名を用いて出版した。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "之のないものは論文でなくて論議的フラグメントに他ならない。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論フラグメントもフラグメントとしてその科学的価値は大きいのではあるが。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらのクラシックのものは、どれも本物ではありますが、其々の大作家の全スケールからみれば全クフラグメントです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
