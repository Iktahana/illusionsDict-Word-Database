        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "酔いどれたならば足がふらつき思わぬ不覚をとることもあろう。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　我らの訪問客は、足がふらつき、右手でマントルピースをつかむ。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "呷ったウイスキイの酔いで、目がとろんこになり、足も少しふらつき気味で、呂律も乱れがちに、でれんとした姿で庸三の傍に寄って来ることもあった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度と外国へふらつき出さぬようなものとして完全にロシアへかえって来たのはツルゲーネフが遺骸となった時であった。",
              "citation": {
                "source": "ツルゲーネフの生きかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚別から、いよ／＼乘馬でなければならなくなつたが、義雄は腰がふらつきながらも心配したほどでもなかつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふらつき歩いた土足のまま何と云っても足を洗わない。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "にじむように昏れだした宵やみのなかに酔漢はふらつき、数歩のうちにばったり倒れた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが立ち上ると頭がふらつき、足もふらついていた。",
              "citation": {
                "source": "祭りの夜",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "眩暈もしよう、ふらつきもしよう、よろけもしよう。",
              "citation": {
                "source": "猫捨坂",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はもう四辺の騒音も耳にとゞかず、羽目板にもたれてゐても足がふらつき、右に左にフラ／＼ゆれてゐるのであつた。",
              "citation": {
                "source": "朴水の婚礼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は裾の方が一尺ばかり破れてブラブラに下つてゐる、汚れた紺絣の着物をきて、小屋から出て、忙しさうにせかせかと歩いて、上半身を左右に搖すぶるやうにして、臺所口の方へ、そこから井戸端へと、ふらつき動いた。",
              "citation": {
                "source": "南方",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐそこの家だからな」　その男はきゅうにはなれて、ぴょこんとお辞儀をして、ふらつきながらすぐ下手の汚い農家の庭へ入って行った。",
              "citation": {
                "source": "石ころ路",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ勇ましく出掛けませう」　他巳吉はふらつきながら立ち上つた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "根岸の里をふらつき出した神尾主膳は、どこをどう踏んでいるのだか、自分でもよくわかってはいないらしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも言う通り、気の利いたお化けならば、とうに引込むべきはずのところを、かくも性懲りなくふらつき出すのは、他の好むと好まざるとにかかわらず、白業黒業が三世にわたって糸を引く限り、消さんとしても消ゆるものではあるまい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァン・ウィンクルのかみさんは、彼らをのらくら仲間と見て、意地の悪い目でウルフをにらみつけ、主人がむやみにふらつき歩いているのはこの犬のせいだ、と言わんばかりだった。",
              "citation": {
                "source": "リップ・ヴァン・ウィンクル",
                "author": "ディードリッヒ・ニッカボッカーの遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "総理が去って二三分後に、ふらつき、よろめいて、倒れるところを、田所が駈け寄って抱きとめましたが、ふらつく前に近づいた者はおりません。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その一　舞踏会殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふらつき倒れる五兵衛を見ていたのは田所ひとり、人のうった手裏剣ならば奴めが見逃すはずはございません」　海舟は煙草盆の下のヒキダシからナイフをとりだした。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その一　舞踏会殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人はやがて毒がまわって、加納さんがふらつき倒れることを知っていました。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その一　舞踏会殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし犬に食べさせてみると、三匹の犬が一様にヨタヨタとふらつきはじめて苦しんだあげく、まもなく死んでしまった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その八　時計館の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "また暫くすると――不意にその全身がふらつきだして、暗い波の面にじっと見入ったまま、前へかがみこんだかと思うと、いきなりソネートカの両足をひっつかんで、相手もろとも、さっとばかり船ばたから身をおどらした。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでもう何べんか会堂の構内をふらつき廻つてゐたくせに、千恵はそんなところに裏門のあることはつい知らずにゐました。",
              "citation": {
                "source": "死児変相",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "きつめねさんは　大きな　バケツ　いっぱいに　ずっしり　水を　くんできて、　ふらつきながらも　かかえたまま　台所を　通って　ねどこへ。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふらつきながら　あなぐまトミーの　頭の上に　つるしました。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までの雲で自分と世間を一筆に抹殺して、ここまでふらつきながら、手足だけを急がして来たばかりだから、この赤い山がふと眼に入るや否や、自分ははっと雲から醒めた気分になった。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこれで宥められたらしく、しばらくするとふらつきながらも両脚で立てるようになった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "拘置所の中で段々足もとがふらつき、耳が苦しく遠くなって来たとき、ひろ子はどんなに、ここに吉岡さえ来てくれたら、と思ったろう。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが行ってしまってから、伸子は、床の上に立って、すこしふらつきながら着物をなおした。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて交る交る膝をついて立ちあがりふらつきながら鉄柵へもどった。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "給仕が盆をかついでとおる道の上を――テーブルとテーブルと、ひよけ傘とひよけ傘との間の道を黙ってふらつきながら歩きだした。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
