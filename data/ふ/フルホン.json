        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その通りを行き切つて、明るい旧通りへ出ると、そこから直ぐと近くにある、彼が三年前に屡々買つたり売つたりしてゐた古本屋に、チヨツと寄つてみようかといふ気が起つた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れて始めて両親を離れ、飛び立つ思ひなり、その秋の暮、寒い夜に丸太町橋際の古本屋で「ダダイスト新吉の詩」を読む。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　古本屋へ雑誌を持つて行くと、まづ大体一冊づつの値段を合計した値段を付ける。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "古本屋は法外の高価でそれを皆に売りつけて居た。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（古本の時価は最初の定価の五倍にもなつて居た。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河岸の古本屋は軒竝みに箱をひろげてゐる。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は西道頓堀の縁切路地の附近にある、古典書にまじって、横文字のマルクス経済学書もあろうと思われる、古本大学の淫書の書架の前に立っていた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、頭を洗つてサツパリして理髮屋を出ると、近所の古本屋二軒で暫く隙を潰した。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　司馬江漢の随筆というのを古本屋の店頭で見つけたので、買って来て読んでみた。",
              "citation": {
                "source": "断片（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古本屋と思って入った本屋は新しい本ばかりの店であった。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻の古本屋へまた逆に歩いて行った。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私が学校で要る教科書が買えなかったので、親仁が思切って、阿母の記念の錦絵を、古本屋に売ったのを、平さんが買戻して、蔵っといてくれた。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、祖母の話では、古本屋は、あの錦絵を五十銭から直を付け出して、しまいに七十五銭よりは出せぬと言う。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処にそれ、はじめの一冊だけ、ちょっと表紙に竹箆の折返しの跡をつけた、古本の出物がある。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "国貞の画が雑と二百枚、辛うじてこの四冊の、しかも古本と代ったのである。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "古本屋は、今日この平吉の家に来る時通った、確か、あの湯屋から四、五軒手前にあったと思う。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一足先へ駈出して、見覚えた、古本屋の戸へ附着いたが、店も大戸も閉っていた。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱のような仕切戸から、眉の迫った、頬の膨れた、への字の口して、小鼻の筋から頤へかけて、べたりと薄髯の生えた、四角な顔を出したのは古本屋の亭主で。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、この平さんが、古本屋の店へ居直って、そして買戻してくれた錦絵である。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八雲氏の夫人が古本屋から掘り出して来たという「狂歌百物語」の中から気に入った四十八首を英訳したのが「ゴブリン・ポエトリー」という題で既刊の著書中に採録されている。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき古本屋から買って、電車の中で読んだばかりの新智識ですから、まだ記憶に残っているのですけど、あすになったら、僕は忘れてしまうでしょう。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは稽古本なんか出して、何だか印をつけたりして、きざだったわね。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は観念して、下の子を背負い、上の子の手を引き、古本屋に本を売りに出掛ける。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく……まだ五時だってえのに電燈を灯けなくちゃ物が見えねえなんて……店ん中に妖怪でも出そうで……もっとも古本屋なんて商売は、あんまり明るくちゃ工合が悪う御座いますナ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "法界節の文句通りに仕方がないからネエエ――てんで、月琴を担いで上海にでも渡って一旗上げようかテナ事で、御存じの美土代町の銀行の石段にアセチレンを付けて、道楽半分に買集めていた探偵小説の本だの教科書の貰い集めだのを並べたのが病み付きで、とうとう古本屋になっちまいましてね。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中で古本屋がイヤンなっちゃって、見よう見真似の落語家になったり、幇間になったりしましたが、やっぱり皮切りの商売がよろしいようで、人間迷っちゃ損で御座いますナ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ来て見ても、お客様が一人立っておいでになる古本屋なら、大丈夫立って行くものです。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいお道楽ですよマッタク……古本屋てものは元来、眼の見えない者が多いんだが、お前は割合によくわかるから、話相手になると仰言ってね……ヘヘヘ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中まで来ると下男が迎えに来るのに逢いましたが、家に帰ると叔母と母とに叱られて、籠を井戸ばたに投げ出したまま、衣服を着更えすぐ物置のような二階の一室に入り小さくなって、源平盛衰記の古本を出して画を見たものです。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "セーヌ河畔の釣り人や、古本店、リュクサンブールの人形芝居、美術学生のネクタイ、蛙の料理にもどこかに俳諧のひとしずくはある。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
