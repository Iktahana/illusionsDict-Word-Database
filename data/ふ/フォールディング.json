          "literary": [
            {
              "text": "面に黒ラシャを張って、ガラガラとフォールディングになった開きのついたデスクの上に、母は円ボヤの明るいラムプをつけた。",
              "citation": {
                "source": "中條精一郎の「家信抄」まえがきおよび註",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋には蝋燭が無かったが、私のルックサックにはフォールディング・ランタンと一緒に数本の蝋燭が入っていた。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとにね、ずくんでいるもんだから……英一、フォールディング・ドーアの一方を開く。",
              "citation": {
                "source": "火のついた踵",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外では、雲が湧いたと見え、微かな陰翳が、輝やいたフォールディング・ドーアの面を過ぎる。",
              "citation": {
                "source": "火のついた踵",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
