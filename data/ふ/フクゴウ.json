[
  {
    "uuid": "c2e529ce-b92f-588d-8701-1153a134f97e",
    "entry": "複合",
    "reading": {
      "primary": "ふくごう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
