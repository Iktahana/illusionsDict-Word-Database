  {
    "uuid": "73909123-4c68-583e-a8a1-742a3280a03e",
    "entry": "ふむ",
    "reading": {
      "primary": "ふむ",
      "alternatives": [
        "ふうむ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "感動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hmm",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蒼天萩原朔太郎いつしんなれば、あふむけに屍體ともなる、つめたく合掌し、いんよくいちねん、きりぎりす青らみ、もはら、雀みそらに殺さる。",
              "citation": {
                "source": "蒼天",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "祕佛萩原朔太郎つゆしものうれひはきえず、わづかなるつちをふむとて、あなうらをやぶらせたまふ。",
              "citation": {
                "source": "祕佛",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の蹄の底の砂利をふむ音と水のばちゃばちゃはねる音とが遠くの遠くの夢の中からでも来るように、こっち岸の水の音を越えてやって来ました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ふむ、それで僕も安心だ‥‥‥』と、水島はその額の廣い、端嚴な理智の勝つた顏で頷きながらかう云つた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ふむ、丁度それに這入りかけた處だ‥‥‥』と、水島は靜に頷いた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ふむ、今濟んだと云ふ知らせがあつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふむむ、総工会のまわし者がもぐりこんどるかどうかは、なか／＼吾々日本人にゃ分からんもんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、「ふむ、あいつは朝鮮人だ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふふむ、君は一体、支那人かね、ロシヤ人かね、――過激派の。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ふむふむ……そいつは、妹さんが税関で引っかゝるなんて、まのぬけたことをやったもんだね。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本、ネコイラズ、中国黄燐マッチ……」「ふむむ、……それだけ日本語が分りゃ、話が出来るじゃないか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふむ、なる程、なる程、面白い！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふむむ、暗くなると男工と女工がちゝくり合うんだね。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふむ、お産をしたんだね。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ふむ、賃銀をよこさないんだね。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ふむ、――苦るしめられたくはないと云うんだな。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ふむ、そうかもしれねえ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木曾の橋をば西行法師の春花の盛に通り給ひて、生ひすがふ谷のこずゑをくもでにて　　　　散らぬ花ふむ木曾のかけ橋また源の頼光、中納言維仲卿の御息女を恋ひさせ給ひて、恋染し木曾路の橋も年経なば　　　　中もや絶えて落ぞしぬめり　此のほか色々の歌も侍るよし承り候と言ふ。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主の抱え車じゃあるめえし、ふむ、よけいなおせっかいよ、なあ爺さん、向こうから謂わねえたって、この寒いのに股引きはこっちで穿きてえや、そこがめいめいの内証で穿けねえから、穿けねえのだ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨は、けふむかうへ泊るよ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、二十ばかり足をふむと、もういやになって、おりてしまいましたので、あとは、松吉と杉作がしなければなりませんでした。",
