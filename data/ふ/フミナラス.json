[
  {
    "uuid": "68a5e4b4-d915-5729-9b67-499ca6fe3132",
    "entry": "踏み鳴らす",
    "reading": {
      "primary": "ふみならす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
