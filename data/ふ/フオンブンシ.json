          "literary": [
            {
              "text": "「こんな事はお前等ばかりでなくて、お前等の後をつッついている不穏分子がいるから、きいてやるワケには行かない。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　不穏分子というのは「農民組合」のことだそうだ。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら憲兵は不穏分子の侵入を防ぐために必ず身体検査をするからだ。",
              "citation": {
                "source": "お菜のない弁当",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "弦三の乗りこんだ地下電車が、構内を離れて間もなく、不穏分子の振舞は、露骨になって行った。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
