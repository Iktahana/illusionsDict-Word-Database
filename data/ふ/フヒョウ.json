    },
    "definitions": [
      {
        "index": 1,
        "gloss": "floating",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてこの、赤褐色の無数の浮漂微生物の群成に依る赤潮が、真珠養殖に取っての大敵である事を思い出したのです。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "群集は恰も深い溝の底のやうなこの街を、さながら引汐の時刻の堀割に浮漂した泥や芥のやうに一定の方向へ移動してゐた。",
              "citation": {
                "source": "のんしやらん記録",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
