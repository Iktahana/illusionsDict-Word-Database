    "definitions": [
      {
        "index": 1,
        "gloss": "discontent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蓋し黄金万能主義的傾向に属することなのだらうが、Ｂの方では、Ａより貧しい条件の下に働いてゐるのに、Ａの方では、いつ知らず「俺の方が元金がかゝつてゐるのに……」といふ不平を抱いてゐるのである。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでＢの方が不平を抱く時は、悲劇なのだが、Ａの不平は悲劇でもない。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＢはＢの内部から起ることに立脚して不平が起れば起るのだが、Ａは偶々文学といふ彼にとつて外部的な物を捉へようとして、それが捉へられないといふ不平なのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而もその不平たるや、独りで文学を思ふ時と、Ｂが面前にある時とだけのものであつて、一般生活、つまり彼の畑に帰れば、あつてなきが如きものでさへあるのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "却々瀟洒な不平だよ、高級でいらつしやいますね。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "又それがために、彼の上唇の辺は見るからに不平の多い人間である。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの訳を読んだ人たちは、案外原作のつまらないのに失望して不平を言つた。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲労も不平も洗い流して蘇ったようになって帰る暗闇阪は漆のような闇である。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい誰れに対してもあたりの良い人の不平の漏らし所は家庭だなど云う。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会に対し、政府に対し、同胞に対しまた家族に対してあらゆる種類の不平不満をいだいている人は、この原始的楽器を原始的の努力をもってたたきつけるのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この椎茸少々｜宜しからぬ事があって途中から免職になったのはよかったが、その後任の爺さんがドーモ椎茸でなかったので坊チャン一通りの不平でない。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾来、私は花袋一派の党同異伐に対して、押えがたい不平を抱いていた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かがり火は、薪木の性と見え、時折、ぷちぱちと撥ね、不平そうに火勢をよじりうねらすが、寂莫たる天地は何の攪き乱さるる様子もなく、天地創ってこのかた、たそがれちょうものの待つ、それは眠るにも非ず覚めたるにも非ざる中間に於て悠久なるものを情緒に於て捉えようとするかれ持前の思惟の仕方を続けている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女も男と同じように働き、学び、考える時代となり、尚上述の条件を男子側より否定されるならば、永遠に、女性の生命は内面の不平を堪えて男子を羨み続けるでありましょう。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気層の不平の結果である。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、不平があると穴を掘ってはこっそりその中へ吐き込んだ人がある。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "授与過剰の物議よりは、まだしも授与過少の不平の方が耳触わりの痛さにおいて多少の差等があるのである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世人の天気予報に対する誤解と不平は畢竟この点に係る。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結句これからは落着いて手許に居るだろう、よい塩梅だ位に思っているらしい風が見える、何もかも慈愛の泉から湧いた情と思えば不平も云えない。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の疚しい所のない僕は頗る不平で、「お母さん、そりゃ余り御無理です。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子とお前とは兄弟も同じだ、お母さんの眼からはお前も民子も少しも隔てはない、仲よくしろよといつでも云ったじゃありませんか」　母の心配も道理のあることだが、僕等もそんないやらしいことを云われようとは少しも思って居なかったから、僕の不平もいくらかの理はある。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランプが見付からない不平から、ついこんな事まで考えたりした。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レビュー見学のノートから脱線してつい平生胸に溜まっていた教科書の不平をこぼしてしまったが、こういう脱線もまた一つのレビュー的随感録の一様式中の一景として読者の寛容を願いたいと思う。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの不平はみんな、つまり自分がだんだん老耄して来て頭が古くなり、感激性が麻痺したせいかもしれない。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり彼のアインザアムが、彼をドリンケンに惑溺させ、醉つて他人に食ひついたり、不平のクダを卷かさせたのだ。",
              "citation": {
                "source": "中原中也君の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならば君は、丁度僕に對してその逆の不平を言つてるからだ。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人の世間に對する不平は◇彼等の輿論が、稍もすればその通俗の一面性（小唄氣分）のみを認めて、より重要なる詩集の核心的價値を忘却してゐることにある。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで野口氏が之れに不平し、最後に「萩原君の見る所にも不服である」といふ意味を述べられた時私は先輩に對する愛と自責で、自ら激動した感情を押へることが出來なくなつた。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と弥助さんは向かふへいきかけた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は一たん跫音を立てて向かふへいつてしまつたが、すぐ跫音をしのばせて、庵の方へ戻つて来た。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
