        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "髪毛もみんな総々としてゐないのかと考へた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大麦も小麦も見渡す限り穂になって、緑の畑は夜の白々と明ける様に、総々とした白い穂波を漂わす。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、あのかんかんの総々して軽そうですこと。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つはあの浦島太郎がつけているような総々とした腰蓑（まえあて）である。",
              "citation": {
                "source": "陸中雑記",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲の長髪は有名であったが、その後なにに感じてか五分がり頭になって雲入道と改名、見た目も貧弱で引き立たぬと思ったら、また一年ほどすると総々とした長髪に返った。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "特にここで出来る蓑は大変特色があって、背を総々とした葡萄皮で作り腰を山芝で編みます。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "背から腰にかけては丈夫な科の皮を総々と用います。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "深い形で頭のみならず襟まで総々した棕櫚毛で被うように作られてあります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "居留地に住んでいるおとうさんの友だちの西洋人がくれた犬で、耳の長い、尾のふさふさした大きな犬。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだじゅうをやけどしたとみえて、ふさふさしている毛がところどころ狐色にこげて、どろがいっぱいこびりついていた。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その細長い痩せた体をふくよかに包むお祖母さんの被布の、何とかいう白茶地には、真白な鳥の羽毛が、ふさふさと織り込まれて居るのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬はいかにも軽さうに、いまは全く毛だけになつたしつぼを、ふさふさ振つてゐる。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物が夜のようにまっ黒、縮れた赤毛が頭から肩にふさふさ垂れまっ青な眼はかがやきそれが自分だかと疑った位立派でした。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の二つのうずのしゅげの花はすっかりふさふさした銀毛の房にかわっていました。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "露垂るばかりの黒髪は、ふさふさと肩に溢れて、柳の腰に纏いたり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅葱の紐は白い頸から、ふさふさとある髪を潜って、苞は両手に外された。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずかに束ねたる頭髪は、ふさふさと枕に乱れて、台の上にこぼれたり。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "容貌について言うなれば、額は広く高く、眉は薄く、鼻は小さく、口が大きくひきしまり、眉間に皺、白い頬ひげは、ふさふさと伸び、銀ぶちの老眼鏡をかけ、まず、丸顔である。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふさふさした白い毛を朝風に吹かせながら児猿に乳を飲ませている者。",
              "citation": {
                "source": "猿ヶ島",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊かな金髪をちぢらせてふさふさと額に垂らしている。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "下に、荷車の片輪はずれたのが、塵芥で埋った溝へ、引傾いて落込んだ――これを境にして軒隣りは、中にも見すぼらしい破屋で、煤のふさふさと下った真黒な潜戸の上の壁に、何の禁厭やら、上に春野山、と書いて、口の裂けた白黒まだらの狗の、前脚を立てた姿が、雨浸に浮び出でて朦朧とお札の中に顕れて活るがごとし。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その竹の耳かきの一端には、ふさふさした兎の白い毛が附いていて、男は、その毛で自分の耳の中をくすぐり、目を細める。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊におほけたでの紅花のふさふさと垂れるのは頗る食慾をそそるのであつた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふさふさの簪を前のめりに挿して、それは人柄な、目の涼しい、眉の優しい、口許の柔順な、まだ肩揚げをした、十六七の娘が、一人入っていたろう。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄人の造った造花でないので、却ってふさふさとして加奈子の胸のあたりに垂れ下り効果があった。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "金髪がふさふさと揺れた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、見る見るうちに、そのかつらの葉の落ちたところへ、ぶどうの実がふさふさとなりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊手にした指で、ふさふさ落ちかかって来る髪の毛を、しきりと後へ高く掻きあげながら、眼の玉をくるりとむき、唇をとがらせて、「これじゃ我々自身が『落伍者の群』になりそうじゃ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　青白い顔の男はおりおり、長い頭髪をふさふさと振り立てていた。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "炉の上にはやはり血に染まった、長い、ふさふさした人間の灰色の髪の毛が二束ばかり、根元から引き抜かれたものらしい。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
