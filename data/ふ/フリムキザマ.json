    "definitions": [
      {
        "index": 1,
        "gloss": "the moment one turns around",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
