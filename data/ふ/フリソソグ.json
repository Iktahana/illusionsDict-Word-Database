    "definitions": [
      {
        "index": 1,
        "gloss": "to rain incessantly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "降り注ぐものは新鮮な竹の葉に雪のごとく結晶し、君を思へば蒼白い月天がいつもその上にかかる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空砲射撃の時にでも、多くのよせて来る奴等を、この銃一ツで、雨が降り注ぐようにやッつけることを想像しながらタッタタタとやっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほこりっぽい、乾苦しい、塩っ辛い汗と涙の葬礼行列の場面が続いたあとでの、沛然として降り注ぐ果樹園の雨のラストシーンもまた実に心ゆくばかり美しいものである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋のたもとの街燈は、ガス燈のように青白く冴えて、柳の葉に降り注ぐ光の中を、小さな虫が群がって泳いでいた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "米原の駅の近く、汽車のデッキから突き落されて、ひと知れず死んで行った名も知れぬ男の、土人形のように固くなった屍の上に降り注ぐ同じ雨が、夜更けの京都の町をさまよう哀れな人々の、孤独に濡れた心にも降り注いでいるのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の関係しているある研究所の居室の室外にこの木の大木のこずえが見えるが、これが一様に黄葉して、それに晴天の強い日光が降り注ぐと、室内までが黄金色に輝き渡るくらいである。",
              "citation": {
                "source": "藤の実",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりの音のすさまじさに縁側に出て見ると、庭さきから直ぐ立ち竝んだ深い杉の木立の中へさん／＼と降り注ぐ雨脚は一帶にただ見渡されて、木立から木立の梢にかけて濛々と水煙が立ち靡いてゐる。",
              "citation": {
                "source": "山寺",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰度彼が視てゐる海の色は秋晴れの空と和して散漫な眺めではあったが、それは肩に暖かい日光が降り注ぐためでもあった。",
              "citation": {
                "source": "アトモス",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、楓の葉を通して絶間なしに降り注ぐ人工の雨に浴している。",
              "citation": {
                "source": "二階から",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かな真昼の光線がなみなみと降り注ぐ。",
              "citation": {
                "source": "夏の日のちぎれ雲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るい光線の降り注ぐ窓辺のデスクで、彼はペンを走らせた。",
              "citation": {
                "source": "虹",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから彼女は夫の苦境に降り注ぐ、世間の悪意を数へる。",
              "citation": {
                "source": "針",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "千鳥の声の聞える一夜、私達はそこから出て、岡崎を南に、知恩院の境内を通りぬけ、絃歌の雨のやうに降り注ぐ祇園を西に、四条大橋の袂まで来た。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "山頂や谿谷へ降り注ぐ梅雨の響を耳にしながら、雲霧の變貌去來の果てしないのを眺めやりながら、畫伯は一切を忘れて、山氣の身に迫るのを繪絹の上へ展開せしめて居られることであらう。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "行く／＼草原に放つ火の煙は夕方遲くまで山一面に爬ひまはつてゐるが、その夜の中に降り注ぐ雨にすつかり消されてしまふ。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時は、俄に山巓を曇らせて降り注ぐ驟雨に洗われ、或時はじめじめと陰鬱な細雨に濡れて、夏の光輝は何時となく自然の情景の裡から消去ったようにさえ見えます。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＨＰという職場には満足していたし、ホームブルー・コンピューター・クラブの仲間たちのフィードバックは、６５０２マシンを進化させるうえで、創造性に降り注ぐ恵みの雨の役割を演じてくれていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "街端れをすぎて影の消えた所へさしかかってからは、邪魔物もなく降り注ぐ光りでますます矢代は幸福を感じた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭上の、蒼白い太陽から降り注ぐ、清冽な夜気の中で、渚の腐れ藻の間から、一人の女が身をもたげてきた。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幻想と風景　　　（雑詩八十七章）曙光今、暁の太陽の会釈に、金色の笑ひ天の隅隅に降り注ぐ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "美くしいパステルの粉絵具に似た、浅緑と淡黄と菫いろとの透きとほりつつ降り注ぐ静かなる暁の光の中、東の空の一端に、天をつんざく珊瑚紅の熔岩――新しい世界の噴火……わたしは此時、新しい目を逸さうとして、思はずも見た、おお、彼処にある、巨大なダンテの半面像が、巍然として、天の半に。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "物のおもひの降り注ぐはてしなさ。",
              "citation": {
                "source": "水のほとりに",
                "author": "三富朽葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりは人影もなく、ただ降り注ぐ雨足がコンクリートの舗道にはねてゐた。",
              "citation": {
                "source": "道化芝居",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、一つ覚えを唱えるが、今のところ考え得る解決法は、国内にある資源と、この国に降り注ぐ太陽光線の勢力とから、民族が生きて行けるだけのものを生産することである。",
              "citation": {
                "source": "科学は役に立つか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都の駅に着いた時、もう降り始めていた小雨が、暗くなると本降りになって夜を通して蕭条と降り注ぐ。",
              "citation": {
                "source": "雨の宿",
                "author": "岩本素白",
                "note": "青空文庫"
              }
            },
            {
              "text": "初秋の眞晝の陽が、惜しみなく降り注ぐ川の上、花火も凉みも濟んで、水の上は至つて閑散ですが、物見高い江戸つ子が人垣を造つて、のんびりと口を開いて眺めて居る中を、平次は屋形船の中に入つて行きました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "僞八五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "成敗は斯うと降り注ぐ唇の雨「お鳥、来い」　大日坂に駈け登ったらしい安城郷太郎、焔のような息をお鳥に吹き掛けるとむんずと、手を捕って庭口へ引入れました。",
              "citation": {
                "source": "裸身の女仙",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "金色の日光がキラキラと金粉を撒くように降り注ぐ明るみの中で、嬉戯する子供等と、陽気な高声で喋りながら、白く肥った腕を素早く動かして、張りわたした綱に濡れた布を吊る彼女の姿は、どんなに彼の心を悦ばせたことだろう。",
              "citation": {
                "source": "美しき月夜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "九日續き陣中に神矢あまねく降り注ぐ、十日に至りアキリュウス、衆を評議の席に呼ぶ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "麥萩原朔太郎麥はさ青に延び行けり遠き畑の田作りの白き襦袢にえんえんと眞晝の光ふりそそぐ九月はじめの旅立ちに汽車の窓より眺むれば麥の青きに驚きて疲れし心が泣き出せり",
              "citation": {
                "source": "麥",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
