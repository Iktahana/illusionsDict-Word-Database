[
  {
    "uuid": "15c54533-dc8d-533b-a7b8-f7946940c39f",
    "entry": "不味",
    "reading": {
      "primary": "ふみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
