    "definitions": [
      {
        "index": 1,
        "gloss": "Acala (Wisdom King)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この七の日は、番町の大銀杏とともに名高い、二七の不動尊の縁日で、月六斎。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "不動尊の木像はその夜のうちに戸波の積善寺に返して、薬師堂の中へ元のように納めた。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「薬師脇立不動之儀、正徳歳中山内監物殿御盗被成候所、於当村不思議之事出来仕、是ハ不動尊無御座故ト申、迎帰、薬師一同奉修覆畢」　と云う文句があった。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はふとすると不動尊の庭先に希望の眼鏡があると心附いたので走つた。",
              "citation": {
                "source": "記憶のまゝ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "省作が永く眼を煩った時などには、母は不動尊に塩物断ちの心願までして心配したのだ。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "窟禅定も仕はてたれば、本尊の御姿など乞い受けて、来し路ならぬ路を覚束なくも辿ることやや久しく、不動尊の傍の清水に渇きたる喉を潤しなどして辛くも本道に出で、小野原を経て贄川に憩う。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "多い神仏の内には豪気な奴もありて、『雍州府志』に京の勝仙院住僧玄秀の時、不動尊の像の左の膝を鼠が咬んだ、秀、戯れに明王諸魔｜降伏の徳あって今一鼠を伏する能わずといった、さて翌朝見れば鼠が一疋像の手に持った利剣に貫かれたので感服したと出づ。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "天慶の亂、寛朝、成田に不動尊をもち來りて、平將門を調伏せりとて、貞盛、秀郷の功を奪ひ、もち歸らむとするに、重くなりて動かずと欺きて、勅命を博して寺を建つ。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "似而非風流の人は、靈場をけがすなどと云へど、こんなものまでも受けて平氣なるが、不動尊の佛徳の廣大なる所以也。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "また上れば、銅佛あり、不動尊也。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヤンレあわれな文屋殿、そこで手をすり申すには、お許しくだされ業平さん、京は祇園会不動尊、八幡様へ願かけて、おたのみ申す小町様、どうぞ私へくださりませ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永代寺には成田山不動尊の開帳があつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「同（三月）廿日より六十日の間、下総国成田山不動尊、深川永代寺に於て開帳」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その使、堂へ入りて捜しける間、大師すべき方なくして、仏の中に逃げ入りて不動を念じ給ひける程に、使求めけるに、新しき不動尊仏の御中におはしけり。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてすぐれた修験の僧をお集めになり、「これが定まった命数でも、しばらくその期をゆるめていただきたい、不動尊は人の終わりにしばらく命を返す約束を衆生にしてくだすった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "印付け可遣候、折角内密之取計い専一に存申候　井上出雲守が頷いて「祈祷に用いる、肌付の品々、確かに入手した」「次に――一つ、先比遣候修法は、当正月元日よりはじめ申候、不動尊も大慶に存候、両尊共に修法いたし候――　公も、われわれの申分を聞入れて下された。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店の下が崖で、不動尊の像か何かあった下の竹の筒から、細い滝が落ちていた。",
              "citation": {
                "source": "四谷、赤坂",
                "author": "宮島資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の年の四月から五月まで深川に成田の不動尊のお開帳があって、大層賑いました。",
              "citation": {
                "source": "名人長二",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "不動尊は不動経に、我は衆生心中に住すと説いてあるではないか。",
              "citation": {
                "source": "日本大地震",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は最初それは不動尊像ででもあらうかと想像したのであるが、意外の祕密が顯はれたので、子供ながら些かの羞恥と驚きとを感じ、急いでそれを元通りのところに据ゑました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいつだ、こいつだ、こいつが夢に出て来やがったんだ」　米友がこいつだと言ったのは、勿体なくも大聖不動尊の掛軸でありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃、ここに掛けられてあったのを、竜之助はもとより見ず、米友だけが毎日見ていたけれども、この男は別段に不動尊の信者ではありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "米友は不動尊の画像を睨めて、我と慄え上りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "米友が不動尊の像を睨んでいる時に、裏の雨戸をホトホト叩く音がしました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢に現われた不動尊は、いまだに米友にはその心が読めない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は例の手槍を持って出ることの代りに、かなり大きな不動尊の画像を担いで、例によって両国橋を渡りかけました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで米友が思うには、これを打捨るにしても不動尊である、有難がっても有難がらなくっても、不動明王のお像である。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合、不動尊の殊勝な信心家が現われて、この画像を米友の手から乞い受けて、祀りあがめる人が出て来れば米友は一議に及ばず、その画像を譲り渡したものであろうと思われるが、不幸にしてその人を得ることができない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく、不動尊を担ぎ出して来たものの、実際、米友はこれをどう扱っていいかということに迷いきっているのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで米友は、せっかくの名案も実行が渋って、いったん肩から取下ろした不動尊の画像を、また担ぎ直して、非常な不機嫌な顔色をして、「ちぇッ」　舌打ちをして焦れったそうに、また両国橋を渡り出しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
