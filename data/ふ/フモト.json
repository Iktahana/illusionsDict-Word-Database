    "definitions": [
      {
        "index": 1,
        "gloss": "foot (of a mountain or hill)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だが新しき季節は來り、氷は解けそめ、再び人々はその麓を通るだらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その山麓の小家の周囲を、夏の羽蟻が飛んでるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高原地方や山麓の焼土に多く生棲していて、特に夏の日中に飛翔する小虫を捉えた着眼点にある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にその飛翔している空を通して、遠望に富士を描き出しているので、山麓の小屋と関聯して、平原一帯の風物が浮びあがって来るのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木枯や何に世渡る家五軒　木枯しの吹く冬の山麓に、孤独に寄り合ってる五軒の家。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴェスヴィオの麓までの馬車には年取った英国人の夫婦と同乗させられた。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙の左上から右辺の中ほどまで二条の並行曲線が引いてあるのが上野の麓を通る鉄道線路を示している。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは東北の仙臺郊外、愛宕山の麓、廣瀬川の急流に臨んだ大竹藪の中である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒ヶ岳の麓、台ヶ原の客舎に昼餐を了りたる束の間に、禿筆を舐ぶりて偶感を記す、その文を成さざる、冀くは我が興の高きを妨ぐるなからむ。",
              "citation": {
                "source": "山を讃する文",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい石祠がある、屋根には南無妙法蓮華経四千部と読まれた、大日如来と書いた木札が建ててある、私たちの一行より、二十日も前に登山した土地測量技師や、昨年登山した東京の人たち、山麓｜蘆安村でよく聞く名の森本某、名取某の名刺が散らばっている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の登った北米のフッド火山は、大なる氷河が幾筋となく山頂から流れているにもかかわらず、麓の高原は乾き切って、砂埃とゴロタ石の間に栽培した柑橘類の樹木が、疎らに立っているばかり。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく富士山麓の宿屋としては、北の精進ホテル以外において、もっとも景勝の地を占めたものであろう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "池は浅間大社のうしろの熔岩塊、神立山の麓から噴き出る水がたたえたもので、社の神橋の下をすみ切って流れる水は、夜目にも冷徹して、水底の細石までが、うろこが生えて、魚に化けそうだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "須走は鎌倉街道ではあるが、山の坊という感じで、浅間山麓の沓掛や追分のような、街道筋の宿駅とは違ったところがある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人がアンデスの登山を悦ぶのは、麓が永久の春であるからだそうだが、山の天国は、発達した裾野を有するところの、富士火山帯に多くあらねばならない。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　室　御中道歩きの特色は、山頂を見あげると共に、山麓を見下すのにある、それが、ブン廻しのように刻々変化してゆくのを、互い違いに併せ視られるところにある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "小御岳から、大沢へゆく間にも、「小御岳流れ」「大流れ」「白草流れ」が押しだして、大森林の一部分をブッ欠き、日当りのいい窓を明けて、欠け間から裾野にかけて、山麓の斜面を見せる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その熔岩は、シャスタの南麓から迸ったのであるが、ちょっと富士山から、桂川に沿うて猿橋まで達しているところの「猿橋熔岩」に似ている。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "山麓帯の裾野で、日に焼けて、疲労をひどくしたくないので、定めの行程は短いにもかかわらず、翌十日は朝｜出立した、馬を五頭、一頭は荷物を積んで、案内者の、チャアルス・グーチという男が、裸馬に乗り、アルペン杖を横たえながら、片手で荷馬車を曳いて先登に立って行く。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その後、幾回となく、山麓を通過した、半周した、約四分の三まで廻った。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つのマック・クラウド氷河の方は、現在では最小の氷河であるが、山麓同名の村に、「マッド・クリーク」という小流があって、その岩壁には、氷河の引ッ掻いた条痕が、鮮明に残っているところを見ると、昔は今よりも、大きな氷河であったらしいことを示している。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも山の高低や、緯度の如何に随って雪の多少はあるが、高山の麓になると、一年中絶えず雪を仰ぎ視る事が出来る。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう時、下りて見ると、麓の草原は雨の雫で緑がシットリと輝くのと対照して、山の新しい雪が、キラキラと雲母のように光って、雪と雨とを区別する境界線が、山の中腹に引かれている。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（あるいは農鳥というのは、農鳥山の麓近い沢に、雪の消えた跡へ、黒く出る岩で、卵を三つも持って、現われるという、言い伝えもあるそうだ。",
              "citation": {
                "source": "雪の白峰",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "麓の方、巷や、農村では、四十年来の暑さの中に、人々は死んだり、殺したり、殺されたりした。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "静岡の南東｜久能山の麓をめぐる二、三の村落や清水市の一部では相当｜潰家もあり人死もあった。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "久能山麓を海岸に沿うて南へ行くに従って損害が急に眼立って来た。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして爪先下りのなだらかな道を下へ下へとおりて行く、ある人はどこまでも同じ高さの峰伝いに安易な心を抱いて同じ麓の景色を眺めながら、思いがけない懸崖や深淵が路を遮る事の可能性などに心を騒がすようなことなしに夜の宿駅へ急いで行く。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして谷底まで下りた人の多数はそのままに麓の平野を分けて行くだろうし、少数の人はそこからまた新しい上り坂に取りつきあるいはさらに失脚して再び攀上る見込のない深坑に落ちるのであろうが、そのような岐れ路がやはりほぼ四十余歳の厄年近辺に在るのではあるまいか。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この橋の両側だけに人間の香ひがするが、そこから六百山の麓に沿うて二十余町の道の両側にはさま／″＼な喬木が林立してゐる、それが南国生れの自分にはみんな眼新しいものばかりのやうな気がする。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
