    "definitions": [
      {
        "index": 1,
        "gloss": "to hug (unintentionally, unable to suppress one's emotions)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三毛の見向きもしない魚の骨や頭でもふるいつくようにして食った。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小格子女郎のところへなぞはどう間違ったにしても、舞い降りて下さる筈もないお直参の旗本が、それを向うから登楼したので、悉く思い上がりながら仇めかしく両頬を紅にぽっと染めて、ふるいつくように言いました。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、弾き手自身は、よほど三味線そのものに興味を持っているところへ、思いがけなく、その好物を探し当てたものですから、ことに、無聊至極に苦しみきっているためでしょうから、ふるいつくように三味にくいついて、自分の知っている、有らん限りの手という手を、弾きぬいて見る気かも知れません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらまし葉をふるいつくした森は、浴室のようにじめじめしていた。",
              "citation": {
                "source": "寡婦",
                "author": "モオパッサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、亭主が、お焦げの御飯を塩にぎりにして、一杯ずつの味噌汁をつけ、奥から持ってきて飯台にのせると、角兵衛獅子のお三輪乙吉、いつもだけの小銭を出して、すぐ、ムシャとふるいつく。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
