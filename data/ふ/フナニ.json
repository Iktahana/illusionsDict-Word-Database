        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "最初に着いた港で船荷を売払って、他の品物を仕入れる。",
              "citation": {
                "source": "ラ・ベル・フィユ号の奇妙な航海",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "途にあるいろいろの船について、その艤装や、トン数や、国籍などを言ってくれたり、やっている作業を――これは荷卸ししているのだとか、あれは船荷を積み込んでいるところだとか、あれは出帆しようとしているのだとか――説明してくれたりした。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸口のところにはポーチがあり、そのポーチの下に、例の小さな泉が、幾らか奇妙な性質の人工の溜池――というのは、船の大きな鉄釜の底を抜いて、船長の言葉で言えば「船荷を満載した時の水準線まで」砂の中に埋めたものなのであるが――の中へ湧き出ていた。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "このジョンのすぐ横で、船荷の宰領（註八一）みてえに寝ましたよ、――夜っぴて、枕を並べてね。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "――商船の航海中船荷の上に乗り添うて守り送る人。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、船荷の受取人である商人を見わけることができた。",
              "citation": {
                "source": "船旅",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人がのがれる時には、宿駕籠に身を投げ、その外部を筵でおおい、あたかも商家の船荷のように擬装して、人をして海岸にかつぎ出させ、それから船に乗って去ったというくらいだ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "神戸はもともとこの商務館の発祥の地なのだが、今では船荷の積込み積卸しや傭船関係の仕事を主として、支部のやうな形で残つてゐる。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "利根川の下流では船頭たちが船荷を何でも少し、くすねる癖があった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、船荷に沢庵石ではどうにもならない。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "船荷監督として乗船していた定期船がドイツの襲撃艇に捕らえられたのは、広い太平洋のなかでも一段と広々として、船の往来がめったにない海域だった。",
              "citation": {
                "source": "ダゴン",
                "author": "DAGON",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉庫今船荷｜呑みをり雪もよひ十二月十六日　物芽会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何百、何千の奴隷を、船荷のようにして。",
              "citation": {
                "source": "アフリカの文化",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出平は眼をむいてこの若者の顔を見直し、それからまたあわててその船荷証券を見た。",
              "citation": {
                "source": "三悪人物語",
                "author": "忍術千一夜　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "この若僧めなんにも知らねえな、持木屋の手形なら金も同様だ、よし五千両で額面そっくりふんだくってやれ、貸す五千両は船荷証券で持木屋から借り出せばいい、こいつは近来にない福の神だ、こう思ってひざを乗り出した。",
              "citation": {
                "source": "三悪人物語",
                "author": "忍術千一夜　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　出平が船荷証券で持木屋から五千両借り、馬に積んで北の庄村の家へ届けたとき、入れ替わりに八百助の家から誰が袖のお杉さんが、とび出して来た。",
              "citation": {
                "source": "三悪人物語",
                "author": "忍術千一夜　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "参蔵殿は手をふるわせてそれを見た、なにを隠そうかの船荷証券である。",
              "citation": {
                "source": "三悪人物語",
                "author": "忍術千一夜　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文句はいらないんだ文句は」姐さんは目じりをつり上げてどなる、「持木屋の手形と船荷証券この二つをもらえばそれでいいんだ、へん、誰だと思う誰が袖のお杉姐さんだよ」　そして店先でくるりと裾をまくり、あられもない弁天小僧を極めこんだ。",
              "citation": {
                "source": "三悪人物語",
                "author": "忍術千一夜　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "』筑波根の東聲して、『天の宮、御使ひ姫は汝こそあれ、われは國造、高翔くる日の羽車をともなひて、朝なゆふなに七度の國見の反身、『汝が希望、あくがれ、吟咏、高わらひ、努力、若やぎ、また愛の華座はここに。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふなに似てるのかな。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、だれいうとなく、金の魚は、ふなに金箔を塗って河に放したのだということがわかりました。",
              "citation": {
                "source": "金の魚",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "川を知らないふなは、おそらくここをすみかと信じ、安心しているのだろうけれど、だれがふなに川を知らせなかったのかと、子どもらは思わずにいられませんでした。",
              "citation": {
                "source": "川へふなをにがす",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "元日はよいものと思ふなにもかも　社会的にも個々にも、なみなみならぬ去年であった。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
