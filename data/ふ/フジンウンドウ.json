    "definitions": [
      {
        "index": 1,
        "gloss": "women's movement",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "石川三四郎君らは右の三派（もしくば二派）から独立して、婦人運動の雑誌を出したりしていた。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "フオラ女史のお友達に、婦人運動に憂身を窶してゐる或る貴婦人があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人運動者にお勧めする。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして押問答しているうちに、案内女や通りすがりの観客の足がそこに止まったところで、葉子は先刻ちょっと廊下で偶然に会って立話をした草葉の知合いの、婦人運動などやっているＯ――女史に頼んで来てもらって、やっと自身の身分を知らせることができた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の或る女――それは娘時代には昔風の母親に生活させられた、然し時代が真の女性の本分を要求したのに刺戟されて、初めて自分の過去の生活を反省し、社会主義から婦人運動の中にまで入り、やや反抗的な態度の生活に入る。",
              "citation": {
                "source": "今日の女流作家と時代との交渉を論ず",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど婦人運動をやりたがってもいるのだし、自分のもののようにして骨折ってくれるに違いない。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる婦人運動などにはあまり係わらない。",
              "citation": {
                "source": "新しい女",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学、宗教、婦人運動、教育などの分野でそれぞれの業績を重ねて来ているこれらの婦人たちが、その母としての立場、主婦としての経験から、名誉ある彼女たちの知慧の叫びを街々のつましい主婦の声に結んで、世界に平和をアッピールしたことは、正しかった。",
              "citation": {
                "source": "平和の願いは厳粛である",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人問題、その問題を何とか解決してゆこうとする婦人運動。",
              "citation": {
                "source": "合図の旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、それらの婦人運動は、婦選運動をもふくめて、まことに微々たるものであった。",
              "citation": {
                "source": "合図の旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョア婦人運動の時代は、日本の新民主主義の段階の到来とともに去って、再びかえらないのである。",
              "citation": {
                "source": "三つの民主主義",
                "author": "――婦人民主クラブの立場に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、外国人の著書に屡々欧米の婦人運動、又は女性の社会に於ける位置の進化というものの研究材料として、東洋、多く支那、日本のそれを例に引く場合を考えて見ましょう。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどその時分、仏蘭西で勉強して日本の社会問題を研究にきたとか称する支那人が、英子さんを通じて日本の新しい婦人運動者に遇いたいというので会見を申し込んできたので、一日その中里の福田英子さんのところで遇うことにした。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "内容も、ロマン・ローランの「日本の若き人々へ」を初め、婦人の職業と民法の婚姻に関する法律の問題、山川菊栄の婦人運動の新局面についての論文などをのせた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ひとくちに婦人と云っても、それぞれの属していた社会層と、その集団が歴史の進展をどう把握しているかということで、婦人の間にも社会的な立場というものが、次第にはっきりわかれはじめ無産婦人運動が擡頭したことは意味ふかい事実である。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、堺真柄などを中心とする赤爛会が小規模な無産婦人運動のさきがけを示した。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十三年総同盟の関東同盟が分裂して、関東地方評議会となったとき、ここに婦人部が設けられ、無産婦人運動は、組合活動から政治的闘争にうつり昭和二年には左翼の立場をとる若い婦人たちによって関東婦人同盟が創立された。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、婦人運動が婦人自身の手を俟つほかに、成功する見込みがない所以である。",
              "citation": {
                "source": "日本の女",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろの婦人運動も、まず子供が生れてからだとも考える折がある。",
              "citation": {
                "source": "平凡な女",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人運動の初期にあってはこの自覚という言葉は、ただ結婚の際に親権に反抗する事にのみ用いられたといっても過言ではないような事実を示しました。",
              "citation": {
                "source": "成長が生んだ私の恋愛破綻",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの言論が多少でも世人の注意を惹くのは、とにかくその人たちの半透明な自覚と、大胆な発言とが因となり、男子側の識者が欧米から得た新知識に由って婦人運動に厚意を持つのと、一般の若い男女が旧思想に対する反動として無自覚に新しいものを歓迎する心理とが縁となっているからだと思います。",
              "citation": {
                "source": "婦人改造と高等教育",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらは文化の帰趨に朝せんとして文化価値の実現を努むる人格として生きんとするのである」といって、文化生活の水準に登らない孤立無理想の生活を批難されましたが、最近の婦人運動には、この厳粛なる批難の前に撤廃するか、もしくは開眼を施すか、いずれかの勇断を要するものが多いように思います。",
              "citation": {
                "source": "婦人指導者への抗議",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれをお詫びすると共に、「婦人運動に理想あれ」という希望の言葉を以ってこの感想を結びます。",
              "citation": {
                "source": "婦人指導者への抗議",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また右の大阪朝日新聞社の大会へ東京から出席された平塚らいちょう女史が、帰来直ちに新婦人協会の創立を発表し、主として全国婦人の連合運動を企図されるに到ったことなども、我国の婦人運動が茲に新紀元を画して、初めて実際に現代的意義を持つようになった表徴であろうと思います。",
              "citation": {
                "source": "新婦人協会の請願運動",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治末葉の、漠然婦人運動者と呼ばれている人々であった。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞を見れば同盟罷工や婦人運動の報道が出ている。",
              "citation": {
                "source": "妖婆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり各人の力が充実してそのコントリビューションで、何とかとにかくやって行けると云うのでなく、先ず会をまとめ、自分も目的――生活の――をさずかろうとするからことが面倒になりつまらない分裂　分裂が繰返され婦人運動の面目をつぶすことになってしまうのだ。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は堅実な英国人の間に起つた婦人運動が決して空騒ぎで終らない事を信じる。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は仏蘭西に於ける婦人運動が過去三十年前に比して甚だ手温いのを不思議に感じます。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人運動を排する諸声の如何に高ければとて、女は何時までも新しきゲエテ、カント、ニウトンを生み、人間は永久うらわかき母の慈愛に育ちゆく。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
