[
  {
    "uuid": "577d70aa-ccf9-5bb5-8db6-8c76875a0f74",
    "entry": "踏み場",
    "reading": {
      "primary": "ふみば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
