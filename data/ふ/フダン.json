[
  {
    "uuid": "9343a110-d1db-559c-bb92-1eec346f3607",
    "entry": "不断",
    "reading": {
      "primary": "ふだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "constant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ここに私共のはれがましい不断の交歓があつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は知性の人でなくして感性の人であり、江戸ツ子的神経の都会人でなくして、粗野に逞しい精神をもつた自然人であり、不断に燃焼するパツシヨンによつて、主観の強い意志に生きてる行動人である。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち言えば、常に変化する空間、経過する時間の中で、ただ一つの凧（追憶へのイメージ）だけが、不断に悲しく寂しげに、穹窿の上に実在しているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不断の満たされた食事と、立派な暖房装置の家を持ち、外出に自動車を有する近代人は、あの蕭条とした自然の中にをののいている原始の恐怖を、もはや全く意識の表象から忘れてしまつた。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つコックの工合の悪いのがあって、それから湯が不断に流出している。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小門｜清楚、「春夏秋冬花不断」の掛額もさびたり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして脳が過敏になっているためか、不断はまるで忘れていたような事まで思い出して来る。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "華麗と歓楽とを夢みるように、この雪白く、氷堅き北方の閉鎖から解かれて、南方の奢侈を、立ち姿や、寝像にまで現して、昼となく、夜となく、おそらく、千年も万年も、不断の進みをつづけているのだ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この病気のために生じた色々な困難や不愉快な事がないではなかったが、しかしそれは厄年ではなくても不断に私につきまとっているものとあまり変らない程度のものであった。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾等が棲む地球はその姉妹なる諸遊星と独楽のように廻りながら太陽の周囲を不断週遊しているのであると講釈する。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちアーク灯の陰極になっている炭の棒を不断廻転させ、陽極には金属の棒を用い、これを水素または炭酸瓦斯で包んでなお強い磁力をアークの光部に作用させる。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち発信器の方では不断に規則正しい波を送りそのアンテナに電話の送話器を接続し、受信器には前述のエレクトロリチック・デテクターを用うればよいのである。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故不断に光らせるためには、時々必要に応じて少量の瓦斯を管内に補給する仕掛けが是非とも入用である。",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不断、お蘭のいうことはすべて賢い言葉だと思って、口移しに真似て見るのが四郎の癖であった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小指は高くゝりの覚」で貸借の争議を示談させるために借り方の男の両手の小指をくくり合せて封印し、貸し方の男には常住坐臥不断に片手に十露盤を持つべしと命じて迷惑させるのも心理的である。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不断に変化する宇宙全体が秤皿に影響してその総効果が収斂しなかったら一物の目方という定まった観念を得る事は出来まい。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒も先生も不断にこの強制的に定められた晴れの日の準備にあくせくしていなければならない。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動で鍛えた身体であったが、中年の頃赤痢にかかってから不断腸の工合が悪かった。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火山から噴出した微塵が、高い気層に吹き上げられて高層に不断に吹いている風に乗って驚くべき遠距離に散布される事は珍しくない。",
              "citation": {
                "source": "塵埃と光",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学者の仕事の生命は人の実験を繰り返す事でないと同様に画家の価値も不断に自分の「実験」を考えながら進んで行くところにあるのではあるまいか。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし「霧不断の香をたく」というのは香煙に見立てた眼の感じで鼻の感じではあるまい。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを防ぐためこの頃行われ始めた方法は、海岸ならばそこに繋留した灯台船の底に鳴鐘を附け、不断これを鳴らしている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その電線の経路九十二マイルの間は近辺の樹林を切り開き、また人の近づかぬように不断｜巡邏している。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでインド洋の真中から西の方へ向うた不断の潮流がある事が知れる、云々」。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳しく言えば、風邪の症状を軽微なる程度において不断に享楽している。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不断の下らない事が。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの致した事を、もし不断の尺度で、日常生活の尺度で量って下さいましたら、それはわたくしのためにひどい冤罪になるのでございますから。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "週期的あるいは非週期的に複雑な変化の相貌を現わす環境に適応するためには人間は不断の注意と多様なくふうを要求されるからである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地震の現象でも大小の地震が不断になしくずしに起こっている代わりにたとえば中部アジアなどで起こるような非常に大規模な地震はむしろまれであるように思われる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "複雑な環境の変化に適応せんとする不断の意識的ないし無意識的努力はその環境に対する観察の精微と敏捷を招致し養成するわけである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
