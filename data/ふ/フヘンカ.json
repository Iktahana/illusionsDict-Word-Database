          "literary": [
            {
              "text": "四　私は今まで、美が単に不変化のものではなく、むしろいろいろの姿をもって歴史の中を歩みきたったことを顧みたのである。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "協団は不変化なものの姿である。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
