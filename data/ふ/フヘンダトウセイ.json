[
  {
    "uuid": "b7d4187d-a3ad-5451-af88-3d61cc46906d",
    "entry": "普遍妥当性",
    "reading": {
      "primary": "ふへんだとうせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
