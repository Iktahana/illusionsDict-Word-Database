        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さようならと清吉は自己が仕事におもむきける、後はひとりで物思い、戸外では無心の児童たちが独楽戦の遊びに声々｜喧しく、一人殺しじゃ二人殺しじゃ、醜態を見よ讐をとったぞと号きちらす。",
              "citation": {
                "source": "五重塔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは実に戦慄すべき二人殺し事件でありまして、現場に犯人の使用した右の手袋と、兇器として使用された斧とが遺留されてあったに拘わらず、犯罪が行われてから四週間を経るも、犯人が知れず、所謂事件が迷宮に入ったのであります。",
              "citation": {
                "source": "新案探偵法",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "署長の鑑定によると、この男は多分煙草屋の二人殺しの犯人で、良心の苛責のために発狂し、殺した女の名を呼ぶのであろうということでした。",
              "citation": {
                "source": "新案探偵法",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "エドガア・アラン・ポオの小説にリユウ・マルグの二人殺しと云ふのがあつて、その主人公は猩々である。",
              "citation": {
                "source": "猿",
                "author": "AFFENPSYCHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰からも注意されない女を一人や二人殺したところで、それが何だろうと思いながらも、それが罪人になってしまう結果の事を考えると馬鹿々々しくなって来るのだ。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰からも注意されない女を一人や二人殺したところで、それが何だらうと思ひながらも、それが罪人になつてしまふ結果の事を考へると馬鹿々々しくなつて来るのだ。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方が奇襲をして、家畜数頭を掠奪したり、人間を一二人殺したりして引揚げますと、こんどは他の一方が、数日或は数十日後に機会を見て奇襲し、だいたい同じやうなことをして引揚げます。",
              "citation": {
                "source": "アフリカのスタンレー",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウ、ウ、ウ――」　動かなくなった留吉の体を、池の中へ転がし込んだが、（人二人殺したからにゃア、いくら何んでも此処にはいられない。",
              "citation": {
                "source": "甲州鎮撫隊",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、そんなひ弱い男でも萩原とおみねと人二人殺してずんと本度胸が坐ったといえばそれ迄であるが、いくら剣術の空っ下手な（情人たるお国が首めのほうでしきりにそう慨いている！",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "（今日も人二人殺したっけ）　それを頼春は考え出した。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の二人殺しの犯人なら始めから分ってらアな。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その五　万引家族",
                "note": "青空文庫"
              }
            },
            {
              "text": "お気の毒ですが、花田、野草二人殺しの犯人一也さんは捕えなければなりますまい」　新十郎は二人をうながし、深い感動をこめて茫然と見送る二人の万引常習者をあとに、外へでた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その五　万引家族",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故ならば、此の事件はただ人を一人殺したか二人殺したかという問題とは全然ちがいます。",
              "citation": {
                "source": "彼が殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よからう、二人殺して、ヌケヌケと三人目を殺しにかゝつて居る奴は、放つちや置けない」「ぢや出かけませうか」　八五郎はすつかりいきり立つて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "詭計の豆",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い娘を誘拐したり、腕つ節の強いやくざを二人殺したりするやうな、そんなことの出來る柄ぢやない」　喜八は頭から相手にしません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "狐の嫁入",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よかろう、二人殺して、ヌケヌケと三人目を殺しにかかっている奴は、放っちゃ置けない」「じゃ出かけましょうか」　八五郎はすっかりいきり立って居ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "詭計の豆",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか、二人殺しが、三人殺しにならうとは思はなかつたよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女御用聞き",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二人殺しの真犯人」　自若とした蜂屋文太郎の声、「何を証拠に」「証拠は充分過ぎるほどある。",
              "citation": {
                "source": "古城の真昼",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて二人殺しの下手人を挙げて、五千両の御用金を勘定方にお返ししよう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "百四十四夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人や二人殺したのを隠すはずはない。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "竹光の殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い娘を誘拐したり、腕っ節の強いやくざを二人殺したりするような、そんなことの出来る柄じゃない」　喜八は頭から相手にしません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "狐の嫁入",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、お前も、そんなに執拗く人の命を絶つには及ぶまい、人間二人殺したら、大抵眼が覚めてもいい頃だ」　一座はシーンとして「足の勇」の話に聞き入りました。",
              "citation": {
                "source": "死の予告",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひとりがひとりも殺さないのに、十二人殺したものは、なんでしょう。",
              "citation": {
                "source": "なぞ",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾を二人殺したのは、本妻の仕業に違げえねえと、萬七親分は鬼の首でも取つたつもりで、あの女を縛つて行きましたよ」　八五郎の報告には泡も飛べば埃も立ちます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "風呂場の祕密",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判の結果、彼は他にも十二人殺していた事が明かになった。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
