    },
    "definitions": [
      {
        "index": 1,
        "gloss": "first",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「レデース・ファースト」と云うのであった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｔ「翌る朝」Ｓ＝ファーストシーンの町角　てっきり鉄と三次が今日も亦ばったり出会った。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと後に先生が留学から帰って東京に住まわれるようになってから、ある時期の間は、ずいぶん頻繁に先生のお宅へ押しかけて行って先生のピアノの伴奏で自己流の演奏、しかもファースト・ポジションばかりの名曲弾奏を試みたのであったが、これには上記のような古い因縁があったのである。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便屋だと思ったんだろ」　といって、〈ミスター・ポウストマン〉のファーストラインを口ずさみながら、高志は、受けとった紙袋から薄い本をひっぱりだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ、ファーストシーンにしようぜ」　こんどは山崎の声だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファーストショットは、ちょっとハレイションを起こしたが、逆光のカットでいくことになった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスマス休暇でニューヨークに帰ったとき、ワラは、じぶんの好みでもないのに、慶一の好きそうな、ファースト・ロッカーをたくさん見つけてきてくれた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "スティーヴ・ウィンウッドは、いまや、ジョン、ポール、ジョージ、リンゴとおなじく、ファーストネイムだけで呼ばれる存在になった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうは、義隆という、ごついファーストネイムをもっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "主題歌だって歌えるぞ」　と、ファーストラインを口ずさむ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「タクシーか」　ファーストショットを決めたいワラは、セドリックのタクシーを見送った。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年ぐらいまえ」　モンキーズもカヴァーしている、という注釈はのみこんで、紙片を令子にわたし、慶一は、それが令子に対する誓いのことばにも受けとれる、などということは意識せずに、「アイル・ビー・トゥルー・トゥ・ユー、イエス、アイ・ウィル」　と、ファーストラインを口ずさんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝口です」「慶一、おれだ」　最近は、ファーストネイムで呼びかけて、オレだ、などという人間は、そうたくさんいるわけではない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、ファーストラインに引っかけた皮肉だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの曲のファーストラインを半分だけうたった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに「寂しき人々」をかの女に教えなかったが、ツルゲネーフの「ファースト」という短篇を教えたことがあった。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイカラな庇髪、櫛、リボン、洋燈の光線がその半身を照して、一巻の書籍に顔を近く寄せると、言うに言われぬ香水のかおり、肉のかおり、女のかおり――書中の主人公が昔の恋人に「ファースト」を読んで聞かせる段を講釈する時には男の声も烈しく戦えた。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在米国でも、相当の知識階級の、青年男女は、殆ど滑稽な外観のレディファースト（婦人第一）を決して誇ってはいないのです。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八一（昭和五十六）年秋、サンフランシスコから成田行きの便のファーストクラスに乗り込んだ西は、隣り合わせた日本人と言葉を交わした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "京セラ、稲盛との出会いが生んだ二つの未来志向マシン開発計画　ファーストクラスの大きな座席から身を乗り出すようにして、メモ用紙にスケッチしたディスプレイの中にいくつもウインドウを書き入れ、アイコンの役割やマウスを使った操作の利点を熱を込めて語り続ける西和彦を、稲盛和夫は唇を固く結んで見守り続けていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファーストクラス機内での西と稲盛の出会いは、のちにノートブックマシンとして大きく成長する真のポータブル機の原点を生んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "前年の秋、京都セラミツクの稲盛和夫と西和彦とのファーストクラス客室内における出会いは、二つの未来志向マシンの開発プロジェクトに結びついた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『ザ・ファーストランナー』田原総一朗著、筑摩書房、一九八五年、「若きヒーロー」）　目指すべき事業のイメージをさまざまに思い描いた孫だったが、本命は「パーソナルコンピューター用のソフトウエアの流通」に置いていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かような次第で、妻ノブ子は、伜嬢次が日本に居るらしいという話を聞くや、大喜びでジェイ・ファースト（Ｊ・１）の番号を貰いまして、小生が居りました桑港を秘密裡に通過して日本に参りました。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェイ・ファースト（志村のぶ子のこと）でも居れあ格別だが、居そうにもねえよ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェイ・ファーストのお代りと云いたいがあれ以上に若くてシャンだ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェイ・ファースト（志村のぶ子）を締めた時の手で、芝浦からモーター・ボートでずらかってもいい……お前はなかなか色男……あはははは。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
