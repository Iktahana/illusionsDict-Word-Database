        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "みだらだの、風儀を乱すの、恥を曝すのといって、どうする気だろう。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "教団が流行らない初めの頃は何と掟をしないでも男女の間の風儀は乱れなかった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の男女の風儀の矯正には最も熱心であった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巣林子戯曲ありてより、浮世を難波の潟に、心中するものゝ数多くなり、西鶴一流の浮世好色小説の流布してより、社界の風儀は大に紊乱せる事、識者の共に認むる所なり。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士の風儀久しく落て、之を救済するの道未だ開けず。",
              "citation": {
                "source": "秋窓雑記",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の方では、東京のような風儀の好くない土地にいて、女の事について何事もなかった倅の、遠慮深い口から、どうでも好いというのは、喜んで迎える気になっているのだと思って、直ぐに話を運ばせた。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは初め此社會の風儀のかくまで亂れたるをば想ひ測らざりしなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お化けの方はなぜ止したんだ」「へえ、どうもあの楽屋は風儀が悪うござんして、御法度の慰み事が流行るもんですから……」「爺さんもあんまり嫌いな方じゃあるめえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか医員の甲乙と自分との関係を、自分の口から誠しやかに噂に立てる……と言った調子で、風儀を乱すことが甚しいので、とうとうＫ大耳鼻科長、大凪教授の好意によって諭示退職の処分をされる事になったという。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "上中下各階級の人々は互にその同階級の人々と風儀を紊し合っている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その忙しさの裡面には風儀の紊乱が潜んでいる場合が多い。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、ここらの芸妓は風儀が悪くていけないと陰でののしっていた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私がここに来てから、もう三年になりますが、その時分は生徒の風儀はそれはずいぶんひどかったものですよ。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "発戸は風儀の悪い村と近所から言われている。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから生徒を見ても、発戸の風儀の悪いのはわかった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "川向こうの上州の赤岩付近では、女の風儀の悪いのは非常で、学校の教員は独身ではつとまらないという話を思い出した。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒沼家は近所でも評判の堅い屋敷で、奉公人もみんな風儀が好い。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "風儀が悪いじゃないの。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だって、結婚しなけれやなお風儀が悪くなるさ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くに工場が出來てから一層風儀がわるくなつたと年寄りなんぞは云つとるが。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな事が流行つては、家中の風儀が悪くなるからといふので、その男は長の暇を取らせられた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは先生を侮辱した訳ではありません、また先生に見せるためにわざわざ遣ったのでもありませんが、とにかくよほど予備門などにおったわれわれ時代の書生の風儀は乱暴でありました。",
              "citation": {
                "source": "模倣と独立",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それにあすこいらはおそろしい風儀がよくないと言うじゃないかい。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "海辺はどうも日本も同じで余り風儀がよくないため、やはり山へ行く人の方が多いようです。",
              "citation": {
                "source": "女学生だけの天幕生活",
                "author": "――アメリカの夏季休暇の思い出――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何を云やアがる、この婆々ア」と、氷峰は心でそれをあざ笑ひ、こんな種類の桂庵的がゐる爲め、北海道のをんなの風儀が亂れるのだと憤慨もしかねなかつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "風儀の好さそうな家を択んで仕えようとした五百なぞには、給料の多寡は初より問う所でなかった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし殿樣が御勤務役になりましてから、市中の風儀は、見ちがへるほど改まりました。",
              "citation": {
                "source": "死刑",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "往來で煙草を吸つたもの、込み合ふ中で人を押し退けて進まうとしたもの、そんなのまでを直ぐ引つ捕へて、打首にするならば、火事は半分に減ずるし、世の中の風儀は忽ち改まるであらうと思つた。",
              "citation": {
                "source": "死刑",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "あえてその天賦の権利たりまたは泰西の風儀たるがゆえをもってするにはあらざるなり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊勢參りといふことが、妙な意味に取られる伊賀あたりの風儀であつた。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
