    "definitions": [
      {
        "index": 1,
        "gloss": "flux",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ラテン詩人（前三七年頃死）【何の地方】地獄の第何圈一〇〇―一〇二【ペルシオ】アウルス・ペルシウス・フラックス。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂肪についての同位体研究の結果を要約するとしたら、正常動物の脂肪は質的および量的に一定であるにもかかわらず急速に流れている（フラックス）の状態にあると結論せざるを得ない。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "フスクスのように町の愛人であり、フラックスのように田野の愛人である。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "クイントゥス・フルウィウス・フラックスも、ケルティベリ人を攻めるに当って同じように命令した。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはポンポニウス・フラックスという者が適任と認められた。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりたければポンポニウス・フラックスになって見るがよい。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
