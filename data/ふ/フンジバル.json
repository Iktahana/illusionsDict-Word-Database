    "definitions": [
      {
        "index": 1,
        "gloss": "to tie up (roughly; esp. to prevent escape)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私等は口惜くて口惜くて仕様が無いの、ああいう乱暴な貧民は何人あろうと、一人々々ふん縛るわけには参りませんか。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこをふん縛るんだ」「しかし、親分、猿飛という奴は、親分にも大火傷、いやお灸を据える位の忍術使いですから、下手すると、こっちがやられてしまいますぜ」「莫迦をいえ！",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分、どうしましょう」「まさか、いきなりにふん縛るわけにも行くめえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ、ね」と、輕く受けて、「おれの一身を田舍婆々アのかたみ位でふん縛ることは勿體ないよ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その時には同心が従く」「目明し衆も従くんでしょうね」「お前なんかすぐふん縛る」「おお恐々！",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……土岐頼兼の妾や小伜、目付け次第ふん縛る！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お巡りになつたのが、わるいというのか、やいこら」「よくもあるめえ、糞面白くもねえ、罪人をふん縛る商売なんぞ、人に任せとけ」「誰かがやらにやなるめえ」「おい、おい、やりたい奴にやらしたらどうだ。",
              "citation": {
                "source": "この握りめし",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官が泥棒をふん縛るんだって、そうだからね。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのいざり乞食をふん縛るんだ」　言い捨てて脱兎のごとく駈け出した。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大坊主はノンダクレで、カンシャクもちで、礼儀知らずで、泥棒をふんじばるには持ってこいだが、国際的な社交場へつれてくると必ず国威を失墜するという念入りの男。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その一　舞踏会殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵なども、推理の頭とふんじばる豪傑はそれぞれ違った人がやるべきことだ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その三　魔教の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さッ、こなけりゃふんじばるぞ」　と、野武士たちは、かれを少年とあなどって、不用意にすすみでたところを、伊那丸は、おどりあがって、「おのれッ」　といいざま、真眉間をわりつけた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
