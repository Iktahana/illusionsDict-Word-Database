        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "痩せた小柄な船長が船人らしい雄大な抱負を正面の卓子から吹聴していた。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が一緒に日本へ行きたいと訴えるのだが、船人のたくましい腕の絆も別離が切って落す。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぼろにみえる沖の方から船人はふしぎな航海の歌をうたつて　拍子も高く楫の音がきこえてくる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の底がどんなにうつくしいか、だから船人たちはしずむことをそんなにこわがるにはおよばない、そううたってやるのです。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、船がしずむと、それなり船人はおぼれてしまいます。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "須磨の浦に心を寄せし船人のやがて朽たせる袖を見せばや　字は以前よりずっと上手になっているが、五節に違いないと源氏は思って返事を送った。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "船人もたれを恋ふるや大島のうら悲しくも声の聞こゆる来し方も行方も知らぬ沖に出でてあはれ何処に君を恋ふらん　海の景色を見てはこんな歌も作っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて熊野川を船で下った時しばしば猴を見たが船人はこれを野猿また得手吉と称え決して本名を呼ばなんだ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "信一郎はそれを船人の命を奪う妖魚の声として、そのまゝ聞き流して、戸外へ飛び出そうと思った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜次第に擴がりて、引汐走る音のみ眞闇に知らるる海のかなた、白き手すがる戸の上、低き光の目標、船人かへると思ひやれば、胸に沁み入る平和に、おぼえず涙を巖に垂れぬ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもしろしと見るに堪へずして船人のよめる歌、「見渡せば松のうれごとにすむ鶴は千代のどちとぞ思ふべらなる」とや。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "船人も皆子（いイ有）だかりてのゝしる。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "信天翁　　　　　シャルル・ボドレエル波路遙けき徒然の慰草と船人は、八重の潮路の海鳥の沖の太夫を生檎りぬ、楫の枕のよき友よ心｜閑けき飛鳥かな、津潮騒すべりゆく舷近くむれ集ふ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるは「命」の威力あるもとめの貢、あるはまた貴に妙なる「恋」の供奉にかづけの纏頭と贈らむも、よし遮莫三瀬川、船はて処、陰暗き伊吹の風に、「死」に払ふ渡のしろと、船人の掌にとらさむも。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "信天翁　　　　　シャルル・ボドレエル波路遙けき徒然の慰草と船人は、八重の潮路の海鳥の沖の太夫を生檎りぬ、楫の枕のよき友よ心閑けき飛鳥かな、奥津潮騒すべりゆく舷近くむれ集ふ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏訳詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャルル・ボドレエル信天翁波路遙けき徒然の慰草と船人は、八重の潮路の海鳥の沖の太夫を生擒りぬ、楫の枕のよき友よ心｜閑けき飛鳥かな、奧津潮騷すべりゆく舷近くむれ集ふ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるは「命」の威力あるもとめの貢、あるはまた貴に妙なる「戀」の供奉にかづけの纏頭と贈らむも、よし遮莫、三瀬川、船はて處、陰暗き伊吹の風に、「死」に拂ふ渡のしろと、船人の掌にとらさむも。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "人買船人買船に買はれて行つた貧乏な村の山ほととぎす日和は続け港は凪ぎろ皆さんさよなと泣き　泣き言ふた。",
              "citation": {
                "source": "別後",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "信一郎はそれを船人の命を奪ふ妖魚の声として、そのまゝ聞き流して、戸外へ飛び出さうと思つた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "よるべなみ風の騒がす船人も思はぬ方に磯づたひせず　と源中将に言われた。",
              "citation": {
                "source": "源氏物語",
                "author": "真木柱",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはずんだ音が響き、煙の中からぽっかりと浮出した風船人形が、ゆたりゆたりと呆けたように空を流れ、浜の子供たちがワーッと歓声をあげ乍ら、一かたまりになって、それを追かけて行くところであった。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○此頃将軍ハ海軍を大ニひらかんとて、米国へ大軍艦一艘船人ともに借入候よし。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年二月二十二日　三吉慎蔵あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "惣じて紀州人は我々共及便船人をして、荷物も何にも失しものを、唯鞆の港になげあげ主用あり急ぐとて長崎に出候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年四月二十八日　菅野覚兵衛、高松太郎あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯の日細りて更くる夜半に岩打つ浪音ひとり高しかかれるとも船人は寝たり誰にか語らん旅のこころ　細く高い三人の肉声が、誰が始めたともなくうたい出した。",
              "citation": {
                "source": "九月一日",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「乗船人心得方規則」と書いてあった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづこの酒場の窓よりぞ、ギタルに合はする船人の唄秋の夜風に混り、波止場に沿ふ散歩道は落葉したる木立の幹に海の反射淡く残りぬ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌の近くに、「朝床に聞けば遙けし射水河朝｜漕ぎしつつ唱ふ船人」（巻十九・四一五〇）という歌がある。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "海蛆ひき潮ゆるやかに、見よ、ひきゆくけはひ、堀江に船もなし、船人、船歌も。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "さけを、のみ、　　ふなびとに。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゆらのとをわたるふなびとかぢをたへ　ゆくへも知らぬこひのみちかな――か、今となると既にもうあの頃がなつかしいな、いや、満里のところの歌留多会がさ。",
              "citation": {
                "source": "まぼろし",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
