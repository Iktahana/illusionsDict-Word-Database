[
  {
    "uuid": "5ab54f32-5900-5f04-9870-fdef2face244",
    "entry": "富裕",
    "reading": {
      "primary": "ふゆう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wealthy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、縹緻よしの踊子は、たえまなく富裕な旋律のなかにいた。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノラはかくして富裕な家庭でもとシソワット王宮舞踊場の踊子であった母の美しい愛撫によって育成された。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人の所へある日遠方の富裕な地主イブラヒム・ベグ・ハジからの手紙をもった使いが来て、「入れ歯を一そろい作ってこの使いの者に渡してくれ」とのことであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "富裕な家に生れて攫むべき機會は幾何も與へられながらそれに對して冷淡な事は驚く計りである。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ伊予の松山の城下は富裕の評判高く行乞に便利であるところからしばらくそれを便って落着いたわけである。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こはこれ、公園地内に六勝亭と呼べる席貸しにて、主翁は富裕の隠居なれば、けっこう数寄を尽くして、営業のかたわらその老いを楽しむところなり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯ういう山村に生れても、家が富裕であるお庇に、十年以前から東京に遊学して、医術を専門に研究し、開業試験にも首尾好く合格して、今年の春から郷里に帰った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の触出しについて、梟娘は何うしてもいの一番に願ひ出なければならないのであつたが、その家が富裕であるので、親たちも遠慮して差控へてゐるのを、町役人どもが相談して先づ親たちにも得心させ、その次第を書きあげて差出すと、係りの役人も額を皺めた。",
              "citation": {
                "source": "梟娘の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだって、自分はあんなに好きなお絹と一しょになり、好きな生活のできる富裕な邸宅に住めないのだろう。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛍雪はその後、漢和の辞典なぞ作ったものが当り、利殖の才もあってだんだん富裕になった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点に於て普通の大阪の多少富裕な家の遊び好きのぼんちに異らなかつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいわい、親戚に富裕の者が二、三あったので、せっぱつまるとそのひとたちから合力を得て、その大半は酒にして、春の桜も秋の紅葉も何が何やら、見えぬ聞えぬ無我夢中の極貧の火の車のその日暮しを続けていた。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子まじりにわたくしと同じ年頃の少女が四五人いて、どこかこの近所の富裕な家の子たちと見え、少し遠慮が無さ過ぎるくらい活溌で人慣れています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中の言うところに依ると、その娘は富裕な両親に連れられて年中温泉めぐりをして居る所謂温泉場人種の一人だった。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主婦の栖子は、園主で園芸技師の尾佐とは恋愛から、無理に富裕な実家を抜け出て、この踏花園に同棲したものなのだが、だんだん掴みにくくなる尾佐の性格に根気も尽きるほどになっていた。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたわら富裕な外国人を友達に持ちたがっている。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り富裕でないアグネスは英国婦人飛行協会員にはなれなかったので此の募集に自分の将来への活路を見出したように喜んでしまった。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に、郷里の実家が富裕であるらしく、毎月少なからぬ送金を受けているので、服装もよく、金づかいもいい。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨身を削る制作から退いて、何か楽な生業に就き、（彼の父は相当に富裕だったのだから）知能や教養は凡て鑑賞と享受とに用いること。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当に富裕なのであろう。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶道は能楽以上の技巧の末に走り富裕人の弄びものに堕ちつくし全く其精神を亡し候。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京｜小石川の某町に、葛西と云って、もと幕臣であった富裕な家があって、当主の芳郎と云うのは仏蘭西がえりの少壮民権家として、先輩から望みを嘱されていた。",
              "citation": {
                "source": "赤い花",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから曾は非常に富裕になった。",
              "citation": {
                "source": "続黄梁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は古いユグノー（２）の一家の子孫で、かつては富裕であったが、うちつづく不運のためすっかり貧窮に陥っていた。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "この話の女主人公は有名な家の、富裕な、またたいへん美しい容姿を持った若い娘、ヴィクトリーヌ・ラフルカード嬢であった。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は予の知人の富裕なることを知っていた。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "夷狄を征伐する軍用金を出せとか云って、富裕の町家を嚇してあるく一種の浪人組が近頃所々に徘徊する。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな店に似合わず、家は甚だ富裕であるらしく、驢馬のたぐいを多く飼っていて、往来の役人や旅びとの車に故障を生じた場合には、それを牽く馬匹を廉く売ってやるので、世間でも感心な女だと褒めていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は富裕とは見えない。",
              "citation": {
                "source": "ぢいさんばあさん",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女物の綿入れは途中で畑の中に立つてゐた案山子を物色して、案山子のなかで一番富裕らしく着込んだ奴から、綿入れを強奪して、それを着込んだのである。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
