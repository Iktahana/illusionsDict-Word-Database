        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（なりひらはイキな覆面でも良いと思います）○＝内部　なりひら今の刀を見ている。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）街　覆面の諸士二十名ばかり、　雲霧主膳を中心にひそひそ話。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前方に覆面の二十名が伏せる。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりひらの行手に覆面が跳び出す。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "とその亦背後から覆面の侍が尾行します。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後から悠然と覆面の右門。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "３４＝門前　坊主の案内で門内に入る善男善女達――３５＝裏口　小門から覆面の立派な侍や隠居風の町人が、続々と入って行く。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "覆面の侍の中に例の結城左久馬も居ます。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "５０＝おふみの室　覆面の侍（太郎左衛門）が襖を開いて入って来る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "５５＝密室　敬四郎今度は右門の去った後を覗くと、５６＝おふみの室　おふみに挑みかかる覆面の太郎左衛門、小柄で額を切られてアッとのけぞる。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、　結城左久馬と坊主の浪之助とお類、覆面の太郎左衛門、おふみ等は到々逃げてしまう。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "６９＝昨夜の　覆面の侍は太郎左衛門ではないか。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "34＝門前　坊主の案内で門内に入る善男善女達――35＝裏口　小門から覆面の立派な侍や隠居風の町人が、続々と入って行く。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "50＝おふみの室　覆面の侍（太郎左衛門）が襖を開いて入って来る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "55＝密室　敬四郎今度は右門の去った後を覗くと、56＝おふみの室　おふみに挑みかかる覆面の太郎左衛門、小柄で額を切られてアッとのけぞる。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "69＝昨夜の　覆面の侍は太郎左衛門ではないか。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして覆面した一人の男庵室に忍び寄る。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗人、その眼ざしを避けるように覆面の顔を他方に振り向ける。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けてから発見したのであるが、賊はなぜか一物をも奪い取らないで、新しいメリンスの覆面頭巾を残して立去った。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一件の一と月ほど前に東両国の質屋へ押込みにはいった二人組がありましたが、その晩は蒸し暑いので、ひとりの奴が覆面を取って顔の汗を拭くと、それが坊主頭であったので、店の者は又おどろいたということです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "その完成の日には、私も覆面をとって私の住所姓名を明らかにして、貴下とお逢いしたいと思いますが、ただ今は、はるかに声援をお送りするだけで止そうと思います。",
              "citation": {
                "source": "恥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は永遠に覆面の女性でいたかった。",
              "citation": {
                "source": "恥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のあの覆面の手紙が、ただちに貴下の製作慾をかき起したという事は、私にとってもよろこばしい事でした。",
              "citation": {
                "source": "恥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう見破られましたから、覆面はやめましょう。",
              "citation": {
                "source": "恥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "平太郎は簑笠を着け、草鞋を穿いて大熊山の方へ向ったが、覆面させられたようで何も見えない。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幽人高士のあまりに少い今の乱脈さは、その気品の低く、香気の薄く、守ることの浅い不見識は、あの市井無頼の徒たりとも口にすることを恥ずる暴言と態度の賤鄙と（いや、それよりも下俗な覆面の残虐と私情の悪罵と）あの卑劣とは何事であろう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "見えない兇賊兩手に兇器ふくめんの兇賊往來にのさばりかへつて木の葉のやうにふるへてゐる奴。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この文珠屋佐吉が、微苦笑とともに高札から眼を離して、むこうの人ごみで立ち話をしている白ふくめんと千浪の様子を、しばしじっと見据えていたが。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "やせぎすの小男……黒のふくめんをしているので、その面立ちは見きわめるよしもないが、切れ長のうつくしい目がやきつくように栄三郎のおもてに射られて、それが、単に気のせいか、なみだにうるんでいるごとく栄三郎には思われるのだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっ黒なシャツとズボンをつけ、頭は、黒ふくめんでつつんで、目と口のところだけ、あながあいています。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
