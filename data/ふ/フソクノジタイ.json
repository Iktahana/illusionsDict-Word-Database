          "literary": [
            {
              "text": "せいぜい一年の間を置くだけのつもりだったが、不測の事態が重なって五年近くも鉱山を出られなかった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "不測の事態が起こるやも知れませんが、その場合は連絡します。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "成功は我が手中にあるが、もし大統領に不測の事態があれば、破産だ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
