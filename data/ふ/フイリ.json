    "definitions": [
      {
        "index": 1,
        "gloss": "small attendance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "○四月歌舞伎座にては一番目を「千本桜」に換え、二番目をそのままにして、菊五郎が河内山を勤めたるも、不入りに終る。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の浅草公園へ行ってみても判ることだが、同じような映画館がたくさんに列んでいても、そのなかに入りと不入りがある。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "両国の観世物小屋にもやはり入りと不入りはまぬかれないので、何か新しい種をさがし出そうと考えている。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前年以来、新富座はとかくに不入り続きであったので、団十郎は一番目に石川五右衛門、中幕に「八陣」の加藤、二番目が「西洋話」の丈助を勤め、大切浄瑠璃に「かっぽれ」を踊るという大勉強に、まず相当の成績を収めたが、二番目の円朝物は好評でなかった。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（更にため息をつく）この正月もやはり不入りであつたか。",
              "citation": {
                "source": "近松半二の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論興行の入り不入りを何うでも構はないと云ふのではないが、けふは今日に生き、明日は、あしたに生きて、自分の藝を樂しんでゐれば好いのだ。",
              "citation": {
                "source": "近松半二の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの見物した日も気の毒なような不入りで、ここには“多摩川の河原”が一面に大きく開けていた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい不入りの芝居とはいいながら、我々のような書生ッぽうが土間の五に陣取って、芝居を一日見物して、菓子を食い、弁当をくい、鮨を食って、その費用が一人前六十八銭とは、その時代としても決して高いものではなかった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、初日の観客は一部の劇通かまたは特別の熱心家にかぎられ、初日満員などというのは殆んど例のないことで、どこの劇場も初日はいつも不入りに決まっていた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ団十郎が京都へ乗込んだのはこれが初めであるから、第一回の興行は非常の大入りであったが、第二回は案外の不入りで、さんざんの体たらくで引揚げて来たということであった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にもいう通り、その当時の芝居は大入りよりも先ず不入りの方が多かったので、芝居が明くという噂を聞くと、今度の芝居は旨く当たるかしらという一種の疑念をいだくのが一般観客の心理状態であったらしい。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この興行は団菊左顔あわせの大一座であったにもかかわらず、哀れさんざんの不入りであったから、この引幕を知っている人はあまり多くなかったかも知れない。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いに家橘も勘当されず、歌舞伎座も舞台を削り直さず、おん大将の団十郎と菊五郎の顔あわせで十月興行を開演することになって、一番目「双面忠義鑑」、中幕「毛谷村」、二番目「新皿屋敷」という列べ方であったが、甚だしい不評不入りで、両大将ともに器量を下げた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二回は十一月二十一日から開場して、狂言は一番目「菅原伝授手習鑑」、中幕「壺坂霊験記」、二番目「三日月」、大切「廓文章」という列べ方であったが、今度は芝翫が抜けたので一座はいよいよ寂しく、これも結局不入りのうちに閉場することになった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "不入りな高價な興行をつづけるよりは、一年三百六十五日の日はかなりなものを運ぶから三十錢滿員の方が、或は遙によい成績をあげないとはいへない。",
              "citation": {
                "source": "むぐらの吐息",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一組は學生劇の連中で、ラインの上流をたつた六人で芝居をうつてまはつたけれどいづれも不入りで、リューデスハイムの町へ泊つた時には、宿賃だけでパンを食べることも出來ない貧しさであつた。",
              "citation": {
                "source": "就職",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてモウ時間ですからこの室を出て行って頂戴……」　事件当夜……八月四日の呉服橋劇場は、非常な不入りであった。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧風熱は沸騰して、十二年の九月には、外国役者の一座、英、米、仏人混合の一座をかけたりしたが、言葉がわからないので一般には不向きで不入りだったという、種々の経緯はあったが、新富座は劇道人の向上にはたいした役割をもった。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思えば、島原の芝居は炎暑で不入り、元金七千円金が、昨日の上り高では千五百円の大損、それに引きかえて、同所の、火除け地へ、毎夜出る麦湯の店は百五十軒に過ぎ、氷水売は七十軒、その他の水菓子、甘酒、諸商人の出ること、晴夜には、半宵の物成高五百円位、きわめて景気よしともある。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "座頭がわっしのことを、新劇崩れと云うだろうが、一時この座を離れて、妙な銭にもならねえ、真似をやっていたことがある」　里虹の行衛が知れなくなって何月目か後のこと、警察でも尋ねあぐんで、結局不入りのための失踪ということでケリをつけたのだが、その日、先夜の四人を前に儀右衛門が切りだした。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、次に見た「予言の夢」は、不吉にも、この一座が不入りを極めた夢だった。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃不入り続きの中村座。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことさら、気負った盆興行が、大の不入り、そこで座元の策戦の秘術をつくして、この大切な顔見世月には、当時大坂でめきめきと売り出している、門閥外の中村菊之丞一座を招き、これに、座付の若手を加えただけで、思い切った興行ぶりを見せようと試みたわけであった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮に不入りのため経済的な負担がかゝるとすれば、これまた、劇場か劇団のみがこれを背負ひこみ、作者は、涼しい顔がしてゐられたのである。",
              "citation": {
                "source": "劇文学は何処へ行くか",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "かてて、加えてひどい不入り。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこもかしこも不入りだった。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "不入りにもなんにも、てんで問題にならない御難ばかりだった。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "端席の不入りは自分が未熟だったのだし、師匠の旅中に断らずやったのは手落ちだったかもしれないが、万々一にも大入りだったらかえっておいでなすったとたん、アッと喜んで頂こうとおもったからに他ならない。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもまあ不入りだろうと考えながら控席へ入って休息していると、いつの間にやらこんなに人が集って来た。",
              "citation": {
                "source": "中味と形式",
                "author": "――明治四十四年八月堺において述――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……といふいりわけが……さうしたいきさつがまへにあつたのである。",
              "citation": {
                "source": "角力",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
