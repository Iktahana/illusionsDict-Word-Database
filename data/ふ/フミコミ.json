    "definitions": [
      {
        "index": 1,
        "gloss": "dealing fully (with)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "寝込みを踏み込みやがったな）　彼は、本能的に息を詰めた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　猫は頻りにないて、道と田との間の溝に後足を踏み込みそうになった。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場へ踏み込み扶けてくりょうと、いきなり隔の襖を開けて、次の間へ飛込むと、広さも、様子も同じような部屋、また同じような襖がある。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の厚いところも、だいぶ軟かになっていて、わたくしはとき／″＼ずぼりと腰の辺まで雪の中へ踏み込みます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分ひとりで出かけて行くのも何だか寂しいようにも思われたので、僕も一旦は躊躇したのですが、やっぱり行ってみたいという料簡が勝を占めたので、とうとう岐阜で道連れに別れて、一騎駈けて飛騨の高山まで踏み込みました。",
              "citation": {
                "source": "指輪一つ",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "若くてか弱きお方に、そのような場所へ踏み込み、ごろつき連中を尻目に夫を捜して引きずり出すなど、どうしてできようか。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういうレイアウトにするかといった約束事には、一切踏み込みません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏み込みますか」と、松吉はきいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "一つ目小僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、なんだか底の知れない泥沼に踏み込みでもしたように、深谷の挙動が疑われ出した。",
              "citation": {
                "source": "死屍を食う男",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田原の町から五六里北へ踏み込み、足柄山の麓にある矢倉沢村といふところの乙鳥音吉なる老人が、わたしの幼少の頃にもこれを作つてわたしに贈つたが、近年――と云つてももう六七年も前のことだが、急にわたしはそれを欲しくなつて、矢倉沢村を訪れたのである。",
              "citation": {
                "source": "山峡の凧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝釈かかる美婦を仙人などに添わせ置くは気が利かぬと謀叛を起し、月神チャンドラを従え雄鶏に化けて瞿曇の不在を覘い、月神を門外に立たせ、自ら瞿曇に化け、入りてその妻と通じた処へ瞿曇帰り来れど月神これを知らず、瞿曇現場へ踏み込み、呵して帝釈を石に化し千の子宮を付けて水底に沈めた。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "若杉さんは、なんの気なしに次の間へ足を踏み込みました。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "田部井氏は空家の庭へ踏み込みながら、「判っていられても、云い憎いんじゃアないですか？",
              "citation": {
                "source": "寒の夜晴れ",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧洲では力あまった分析力に随って自身の頭の中にまで踏み込みつつ、ここからも科学的法則を掴もうとした結果、認識論的法則と科学的法則との識別作用の混乱が、ますます増大して来た悪時期にさしかかっていたのである。",
              "citation": {
                "source": "北京と巴里（覚書）",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川は思わず、「ああ、こっちですか」と、雑草を掻き分けて踏み込みながら云った。",
              "citation": {
                "source": "牡丹",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "メモリーの必要量を増大させるグラフィックスの世界に踏み込みながら、ＲＡＭとドライブの容量を充分用意できなかった点は、ＰＣ―１００とマッキントッシュに共通する欠陥だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　手帳を受け取ってそう云う真紀子の顔を久慈は見返りながら、「駄目だ、東野さんこんなの俳句じゃない抒情詩だというね、あの人は俳句を踏み込みだというから、見せたってやられるだけだよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、俳句が踏み込みだなんて、よく分らないね。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　久慈はこう云ったとき東野が足を踏みつけた後で、この痛みどこより来ると云ったその踏み込みの疑問を思い出した。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらも互に踏み込み合って乱れた後の静けさからは、まだ遠い自分たちだと気がつくと、ああ、まだこのままには済まぬぞと思い、また女たちを踏み下したまま前方をきっと高い眉毛で見詰めているベルレーヌの心境が、さらに深く内奥で拡がりわたって来るのだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それはいろいろややこしいことが、こんがらかっているので一口には云えないのですが、やはり、東洋の道徳と西洋の科学やキリスト教などとの、踏み込み合ってる足の問題が、中心のように思えますね。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき、一足なかに踏み込み、その光景をみるなり、ぼくは居竦んでしまいました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "対手に薄手傷を負わした上は、踏み込み、畳み込んで、仕留めなければ、対手が、どう死物狂いになって来るか、判らないからであった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「娘の敵」　七瀬は、近づいたが、踏み込みもしないで、斬りつけた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "予審判事が警官を指揮して、母の病室へまで踏み込み、枕元なる箪笥の中、棚の隅々、無遠慮に取り乱して物を探す――母は白髪頭を枕につけたまゝ、目を閉ぢて、眉一つ動かさない。",
              "citation": {
                "source": "幸徳秋水と僕",
                "author": "――反逆児の悩みを語る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関の戸を開いて中へ足を踏み込みますと、さあたいへん、僕は彼より五分間後れて帰ったばかりに一大事突発です。",
              "citation": {
                "source": "密林荘事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と西条勘右衛門様は――そう、編笠が取れましたので、そのご家来が尾張の藩中でも、中条流では使い手といわれる、西条様だということがわかりましたが、そう仰せられると、踏み込み、刀を真向にふりかぶり、倒れている職人風の男の背をめがけ、お斬りつけなさいました。",
              "citation": {
                "source": "怪しの者",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はつかつかと庭の中にふみこみました。",
              "citation": {
                "source": "幻の園",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩の上へ着物をぬいでおいて、水の中へ、一足ふみこみますと、水晶のやうなつめたい水が、ぞつとしみて、からだぢゆうの毛穴がひきしまるやうに、おもはれました。",
              "citation": {
                "source": "千本木川",
                "author": "土田耕平",
                "note": "青空文庫"
              }
            },
            {
              "text": "リューシは　つつみを　てに　ふみこみだんを　かけあがって、　それから　ふりかえって　「さよなら」って　そのせんたくおばさんに　ありがとうと　いったのですが　――　おっかしなことに！",
              "citation": {
                "source": "チギウィンクルおばさんのはなし",
                "author": "THE TALE OF MRS. TIGGY-WINKLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
