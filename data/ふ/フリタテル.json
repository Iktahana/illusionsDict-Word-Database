    "definitions": [
      {
        "index": 1,
        "gloss": "to toss (i.e. one's head)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
