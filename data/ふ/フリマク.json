[
  {
    "uuid": "462dcf96-b882-5275-8762-6b4378428985",
    "entry": "振りまく",
    "reading": {
      "primary": "ふりまく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
