    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fluke",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『わたし、フロックコート着る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの趣味はすべてにおいて庶民的で、儀式ばったことが嫌いなので、フロックコートなどの礼服を非常に嫌い、常に野蛮人の服と称し『なんぼ野蛮の物』と言っていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれではあまり体面に関するので、夫人が是非フロックコートを新調するようにすすめたが、頑として中々きかない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上に参るの時、あなた、シルクハット、フロックコートですよ』などと、子供をだますようにして説き伏せられ、やっと礼服を新調したけれども、やはり少しも着ようとしない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈が高く顔の小さい、額がノツシリしてフロックコートのよく似合ふ、前校長の容姿が何時か彼の心を離れないものとなつてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルマン教授は胡麻塩の長髪を後ろへ撫でつけていて、いつも七つ下がりのフロックを着ていたが、講義の言語はこの先生がいちばん分りやすくて楽であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからあのいつもの漆喰細工の大玄関をはいってそこにフロックコートに襟章でも付けた文部省の人々の顔に逢着するとまた一種の官庁気分といったようなものも呼び出される。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒のフロックコオトに黒のネクタイ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "フロックコオトに御奉公をしているのだ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（フロックコオトの上着を脱いで床の上に投り出す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬向きにこしらえた一ちょうらのフロックがひどく暑苦しく思われたことを思い出すことができる。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カイロ男爵だって早く上等の絹のフロックを着て明るいとこへ飛びだすがいいでしょう。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "釦の多いフロックコートを着たようである。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが済むと怪しげな名前の印度人が不作法なフロックコートを着て出て来た。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつのまにか獅子が立派な黒いフロックコートを着て、肩を張って立って「もうよからうな。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正何年であったか正月の三日に、国原がフロックコートで初出社をすると、左手の甲に仰山らしく繃帯をしている。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそばへ一人の夏フロックコートを着た男が行って何か耳うちしました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとやはりフロックを着てテーモが来ていました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきの夏フロックを着た紳士が心配そうにもみ手をしながら何か云おうとするのですがデストゥパーゴはそれさえおどして引っこませてしまいました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そのときさっきの夏フロックが出てきました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとテーモも夏フロックもそのほか四五人急いであとを追いかけて行ってしまいました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は三越でこさえた白い麻のフロックコートを着ましたが、これは勿論、私の好みで作法ではありません。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "異教徒席の中からせいの高い肥ったフロックの人が出て卓子の前に立ち一寸｜会釈してそれからきぱきぱした口調で斯う述べました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒のフロックを着た先生が尖った茶いろの口を閉じるでもなし開くでもなし、眼をじっと据えて、しずかにやって来るのです。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　向うの葵の花壇から悪魔が小さな蛙にばけて、ベートーベンの着たような青いフロックコートを羽織りそれに新月よりもけだかいばら娘に仕立てた自分の弟子の手を引いて、大変あわてた風をしてやって来たのです。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸事で宗山の留を刺したほどの豪い方々、是非に一日、山田で謡が聞かして欲しい、と羽織袴、フロックで押寄せたろう。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これのみならず玄関より外科室、外科室より二階なる病室に通うあいだの長き廊下には、フロックコート着たる紳士、制服着けたる武官、あるいは羽織｜袴の扮装の人物、その他、貴婦人令嬢等いずれもただならず気高きが、あなたに行き違い、こなたに落ち合い、あるいは歩し、あるいは停し、往復あたかも織るがごとし。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　エミ子はそれから、黒地のフロックの首や手首に金箔の条を巻きつけた洋服を着て、真赤な｜お椀帽子をかぶって、待っていました。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日の朝になると、まだ暗いうちに一帳羅のフロックコートを着て、金鎖を胸高にかけて、玄関口に寄せかけた新調の自転車をながめながら、ニコニコ然と朝飯の膳に坐ったが、奥さんの心づくしの鯛の潮煮を美味そうに突ついているうちに、フト、二三度眼を白黒さした。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の門のところに、フロック着たへんなおじいさん立っています。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
