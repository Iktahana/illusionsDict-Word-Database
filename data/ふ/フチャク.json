[
  {
    "uuid": "e5471a63-5c92-5141-b815-3c7fb26b424d",
    "entry": "不着",
    "reading": {
      "primary": "ふちゃく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
