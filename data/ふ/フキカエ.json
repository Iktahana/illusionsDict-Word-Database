[
  {
    "uuid": "f170a3c1-7507-5559-b179-02349fc73dba",
    "entry": "吹き替え",
    "reading": {
      "primary": "ふきかえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
