    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dubbing (of a film, etc. into a different language)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もしこれが吹き替え翻訳であれば、すぐに尺が合わなくなるでしょう。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その群がりかさなってたおれた人の一ばん下になっていたために、からくもたすかって息をふきかえし、上部の人がすっかり黒やけになったのち、やっともぐり出たという人が二、三十人ばかりあります。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに死人の枕頭に詰めて死人の番をしていた家内の者は、呼吸をふきかえした死人を見て驚いた。",
              "citation": {
                "source": "蘇生",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一緒に呼吸をふきかえして、きょときょとあたりを見廻していた非人の面をじろりと見眺めていましたが、おどろいたもののごとく言いました。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人、息をふきかえしたのだ』　と警官が叱った。",
              "citation": {
                "source": "街の探偵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は息をふきかえした。",
              "citation": {
                "source": "春桃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "座間は、息をふきかえした愛情のはげしさに泣きながら、もう一刻も猶予できないことに気がついた。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ははあ、あれは拙者のふきかえ紳士でな、日当千円のものいりじゃ。",
              "citation": {
                "source": "烏啼天駆シリーズ・４　暗号の役割",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、どのくらいの時間が流れたかわからないが、蜂矢はようやく息をふきかえした。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "先へ逃げかえった実業家マルタンとツルガ博士親子の熱心な看護によって、やがて三人は息をふきかえしたのだった。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへマートン技師が駆けつけて、活を入れてくれたので、ネッドは息をふきかえした。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、黒川にどうかなってしまわれると、せっかく息をふきかえした、新興ミマツ曲馬団の全員が、また路頭に迷わなければならない。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "気を失って倒れている男も、息をふきかえさしてしばりあげました。",
              "citation": {
                "source": "長彦と丸彦",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姫さまの顔に水をそそぎかけたり、ひもをといて着物をゆるめたり、手のひらをたたいてみたり、ハンガリア女王の水という薬で、こめかみをもんだり、いろいろにしてみても、王女は息をふきかえしませんでした。",
              "citation": {
                "source": "眠る森のお姫さま",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いに彼は間もなく息をふきかえしたが、その語るところによると、両手がち切れそうな苦痛を感じたという。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この怪事件は、佐々刑事が息をふきかえして、始めて大江山課長をはじめ、警視庁の掛官たちに知れわたったのであった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "百年も前に死んだ人を、今の世の中に、もう一度息をふきかえさせてみると、この大空艇などはもちろんのこと、ロケットでも飛行機でもテレビジョンでも、みんな魔術としか、見えないだろう」　と、蟻田博士は、しみじみ言った。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし間もなく息をふきかえすだろうから、そうだ、いまのうちに大切なマスクをかぶっておこう」　と、怪塔王は、あわてて床の上にしゃがむと、帆村の手から例の汐ふきの顔をしたマスクをひったくりました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜって、博士はさっき怪塔王のおちたその岩の割れ目から出てこられたものですから、僕はてっきり怪塔王が息をふきかえし、匐いだしたことと早合点したのです。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸い、両少年とも息をふきかえしたるも、未だに自由に活動出来ざる状態にあり……”「うーむ、風間も木曾も、いい具合に息をふきかえしたらしいな」　艇長は、にっこりして幕僚の方を一寸見たが、すぐ又、電文の方に眼を移した。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、読者諸君は、パイ軍曹とピート一等兵とがたいへん好都合にも、間もなく息をふきかえしたことに気がつかれるだろう。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、黄いろい幽霊が先に息をふきかえして気がつけば――幽霊が、息をふきかえすというのも、へんであるが――すべて、戦車が墜落する前のとおりであろう。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、ほうぼう姫のからだをしらべてみますと、毒の櫛が見つかりましたので、それをひきぬきますと、すぐに姫は息をふきかえしました。",
              "citation": {
                "source": "白雪姫",
                "author": "グリム",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、たちまち、花よめは息をふきかえして、元気をとりもどしました。",
              "citation": {
                "source": "忠義者のヨハネス",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは――吊された綱があまり早く切られたので地上において息をふきかえし、すっくと立ち上るや、やけになって絞首役人におどりかかる。",
              "citation": {
                "source": "せいばい",
                "author": "服部之総",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
