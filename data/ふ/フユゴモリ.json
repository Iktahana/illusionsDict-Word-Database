        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "冬ごもり時しも、旨飯を水に醸みなし客を犒う待酒の新酒の味はよろしかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうするとまたこの「冬ごもり」の五字がひどくきいて来るような気がするのである。",
              "citation": {
                "source": "伊吹山の句について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしやがて葡萄の収穫も済みますと、もう冬ごもりのしたくです。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌いつしかとなごみ来ぬらし向山の地震の壊え土萌えかすみつつ福寿草冬ごもり、こもりあかねど、寒き日は吾もちぢまりぬ。",
              "citation": {
                "source": "風隠集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌この殿はうべもかしこし白妙の不二の高嶺をまともにぞ見る春鵙冬ごもり冬ごもりうらさびぬらし。",
              "citation": {
                "source": "篁",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌いつしかとなごに来ぬらし向山の地震の壊え土萠えかすみつつ福寿草冬ごもり、こもりあかねど、寒き日は吾もちぢまりぬ。",
              "citation": {
                "source": "篁",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "永い冬ごもりに人馬とも全くこの大根ばかり喰べてゐるらしい。",
              "citation": {
                "source": "樹木とその葉",
                "author": "草鞋の話旅の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、　　　冬ごもり五車の反古のあるじかな　　　　召波　五車の書といふ支那の故事を転じて反古となし、反古の多きことを言へる者にして、冬ごもりの書斎｜狼藉たる様なるべし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の中へ來る冬は、斯うして冬ごもりの支度にかゝる爺やのところへも、『シヨクノ』の遊びに夢中になつて居る父さん達のところへも一｜緒にやつて來ました。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い、寒い、冬ごもりの用意は出来ますか。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……霜日和が雪もよい空となり寒い風が吹きだした、いよ／＼冬ごもりである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "待つてゐた本がきた、冬ごもりの読物として広島のＧさんに頼んでおいたのである、Ｇさん、ほんとにありがたう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐうたら手記（覚書）　行乞　三輪空寂、三つの功徳　　　　　　一、腹を立てなくなつた事　　　　　　一、物を粗末にしなくなつた事　　　　　　一、何を食べてもおいしくなつた事　年の暮　年くれぬ笠きて草鞋はきながら　冬ごもり　冬ごもりまたよりそはむこの柱□月と緑平と私と酒。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬ごもりには炬燵と共にふさわしい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "シヱーターきては冬ごもりらしくない（ネンネコ、サル、胴着、追憶ばかり）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……・きら／＼ひかつて売り買ひされるよう肥えた魚　孫の手をひきお寺まゐりのさげてゐるはお米・月からこぼれて師走の雨のぬくい音・触れると散るまへの櫨紅葉かな　其中一人にして冬ごもり・小春日のさせば障子をあるく虫のかげ　十二月廿四日　晴、めつきり冬らしい寒さとなつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪がふれば雪見酒、酒がなければ読書、炬燵と餅とはいつでもある、――これが私の冬ごもり情調だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "北国ではよく飲む、冬ごもりは毎日毎夜飲むさうで、酒でも飲まなければやりきれないといふ、そんなわけで、一升飲むとか二升飲むとかいはないで、二日飲めるとか三日飲めるとかいつて酒量を日数であらはすさうな。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬が来た、冬ごもりの季節が近寄つた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよ／＼冬ごもりだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなしく冬ごもりすることだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日の冬ごもりには困るけれど詮方ない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "□冬ごもりの幸福――火燵、本、食物、そして煙草も酒も――それから――それ以上あると不幸になる！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬ごもり、ことしはつゝましく私らしい冬ごもりをしたい、今日まづ炬燵の用意をした（今年はとても暖かくて、当分炬燵に用もないらしいが）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "『わが冬ごもりの記』　十二月十四日　晴、曇、時雨。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "春が来た、春が来た、空から太陽から、土から草から、いろんな虫が出て来て飛んだり這うたり、――だが、私は冬ごもりの暗い穴から抜け出せない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふゆごもり　春の大野をやく人は、やき飽かぬかも。",
              "citation": {
                "source": "古代民謡の研究",
                "author": "その外輪に沿うて",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふゆごもり　春の大野を焼く人は、やき足らじかも、わが心焚く（万葉集巻七）此ほどまでになつた譬喩歌は、万葉に発達して、後には一部門をせなくなつた。",
              "citation": {
                "source": "日本文章の発想法の起り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふゆごもり　春の大野を焼く人は、焼き足らじかも、わが心焼く（万葉巻七）此一時、象徴歌と誤認せられた万葉集の譬喩歌も、春野焼く事に対する反感を含んでゐる。",
              "citation": {
                "source": "副詞表情の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
