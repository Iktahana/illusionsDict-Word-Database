    "definitions": [
      {
        "index": 1,
        "gloss": "husband and wife travelling together (traveling)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで茶をのんで餅をつまんでゐたら、同宿の若い夫婦連れがあとからはいつて来た。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで茶をのんで餅をつまんでいたら、同宿の若い夫婦連れがあとからはいって来た。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度ヘルムホルツも学位を受けに来合せて夫婦連れで二晩泊った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹄で落葉を蹶散らす音、これは騎兵演習の斥候か、さなくば夫婦連れで遠乗りに出かけた外国人である。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ亭主の名は徳之助と云って、二十年ほども前から夫婦連れで国を出て、何かの縁を頼って、初めは江戸の品川に草鞋をぬぎ、それから山の手辺を流れ渡って最後にこの押上村におちついて、十五六年も無事に暮らしていたんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただひと組、九月九日の夜に投宿した夫婦連れがある。",
              "citation": {
                "source": "指輪一つ",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉宿に来ている男の客が散歩に出て、二時間や三時間帰らないからといって、さのみの大事件でもないのでしょうが、わたくしどもが新婚の夫婦連れであるらしいことは宿でも承知していますので、特別に同情してくれたのでしょう、宿の男ふたりに提灯を持たせて川の上下へ分かれて、探しに出ることになりました。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時分はマダ今ほど夫婦連れ立って歩く習慣が流行らなかったが、沼南はこの艶色｜滴たる夫人を出来るだけ極彩色させて、近所の寄席へ連れてったり縁日を冷かしたりした。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番小鳥を余計にお買いになるのは若い御夫婦連れで……」という話。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾組かの夫婦連れの中には、夫々良人以外の者、妻以外の者を物色しながら汚い眼付きをして通り過ぎる組があつた。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子も冠らないで、ピンヘットを耳のところに挟んだような、目容のこわらしい男や、黒足袋をはいて襷がけしたような女の往来している中に、子供の手を引いた夫婦連れや、白い巾を頚に巻いた女と一緒に歩いている、金縁眼鏡の男の姿などが、ちらほら目についた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は日曜日のお天気で浴客が多かつた、大多数は近郷近在のお百姓連中である、夫婦連れ、親子連れ、握飯を持つて来て、魚を食べたり、湯にいつたり、話したり寝たり、そして夕方、うれしげに帰つてゆく、田園風景のほがらかな一面をこゝに見た。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「然し夫婦連れですからな。",
              "citation": {
                "source": "茗荷畠",
                "author": "眞山青果",
                "note": "青空文庫"
              }
            },
            {
              "text": "その門の前で、立ち止つた夫婦連れ、結婚一二年、今に今にと思ひながら、知らず識らず生活にひしがれて行く無産知識階級の男女である。",
              "citation": {
                "source": "百三十二番地の貸家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "桟橋附近で、夫婦連れのスパイを見かけたが、一人は海へ飛びこむし、他の一人は行方不明になるし、それで、この騒ぎですよ」「それは、どこの国のスパイですかね」「もちろん、ドイツ側のスパイですよ」「ああ、ドイツですか。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫婦連れが二人の小さな女の子を中にはさんでひろびろと場所を占領した。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつと、例の夫婦連れの男の方の隣へ割込まうとして、「ちよつと、すみませんが、もう少しそつちへ」と嘆願してみる。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その声が終らぬうちに、夫婦連れの女の方が、素早く、実にあつさりそばの女の子の一人を膝へ抱きあげた。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（前の方を頤で指し）あれ、誰だか知つてるかい、あの夫婦連れさ。",
              "citation": {
                "source": "屋上庭園",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三の旅客に交つて、都会のものらしい夫婦連れが、改札口の方から現れる。",
              "citation": {
                "source": "村で一番の栗の木（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の袂で逢った夫婦連れの巡礼。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "『やがて、今過ぎ来りし、江東梅園前にさし掛りしに、観梅の客の、往く者還る者、織る如く雑沓したりしが、中に、年若き夫婦連れの者あり。",
              "citation": {
                "source": "釣好隠居の懺悔",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "又夫婦連れなどで来て、俺が何番を買へと云ふのに貴様が愚図々々云ふから、それ見ろこんな大きな穴が出来たぢやないかと争つて居るのもあります。",
              "citation": {
                "source": "競馬興行と競馬狂の話",
                "author": "初代　桂小南",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に、今日手金を打つて行つた夫婦連れの紳士は、是非親戚や友人にも勧めてみると云つてゐた。",
              "citation": {
                "source": "浅間山",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "えゝ、さうです、夫婦連れの……。",
              "citation": {
                "source": "音の世界",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきほども、あの御夫婦連れの、旦那様の方にお話しいたしましたんですけれど、わたくし、此処へ参りますまで、ずつと船へ乗つてをりましたもんですから……。",
              "citation": {
                "source": "顔",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の、夫婦連れが、これも食事を済ましてはひつて来る。",
              "citation": {
                "source": "顔",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、僕が国へ帰つたのを幸ひ、今日は夫婦連れで浅草へでも出掛けたかな。",
              "citation": {
                "source": "世帯休業",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんた、知らない、そら、よく来る夫婦連れさ、奥さんの方が背が高い……。",
              "citation": {
                "source": "留守（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
