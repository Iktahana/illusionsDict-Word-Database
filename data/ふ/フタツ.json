[
  {
    "uuid": "087aacf9-212f-5e3c-a652-255795779fe1",
    "entry": "二つ",
    "reading": {
      "primary": "ふたつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "数詞"
