    "definitions": [
      {
        "index": 1,
        "gloss": "(exaggerated) professing to be",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「尤もそこは女だけに、将軍家の御落胤というほどの大きな触れ込みをしないで、男の天一坊ほどの評判にはなりませんでしたが、小さい女天一坊は幾らもありましたよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子はもとちょっと居た人形町の家へも行きづらく、その土地で人に顔を見られるのもいやで、今度はあらためて河岸をかえ、体が楽だという触れ込みのある千葉の蓮池から出ることにしたのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "若林も晴子が孝行芸者だという触れ込みで、最初呼んでみる気になったので、お神の意味がわかり、なるほどそうかと言った顔で頷いていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミップスの最高速版であるＲ４０００の８０ＭＩＰＳに対して、ＡＬＰＨＡは３００ＭＩＰＳはでるという触れ込みで、商売人のビル・ゲイツはさっそくＷｉｎｄｏｗｓ　ＮＴをＡＬＰＨＡに載せると言いだした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かいわくのありそうな捨て駕籠のようだが、それにしても触れ込みよりゃちっと駕籠の数が少なかったな」「へ……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前九時あるいは十時開場という触れ込みが午後三時になるか四時になるか、またその幕間が二時間かかるか三時間かかるか、狂言が二幕か三幕で閉場してしまうか、そんなことは一切わからない。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "先をいそぐ四人は御用の旅という触れ込みで、むやみに駕籠を急がせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "狐と僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "スクリブ街に事務所を持って、本部の命令で国際的な事件を扱っていたのだが、このバニスタアが、特にベルチョン博士の懇望で動いて、亜米利加の宝石商人という触れ込みで密かにホテル・アムステルダムへ投宿したのだった。",
              "citation": {
                "source": "ロウモン街の自殺ホテル",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こんな風に触れ込みつつ今自分が馳け込んでいるときだと彼は思った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩形圭吾氏は現在｜印度貿易商という触れ込みで、こうした東京一流のホテルに泊っている人物で、又、実際に金持ちらしく見えていたのであるが、その財産というのは、米国の加州辺で稼ぎ溜めたものらしい。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "触れ込みはそうでも、総員男女二人しかいない」「なんだ？",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "触れ込みはそうでも、総員男女二人しかいない」「なんだ※」　ちょっと、ダネックの顔色が和らいだ。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "次から次と、ひどい目にあわされれば、どんな人間だろうと……」「おおご主人もそうお思いか」　と、云ったは、易者という触れ込みの男であったが、「それで安心」　と口を辷らせたように云い継ぎ、ハッとしたように、急に黙ってしまった。",
              "citation": {
                "source": "猿ヶ京片耳伝説",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "円山会議の後、真先に江戸へ下った堀部安兵衛は、浪人剣客長江長左衛門という触れ込みで、米屋の店にほど遠くない林町五丁目に借宅した。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "木曾街道筋の通行は初めてと聞く仙台藩主の場合にも、時節柄同勢やお供は減少という触れ込みでも、千六百人の一大旅行団が京都へ向けてこの宿場を通過した。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "時節柄、万事質素に、という触れ込みであったが、それでもその通行筋にあたる東海道では一時旅人の通行を禁止するほどの厳重な警戒ぶりで、三月四日にはすでに京都に到着し、三千あまりの兵に護られながら二条城にはいった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時の仙台の同勢は中津川泊まりで、中通しの人足二百八十人、馬百八十｜疋という触れ込みだった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ隣宿の妻籠からはお札降りの祝いという触れ込みで、過ぐる四年前水戸浪士通行の際の姿にこしらえ、鎧、兜、弓、鎗、すべて軍中のいでたちで、子供はいずれも引き馬に乗り、同勢およそ百余人の仮装行列が練り込んで来た。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "府中あたりの田舎浪士が、気楽な長逗留という触れ込みで、藤屋でも、この一行の身分は知らないのである。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　といっている、四十四、五のでっぷりした、温厚な人物は、近江の豪農、垣見吾平という触れ込みで泊まりこんでいる大石｜内蔵助である。",
              "citation": {
                "source": "口笛を吹く武士",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、そんな大悪の妹だなんて触れ込みで、人聞きがわるいやね。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの美男の妹などと触れ込みやがって、いずれまたろくでもねえ芝居をたくらんでいるのだろう。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたいはいま磯屋の人間さ」「ふん、妹でもねえものが、妹という触れ込みでな。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしい買うよ――だが、製作は、どうすればいいかな」「それは実費で僕が引きうけるよ、僕だって考案者としての興味が旺盛なのだ、他人に任したくないからね」　手附に二百円とって、製作には二十里ほど先の都会へ行き、そこで試験製作という触れ込みでつくらせた。",
              "citation": {
                "source": "奇術考案業",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより娼婦上りにちがひなかつたが、白系将校の未亡人といふ触れ込みで、同じ下宿の一室に住んでゐた。",
              "citation": {
                "source": "それができたら",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後岩倉なる癲狂院には、金満家の主人てふ触れ込みの患者一人殖えて、そが妻と覚しき美しき女の、七ツばかりなる女の子携へたるが、絶えず見舞に来りて、骨身を砕くいたわり方を、見るほどのものいとしがらぬはなしとかや。",
              "citation": {
                "source": "心の鬼",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "遂々私はあの人の秘書という触れ込みで、男装して日本へ従いて来てしまったのです。",
              "citation": {
                "source": "情鬼",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕たちは夫婦というふれこみにすると言葉使いもいくらか変えなきゃいけませんね。",
              "citation": {
                "source": "謎の女",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "同社のふれこみでは、この新しい製品の機能は６８００と同等であり、より小型化してシンプルに構成したものが６５０２であるという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸の内でタイピストに通つてゐると云ふ春子は、タイピストをしてゐると云ふふれこみだけのもので、錻力屋のをばさんの話によると、実際は春子はバーへ勤めを持つてゐる様子だつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
