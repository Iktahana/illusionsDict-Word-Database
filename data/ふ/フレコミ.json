[
  {
    "uuid": "870aa271-b769-56c0-9ad5-78f9c9b358b9",
    "entry": "触れ込み",
    "reading": {
      "primary": "ふれこみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
