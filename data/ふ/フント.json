        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "フントウ　ヲ　シャス、セイコー　ヲ　イノル、キカンブカフ　一ドー　セーラー　ショクンと電報文みたいに片仮名で書いてあった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "助手は体重を取ると、帳簿の彼の名のところに一〇九フント（ロシヤの重量の単位。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            },
            {
              "text": "一フントは四〇七・七グラム）と記入した。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそれにも拘らず、また患者の異常な食慾にも拘らず、彼は日に日に瘠せ衰えて、助手が日毎に記入するフントの数はだんだん少なくなって行くのだった。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の体重は九三フントでした。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみみたいな人ばっかりだったら、何にも出来ゃしないじゃないか　○パン一人につき一フントだけ買える由。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君が見て居たら、一フントのバター ５р.、テリャーチナ〔子牛肉〕の足一本十五｜留して居た由。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっとキースルイ〔すっぱいの〕を半フント五｜哥で買った。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間ラフカで一フント〔ポンド〕一р66к だと云って、くさったようなトマト二つ60к で売ってた。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "◎同じラフカで、マースロフント９р ！",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "◎犢のやいた美味のがフント８р ！",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、神蔭流の極意によって、狂六はジリジリと追いつめられ、危機打開のために、イヤでも彼が孤軍フントウ立向わねばならないようになってしまった。",
              "citation": {
                "source": "影のない犯人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし尚もひるむところはなく孤軍フントウ稽古をつづけているところ、見かけとちがってオカミサンは剛気であり、大そう負けギライらしい。",
              "citation": {
                "source": "九段",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年は、フント一ルーブルのトマト売が出ている。",
              "citation": {
                "source": "子供・子供・子供のモスクワ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウルフ・ハウンドとダックスフントとの混血種みたいな、……とても見てくれの悪い大きな犬なんですって、モリナーレの夫人が言ってらっしゃいましたわ」　見てくれの悪い犬と言われた途端、私は口許を掩うている扇子の陰から、妻の視線を激しく浴びたような気持がして、無意識に卓子の下の脚を引っ込めた。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒れば獰猛になって死闘する犬にはウルフ・ハウンドもあれば、ブルテリアもありブルドッグもあれば、シェパードもあり、ダックスフントもおそらくその範疇に入ったであろう。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "胴が無暗に長くて四肢の極端に短い点では、ダックスフントそっくりであり、前肢の逞しさや毛色では英国産のマスチーフであり、やがて成長すれば三二｜吋の高さ体重一一〇｜封度にも達するのでは、まさに犬種中の最大種アイリッシ・ウルフ・ハウンドであった。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体ダックスフントだってそうなのよ。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこへ行くんだ」「ちょっと」「ちょっと、なんだ」「フントウバだ」　監獄の便所のことで、ムシニン（囚人）の言葉だが、ムシ（監獄）に縁の深い俺たちはズバチョオ（手水場）なんて言葉よりもっぱらこれを使っていた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
