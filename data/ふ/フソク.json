    "definitions": [
      {
        "index": 1,
        "gloss": "unexpected",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この日の薄暮ごろに奈々子の身には不測の禍があった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と私は不測に※涙の流るゝを禁じ得なかつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯る物語に不知不測夜を更し、頓て私の遭難實談も終ると、櫻木大佐は、此時稍や面を改めて私に向つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "将卒を強いて戦わしめんとすれば人心の乖離、不測の変を生ずる無きを保せず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "建文帝｜是の如くにして山青く雲白き処に無事の余生を送り、僊人隠士の踪跡沓渺として知る可からざるが如くに身を終る可く見えしが、天意不測にして、魚は深淵に潜めども案に上るの日あり、禽は高空に翔くれども天に宿するに由無し。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで上に残った者は狂人の如く興奮し、死人の如く絶望し、手足も動かせぬようになったけれども、さてあるべきではありませぬから、自分たちも今度は滑って死ぬばかりか、不測の運命に臨んでいる身と思いながら段々｜下りてまいりまして、そうして漸く午後の六時頃に幾何か危険の少いところまで下りて来ました。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで上に残った者は狂人の如く興奮し、死人の如く絶望し、手足も動かせぬようになったけれども、さてあるべきではありませぬから、自分たちも今度は滑って死ぬばかりか、不測の運命に臨んでいる身と思いながら段々下りてまいりまして、そうして漸く午後の六時頃に幾何か危険の少いところまで下りて来ました。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、天恩｜洪大で、かえって芸術の奥には幽眇不測なものがあることをご諒知下された。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "山林濫伐を敢てして福を惜まなかつた結果は、禿山渇水を到處に造り出して、土地の氣候を惡くし、天候を不調にし、一朝豪雨あるに至れば、山潰え水漲りて、不測の害を世間に貽るに至るではないか。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "迂闊といえば迂闊だが、（というのは、死刑を予期するくらいなら当然、他のあらゆる刑罰も予期しなければならないわけだから）彼は自分の運命の中に、不測の死が待受けているかもしれぬとは考えていたけれども、このような醜いものが突然現われようとは、全然、頭から考えもしなかったのである。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩下、之を岩倉に告げたので、具視大いに決する所あり、土越二藩｜尚前説を固執するならば、いかなる不測の変あらんも測られざるに至ったので、浅野｜茂勲その間に周旋して遂に容堂、春嶽をして譲歩せしめた。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "せいぜい一年の間を置くだけのつもりだったが、不測の事態が重なって五年近くも鉱山を出られなかった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めわれ不測の禍のために母上を喪ひまゐらせき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "此日の薄暮頃に奈々子の身には不測の禍があつた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "山林乱伐を敢えてして福を惜しまなかった結果は、禿山や渇水をいたる処に造り出して、土地の気候を悪くし天候を不調にし、いったん豪雨が有れば山は潰え、水は溢れて、不測の害を世間に贈るに至るのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も※れ難き義理に迫りて連帯の印捺きしより、不測の禍は起りてかかる憂き目を見るよと、太く己に懲りてければ、この際人に連帯を頼みて、同様の迷惑を懸くることもやと、断じて貫一の請求を容れざりき。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば先祖から持ち伝えた山を拓いて新らしい果樹園を造ろうとしたようなもので、その策は必ずしも無謀浅慮ではなかったが、ただ短兵急に功を急いで一時に根こそぎ老木を伐採したために不測の洪水を汎濫し、八方からの非難攻撃に包囲されて竟にアタラ九仭の功を一簣に欠くの失敗に終った。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "西行法師が「何事のおはしますかは知らねどもかたじけなさになみだこぼるる」と詠じたように、道徳の威厳は実にその不測の辺に存するのである。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知でもありましょうが、近来どうしたものか、われわれ科学者仲間におきまして、不測の災害に斃れるものが少くない、いや、寧ろ甚だ多いと申す方がよろしいようであります。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸家迚大概平日より一定の國是相立候向は無御座、萬一危急の時に臨候はゞ、唯家來共の議論にて、或は關東と云ひ、或は京都と云ひ、或は獨立と云ふ抔、口論同樣の評議にて、評議最中にも不測の難題指起可申、實に氣の毒の事共に御座候。",
              "citation": {
                "source": "御時務の儀に付申上候書付",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すると、不測の戦闘が起ったというわけですね」「そうじゃ。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（その梶子殿はどうしたことか、和歌山のお城へはいったきりで、その後まるで消息がない）　もちろんあれほどの女であるから、不測の災いを受けるというような、そんな事はあるまいとは思われるものの、やはり心にかかってならなかった。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、株式市場に又不測の変動が近づかうとしてゐる。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "余はさながら不測の運命に魘われて悄然として農夫の顔其まゝに言わぬ哀愁に満ちた自然の面影にやるせなき哀感を誘われて、独｜望台にさま／″＼の事を想うた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや文化の伝播にはもっと自在で不測な交流が行われていたはずだといっても好いのではあるまいか。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、引越しの性分というものにも、だいたい周期というものがあって、中には夜逃げだとか、環境が気に入らないことからという不測の事故もあるかも知れんが、北斎のように百回ちかい引越しはひどすぎるようだ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しても絶代の明師が不測の難に遭うて遠流の途に上るのだから、貴賤道俗の前後左右に走り従うもの何千何万ということであった。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "假使其踰耄至期、則其神明不測、想當爲何如哉。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "「少し風過ぎる事」と、自分でらふそくに灯を入れる。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、いくら小さいとはいっても、お妃をむかえるのに、ふそくなほどではありませんでした。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
