    "definitions": [
      {
        "index": 1,
        "gloss": "thigh",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして嬉しくなったのか、突然、太ももを叩き始めた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで一策をかんがえて、ドン助のはりきった太ももをギューッとつねってやった。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "急上昇のときだと思うが、胸と太ももとが、目に見えない魔物のために、今にも押し潰されそうに痛むのを発見して、ああこれこそ我慢づよいわが空の勇士が、絶えず相手に闘っているところの見えざる敵“慣性”だなと悟った。",
              "citation": {
                "source": "三重宙返りの記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房に茶を汲んで出し、善太に賭事を教へ、金を股倉へくぐらするなどの仕草は場当りなれど、本文の権太ももどりにならぬまでは極の安敵なれば深く咎むるにも及ばざるべし。",
              "citation": {
                "source": "いがみの権太",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると、小平太ももう自分のことのような気はしなかった。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く、早くたのむ」　ハルクは、歯をくいしばりつつ、自分の右の太ももを指した。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、そうか、もっと上を、しばるんだな」　竹は、ようやく合点がいって、ハルクがいったとおり、バンドをといて、太ももを、力のかぎり、ぎゅっとしめた。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うーん」　竹見は、全身の力を腕にあつめて、ハルクの太ももをしばった。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、思うと、懸け声もろとも、ハルクはナイフを自分の太ももに、ぐさりとつき刺した。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をどうしたのか詳かではないが、蛇毒をうけて瀕死のハルクは、ついに自らの手で、自分の太ももを切断することに成功したのだ。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "君も一しょについてきませんか」　帆村探偵にいわれ、正太ももちろん尻ごみをするような弱虫ではなかった。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "のこった者たちの体はいちように青銅いろに膨れ、腕が太股なのか太ももが腹なのか、焼けちぢれたひとにぎりの毛髪と、腋毛と、幼い恥毛との隈が、入り乱れた四肢とからだの歪んだ線のくぼみに動かぬ陰影をよどませ、鈍くしろい眼だけがそのよどみに細くとろけ残る。",
              "citation": {
                "source": "原爆詩集",
                "author": "峠三吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに力を合せようと周章てた長太ももろともに引摺られて横倒しになりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そういう宗太ももはや一人前の若者で、木曾山の前途には関心を持つらしい。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "下半身のズボンもボロボロに破れて、青い太ももまで見える。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャンの太ももに赤い刺し傷が二つあった。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "十本のはだかの腕は、かれのからだを抱きしめ、十本の桃色の太ももが、かれのからだを絞めつけていた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔の上に太ももが重なり、腕と腕とがもつれ、なめらかなかっこうのよいおしりが、無数に露出していた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔の上に太ももが重なり、なめらかなかっこうのよいおしりが無数に露出していた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お浜は両股を半びらきにして、白い太ももの奥まで覗かせていることがあるからである。",
              "citation": {
                "source": "南方郵信",
                "author": "中村地平",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりでは持ちきれまい三、四人つれて」四　為も勘太ももどって来ないうちに、広厳寺の僧たちが、提灯をたずさえて、駈けつけて来た。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（白い齒をむいて、右手のひらでピシャリと音を立てて自分のふとももを叩く）バイバイ、マグロくわすから、またおいで！",
              "citation": {
                "source": "夜の道づれ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみはいま、おじさんのふとももの上に乗っているでしょう、そして時々そっと横になって光ったお腹を見せびらかしているだろう、それでいて自分で羞かしいと思ったことがないの。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふとももをたたいた。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、これだな……」　ふとももにポツンと赤くはれあがって、根をはった腫物がひとつ……これが原因だとわかりました。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白く光る首は、ツーッと、むこうのほうへ遠ざかっていきましたが、そこで黒いシャツをぬぎはじめたとみえて、銀色の肩、胸、腹、それから、腰、ふともも、足のさきまで、夜光怪人の全身があらわれました。",
              "citation": {
                "source": "夜光人間",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
