[
  {
    "uuid": "565353c1-4cdb-59d4-a87e-65a746f713e6",
    "entry": "不成績",
    "reading": {
      "primary": "ふせいせき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
