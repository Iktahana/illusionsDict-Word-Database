[
  {
    "uuid": "1957fd5a-fe8b-53f2-8dc5-7a7cdae2d39f",
    "entry": "腹背",
    "reading": {
      "primary": "ふくはい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "back and front",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ロシヤは腹背に敵を受けとるからだべ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤軍長駆して深く敵地に入り、腹背左右、皆我が友たらざる也、北平は遼遠にして、而も本拠の四囲｜亦皆敵たる也。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "正成、桜井駅に子｜正行と訣別し、兵庫に赴きて、義貞と共に賊の大軍と戦ひ、腹背敵を受けて忠死を遂げた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹背に敵を受けた社員たちはもはや動くことが出来なかった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから新聞に出る事件を見ると命中面のひろい腹背なんかうっては、必要のない殺人をひきおこしています。",
              "citation": {
                "source": "浦和充子の事件に関して",
                "author": "――参議院法務委員会での証人としての発言――",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹背から受けたその差迫った険しいものの間で、矢代は、辛うじて呼吸をしている白白しい時間をつづけるばかりだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹背敵を受けてしまった。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右から廻わり、腹背を衝こうとするらしい。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに至って七福神組は、腹背敵を受けてしまった。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、腹背の二手の勢は、ドッと喊声を響かせたが、思慮浅くムラムラと、七福神組へ走り寄った。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして小一郎と君江とは、腹背に敵を受けてしまった。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はここに計らずも腹背に敵を受けたのである。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして腹背敵を受けたその危険からは遁がれたが、神秘を極めた地下国へは再び行くことが出来なくなった。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は面従腹背を人の当然の行為であると信じてゐた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬のヌケ穴からムリに身を現して一服もるという困難な所業が、全然他に活用する意志のない面従腹背の学習だということは誰にもはじめは分らない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、サビに対して面従腹背の難民に保護せられたものが宝塚少女歌劇であるということが分ると、宝塚を理解するのはもう手間がかからない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "面従腹背のトモガラがひそかに忠誠を誓った神を迎える逆上ぶりなのである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するにこのトモガラは面従腹背を一生の定めとしていることを現しているようなものさ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は腹背に敵を受け、進退まったく谷まった。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹背敵を受けたのであった。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹背敵を受けたばかりか、その中の一人は剣聖ともいうべき、秋山要介正勝であった。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹背に敵を受けたのである。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹背に敵　敵の一人を真っ向にかけて、一刀に切り倒した山県紋也は、新しく血に濡れた抜き身を引っ下げ、逃げて行くもう一人の敵の後を、お粂を背後に従えて、今やまっしぐらに走って行く。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局紋也とお粂との二人は、前後腹背に敵を受けて、退路を断ち切られてしまったのである。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹背に大軍を引き受けて、今はこれまでと覚悟を定めた、多治見ノ四郎二郎国長は、この時まで中門に床几を立て、大将軍のごとく控えていたが、「今はこれまでぞ、死に恥じさらすな！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがのお館義明公もこう腹背に敵を受けてはどうしようにも手が出ない。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「腹背敵を受けました上は、悠長に構えてはおられませぬ」千坂杢之介は悲痛の声で、「いざ、ご出陣くださいますよう」「具足を持て！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は腹背兩面に其「性」の機關を持つた圓い存在であつた。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹背に敵をうけて逆上した平家の軍勢は「帰せ、帰せ」という、必死の下知も何のその、もう命が惜しいばかりに、後へ後へと泡を喰って逃げ出した。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第七巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹背に敵を受け、全く孤立した形である。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
