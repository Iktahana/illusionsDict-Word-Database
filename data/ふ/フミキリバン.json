[
  {
    "uuid": "7581dc66-e259-580f-bc99-73ab7cb9b47f",
    "entry": "踏切番",
    "reading": {
      "primary": "ふみきりばん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
