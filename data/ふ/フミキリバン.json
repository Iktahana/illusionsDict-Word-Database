    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gatekeeper",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かつて讀んだことのある――そして今でも印象に殘つてゐる――福士君の詩「踏切番の娘」を思ひ出して、或る性格のもつ素朴さに感動した。",
              "citation": {
                "source": "歳末に近き或る冬の日の日記",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくつとなく踏切番のいない鉄路を横切るのは不安である。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本にもあるような秋草が咲いていたり、踏切番の小屋に菊が咲いていたり、路傍のマリヤのみ堂に花が供えてあるのも見ました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車には踏切番といふものがあるが電車にはそれが無いから、子供等には危險だと一人の男がいふと、番臺の女房が「ほんにさうどすな」と相槌を打つてゐた。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道さ行って、鉄道の踏切番でもすれば……！",
              "citation": {
                "source": "土竜",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏切番はいいぞ、父！",
              "citation": {
                "source": "土竜",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「父は馬鹿なごどばり言って……」　市平は尚、踏切番という仕事が、年寄りに取って、いかにいい職業であるかを説いた。",
              "citation": {
                "source": "土竜",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「踏切番は、初めの中は日給五十銭ぐらいなもんだげっとも、仕事は楽なもんだで、父！",
              "citation": {
                "source": "土竜",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車と踏切番動揺と苦しみの愛の路ははてもない。",
              "citation": {
                "source": "小熊秀雄全集-10",
                "author": "詩集（９）流民詩集２",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛はとかく通りすぎるものです、時間も無視して酔ふものです、一方が、一方をかならず守るものが必要です怪我のないやうに目的地に着くやう汽車になつたり踏切番になつたりしてゆかう。",
              "citation": {
                "source": "小熊秀雄全集-10",
                "author": "詩集（９）流民詩集２",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後八時過は踏切番がいないので、慣れないトラックが二、三度引っかけられた事のあるトテモあぶない処なのよ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番先頭に立つてゐたのが、いきり立つてゐる馬の手綱を力一杯に身體を後にしのらして引きながら、踏切番に、汽車をきいた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　顏を見知つてゐた踏切番が、柄に卷いた白旗をもつて、出てきた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の道はよい、上郷の踏切番小屋から乞ひはじめる、田植がなつかしく眺められる、それはすでに年中行事の一つとしての趣味をなくしてゐるが、やはり日本伝統的のゆかしさがないことはない。",
              "citation": {
                "source": "行乞記",
                "author": "北九州行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「同じ踏切番でございます。",
              "citation": {
                "source": "マルクスの審判",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前はまだ踏切番がしたいかな。",
              "citation": {
                "source": "マルクスの審判",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり毎日出張するので女中が、ひまな改札係や踏切番と大変親密になってしまったという話だが、どの程度に親しくしたものか背中の私には一向わからなかった。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーリキイは二十四歳になる迄に、更にパン焼職人であり、カスピ海の漁業労働者であり、踏切番であり、弁護士の書記でありました。",
              "citation": {
                "source": "マクシム・ゴーリキイについて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨十八日（五月）午前八時｜四十分、奥羽線上り急行列車が田端駅附近の踏切を通過する際、踏切番人の過失に依り、田端一二三会社員｜柴山鉄太郎の長男｜実彦（四歳）が列車の通る線路内に立ち入り、危く轢死を遂げようとした。",
              "citation": {
                "source": "白",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "×泥の郊外、雨が降る、濡れた竈に木がいぶる、踏切番が旗を振る、ぼうぼうとした草の中屑屋も買はぬ人の故。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちのいた街の方から、ベン隧道の中に、十本の貨物列車が入っていくのを数えた人があるのに、隧道を出た向こうの踏切番は、いや十本の貨物列車なんて、うそだ。",
              "citation": {
                "source": "人造人間の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、私は停留場のそばの踏切番だか轉轍手だかの小屋の前に立つて、二三人ゐた若い男の人たちに訊いた。",
              "citation": {
                "source": "不良兒",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "小村のいった毘沙門前の停留場というのは、大津街道の追分からすこし行くとすぐなので、そこで電車を降りて、踏切番をしている女に小山というところへ行くのはどう往ったらよいかと訊ねると、女は合点のいかぬように、「小山はここから五、六町やききまへんなあ。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "その駅長が、ある時、踏切番の仕事について面白い話をしてくれた。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなはち、「踏切番は、人を通さないのが目的ではなく、人を通すのが目的の仕事である。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏切を遮断するといふことが目的の仕事であるかのやうな印象を受けるのは、微妙なところで、踏切番の「心得違ひ」を暴露してゐるからであらう。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏切番のいない踏切をよこぎる時、私、このまま轢かれてしまいたいと思った位です。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏切番のいない踏切をよこぎる時、私、このまま轢れてしまいたいと思った位です。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄道線路に出で踏切番の小屋を見つけて逃げ込む。",
              "citation": {
                "source": "来訪者",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "その線路には踏切番の小舎がある。",
              "citation": {
                "source": "悪魔",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
