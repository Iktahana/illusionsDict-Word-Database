    "definitions": [
      {
        "index": 1,
        "gloss": "wiping out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "殊に青い空の盤上に白い雲が、いいようもないさまざまの形をあらわして、流れ漂うさまは、払拭された青一色の空よりも私の眼にはたのしかった。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々に勤めて払拭せよ。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづかな日だつた、遊蕩気分を払拭した。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十日の卒倒菩薩は私から過去の暗影を払拭してくれた、さびしがり、臆病、はにかみ、焦燥、後悔、取越苦労、等々からきれいさつぱりと私を解放してくれた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐうたら根性、やけくそ気分を払拭すべし、是非実行すべし。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "集中排除が緩和され「第一義的軍事施設以外は日本から極く僅かな施設しか賠償として撤去しないよう」にと、ストライク委員会の報告が示しているという記事をよむと（三・一七、読売）日本の勤労階級すべての人々は男も女も、日本の軍国主義の残滓はどこまで払拭され得るだろうかと、空おそろしい気がしないではいられない。",
              "citation": {
                "source": "正義の花の環",
                "author": "――一九四八年のメーデー――",
                "note": "青空文庫"
              }
            },
            {
              "text": "処で他方その反面として、こうした合理主義は歴史の発展を一つの必然性と見る代りに、之を単なる缺陷誤謬偶然等々と見做し合理的な見地から云って払拭清算されるべき過去と見ることとなる。",
              "citation": {
                "source": "啓蒙の現代的意味と役割とについて",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼等は人民の社会的感覚があまり民主化されないうちに、すなわち人民の人間的権利についての自覚は目覚めつつあるが、習慣に根ざした隷属性や迷信が、あまり見事に払拭されてしまわないうちに、天皇および天皇制を妥協的な形で再確立するのが賢明であると考えた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一は根強くはびこっている絶対主義的軍国主義教育を根底から払拭すること。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の軍国主義教育の払拭のためには一九四五年十月二十二日連合軍総司令部から教育の民主化に関する指令が発表された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四六年一月、ジャーナリズムが戦時色を払拭して再発足をはじめたとき、そこに面白い現象が現われた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "偉なる自由に向ふ大道に数世紀の間横たはつてゐる服従と奴隷の足跡が払拭せられなければならない。",
              "citation": {
                "source": "「婦人解放の悲劇」自序",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍国主義や封建主義の払拭は、一抹の残滓をも残さざらんことが望まれるばかりである。",
              "citation": {
                "source": "或る日の対話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度この思想にまで戻って考えることが、生活と娯楽という対立を払拭するために必要である。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚くばかり、何と記憶が払拭せられてしまつてゐた。",
              "citation": {
                "source": "「なよたけ」の解釈",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭湯になど行かずとも、毎日身体の上下の払拭を怠らぬこと。",
              "citation": {
                "source": "鴎外を語る",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしにもその精神がいつしか感染して、時節柄多分に洩れず、同居生活の窮屈さを味はされてゐたをりのことであるが、毎朝洗面の後、鴎外の故智に做つて、身体の上下を摩擦し払拭した。",
              "citation": {
                "source": "鴎外を語る",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "日清戦争当時、何を見て過したか、殆、払拭せられた碁盤の面のやうに記憶の痕もなくなつてゐる。",
              "citation": {
                "source": "春永話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生に於て吾々の眼を強く惹きつけていたあらゆるものの価値が一時に払拭され、凡てのものの中心であった自分自身が微々たるものになって、ただ悠久永劫な大自然のみが、何物にも無関心な大きさで君臨する。",
              "citation": {
                "source": "大自然を讃う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "確乎たる臣民道の自覚についで、ゆがめられた文化意識の払拭と、各専門部門の独善割拠の弊を改めなければ、この協力態勢は望んでも無駄である。",
              "citation": {
                "source": "戦時下に於る文化運動の意義",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々が日本に新しい文化を建設するこの時代に、さういふ理想をもつてここに立ち上つたときに、平和に狎れ安逸に溺れた奇矯脆弱な文化的の払拭といふことを、まづ考へなければならないのであります。",
              "citation": {
                "source": "戦時下の文化運動",
                "author": "――九州地方講演筆記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活の理想を個人的幸福に置き、或は社会の改造を単に経済的物質的水準の向上に置いた今日までの文化意識は、全く払拭しなければならぬ。",
              "citation": {
                "source": "生活力の強化",
                "author": "――北陸地方文化協議会講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その分子がヒットラー総統及びヒムラー内相を暗殺することあらば、ドイツはナチの色を払拭し、休戦するであろうとの情報が存在した。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、将来は、個人的にみても、また満洲それ自体としてみても、かくの如き表情は一日も早く払拭せらるべきであり、作家も亦おそらくその業蹟を通じて、諸民族の協力による国土の発展に寄与することを念願とするに至るであらう。",
              "citation": {
                "source": "「満洲国各民族創作選集」選者のことば",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野性」に帰れとか、「野性」を養へとか云つてもそれは無理な話で、実際は、不必要、かつ有害な都会的装飾、乃至、繊弱な文化意識を払拭せよといふ意味になるのです。",
              "citation": {
                "source": "戦争と文化",
                "author": "――力としての文化　第三話",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、かゝるすがたは、「卑しきもの」すべてを払拭することによつて、鮮やかに描き出されるからであります。",
              "citation": {
                "source": "青年の矜りと嗜み",
                "author": "――力としての文化　第四話",
                "note": "青空文庫"
              }
            },
            {
              "text": "果樹の枝を裁断する時、樹皮を掃除し払拭して病菌や寄生虫を駆除する時期、地にうんと肥料を注いで来るべき収穫の約束を結び置くべき時期、一年の成効と失敗とは今日に於て決せられるのです。",
              "citation": {
                "source": "百姓日記",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僻目であろうかと恐れたが、それかといって、その疑を払拭する反証をも捉え得なかった。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは今日では払拭されたようであるが、洗煉されたものよりも粗野の方へ、デリケートなものよりも無神経の方へ生活形態の方向を推し進めようとしていることは争えない。",
              "citation": {
                "source": "安吾巷談",
                "author": "野坂中尉と中西伍長",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
