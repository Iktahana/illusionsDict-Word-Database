          "literary": [
            {
              "text": "渡辺篤を誘って、アラスカで夕食、トマトのポタアジュと、チキンクリーム煮にコーン・フリッター。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "青豆ポタージュに、豚のグリル、コーンフリッター。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタージュ・アスパラガス、チキン・ソティーにコーン・フリッター、それに野菜のカレーライス、うまかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "平目のグラタン、チキンの挽肉のスフレ（スフレと言ってたのが、かまぼこみたいになってしまった）、チキンのフリッターにバタライス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
