        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雹雲砲手宮沢賢治なべて葡萄に花さきて蜂のふるひのせはしきにをちこち青き銅液の噴霧にひるは来りけりにはかに風のうち死してあたりいよよにまばゆきを見ずやかしこの青きそら友よいざ射て雹の雲",
              "citation": {
                "source": "雹雲砲手",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ったけれども、君たちのやったようでなく、噴霧器を使わないといけないんだ。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」爾薩待「いや、それはね、今も言ってたんだが、噴霧器を使わずに、この日中やったのがいけなかったのだ。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛岡は花畑の添木をさしてやっていたり、噴霧器で果樹に殺虫剤を噴きかけていたりします。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯林のカイゼル・ウィルヘルム街の薬屋へ繕しに預けて置いたまま伯林を立ってしまったおしろいの噴霧筆はどうしたろう。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とさっきから噴霧器で頭に殺虫剤をかけているが、これがさっぱり効き目がない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "応接室まで来て上っ張りを脱ぐと、看護婦が噴霧器を持って来て倉地の身のまわりに消毒薬を振りかけた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "噴霧器から噴き出す霧の中でベルトの線が霞み出した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "噴霧器から流れる霧は、どよめく人の流れのままにぼうぼうと流れていた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、各種の園芸用具や害虫駆除の噴霧器などが、雑然と置かれてあった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "エーテルを噴霧状にして皮膚に吹きつけると、その部分の感覚が滲透的に脱失してしまう。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貌一面に吹きつけて来る噴霧は、冷えびえとした感触で皮膚を柔らげ、鼻の先からはぽつんぽつんと雫がしたたり、顎の下へ流れ込んだ。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "書窓から眺めると、灰色をした小雨が、噴霧器で噴く様に、弗――弗と北から中ッ原の杉の森を掠めて斜に幾しきりもしぶいて通る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二二・六噴霧的な夢あのしやれた登山電車で智恵子と二人、ヴエズヴイオの噴火口をのぞきにいつた。",
              "citation": {
                "source": "智恵子抄",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢といふものは香料のやうに微粒的で智恵子は二十代の噴霧で濃厚に私を包んだ。",
              "citation": {
                "source": "智恵子抄",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "食塩水の噴霧がさっと注ぎかかると、隆吉は咳き入った。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔も渋めずにひたすら噴霧を吸い込むことにつとめていた。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに対抗するような気で、やたらに噴霧を注ぎかけてやりたくなった、後はアルコール・ランプの芯をかき立てた。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "噴霧筒の水滴を受くる下のコップが一杯になっても、周平はまだ吸入を止そうとしなかった。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "桶もテンビンも、噴霧器まで揃ってますぜ。",
              "citation": {
                "source": "水鳥亭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際にやるには、特殊の噴霧器で、飛行中の飛行機からまくのが一番いいのであるが、地上で噴出させて、上昇気流に乗せて、簡単に上空に送り上げることも出来る。",
              "citation": {
                "source": "雨を降らす話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その噴霧器も、優秀な性能のものが考案された。",
              "citation": {
                "source": "雨を降らす話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩尾根とまでは行かないが、なるべく幅の狭い山脈を選び、その風上側八合目くらいのところに、噴霧器を設置して、沃化銀の粉を風に乗せて吹き出してやる。",
              "citation": {
                "source": "雨を降らす話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで噴霧器で吹き出し、水素の焔を通して灼いてから、撒布する。",
              "citation": {
                "source": "雨を降らす話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この噴霧器付きの燃焼装置を、沙漠の中に設置した。",
              "citation": {
                "source": "雨を降らす話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに一時間半発焔噴霧器を働かしつづけると、その雲が崩れ出して、やがて「稲妻が閃めき豪雨が降ってきた」そうである。",
              "citation": {
                "source": "雨を降らす話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺虫剤を入れた噴霧器を裸の背中に背負った五兵衛が、納屋の格子へ立ちよって馬鈴薯の処理を教えていた。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸棚の前で、女中は印度の詩人の室に撒く南京虫よけ薬を噴霧器に移した。",
              "citation": {
                "source": "モスクワ印象記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはきっとここからエーテルを精巧な噴霧器で吹きこむんだろうと思った。",
              "citation": {
                "source": "黒襟飾組の魔手",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとともにマッサージ（いろいろな変更型、軽いタッチからタッチングおよび踏み付けまで）、水治療（冷水浴、冷水温水の噴霧、薬湯、高温浴、蒸気浴）、飲水。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
