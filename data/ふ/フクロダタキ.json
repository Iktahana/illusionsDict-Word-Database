    "definitions": [
      {
        "index": 1,
        "gloss": "beating someone up by ganging up on them",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうして、逃ぐる間もなしに引き摺り倒されて、袋叩きの仕置に遭ったのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも或るところでそれを見つけられて、店の者に袋叩きにして追い払われたことがあったので、その苦い経験から彼女は一種の味方を作ることを考え出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "チョッ、べら棒め、サーベルがなけりゃ袋叩きにしてやろうものを、威張るのもいいかげんにしておけえ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「袋叩きにしようという、あれですかい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出入って、博徒の仲間にはいったのか、女出入か、縄張りか」　それならまだしも浮浪者より気が利いていると思ったが、「闇屋の天婦羅屋イはいって食べたら、金が足らんちゅうて、袋叩きに会いましてん。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "無銭飲食をする気かと袋叩きに会い、這うようにして地下道へ帰り、痛さと空腹と蝨でまんじりともせず、夜が明けると一日中何も食わずにブラブラした。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のような美術家が袋叩きにされて半死半生になったという噂も聞いている。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、各種の「袋叩き」をはじめとする、「暴力行為」も列挙された。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに一年三組でも、彼は何回か袋叩きにあっています。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その七八人がいきなりに小坂さんを土間へひき摺り下して、袋叩きにしてしまったのです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "くどくも申す通り、こっちも酔っておりますので、ひとを乞食あつかいにするとは怪しからねえと、喧嘩にいよ／＼花が咲いて、とう／＼その喜路太夫を袋叩きにしてしまいました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "八人の者は勿論なんにも知らないで、たゞの芸人だと思って喜路太夫を袋叩きにして、それがほんとうに死んだと判り、しかもそれが旗本の殿様とわかって、みんなも一時は途方にくれてしまったのですが、誰か悪い奴が意地をつけて、相手の弱味につけ込んで、逆ねじにこんな狂言をかいたのだと云うことです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし悪いことをして、次の宿の問屋場にその次第を届け出られゝば、すぐに取押えて牢に入れられるか、あるいは袋叩きにされて所払いを食うか、いずれにしても手ひどい祟をうけることになっているのですから、問屋場にいるものは先ず安心して雇えるわけです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐず／＼していると袋叩きにして自身番へ引渡すぞ。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は遂に勘太郎をねぢ倒して袋叩きにする。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥坊にしろ、博奕打ちにしろ、相手が大勢で袋叩きにでもされるか、あるい後日の難儀を恐れて、その口をふさぐために息の根を止められるようなことが無いとも限らない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "御近所へ対して申し訳がねえ」　かれは親方や兄弟子に袋叩きにされて、それから自身番へ引き摺って行ってさんざん謝らせられたが、権太郎は素直に白状しなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶応三年十二月十三日、歩兵隊が吉原で喧嘩をはじめて、廓内の者や弥次馬に取り囲まれ、十幾人が半死半生の袋叩きに逢いました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ちに弥次馬が大勢あつまって来て、三人の異人を袋叩きにするという騒ぎになりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは共産派の指令が来ると袋叩きにして河へ投げた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつかの朝、顔を瘤だらけにして帰って来たでしょう、あの時吉原で、袋叩きに逢ったんですって……言ってくれるなと言ったから言いませんでしたがね。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて多勢で罵りながら、床に倒れた安重根を袋叩きにする。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえ何より奇態なことに、これはひとりロシアだけにしか見られない現象であろうが、暫くして、自分を袋叩きにした仲間と落ち合うと、まるで何事もなかったような顔で応対して、謂わば、こちらも先方も何らの蟠まりを持っていないのである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "護憲運動のあった時などは善良なる東京市民のために袋叩きにされているのですよ。",
              "citation": {
                "source": "或恋愛小説",
                "author": "――或は「恋愛は至上なり」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "多勢が寄って聚って、むりに女の髻を放させたが、それに逆ったというので、とうとう万年屋を袋叩きにしてしまった。",
              "citation": {
                "source": "世間師",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこれを云うと、人から袋叩きにされるんだが、――君、僕は外国から帰ってから評判がひどく悪くなってね、手も足も出ないのさ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "チンピラ隊の子どもたちが、これをきいたら、きみをふくろだたきにして、半殺しにしてしまうよ。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
