    "definitions": [
      {
        "index": 1,
        "gloss": "to seal (letter)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――だが、浮気の道を封ずることは男の特権だからな。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵の主人は抱えの読書を嫌い、厳しく封ずるのが普通で、東京でも今におき映画すら断然禁じている家も、少なくなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "建文帝の国を遜らざるを得ざるに至れる最初の因は、太祖の諸子を封ずること過当にして、地を与うること広く、権を附すること多きに基づく。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "太祖が諸子を封ずることの過ぎたるは、夙に之を論じて、然る可からずとなせる者あり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し之を會津に封ずるに當つて、忽として百萬石を與へたのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるほどに、山又山、上れば峰は益累り、頂は愈々聳えて、見渡せば、見渡せば、此處ばかり日の本を、雪が封ずる光景かな。",
              "citation": {
                "source": "雪の翼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて婦人が無体にも予が寝し衾をかゝげつゝ、衝と身を入るゝに絶叫して、護謨球の如く飛上り、室の外に転出でて畢生の力を籠め、艶魔を封ずるかの如く、襖を圧へて立ちけるまでは、自分なせし業とは思はず、祈念を凝せる神仏がしかなさしめしを信ずるなり。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまつさえ、水底に主が棲む……その逸するのを封ずるために、雲に結えて鉄の網を張り詰めたように、百千の細な影が、漣立って、ふらふらと数知れず、薄黒く池の中に浮いたのは、亀の池の名に負える、水に充満た亀なのであった。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほぼその幼馴染とでもいッつべき様子を知って、他人には、堅く口を封ずるだけ、お夏のために、天に代りて、大いに述懐せんとして、続けてなお説おうとするのを、お夏は軽く手真似で留めた。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "といってからに俺しには商人のような嘘はできないのだから、無理押しにでも矢部の得手を封ずるほかはないではないか」　彼はそんな手にはかかるものかと思った。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのたびごとに大風雨あり一郷ひどく難渋するので、ついには村方からの掛合いとなり、なんとかしてその老婆のこないように封ずるようにとの厳談であった。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "天を封ずる老幹の亭々と行儀よく並ぶ隙間に、的※と近江の湖が光った。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを説明して死は万障を封ずるが故に偉大だと云うものがある。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が異国に執着するのはそこへ自分を封ずるためであり、ていよく日本から追ひだすためだと考へる。",
              "citation": {
                "source": "我鬼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "福島正則の如きまで禁を承知で家康と婚を結ばうとする、いはんや黒田如水などはわざわざ九州から出ばつてきて家康を護衛する、名目は三成の天下の野望を封ずるためとあるのだが、それはうはべだけのことで内実は家康の天下を見越してすこしも先に忠勤を見せようといふさもしい心掛けだ。",
              "citation": {
                "source": "家康",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の一人でも圧迫して、研究を封ずるような事をしては、日本の植物学にとって損失であるから、私に教室の本や標品を見せんという事は撤回してくれ。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の理由のない圧迫が、浪人の口を封ずるからである。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう物しい掛け声は、当分封ずることにしよう。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ鳥を籠中に封ずるのみならず、またその羽翼を殺ぐものなり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "叫ばうとすれば、口を封ずるものがある。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この投球は、五間六間の先までもきく上、巧妙極まるピツチングで、必ず相手の面上を襲ひ、暫くは全く武力を封ずるので、どんな捕物の名人でも手の出しやうはありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鼬小僧の正体",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、これだけでも寺本金之丞の毒舌を封ずるには充分でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "歎きの幽澤",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田、園山兩家は、七日經たないうちに取潰される――どうだ御兩人」「――」　平次の言葉は、石澤左仲の癇癪を封ずるに充分でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "迷子札",
                "note": "青空文庫"
              }
            },
            {
              "text": "お喜多と別れ話をしたのは、その下心だよ」「なアるほど――」「植幸はお喜多の幽霊姿を捕えて、綾吉の悪企みを封ずる積りだったが、急に気が変って、一と思いに綾吉を殺したのさ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "綾吉殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田、園山両家は、七日経たないうちに取潰される――どうだ御両人」「…………」　平次の言葉は、石沢左仲の癇癪を封ずるに充分でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "迷子札",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯五郎が俺のところへ手紙を出したと氣が付いて急に仲間の船頭の金助を語らつて殺したが、金助の口から、ばれさうに思へたので、それを封ずるつもりで油斷を見すまして金助も殺したのだらう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "僞八五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "福島正則の如きまで禁を承知で家康と婚を結ぼうとする、いわんや黒田如水などはわざわざ九州から出ばってきて家康を護衛する、名目は三成の天下の野望を封ずるためとあるのだが、それはうわべだけのことで内実は家康の天下を見越してすこしも先に忠勤を見せようというさもしい心掛けだ。",
              "citation": {
                "source": "家康",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は與三郎が殺されたとは言つたが、まだ何處で殺されたとも言つてない筈だ――藥研堀といふ場所をどうして知つた」　平次の聲は、間髮を容れずに、お六の饒舌を封ずるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "眞珠太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手紙を封ずるものが何もないので、彼はただ紙を四つに折って、上に次のあて名を書きつけた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
