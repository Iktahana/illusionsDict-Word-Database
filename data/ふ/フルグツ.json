        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "泥濘のひどい道に古靴を引きずって役所から帰ると、濡れた服もシャツも脱ぎ捨てて汗をふき、四畳半の中敷に腰をかけて、森の葉末、庭の苔の底までもとしみ入る雨の音を聞くのが先ず嬉しい。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の中には、約二十挺の鉄砲と、箱に這入った拳銃が古靴を積重ねた傍に置いてある。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "背景となるべき一つの森や沼の選択に時には多くの日子と旅費を要するであろうし、一足の古靴の選定にはじじむさい乞食の群れを気長く物色することも必要になるであろう。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃古靴を売る事は……長靴は烟突のごとく、すぽんと突立ち、半靴は叱られた体に畏って、ごちゃごちゃと浮世の波に魚の漾う風情がある。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "古靴屋の手に靴は穿かぬが、外套を売る女の、釦きらきらと羅紗の筒袖。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御丁寧に古靴なんか持ち出しやがって！",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、村の沼にしずんでいる、古靴みたいに、海の底にしずんでしまいました。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな魚や、古靴や、油や、蛾を。",
              "citation": {
                "source": "白紙",
                "author": "立原道造",
                "note": "青空文庫"
              }
            },
            {
              "text": "裾をからげて砲兵の古靴をはいている様子は小作人というよりも雑穀屋の鞘取りだった。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして身には赤い襯衣を着て、青い腰巻の下から出た毛だらけの素足に半長の古靴を穿いていたが、赤い顔に白髪髯を茫々と生やして酒嗅い呼吸を吐きながら、とろんこ眼で姫の顔を呆れたように見つめていた。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ南風よ、南風よ、「時」が編みあげたこの古靴を、ぎざぎざにしておくれ、冬だ、ああ厭な冬が來た。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄がわざわざ、母の古靴で蠅叩きを拵らへましたのですけれど、やつぱり、まだとても大変ですわ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "口を開けた古靴の群れの中に転げたマンゴ、光った石炭、潰れた卵、膨れた魚の気胞の中を、纏足の婦人がうろうろと廻っていた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "河岸の地べたに敷かれた古靴の店の傍で、売られる赤児が暗い靴の底を覗いていた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖い南の日が流れる隠居所の縁側に、大きな八丈の座布団を出し、洗濯した古靴下を解くのが彼女の日課である。",
              "citation": {
                "source": "光のない朝",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『出た』　忽ち全山の高等野次馬は、我おくれじと馳付けて見ると、博士は笑ひながら、古靴の片足を、洋杖の先に懸けて示された。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "お穴樣の探檢",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小男は頭をクルクル坊主の五分刈にして、黒い八の字｜髭をピンと生やして、白い詰襟の上衣に黒ズボン、古靴で作ったスリッパという見慣れない扮装をしていた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに後から寄り集まった大勢の野次馬が加わって、油売り半分の面白半分といった調子で、ワイワイ騒ぎ立てたので、狭い坑道の中が芋を洗うようにゴッタ返したが、その中に、浮上った炭車の車輪の下から、思いがけない安全燈の光りと一緒に、古靴を穿いた福太郎の片足が発見されたのでイヨイヨ大騒ぎになったものだという。",
              "citation": {
                "source": "斜坑",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "コイツを遣ろう」　と云ううちに最早、古山高と古マントと古靴を次から次に窓から出してくれたので、流石の吾輩も少々｜煙に巻かれた。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、そのうちにジッと考え込んでいたウルフは、何と思ったか両手に提げていた古靴下を麻雀台の上に投げ出した。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の場末にもかう云ふ古道具屋が古靴や空瓶や古金類を並べてゐるが、こんなに同じやうな店が街区を成してゐるのは支那以外に見られない光景であらう。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "その話に、倉庫がゝりの人は感心して、古靴を一そく持つて来てくれました。",
              "citation": {
                "source": "太一の靴は世界一",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　倉庫がゝりの人が、太一のうはさをしたとみえて、それから、ぽつぽつと古靴を持つて来る人がありました。",
              "citation": {
                "source": "太一の靴は世界一",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "きたない古靴を持つて来る職工もありました。",
              "citation": {
                "source": "太一の靴は世界一",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、つぶやきながら、古靴の底をたゝきつゞけました。",
              "citation": {
                "source": "太一の靴は世界一",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、職工が二十人ばかり連立つて、古靴を持ちこんで来ました。",
              "citation": {
                "source": "太一の靴は世界一",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "前からたのまれてゐる古靴のそばに、それらの古靴をつみかさねて、太一は、ためいきをつきました。",
              "citation": {
                "source": "太一の靴は世界一",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、あづかつてゐる古靴をどうしたらよいでせう。",
              "citation": {
                "source": "太一の靴は世界一",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで、太一は、また、ためいきをついて、あづかつてゐる古靴のしまつに、困つてゐることを話しました。",
              "citation": {
                "source": "太一の靴は世界一",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
