    "definitions": [
      {
        "index": 1,
        "gloss": "lack of uniformity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
