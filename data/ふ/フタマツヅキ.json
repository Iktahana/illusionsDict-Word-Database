        "index": 1,
        "gloss": "two adjoining rooms (connected by a sliding door)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
