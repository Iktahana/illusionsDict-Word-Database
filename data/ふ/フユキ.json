[
  {
    "uuid": "acd91cfa-3128-5547-9606-521c9e916144",
    "entry": "冬木",
    "reading": {
      "primary": "ふゆき",
      "alternatives": [
        "ふゆぎ"
      ],
      "is_heteronym": false
    },
    "grammar": {
