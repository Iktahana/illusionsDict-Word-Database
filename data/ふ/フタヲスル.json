[
  {
    "uuid": "74c01471-03b0-5058-973b-e91e0b94e0ec",
    "entry": "蓋をする",
    "reading": {
      "primary": "ふたをする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-サ変-する"
      ],
