    "definitions": [
      {
        "index": 1,
        "gloss": "French bread (esp. baguette)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
