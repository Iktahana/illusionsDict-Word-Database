        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "勝坊の頭を撫で乍ら商人に向って、Ｔ「自分で落しときァがって巫山戯るねえ！",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも真面目な勤勉な市民が羽目をはずして怠け巫山戯る日であった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑な線で、発車するまでの間を、車掌がその辺の子供と巫山戯ていたり、ポールの向きを変えるのに子供達が引張らせてもらったりなどしている。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪巫山戯に威したらしい。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな心懸じゃあ盲目の夫の前で、情郎と巫山戯かねはしないだろう。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は影絵、うつし絵などでは、巫山戯たその光景を見せたそうで。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから畚に入れてある、あのしめじ蕈が釣った、沙魚をぶちまけて、散々悪巫山戯をした挙句が、橋の詰の浮世床のおじさんに掴まって、額の毛を真四角に鋏まれた、それで堪忍をして追放したんだそうだのに、夜が明けて見ると、また平時の処に棒杭にちゃんと結えてあッた。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑さの取着の晩方頃で、いつものように遊びに行って、人が天窓を撫でてやったものを、業畜、悪巫山戯をして、キッキッと歯を剥いて、引掻きそうな剣幕をするから、吃驚して飛退こうとすると、前足でつかまえた、放さないから力を入れて引張り合った奮みであった。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八蔵は本音を吐き、「おい、可加減に巫山戯ておけ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小間使は腹を立て、「誰だい、ひと、愉快くもない、お巫山戯でないよ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "待て待て狂人の真似何でもない事、嘉吉も一升飲まされた――巫山戯た奴等、どこだと思う。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい年をして娑婆気な、酒も飲めば巫山戯もするが、世の中は道中同然。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、その顔色に似合わない、気さくに巫山戯た江戸児でね。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに巫山戯た真似をする野郎だ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこまでだからいっしょに召していらっしゃい」「お巫山戯でないよ」　欣弥はすでに車上にありて、「車夫、どうだろう。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝原に二匹の犬が巫山戯ている。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何方の云うことが真実か知らぬが、先刻市郎の話では、忠一が女と巫山戯たと云う。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お酒を飲むと、無闇に悪巫山戯をして……。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれが起きているのを承知で巫山戯て見せた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰か友だちを呼んで見せて、人面疽が出来たと巫山戯てやろう」鼈四郎が辞んでも彼は訊入れなかった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、雛妓のその止め方には、その巫山戯方の中に何か本気なものをわたくしは感じた。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "数枝に、無理矢理、劇場から引つぱり出され、さうして数枝の悪意ない、ちよつとした巫山戯た思ひつきが、高須をここへ連れこんだ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……巫山戯た爺が、驚かしやがって、頭をコンとお見舞申そうと思ったりゃ、もう、すっこ抜けて、坂の中途の樫の木の下に雨宿りと澄ましてけつかる。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまじやあもう半年も経つたらう、暑さの取着の晩方頃で、いつものやうに遊びに行つて、人が天窓を撫でゝやつたものを、業畜、悪巫山戯をして、キツ／＼と歯を剥いて、引掻きさうな権幕をするから、吃驚して飛退かうとすると、前足でつかまへた、放さないから力を入れて引張り合つた奮みであつた。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいつもながら少し揶揄い気味に、「転んでも、たゞでは起きない相手の胸倉って何よ」　と恍けて訊いてやりますと、母は今度は両袖の口を指先で掴んで背中が痒いように左右に引いて、上体をやけのように身揺ぎ一つさせると同時に、「お巫山戯でないよ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田島は勿論、こんな女が自分の傍に居るのを知ってもイベットが何とも思わないことを知って居た、それよりもイベットの子供らしいとはいえ態と自分にからかって他の男に巫山戯る様子にいくらかの嫉妬を感じた。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　イフェミヤはその乱れた前額の毛をわざと巫山戯てその手で掻き散らした。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうでもないか、此奴、解剖学の標本室で見た死刑囚の白い面型その儘だ、さうだあの面型には眉の毛が二三本赤つちやけてくつついて居たつけな――ここまで揶揄つて来て俺ははつと思つた、能い加減に巫山戯け散らしてゐた霊魂がピタと緊張まる。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この畜生……、……巫山戯たことをしやがる……」　新一は母のするままに任していた。",
              "citation": {
                "source": "狐の手帳",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に邪魔になる程に、大声で笑つたわけでもなかつたし、それにしてもだ、先生がカン／＼になつてたことは事実だし、先生自身何をそんなに怒るのか知つてゐぬらしいことも事実だし、俺としたつて意地やふざけで笑つたわけではなかつたのだ。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
