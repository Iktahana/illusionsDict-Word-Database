        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "詩の頷聯に、「病脚不趨官路険、微量難敵酒軍長」と云つて、「此日不応雪堂招飲、故第四及之」と題下に自註してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "公事セス　　合御公事足八人此外ニ五ヶ所者共致訴訟、不応御下知。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "したたる空色の窓の下で、私の愛する女と共に純銀のふおうくを動かしたい。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふおうふおう、ふうふう、ふおうふおうというように鳴くの声の後から、また獣の鳴くような声も聞えてきた。",
              "citation": {
                "source": "太虚司法伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
