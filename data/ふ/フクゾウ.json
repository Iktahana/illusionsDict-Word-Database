[
  {
    "uuid": "01dadcf8-d02f-5532-a3da-8acbd97119e5",
    "entry": "腹蔵",
    "reading": {
      "primary": "ふくぞう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "concealing one's thoughts",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蒲に着くと子路はまず土地の有力者、反抗分子等を呼び、これと腹蔵なく語り合った。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "袖口がひどく脹れていることや、いやに何の腹蔵もなさそうな様子をしていることで、すぐ怪しいと気づかれるはずなのだ。",
              "citation": {
                "source": "群集の人",
                "author": "THE MAN OF THE CROWD",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と腹蔵の無い高笑。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　腹蔵なく大笑をするので、桂木は気を取直して、密と先づ其の袂の端に手を触れた。",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹蔵なくいえば文芸協会の芝居がそれほど立派なものだとは思わぬ。",
              "citation": {
                "source": "明治の文学の開拓者",
                "author": "――坪内逍遥――",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく御腹蔵なくお話下すった。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は何事も腹蔵なく打ち明け呉れと頼んで置いて、爾して何故に秀子へ恐ろしい嫌疑が掛かったかと詳しく聞いたが、成るほど仔細を聞けば尤もな所も有る。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何気無く聞き取りましたが愈々手術に取り掛かる約定を極める時と為って権田に向い、「腹蔵なく依頼者の身の上を聞いた上でなくては」と主張し「第一権田さん、依頼者の松谷秀子という姓名では了ません。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹蔵のない話が、こうして景気を付けてはいるものの、それはほんの酒の上、心の底は苦しいので、「先生、足の骨を折られて死んだものがごわしょうか」　と恍け顔に聞いて見る。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの御意見によってどうとも決めたいと思うのですから、ああしたいとか、そうしてもいいとか腹蔵なくおっしゃってください。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹蔵なく言わせて頂けば、私はあなたが具えておいでになる値打の、せめて何割かを身につけることが出来るなら、この身代の半分くらい、悦んで投げ出しますよ！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顔には常に真率で腹蔵のない、豪胆なところが現われている。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私の考えでは、この問題はよくよく研究し、審議する必要があると思いますねえ、ちょうどイギリスの議会でやるように、腹蔵なく互いに意見を開陳してですねえ、いいですか、あらゆる迂余曲折を明確に闡明するため、内輪にひとつ会議をする必要があると思うんですがねえ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "……で、それに就いて少々お訊ねしたい事がありますから何卒御腹蔵なく……」「は、はい。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると又……イヤ、金兵衛はこの頃、築地のどことかに妾を置いているという話だから何とも知れない、なぞ云う者が出て来てワイワイ云い合いながら別れた……という腹蔵のない連中の話なんだ。",
              "citation": {
                "source": "近眼芸妓と迷宮事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "切り株に腰をおろして、誰に遠慮もなく腹蔵なく語り合つた。",
              "citation": {
                "source": "幸徳秋水と僕",
                "author": "――反逆児の悩みを語る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生も亦多年の実験を腹蔵なく語つて下された。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し一たび起つた以上は仕方がない、どうにか処分をせんければならん、事実は既に諸君の御承知の通であるからして、善後策について腹蔵のない事を参考の為めに御述べ下さい」　おれは校長の言葉を聞いて成程校長だの狸だのと云ふものは、えらい事を云ふもんだと感心した。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしひとたび起った以上は仕方がない、どうにか処分をせんければならん、事実はすでに諸君のご承知の通りであるからして、善後策について腹蔵のない事を参考のためにお述べ下さい」　おれは校長の言葉を聞いて、なるほど校長だの狸だのと云うものは、えらい事を云うもんだと感心した。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "双方で腹蔵なくすべてを打ち明け合う事ができたという点において、いまだに僕の貧しい過去を飾っている。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "秦は腹蔵なく語り出したのである。",
              "citation": {
                "source": "秦の出発",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "所在なさに掴みあひの喧嘩はするし、女房子供の前でだけは世界で相当の人物のやうなことも言ふし、礼義節度といふものは影も形もとどめてゐなくて、腹蔵なく油断しあひ、いい気になつて人たるものの本分を忘れてゐる。",
              "citation": {
                "source": "総理大臣が貰つた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "常々平身低頭の下役に気を良くして腹蔵なく威張つてゐると、宴会の夜更けにビールの壜で後頭部を粉砕され、それまでの人生となつてしまふ。",
              "citation": {
                "source": "総理大臣が貰つた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャラ／＼と裏口で御用聞きと歓談する女中の方が腹蔵ないかも知れない。",
              "citation": {
                "source": "無毛談",
                "author": "――横山泰三にさゝぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はともあれ外出するのが第一だから、全てを看護人なにがしに打開けて腹蔵なく相談するのが先決条件にきまつてゐる。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "膝つき合せれば何事でも腹蔵なく言ひ合へるやうな印象だつたが、婆さんの依頼の用で会ふ気はなかつた。",
              "citation": {
                "source": "二十一",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、近臣を集めて四方山話の果に、どうだな、俺の死後に天下をとる奴は誰だと思ふ、遠慮はいらぬ、腹蔵なく言ふがよい、と秀吉が言つた。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "利巧な奴らであるから然るべき魂胆あつての策略だと信長は見込んでゐたが、ある日、オルガンチノといふバテレンを別室に呼び入れ、侍臣全部遠ざけておいて、さて、お前も商売だから本当のことを打開けては障りがあらうが、然し、今日は家来一同遠ざけたから腹蔵なく語るがよい。",
              "citation": {
                "source": "鉄砲",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃ、わかっとるから……ハッキリいってくれても、それでどうこうという事はないから、安心して、ふくぞうなくいってくれたまえ。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
