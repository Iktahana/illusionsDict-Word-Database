    "definitions": [
      {
        "index": 1,
        "gloss": "blowing through",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小さな不連続線が東京へかかったと見えて、狂風が広小路を吹き通して紳士の帽を飛ばし淑女の裾を払う。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際両側に広い空地を控えたこの垣根では嵐が吹き通したり、雨に洗われたり、人の接近する事が頻繁であったりするので蜂にとってはあまり都合のいい場所ではない。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "剥げた八寸膳の上に薄汚ない茶碗が七ツ八ツ……それでも夏は海から吹き通しだし、冬の日向きがよかったので、街道通いの行商人なぞがスッカリ狃染になっていた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやに熱苦しい南風が一日吹き通して、あまり心持ちのよい日ではなかったけれど、数日来雨は降る水は増すという、たまらぬ不快な籠居をやってきたのだから、今日はただもうぬれた着物を脱いだような気分であった。",
              "citation": {
                "source": "水籠",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その木枯が今朝までも吹き通してゐたのである。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝からと林からと入り乱れた微風が室内を吹き通した。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは山を踰え谿に沿いあるいは吹き通しの涼しき酒亭に御馳走を食べたなどと書いてあるのを見ると、いくらか自分も暑さを忘れると同時にまたその羨ましさはいうまでもない。",
              "citation": {
                "source": "徒歩旅行を読む",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "――風、風、風だつた、日中吹き通して、夜中も吹きつゞけた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の小さい窓から一日、海の風が吹き通しには入つて参ります。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼しい風が吹き通して納戸の蚊帳の裾を煽つた。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御住居は、夏の風が青く吹き通していることと思います。",
              "citation": {
                "source": "平塚明子（らいてう）",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月二十七日（月曜）　一日南風が吹き通した。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまった煙管を真っ赤になって吹き通していた親方は、吻っとひと息いれて、「可哀相なのはお高さんだなあ。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日吹き通した南風が舟を捨てる間際、沛然たる驟雨になつた。",
              "citation": {
                "source": "南予枇杷行",
                "author": "河東碧梧桐",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝から吹き通した寒い北風はぱつたり止んで室の中も外も靜かになつた。",
              "citation": {
                "source": "自分は見た",
                "author": "千家元麿",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十五日（月曜）秋らしく、涼しい風が吹き通した。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "中塗もせぬ荒壁は恣に崩れ落ち、床の下は吹き通し、唐紙障子も足らぬがちの家の内は、火鉢の火位で寒さは防げなかった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之其処は破れ壁から北風が吹き通し、屋根が低い割に炉が高くて、熾な焚火は火事を覚悟しなければならなかった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、大いにやってもらって、教育上、ないし児童の保健上、現在のような雨漏り吹き通しの校舎はよろしくない――立派な鉄筋コンクリート二階建の校舎を近村に誇ろうではないかというようなのが、村当局一般の意向でさえあるらしかった。",
              "citation": {
                "source": "瘤",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "座敷なら欄間と云うような所が幅一尺ほど切り抜かれて夏冬吹き通しに引窓の代理を勤めている。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹き払い、吹き通し、抜け裏、通行御免天下晴れての空地である。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹き通しも夏はせいせいして心持ちがいいものだ、不用心だって金のないところに盗難のあるはずはない。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "乏しい榾火がちらついているばかりで、寒い風が吹き通しの部屋でございました。",
              "citation": {
                "source": "あじゃり",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は澄んだ秋日和で終日南風が吹き通した。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は一日寒い北風が吹き通した。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一二、四）　終日寒い西風が吹き通した。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二五八八、一二、二八）　北の強い寒風が吹き通した。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい風が終夜吹き通した。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑い時には空気が頸のまわりを吹き通して誠に気持がいい。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "三階の河添ひの室、風が吹き通して涼しい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
