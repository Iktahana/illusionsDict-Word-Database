    "definitions": [
      {
        "index": 1,
        "gloss": "frock coat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『わたし、フロックコート着る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの趣味はすべてにおいて庶民的で、儀式ばったことが嫌いなので、フロックコートなどの礼服を非常に嫌い、常に野蛮人の服と称し『なんぼ野蛮の物』と言っていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれではあまり体面に関するので、夫人が是非フロックコートを新調するようにすすめたが、頑として中々きかない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上に参るの時、あなた、シルクハット、フロックコートですよ』などと、子供をだますようにして説き伏せられ、やっと礼服を新調したけれども、やはり少しも着ようとしない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈が高く顔の小さい、額がノツシリしてフロックコートのよく似合ふ、前校長の容姿が何時か彼の心を離れないものとなつてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからあのいつもの漆喰細工の大玄関をはいってそこにフロックコートに襟章でも付けた文部省の人々の顔に逢着するとまた一種の官庁気分といったようなものも呼び出される。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "釦の多いフロックコートを着たようである。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが済むと怪しげな名前の印度人が不作法なフロックコートを着て出て来た。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつのまにか獅子が立派な黒いフロックコートを着て、肩を張って立って「もうよからうな。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正何年であったか正月の三日に、国原がフロックコートで初出社をすると、左手の甲に仰山らしく繃帯をしている。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそばへ一人の夏フロックコートを着た男が行って何か耳うちしました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は三越でこさえた白い麻のフロックコートを着ましたが、これは勿論、私の好みで作法ではありません。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　向うの葵の花壇から悪魔が小さな蛙にばけて、ベートーベンの着たような青いフロックコートを羽織りそれに新月よりもけだかいばら娘に仕立てた自分の弟子の手を引いて、大変あわてた風をしてやって来たのです。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これのみならず玄関より外科室、外科室より二階なる病室に通うあいだの長き廊下には、フロックコート着たる紳士、制服着けたる武官、あるいは羽織｜袴の扮装の人物、その他、貴婦人令嬢等いずれもただならず気高きが、あなたに行き違い、こなたに落ち合い、あるいは歩し、あるいは停し、往復あたかも織るがごとし。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日の朝になると、まだ暗いうちに一帳羅のフロックコートを着て、金鎖を胸高にかけて、玄関口に寄せかけた新調の自転車をながめながら、ニコニコ然と朝飯の膳に坐ったが、奥さんの心づくしの鯛の潮煮を美味そうに突ついているうちに、フト、二三度眼を白黒さした。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "山高でフロックコートで、お従者を連れてすうと素通りで、や、ＳＳ、気の毒した、御苦労とも抜かすこつじゃねえ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は書籍商らしい見すぼらしいフロックコートを着ていたが、その他、真白な頭髪と云い、また机の上に置いた古書籍と云いたしかに書籍商を思わしめるものであった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は君と大に談じてみたい問題もあるんだが、――」　ホームズは見すぼらしいフロックコートを脱ぎ捨てて、半身像から例の鼠色の寛服を取って着たので、依然たるシャーロック・ホームズに返った。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の服装は穏やかな厳かなもので、黒いフロックコートに暗い色の縞ズボン、それらに調和したネクタイをむすんでいた。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "色の褪せた黒いフロックコートは前の釦がみな留められ、襟も立っている。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いトップ・ハットに長いフロックコート、長いゲートルという格好で、手で狩猟鞭を振り回している。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "身長五フィート七インチ、体格よし、顔色悪し、黒髪、頭頂に小禿あり、たわわな黒い頬髯口髭、色眼鏡、話し方はやや訥々、失踪時の服装は黒のフロックコート、黒のベスト、金のアルバート鎖、下はハリスツイードの鼠色、ゴム布の長靴に茶褐色のゲートルを重ねる。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうひとりはきびきびした小柄の人物で、身なりは小ぎれいなフロックコートとゲートル、短く整えられた頬髭に加えて片眼鏡があった。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ややだぶついた灰色の弁慶格子のズボン、くたびれた感じの黒いフロックコートを着て、コートの前ボタンを外していた。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜はそのままフロックコートの丸寝をやった。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の結婚を纏めた殊勲者である木下が新調のフロックコートを着ながら、ニコニコと入って来た。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士は、大抵フロックコートか、五つ紋の紋付であったが、婦人達は今日を晴と銘々きらびやかな盛装を競っていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚の時に、近藤夫人は譲吉の為に、フロックコートを新調して呉れたし、その外にも譲吉は、四五着の背広やモーニングを持つようになった。",
              "citation": {
                "source": "大島が出来る話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところへ広田先生がフロックコートで天長節の式から帰ってきた、三人は挨拶をする時に画帖を伏せてしまった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
