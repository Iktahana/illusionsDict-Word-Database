        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "○竹屋の渡場は牛の御前祠の下流一町ばかりのところより今戸に渡る渡場にして、吾妻橋より上流の渡船場中最もよく人の知れるところなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊女の句に名高き○駒形の駒形堂を右に見、駒形の渡船場を過ぎ、左には長屋｜越に番場の多田の薬師の樹立を望みて下ること少許すれば○厩橋に至る。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○百本杭は渡船場の下にて、本所側の岸の川中に張り出でたるところの懐をいふ。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡船場の下数町にして○新大橋あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙台堀入口より中洲へ渡るの○中洲の渡船場あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡船場の下一町余にして復小渠の東南に入るあり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡船場より下、町余にして二水の北西より来るを見る。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "船松町佃島の間には渡船場あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひのきの垣根の横を行き麻ばたけの間を通り桑の畑のへりを通りそして船場までやって来ました。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に久慈川のとある渡船場付近では、見上ぐる前方の絶壁の上から、巨巌大石の夥しく河岸に墜落しているのを見る。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この渡船場で滑稽な事があった。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずつと見通しの、油堀から入堀の水に、横に渡した小橋で、それと丁字形に、眞向うへ、雨を柳の絲状に受けて、縱に弓形に反つたのは、即ち、もとの渡船場に替へた、八幡宮、不動堂へ參る橋であつた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあ、あの渡船場に迷つたのだから、よくは分らないが、彼の邊だらうね。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永喜橋――町内持ちの、いましがたの小橋と、渡船場に架けた橋と、丁字形になる處に、しばらくして私たちは又たゝずんで、冬木の池の方を振返つたが、こちらからは、よくは見通せない。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上町に育つた私たちは船場、島ノ内、千日前界隈へ行くことを「下へ行く」といつてゐたけれども、しかし俗にいふ下町に対する意味での上町ではなかつた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪｜船場目ぬきの場所にある旧舗の主人で鼈四郎の父へ深く帰依していた信徒があった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」「ええ、丸田官蔵、船場の大金持です。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕らが子供の頃、黒い顔の初代春団治が盛んにややこしい話をして船場のいとはんたちを笑わせ困らせていた「花月」は、今は同じ黒い顔のエンタツで年中客止めだ。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これはその家だけの習慣ではなく、あとであちこち奉公してみて判ったのだが、これは船場一体のしきたりだったようです。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "横堀｜筋違橋ほとりの餅屋の二階を月三円で借り、そこを発行所として船場新聞というあやしい新聞をだしたのは、それから一年後のことであった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま引いた文章にも書いてある通り、おれとお前の関係はこの船場新聞にはじまって以後いわば蔭になり日向になり、おれはお前を助けて来たのだ。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお「蘆のめばえ咲分娘」と題して、船場娘の美人投票を募集するなど、変なことを考えついたのも、おれだった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、もともとこの船場新聞ではお前もたいして得るところはなかった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、さすがにおれは、おれのおかげで……と言っても、そんなに言い過ぎではあるまい――お千鶴をわがものにして、船場新聞の社長で収まり込んでいるお前を見ると、こいつ、良い気になりやがって、いっぺん失脚させてやったら、どんな顔をするだろうか、とひそかに思わぬこともなかったのだ……。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　船場新聞を廃刊してしまうと、お前はすっかり文無しで、たちまち暮しに困った。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "新何とかいうのに書いたはりましたンは、あ、そうそう、船場の何とかいう題だしたな」　お内儀さんは小説好きで、昔私の書いたものが雑誌にのると、いつもその話をしたので、ほかの客の手前赤面させられたものだったが、しかし、今そんな以前の癖を見るのもなつかしく、元の「波屋」へ来ているという気持に甘くしびれた。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄道開通以来、土地の人が頑固で、折角の停車場の設置を肯ぜなかったばかりに、木曾下流の渡船場として殷賑であったこの笠松街道もさっぱり寂れてしまったということであった。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "折ふし向岸の諏訪下の渡船場より早船にて、漕ぎ渡し来る数十人の捕吏の面々を血刀にてさし招きつゝ、悠々として大文字山に登り隠れ、彼の大判小判の包みと、香煙の器具一式とを取出して身に着け、鞘を失ひし脇差を棄てゝ身軽となり、兼ねてより案内を探り置きし岨道伝ひに落ち行く。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "船場か島ノ内のいたずら娘であろうか。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "四山環翠、一水澄碧の湖上に輕艇を駛らすれば、凉風｜面を撲つて、白波ふなばたに碎くるさま、もとより爽快の好い心持である。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
