        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "老衰して黒っぽくなりその上に煤煙によごれた古葉のかたまり合った樹冠の中から、浅緑色の新生の灯が点々としてともっているのである。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は猿蓑の　　　たゝらの雲のまだ赤き空　　　　　去来　　　一構｜鞦つくる窗のはな　　　　　　凡兆　　　枇杷の古葉に木芽もえたつ　　　　史邦を引いて此不調和を取りつくろつて下すつた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に春落葉する前に、暗示の古葉を着け、これに新芽の淡緑と壮葉の藍鼠とが交るのが、色取が好い。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "松が古葉を黄色い茱萸の花の上へ落している。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙は愈益鳴き矜つて樫の木のやうな大きな常緑木の古葉をも一｜時にからりと落させねば止まないとする。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "椎の木の古葉もすっかり散り尽くして、松も新しい緑にかわって、草も木も青い焔のようになった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬味のネギの中に古葉と新葉とあるのが、百姓だけにすぐ気が付いた。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "古葉が凋落して、新しい葉がすぐ其後から出るということは何となく侘しいような気がするものである。",
              "citation": {
                "source": "新茶のかおり",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "檜、樅は古葉の上に、唯新しい色を着けるばかりだ。",
              "citation": {
                "source": "新茶のかおり",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "埃だらけの硯、齒磨の袋、楊枝、皺くちやになつた古葉書が一枚に、二三枚しかない封筒の束、鐵筆に紫のインキ瓶、フケ取さへも載つて居る机の上には、中判の洋罫紙を赤いリボンで厚く綴ぢた、一册の帳面がある。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "埃だらけの硯、歯磨の袋、楊枝、皺くちやになつた古葉書が一枚に、二三枚しかない封筒の束、鉄筆に紫のインキ瓶、フケ取さへも載つて居る机の上には、中判の洋罫紙を紅いリボンで厚く綴ぢた、一冊の帳面がある。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればこの句意は神無月の頃は到る処に木の葉落ち重なりて下駄草履にも音あるほどなるに、独りこの禅寺は松の古葉の少しこぼれたるばかりなるぞ清らかに淋しく禅寺の本意なるべきと口ずさみたる者ならん。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "この老母に言はせると、おそらく深山のやうな老舖で賣る茶は多年の經驗から、古葉に新葉をとりまぜ、いろ／＼な地方で産するものを鹽梅し、それに茶の中の茶ともいふべき『おひした』（味素）を加味して、それらの適當な調合から香もあり味もある自園の特色を造り出してゐるのであらうとの話もあつた。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "新葉の愛はもとより、古葉をおろそかにしないといふことが好い風味を見つける道であらう。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "動き、進み、古葉をどんどんおとして更新しつつある歴史の足どりのなかに、それに相応ずる発現として「いのちの力」を把握する能力をもたなかった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この常緑樹は、他の落葉樹と異って、晩春初夏の頃、盛んに古葉を散らし、余剰の花を降らせる。",
              "citation": {
                "source": "「自然」",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一群れが飛びたつ羽風に、椎の古葉がいくつも散って、はらはらとまい落ちました。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こがね虫のかわりに、椎の古葉が一枚、ひらひらとまい落ちてきました。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その古葉が落ちたあたりに、ほかの落葉の上に、三毛猫はもうまるくなって眠っていました。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭のすみにある椎の木の古葉が、一つ二つ散っていました。",
              "citation": {
                "source": "風ばか",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れの岸や隅の処に根を張つてゐるスゲの枯れた古葉の傍からは、新しい芽の角が逞しく出てゐるしその根株にかくれたり、そこから走つて泳ぎ出したりする小さいタナゴやハヤの子がすつかり活溌になつてゐる。",
              "citation": {
                "source": "かたくり",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "御飯の後、二時два　часа　после　хлеба　и　соли〔パンと塩を食べたあとの二時間〕　○雪がとけ始めると、今までちっとも気のつかなかった樹の小さい枯枝や、古葉が雪の上で目についた。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉木は若葉から漸次青葉になり、杉松樫などの常緑木が古葉を落し落して最後の衣更をする。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉木が悉皆若葉から青葉になった処で、樫、松、杉、樅、椎等の常緑樹や竹の類が、日に／＼古葉を落しては若々しい若葉をつけ出した。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此頃は毎日｜掃いても掃いても樫の古葉が落ちる。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "常緑木の中でも、松や杉は青々とした葉の下に黄ばんだ古葉を簇々と垂れて、自ら新にす可く一吹の風を待って居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半蔵はその辺に立てかけてある竹箒を執って、古い墓石の並んだ前を掃こうとしたが、わずかに落ち散っている赤ちゃけた杉の古葉を取り捨てるぐらいで用は足りた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しの風もないのに扇骨木の生垣からは赤くなつた去年の古葉が雨の雫と共に頻と落ちる。",
              "citation": {
                "source": "花より雨に",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕山風が古葉をふるわして樹々の間を掠めてくる。",
              "citation": {
                "source": "茸をたずねる",
                "author": "飯田蛇笏",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に語りたい心持がするのは、私が最近経過した内部的な大掃除みたいなもの、或は嵐のようなもののおかげで、すこし古葉が落ちて、ものがはっきり見えはじめた部分があって、そのおかげで、漠然納得ゆかない気持でうけていたものを、はっきり捕え分析し得るようになった。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
