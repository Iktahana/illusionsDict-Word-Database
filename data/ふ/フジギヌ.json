        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ミサ子が富士絹の風呂敷づつみを抱え、ソッとドアをあけて入って行くと、荒板を打ちつけて拵えたベンチにかたまって板をしわらせながらかけている連中の中から菅が、「ヤア……ちょうどいいところだ、早く来なさい。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母ちゃんは、戸棚の奥へ風呂敷包みをつみかえ、前の方だけあけ、そこへ水色の富士絹の風呂敷をひろげてアヤのお骨壺をのせた。",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてハンカチを自分の手にとって、僕の顔を拭ってやろうとしながら、「富士絹ね」と無心にぽつりと言った。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき赤ちゃんの着ている富士絹らしい白いベビー服が、ムクムクと膨れあがってきた。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士絹のブルウゼに薄羅紗のスカートをつけ……まじめな百貨店の売子のように、さっぱりと地味ないでたちだった。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかに富士絹の白い下着。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもブラウスとかナイトキャップとかワンピースとか富士絹とか、いやにくわしいと思っていたら、今年の夏は婦人同伴鹿島槍に登っている。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車をおりて、三四丁歩く間に、脇の下や背筋などが、ジクジクと汗ばんで、触って見ると富士絹のワイシャツが、ネットリと湿っていた。",
              "citation": {
                "source": "陰獣",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふじぎぬのやうな光と空気とに織られてゐた。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
