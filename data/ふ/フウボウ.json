[
  {
    "uuid": "debd0ace-3e44-5715-abcc-eb5bed0ada45",
    "entry": "風防",
    "reading": {
      "primary": "ふうぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
