        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ナチスの焚書に倣って、日比谷公園で過去の出版物を焚刑に処するそうだという噂まで製造された位いである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルイコフの名によるクラブの広間の壇上装飾は、聖書、十字架、僧冠などの赤い色電気により焚刑の光景だ。",
              "citation": {
                "source": "モスクワ印象記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、異端者や魔女を焚刑に処したときに使った種のものだ。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
