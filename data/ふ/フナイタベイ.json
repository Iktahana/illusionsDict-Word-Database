    "definitions": [
      {
        "index": 1,
        "gloss": "fence made from disused ship planks",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
