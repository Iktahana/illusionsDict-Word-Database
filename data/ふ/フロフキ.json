        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鰹のたたき、あいなめの煮物、船で作った絹｜漉しの冷奴、大根の風呂吹き。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "変りふろふき　これからはよくどちらでも大根ふろふきが流行ります。",
              "citation": {
                "source": "十八番料理集",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからふろふき大根。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生で食うときは大根おろしにし、烹て食うときはふろふきにした。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七八貫もあろうと思う、煮しめたふろふきのような水っぽい女。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二本の脇差",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
