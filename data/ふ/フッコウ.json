[
  {
    "uuid": "df63328d-4ea0-5e8d-9044-90351172f678",
    "entry": "復興",
    "reading": {
      "primary": "ふっこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
