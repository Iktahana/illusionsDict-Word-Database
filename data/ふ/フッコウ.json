    },
    "definitions": [
      {
        "index": 1,
        "gloss": "revival",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今は甲斐の自然が、人文の上に輝き始める回春期である、甲斐の文芸復興は、恐らくその洪大なる自然の上に打ち建てられるであろう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして滅亡するか復興するかはただその時の偶然の運命に任せるということにする外はないという棄て鉢の哲学も可能である。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近、流行界における横縞の復興が、横縞のうちに特に「いき」の性質を見させる傾向をもっているのは、主としてこの理由に基づいている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来哲学の一部分であった科学が、近世の始め文芸復興期以来に長足の進歩をなした所以もまた科学の対象が能知者から解放された事に起因すると云ってもよい。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし古来の科学者が、「試み」なしの臆断を続けたり、「試み」の結果を判断する合理的の標準なしに任意の結論を試みたり、あるいは「試み」に伴なう怪我のチャンスを恐れて、だれも手を下す事をあえてしなかったら、現在のわれわれの自然界に関する知識と利用収穫は依然として復興期以前の状態で足踏みをしていたであろう。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれら哲学者の植え付けた種子が長い中世の冬眠期の後に、急に復興して現代科学の若葉を出し始めたのは、もちろん一般的時代精神の発現の一つの相には相違ない。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし復興期の学者と古代ギリシアの学者との本質的な相違は、後者特にアテンの学派が「実験」を賤しい業として手を触れなかったのに反して、前者がそういう偏見を脱却して、ほんとうの意味のエキスペリメントを始めた点にあると思われる。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新宿辺も、こんどの戦火で、ずいぶん焼けたけれども、それこそ、ごたぶんにもれず最も早く復興したのは、飲み食いをする家であった。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると復興事業が始まって、いつのまにかもとのように立派な都市ができる。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおかげで帝都の復興が立派にできて、そうして七年後の今日における円タクの洪水、ジャズ、レビューのあらしが起こったのかもしれない。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日ごろからいだいていたこんな考えが昨今カメラをさげて復興帝都の裏河岸を歩いている間にさらにいくらかでも保証されるような気がするのである。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府は全国の扶持取りから百石につき二両ずつ上納させて救助復興の資金にあてた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村問題、漁村問題などを専門に研究していらっしゃる方々も随分沢山ありますし、また、実際地方の人々がその問題について実地に苦心、復興を計っておられますから、私などが何も申し上げることはありませんが、唯、私がフランスの田舎にいた時、見聞した農夫の生活ぶりを参考までにお伝えして置きたいと思います。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈の照明も文芸復興期の夢のままだ。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……見た處は千丈の峰から崩れかゝる雪雪頽の下で薪を樵るより危かしいのに――此の度胸でないと復興は覺束ない。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災後、多年中絶して居たのが、頃日區劃整理に及ばず、工事なしに復興した。",
              "citation": {
                "source": "九九九會小記",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に復興の第一囘の幹事は――お當めでたうござる――水上さんで。",
              "citation": {
                "source": "九九九會小記",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに、本当に附いたわけぢやあないが、まあ半分は泣寝入りの形で、みんなも虫を殺して往生することになつて、去年の九月に復興局の人たちが来て、竿を入れたり何かした揚句に、どこでもするやうに赤い杭を打ち込んで行きました。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "入らつしやいと云ひながら好く視ると、どの人も覚えのある顔で、半月ほど前にこゝらへ来て、測量をしたり杭を打ち込んだりして行つた復興局の人達でしたから、わたしも商売柄、先日はご苦労様でしたとか何とか挨拶をして、さてお誂へを訊くと、サラダか何かのあつさりしたもので、ビールを飲ませろと云ふんです。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にこのあひだ中は随分世話を焼かせた復興局の人たちですから、かみさんや娘たちも精々お世辞をならべて、お誂へを運び出すと、三人ともに黙つて飲んでゐるばかりで、わたしの方から何か話しかけても、碌に返事もしないんです。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな夜ふけに、復興局の人たちが三人揃つて何処をうろ付いてゐるのか。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "復興局をクビにでもなつて、自棄になつてそこらを飲みあるいてゐるんぢや無いかなどとも考へると、この人達にむやみに飲ませるのも何だか不安心なやうにも思はれましたが、まさかに註文を断るわけにも行かないので、その云ふ通りに飲ませると、大きいコツプでたうとう五杯づつ飲みました。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まつたくこゝらでは、復興局の人をみると喧嘩腰で喰つてかゝるのが随分ありますから、一々相手になつてゐるのも面倒だと思つて、わざと夜ふけに見廻つてあるくと云ふことも無いとは云へません。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "『それで、その復興局の人達といふのは其後に姿を見せないんですか。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "『その杭を抜いたと云ふのは、まつたく復興局の人達だらうか。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあひだも復興局の人が杭を打ち直しに来ましたが、みんな識らない顔ばかりなんです。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云つて、復興局までわざ／＼訊きに行くのも変ですから、まあそれぎりになつてゐるんですがね。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の古典なども、僕らが学生時代にしきりに古典復興を唱えている先生たちから習って置かなければ、今もっと読みなおしてよい気持が起るのではなかろうか。",
              "citation": {
                "source": "僕の読書法",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
