[
  {
    "uuid": "56981c65-f954-5111-8401-e18065ef129a",
    "entry": "二月",
    "reading": {
      "primary": "ふたつき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
