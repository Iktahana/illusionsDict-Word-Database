      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "two months",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昭和八年十二月、結婚。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和九年十二月、「ランボオ学校時代の詩」を三笠書房より刊行。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "仝年十二月「山羊の歌」刊行。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和九年二月著者我が心また新しく泣かんとす冬日暮れぬ思ひ起せや岩に牡蠣漂泊者の歌日は斷崖の上に登り憂ひは陸橋の下を低く歩めり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃木坂倶樂部十二月また來れり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月また來れりなんぞこの冬の寒きや。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が十九歳の夏休みに父に伴われて上京し麹町の宿屋に二月ばかり泊っていた時の事である。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和五年二月『文芸春秋』）",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和九年十二月『短歌研究』）",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和九年十二月『野鳥』）",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治三十四年十二月）",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは相撲取かも知れぬが髪は二月前に刈ったと云う風である。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和七年二月『郷土読本』）",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年二月『ホトトギス』）",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正七年十二月『渋柿』）",
              "citation": {
                "source": "蛙の鳴声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月二十九日までに五、六枚書け、といふお手紙であつた。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また私は、二月二十五日までに今月の豫定の仕事はやつてしまつた。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかげで明治三十七年二月の『太陽』に掲載せられたのはいいが、どうしたものか、博文館から原稿料を送ってよこさない。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十二年十二月）",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十年二月『思想』）",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九三五年二月「自由画稿」より）",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず十二月から正月へかけて二ヶ月くらいなものであろう。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十二月十四日『東京朝日新聞』）",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月の初めには風呂にも入る、髪も結うようになった。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしの二月、あけて六つになる忘れ形身のみつ坊をつれて、この植物園へ遊びに来て、昔ながらのどんぐりを拾わせた。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その時、殆ど何ものかに教えられたように、彼が二月前日本を発つ時、彼の恋人が、　――たまに公園でも散歩なさる時、おはきなさいまし。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、十二月　蟹の子供らはもうよほど大きくなり、底の景色も夏から秋の間にすつかり変りました。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和九年二月『文体』）",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月頃から、一度子供連れで熱海へでも行ってみようと云っていたが、日曜というと天気が悪かったり、天気がいいと思うときっと何かしら差障りがあって、とうとう四月二十日の今日の日曜までこのささやかな欲望を果たす機会がなかった。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつき経ち、ふたつき経って、そろそろ百日目がちかくなって来ても、私たちはだまって見ていなければいけません。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
