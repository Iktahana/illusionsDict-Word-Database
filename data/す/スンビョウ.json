        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただ風景面白いのを二つ三つ見て、自分一寸描くもののなかったのを残念に思い、かつ、あの辺へ十日か一週間すんでああいう強い、美しい□スケッチとっておきたかった。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして又、宋元の畫、足利期のたれかれの作品、宗達、光琳などにいたる琳派のものまでを、よく模寫したり、骨法を寸描してゐたりしてゐる。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
