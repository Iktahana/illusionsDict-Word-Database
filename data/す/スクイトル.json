          "literary": [
            {
              "text": "畔柳博士はすくい取るように拾った。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、水面すれすれのところから、ぱっと陸にはねあげるか、手網ですくい取るかするのです。",
              "citation": {
                "source": "崖下の池",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその美を新鮮な味わいにおいてすくい取る。",
              "citation": {
                "source": "享楽人",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、灯りをともして、すくい取るので、たいへん面倒だが、肉は美味しいものですと、島から来た人がいっていた。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく釣っていると穴に薄氷が張るので、家から灰ふるいを持って行って、それで氷をすくい取る。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会の富をすくい取るためにサン・クルーの辺に網でも張るべきであろう。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "金属製の半球の容器に、ご飯を思いっきりすくい取る。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
