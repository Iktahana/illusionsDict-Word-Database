    "definitions": [
      {
        "index": 1,
        "gloss": "form of astrology based on the Xiuyaojing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やまには宿曜經を見る大徳が居るだらうな。",
              "citation": {
                "source": "死者の書　續篇（草稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿曜師など言ふほどのことも御座いませんので――。",
              "citation": {
                "source": "死者の書　續篇（草稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年期には葛木山に籠つて修法錬行し、如意輪法、宿曜秘法等に達し、看病薬湯の霊効に名声があつた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "七曜の名目は今日の七曜のごとく日、月、木、火、土、金、水にして、その源は『宿曜経』に出ておる。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年期には葛木山に籠って修法｜錬行し、如意輪法、宿曜秘法等に達し、看病薬湯の霊効に名声があった。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ロ）次には、支那には用例はありませぬが、准那の二字が波斯語系の語の音譯であるに適合せんがため、同語系の語で、「米」字の音に邇く且つ姓字に用ひられた例もあるものは、宿曜經などに「蜜」と音譯してある、中世波斯語「ミール」（Mihr）であります。",
              "citation": {
                "source": "金剛智三藏と將軍米准那",
                "author": "榊亮三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その先生の態度がいかにも無邪気で、ちっとも威張らず気取らないのが実に愉快で胸がすくようであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "色よく黄ばんだ晩稲に露をおんで、シットリと打伏した光景は、気のせいか殊に清々しく、胸のすくような眺めである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの魯鈍な機械に比べて「ベルリーン」に映出される本物の機械の美しさは、実に見ていて胸がすくようである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、少女には、寒いことも、おなかのすくようなことも、こわいこともありません。",
              "citation": {
                "source": "マッチ売りの少女",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅の花においしいにおいがしますか」「ええ、梅のにおいをかぐとおなかが急にすくようです。",
              "citation": {
                "source": "梅のにおい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時彼等二人がいかに乱心しただろうか、自分は考えるだに胸がすくような気がする。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう、きちんとした、理路整然たる、胸のすくような、快刀乱麻を断つってえな風な、「ネー、テー、ドーン」といった調子で、断々乎として、生きて行きてえもんだ。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちに待った名人のすっと胸がすくような伝法句調が、はじめてズバリと言い放たれました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "――身内のやつら、おやかましゅう」　すうと胸のすくような男まえです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」「やっぱりすうっと胸のすくような傷痕をしてでござんすな。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "口の合うたが幸い、早速に用いましょうわい」　変り者同士の、きくだにまことに胸のすくような団欒でした。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも胸のすくような朱色だな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君が主の好奇を喜ばない気振りが、お庄には見えすくように思えて来た。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と叫んだ帆村の声は、いつの間にか普段の、あの胸のすくような名調子に変っていた。",
              "citation": {
                "source": "西湖の屍人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの頃の御奉行様の御裁きと申すものは、どれもがほんとうにてきぱきとして、胸のすくようなもの計りでございました。",
              "citation": {
                "source": "殺された天一坊",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）といい、こちらは胸がすくような思いである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　――遊撃隊は三十五ノットの快速力で走りながら、腕におぼえの砲術で、胸がすくようなねらい撃をやった。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "殴り合い取っ組み合いになったら、勝っても負けても、胸のすくように、すっきりとはいきませんよ。",
              "citation": {
                "source": "女と帽子",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへいくとサチ子夫人の如きは天性てんでからだなんか問題にしていない人なんだから、そしてあなた愛情が感謝で物質に換算できるてえのだから、自ら称して愛情による職業婦人だというのだから、これは天晴れ、胸のすくような淑女なんだな。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちそれは精緻、冷厳、鋭利、正確、一言にしていえば「胸のすくような切れた感じ」である。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "太刀川青年は、艇長の方をふりむいて、「さあ、ダン艇長、早く麻綱をもってきてください」　ダン艇長は、さいぜんから太刀川青年の胸のすくような応対ぶりに見とれていたが、はっとわれにかえり、いいつけどおり、この操縦室の網棚から麻綱の束をかかえおろした。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは精緻、冷厳、鋭利、正確、一言にしていえば「胸のすくような切れた感じ」である。",
              "citation": {
                "source": "絵画の不安",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "圭太は胸がすくようだった。",
              "citation": {
                "source": "橋の上",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾山のように光琳にも優る絵画が描け、能筆であり、仁清とは又別風の日本趣味的デザインを創作し、胸のすくような作品を種々遺しております。",
              "citation": {
                "source": "近作鉢の会に一言",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
