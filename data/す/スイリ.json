[
  {
    "uuid": "68cf59e5-863c-5eea-976f-406ff4292899",
    "entry": "推理",
    "reading": {
      "primary": "すいり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "reasoning",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これに反して数学的推理の能力は早くから芽を出し初めた。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も簡単な推理によって問題の要点を直進するところが似ていると、今のレーリー卿が評している。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等が眞理の室内へ這入るためには、推理によつて正面の扉から這入るのであり、外に入口はないのである。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その緻密な推理力（無論探偵的な）に驚くべきものがあつても、全篇の面白味に至つては、コナン・ドイル到底ルブランの比ではないやうに思はれる。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――十三年五月――底本・初出：「新青年　第五巻第十號　夏季増刊『探偵小説傑作集』」博文館　　　1924（大正13）年※底本のコピーは、推理小説研究家の山前譲氏にご提供頂きました。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人普通の感官を備えた人間がこのような相違に気のつかぬのは遺伝や長い間の経験によって、外界の標準を外界に置いて非常に複雑な修練と無意識的の推理を経て来た結果にほかならぬのであろう。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はできるだけ根拠なき臆断と推理を無視する空想を避けたつもりである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "推理の誤謬や不備があればそれは不敏のいたすところである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代物理学に新紀元を画した相対的原理にしても、素量力学や波動力学にしても、直観なしの推理や解析だけで組み立てられると考える事がどうしてできよう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも厳密な推理から得た結果ではなくて、結局は直観で透視したものであろう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり観察と分析と推理の正確周到を必要とするのは言うまでもないことである。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃあれがストーンだ」というと、「驚くべき推理の力だな」と冷やかす。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャアロック・ホルムズが眼鏡をかけて兵隊の死因をしらべに来たのだが、この十九世紀の古風な探偵のもつ観察と推理とは、兵隊の心に宿っていたところの最も近代的なる一つの要素を検出し得べくもなかったので、探偵は頭をかいて当惑したと云う。",
              "citation": {
                "source": "兵隊の死",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し凡そ警察ってものは、あれァ学者の寄り集りですよ、殺されてからの後の推理や観察は極めて丁寧に、綿密に、一々ご尤にやっては呉れるでしょうがね。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これが……これが……種に苦しんだ活動屋の思い付きだろうか……星田の推理した『完全な犯罪』の真相だろうか……これが……これが……」　津村は頭がジイーンと鳴り出したまま、こうした疑いを氷のように背骨に密着させて新聞社の階段を降りた。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはその美少女から百万円を奪い返すべき権利があります」　　　　　　　六　中村芳夫は、高山名探偵の、こうした炯眼と推理力に心から嘆服してしまった。",
              "citation": {
                "source": "夫人探索",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際また、それより外に推理の仕方はなかったのだ。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対に理智の発達した、推理癖のある女性であった。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが彼女の推理癖は、どうにもしてこの奇怪な事件から、真の原因を探り出そうと考えた。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてのあり得べき奇異の事情と、その臆測される推理の後で、夫人はすっかり混惑してしまった。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂律格論者の思想は、次の推理式に示されている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが論理の原則であり、我々の推理の方式は、いつでもこの前提の上に組みたてられる。",
              "citation": {
                "source": "非論理的性格の悲哀",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら多くの事實は、いつも人間の推理を裏切つてゐる。",
              "citation": {
                "source": "非論理的性格の悲哀",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そこに孕まれた金魚に望むところの人間の美の理想を、推理の延長によって、計ってみるのに、ほぼ大正時代に完成されている名魚たちに近い図が想定された。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが大事に到らず濟むことは確かだ、と金太郎は、速度を増してゆく自轉車の上で、幾何の問題を解くときのやうに冷｜靜に推理した。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大いそぎにて候故、御すいりよふ（推量）／＼。",
              "citation": {
                "source": "手紙",
                "author": "安政五年七月頃　坂本乙女あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺殿にも慎作にも何卒ないしょにお願申候、それからタンスの百五十円は無之候御すいりょ下されて何卒何卒宜敷願上候、お詫びは帰りて幾重にもいたす可候直造糸殿　手紙を書いたこと等の殆んど無い父の、この拙い文章が、どんな悲痛な台詞にも増して胸にせまった。",
              "citation": {
                "source": "十姉妹",
                "author": "山本勝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことを、おかしいと思いませんか」　とカンノ博士がすいりの糸口をほどきはじめた。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士のすいりは、なかなかするどいですね」「すると、何者がこんなことをしたか、扉をあのように曲げることも、ふつうの人力ではできません」　博士がことばをとめた。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんという、うすいりっぱな、羽のようなこうもりだろう。",
              "citation": {
                "source": "日がさとちょう",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
