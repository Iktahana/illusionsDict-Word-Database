        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この頃またグラドストーンにも会った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラドストーンは雪が長靴の革を滲透する特殊な力があるということを主張した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八七二年にはグラドストーンから大学の財政に関する調査委員会の一員となることを勧められた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新入りの二人を出迎えに行った先輩のスコッチが一人をつかまえて「お前がストーンか」と聞くと「おれはフォーサイスだ」と答える。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃあれがストーンだ」というと、「驚くべき推理の力だな」と冷やかす。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ一つが貴重なロゼッタストーンである。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西はシエラネヴァダ山脈から東はネブラスカ、北はイエローストーン川から南はコロラドまでの、荒廃した無音の地だ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "原注一四　ストーン大佐編集のニューヨーク、『コマーシャル・アドヴァタイザー紙』。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "便所というのは「トイレ」で通じるのかなと朦朧とし始めた頭をふりふりたずねあてて便座に腰を下ろすや、腹はナイヤガラの滝のように下るわ、イエローストーンの間欠泉のように吐瀉物は口から吹きだすわ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "リヴィングストーンの『南阿行記』七章に、マシュエ附近に鼠多く、その穴地下に充満して人歩むごとに足を陥るとある。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "リヴィングストーンの『南阿行記』十八章には、ムグラモチと小鼠のほか食うべき肉ない地を記す。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは憲法発布が約束されて政治が休息期に入ったからだが、一つは当時の欧化熱が文芸を尊重する欧米の空気を注入して、政治家もまた靖献遺言的志士｜形気を脱してジスレリーやグラッドストーン、リットンやユーゴーらの操觚者と政治家とを一身に兼ぬる文明的典型を学ぶようになったからだ。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎は、ローリング・ストーンズのファンだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローリング・ストーンズは、慶一にとっては、デイヴ・クラーク・ファイヴより落ちる、三流のバンドだが、〈サティスファクション〉よりは、こっちのほうが好みではある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストーンズのチャーリー・ワッツは、慶一が憎悪している、「ジャズ・ドラマー」の親戚のような叩き方をする。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎がなにやらつぶやくのを無視して、慶一は、ストーンズが終わったところで、高志に「いい？",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎はさ、ストーンズとか、アニマルズとか、そういう暗いもんしか聴かないじゃないか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝なんだから、陽気なやつにしようぜ」　といって、ストーンズとビートルズをはずした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストーンズ・ファンの山崎が、この絶望に加わらないのはわかる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストーンズばかり聴いているからなのか、先天的なものなのか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたい、そんな名前は “ストーンズ世代” の連中には迷惑だろうに」「ビートルズって、ストーンズみたいなワルのイメージがないのに、へんですね」　まただ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビーチボーイズは『ペット・サウンズ』『トゥデイ』『エンドレス・サマー』の三枚、ストーンズは『ホット・ロックス』があります。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃考古学の講義で聴いたフランスの学者がロゼッタストーンを研究した話などは、私の好奇心を高めるに与って力があった。",
              "citation": {
                "source": "「古琉球」自序",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "エツヂストーン島では殆ど凡ての疾病は、禁ぜられた樹木の実を食べた為に起つたのだと考へられて居る。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国のある停車場の駅長はグラツドストーンが落して往つた履の踵を拾つて、丁寧に箱入にして蔵つておいたといふから、黄河の濁り水を克明に瓶に入れて持つて帰つたからといつて、別に咎め立もしないが、同じ持つて帰るなら、もつと美しい物を見つけて欲しかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "中でもジョンストーン・ストーネー（Johnstone Stoney）とブライアン（Bryan）が最も顕著な代表者であった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二の二　代助は其夜すぐ立たうと思つて、グラツドストーンの中を門野に掃｜除さして、携帯品を少し詰め込んだ。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "代助はグラツドストーンを前へ置いて、顔を上げた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
