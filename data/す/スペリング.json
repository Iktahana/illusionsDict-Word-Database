          "literary": [
            {
              "text": "「スペリングがちがうんだよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう、変更はなしだよ」　といって、ワラはスペリングをチェックする。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "スペリングの間違い一つでもすぐ印税にひびくわけである。",
              "citation": {
                "source": "校正の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時を見計って今日もなるべくスペリングを間違わないように注意してボールドに書きます。",
              "citation": {
                "source": "悦しき知識",
                "author": "――停年講義（昭和三十三年九月十六日）",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーンズのスペリングは、ケイ・エイ・エイチ・エヌ・アポストロフィ・エス。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "正しくプレスリーとこたえた人たちも、若い人ほど彼の名のスペリングをまちがえ、二十代にちかづくにしたがって正しくなっていた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
