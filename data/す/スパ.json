    },
    "definitions": [
      {
        "index": 1,
        "gloss": "spa (mineral spring)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "インスパイヤーされるとは、蓋しそのことであらう。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレフンケン・システムの大きな蛇のようなスパークがキュンキュンと音を立ててひらめいては消えるのを見た。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日はポツオリに行って腹立たしくうるさい案内者に悩まされながらセラピスの寺の柱に残る地盤昇降の跡を見、ソルファタラ旧火口の噴煙を調べ、汚い家でスパゲッティの昼食を食って、帰りの電車で、贋銀貨をつかまされた外にはあまり人間味のある記憶が保存されていない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか有田の乞食婆の喰っていたあの唐辛子のかかった真赤なうどんと、ポツオリの旗亭のトマトのかかった赤いスパゲッティとの類似のためであろうとも思われない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "刈り株ばかりの冬田の中を紅もめんやうこんもめんで頬かぶりをした若い衆が酒の勢いで縦横に駆け回るのはなかなか威勢がいい、近辺のスパルタ人種の子供らはめいめいに小さな凧を揚げてそれを大凧の尾にからみつかせ、その断片を掠奪しようと争うのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒眼鏡をかけたスパイは、スパイとして使ひものにならないのと同樣に、所謂「詩人らしい」虚榮のヒステリズムは、文學の不潔な虱だとさへ思つてゐた。",
              "citation": {
                "source": "郷愁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お前はスパイかい？",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、此車にゃスパイが二十人も乗ってるんだからな。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心はスパークのやうに、一瞬間青白い光を放ち、熱を持つた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぞれのエキスパートが品物の産地を云ひ當てるやうに、此の男には矢張り特別な眼識が具はつて居るかと思はれた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "コトレツ・ミラネーズとウィンナー・シュニッツレルの異るところは前者は伊太利風のマカロニかスパゲチを付け合せとして居り、後者が馬鈴薯を主な付け合せとしていることで、そこに両本家の特色を表わしている。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三つならんだ入口の一番左側には空箱に紫いろのケールやアスパラガスが植えてあって小さな二つの窓には日覆ひが下りたまゝになってゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまん中に円い黒い星座早見が青いアスパラガスの葉で飾ってありました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴォアラ、ネスパ、セッサ、ムシュー、アラマディ、プレンプアン、ラタヽパン。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "服装は赫い短靴を埃まみれにしてホームスパンを着ている時もあれば、少し古びた結城で着流しのときもある。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "間近い城東電車のポールが電力線にスパークする光なのだが、小初は眺めているうちに――そうさ、自分に関係のない歓楽ならさっさと一｜閃きに滅びてしまうがいい、と思った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまでは横田はヤンキーの女達が過去スペインの愛犬に恋慕したように、無謀な愛情ときわどい婦人社会の教養をうけて裸体で近東風な機械体操や、スパルタ風の腕力を発揮したり、恐らくあの毛むくじゃらの胸を、つき出して、サロンを物好きな流行女の号令によって、自由自在に這い廻っていることだろう。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の旅程――　１　横浜外交官の無線電信の費用見つもり処、グランドホテル・ド・ヨコハマに設計された硝子張りの円舞場でスパルタの女と根岸の外人ティームとの間で弓術試合が行われた。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が「助けて」（スパシーテ）というつもりで云った言葉が「有がとう」（スパシーポ）と響いた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと、郷里の家へ帰っているともう、スパイが、嗅ぎつけて、家のそばに張りこんでいる。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嚊を貰って、嚊の親もとへ行っていると、スパイは、その門の中へまでのこ／＼はいって来る。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "スパイは、僕等の結婚や、お祝いごとまでも妨害するのだ。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時にでも、スパイは、小うるさく、僕の背後につき纒って、墓場にまでやって来るだろう。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西山も、帰るとスパイにつき纒われる仲間の一人だ。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　下駄屋の前を通って、四ツ角を空の方へ折れたところで、饂飩屋にいたスパイがひょっこり立って出て来た。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "スパイは、饂飩屋で饂飩を食って金を払わない。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、スパイに借られ、食われたものは、代金請求もよくせずに、黙って食われ損をしているのだ。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　スパイは、疑い深かげな眼で三人を眺めた。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
