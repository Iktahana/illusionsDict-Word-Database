    "definitions": [
      {
        "index": 1,
        "gloss": "sailor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ボーイ長（水夫見習）を見な。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長、機関長、を初めとして、水夫長、火夫長、から、便所掃除人、｜石炭運び、に至るまで、彼女はその最後の活動を試みるためには、外の船と同様にそれ等の役者を、必要とするのであった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫の一人が、出帆すると間もなく、ひどく苦しみ始めた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫たちは、デッキのカンカンをやっていたのだった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、水夫たちは、珍らしくもなく、彼を水夫室に担ぎ込んだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "錆のとれた後は、一人の水夫が、コールターと、セメントの混ぜ合せたのを塗って歩いた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い、暑い、息詰る、臭い、ムズムズする、悪ガスと、黴菌に充ちた、水夫室だった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗くて、暑くて、不潔な、水夫室は、彼が「静か」になったにも拘らず、何かが、眼に見えない何かが、滅茶苦茶に暴れまくっていた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫室の病人は、時々眼を開いた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、同じ乗組の、同じ水夫としての、友達甲斐から、彼に、いや彼等に今、そのどこだったかを知らせなければならない。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　一人前の水夫になりかけていた、水夫見習は、もう夕飯の支度に取りかからねばならない時刻になった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、彼は水夫等と一緒にしていた「誇るべき仕事」から、見習の仕事に帰るために、夕飯の準備をしに、水夫室へ入った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　水夫見習は、も一度踏みつけて見た。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとかい」「ほんとだとも」　水夫たちは、ボースンと共に、カンカン・ハマーを放り出したまま、おもてへ駆け込んだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもて（水夫室）の中は、然し、静かであった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫達は、死体の周囲に黙って立っていた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "安田は、水夫たちの手に依って、彼のベッドへ横たえられた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫は未だ確りしていた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "病める水夫は、のたうちまわった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "高級海員が六人と、水夫が二人と、火夫が一人残った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "えゝボートはきっと助かったにちがひありません　何せよほど熟練な水夫たちが漕いですばやく船からはなれてゐましたから。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国の海軍ではこの器械を四十台使っているが、水夫二、三人掛りで十五分間も運転させると一日の食糧くらいは楽に出来るという事である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "津々浦々に海の幸をすなどる漁民や港から港を追う水夫船頭らもまた季節ことに日々の天候に対して敏感な観察者であり予報者でもある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええボートはきっと助かったにちがいありません、何せよほど熟練な水夫たちが漕いですばやく船からはなれていましたから。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ、ボートはきっと助かったにちがいありません、なにせよほど熟練な水夫たちが漕いで、すばやく船からはなれていましたから」　そこらから小さな嘆息やいのりの声が聞こえジョバンニもカムパネルラもいままで忘れていたいろいろのことをぼんやり思い出して眼が熱くなりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで区役所では撒水夫に雇ひました。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何せよほど熟練な水夫たちが漕いで、すばやく船からはなれてゐましたから。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこれは笑いやすいふうではない、落ち着いた人が酒瓶の役に選ばれてあったのである。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
