        "index": 1,
        "gloss": "hanging tail (of a traditional Japanese hat)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いふまでもなくこれらのすべてが優美な垂纓の微かにゆらめく背を參列者に向けて、神殿に面して笏を正すのである。",
              "citation": {
                "source": "賢所御神樂の儀",
                "author": "羽田亨",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡厥体像、髣‐髴丈夫、頭上加冠、鬢辺垂纓、成緋衫色、起居不同、遞各異貌、或所作女形、対丈夫而立之、臍下腰底、刻絵陰陽、搆几案於其前、置坏器於其上、児童猥雑拝礼、慇懃捧幣帛、或供香華、号曰｜岐神。",
              "citation": {
                "source": "オシラ神に関する二三の臆説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
