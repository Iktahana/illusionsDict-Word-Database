[
  {
    "uuid": "8569d5e0-8908-53bd-872e-dcce645337d3",
    "entry": "ＳＴＯＬ",
    "reading": {
      "primary": "ストール",
      "alternatives": [
        "エストール"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "short take-off and landing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "特にインストールの厄介さときた日には、殺人的である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はパストールやコッホやエールリッヒなどの業績を思うごとに、彼等が人類に与えた恩恵に感謝すると同時に、これ等の大天才たちは、何故、人工心臓の発明に力を注いでくれなかったかと痛嘆するのでありました。",
              "citation": {
                "source": "人工心臓",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時初三発致し候時、ビストールを持し手を切られ候得ども浅手ニて候。",
              "citation": {
                "source": "手紙",
                "author": "慶応二年二月六日　木戸孝允あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "※ネストール　思慮に長ずる老將軍、ゲレーニャの領主。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "網棚へ小道具の入ったスーツ・ケースを載せると、灰銀のフラノのワンピースに緋裏のついた黒のモヘアのストールという、どこかのファッション・モデルのような恰好で車室を流して歩き、知った顔がないかと物色していたが、三つ目の車でロケハンにでも行くらしい楠田という助監督の一行を見つけた。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "またあとで話しにくるわ」　さっきの座席に戻ると、話しかけられるのを防ぐために、久美子は顔にストールをかけて寝たふりをしていた。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰銀のフラノのワンピースに緋裏のついた黒のモヘアのストール、パンプスの靴とナイロンの靴下が入っていた。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらミスカトニック・アヴェニューやハイ街やソールトンストール街の身なりのよい人々が知らぬ振りをしていても、常にそれはアーカムでは極めて悪い時期だった。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は拍動力が心臓の壁および動脈にあることを知っていて、拡張すなわちディアストールが血液を心臓の腔内に引きこみ、シストールが血液を外に出すことを知っていた。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから彼は動脈の運動を研究して、動脈のディアストールすなわち拡大の期間は心臓のシストールすなわち収縮に対応し、動脈の脈拍は心室の力、頻度、およびリズムに従い、実際にそれに依存することを示した。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローマではピストール金貨二百枚積んでも売っていただけなかった本じゃありませんか。",
              "citation": {
                "source": "犬酸漿",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "アキリュウス、ネストール、パトロクロス、神明中にはヂュウス、ヘーレー、アテーネー。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネストール之を讚す。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くてすぐれし＊元老の集議まさきにネストール（ピュロスの王者ネストール）其船めぐり行はる。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "『諸友願はく我に聞け、尊き夢の靈｜夜半に眠の中に現はれぬ、其風貌はさながらに、其身の丈に到る迄、みなネストール見る如し、わが枕上に立ち留り、我に向ひて彼は曰ふ、『軍馬を御する勇猛のアトリュウスの子たる者！",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "つゞきて衆の前に立つ、ピュロス沙岸の一帶を領し治むるネストール、計量密に參列の衆に向ひて陳じ曰ふ、『＊あゝアルゴスの諸君王及びわが友、諸將軍、今聞くところ、此夢を他のアカイア人見しとせば、　80欺瞞となして信頼をこれにおくべき由あらじ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "されども見しはアカイアの至高と自ら誇る者、いざ、さは、アカイア軍勢に勉めて準備なさしめよ』79　ネストールの演説極めて弱し、アリスタルコスは全く之を省く。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "335ゲレーナ騎將ネストール、その時衆に宣んし曰ふ、『ああ、痛むべし、集會の席に汝ら曰ふところ、心に軍事留めざる幼穉の輩にさも似たり、先に結びし＊約束と誓いづくに今ありや？",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め來るはネストール、王イドメネー之に次ぐ、　405次ぐは二人のアイアース、同じく跡に續き來るヂオメーデース、第六は聰明理智のオヂュシュウス、更に英豪メネラウス、自ら來る、其兄の胸中の感、悟り得て招かれなくに來り訪ふ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして宴飮了し果て口腹おのおの滿てる時、ゲレーナ騎將ネストール、衆中立ちて宣んし曰ふ、421　I 449 とほぼ同じ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒れる神女彼を打ち、盲目となし加ふるに彼の歌謠を奪ひ取り更に彈琴忘れしむ）　600これらの族を率ゐるは＊ゲレーニャ騎將ネストール、兵船九十一齊に彼に從ひ進み來ぬ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "其他すべての眼光るアカイア人を我は見る、彼等を我は能く知れり、彼等の名を皆語り得む、　235たゞ民族の二將軍今わが眼は見出し得ず、馬術巧みのカストール、ポリヂュウケース、拳鬪者、兄弟二人われととも同じ胎より生れし身、ラケダイモンの故郷より二人はこゝに來らじか？",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に見たるはネストール、ピュロスの首領、朗々の聲を放ちて戰鬪に軍を整へ進ましむ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたへに立つはペラゴーン、アラストール、クロミオス、王ハイモーン更にまたビアス、諸民の主たるもの、　295戰馬兵車を備へたる騎兵まさきに進ましめ、後陣は勇氣凛々のあまたの歩兵、戰ひの防壁として守らしめ、劣れるものを中央に据えて斯くして好まずもやむなく戰鬪勉めしむ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　315ゲレーニャ騎將ネストール即ち答へて彼に曰ふ、『アートレ，デーよ我も亦切に望めり、その昔＊エリユウタリオーン斃したる其日の如くあれかしと。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして打たるコイラノス、アラストールと＊クロミオス、アルカンドロス、ハリオスとノエーモーンとプリュタニス。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "65その時高くネストール、アルゴス勢に叫び曰ふ、『友よ、ダナオイ諸勇士よ、神アレースの從者らよ、汝等の中何人も、戰利の品を飽く迄も水師の中に運ぶべく、後に留りて掠奪の業にいそしむこと勿れ、たゞ敵人を打倒せ、　70後に靜に原上に彼等の死屍を剥ぎ得べし』しかく陳じておのおのの意氣と勇とを奮はしむ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
