    "definitions": [
      {
        "index": 1,
        "gloss": "already",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――言葉は既に無益なるのみ。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢のうちなる遠近法、夏の夜風の小鎚の重量、それ等は既になし。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "久留米絣を来てゐて、既に酔つてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに不思議な運命のそれ自体単純にして、それを織成す無限に複雑な因子の離合の間に、今や我々に既に分つたことは、宮沢賢治は死後間もなく認めらるるに至つたといふことである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "良心があるだけで、既に結構なことではないか。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨、現代が芸術にとつて、好都合な時代でないといふことは、漠然と乍ら、既に誰人の胸にも抱懐されてゐる所である。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨新短歌は、既に新しい様式として存在してゐるか？",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その成績を今問はないこととするならば、新短歌は、どうやら詩歌の新しい様式として、既に存在してゐるやうに思はれる。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが短歌より出て来たものだとしても、既に短歌と訣別して、新しい領土に立つてゐることも恐らく間違ひない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "『二十才にして既にひどい心痛は歌ふことを断念せざるを得ざらしめた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、事々に、真実と虚飾とを篩ひ分ける感情基底を失はずしてあることが既に問題なのである。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて意志にばかり依拠することは、そのことが既に芸術の方則に悖ることとなるのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論外国にしろ、多少とも此の世の中は左様なものではありますが、高い程度の技術ではともかく、凡そ常識の既に認める範囲にある技術では、我が国程に台所情実は場を占めてないやうであります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてニツコリするのだが、ニガムシつぶした所が芸術で、ニツコリする所は既に生活であるといふやうなことが云へる。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、何時もするこれらの自問自答、私は既に鳴子馴れてる。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "それの周囲の棚だつた鉛の棒を共に抜取つた弟さへ、今は既に亡き数に入つたのである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私共は、既にかうした青春時代の花やかな、とはいへいくぶん狂気じみた創造の夢を過去に微笑して観ることさへもできる。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に老いの近づいたヘルンは、自分の死後における妻子の地位を考えた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚十数年、ヘルン既に五十｜歳を過ぎ、二人の男児と一人の女児の親となってる晩年の手紙である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に老の近づいたことを知った彼は、自分の残されてる短かい時間に、なおまだ書かねばならない大事の事が、あまりに多くありすぎるのを考えて愁然とし、『人生は短かすぎる』と幾度も言って嘆息した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いが既に来り、死の近づいて来たことを知った彼は、すべての自然を感傷的に眺めることから、万象に対して愛以上の深いものを注いだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "實にその時、既に既に、彼は死を計畫してゐたのである。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自作を説明するという事は、既に作者の敗北であると思っている。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小坂氏の夫人は既に御他界の様子で、何もかも小坂氏おひとりで処置なさっているらしかった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に、世界的な評論家なのである。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎氏も真の困難は、今日以後に在るという事に就いては、既に充分の覚悟をお持ちだろうと思います。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものの考えかたが、既に常人とちがっている。",
              "citation": {
                "source": "無題",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）だから、短歌や俳句には、既に盛るに不適当な感性が現代にはあると多かれ少なかれ感じられてゐるにも拘らず、歌人俳人の方が詩人よりも遥かに身過ぎ世過ぎは楽だといふ有様である。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、旧約聖書の「詩篇」に於いて、「ヤーエ」と呼ぶ時に、ヤーエといふ一単語の音色が既に今では感じ切れない程の微妙な意味をも有してゐたであらうことなぞ、一応想起されたいのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのふ山より摘みてかへれば、紫苑はなしぼみて、すでに秋の愁ひをさそふ。",
              "citation": {
                "source": "立秋",
                "author": "――大沼竹太郎氏ニ捧グル詩――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
