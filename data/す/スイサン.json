[
  {
    "uuid": "95cc516d-9262-517c-820c-9d11e265f9d6",
    "entry": "水産",
    "reading": {
      "primary": "すいさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "aquatic products",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たいまいの他に、掌の鰭状を爲してゐる鹹水産の龜は、無いものか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敢えて農作関係ばかりとは限らず、系統的な海洋観測が我邦のような海国にとっては軍事上からも水産事業のためにも非常に必要であるということは、実に分りきったことであるが、この分り切ったことがどういう訳か昔の日本の政府の大官には永い間どうしても分らなかったのである。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "故人北原多作氏のごとき少数な篤学の官吏の終生の努力と熱心によってようやく水産に聯関した海洋調査がやや系統的に行われるようになりはしたが、自分の知る限りでは時々の政府の科学的理解のない官僚の気まぐれなその日その日の御都合による朝令暮改の嵐にこの調査の系統が吹き乱される憂いが多分にあった。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱根は二十年も昔水産関係の用向きで小田原へ行ったついでに半日の暇を盗んで小涌谷まで行ったのと、去年の春長尾峠まで足を使わない遠足会の仲間入りをした外にはほとんど馴染のない土地である。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "我邦の産業中で農業に劣らず重要な水産漁業の方面でも物理学的研究の必要はだんだんに増して来るようである。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお直接水産方面に関して、自分の知っているだけの僅少な例を挙げてみると、第一に漁具ことに網の研究である。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水産生物の種類と数量の豊富なことはおそらく世界の他のいかなる部分にもたいしてひけを取らないであろうと思われる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあとでよく考えてみると、物理でもやはりプランクトンと同様なものを、水産学におけると同様に取り扱っていることは少しも珍しくない。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとは大きな盥を浮かべて船の代わりにしたものであるが、いろいろの観測に必要だというので、水産講習所へ頼んで造ってもらったものである。",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "某水産技師の講演放送中でありました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆三が十七になり、お涌が十六になった春、皆三は水産講習所に入って、好きな水産動物の研究に従うことになった。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、自分のはいっている中学の理科の教師でＴという老学士が水産講習所の講師を主職にしているので、その縁に牽かれてそこへはいった。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいまいの他に、掌の鰭状を為してゐる鹹水産の亀は、無いものか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "復一が六年前地方の水産試験所を去って、この金魚屋の跡取りとして再び育ての親達に迎えられて来たときも、まだこの谷窪に晩春の花々が咲き残っていた頃だった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "復一は生れて地方の水産学校へ出る青年期までここに育ちながら、今更のように、「東京は山の手にこんな桃仙境があるのだった」と気がついた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち復一は東京の中学を卒え、家畜魚類の研究に力を注いでいる関西のある湖の岸の水産所へ研究生に入ることになった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "復一が研究生として入った水産試験所は関西の大きな湖の岸にあった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡水魚の、養殖とか漁獲とか製品保存とかいう、専門中でも狭い専門に係る研究なので、来ている研究生たちは、大概就職の極っている水産物関係の官衙や会社やまたは協会とかの委託生で、いわば人生も生活も技術家としてコースが定められた人たちなので、朴々としていずれも胆汁質の青年に見えた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は幾つかのこの湖畔の水産に関係ある家に試験所の用事で出入りをしているうち、その家々で二三人の年頃の娘とも知合いになった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭鋳、和蘭獅子頭はもちろんとして、出目蘭鋳、頂点眼、秋錦、朱文錦、全蘭子、キャリコ、東錦、――それに十八世紀、ワシントン水産局の池で発生してむこうの学者が苦心の結果、型を固定させたという由緒付の米国生れの金魚、コメット・ゴールドフィッシュさえ備えられてあった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三年前、Ｏ市に水産共進会があって、その際、金牌を獲ち得たこの金魚の名品が試験所に寄附されて、大事に育てられているのだ。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ淡水産のものだからそう違うまい。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆三が十七になり、お涌が十六になつた春、皆三は水産講習所に入つて、好きな水産動物の研究に従ふことになつた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、自分のはひつてゐる中学の理科の教師でＴといふ老学士が水産講習所の講師を主職にしてゐるので、その縁に牽かれてそこへはひつた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この町あたりが、津軽の西海岸の中心で、江戸時代には、ずいぶん栄えた港らしく、津軽の米の大部分はここから積出され、また大阪廻りの和船の発着所でもあつたやうだし、水産物も豊富で、ここの浜にあがつたさかなは、御城下をはじめ、ひろく津軽平野の各地方に於ける家々の食膳を賑はしたものらしい。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水田は、村のはづれに、ほんの少しあるだけだが、水産物は相当豊富なやうで、ソイ、アブラメ、イカ、イワシなどの魚類の他に、コンブ、ワカメの類の海草もたくさんとれるらしい。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水産業は何樣である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚を獲れば利益が有るには相違無からう、が、これも國家が福を惜んだならば、水産も永く繁殖することで有らう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ついぞまだ、宮中へすいさんいたしたこともございません。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから日本軍がちゃちゃっとはんごうすいさんをやって、胡麻塩かなんかでちゃちゃっと片づけて戦線へ出るじぶんに、やつらはようやくパン竈から焼けたパンを出し、片一方ではシチュー鍋をかきまわしているという始末さ、と春彦は云った。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
