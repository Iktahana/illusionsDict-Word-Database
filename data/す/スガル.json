[
  {
    "uuid": "648d9552-216a-59c0-912d-ec17720fbc8d",
    "entry": "縋る",
    "reading": {
      "primary": "すがる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to cling to",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "早くもそれと見て、おしまが「先生ッ」と馳け寄って、縋る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには泣出すと、外聞もあり、少焦で、医者は恐しい顔をして睨みつけると、あわれがって抱きあげる娘の胸に顔をかくして縋るさまに、年来随分と人を手にかけた医者も我を折って腕組をして、はッという溜息。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "集る者は大抵四十から五十、六十の相当年輩の男ばかりで、いずれは道楽の果、五合の濁酒が欲しくて、取縋る女房子供を蹴飛ばし張りとばし、家中の最後の一物まで持ち込んで来たという感じでありました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘、いよいよ執念く取り縋る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お千世は、生際の濃い上へ、俳優があいびきを掛けたように、その紫の裏を頂いたが、手へ返して、清葉のその手に、縋るがごとく顔を仰いで、「姉さん、このお宝で、私をお座敷へ呼んで下さいな。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛木はなお縋る袖をお孝に預けたまま、跪いて悶絶した小児を抱いた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お孝は、離さじ、とただ黙って葛木に縋る。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "取縋るものはないのだから、部屋の中央に胸を抱いて、立ちながら吻と呼吸をついた。",
              "citation": {
                "source": "怪談女の輪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "思わず縋る手を取られて、団扇は庭に落ちたまま、お雪は、潤んだ髪の濡れた、恍惚した顔を上げた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　詮方なげに見えて島野に縋るようにいった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お雪は驚いて、追縋るようにして、「貴下、どちらへ参るんでございます。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "可うがす、何そりゃ好いた女のためにゃあ世の中を打棄るのも、時と場合にゃ男の意地でさ、品に寄っちゃあ城を一百一束にして掌に握るのと違わねえんでございましょうが、何ですぜ、野郎の方で、はあと溜息をついて女児の膝に縋るようじゃあ、大概の奴あそこで小首を傾げまさ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "でれでれとするのはお金子のある分だ、貴方のなんざ、女に縋るんだから堪りませんや。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂高く、天近く、仰げば遥かに小さな少年の立姿は、狂うがごとく位置を転じて、腕白く垂れたお雪の手が、空ざまに少年の頭に縋ると見た。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども今は此人より外に縋る処はないのであつた。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども今は此人より外に縋る處はないのであつた。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "世に無き母に救を呼びて、取り縋る手を得三がもぎ離して捻じ上ぐれば、お録は落散る腰帯を手繰ってお藤を縛り附け、座敷の真中にずるずると、髷を掴んで引出し、押しつけぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小児同士が喧嘩して及ばぬ敵の迫る時も、腕白な悪戯を薪雑木で追わるる時も、石垣が逃げ場所で、ぴたりとひそんで縋るとそのまま、衣服の裳のそよそよと、潮に近き唐撫子、手に取る術はなかったそうな。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たといここに、天津乙女の、麗しき翼を休めたとて、縋る力も絶えたのが、三人といわず、五人といわず、濃く薄く湯気の動くに連れて、低くむらむらと影が行交う。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時、吸い草臥れて、長々と寝たるもあれば、そのあとへ、這い寄って、灰色の滑らかな背を凹に伸ばしながら両手で穴に縋るもあり、ぐッたりと腰を曲げて臍へ頭をつけるもあり、痩せた膝に、両手を組んでいるのもあり、なえつかれたようになって、俯伏した女も見えた。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……昨夜、戸外を舞靜めた、それらしい、銀杏の折れ枝が、大屋根を越したが、一坪ばかりの庭に、瑠璃淡く咲いて、もう小さくなつた朝顏の色に縋るやうに、たわゝに掛つた葉の中に、一粒、銀杏の實のついたのを見つけたのである。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとへに寄縋る、薄暗い、消えさうに、ちよろ／＼またゝく……燈と言つては此一點で、二階も下階も臺所も内中は眞暗である。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お百合、晃の手に取縋ると、縋られた手を震わしながら、し、しからずんば決闘せい。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お百合、振上げたる晃の手に縋る。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今は疑うべき心も失せて、御坊様、と呼びつつ、紫玉が暗中を透して、声する方に、縋るように寄ると思うと、「燈を消せ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　縋る波に力あり、しかと引いて水を掴んで、池に倒に身を投じた。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、手をふるはずみに、鳴子縄に、くいつくばかり、ひしと縋ると、刈田の鳴子が、山に響いてからからから、からからからから。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "草には露、目には涙、縋る土にもしとしとと、もみじを映す糸のような紅の清水が流れた。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私、何だか、案じられて気が急いて、貴方、ちょっと顔を見せて頂戴（背ける顔を目にして縋る）ああ（嬉しそうに）久しぶりで逢ったようよ。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）お蔦　（はっと泣いて、早瀬に縋る。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
