    "definitions": [
      {
        "index": 1,
        "gloss": "passing through without stopping",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "青春などは素通りしてしまって、心はこどものまま固って、その上皮にほんの一重大人の分別がついてしまった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の中の小さな驛を素通りするたんびにがたっと横にゆれながら、汽車はいっしんにその七時雨の傾斜をのぼって行きました。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し詳しく立止まって見たいと思う者があっても、大勢に追従して素通りをしてしまわなければならない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "美術院はほとんど素通りした。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これじゃ網のまん中に穴があるようなもので、利というものは素通りでさ」貝原は、父親には、反感を持っていないようなものの、何の興味もないらしい口調だった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の傲がんなこころがすこしの反省もなく、イズモ町の彼女経営の流行品店を素通りして、築地河畔のコルビジェ風のアパートメントの一室を訪れた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後のブルジョア文学は、一二の作品で農民を題材としていることがあっても、ほとんど大部分が主として、小ブルジョア層や、インテリゲンチャにチヤホヤして、農民をば、一寸、横目でにらんだだけで素通りしてしまった。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリア文学には、ブルジョア文学が、農民には、ほとんど眼も呉れずに素通りしてしまった、そういうことは絶対に許されないのである。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "故｜野口英世博士が狂人の脳髄の中からスピロヘータを検出したときにも、二百個のプレパラートを順々に見て行って百九十何番目かで始めてその存在を認め、それから見直してみると、前に素通りした幾つもの標本にもちゃんと同じもののあるのが見つかった。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、地下道を素通りしただけで、そのような戦慄を、本気に感じたのでした。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣りの人見の部屋には柿江と森村とが集っているらしく、話声で賑わっていたが、園はそこを覗いてみる気持にもなれないで、そっと素通りして自分の部屋にはいった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青春などは素通りして仕舞って、心はこどものまま固って、その上皮にほんの一重大人の分別がついてしまった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "素通りに進んで、前庭へ拔けると、再び其處に別亭あり。",
              "citation": {
                "source": "畫の裡",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　汽車は時々素通りする停車場の踏切でがたつと横にゆれながら一生けん命ふゞきの中をかけました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "△△屋の前は知らん顔に素通りして、後から宿屋の者を取りに遣る。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これだな」と、一行は澄ました顔をしてその前を素通りしながら、そっと横眼を使って店内を眺めると、有るわ有るわ、天幕、写真器械、雑嚢など、一行の荷物は店頭に堆高く積んである。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "時すがら悪き病疾に罹れるやらむ、近寄りては面倒、と慈悲心無き男なれば遠くより素通りしつ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗吉は、しかし、その長屋の前さえ、遁隠れするように素通りして、明神の境内のあなたこなた、人目の隙の隅々に立って、飢さえ忘れて、半日を泣いて泣きくらした。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに馬車の休憩所ありて、馬に飲い、客に茶を売るを例とすれども、今日ばかりは素通りなるべし、と乗り合いは心々に想いぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その癖、表の往来はふだんの通りに賑かいんですが、誰もこゝの店へ這入つて来るものが無い、みんな素通りです。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、やはり肝心の家の門はくぐらず、せかせかと素通りしてしまう。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして次に今一つある西洋間の青い扉の前を素通りにして一番向うの廊下の端にある日本間の障子に手をかけた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷹の白羽の矢が次郎兵衛の家の屋根を素通りしてそのおむかいの習字のお師匠の詫住いしている家の屋根のぺんぺん草をかきわけてぐさとつきささったのである。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちのいま最も気がかりな事、最もうしろめいたいもの、それをいまの日本の「新文化」は、素通りして走りそうな気がしてならない。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しわかりかけたら、あとはドライアイスが液体を素通りして、いきなり濛々と蒸発するみたいに見事な速度で理解しはじめた。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっと部屋を素通りして、次の間に行ってしまった。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいていの町には、その町の中心勢力が、ある箇所にかたまり、町の重になつてゐて、その町を素通りする旅人にも、ああ、この辺がクライマツクスだな、と感じさせるやうに出来てゐるものだが、鰺ヶ沢にはそれが無い。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番の八時の汽車で五所川原を立つて、津軽鉄道を北上し、金木を素通りして、津軽鉄道の終点の中里に九時に着いて、それから小泊行きのバスに乗つて約二時間。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "真砂町の家へ帰ると、玄関には書生が居て、送迎いの手数を掛けるから、いつも素通りにして、横の木戸をトンと押して、水口から庭へ廻って、縁側へ飛上るのが例で。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭痛がしてならないから、十畳の真中へ一人で寝て見たいの、なんのッて、都合をするのに、貴下は、素通りさえしないじゃありませんか。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
