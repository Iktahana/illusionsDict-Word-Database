          "literary": [
            {
              "text": "この討論は到底相撲にならないで終結したらしい。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さまにもよくそう仰しゃって下さい」　こうなると、多年の功を積んだ岡っ引と、前髪のある若侍とは、まったく相撲にならないのは判り切っているので、長三郎も意地を張るわけには行かなくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "くやしい失敗　巨獣恐竜とテリアのポチとでは、相撲にならない。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハタキ込みというようなあの手にかかると、相撲にならない先に、わが浜辺の名うての力士たちがひっくり返ってしまう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでないと相撲にならない。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "抑えたけれども、米友の力と、道庵の力とでは、相撲にならない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしても、危険の刻々に迫るのを見て取った道庵は、ほとんど畢生の力を出して、抑えてみたが、前にいう通り、道庵の力では相撲にならない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
