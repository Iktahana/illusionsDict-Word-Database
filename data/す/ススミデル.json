        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "Ｓ＝道場内　用意万端整えて白倉、悠然と進み出る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその前半の進み出る方をシカケと名付け、後半をヒラキと名付けるとする。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "楯井さんは黙って、前の方に進み出ると、うす暗いランプの光りで、なんとなく夢のような荘厳な心持になりながら、いろんな巾で蔽うてある死体らしいものゝ巾を半分ほど除けて見た。",
              "citation": {
                "source": "惨事のあと",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをきっかけに二人三人とつづいてあとから列を割って進み出ると、いずれも競って目を輝かしながら、弓を手にとりあげました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "十箭のうち五本も射はずすナマリ武士が、人がましゅう鯉口切るとは片腹痛かろうぞ」「言うなッ、ほざくなッ」　つつうと進み出ると、噛みつくように言ったのは擬い鎮西八郎のあの大兵漢です。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "播磨も縁さきに進み出る。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彌平次　（進み出る。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一同に會釋して進み出る。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、暫く其処に立ち止つた後に――つかつかと床柱の前へ進み出ると、「やツ！",
              "citation": {
                "source": "蝉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "たわけ、名簿はどこだ」「は、これにございます」　万兵衛はオズオズ進み出ると、手に持っていた帳面を恭しく差し出した。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちやうどその時、チェレークの胸の血がさわぎだして、やをら誇りかに両手を腰につがへて前へ進み出るなり、彼は前後を忘れてしやがみ踊りをおつ始めたものだ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人のザポロージェ人は勿体ぶつて前へ進み出ると、かう言つた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "大尉は厳かに威儀を正して前へ進み出ると、魔法使の面前に聖像をかざしながら、凛然たる声で言ひ放つた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は矢代の方へ進み出ると、低い腰で遅参を詫びたが、矢代はこの人も知らなかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　諦めて引き返すか、思ひ切つて前に進み出るか？",
              "citation": {
                "source": "惑ひ",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　船首に立った頼正は地団駄踏んで叫ぶのであったが、しかし進み出る者はない。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸浪三四郎がこれに代って進み出ると、少女の身体をソッと上向きに寝かせた。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "田丸は、もうそんなのにはかまつてゐられず、きちんと丈の順に並んだ三人の紅顔の勇士の前に一歩進み出る。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その新しいのを羨ましいくらゐであるが、日本は古い國で、佛教が渡つて來てからでも千四百年になるし、支那や印度はもつともつと古いから、日本人が、曲りなりにも東洋の文化を研究をして、世界的の水準に進み出るには、そのために必要な書物は山の如くにある。",
              "citation": {
                "source": "綜合大學の圖書",
                "author": "會津八一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その過酷を嘆いて、ひたすら寛大な処分を嘆願しようとすれば、半蔵ごときは戸長を免職せられ、それにも屈しないで進み出る他の総代のものがあっても、さらに御採用がない。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "コノール　（ゆっくり進み出る）デヤドラはどこにいる？",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイネ　（徐かに樹のかげより進み出る。",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "（王の方にゆっくりと進み出る）あの声はウスナの家の声でございます！",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "【２】１．誰として進み出る者がない。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（手を叩く）みんなが尻ごみしてゐるので、男優Ａ自ら進み出る。",
              "citation": {
                "source": "職業（教訓劇）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中から、献作が、一人前に進み出る。",
              "citation": {
                "source": "浅間山",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "外交員乙竹外雄、口髭を生やした男、慇懃に進み出る。",
              "citation": {
                "source": "医術の進歩",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "老女が、三宝の上に、土産の品々を持つて、そこへ進み出る。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "抱きしめるどころか、妹の方へすすみでることもできないほどのそらぞらしさが二人の間を距てている。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついと、みんなの　まえに　すすみでると、「わたしが　じくさいさんの　こなくなる　まじないを　しましょう。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
