          "standard": [],
          "literary": [
            {
              "text": "マルスリーヌ・デボルド―※ルモオルは千七百八十六年七月の二十日にドゥエ（Douai）に生れ、千八百五十九年七月二十三日巴里で死んだ。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ幼いマルスリーヌを伴つて、彼女は実際アメリカに行つたのだつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルスリーヌはフランス女流詩人中の第一人者であつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "北米合衆国の気象台で定めたスリート（sleet）というものの定義が大体この凍雨に相当している。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（英国で俗にスリートと言うのは我邦の霙である。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）スリートとして挙げられているものの中には、以上のようなものの外に雪片のつながったのが一度溶けかけてまた凍った事を明示するようなものや、氷球の一方から雪の結晶が角を出しているのや、球の外側だけが氷で内部は水のままでいるのもある。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ人類の食糧と云はゞスタンダードチョイスリーダー三　フレデリック大王の質問をまたずと雖も動物植物鉱物の三種を出づべからず。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで君は、俄に恐しく神経を悩ましはじめたのだ――』　西村はシャアロック・ホルムズの様な口調でこう云うと、少し勿体ぶった手つきでスリーカッスルをつめたマドロスパイプを脂さがりに斜めに銜えた。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええっと、三鷹を英語で言うなら、スリー、……スリー、スリー、ええっと、英語で鷹を何と言いましたかね、ドイツ語なら、デルファルケだけれども、英語は、イーグル、いやあれは違うか、とにかく十二になる筈です。",
              "citation": {
                "source": "女神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　四条河原町の三味線屋の飾窓の中に、委託品として陳列されているスリービーのマドロスパイプを吸口の所だけ照らしていた落日の最後のあかりも、市電を待っているうちにいつか消えてしまい、黄昏がするすると落ちて来た。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は、新子が傍にいることなどは、すっかり忘れたように、スリー・キャッスルの細巻を吸いながら、綺麗なファッション・ブックを漫然とながめているのだった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、いって夫人は、自分の赤革のケースから、スリー・キャッスルの細巻を出して、青年がライターをつけてくれるのを待った。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "スリー・ハンドレッドでいいんですね。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき私はリッチモンドのスリークォーターでした。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でかボブ・ファーガソン、歴代でもリッチモンド一のスリークォーターだ。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして、フォークソングの人気を押し上げたＰＰＭ（ピーター・ポール＆マリー）というグループを案内役にボブ・ディランを聞き始め、そこからピート・シーガー、ウッディー・ガスリーとさかのぼっていきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "動作周波数を変化させてクロックを止めてしまうことも可能なスタティック設計を採用することで、ＤＸＬはスリープモードの消費電力を〇・〇八ミリアンペアにまで抑えたという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この眠らないマシン（いや、スリープ・モードだから眠るのかな）は、とりあえず留守番電話とＦＡＸを取り込んでホームコンピューターを成立させるという素晴らしいお話が次に展開されますので、皆さんまずは秋のコムデックスの速報を読んで、オレの予想が外れていたら大笑いしててね。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しいイボンヌ先生が、ワンツウ、スリー……何々何々！",
              "citation": {
                "source": "舞踏学校見物",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧州でも、一七二四年ダブリン版、アーロン・クロッスリーの『紋章用諸物の意義』ちゅう、予未見の書に、野猪は角を具えぬが、獣中最強のものだ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中で照子が買つて呉れたスリーキャッスルを咬へた彼は、それが随分短くなつてゐるにも関はらずまだ喫して居たのを、照子に注意されて棄てた。",
              "citation": {
                "source": "公園へ行く道",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "であるから政治家の変装たるヂレスリーの亜流を随喜しておっても、真の文人たるヂッケンスやサッカレーに対しては何等の注意を払わなかった。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（ノー、ゼ、ネイバー、イズ、アスリープ）」と小さく云ひながら、向うへ行つて了つた。",
              "citation": {
                "source": "女の子",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームランか、スリーアウト、チェンジかの分かれ目だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワン、ツのスリーで生れたんだよ。",
              "citation": {
                "source": "父が生んだ赤ん坊",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "軈て十五歩も歩んだ時、急に後の騷ぎが止んだ、と思ふと、『ワン、ツー、スリー、泥鰻――』と、校舍も爲めに動く許りの鬨の聲、中には絹裂く樣な鋭どい女生徒の聲も確かに交つて居る。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "軈て十五六歩も歩んだ時、急に後の騒ぎが止んだ、と思ふと、『ワン、ツー、スリー、泥鰻――』と、校舎も為めに動く許りの鬨の声、中には絹裂く様な鋭どい女生徒の声も確かに交つて居る。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
