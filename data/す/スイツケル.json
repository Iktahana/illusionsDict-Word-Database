        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "磁石を砂場に入れると、砂に混じっていた砂鉄が表面にびっしりと吸い付けられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "静電気を帯びた下敷きを頭の上にかざすと、髪の毛が逆立って吸い付けられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "強力な掃除機を使って、カーペットの奥に潜む細かい埃を根こそぎ吸い付ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "だから惣兵衛の横に腰をかけてバットを一服吸い付ける迄の吉之介には、殺意なんか無論、無かった。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッチを擦って徳市のにつけてやり自分も吸い付けると、先に立ってあるき初めた。",
              "citation": {
                "source": "黒白ストーリー",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人はスバスバ吸い付ける。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのさらの上に、まだ火のついているすいがらをのせておき、つぎのたばこにすいつけるための道具なのだそうである。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄をすいつける磁石の力のことらしいのですが、そんな強い磁石があるのでしょうか。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
