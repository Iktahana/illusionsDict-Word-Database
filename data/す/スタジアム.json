        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜、スタジアムの様子を書く。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツェッペリンが再び巨体をスタジアムの上に現す。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日、マリンスタジアムに練習始め。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "話はちょっと飛ぶが、後楽園のスタジアムはあまり恵まれた場所ではない。",
              "citation": {
                "source": "砂漠の情熱",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタジアムの内部は芝生の色も褪せ、風吹けば黄塵が渦巻く。",
              "citation": {
                "source": "砂漠の情熱",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これを逆に云えば、鳶の見えない後楽園スタジアムは佗しい。",
              "citation": {
                "source": "砂漠の情熱",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "このイメージを発展さして、そして考えてみるに、鳶の見えない後楽園スタジアムが存在すると同様に、一羽の小鳥もいない心理風景も存在しよう。",
              "citation": {
                "source": "砂漠の情熱",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただスタディオン〔スタジアム〕の前の往来で、いろんなもの売りが出て来て、巡査が来るとにげ出すところなどは現代風俗画として或興味はあった。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえりにもとの砲兵工廠の横を通ったら、今あすこは後楽園スタジアム九月開場予定として工事をやって居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカのシェイ・スタジアムのコンサートで、ビートルズは、一曲だけ、うたわず演奏せず動作だけやってみせた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
