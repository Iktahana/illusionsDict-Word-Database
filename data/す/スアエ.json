        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昼食の時、奥テル子のお膳の上を見て、そこに海苔で巻いたおひたしの緑、ゆで卵、焼ざかなのあぶりの照りを眺め、なかんずく若さぎの酢和えが眼をとらえた。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は奥テル子からその若さぎの酢和えを貰い、熱い粥が食べたくなった。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏目にたたすあえかさに、ひと日は、白き難波薔薇夕日がくれに息づきし津の國の野を思ひいで。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二伏目にたたすあえかさに、ひと日は、白き難波薔薇、夕日がくれに息づきし津の國の野を思ひいで。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            }
          ]
        }
