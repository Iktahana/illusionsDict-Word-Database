        "examples": {
          "standard": [
            {
              "text": "彼は高校時代からのスウィートハートと、ついに来月結婚式を挙げることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「僕のスウィートハート、愛しているよ」と、彼は照れもせず公衆の前で妻にささやいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔の映画に出てくるスウィートハートのような、純粋で一途な恋に憧れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「……違います……スウィートハートです……」「フフ――ウム」　と巡査は冷やかに笑いながらヒゲをひねった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――小犬どもまでいっしょになって、　トレイも、ブランチも、スウィートハートも、どうだ、みんなわしにほえかかって来るわい」と、ブレースブリッジは大声で言って、笑った。",
              "citation": {
                "source": "クリスマス・イーヴ",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
