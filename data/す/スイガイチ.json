    "definitions": [
      {
        "index": 1,
        "gloss": "flood-damaged area",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
