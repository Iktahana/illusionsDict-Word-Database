        "examples": {
          "standard": [
            {
              "text": "その限定版スニーカーは、コレクターたちの垂涎の的となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、業界で成功を収め、多くの若手にとって垂涎の的となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの最新ガジェット、転売ヤーの間で垂涎の的になってるらしいよ。」と、テクノロジー系ニュースで報じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "宝石マニヤ垂涎の的として、欧州中にも轟き渡っていたかも知れぬ。",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
