    "definitions": [
      {
        "index": 1,
        "gloss": "hydrogen (H)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
