        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つまり友達としては向上心もあり、感受性も活溌で、幾らかはスポーティな、いってみれば手ごたえの鮮やかな女性を好む若い男たちが、いざ結婚のあいてを選ぶとなると案外そのようなタイプとは逆の、いわゆる家庭的と総称されて来ている娘たちの方を妻として安心に思う消極性によってしまう。",
              "citation": {
                "source": "異性の友情",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "快活な、スポーティな雰囲気よりも、かたい決意のみなぎるこの写真の空気は、わたしに複雑な思いをいだかせた。",
              "citation": {
                "source": "ボン・ボヤージ！",
                "author": "――渡米水泳選手におくる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼ですが、大須賀さんで……」　色の浅黒いスポーティな青年がゆっくりと床几から立ちあがった。",
              "citation": {
                "source": "一の倉沢",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "久美子が車のそばまで行くと、格子縞のハンティングをかぶった、いかにもスポーティな初老の紳士が脇窓から声をかけた。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "久美子は探るように大池というひとの顔をながめまわしたが、黒々と陽に灼けたスポーティな顔にうかんでいるのは、感慨を洩らして満足している、いかにも自然な表情だけだった。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "大池というスポーティな紳士の死体は、湖底のどこかで、ひっそりと藻に巻かれているのだろうが、死んだあとでもなお執拗に絡みついて、久美子の運命を狂わせようとしている。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ」　大池忠平と名乗ったあのスポーティな紳士だった。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰がために鐘はなる」などは、肉体的ぬくみと柔軟さとスポーティな確乎さをもっていて新しい一つのタイプでした。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
