        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そういう晩には綿入羽織をすっぽり頭からかぶって、その下から口笛と共に白い蒸気を吹出しながら、なるべく脇目をしないようにして家路を急いだものである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "車中の一行は、明朝の登山を控えて、「この雲では山は雨かな」と心配すれば、「なあに、雲は低いですよ、すっぽり抜けると、上はカラカラの上天気ですよ」などといい合った。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝る時、上人は帯を解かぬ、もちろん衣服も脱がぬ、着たまま円くなって俯向形に腰からすっぽりと入って、肩に夜具の袖を掛けると手を突いて畏った、その様子は我々と反対で、顔に枕をするのである。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "石崖の上の端近く、一高の学生が一人あぐらをかいて上着を頭からすっぽりかぶって暑い日ざしをよけながら岩波文庫らしいものを読みふけっている。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "がらくた壇上に張交ぜの二枚屏風、ずんどの銅の花瓶に、からびたコスモスを投込んで、新式な家庭を見せると、隣の同じ道具屋の亭主は、炬燵櫓に、ちょんと乗って、胡坐を小さく、風除けに、葛籠を押立てて、天窓から、その尻まですっぽりと安置に及んで、秘仏はどうだ、と達磨を極めて、寂寞として定に入る。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにとうとう、一人はバアと音がして肩から胸から腰へかけてすっぽりと斬られて、からだがまっ二つに分れ、バランチャンと床に倒れてしまいました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒服の親仁は、すっぽりと中山高を脱ぐ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、目金を拭こうとして、蝙蝠傘を頤で押えて、うつむいたと思うと、ほら、ほら、帽子が傾いて、重量で沈み出して、見てるうちにすっぽり、赤い鼻の上へ被さるんだもの。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　得三はぎょっとして、四辺を見廻し、人形の被を取って、下枝にすっぽりと打被せ、己が所業を蔽い隠して、白刃に袂を打着せながら洋燈の心を暗うする、さそくの気転これで可しと、「誰だ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と反って飛退り、下駄を脱ぎて、手に持ちはしたれども、腰の骨の蝶番がっくり弛みてただの一足も歩かれず、くしゃりと土下座して、へたへたになり、衣服をすっぽりと引被りて、南無阿弥陀仏南無阿弥陀仏。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも宿を出る時、外套はと気がさしたが、借りて着込んだ浴衣の糊が硬々と突張って、広袖の膚につかないのが、悪く風を通して、ぞくぞくするために、すっぽりと着込んでいるのである。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父のすやすやは、上首尾で、並べて取った床の中へ、すっぽり入って、引被って、可心持に寝たんだが。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれが一人の人間に下したいかなる解釈も、あたかもすべての多角形が円の中にすっぽりとはまるように、その人間に当てはまるのだが、しかし、円はつねに多角形より面積が広いのである。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "呀ッとッと」］云うとイワンの兄は忽ち深い深い穴の底へ落ち込みましたがうまい工合に大そう柔いベッドがすっぽりと体を受けとめて呉れました。",
              "citation": {
                "source": "イワンとイワンの兄",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は鍔広帽子を眼深にかぶり上衣の襟を深く立てて、女は長い睫毛の真黒な眼だけを残してすっぽりと被衣を被っている。",
              "citation": {
                "source": "薔薇の女",
                "author": "渡邊温",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はマントをすっぽり頭からかぶって、見えつ隠れつ、姉を尾行した。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとうその苦心の外套をも廃止して、中学時代からのボロボロのマントを、頭からすっぽりかぶって、喫茶店へ葡萄酒飲みに出かけたりするようになりました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銅像には、まっ白な布が、すっぽり、かぶせてありました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "周さんが、頭から外套をすっぽりかぶり、全身雪で真白になって私の下宿にやって来た。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　帽子をすっぽり亀の子｜竦みで、「ホイ阿陀仏、へい、あすこにゃ隠居ばかりだと思ったら……」「いいえね、つい一昨日あたり故郷の静岡からおいでなすったんですとさ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから幹に立たせて置いて、やがて例の桐油合羽を開いて、私の天窓からすっぽりと目ばかり出るほど、まるで渋紙の小児の小包。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」煙草をぽんとほうって、二重まわしを脱ぎ、さらに羽織を脱ぎ、ちょっと思案してから兵古帯をぐるぐるほどき、着物まですっぽり脱いで、シャツと猿又だけの姿になり、「女を肉体でしか考えることができないとは、気の毒なものさ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風邪をひかないようにほっぽこ頭巾をすっぽり被り、足にはゴムの長靴を穿いて。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "木之助はすっぽりほっぽこ頭巾をかむって歩き出した。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっぽりと被るのが、寒さを凌ぐより、半分は見得で、帽子の有無では約二割方、仕立上りの値が違う。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　脊の高い方は、それでも外套一着で、すっぽりと中折帽を被っている。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おや……帽子はすっぽりでも、顔は分りましたから、ちょっと挨拶はしましたけれど、御堂の方へ心はせきます。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主はさぞ勝手で天窓から夜具をすっぽりであろうと、心に可笑しく思いまする、小宮山は山気｜膚に染み渡り、小用が達したくなりました。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い神は、すぐそのわけをおさとりになって、足の下を、とんときつく踏んでごらんになりますと、そこは、ちゃんと下が大きな穴になっていたので、からだごとすっぽりとその中へ落ちこみました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっぽりと蒲団をかぶり、足をちぢめ、舌を出してみぬ、誰にともなしに。",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
