          "literary": [
            {
              "text": "それにストロベリーシェイク！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきからずっと、この〈ストロベリー・フィールズ・フォーエヴァー〉を、くりかえし、くりかえし、かけている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈ストロベリー・フィールズ〉は、もういちどフェイドインしたら終わる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座三越にゆく、ポンジーの紙箱入白粉二つ、ストロベリー口唇棒だけパラフィンに包んだの二つ、12.75。",
              "citation": {
                "source": "日記",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレンジ・フリーズ　１ドル10　ルート・ビア・フロート　１ドル　アイスクリーム・ディッシュ　95セント　ストロベリー・サンデー　１ドル10　バナナ・スプリット　１ドル60　この店が開店したときからここにこのままある品書きだ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストロベリー・サンデーはストロベリーではなくチョコレートのようだし、バナナ・スプリットはぜんたいが一様に色あせたシルエットになっていて、アメリカで育った人以外には、これがバナナ・スプリットだとはわからないだろう。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大庭を連れて外出、不二アイスの二階で、チキンコロッケとトマトクリームスープ、シュガーコーン、ストロベリーショートケーキ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
