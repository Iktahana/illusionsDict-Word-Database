        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "帝劇のトーキー披露会で貴方とスレ違ったこともあるわ……御存じなかったでしょう」　私は正直にうなずいた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い女とスレ違っても振り返る力がなくなってしまった。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らぬ者が見たら、銀座裏でギャング同志がスレ違った程度の手軽い挨拶に過ぎなかったが、しかし、その内容は雲泥の違いで、両翁とも互いに、往年の死生を超越して気魄が、老いて益々｜壮なるものが在るのを一瞥の裡に看取し合って、意を強うし合っているらしい。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "田圃道でスレ違いさまにお辞儀をして行く村の娘の髪毛の臭気を嗅いでも、彼は烈しいインスピレーションみたようなものに打たれて眼がクラクラとする位であった。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "向う側を見ると、飛び降りた若い男は、スレ違って停車した電車の蔭に隠れるようにして西門通りの横町に走り込んだ。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りに、路傍でスレ違う赤の他人と同様の冷淡さが、あらわれていた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "交通規則の中に、夜間、自動車同志がスレ違った時にヘッド・ライトを消すべしという箇条は別にない。",
              "citation": {
                "source": "衝突心理",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしや蟹口のトラックに行き合いはしないだろうかと思ってヒヤヒヤしいしい運転して行くところへ、向うから来たトラックがヘッド・ライトを消したから、こちらも直ぐに消したが、その消した瞬間に、蟹口の頑固な顎と、物凄く光る眼が、真正面に見えたのでゾッとしてスレ違った。",
              "citation": {
                "source": "衝突心理",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、スレ違ってしまった。",
              "citation": {
                "source": "切捨御免",
                "author": "――貞操なきジャーナリズム――",
                "note": "青空文庫"
              }
            },
            {
              "text": "想像もできないようなスレ違いが生じることもある。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっとスレ違おうとしたのである。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやくおいでなされませ」　青衣の童子は、そう告げて、李逵のそばをスレちがった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、庁内もずんと奥の、大牢門と呼ぶ獄界の境まで来ると、ここではふとスレちがった男が、「おやっ？",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――細川の隊とスレちがいかけた。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            }
          ]
        }
