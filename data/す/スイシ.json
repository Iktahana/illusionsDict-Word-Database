  {
    "uuid": "f651b872-9bfc-5946-bf48-399c5e53b9a2",
    "entry": "垂死",
    "reading": {
      "primary": "すいし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
