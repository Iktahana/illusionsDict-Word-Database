[
  {
    "uuid": "417d607d-cd46-5955-a2ee-6fb6bb17f9b9",
    "entry": "出師",
    "reading": {
      "primary": "すいし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dispatch of troops",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "出師の表を読みて涙をおとさぬ人は猶友とすべし、この花好まざらん男は奴とするにも堪へざらん。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてその頃は、征清の出師ありし頃、折はあたかも予備後備に対する召集令の発表されし折なりし。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "共王は斉と結んで、魯を討とうとし、其の出師の期を告げる為に巫臣を使として斉に遣わすことにした。",
              "citation": {
                "source": "妖氛録",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神功皇后の新羅征伐は、熊襲の背後を成す新羅を伐つと共に、この任那を新羅の圧迫より救援されるための出師であつたとも云はれる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此上書は『後漢書』の班超傳に附載されてあるが、筆情兼ね備はる點に於て、孔明の出師表や、李密の陳情表に比敵し得べき名文と思ふ。",
              "citation": {
                "source": "東漢の班超",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "出師表は忠義を骨子とし、陳情表は孝行を骨子とし、班昭のは友情を骨子として居る。",
              "citation": {
                "source": "東漢の班超",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時劉禪に上つたのが、かの前出師表で、所謂鬼神をも泣かしむると評さるる程の名文である。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に彼の後出師表に、漢賊不兩立。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "我輩は毎年大学における法理学の講壇にてオースチンの学説に説きおよび、この夫人サラーの功績を語る時には、毎にこの序文をもって、かの諸葛孔明の「出師表」に比するのである。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "古人は、「出師表」を読んで泣かざる者は忠臣にあらずといったが、我輩はサラー夫人のこの序文を一読して感涙に咽ばない人は、真の学者ではないと評したほどであった。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "謀此に出でず、之を半屬の國たらしむ、年々兵禍あつて、一毫の租税なく、我に出師の責あるも、統一の權なし、此に於てか遂に彼をして李后に屬せしむ。",
              "citation": {
                "source": "深憂大患",
                "author": "竹越三叉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴻業果たし收むべきその時天は貸さずして出師なかばに君病みぬ、三顧の遠きむかしより夢寐も忘れぬ君の恩答て盡すまごゝろを示すか吐ける紅血は、建興の十三秋なかば丞相病篤かりき。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、一同｜対の鼠いろの木綿袷に浅黄の袴、足半という古式の脚絆をはいているところ、今や出師の鹿島立ちとも見るべき仰々しさ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちかく出師せんとする柴田がたの滝川｜征伐、その兵を糾合する諸大名への檄文であるらしい。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（出師の準備中に）　と、いう説や、（いや、すでに春日山を発し、陣中で）　ともいわれているし、また、（平生、大酒家であったため、卒中で仆れたことは確かである）　と、常識的なうわさもあり、そうかと思うと、春日山城内で、厠にゆくところを、刺客のために殺された――などと強いて奇説を附会する者もあった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出師のご発議、われらに於てもしかるべく存じます。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉の出師は思いどおり実現された。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "程普は由来、大都督｜周瑜と、余りそりのあわない仲だったし、こんどの出師にも、反対側に立っていたが、いまは口を極めて、周瑜の人物を賞揚していた。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――またこのたびの出師にその戦端を陸地から選ぶは不利。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸卿よろしく出師の準備にかかれ」　すると、議堂の屏風の蔭から、誰かひとり進み出て、甲高い声していった。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "出師の表を読んで泣かざるものは男児に非ずとさえ古来われわれの祖先もいっている。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "出師の表一　馬謖は云った。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に有名な前出師の表は実にこのときに成ったものである。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりに籠居を離れて、朝へ上ると、彼は直ちに、闕下に伏して、出師の表を奉った。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ひとり後主｜劉禅の憂いに止まらず、出師の表によって掲げられた孔明の「北伐の断行」は、俄然、蜀の廟堂に大きな不安を抱かしめた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "出師の表一千余字、かりそめにも恨みがましい辞句などはない。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜀の出師は国を傾けてくるの概ありと知ったからである。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "二｜次出師表一　蜀呉の同盟はここしばらく何の変更も見せていない。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも H0 - A がＫより大きいような人ならばその人は年中怒りっぽくまた憂鬱になりやすいし、また H0 + A がＫより小さい人は年中元気がなく悄気ていることになる。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、あのひとは、すぐにかっとなりやすいし、それに、ポルトガルのことばっかし話しているんですもの」「あの中国のニワトリさんたちは、ずいぶんひそひそ話をしているねえ」と、アヒルの夫婦が言いました。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
