        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "水上飛行機が桟橋に横付けされ、観光客が次々と降りてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "上空からサンゴ礁を眺める水上飛行機のツアーは、この島で一番の人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いつか水上飛行機を自分で操縦してみたいんだ」と彼は夢を語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "タイヤなしで飛行機をとばすわけにも行かんからね」委員Ｋ「水上飛行機と飛行士ばかり作っちゃどうかね。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから新らしい潜航艇や水上飛行機も見えないことはなかった。",
              "citation": {
                "source": "三つの窓",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳山と岡山と、広島と姫路にはそれぞれ水上飛行機が待機していたんだよ。",
              "citation": {
                "source": "人間レコード",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月十六日の午前四時、アムンセンは五人の同志と共に、水上飛行機ラタム号に乗つて、ノールウェー北岸のトロムソ港から飛びだしました。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "池はまるで海の様で、水上飛行機がブー／＼／＼滑走してゐました。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは別府の海にうかんでおる水上飛行機が十分間十円で客を乗せて飛ぶのだそうである。",
              "citation": {
                "source": "別府温泉",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
