    "definitions": [
      {
        "index": 1,
        "gloss": "several animals",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一群の鶏も、数匹の白兎も、ダリヤの根方で舌を出している赤犬に至るまで。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして隣りの物干しの隅には煤で黒くなった数匹のセキセイが生き残っているのである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の奥の、やや広い草原に、異形の物が十数人、と言ふのか、十数匹と言ふのか、とにかく、まぎれもない虎の皮のふんどしをした、あの、赤い巨大の生き物が、円陣を作つて坐り、月下の宴のさいちゆうである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、濡れてぴんぴんしてゐるえびが数匹はいつてゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "婚礼の祝宴の夜、アグリパイナは、その新郎の荒飲の果の思いつきに依り、新郎｜手飼の数匹の老猿をけしかけられ、饗筵につらなれる好色の酔客たちを狂喜させた。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和五年一月、渋柿）　　　　　　　＊「三毛」に交際を求めて来る男猫が数匹ある中に、額に白斑のある黒猫で、からだの小さいくせに恐ろしく慓悍なのがいる。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ア画馬は馬に審査せしめよとて、馬数匹を牽き来らしめ諸画を示すに、アの画馬を見て始めて鳴いたからアを一等とした。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃私の家には、十数匹の猫がいたが、いずれも肥え太った綺麗な猫であった。",
              "citation": {
                "source": "私の子供時分",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父さんは外から帰って来る時には、いつも咳払いするのであったが、十数匹の猫はこの声を聞くや否や、先を争って門の所まで行って、その老主人を迎えるのであった。",
              "citation": {
                "source": "私の子供時分",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇入穴、まだ早いが、今日も裏で数匹のろ／＼してゐた、蛇は嫌だ、見るとぞつとする。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて姿を現わしたのを見れば、十数匹の甲州猿であった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道具というのは、大きな釣針を畳糸でステッキの先に結びつけたもの、蚯蚓数匹、大きな竹の筒、風呂敷一枚、それだけなんだ。",
              "citation": {
                "source": "鯉",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い金網のなかに親仔数匹の猿がはいっていた。",
              "citation": {
                "source": "オランウータン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち数匹の狼である。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、数匹の狼が、ヒュウヒュウと床下へ飛び込んだ。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "総じて獣類は胎生なれど、多くは雌雄｜数匹を孕みて、一親一子はいと稀なり。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "棄てられた小犬と、数匹の金魚と亀の子も飼つてゐた。",
              "citation": {
                "source": "哀しき父",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "……助けてくれ――ッ、助けてくれ――ッ」　逃げるその後から蜥蜴の群は、吹矢のような速さで走り、十数匹の蛇は鎌首を持ち上げ、波のように背中を蜒らせて追い、蜈蚣の大群は壁から下りて、床の上をさながら漣のように、騒ぎ立てながら追いかけた。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは、さかりがついて、一匹の牝猫を中心に、集まってきた数匹の猫と一団になり、ぎゃあぎゃあ騒ぎたてていましたが、そのままどこかへ行ってしまって、一週間たっても、十日たっても、戻って来ませんでした。",
              "citation": {
                "source": "水甕",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の庭で、猫が数匹、ぎゃあぎゃあ騒いでいました。",
              "citation": {
                "source": "水甕",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一匹の牝猫を中心にして、数匹の牡猫が蹲まっていました。",
              "citation": {
                "source": "水甕",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その一例として、この物語に関係のあることを述べれば、片隅の卓子の上の瓶に、数匹の蛭が泳いでいた。",
              "citation": {
                "source": "非情の愛",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな銚子二本、小鯵の干物数匹、たくあん。",
              "citation": {
                "source": "ヘヤーピン一本",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は三時半まで起きてゐ、二たび寝て大小数匹の南京虫を捕へ、碌々眠らずして一夜を明かした。",
              "citation": {
                "source": "南京虫日記",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "話声のようでもあり、また数匹の獣が低くうなりあっているようでもあった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "このほど、宮城のまわりの堀渫いをした時に数匹のすっぽんが網に掛かってきたのを見ると悉く爪の先が鋭くとがっていたというが、これはお堀の底が、泥であるのを物語っているのである。",
              "citation": {
                "source": "すっぽん",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな野面の果てには、十数匹の牛と馬が一しょになって、彼処此処と移りながら草を食べていた。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "或村では彼は数匹の犬に追われて逃げ惑うた。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに豪酒の河童共と雖も、僅かに数匹で一斗瓶底近くまで呑みほしては、酩酊せざるを得まい。",
              "citation": {
                "source": "河童酒宴",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば、袋のなかに僅かに十数匹の蝗が、飛び脚を踏ん張り合って、揉み合っているだけである。",
              "citation": {
                "source": "岡ふぐ談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
