    "definitions": [
      {
        "index": 1,
        "gloss": "good luck to come (esp. as an omikuji fortune-telling result)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "中央に立って歩いて来るのは、この製鉄所切っての怪力の持主で、名前は又野末吉、綽名をオンチという古参の火夫であった。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞では盛んに書き立てた……白昼の製鉄所構内で衆人環視の中に行われた、天魔の如く大胆なる殺人強盗……犯人は大地に消え込んだか……実見者又野末吉氏談……前代未聞の怪事件なぞと……殊に後頭部を粉砕されながらも勇敢に抵抗した西村会計部員の奇蹟的な気強さを、製鉄所長と医学博士の談話入りで賞讃した。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄首里の人末吉安恭君二月号に載せた予の不毛婦女に関する説を読んで来示に、かの辺りで不毛をナンドルー（滑らか）と俗称し、少し洒落ては那覇墓と唱う、琉球の墓は女根に象る、普通その上と周縁に松やうず樹｜芒等を栽え茂らす、しかるに那覇近所の墓に限り多くは樹芒少なく不毛故の名らしい。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に言った末吉氏は純粋の琉球人、篤学の士、予氏より未聞を聞く事多い。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "末吉安恭氏来示に、琉球人は山羊を温柔な獣とせず、執拗｜剛戻な物とす。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃までは九〆といって晩の八時頃になると、円覚寺や天界寺や天王寺や末吉の寺の鐘が同時に鳴り出すので、何となく寂しいような気がして、夜はたいがいは家の夢ばかり見ていた。",
              "citation": {
                "source": "私の子供時分",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の店の前髪の末吉という私より二つ年上の少年が、いいと言うのを聞かずに市村という三里ある村まで送って来てくれた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよお別れという時、末吉は涙をこぼしていた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "市村の橋の袂で別れた前髪末吉の姿だけでも今となってはどんなに尊いものであろう。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中で、末吉の貝塚は、稍望みがある。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "末吉の貝塚",
                "note": "青空文庫"
              }
            },
            {
              "text": "望蜀生が完全なる土器の蓋を掘出して來たので、急に行きたい氣に成り、三十六｜年十二｜月十四｜日に、幻花翁、望蜀生、玄川子との四｜人連、品川から汽車で鶴見、それから一｜里弱、下末吉村へと行つた。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "末吉の貝塚",
                "note": "青空文庫"
              }
            },
            {
              "text": "同月十七｜日、いよ／＼發掘に行く事としたが家人も其状態が見たいといふので、然らば其用意して行くべしとて、妻と婢とに糧食を携へさせ、余は愛する親族の六｜歳の幼女を背に負ひ、玄子は器具など擔ぎ、鶴見にて電車を降り、徒歩にて末吉に著いた。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "末吉の貝塚",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからは霎時遠ざかつて居たが、四十一｜年六｜月四｜日に、一人で寺尾、子安、篠原、大網、樽、駒岡の諸遺跡を過ぎて、末吉に掛つて來ると、這は抑も如何に、這は如何にである。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "末吉の貝塚",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいろ／＼手が引けなくつて、漸く七｜月十一｜日に末吉へ駈付けて見ると、貝殼の山だけ白く遺つて、あゝ因業な親分等は、一人も影を見せぬのであつた。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "末吉の貝塚",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十二日　晴、岩川及末吉町行乞、都城、江夏屋（四〇・中）九時の汽車に乗る、途中下車して、岩川で二時間、末吉で一時間行乞、今日はまた食ひ込みである。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "家譜に拠るに、此年瑞英の六男末吉が生れた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "又六男末吉の縁談があつて、成らずして罷んだ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中の末吉平左衛門、中瀬九郎兵衛の二人が、美吉屋から帰つた女中の話を聞いて、郷の陣屋に訴へた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――や、ありがたい、悦びなはれ、……何も案じることはないわ、病気まもなく快方に向ふべしとあるわ、末吉やがな」　と、「高等乞食」の眼の前に突出した。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は、毎電、東京毎日、やまと、日本の記者と共に、山越をして、駒岡貝塚、末吉貝塚の遺跡を過ぎ、鶴見に出て歸宅した。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "お穴樣の探檢",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九　当時、末吉橋東詰松屋町に、豊竹呂昇の持小屋「松の亭」というのがあった。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は末吉（五十五）母はおなか（六十二）と言ふ。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "島袋源一郎さん・川平朝令さん、それから亡くなつた麦門冬末吉安恭さん・仲吉朝助翁である。",
              "citation": {
                "source": "「琉球の宗教」の中の一つの正誤",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡くなつた麦門冬　末吉安恭さんである。",
              "citation": {
                "source": "組踊り以前",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此文章が、伊波さんの本の役に立つ傍、亡き南島第一の軟流文学・風俗史の組織者――たるべき――末吉さんの為の回向にもなれば、この上なく嬉しいと思ふ。",
              "citation": {
                "source": "組踊り以前",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三東京へ引き出しても、不覚はとらなかつた筈の琉球学者末吉安恭さんは、島の旧伝承の生きた大きな庫であつた。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "首里の川平朝令さんの家へ、末吉さんと二人で、およばれに行つてゐた。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう話された時、『末吉さん。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇部末吉は、汽車の中で、悪夢の名残に唾を吐きかけたい気持になつてゐた。",
              "citation": {
                "source": "山形屋の青春",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
