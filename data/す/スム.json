[
  {
    "uuid": "7b04553d-ba64-5e36-a705-9075388f60de",
    "entry": "済む",
    "reading": {
      "primary": "すむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to finish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "遉に現在の耕二を話題にすれば、そこに集つた人達も空想の悲哀を、茫然ながら感じないで済むものとみえて、稍々沈んだ調子で話されてゐた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに黄ばんだしみのあるのも鼠のいたずらじゃないかしらんなど独語を云いながら我も手伝うておおかた三宝の清めも済む。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さん、直ぐ帰って来ますよ、坊やを連れて行って来まさ」（大丈夫ですよ、向うの気の済むまで居て来ますよ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、間違ったことが書いてあれば、読者はそれによってその筆者がそういう間違ったことを考えているという、つまらない事実ではあるがとにかく、一つの事実を認識すればそれで済むのである。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえの居ると同じ屋の棟の下にいれば気が済むのだから、決して祭りの邪魔はしないのだから」「それが、おさせ申上られないことは、お出でにすぐ申上げたではございませんか。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものごとが凡て、原則どおり単純に行って済むのなら世の中は案外やさしいものです。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ舷一つ跨げば事が済むことなのだから、ちょっと危かった」「どうしてそれを思い止ったのか」と柚木はせまい船のなかをのしのし歩きながら訊いた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナプキンを決めておけば食事｜毎にその洗濯代として二十五サンチームぐらいの小銭を支払わなくても済むからである。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "体に障ってはと思いまして葬式が済むと車で御送り申した次第です。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が心の何方に走れりとも知らで、乳に倦きれば乳房に顔を寄せたるまゝ思ふ事なく寐入し児の、頬は薄絹の紅さしたるやうにて、何事を語らんとや、折々曲ぐる口元の愛らしさ、肥えたる腮の二重なるなど、かかる人さへある身にて、我れは二タ心を持ちて済むべきや。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢さら二タ心は持たぬまでも、我が良人を不足に思ひて済むべきや。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、如何に評判の絵でも、自分に興味のないものは一度きりで見ないで済むし、気に入った絵なら誰に気兼ねもなく何遍でも見て楽しむことが出来る。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "危険線のすぐ近くまで来てうろうろしているものが存外その境界線を越えずに済む、ということは病気ばかりとは限らないようである。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の用だ」　「これは都田村の親分で御座いますか」　安五郎が吉兵衛に、　「吉兵衛、お前の知ってる人か」　「へえ、この近在の村の若い者で御座いますよ」　「そうか、七五郎さんとやら、一体俺に何の話か知らねえが、丁度今将棋の面白え処だ、もうじき済むから済んでから話を聴こう。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう直き済むから済んでから話を聴こう。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "祈祷が済むと、現に族長になつてゐるスタニスラウスが、先頭になつて席を起つた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の話しぶりはきわめて卒直であるものの今宵初めてこの宿舎で出合って、何かの口緒から、二口三口｜襖越しの話があって、あまりのさびしさに六番の客から押しかけて来て、名刺の交換が済むや、酒を命じ、談話に実が入って来るや、いつしか丁寧な言葉とぞんざいな言葉とを半混ぜに使うようになったものに違いない。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから改まって挨拶が済むと、雑談に移り、武は叔父叔母さし向かいで、たいがい毎日碁を打つ事、娘ふたりはきょう上野公園に散歩に出かけた事など聞かされた。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこのような植物の多様な分化を生ぜしめたその同じ気候風土の環境の多様性が日本人という人間の生理を通してその心理の上にまでも何かしら類似の多様性を分化させるような効果をもたないで済むものであろうか。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私が今こんな事を書かなければ、私のこの過失は関係者の外には伝わらないで済むかもしれない。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらあ黙って聞き手になるから」「どうも相済みません」「済むも済まねえもあるもんか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それで、千さんの居どこが判ったらどうなるんでしょう」「相手が死んだ以上は無事に済むわけのものでねえ」「親分が見つけたら捉まえますか」「いやな役だが仕方がねえ」「じゃあ、すぐに捉まえてください」　お登久はいきなり起ちあがって、床の下の戸棚をがらりとあけると、戸棚の隅には若い男の蒼ざめた顔が見えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂が済むと、また別の広い座敷へ案内された。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも食事が済むと、また少し休息するがよかろうと云って、このあいだの女はしずかにその席を起った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "あさ飯が済むと、このあいだの女がまた出て来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜があけると、すべてきのうの通りに、顔を洗って、髪をあげて、化粧をして、あさ飯が済むと庭へ連れ出された。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、この地に棉産を得るとせば、日本は米国より棉花の輸入を仰がずとも済む時節が来るかもしれない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも物干しの一方の方へ寄っていれば見られないで済むのであるが、雨戸が開いている、それを見て大きい声を立てて注意をされたりするとなおのこと不名誉なので、彼がやって来ると匆々家のなかへはいってしまうのである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが済むと怪しげな名前の印度人が不作法なフロックコートを着て出て来た。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "信義がないからといつて、人間同志が会はなくてすむやうになるわけはない。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
