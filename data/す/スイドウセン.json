        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それが近頃になって、どうかした機会に、近所のラジオ屋に来て見てもらったら、このラジオ屋さんはちゃんと心得ていてさっそく水道栓へアースを引っぱって、アンテナを天井の廻りに引延ばして、ともかくも音だけは旧通りに聞こえるようにした。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして水道栓の水の滴り、誰かしら吹き鳴らす昼の銀笛……　私の気まぐれな聯想はまた鮮な郊外の景色に手を振つてゆく郵便脚夫の白い帽子に飛んでゆく。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "水道栓の傍らには素人製のベンチがあつて、涼みがてらの老人やら水汲みの人達で終日賑はつてゐた。",
              "citation": {
                "source": "真夏の朝のひとゝき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "水道栓に縛りつけられたホースの陣列の間を、静に装甲車が通っていった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "格子のはまった二階の窓からは、下の水道栓に集まって来る近所の人や、その人たちの家の裏門などがあけ透けに見えた。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗面台はあるが、水道栓もなくしたがってまた流しもなく、一々下から水を持って来て、そしてその使った水を流しこんで置く、そのバケツの中へだ。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして同じ壁の入口の向うの、寝台の足の方の隅には、上に水道栓が出ていて、その真下に白い瀬戸物の便所が大きな口を開いていた。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その右の方の半分のところには、隅っこに水道栓と鉄製の洗面台とがあって、その下に箒と塵取と雑巾とが掛かっていて、雑巾桶らしいものが置いてある。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "板をもと通りに直して水道栓をひねって手を洗う。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間ぎめで、順ぐり用便させるとき、すこし手間をかけている男に、きくにたえない悪罵をあびせながら、水道栓にホースをつけて、かがんでいる者の頭の上から水をぶっかけた。",
              "citation": {
                "source": "本郷の名物",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそこで温めてくれる一杯の濃い珈琲を味いながら、往来の角に立つ石造りの水道栓の柱を眺め、水瓶を提げて集る婦女を眺め、その辺に腰掛けて編物する老婆の鄙びた風俗を眺めては、独りで時を送るのを楽みにした。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど左の壁には、いくつも並んで水道栓と流しがついていた跡がある。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても、手前の、水道栓のあとのある室を通って来なければ、こっちへ入れないように出来ている。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水道栓のわきに、低くミーチャの手拭と歯ブラシとがぶら下ってる。",
              "citation": {
                "source": "楽しいソヴェトの子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところどころに急設された水飲場の水道栓から溢れる水が、あたりの砂にしみている。",
              "citation": {
                "source": "インターナショナルとともに",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　　　　　　　　夜　小さい鏡が水道栓の横の柱にかかっている。",
              "citation": {
                "source": "ソヴェト同盟の三月八日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人が思い出したように立って、室の隅の水道栓のところで含漱を始めた。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エミール・ヤニングスが世界的映画「※リエテ」の中で、食卓から立ってしめたと同じプロレタリアの水道栓が壁にあった。",
              "citation": {
                "source": "無題（七）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "油虫の多い炊事場は、二階階段の上り端に、便所と隣りあつてあるが、流しもとは狭くて水道栓は一つ、ガス焜炉は二つしかないので、支度時には混雑して、立つて空くのを待つてゐなければならない。",
              "citation": {
                "source": "日本三文オペラ",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "程もなく洗面器の処から引返しました若林博士は、まず屍体の足の処にボール鉢を置いて、そこに取付けてあります水道栓のホースを突込んで、屍体の脚部から背中へかけた解剖台面に水を放流し初めました。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "リザ・セミョンノヴナは芝居へ行ったし、ナースチャの台所では、水道栓からしたたる水の音がきこえるだけであった。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長靴ばきの道路人夫が、木の輪のついた長いゴムホースを、角の反宗教書籍出版所の壁についてる水道栓から引っぱって、ザアザア歩道を洗いだした。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼のボーが鳴って、洗面所の水道栓が一時に盛にジャージャー使われるので冷たい滴をいっぱいつけた。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "法水は扉の横手にある水道栓に眼を止めたが、それからは、昨夜のうちに誰か水を出したと見えて、蛇口から蚯蚓のような氷柱が三、四本垂れ下っている。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その部屋のまん中には、壺を埋けたような穴が三つあって、そのまた穴の上には、水道栓が蛇口を三つ揃えていた。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "与次郎は共同水道栓の傍に立つて、此夏、夜散歩に来て、あまり暑いから、此所で水を浴びてゐたら、巡査に見付かつて、擂鉢山へ馳け上がつたと話した。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "音と云つたら副室で沸る鉄瓶の音と、廊下の前の横長い手洗場で折折医員や看護婦さんが水道栓を捩ぢて手を浄める音と、何処かで看護婦達の私語する声と、看護婦の溜で鳴る時計の音と、其れ位のものである。",
              "citation": {
                "source": "産褥の記",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミズテン芸者も気のきいたのは、ウチの水道栓は酒瓶に沿つて流れてゐるからアルコールが沁みてゐるよ、ぐらゐの返事は致しますよ。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして木戸から共同水道栓の所へ出ようとした時小母さんが家の裏口から突然姿を現わした。",
              "citation": {
                "source": "少年の死",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "共同水道栓がその真中にあって、土地がじめじめしていた。",
              "citation": {
                "source": "掠奪せられたる男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
