    },
    "definitions": [
      {
        "index": 1,
        "gloss": "by far",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "沢山に並べた栗のいがばかりしゃぶらせるような教科書は明らかに汽車弁当に劣ること数等であろう。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう意味では音楽自身よりもこうした音楽映画は数等複雑多様なディメンションをもった芸術であると思われる。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな幼稚なものでも当時の子供に与えた驚異の感じは、おそらくはラジオやトーキーが現代の少年に与えるものよりもあるいはむしろ数等大きかったであろう。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすればこの赤露の絵本などよりは数等すぐれた、もっと科学的に有効適切で、もっと芸術的にも立派なものができるであろうと思われる。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "連句は音楽よりも次元的に数等複雑な音楽的構成から成立している。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども今の裁判官に任せて置くよりも、数等、数十等正確な事実の認定が出来る。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までよりも更に数等深い鋭い恐怖に襲われつつ、白昼の夢遊病者のようにノロノロと自分の周囲を見まわした。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者のほうが患者よりも、数等みじめな生活をしている。",
              "citation": {
                "source": "饗応夫人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも数等恐ろしい恥辱が追立てるのだから死をおそれる気持は全然なかった。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪魔式鼻の表現の苦手は、いつでも音なしい正直な人間か又は数等｜上手を行く明眼達識の士かであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "方角や歩数等から考えると、私が、汚れた孔雀のような恰好で散歩していた、先刻の海岸通りの裏｜辺りに当るように思えた。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の容貌に就いては、僕のほうが君より数等きびしい審美眼を具有しているつもりだがね。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "服装は宮より数等立派なるは数多あり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤倉に比較すると、温泉はかれにあつて、山はこれかれに勝ること数等である。",
              "citation": {
                "source": "スケツチ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「然し汝よりも数等醜い妖魔共が到る処に王となつて、縦な快楽に耽つてゐるではないか。",
              "citation": {
                "source": "闘戦勝仏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は十七歳で父が二十四歳で、彼等は熱烈に恋し合つてと云ふ噂だが――然し多分母の方はそれ程でもなかつたらう、純七郎の容貌に比べたら彼女の方が数等優つてゐたであらうことは、現在でも一見して想像がつく――十七歳の母を想像すると、私は極めて快い幻に恍惚とする……私は様々な情景を想像した。",
              "citation": {
                "source": "痴想",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "道子に比べると千代子の容貌が数等優つてゐるのを私は沁々と味つて、大変いゝ気持がしました。",
              "citation": {
                "source": "砂浜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "合田氏は、私の今使っているモデルの狆を口ではそれと悪くはいわないが、この狆よりも数等｜上手の狆がいることを話された。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "好き狆のモデルを得たはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏通りも同様で、表通りよりは新開地式であるが、それでも丸の内のソレより数等上である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺だつて、これくらゐの恰好をつけれあ、まんざらの男前でもないではないか、少くとも、あんな安物仕立の勉助輩よりは、数等立派であり、仲々分別臭くも見えるではないか、あんな奴等に馬鹿にされ、小突きまはされてグウの音もあがらなかつたなんて、余ツ程あの時は何うかしてゐたといふものだ……。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し斯んなにも絶対にメイ子を信じてゐられるのは幸福だが――と私は思つたり、然し太十等の声が誰が聞いても私よりは数等傑れてゐると思ひ出したりすると、無性に自信の欠けた悲しみが巻き起つて来て危うく涙が滾れさうになつたので、慌てゝ、うたつた。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴下は科学者であるよりも、数等卓越した政治家なんです。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球上においてはなるほど、人類が最も知能にすぐれてはいるが、この広大なる宇宙には、われら人類よりも数等数十等高級な生物が棲息しているだろうことが容易に想像されるのだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の老人の家柄は、今移転して行かうとして居る家族よりは、数等すぐれた家柄であつた。",
              "citation": {
                "source": "朝",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、天は不幸なるこの重右衛門にこの纔かなる恩恵をすら惜んで与へなかつたので、尋常よりも尚数等愚劣なるかれの妻は、この危機に際して、あらう事か、不貞腐にも、夫の留守を幸ひに、山に住む猟師のあらくれ男と密通した。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中にはお前さんなどよりも数等｜利かぬ体で、立派な事業を為た人はいくらもある。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "照子に比べて千代子の容貌が数等優つてゐるのを私は、沁々と味はつて、悦びを感じました。",
              "citation": {
                "source": "晩春の健康",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句の如きは俗のまた俗なるものにして、前二句に比するもまた数等の下にあり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "（但し千代の朝顔の句、秋色の桜の句｜抔に比すればこの句の高きこと数等なり）もし絶間といふ語を改めなば今一段の佳句ともなるべし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女の肩のさびしい斜線の、すうとうすい鉛筆でひいたように薄く流れているのを、男はその細い腕のあたりまで目にいれて言った。",
              "citation": {
                "source": "香爐を盗む",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
