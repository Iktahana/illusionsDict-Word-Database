        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "恁くて互に其の間に考案する隙ありき。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓敬と道衍と、故より隙ありしと雖も、帝をして方孝孺を殺さゞらしめんとしたりし道衍にして、帝をして敬を殺さしめんとす。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "太史令は故あって弐師将軍と隙あり、遷が陵を褒めるのは、それによって、今度、陵に先立って出塞して功のなかった弐師将軍を陥れんがためであると言う者も出てきた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼邊の壁に罅隙ありて、一の大なる物を安んず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "間問題相共にその自らの力を試さぬ人と行かじ、彼等の心には隙あり、油断あり。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる隙ありと見たのか、玄八、やにわに、「ううむ」　一声！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "右にすきあるごとく見ゆるときは左に真のすきあり――柳生の大先生が名言をおっしゃっていらあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
