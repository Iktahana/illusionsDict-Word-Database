  {
    "uuid": "9c89d39a-1345-5cd9-a168-0e2fde2188a4",
    "entry": "数件",
    "reading": {
      "primary": "すうけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
