    },
    "definitions": [
      {
        "index": 1,
        "gloss": "several houses",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "汽車、利根川の鉄橋に差し掛かれば、雨はますます激しく、ただ見る、河水は氾濫して両岸湖水のごとく、濁流｜滔々田畑を荒し回り、今にも押流されそうな人家も数軒見える。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "その邸は二十七、八年頃に取毀されて、その跡に数軒の家が建てられた。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで他の家から嫁を迎えようと思って、数軒の家の女を見たが十娘におっつく者はなかった。",
              "citation": {
                "source": "青蛙神",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつは通りをふらふらすると、酒場を数軒はしごして、最後のには半時間ほど居座りました。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く同じ造りの二階家が数軒並んで、隣の二階にもわたしと同じやうな姿の若い士官がゐて夜更まで灯りの下で勉強して居り、そのまた隣も海兵の合宿所で時々、今日ハ手ヲ取リ語レドモ　明日ハ雲井ノヨソノ空　行クモ留ルモ国ノタメ　勇ミ進ミテ行ケヨ君――と合唱する聞くだに健やかな血の湧き立つ軍歌が響いた。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その邸は二十七、八年頃に取り毀されて、その跡に数軒の家が建てられた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇山にや霧立つ雉子の子さへ越後恋しかほろたたく四万温泉の一夜　四万は渓谷の中のさびしい温泉場であるが、相当な設備の温泉旅館が数軒ある。",
              "citation": {
                "source": "大利根八十里を溯る",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "両側には植え込みを持った家が数軒ならんでいて、もしこの家のどれかに逃げこんだとすると、すこぶる捜索が厄介です。",
              "citation": {
                "source": "墓地の殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草がない、数軒探しまはつたがない、詮方なく“光”を買ふ、貧乏人はユウウツにならざるをえない（刻煙草があるにはあるが私たちには高級すぎるものばかりである！",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "此所も四百坪ほどの地面と表通りに貸長屋が数軒附いていた。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "初めて家持ちとなったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "川岸に数軒ひどい破屋があって、一軒では往来から手の届く板の間に黄色い泥のようなもので拵えた恵比寿がいくつも乾してあった。",
              "citation": {
                "source": "白い蚊帳",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時大塩の同勢は、高麗橋を渡つた平八郎父子の手と、今橋を渡つた瀬田の手とが東横堀川の東河岸に落ち合つて、南へ内平野町まで押して行き、米店数軒に火を掛けて平野橋の東詰に引き上げてゐた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "杏花一孤村流水数間屋にしても、川添ひに小さな家が一軒あると解して少しも差支ないが、車塵集は何が故に数間の屋を数軒の家と解したのであらうか。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野屋は、二丁目の海老屋とともに日本で高級｜足袋を造る数軒の一つである。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "加えて、各地の半導体部品の販売会社の中に、ＮＥＣマイコンショップを名乗ってＴＫ―80を扱ってくれるところが数軒生まれていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "途上、神明町の狭斜を過ぐれば、人家の倒壊せるもの数軒を数ふ。",
              "citation": {
                "source": "大正十二年九月一日の大震に際して",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "千鶴子も戻って来たとき四人は附近の版画屋を数軒見て廻った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "井上氏の庭は数千坪の見事なもので、廊下でつながった別棟の数軒に囲まれた広い庭の中央に、大きな池があり、根元から五つに岐れた榧の大木が枝を張っている。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "数軒の簡易な旅館がある。",
              "citation": {
                "source": "高千穂に思う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、米沢・新庄・鶴岡などの駅々で見た、宣伝びらでは、今年は信夫の湯に力を入れて評判を立てたようだから、定めてあの山の上の数軒しかない古い湯宿が、立てこんだことだろう。",
              "citation": {
                "source": "山の湯雑記",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒川と言う其流れについて下って、高瀬とか言った宿屋数軒、外湯一棟と言う処も見て、湯沢温泉へ出た。",
              "citation": {
                "source": "山の湯雑記",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから佐竹の通りには馬肉屋が数軒あったが、私はそういう処に入ることを知らなかった。",
              "citation": {
                "source": "三筋町界隈",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかの別荘に来た奴のだなと思いながら、その轍を辿っていったら、やがて山にかかると、それが消え失せ、その代りに男女の足跡らしいのが入り乱れてついているので、更にそれを追って行くと、釘づけになった数軒の別荘の間から、私の前に突然、緑と赤とに塗られた雛型のように美しい三階建のシャレエが見え出した。",
              "citation": {
                "source": "雉子日記",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "火事があって十数軒焼け、板囲いもせずそのままにして、日を経たという空地であった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "親子六人飢餓のために、枕を並べて死んだ家、死馬を食い、犬を食い、猫を食い、鼠、蛇、あらゆるものを食いつくし、十数軒をもって形成されていた、浅間山麓奥地にある、硫黄谷附近の一部落が、一人残らず死に絶えたという事実。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃には既に、木下大五郎のことは、その帽子や外套の絨毛と共に、この辺の数軒の小さな酒場から忘れられてしまっていた。",
              "citation": {
                "source": "変る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の三味線の手ほどきを頼まれて、数軒の家へ出稽古に行っていた。",
              "citation": {
                "source": "祭りの夜",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "値段は相当に高いが候補の一つにして、それから Schwanthaler Str. の数軒を見た。",
              "citation": {
                "source": "南京虫日記",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふも新聞の広告で見当を附けておいた数軒の部屋を見まはり、今夜は Klenze Str. 三十番地の部屋に寝泊りして虫の襲撃を試すつもりである。",
              "citation": {
                "source": "日本大地震",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も部屋のことで斯う愚図愚図してゐてはならぬと思ひ、けふも数軒部屋を見、遠くて不便であるが一間借りるやうに決心した。",
              "citation": {
                "source": "日本大地震",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
