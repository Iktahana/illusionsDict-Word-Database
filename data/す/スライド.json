        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "物価の上昇に伴い、年金の支給額がスライドして増額された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "勤続年数に応じて、給与のベースが段階的にスライドしていく仕組みだ。",
              "citation": {
