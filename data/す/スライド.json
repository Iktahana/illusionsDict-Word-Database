        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "採取したプランクトンをスライドにのせ、顕微鏡のピントを合わせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プレパラートを作るために、スライドの上にカバーガラスを慎重に重ねる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "研究室の棚には、過去の実験で作成された大量のスライドが保管されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
