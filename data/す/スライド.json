        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "会議の予定が1時間スライドしたので、少し時間に余裕ができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大雨の影響で、運動会のプログラムが全て午後にスライドされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "締め切りが1週間スライドしたおかげで、内容をさらに精査することができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 5,
