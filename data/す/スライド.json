    "definitions": [
      {
        "index": 1,
        "gloss": "slide (for projection)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
