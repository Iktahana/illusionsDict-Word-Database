[
  {
    "uuid": "9079aaad-76b2-5c91-ae0a-ebec32d73e1b",
    "entry": "推進機",
    "reading": {
      "primary": "すいしんき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
