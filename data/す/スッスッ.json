        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕がこいつをはいてすっすっと歩いたらまるで芝居のやうだらう。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがカン蛙は一言も物を云はずに、すっすっとそこらを歩いてゐたばかりです。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カン蛙はまだすっすっと歩いてゐます。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がこいつをはいてすっすっと歩いたらまるで芝居のようだろう。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがカン蛙は一言も物を云わずに、すっすっとそこらを歩いていたばかりです。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カン蛙はまだすっすっと歩いています。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下に跫音、ばたばたと早く刻んで、羽織袴の、宝の市の世話人一人、真先に、すっすっすっと来る、当浪屋の女房さん、仲居まじりに、奴が続いて、迎いの人数。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで恰も木馬に乗った勇士のようにすっすっと彼等の傍を突き進んで行った。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勢の鉛筆の音がすっすっと走っている。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっすっと彼らがはいって来た。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ面白いわ、早く来て御覧なさい」　蛸は八本の足を真直に揃えて、細長い身体を一気にすっすっと区切りつつ、水の中を一直線に船板に突き当るまで進んで行くのであった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は日陰になってる人通りの少い方の側を、新橋の方へ真直に、わき目もふらず、草履の裏を見せないですっすっと歩いていた。",
              "citation": {
                "source": "道化役",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "船は追風を受けて鳥のようにすっすっと走り、島の岸は閃くように過ぎ去り、眺望は一分毎に変って行った。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを我慢して、彼女の手を取りながら、踵を浮かし、爪先ですっすっと、ダンスの真似をやってのけた。",
              "citation": {
                "source": "裸木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "狼は三之丞の方を時々するどく睨みながら、反対の端を走っているが、その全身の動きは頗る軽く、すっすっとまるで四足が地を踏んでいるとは思えないほどであるが……三之丞は眼も放さず狼をみつめながら、ほとんど同じ速度で矢来の外を廻ること二周、三周。",
              "citation": {
                "source": "備前名弓伝",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七十郎の躰はかれらのあいだをすっすっとぬけるように見え、その棒は直角に三度ばかりひらめいただけであった。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
