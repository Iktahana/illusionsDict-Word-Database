[
  {
    "uuid": "544def7a-5051-5ef0-9628-a14dfacaee5a",
    "entry": "掏摸",
    "reading": {
      "primary": "すり",
      "alternatives": [
        "スリ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
