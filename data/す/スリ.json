      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pickpocket",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十月十四日土曜午前十一時上野發に乘つたが、今度は掏摸の厄介にはならなくて濟んだし、汽車の中は思ひの外に空いて居たし、それに天氣も珍らしい好晴であつたが、慾を云へば武藏野の秋を十二分に觀賞する爲には未だ少し時候が早過ぎて、稻田と桑畑との市松模樣の單調を破るやうな樹林の色彩が乏しかつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "掏摸が一度、豪勢な身なりをしている男の懐中物をくすねて鼻をあかしてやると、その快味が忘れられず、何回もそれを繰りかえし、かっぱらう。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、ちょうど、その掏摸根性のような根性を持っていた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなのが大きくなって、掏摸の名人なんかになるものだ。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、案外にも、どこか一つ大きく抜けているところがあると見えて、掏摸の親方になれなかったばかりか、いやもう、みっともない失敗の連続で、以後十数年間、泣いたりわめいたり、きざに唸るやら呻くやら大変な騒ぎでありました。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛り場である人がなんの気なしにとった写真に掏摸が椋鳥のふところへ手を入れたのがちゃんと写っていたという話を聞いたこともある。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "掏摸に金をすられた肥った年増の顔、その密告によって疑いの目を見張る刑事の典型的な探偵づら、それからポーラを取られた意趣返しの機会をねらう悪漢フレッド、そういう顔が順々に現われるだけでそれをながめる観客は今までに起こって来た事件の行きさつを一つ一つありありと思い出させられる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また掏摸にすられた中ばあさんが髪をくくりながら鼻歌を歌っているうちに手さげの中の財布の紛失を発見してけたたましい叫び声を立てるが、ただそれだけである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　掏摸は陳じ得ず、低頭して罪を謝し、抜取りたる懐中物を恐る恐る捧げて踞まりつ、「どうぞお見逃しを願います。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その意を得ざる掏摸は、ただへいへいと応うるのみ。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と掏摸だになお憤慨の色を表わせり。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "下　三郎は掏摸の奪いたりし金時計を懐にしつ、健児大助を従えて、その夕月下にへいげんの門を敲きぬ。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼方もさる者｜詭弁を構えて、「あれとは違いますが、やっぱり私の時計で、それは先刻掏摸に盗られた品だが。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と暴らかに詰れば、三郎少しも騒がず、「そんなら掏摸が遺失たのでしょう。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　へいげんは大喝して、「小僧、汝は掏摸だ。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ありがとう、お妾出身の女代議士もあるんだから、掏摸出身の女代議士だって不思議じゃないわね」「かえって乙かも知れない」　鶴雄はにやりと笑ったが、すぐ生真面目な表情になると、「――とにかく、この百円は僕は受け取りませんよ」「あら、どうして……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あんたはただの掏摸じゃないんだろう。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねっからの掏摸じゃないんだろう」「誰だって、生れた時から掏摸じゃないわ」「いや、僕の言ってるのは、そんな意味じゃない」　と、鶴雄はもどかしそうに、「――つまり、何といったらいいかな。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "掏摸だって『赤と黒』を読むわ」　弓子は古綿を千切って捨てるように、言った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは……」　それには答えず、「とにかく、あんたはただの掏摸じゃない。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つまり生意気なようだけど、悲願なの」「なるほど、ただの掏摸じゃなかったわけだね。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "四、相馬弓子という「赤と黒」趣味の女掏摸に賞金の百円をすられたこと。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "五、木屋町の小野屋旅館まで弓子を尾行して、弓子に面会を求め、弓子が掏摸になった原因や、弓子の姉の千枝子の話をきいて、弓子に百円を進呈したこと。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "望月は弓子が掏摸をしているという話を、たまたま隣の部屋できいたことを奇禍として脅迫的に弓子を誘惑しようとした。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「声を出して、人を呼べば、その人にあたしが掏摸だってことをバラすっていうわけね」「そんな野暮なことはしたくないが、しかし万一そんなことになれば、君のためにならんというわけよ」「構わないわ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓子は耳の附根まで、いや、眼の中まで赧くなりながら、「まあ」　と、暫らく口も利けなかったが、やがて「――じゃ、あたしが掏摸だってこともご存知ですの」「知ってます」　簡単に小田は言って、「――いけませんか」　と、煙草に火をつけた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それに、あたし、今日は掏摸として参ったのです」「えッ……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「結局あたしは掏摸じゃないの。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉さんを身うけしてしまったからもう、掏摸をやる必要はない。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の外は真つ暗で、硝子に額をすり寄せて見ても森と空との境界も漸く見分けられるくらゐであつた。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
