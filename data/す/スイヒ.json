[
  {
    "uuid": "6ab3660b-6ae7-5c2a-9524-5a21602d3018",
    "entry": "水肥",
    "reading": {
      "primary": "すいひ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "liquid manure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼はたゞ身体が水肥りのやうに膨れて行くやうに感じた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの納屋や、水肥小屋や、または井桁の小窓があけてある便所すらも、形が美しいではありませんか。",
              "citation": {
                "source": "民藝とは何か",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういひますいひますと懷しい郷土を思ひだして、にこにこしながらいつた。",
              "citation": {
                "source": "春宵戲語",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "この月のはじめ、石田氏が失業の由来をうちあけてくれてから、百々子にとって、パパは親しみやすいひとになった。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の専門は、わかりやすいひと言で言うなら、無線通信だった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の電灯がついているとみえて、えんがわのほうから、ボーッと、うすいひかりが、しょうじに、さしています。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
