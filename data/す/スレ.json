    "definitions": [
      {
        "index": 1,
        "gloss": "thread (on an Internet forum, mailing list, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「フランスレビュウの大立者の女優で、ミスタンゲットというのがあるがね」「ああそんなら知ってるよ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルダス・ハクスレーの短篇『若きアルキメデス』には百姓の子のギドーが木片の燃えさしで鋪道の石の上に図形を描いてこの定理の証明をやっている場面が出て来るのである。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その試験問題の討究のために試験官仲間をターリングに招待したが、そのためにソリスベリー卿とディスレリーとの和解の饗宴という歴史的のシーンに出席する機会を逸した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時彼の長子が「科学者も六十過ぎると、役に立たないばかりか、むしろ害毒を流す」と云ったハクスレーの言葉を引いて、どう思うかと聞いたら、「それは、年寄って若い人の仕事を批評したりするといけない事になるかもしれないが、自分の熟達した仕事を追究して行くなら別に悪い事はあるまい」と答えた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれが、地方雜誌のスレからした投書家などにありがちな、野卑な厭味とキザとで芬々たる臭氣を放つてゐた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎蔵の刀は仲蔵の首とスレスレに土に突き刺さされている。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根はスレート葺きだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゞれ雲西に傷みて、　　　　いささかの粉雪ふりしき、警察のスレートも暮れ、　　　売り出しの旗もわびしき。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "漆喰の土間の隅には古ぼけたビクターの蓄音器が据えてあって、磨り滅ったダンスレコードが暑苦しく鳴っていた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の作家では夏目先生のものは別として国木田独歩、谷崎潤一郎、芥川竜之介、宇野浩二、その他数氏の作品の中の若干のもの、外国のものではトルストイ、ドストエフスキーのあるもの、チェホフの短編、近ごろ見たものでは、アーノルド・ベンネットやオルダス・ハクスレーの短編ぐらいなものである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでその杉木立の中にポツネンと立っている南堂家の図書館というのは、五｜間に四間ぐらいの二階建の鉄筋コンクリートに茶褐色のタイル張りで、上等のスレート屋根の下に緑色に塗った鉄のブラインドが並んでいる。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると又それに連れて図書館の外側の手入れが不充分になったらしく、スレート屋根の上にタンポポだのペンペン草だのがチラチラと生え始めた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝劇のトーキー披露会で貴方とスレ違ったこともあるわ……御存じなかったでしょう」　私は正直にうなずいた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フランスレビュウの大立物の女優で、ミスタンゲットというのがあるがね」「ああそんなら知ってるよ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大将「ベルギ戦役マイナス十五里進軍の際スレンジングトンの街道で拾ったよ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論どの人も首ということは一言もいいません、いかなる場合にも単にスレイン（殺す）といっていたのは、外国人として無理ならぬことです。",
              "citation": {
                "source": "米国の松王劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ」と妻木君は変にカスレた声で云った。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い女とスレ違っても振り返る力がなくなってしまった。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……ア……ア……アナタハ……サッキ……ノ……」　彼女はカスレた声でこう言いさしてグッと唾を呑んだ。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "低い、カスレた声であった。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソコヘ　カケツケタ　カゴカキガ、「ダンナ、カタナヲ　オワスレニ　ナリマシタ。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヲトコハ　ラツパヲ　ミルト　花ヲ　オコシテ　ヤル　コトモ　ワスレテ、「アア、コレダ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "コドモダヌキハ　オアシヲ　モラツタノデ　サツキノ　クルシサモ　ワスレテ、ヨロコビ　イサンデ　カヘツテ　イキマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宰イツマデモ病人ノ感覚ダケニ興ジテ、高邁ノ精神ワスレテハイナイカ、コンナ水族館ノめだかミタイナ、片仮名、読ミニククテカナワヌ、ナドト佐藤ジイサン、言葉ハ怒リ、内心ウレシク、ドレドレ、ト眼鏡カケナオシテ、エエト、ナニナニ？",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "打チサエスレバ、カナラズ安打。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "走リサエスレバ、必ズ十秒四。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "的言イアテルヨリハ、ワガ思念開陳ノ体系、筋ミチ立チテ在リ、アラワナル矛盾モナシ、一応ノ首肯ニ価スレバ、我事オワレリ、白扇サットヒライテ、スネノ蚊、追イ払ウ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の前には、丘の傾斜に在る先生たちの舎宅の一劃が見え、更に一段下った崖端の平地には学園の建物が厳かに眺め渡されるのですが、校庭にはポプラの大木が周囲に植え込まれているので、そのスレートの屋根は木々の間より僅かにしか見えません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四年の長い恋愛ののち結婚した木崎はダンスは出来ず、彼女もダンスレコードは集めたが、踊りたがらなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
