    "definitions": [
      {
        "index": 1,
        "gloss": "on the water",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "落葉が水上で朽ちて小さな浮島のように処々にかたまっていた。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは藁苞のような恰好をした白鳥が湿り気のない水に浮んでいたり、睡蓮の茎ともあろうものが蓮のように無遠慮に長く水上に聳えている事もある。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十月十五日『東京朝日新聞』）　　　　　　　　　二十　　　　　　ボートレースに無線電話　今年の七月、北米の大湖エリーの水上で端艇競漕のあった時、その時々刻々の景況を陸上に報ずるためテルマと名づくる小蒸気船に無線電話機を載せて現場に臨ませた。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "目を眩しそうにぱちつかせて、女教師の動作の全部を見届けた貝原は「型が綺麗だなあ」　と思わず嘆声を挙げてやや晦冥になりかけて来た水上三尺の辺を喰い付きそうな表情で見つめた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見ていると靄は水上からだんだん灰白色の厚味を増して来る。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らく波の音が水上の音楽を私達にもたらした。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "河水に向って明滅する大電気時計が赤色に染められて、水上警察の快速巡航船が、女の小指のような尾を引いて光の纒綴の下を通り過ぎるとき、美人茶屋のグランド・コンサートが聞えてきた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "水上瀧太郎、小泉信三の兩先輩、その他水木京太、勝本清一郎、高橋邦太郎などに會ふ。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "混雜するお寺の玄關先、水上瀧太郎さんにふと紹介されて喜多村緑郎丈と初めて詞を交へた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こないだ女中殺しのあつた……」「ははは、物騷な方か……」と、引き取つて咳き、水上さんが顏を笑ひ崩した。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬籠もりをした汽船は、水上にぬぎ忘れられた片足の下駄のように、氷に張り閉されてしまった。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてこの水上は、昨日孤家の婦人と水を浴びた処と思うと、気のせいかその女滝の中に絵のようなかの婦人の姿が歴々、と浮いて出ると巻込まれて、沈んだと思うとまた浮いて、千筋に乱るる水とともにその膚が粉に砕けて、花片が散込むような。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水上は旧石神井村三宝寺の池なれば、正しくは石神井川といふべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その水中を泳ぐ格好がなかなか滑稽で愛敬があり到底水上では見られぬ異形の小妖精の姿である。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅間観測所の水上理学士に聞いたところでは、この日の爆発は四月｜二十日の大爆発以来起こった多数の小爆発の中でその強度の等級にしてまず十番目くらいのものだそうである。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし本館のほうにいた水上理学士は障子にあたって揺れる気波を感知したそうである。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にせい筑紫次郎という筑後川の水上に在る山奥の町じゃけに、四方の山々から切出いて川へ流す材木というものは夥しいものじゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶屋を出て、自分らは、そろそろ小金井の堤を、水上のほうへとのぼり初めた。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "水上を遠く眺めると、一直線に流れてくる水道の末は銀粉を撒いたような一種の陰影のうちに消え、間近くなるにつれてぎらぎら輝いて矢のごとく走ってくる。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "水上が突然薄暗くなるかとみると、雲の影が流れとともに、瞬く間に走ってきて自分たちの上まで来て、ふと止まって、きゅうに横にそれてしまうことがある。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると水上がまばゆく煌いてきて、両側の林、堤上の桜、あたかも雨後の春草のように鮮かに緑の光を放ってくる。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川の水上の柳の上を遠く城山の石垣のくずれたのが見える。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれが前なる流れは音もせで淀みなく走るを、初めかれ心なくながめてありしが、見よ、水上より流れ来たる木の葉を、かれはひたすらながめ入りぬ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、水上に浮かぶ二つの浮き草の花が水中に隠れた根によって連絡されているようなものである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この洋行帰りの青年紳士は、室子の家の遠縁に当り、嘗て彼女をスカールへ導き、彼女に水上選手権を得させ、スポーツの醍醐味も水の上の法悦も、共に味わせて呉れた男だった。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "石油色に光る水上に、漕いでいる。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の上であの男に感じる匂いや、神秘は何処へ消えるか、彼は二つ三つ水上の話を概念的に話したあとは、額に苦労波を寄せて、忙しい日常生活の無味を語る。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘が鳴ったが、その浅草寺の五重塔は、今戸側北岸の桜や家並に隠れて彼女の水上の位置からは見えない。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "金魚や鮒の腹に食いつく源五郎虫のように、彼女達は水上で不良の男達の艇にねばられることがあった。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……水上は幾千里だか分らない、天竺のね、流沙河の末だとさ、河幅が三｜里の上、深さは何百尋か分りません。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
