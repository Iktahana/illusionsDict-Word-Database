        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのほか、ばくらふ、炭焼き、烏帽子折り、鏡｜磨きといふやうに、いろんなことをしながら、あちこちとさまよひ歩きました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて従前に比して社費は二、三倍に嵩むゆえに、樵夫、炭焼き輩払うことならず、払わずば社殿を焼き払い神木を伐るべしと逼られ、常に愁訴断えず。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業後、漁師の手伝い、養鶏場の番人、炭焼きの手伝い、呉服屋の行商人などの職業を転々とする。",
              "citation": {
                "source": "小熊秀雄全集-1",
                "author": "短歌集",
                "note": "青空文庫"
              }
            },
            {
              "text": "その故を尋ぬるに、この畑村に、昔炭焼き藤太という者居住す。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "車を運転していた父親は、あれは炭焼きだな、と呆れたようにいった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "むこうの谷間で、炭焼きの煙がゆったりと広がっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのフキやシダのあいだに、低い藁屋根をさしかけた肥溜めがひとつ、もうすこしいくと、炭焼き小屋もあるが、煙は出ていない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫の方は助ける事が出来ましたが、勘太郎はもう炭焼きなんぞはする気になりませんでした。",
              "citation": {
                "source": "虫の生命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし生れて炭焼きしかした事のない勘太郎は他の仕事を一つも知りませんでした。",
              "citation": {
                "source": "虫の生命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い山には炭焼きの煙が見える。",
              "citation": {
                "source": "ネギ一束",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、杣や炭焼きではなさそうだ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元オシシはじつは山男であったが、人間に炭焼き方法を教えた恩顧でかような神となったのである（６）という民伝がある。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、先生の海南小記のなか（３）には、竈神の起原に関した話として、かの炭焼き長者に縁因あることを明かされている。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "「木曾の方は又違った風で、えらい目をしている」　木曾は知ってのとおり山々が大抵御用林で、その山の根がたの住民の生計は炭焼き主だが、炭が俵二十何銭では一ヵ村かたまって炭の材料になる御用林の木を払い下げをして貰うことは出来ん状態になって来た。",
              "citation": {
                "source": "今にわれらも",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、炭焼きか山番かであろう男が一人いる処は、向う山か、遙かな天城山の奥か。",
              "citation": {
                "source": "山峡新春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまでは村人が炭焼きにくるので道がありますが、ここから頂上までは道がありません。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは鳥取の人が炭焼きにきて少し木を切っていて楽に歩けます。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上辺で炭焼きの人に逢い、鳥取県からはこの山へ道があると聞きました。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたりの民家では、炭焼きのかまども見られた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸を明け放つた縁側の外には、暗い山に唯一点、赤い炭焼きの火が動いてゐた。",
              "citation": {
                "source": "槍ヶ嶽紀行",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "学者という者は、こんなにごうまんなものであって、農夫や炭焼きなどを相手にしないものだと、昔からのいいつたえで、そう思っていたのだ。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の中の、まったく素人の農夫や炭焼きだった人たちが、博士の指導によって短い期間のうちにびっくりするほどりっぱな職工になった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "農民たちや炭焼きや猟師たちが喜んだことは、いうまでもない。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　日向の炭焼き難波の土橋（今の叶橋）の西詰に、ヽヽといふ畳屋があつた。",
              "citation": {
                "source": "三郷巷談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は、畳屋が子供を盗んで、日向へ炭焼きに遣るのだ、といふ評判であつた。",
              "citation": {
                "source": "三郷巷談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林らは静かに登る炭焼き小屋の煙をめがけて下りて行った。",
              "citation": {
                "source": "五色温泉スキー日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
