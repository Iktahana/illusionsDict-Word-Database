        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、全員はボートデッキへスタンバイした。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今から、ディープシーレット（深海測定器）を入れろッ」と、それから水夫室へ来てそのまん中で大声に「スタンバイ」と怒鳴った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫たちは皆｜各スタンバイした。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チーフメートさん、スタンバイだそうです。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とにかく、お前はおもてへ行ってスタンバイしてくれ、何とでもごまかして水夫らを働かしてくれ！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長はスタンバイをかけたのに、チーフメーツがフォックスルに現われないので、彼女との別れ前からそのまま保っていた幸福感が、爆発しかけていたところであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長は、スタンバイの命令を出しっ放して、サロンへはいって、そこで、水夫らを「とっちめ」てやろうと待ち構えた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタンバイがかかったのに、船体はピクともしない。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫たちはフォックスルにスタンバイしていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "全員スタンバイしたのを確認すると西田増美はギターでイントロを奏で始め、タイミングよく照明の青白い光線が暗闇の中に彼女の姿をぽつねんと浮かび上がらせる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
