        "examples": {
          "standard": [
            {
              "text": "主観的な感想ではなく、数値的な根拠を示してクライアントを説得した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "過去の売上実績を数値的に分析し、次期の販売戦略を立てる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の能力は数値的なテストだけでは測れない、豊かな人間性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これらの発見の重大な意義はと言えば、それらのものの精密なる数値的決定より先にそれらのものが「在る」ということを確立することである。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "入るものと出るものとの人の流れは数値的に等しいが構成は変化する。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            }
          ]
        }
