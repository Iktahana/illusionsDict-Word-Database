        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "睡眠時間が、短いのである。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社への往復と食事時間と夜の睡眠時間以外にはＢの眼から双眼鏡が離れないのです。",
              "citation": {
                "source": "雑談抄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれ教育だ、それ睡眠時間だ、もう一分で午砲だ、お昼飯だ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎外は睡眠時間の極めて少ない人で、五十年来の親友の賀古翁の咄でも四時間以上寝た事はないそうだ。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "妨害される夜の睡眠時間の三十分にしても、彼女等にとっては昔の三十分ではなかった。",
              "citation": {
                "source": "黒猫",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では睡眠時間の半分は寝る。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日に十五箱といえば百五十本、睡眠時間や食事其他の時間を差引いて、一時間に幾本、一本が幾分と、つまらない計算を私はやってみたこともある。",
              "citation": {
                "source": "十一谷義三郎を語る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の睡眠時間もまた同じく、なにもなさずにいるという消極的作用にとどまらで、起きて大いに働く力を養う時である。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "睡眠時間は問題外だ。",
              "citation": {
                "source": "女客一週間",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "睡眠時間は少く、早起であつた。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "碌に睡眠時間もとらないで、この組立に急いだ結果、四日という短い日数のうちに、新しい第二装置ができあがった。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ日本地理の見学をそのためにオロソカにしては巷談師たるもの職人の本分にもとるから、これを天の定めと見て、睡眠時間を極度にきりつめることによって三ツながら全うしてみせるという覚悟をかためざるを得なかった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "睡眠時間は十分にあるように、主婦のほうでは気をつけなくてはならず、みなさんのほうでは、床にはいって本を読み、電気を消すことを忘れたりするようなことでなく、きまりよく床にはいり夢をもみずに眠ることのできるのは、ほんとうに仕合わせです。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔八〕睡眠時間、起床、就床　睡眠時間はまず通常六時間あるいは七時間位で、朝は大抵八時前後に床から離れます。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その日に限って、彼は睡眠時間の限度を超過してしまったのである。",
              "citation": {
                "source": "扉は語らず",
                "author": "小舟勝二",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の睡眠時間も長くなったらしい。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでね、おれも睡眠時間を四時間に縮めるには、永年修業をしたもんだ、若いうちはどうしても眠たくていかなんだが、近頃に至って始めて随処任意の庶境に入ってはなはだ嬉しいと自慢するんです。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際四カ月の間、睡眠時間はわずか三時間に過ぎなかった。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "睡眠時間はわずかに、四時間だよ。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、もうトックに睡眠時間になっていて、一同ゴネとるんだっ！",
              "citation": {
                "source": "破れわらじ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴネとるのは睡眠時間が来たからじゃなくって、起きてると腹がへるからでえ！",
              "citation": {
                "source": "破れわらじ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐助は夏以来ずっと押入の中でしていればよかったのだが誰も気が付きそうにないので大胆になって来たのと、何分激しい業務の余暇に睡眠時間を盗んでは稽古するのであるから次第に寝不足が溜って来て暖い所だとつい居睡りが襲って来るので、秋の末頃から夜な夜なそっと物干台に出て弾いた。",
              "citation": {
                "source": "春琴抄",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も二三年この方、だんだん体が肥えて来る傾きがあるので、睡眠時間を減らした方がいいと思っているのだし、眼に借りの出来るのはそうまで苦痛に感じていないようなものの、朝寝の快感は又おのずから別である。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "都市の人たちは過去に比べて睡眠時間が短く、しばしば不充分となり健康はそれによって改めて害されるようになった。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし１日は24時間からなり働ける時間は10時間で睡眠時間は８時間しかない。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は夜半の一時よりまえに寝たことはなく、午前四時すぎまで寝ていることもない、睡眠時間は多くて三時間、そのあいだは失神した者のように、寝返りもうたず、いびきもかかずに熟睡した。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "睡眠時間が短くなるのも嫌」「老人になるまで、別な自分の夢を見続けるつもり？",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月二十六日（金曜）　辛さも辛し、睡眠時間二時間。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
