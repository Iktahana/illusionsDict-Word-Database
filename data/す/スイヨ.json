    "definitions": [
      {
        "index": 1,
        "gloss": "drunken (e.g. brawl)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
