        "examples": {
          "standard": [
            {
              "text": "音楽教室の体験レッスンで、初めてフルートという吹奏楽器に触れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の家には、様々な種類の吹奏楽器がコレクションされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "吹奏楽器の独特な響きは、オーケストラに深みを与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "蕪村七部集が艶麗豪華なようで全体としてなんとなく単調でさびしいのは、吹奏楽器の音色の変化に乏しいためと思われる。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白熊、ラクダや驢馬の橇、オーケストラ吹奏楽器□□　人間、悪くなると、心のゆるむことの早いのを感じ自分悲しみを感じた。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな吹奏楽器だね。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
