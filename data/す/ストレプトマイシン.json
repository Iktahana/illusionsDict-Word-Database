        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二篇とも、ストレプトマイシンが無料で闘病者のベッドに訪れて来る日を待っているのは、心をうたれる。",
              "citation": {
                "source": "『健康会議』創作選評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストレプトマイシンが療養所でつかわれる日を「何日かは春に」と待っているひとは、日本じゅうに、どれほどいるだろう。",
              "citation": {
                "source": "『健康会議』創作選評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペニシリン、ストレプトマイシンのごときは最近顔を出したばかりである。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストレプトマイシンも買える。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともペニシリンやストレプトマイシンのように、すぐ眼に見えるものについては、日本人は決してぼんやりしていない。",
              "citation": {
                "source": "老齢学",
                "author": "――長生きをする学問の存在――",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学の方も、この頃は、ペニシリンだの、ストレプトマイシンだのというものが出来たので、大分信用を高めて来た。",
              "citation": {
                "source": "ジストマ退治の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
