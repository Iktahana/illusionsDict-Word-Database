    "definitions": [
      {
        "index": 1,
        "gloss": "dye made of fermented indigo leaves",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
