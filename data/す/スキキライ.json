    "definitions": [
      {
        "index": 1,
        "gloss": "likes and dislikes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
