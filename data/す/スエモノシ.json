        "examples": {
          "standard": [
            {
              "text": "熟練の陶物師が、ろくろの上で粘土を鮮やかに形作っていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は陶物師としての修行を積むため、山奥にある師匠の工房に弟子入りした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若き陶物師の手によって、伝統とモダンが融合した新しい作品が生まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それのみか、古手紙から朧ろに察せられる所によれば、彼女の出生は祖父の不図した不行跡にさへ、少くも直接には依るものでなく、全く縁もゆかりもない京都の或る賤しい陶物師の娘でしかなかつた。",
              "citation": {
                "source": "垂水",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "斬り手はちゃんと定まっていて「すえものし」（居物師）といい壇術家ともいって、三家の師範がありおのおの門弟があった。",
              "citation": {
                "source": "せいばい",
                "author": "服部之総",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
