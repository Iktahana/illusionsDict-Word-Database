        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "衰残の気色がありありと見える。",
              "citation": {
                "source": "夜長ノート",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "天床、畳、壁、障子、襖、小さな天地ではあるけれども、都て敗頽と衰残の影が、ハツキリと眼に映る。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "今行くは追憶の影――黄金なす幻追ひて、衰残の心の大路暮れゆけば顧みもせぬ人生の若き旅びと、――くづをれて匂ゆかしみ我愁ふ、追慕の涙綿綿と青む夜までも。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし必ずしもどちらの説が真かを決定するは及ばない、世界人類が未だ衰残減少に傾いていないことに照らしても世界が今張る気を有していることは明らかである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は、衰残の姿いたいたしい市九郎に、「もはや、そなたは石工共の統領をなさりませ。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "冒しがたき大自然の威厳を示して、市九郎の前に立ち塞がっていた岩壁は、いつの間にか衰残の乞食僧一人の腕に貫かれて、その中腹を穿つ洞窟は、命ある者のごとく、一路その核心を貫かんとしているのであった。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩年衰残の悲運を誰か知ろうぞ、かれは実に一座の花形役者であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは明治二十四年の六月、この座で初めて上演された桜痴居士の作で、団十郎は今度が二度目であったが、その衰残のすがたが著るしく眼について、恐らくこれが最後の舞台ではないかという一種の予覚を我々にあたえた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳橋を過ぐる詩と橿園に訪はれた詩とには、稍衰残の気象が見える。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」語に毫も衰残の気象を認めない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "始識衰殘美　　始めて識る衰残の美、臨風白鬢斜　　風に臨んで白鬢斜なり。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が、困憊、衰残の政府を提げて、驀然として来り迫る革命軍に応戦したるを見る、恰も、颶風の中に立てる参天の巨樹の如き概あり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "衰余の国民が文明国の干渉によって勃興した例は少ないが、今は商業も著しく発達し、利益と人道とが手を取って行く世の中となって来たから、よろしく日本を良導して東洋諸衰残国の師たる位置に達せしめるがいいというような、比較的同情と親愛とをもって進んで来るものもある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車はまだ布設されていなかったが既にその頃から、東京市街の美観は散々に破壊されていた中で、河を越した彼の場末の一劃ばかりがわずかに淋しく悲しい裏町の眺望の中に、衰残と零落とのいい尽し得ぬ純粋一致調和の美を味わしてくれたのである。",
              "citation": {
                "source": "深川の唄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」〔後起駸駸トシテ此クノ如キ有リ／衰残ノ吾輩｜復何ヲカ云ハン〕といっている。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、私は此らの人々の来歴を詳にしてゐないが恐らくや小芝居の俳優中の大半の経歴と同じく彼らとても一とたびは檜舞台を踏むの機会を有しながら、自らの性情その他が原因して失敗衰残の後半生を六区高塔下の舞台の上に曝してゐた悲惨の人々なのであらう。",
              "citation": {
                "source": "異版　浅草燈籠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二階歌舞伎の幕間余興は、衰残の緞帳役者たちと異つて太神楽、活惚のベテランのみが出演してゐた。",
              "citation": {
                "source": "異版　浅草燈籠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "さる老落語家の手記によると、於梅は寄席では主に手踊りなど見せていたらしいが、衰残の大姥桜、せっかくの踊りも脂気が抜けてただいたましく寄席もひと廻り巡演しただけで好評再演というわけにはいかず、最後は郡部の寄席へまで看板を曝した、とある。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう衰残の憐れな顔を刻んだものは、ただ老年と疾病のみではなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
