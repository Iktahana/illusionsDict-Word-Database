        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今に近づけばむしろ下手をすると警察から目をつけられるかもしれないという理性はその衝動を抑制するにはあまりに弱すぎ、気がつくと隼人はアパートを出て駐車場の自分のバイクにまたがり、スロットルグリップを回しながらアクセルを思い切りふかしている自分を見出していた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "スロットルグリップを全回して加速すると風の抵抗で上半身が後方に押し返される。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "フェリーとすれちがうころには、へさきで蹴り立てる白い波を左右にほうりあげ、フル・スロットルになっていた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アクセルは、ハーフ・スロットルで軽くパワーをかけたまま、一定させている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "白バイを追って、ぼくたちはスロットルを全開した。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくと小川は、スロットルを開け、法廷スピードのセリカを置き去りにし、飛びはじめた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見届けてスロットルをもどすと同時にチェンジ・ペダルを踏みつけ、一段落とし、間髪を入れずにスロットルをあけた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
