    "definitions": [
      {
        "index": 1,
        "gloss": "priced dirt cheap",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
