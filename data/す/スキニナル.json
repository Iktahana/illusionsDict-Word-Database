    "definitions": [
      {
        "index": 1,
        "gloss": "to come to like",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女を好きになるということは、悪いことでも、恥ずべきことでもない。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またやって来た※々直ぐ東京が好きになるような人は不愉快です。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "食欲色欲ばかりで生きている人間は、まだ犬猫なみの人間で、それらに満足し、若くはそれらを超越すれば、是非とも人間は骨董好きになる。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "マアこんな意味合もあって、骨董は誠に貴ぶべし、骨董好きになるのはむしろ誇るべし、骨董を捻くる度にも至らぬ人間は犬猫牛豚同様、誠にハヤ未発達の愍むべきものであるといってもよいのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう時にわれわれがもしも、自分のいちばんいやなようないちばん新しい傾向の品を買って来て我慢して使ってみていると、おしまいには案外それが好きになるかもしれない。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしは、こんどは、このひとを好きになる事にしましたから、そのつもりでいて下さい。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで初めて紀代子は彼を一寸だけ好きになるという気持を自分に許した。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "年をとるにしたがって、みょうが、とうがらし、しょうが、ふきのとうが好きになるように、茶の木が、茶の花が好きになる。",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の中のだれかが、おまえを好きになって、それこそ、おとうさんよりもおかあさんよりも、おまえのほうが好きになるんだね。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば、魔法の力がとけて、お姫さまは、おまえさんが好きになるよ」　ヨハンネスは、旅の仲間の言うとおりにしました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば見るほど好きになる、温い、優しい、そしてりんとしたところのある文字だ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その動作が二十幾年後の今になっても私には忘れられず、慶四郎君と言えばその動作がすぐ胸中に浮んで来て、何だか慶四郎君を好きになるのである。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "食欲色欲ばかりで生きてゐる人間は、まだ犬猫なみの人間で、それらに満足し、若くはそれらを超越すれば、是非とも人間は骨董好きになる。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "マア此様な意味合もあつて、骨董は誠に貴ぶべし、骨董好きになるのは寧ろ誇るべし、骨董を捻くる度にも至らぬ人間は犬猫牛豚同様、誠にハヤ未発達の愍むべきものであると云つても可いのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "土を踏んで歩いていると、自分を好きになる。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、紀代子ははじめて豹一を好きになる気持を自分に許した。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと進んだ芝居好きになると、扮装も背景も無い素舞いを見て随喜の涙をこぼすのがある。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀代子ははじめて、豹一を好きになる気持を自分に許した。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにひとり人間があってね、あなたひとりが好きになる。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとよの父も一度省作に逢ってからは、大の省作好きになる。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "君も、きっと、マア坊を好きになるだろうと思う。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "マア坊が、つくしを好きになるのも無理がないと思うんだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、なんとかして竹さんを忘れようと思って、ことさらにマア坊のほうに近寄って行って、マア坊を好きになるように努めて来たのだが、どうしても駄目なんだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは源氏がこの人を顕わに見た刹那から好きになる可能性があるとも言えるのである。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "キンクスの〈ユー・リアリー・ガット・ミー〉や、ボビー・フラー・フォーの〈アイ・フォウト・ザ・ロウ〉のような、そして、この〈ゲット・オフ・オヴ・マイ・クラウド〉のような、ギターコードでゴリゴリ押しまくる曲は、慶一は、とりあえず無条件で好きになる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまでは、国というのは、すべて最低なのがわかっているが、それで、日本国が好きになるわけではない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に永年東京に住んでいると、こんなイカものが喰えるようになるらしいので、江戸ッ子になると納豆が好きになるのも、そんな感化を受けるからかも知れない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いるとすきになるところよ、何だか落つくの」　庭に小松の繁茂した小高い砂丘をとり入れた、いかにも別荘らしい、家具の少ない棲居も陽子には快適そうに思われた。",
              "citation": {
                "source": "明るい海浜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋食は三度三度だが、一向飽きない、だんだんすきになる。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカじゃそれが必要だそうだが――p.86　おれはフランスよりアメリカの方をすきになるわけにはゆかん。",
              "citation": {
                "source": "「緑の騎士」ノート",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
