[
  {
    "uuid": "72d7b15c-15c3-58e0-8cd9-41432110cfe3",
    "entry": "推定",
    "reading": {
      "primary": "すいてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
