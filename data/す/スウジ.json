    "definitions": [
      {
        "index": 1,
        "gloss": "numeral",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だが、無頼漢共を量る時には、一年の概念的な数字に過ぎなかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "公式は、丁度世界歴史の年代の数字と同様に、彼等の物理学の中に潜む気味の悪い怖ろしい幽霊である。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツだとこれほど簡単に数字的に始末の出来る事が、我が駒込辺ではそう簡単でないようである。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十二月二十七日『東京朝日新聞』）　　　　　　　　　五十五　　　　　　巨船モーレタニア　先日ルシタニア号の話を掲げたが、その姉妹船モーレタニア号に関する概略の数字だけ比較のために挙ぐれば、船の長さ七百六十フィート、幅が八十八フィート、トン数三万二千。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自働電話の送信器の数字盤が廻るときのカチカチ鳴る音と自働連続機のピカピカと光る豆電燈の瞬きもやはり同じような考えを応用して出来た機構の産物であると見れば見られなくはないであろう。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、農林省の『本邦農業要覧』にあらわれた数字よりも、もっと正確に日本農民の生活を描きだしていた。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、アルファベットとアラビア数字がきれぎれに、一字一字、全部で三十字ほど折れ釘のように並んでいた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田は平常よく思い出すある統計の数字があった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "：入力者注　主に外字の説明や、傍点の位置の指定　　　（数字は、JIS X 0213の面区点番号、底本のページと行数）（例）※いたり、-------------------------------------------------------　旅行に就いて何か経験上の談話をしろと仰ゃるのですか。",
              "citation": {
                "source": "旅行の今昔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともそのためには精密な計画と行き届いた考察なしには手を出せないことは言うまでもないことであるが、その際得る数字の最高精度は少なくも最初には必ずしも問題にならないのである。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともその符徴はたいていだれでも知っていたので、秘密の暗号でもなんでもなくただ数字の代わりにかたかなを使ったというだけのものであった。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "観測の方法は、鉛筆と手帳をもって、数秒ごとに四つの昇降機のダイアルの示す数字を書き取るだけである。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も変わったレコードとしては、アメリカのコーラスガールで、接吻の際における心臓鼓動数の増加が毎分十五という数字を得ているのがある。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しばかげてはいるが、とにかくも人間のテンペラメントを数字で代表させようという傾向を示すものとして興味があるであろう。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの例で明らかであるように、いわゆるレコードはすべて数字によって記録されるものである。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと数字の差違は実に明確である。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた、数字のレコードで優勝したとしても、その人が、その数字の代表する量の大小以外の点でもすぐれているという証拠には決してならない。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、空間の中に静止する一点の位置を決定するだけでも三つの数字が必要である。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "百個の点の集団なら三百の数字が入用になる。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろよく「学問の自由」というようなことが議論されるようであるが、この自由なるものの自由度がいまだ数字できめられない限り、精密科学的には全く無意味な言葉である。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "百年議論してもこの自由の限界は数字では決められそうもない。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三原山の投身自殺でも火口の深さが千何百尺と数字が決まれば、やはり火口投身者の中での墜落高度のレコードを作ることになるかもしれない。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし単に墜落高度というだけのレコードならば飛行機｜搭乗者のほうにもっと大きい数字がありそうである。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたの懐中時計の六時の所はどんな数字が書いてありますか」と聞いてみると、大概の人はちょっと小首をかしげて考え込んでしまう。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "数の勘定には十進法の数字だけあればそれでよいというのは、言わば机の三本足を使う流儀であって、これに一見無用な干支を添えるのは用心棒を一本足した四本足を採用する筆法である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、なかの数字の羅列がどんなに美しく眼にしみたことか。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その詳細の数字は略するが、冬期すなわち十二月一月二月の三か月中における総降水日数を、最近四か年について平均したものをあげてみると、次のようである。",
              "citation": {
                "source": "伊吹山の句について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが大きな管弦楽ならばまたいっそう多数の音が重畳して来るわけであるが、連句の一句に同時に響いて来る表象情緒の重なり方の複雑さは、管弦楽などよりもいっそうウルトラの複雑さで到底数字や記号で表わさるべき程度のものではないのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "数字と数字との連想も半ば内容的であるが半ばは音調的の口移りから呼び出されるらしい。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなのひとは、すうじが大すきだ。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
