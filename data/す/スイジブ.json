        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、昔あの三本煙突の西洋館にいた炊事婦であったことを思い出した。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "――最初、彼女達は畑から事務所へと、炊事婦に傭われて行った。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "炊事婦のキングさんに話がある。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょうど女中や炊事婦が探しているところです。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日のこと、古くから、この病院へ出入りして、炊事婦や看護婦と、顔見知りという老婆が、ふいに、お竹のもとへやってきて、前に約束があるのだから、少年の付き添いを代わってもらいたいといいました。",
              "citation": {
                "source": "だまされた娘とちょうの話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
