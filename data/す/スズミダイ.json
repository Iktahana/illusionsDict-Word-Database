    "definitions": [
      {
        "index": 1,
        "gloss": "outdoor bench (placed under the eaves of a house and used for cooling off during the summer)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四　新星　毎年夏になってそろそろ夕方の風が恋しい頃になると、物置にしまってある竹製の涼み台が中庭へ持ち出される。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう明日あたりは涼み台を出そうじゃないかという事が誰かの口から云い出される。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼み台の外に折り畳み椅子が三つ同時に並べられて一同が中庭へ集まる。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の夏始めに、涼み台が持ち出されて間もなく、長男が宵のうちに南方の空に輝く大きな赤味がかった星を見付けてあれは何かと聞いた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月になってから雨天や曇天がしばらく続いて涼み台も片隅の戸袋に立てかけられたままに幾日も経った。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の夕方になると涼み台へ出て子供と共にその新星を捜したらすぐ分った。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼み台もつい忘れられがちになった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夕方一同が涼み台と縁側に集まっていろんな話をしている間に、去年みんなである夜銀座へ行ってアイスクリームを食った時の話が出た。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供等が出て行った後で私は涼み台で母とただ二人で話していた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来に涼み台を出している近所の人びとが、通りすがりに、今晩は、今晩は、と声をかけた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学時代にひと夏裏の離れ屋の椅子に腰かけて読書にふけり両足を言葉どおりにすきまなく蚊に食わせてから以来蚊の毒に免疫となったせいか、涼み台で手足を少しぐらい食われてもほとんど無感覚である。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、たまった手紙を書き終え九時頃従妹と庭の涼み台に出た。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻川氏は私達の側から立って今一つあいている長方形の涼み台の上に仰向けになった。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことを云っているうちに、あたりはもう夜の景色になって、そこらの店先の涼み台では賑やかな笑い声もきこえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "図は四条の河原の涼みであって、仲居と舞子に囲繞かれつつ歓楽に興ずる一団を中心として幾多の遠近の涼み台の群れを模糊として描き、京の夏の夜の夢のような歓楽の軟かい気分を全幅に漲らしておる。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四夜　広い土間の真中に涼み台のようなものを据えて、その周囲に小さい床几が並べてある。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらの涼み台では団扇の音や話し声がきこえる。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏のゆうぐれ、うす暗い家の奥からは蚊やりの煙りが仄白く流れ出て、家の前には涼み台が持ち出される頃、どこからとも知らず、一匹か二匹の小さい蝙蝠が迷って来て、あるいは街を横切り、あるいは軒端を伝って飛ぶ。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る晩、家中、店先の涼み台で、大河から吹く風を納れて、種々無駄話をしていました折から、師匠東雲師は、私に向い、「幸吉、お前も仕事ばかりに精出しているのは好いが、何か一つ遊芸といったようなものを稽古して見たらどうだい。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "遊芸には縁のなかったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを二つ庭の突鼻に据ゑて涼み台にした。",
              "citation": {
                "source": "スプリングコート",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こゝに涼み台を据ゑたのは理由があるんだよ。",
              "citation": {
                "source": "スプリングコート",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼み台のやうな長椅子があつた。",
              "citation": {
                "source": "Ｆ村での春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は燈火管制で暗いので、涼み台がおそくまで賑やかだつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の裏の河原、涼み台、岸に咲く紅い柘榴の花、四条の石橋の下の方から奔り流れて来る鴨川の水――そこまで行くと、欧羅巴の戦争も何処にあるかと思われるほど静かであった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "――○――　ブドー棚の下の涼み台、老人、冷酒をのみナムナムナムと低誦す。",
              "citation": {
                "source": "一九二三年夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親という人は後家で通して来たので、名代の気丈なものだったそうですが、ある夜、もうかれこれ更けて、夏の夜でしたが、涼み台もしまおうという時分に、その後家の家の軒前へ人魂がたしかに見えたと、近所の者が騒ぎだしたのです。",
              "citation": {
                "source": "人魂火",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつてはおれの額の上にも勇ましい流浪のあらしは吹き荒れていた、（「永劫への旅」より）　　　　　＊１　七夕の夜、涼み台のほとりで交された、ある家族の会話。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして二人の向側にある涼み台みたようなものの上に腰をかけた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、二人で、よく見舞に来てくれました、ゆっくり昔話でもしようではないか」　懸崖絶壁に腰をかけながら、涼み台に出て世間話でも持ちかけるような気分で、いやになれなれしいところへ、お銀様がまた妙に砕けたしなをして、「どうです、悪女大姉のことは。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
