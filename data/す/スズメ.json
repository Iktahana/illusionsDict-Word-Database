        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……対象の知れぬ寂しみ神様はつまらぬものゝみをつくつた盥の底の残り水古いゴムマリ十能が棄てられました雀の声は何といふ生唾液だ！",
              "citation": {
                "source": "（ツツケンドンに）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼天萩原朔太郎いつしんなれば、あふむけに屍體ともなる、つめたく合掌し、いんよくいちねん、きりぎりす青らみ、もはら、雀みそらに殺さる。",
              "citation": {
                "source": "蒼天",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、共に府下｜三鷹町｜下連雀の住人なのである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりかうした作家たちが、詩や俳句を作るのは、飽食の後で一杯の紅茶をのんだり、或は労作の汗を流し、一日の仕事を終つた後で、浴衣がけに着換へて麻雀でもする気持なのだ。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕立や草葉を掴む群雀　急の夕立に打たれて、翼を濡らした雀たちが、飛ぼうとして飛び得ず、麦の穂や草の葉を掴んでまごついているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時に襲って来た夕立の烈しい勢が、雀の動作によってよく描かれている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手の車庫のトタン屋根に雀が二羽、一羽がちょんちょんと横飛びをして他の一羽に近よる。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電柱の雀がからたち寺へ飛んで行く。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の世界は何もかも変って行くが、雀はおそらく千年前の雀と同じであろう。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の雀だかどうかは分からない。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀はどれを見ても人間には同じである。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏目先生、虚子、鼠骨、それから多分｜四方太も一処で神田｜連雀町の鶏肉屋でめしを食ったことがあった。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろんな奇抜な方法で雀や鴉を捕る話も面白かった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀が来てそれを食うと間もなく酔を発して好い気持になり、やがてその柿の葉を有合わせの蒲団にしてぐっすり寝込んでしまう。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の日がかんかん照りつけるので柿の葉が乾燥してじりじりと巻き上がるのでいつの間にかそっくりと雀を包んで動けないように縛ってしまう。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃太郎、カチカチ山、舌切雀、瘤取り、浦島さんなど、父は子供に讀んで聞かせる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瘤取り、浦島さん、カチカチ山、その次に、桃太郎と、舌切雀を書いて、一應この「お伽草紙」を完結させようと私は思つてゐたのであるが、桃太郎のお話は、あれはもう、ぎりぎりに單純化せられて、日本男兒の象徴のやうになつてゐて、物語といふよりは詩や歌の趣きさへ呈してゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、すぐつぎに舌切雀の物語を書き、それだけで一應、この「お伽草紙」を結びたいと思ひ直したわけである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この舌切雀にせよ、また前の瘤取り、浦島さん、カチカチ山、いづれも「日本一」の登場は無いので、私の責任も輕く、自由に書く事を得たのであるが、どうも、日本一と言ふ事になると、かりそめにもこの貴い國で第一と言ふ事になると、いくらお伽噺だからと言つても、出鱈目な書き方は許されまい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、この舌切雀の主人公は、日本一どころか、逆に、日本で一ばん駄目な男と言つてよいかも知れぬ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙臺地方には昔から、雀が多かつたのか、仙臺笹とかいふ紋所には、雀が二羽圖案化されてゐるし、また、芝居の先代萩には雀が千兩役者以上の重要な役として登場するのは誰しもご存じの事と思ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお爺さんの草庵の周圍の大竹藪にも、無數の雀が住んでゐて、朝夕、耳を聾せんばかりに騷ぎ立てる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀がどこで何をしようと、全然無關心の樣子を示してゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雀が、いまお婆さんの退場後に、はたはたと軒下から飛んで來て、お爺さんの頬杖ついてゐる机の端にちよんと停る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんは少しも表情を變へず、默つて雀を見てゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このへんから、そろそろこの小雀の身の上に悲劇がはじまる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえって、よだかは、あの美しいかわせみや、鳥の中の宝石のような蜂すずめの兄さんでした。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜂すずめは花の蜜をたべ、かわせみはお魚を食べ、夜だかは羽虫をとってたべるのでした。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はちすずめへ、あとでよろしく云ってやって呉れ。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みちにはすずめのかたびらが穂を出していっぱいにかぶさっていました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
