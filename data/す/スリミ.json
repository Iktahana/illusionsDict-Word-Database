        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "卵と鶏肉のすり身の豆腐、白い魚の刺身、野菜煮他、日本食は腹が張らなくていゝ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――昼と晩の順は忘れたが、鱒と葱の玉子綴、鳥のスチウ、鱒のすりみと椎茸と茗荷の椀。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか、そんな、こじつけみたいな、あてこすりみたいな、芝居のせりふのやうなものは、一向あなたに似合ひませんよ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか、そんな、こじつけみたいな、あてこすりみたいな、芝居のせりふのようなものは、一向あなたに似合いませんよ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "花にそそのかされて明る朝ははやく起き寐巻のまままぶしい眼をこすりこすりみると、花や葉に露がちろりとたまつて、天鵞絨のやうな石竹の花、髷の形した遊蝶花、金盞花などいきいきと目ざめてゐる。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
