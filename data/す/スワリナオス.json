        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "シャーロック・ホームズは口笛を吹いて座り直すと、「驚きだ、ピータソン！",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャーロック・ホームズがゆっくりと立ち上がり、扉側にある椅子へと座り直す。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の前に座り直すと、ペンを執った。",
              "citation": {
                "source": "仙人掌の花",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヘ、ヘエ、ただいま」　もう一ぺん小さくお辞儀をして、もうチャンと座っているものを、さらに座り直すようにした。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "すわりなおす衣ずれの音がして、やがて、「黒！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "百々子が顔をあげ、モトムがすわりなおす。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "康子は、そこで、えりをかきあわせながら、静かにすわりなおす。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、モナリザのおばさんが急にすわりなおすのが見えた。",
              "citation": {
                "source": "風宴",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "椅子へ戻って来た彼は、すわりなおすやいなや、湯飲みを片手でわしづかみにした。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い布のカヴァーを掛けたソファに彼らがすわりなおすと、すぐに女性の事務員がお茶を持ってきた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし腰をうかし、じわっと体重をかけるようにしてシートにすわりなおすと、ジーンズやパンツにしみこんだ水がしぼり出されてくる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
