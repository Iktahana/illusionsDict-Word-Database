    "definitions": [
      {
        "index": 1,
        "gloss": "sedge-woven (bamboo) hat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
