      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "immediately",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕の連れの男は僕の丁度直ぐ前の席に、もう先刻から眠つてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の直ぐ隣にはばかに肥つた男がゐて、僕は追ひ詰められたやうになつて腰掛けてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "通路を距てて直ぐの向ひ側には、鉄道従業員の妻君みたいなのが、胸をはだけて赤坊に乳を飲ませてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その通りを行き切つて、明るい旧通りへ出ると、そこから直ぐと近くにある、彼が三年前に屡々買つたり売つたりしてゐた古本屋に、チヨツと寄つてみようかといふ気が起つた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうです、安宅さん、みたところお元気で、御景気も好いやうですが……」　彼が茫然して直ぐに返事をしないと、親爺は急に笑顔をやめた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで私自身では、いくら元気である時にでも、もしその時に佗しげな夢を見てゐたとしたら、尠くとも直ぐにニコニコはしないであらう。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話をかけて直ぐ持って来させるように。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が直ぐに引返さうとすると、女が少し遊んでゆけといふし、それに続いて新しき男が、一寸上れよと云ふから、私は上つたのであつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場はそれから近くだつたのだが、とても直ぐ電車になぞ乗る気にはなれなかつたので、ともかく私は次の駅まで、開墾されたばかりの、野の中の道を歩くことにした。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐは蒲団の上に仰向きになれなくて、暫くは枕に肘を突いてゐたが、つらいことだつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがその直ぐの瞬間に、「あれは命をつなぐものだ」といふ考へが彼の頭を占領した。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "額の脂で手が辷りさうなので直ぐにそれはこめかみに当て換へられた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐ行くから」　看護婦は難所を抜け出るやうに走り去つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の背後の方の戸が開く音を聞くと直ぐ彼は振り返つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "叱り飛ばされた妻君は引き返したその足を直ぐに長男の書斎に運んだ。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は直ぐその方に行つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡台のある間の二三間ばかり向ふは直ぐに病室だつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐそんな所まで話が来るのが。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　祖母は何時も私の言葉が少し堅くなると、直ぐそのお定り文句を出した。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「直ぐに此の人は何か口を出す。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼食の直ぐ前頃だし田舎道を通るものなんて殆どなかつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も誰でも熾んに考へた直ぐ後体感的な気持になれるものではない。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川の直ぐ向ふの笹籔が、サワサワと秋風に吹かれて音立てゝゐた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸挨拶を済ますと、彼は直ぐ引つ込んだ。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分がＳ子に接近したことをＳ子が感じてとび逃げたものだと直ぐ次の瞬間に感じた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから元来た道を交番所の前まであるいてここから曲らずに真直ぐに行くとまた踏切を越えねばならぬ。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お婆さんはお掃除が好きで、大好きで、時偶女中がお掃除をしようものなら直ぐまた自分がやりなほすといふふうでした。",
              "citation": {
                "source": "家族",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "若山牧水の生地の直ぐ隣りの部落に友人がゐて、来いといふ。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、眼の前に、ふわりと、雪の粉が落ちる……七月末の炎天である……直ぐ、水に吸い込まれて消える……また、頬を掠めて、ふわりと飛ぶ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "測量標の直ぐ下は、野宿に適当な広い平地があって、それから凄まじいほど、垂直の断崖を作している、その下が雪田で、雪解の水は大樺の谷、それから小樺の谷へと、落ちているらしいが、そこまでは解らない。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
