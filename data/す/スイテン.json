    },
    "definitions": [
      {
        "index": 1,
        "gloss": "water and sky",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "千住大橋でおりて水天宮行の市電に乗った。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金刀比羅宮、男山八幡宮、天照皇大神宮、不動明王、妙法蓮華経、水天宮。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、ふだんから信仰する観音様や水天宮様を口のうちで一心に念じていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "（清正公樣の前だよ……煎豆屋の角、唐物屋の所……水天宮樣の横通………）　と所々で、――釣臺に附いてくれました主人が聲を掛けて教へますのを、あゝ、冥途へ行く路も、矢張り、近所だけは知つた町を通るのかと思ひました。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清正公樣の前、煎豆屋の角、唐物屋の所、水天宮樣の裏通り、とそツち此方で、一寸々々見えなく成つたらしいんですが、……」十一「すぐに、卍が出て、ふつと前へ通つて行きます。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、水天一碧の地平線上、團々たる黒烟先づ見え、つゞゐて白色の新式巡洋艦現はれ、それと共に、龍の如く、鯱の如き怪艇の水煙を蹴つて此方に向ふを見ば、請ふ、旗ある人は旗を振り、喇叭ある人は喇叭を吹奏し、何物も無き人は双手を擧げて、聲を限りに帝國萬歳！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "船が下流に落ちると、暮雲岸を籠めて水天一色、江波渺茫、遠く蘆が靡けば、戀々として鷺が佇み、近く波が動けば、アヽ鱸か？",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いで、紺青の波を蹈んで、水天の間に糸のごとき大島山に飛ばんず姿。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お神は裏木戸の瀬川に余分の祝儀をはずみ、棧敷の好いところを都合させて、好い心持そうに反り返っているのだったが、銀子もここへ来てから、ようやく新聞や画報で見ていた歌舞伎役者の顔や芸風を覚え、お馴染の水天宮館で見つけた活動の洋画から、ついに日本の古典趣味の匂いを嗅ぐのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光水ノ如ク水天ニ連ル。",
              "citation": {
                "source": "月の詩情",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水天髣髴の間に毛筋ほどの長堤を横たえ、その上に、家五六軒だけしか対岸に見せない利根川の佐原の宿、干瓢を干すその晒した色と、その晒した匂いとが、寂しい眠りを誘う宇都宮の田川の宿――その他川の名は忘れても川の性格ばかりは、意識に織り込まれているものが次々と思い泛べられて来た。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが水天一枚の瑠璃色の面でしばしば断ち切れて、だんだん淡く、蜃気楼の島のように中空に映り霞んで行く。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "洪水天に滔るも、禹の功これを治め、大旱地を焦せども、湯の徳これを済えば、数有るが如くにして、而も数無きが如し。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度、神仏の前に供えたのだ、と持つ手もわななく、体を震わして喜ぶんだ、とかねて聞いておりましたものでございますから、その晩は、友達と銀座の松喜で牛肉をしたたか遣りました、その口で、　――水天宮様のだ、人形町の――　と申したでございます。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――水天宮様のをお目に掛けましょう――　そう云って、柔らかい膝の衣摺れの音がしますと、燐寸を※と摺った。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あれは――　――水天宮様のお蝋です――　と二つ並んだその顔が申すんでございます。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまも今とて、離れて見ればなつかしい自分の河岸の家のことを考えたり、紅い丹波｜酸漿を売る店の出る水天宮の縁日を想い出したり、擒になった影画芝居の王子さまのことを考えたり、どうしても箸は遅くなります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――水天裂けて髣髴と白光走る。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚呼暮色微茫のあはひ、笙すずろ、かなたは町の夜祭に水天宮の舟囃子。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "水晶を買ふものをして、数十金を出して露店の硝子玉を買はしめんとする神学を創見するものあらば、余は疑はず、水天宮に参詣する衆生は争ひ来りて其説法を聴聞するなるべし。",
              "citation": {
                "source": "人生に相渉るとは何の謂ぞ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の郷国筑後の柳河は沖の端の水天宮の水祭には、杉の葉と桜の造花で装飾され、簾を巻き蓆張りの化粧部屋を取りつけた大きな舟舞台が、幕あいには笛や太鼓や三味線の囃子もおもしろく町の水路を三日三｜夜さも上下する。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "月夜にはの、あれが自分の影に怖れてびくびくするけに痩せるんでがんすといの」　村の水天宮様の御威徳を説く時の顔つきである。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あそこに水天宮さまが見えてるでしょう。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを出ると水天宮の社である。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は初めて貝殻の事を思いだして、そこそこに水天宮のところまで帰ってくる。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「過年、水天宮様の縁日の晩でしたっけ、大通のごッた返す処をちっとばかり横町へ遠のいて明治座へ行こうという麺麭屋の物置の前に、常店で今でも出ていまさ、盲目の女の三味線を弾くのがあります。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「誰だ、交ぜるない、嘉吉が処の母親さえ、水天宮様へ日参をするという騒だ。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（じゃね、愛吉、お前、何でもかでも私のために、医学士の奥様を殺して、願いを叶えてくれるんなら、水天宮様の縁日に、頭の乾児と喧嘩をするようにして暴れ込んで行ったって殺されるものじゃない。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、お肴には何がある、錦手の鉢と、塗物の食籠に、綺麗に飾って、水天宮前の小饅頭と、蠣殻町の煎豌豆、先生を困らせると昼間いったその日の土産はこれで。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
