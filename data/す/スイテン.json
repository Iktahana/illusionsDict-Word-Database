[
  {
    "uuid": "1714bce4-dc8e-5f6e-a8a0-ff834de6e847",
    "entry": "水天",
    "reading": {
      "primary": "すいてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
