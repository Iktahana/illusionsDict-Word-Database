      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cool",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "外もあんまり涼しくはなかつた、家の中よりか涼しいくらゐであつた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、帽子をあみだにかぶっても気になるし、まぶかにかぶっても落ちつかないし、ひと思いに脱いでみてもいよいよ変だという場合、ひとはどこで位置の定着を得るかというような自意識過剰の統一の問題などに対しても、この小説は碁盤のうえに置かれた碁石のような涼しい解決を与えている。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえって涼しいかも知れない。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時の女の顔は不思議な美しさに輝いて、涼しい眼の中に燃ゆるような光は自分の胸を射るかと思ったが、やがて縁側に手をついて、宜しくば風呂を御召しあそばせと云った時はもう平生のお房であった。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼しい風は店の灯を吹き、軒に吊した籠や箒やランプの笠を吹き、見て過ぐる自分の胸にも吹き入る。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼しい風が吹いて来て榊のゆうがサラサラと鳴り、檜扇がまた散った。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "表の河沿いの道路に面した格子窓には風鈴が吊されて夜風に涼しい音を立てていたように思う。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六日　涼しいさえさえした朝だ。",
              "citation": {
                "source": "窮理日記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや七十歳ちかいけれども、このお婆さんは、腰もまがらず、眼許も涼しい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大宮町への道も、玉を転がす里の小川に沿うてゆく、耳から眼から、涼しい風が吹き抜ける。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、森林帯に入るとさすがに涼しい、中でもシャスタ樅と呼ばれる喬木の一種は、この山、特有とまでゆかなくても、この山の産として最も名高いのであるが、富士の落葉松を、富士松と呼ぶたぐいであるかも知れない。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "附近一帯の水涸れで、工面のいい家は、どん／＼井戸を掘り下げたり、水道を引いたりして、文字通り「涼しい顔」をしてゐられるのであるが、この埃の溜つた井戸の使用者は借家人であり、その家主は、前代は財布の紐で首でも吊つたんではないか、と疑はざるを得ない吝ん坊なのである。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "気温は高くても風があれば涼しい。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見て涼しいという点ならもう少し涼しい色はいくらでもある。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の前がすぐ大堰川の流で「梵鐘は清波を潜って翠巒に響く」という涼しい詩偈そのままの境域であります。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう涼しいからね」　ジョバンニは立って窓をしめお皿やパンの袋を片附けると勢よく靴をはいて「では一時間半で帰ってくるよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って審査委員自身は平気で涼しい顔をしていても、他の同僚が知らん顔をしてはいられなくなるであろう。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸では晴れた夏の日の午前にはたいてい風が弱くて、午後になると沖のほうから涼しい風が吹き出します。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この黒い所が浜べに近づいて来ると、もうそよそよと涼しい風を感じるようになります。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して東京の夏には地方的季節風が相当強い南東風として発達しているためにそれが海陸風と合成され、もしこれがなければべた凪になるはずの夕方の時刻に涼しい南東がかった風を吹かせるらしい。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "穏やかで、パッシイヴで、そしてどこか涼しい感じのする人であった。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、涼しい、人氣のないムウドンの森に出かけました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、いま時分、こんなに遅く、いいのかしらん」「なに、ちっとばかり、資金を廻してある家なので、自由が利くんです」　涼しい食物の皿が五つ六つ並んで、腹の減った小初が遠慮なく箸を上げていると、貝原はビールの小壜を大事そうに飲んでいる。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "薫はそれを涼しいもののように眼を細めて恍惚と眺め入っていたが、突然野太い男のバスの声になって「そりゃ、貝原さんはいい人さ、小初先生と僕のことだって大目に見ての上で世話する気かも知れませんさ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてだんだん虚脱に似た無批判になってゆく心境のなかにいつか涼しい一脈の境界が透って来た。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、明け放した正面から窓の方へ流れてくる涼しい風に吹かれながら、ぢつと口を噤んでゐた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く止めてくれと言っても車掌は「信号したけれども止めないです」と言って至極涼しい顔をしていた。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声が妙に涼しいようでもあり、また暑いようでもあった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京では、夏の暑い盛りに天気のいい日だと夕方涼しい南がかった風が吹くので、瀬戸内海地方のような夕なぎの苦しみを免れている。",
              "citation": {
                "source": "海陸風と夕なぎ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が講義のあいまあいまに大学の裏門から公園へぶらぶら歩いて出ていって、その甘酒屋にちょいちょい立ち寄ったわけは、その店に十七歳の、菊という小柄で利発そうな、眼のすずしい女の子がいて、それの様が私の恋の相手によくよく似ていたからであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
