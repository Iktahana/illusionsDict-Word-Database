[
  {
    "uuid": "a197fc9b-d2b2-577f-a156-da5d76362f13",
    "entry": "涼しい",
    "reading": {
      "primary": "すずしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
