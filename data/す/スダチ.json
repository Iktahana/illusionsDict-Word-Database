[
  {
    "uuid": "c528700e-4869-5bf7-b1df-a6b1166d7a47",
    "entry": "巣立ち",
    "reading": {
      "primary": "すだち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "leaving the nest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おくれた座敷は、若い妓の背後に控えて、動く処は前へ立って目立たないように取り廻す、というのであるから、お茶屋の蔵の前に目の光る古狸から、新道の塒を巣立ちの雛児まで、「ああ、いい姉さん。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "巣立ちの頃か、羽音が立つて、ひら／＼と飛交はす。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう暦もない　記憶もないわたしは燕のやうに巣立ちをし　さうしてふしぎな風景のはてを翔つてゆかう。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "引き分かれ年は経れども鶯の巣立ちし松の根を忘れめや　少女の作でありのままに過ぎた歌である。",
              "citation": {
                "source": "源氏物語",
                "author": "初音",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようように巣立ちをしたばかりの雛にて、なんという鳥か判らず。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦茶色の頭巾をかぶった燕の子の巣立ちである。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして若鷲の巣立ちを思はせるやうに忙たゞしく東京をさして上つた。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」住友重役の苦笑ひ８・８（夕）　毎年梅雨があけると蜂の巣からは蜂の子が巣立ちをし、方々の大学からは、口髯をちよつぴり生やした若い学士が巣立ちをする。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　堅気の田舎の家庭から巣立ちして来たばかりのお今の生な目には、お増の不思議な生活が、煩わしくも惨めらしくも見えるのであった。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年子供たちがようやく巣立ちに用意しなければならなくなったころ、父は子供たちのこの美徳のために悩まされだした。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかでかく巣立ちけるぞと思ふにもうき水鳥の契りをぞ知る　よい歌ではないがその時は身に沁んで思われた。",
              "citation": {
                "source": "源氏物語",
                "author": "橋姫",
                "note": "青空文庫"
              }
            },
            {
              "text": "世人またこの教えを誤解して、学者は学者、医者は医者、少しくその業を異にすれば相近づくことなし、同塾同窓の懇意にても、塾を巣立ちしたる後に、一人が町人となり一人が役人となれば、千里隔絶、呉越の観をなす者なきにあらず。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、いろいろの事情を綜合して、これを俳優の「巣立ち」と呼んだ。",
              "citation": {
                "source": "芝居と僕",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "年かはるまで塒たて飼ひし雁の子、巣立ちなば、檀の岡に飛び帰り来ね（巻二）と鳥に将来の希望を述べてゐる。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその逃げぶりが蹌々踉々として頼りないこと、巣立ちの鳥のような歩きぶりであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあ三吉、手前も合点長屋の巣立ちじゃねえか、よっく玉を見ろい、そりゃあ、お前出刃の傷じゃねえぜ。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "のの字の刀痕",
                "note": "青空文庫"
              }
            },
            {
              "text": "素子は姉たちのさういふ巣立ちを、まつたく離れたところから眺めてゐた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴山の鶴は巣立ちて遊ぶなり家なる稚児を思ひこそやれ　長女が、今年数え年五十歳になったが、その娘が生れたばかりの時であった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここで養成された看護婦さんの巣立ちだもんだから、どうも手間どって」　実験用テーブルの上の、つつましいピクニックのあとを見まわした。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今巣立ちした、鳥の王なる若鷹のように雄々しい我が息子よ！",
              "citation": {
                "source": "風に乗って来るコロポックル",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、床に入ると、頭の中一杯にそこはかとない韻文や、巣立ち前の着想が満ちあふれた。",
              "citation": {
                "source": "犬酸漿",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉野村別記　いま頃、疎開歸りでもないが、子供らの巣立ちにひかれて、東京へ居を移した。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなることを知って立った、巣立ちの鳥、老いの愚痴が、耳に入るものではない。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "発起人には、窪田清音や知名の旗本や、酒井家の藩臣たちだの、巣立ちの一剣工にはむしろ過ぎた位な人々の名が連ねられた。",
              "citation": {
                "source": "山浦清麿",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い世の中へ、各※、力いっぱいの巣立ちをせよ。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "衆人の中で、恥辱をお与えなさるかと、咄嗟には、むっといたしたが……よう考えてみれば、罪はわしにある」「な、なんの科が」「誰にも云わなかったが、おまえはわしの巣立ちの親だ。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鶯の声まだ渋く聞ゆなり、すだちの小野の春の曙」というときの渋味は、渋滞の意で第一段たる「正」の段階を示している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
