  {
    "uuid": "a448b14d-9f84-5663-a7e1-02ea7c7e41bb",
    "entry": "水飯",
    "reading": {
      "primary": "すいはん",
      "alternatives": [
        "みずめし"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rice washed in cold water",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "氷の水、水飯などを若い人は皆大騒ぎして食べた。",
              "citation": {
                "source": "源氏物語",
                "author": "常夏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついて来た人々に水飯が饗応され、中将には蓮の実などを出した。",
              "citation": {
                "source": "源氏物語",
                "author": "手習",
                "note": "青空文庫"
              }
            },
            {
              "text": "水飯に味噌を落して濁しけり昭和九年七月二十六日　丸之内倶楽部俳句会。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして院が上達部や殿上人と御一緒に水飯を召しあがったという釣殿はどのへんにあったのだろうと右の方の岸を見わたすとそのあたりはいちめんに鬱蒼とした森が生いしげりそれがずうっと神社のうしろの方までつづいているのでその森のある広い面積のぜんたいが離宮の遺趾であることが明かに指摘できるのであった。",
              "citation": {
                "source": "蘆刈",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
