[
  {
    "uuid": "5065d00f-85bf-5403-a637-616853994ecc",
    "entry": "過ごす",
    "reading": {
      "primary": "すごす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
