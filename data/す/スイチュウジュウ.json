        "examples": {
          "standard": [
            {
              "text": "スピアフィッシングの愛好家たちが、手入れの行き届いた水中銃を船に積み込む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大型の獲物を狙うため、強力なゴムを装着したプロ仕様の水中銃を購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "水中銃の使用には厳しい規制があるため、事前に現地のルールを確認しておく必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そのはだかの人たちはみんな、背中に酸素のボンベをつけ、水中めがねをもち、足のさきには、大きな水かきをはめ、手には、みょうな形の水中銃を持っていました。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし出てきたら、水中銃でうってやろうと、はだかの勇士たちは待ちかまえているのです。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三人のはだかの勇士が、水中めがねをつけ、ボンベをせおい、足には大きな水かきをつけ、水中銃をかまえて、ほら穴の上下左右を、じゅうおうに泳ぎまわっているありさまは、じつにいさましい光景でした。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、水中銃で八人のきみの部下をおどかし、人魚の鉄の皮をぬがせて、おれたちがいれかわったんだ。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
