[
  {
    "uuid": "36f9de14-f260-5265-aebd-15f5c7065c84",
    "entry": "推古時代",
    "reading": {
      "primary": "すいこじだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
