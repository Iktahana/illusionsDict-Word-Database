[
  {
    "uuid": "f2b8f0aa-00f4-59b2-a4a4-8ce4ae82e00c",
    "entry": "推進",
    "reading": {
      "primary": "すいしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "propulsion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また推進器の羽で水を艫部に打ち付けるためにいくぶんの振動を起すが、これは船体の枢要な箇所を丈夫にすれば大抵防がれる事になる。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後方に一輪車が取り付けられ、そうして三つの輪の中央のサドルに腰をかけた人がペダルを踏んで推進する仕掛けになっている。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間がある限り、その中に在ってその発展の方向を示し、これを浄化推進して行く羅針盤兼、白血球であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくも驚くべき速力を有するのは全く艇の形體と、蒸氣力よりも電氣力よりも數十倍強烈なる動力による事は疑を容れぬが、殊に艇尾兩瑞に裝置されたる六枚の翅を有する推進螺旋の不思議なる廻轉作用の與つて力ある事を記臆して貰はねばならぬ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "本艦は一令の下に推進螺旋波を蹴つて進航を始めた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼年から数奇な運命は彼の本来の性質の真情を求めるこころを曲げゆがめ、神秘的な美欲や愛欲や智識欲の追躡といふやうな方面へ、彼の強鞣な精神力を追ひ込み、その推進力によつて知らぬ間に、彼の和漢の学に対する蘊蓄は深められてゐた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、明治の御維新は決して蘭学者たちに依って推進せられたのでは無い、と言いはじめた。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "町政の溌剌たる推進をさまたげる妙な古陋の策動屋みたいなものがゐるんぢやないか、と私はＮ君に尋ねたら、この若い町会議員は苦笑して、よせ、よせ、と言つた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "推進機でかきまぜた泥水が恐ろしく大きな渦を作って潮に流されて行く。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀之内さんのページからたどって、ＢＢＡのサイトを開くと、「弱視者を含めた視覚障碍者全般の読書を支援するために点訳・音訳・拡大訳の３分野の活動を全て統合的に推進しています。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「知的財産戦略の推進」を国策としている我が国は、著作権保護のあり方について国際間の調和を図るべきである。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「知的財産戦略の推進」を国策とし、コンテンツビジネスの積極的な海外展開を進めようとしている我が国は、保護期間をはじめとする著作権保護のあり方について、国際間の調和を図るよう努力すべきである。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ米ＰＣ　ＭＡＧＡＺＩＮＥからの強力スタッフに加えて日本からは、東芝の溝口哲也パソコン・ワークステーション事業部長、日本電気の高山由パーソナルコンピュータ販売推進本部長、古川享マイクロソフト社長、脇英世東京電機大学助教授の豪華メンバーである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンは誰が何といおうとＳＰＡＲＣを推進するし、アップルは自分でマッキントッシュのＯＳをＲＩＳＣに乗せる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その谷がやがて、ともへ行くと推進器は空中でから回りをする。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "推進器は、飛行機のプロペラーのように空中で回転する。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "速力は今ではもう推進器の空転の危険から、ほとんど三マイルぐらいに減じられて、ただ船首を風の方向から転換しないようにのみすべての努力を尽くしていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "推進機の油差しに出掛けて誤ってこぼしたらしいです。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして人は強い衝動によって推進の力を与えられる。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "検疫官がその忙しい間にも何かしきりに物をいおうとした時、けたたましい汽笛が一抹の白煙を青空に揚げて鳴りはためき、船尾からはすさまじい推進機の震動が起こり始めた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "舷側には双つの水車様の推進器を備へてゐた。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもテイクロトロンを以てボロンの原子崩壊を適度に続行させ、それを以て飛行機を推進させると、航続距離は殆ど無限であり、飛行機上で年を重ねることも可能である。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "テイラー博士「余の苦心せるところは、如何にして原子崩壊の際生ずるエネルギーを、航空機推進力に転換せしめるかということ、それから如何にして最少のエネルギーを取出すかということであった。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが国は今日より非常推進を行うのです」「非常推進か。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「渋谷博士の最大の犠牲がロケットをふたたび推進させた。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、日が経つて、再びそんな稿を翻して見ると、無意識なる、凡々たる日録のうちにも、何か、再び廻り合せぬかの如き心の媚惑と、「物質の鉄則から釈放されたる宇宙」に向つての止め度もなき霊の推進器の飽くなき回転の響きを耳にする思ひがする、たゞ、それが春であつたがために――あゝ、わたしは、今日！",
              "citation": {
                "source": "波の戯れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもわたる渡良瀬川の渡しを渡って土手の上に来ると、ちょうど眼の前を、白いペンキ塗りの汚れた通運丸が、煙筒からは煤煙をみなぎらし、推進器からは水を切る白い波を立てて川をくだって行くのが手にとるように見えた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三三年以後日本のファシズムと侵略戦争の推進に対して、不幸な日本人民とその芸術家であるべき作家はあまり無力でした。",
              "citation": {
                "source": "心から送る拍手",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
