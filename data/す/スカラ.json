        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "デスカラ身体ヲ大事ニスルヨウニクレグレモ願イマス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケレド　ナタネノ　ツボミト　イツシヨニ　ソダツタ　テフテフデスカラ、ナタネノ　花タチトハ　タイヘン　ナカヨシデシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヤア、チヒサイネ」「コドモデスカラネ」「コレデハ、オトナニ　ナツテモ　アマリ　オホキク　ナリマスマイ」「イヤイヤ　オトナニ　ナツタラ、コヤクラヰノ　オホキサニ　ナル」「ダマサウタツテ　ダメダヨ」「ホントウデスヨ。",
              "citation": {
                "source": "ウサギ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナニシロ、イマニ、コヤミタイニ　オホキナ　ロバニ　ナルト　イフノデスカラ、チヒサナ　クルマデハ　マニアヒマセン。",
              "citation": {
                "source": "ウサギ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ケフハ　ガチヨウサンノ　タンジヨウビデスカラ　オデカケ　クダサイ」「ア、サウデスカ」「トコロデ、イタチサン、ヒトツ　オネガヒガ　アルノデスガ」「ナンデスカ」「アノ、スミマセンガ、ケフダケハ　オナラヲ　シナイデ　クダサイ」　イタチハ　ハヅカシクテ、カホヲ　マツカニ　シマシタ。",
              "citation": {
                "source": "ガチヨウノ　タンジヨウビ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夜「ラ、スカラ」座に入りて樂曲を聽きたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれは、慶一や柾生と、スカラ座でビートルズの二本立てだ」　高志がヴェランダにもどりながらこたえた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度工場外ニ足ヲフミ出シテ見レバ分ル通リ、当工場ハマサニ「Ｙノフォード」タル名ニ恥シクナイ充分ノ待遇ヲ、ソノ時間ノ点カラ云ッテモ、ソノ賃銀ノ上カラ云ッテモ、皆サンニ与エテ居ルノデアリマスカラ、コノ際決シテ、カヽル宣伝ニ附和雷同セザル様、呉々モ申述ベテ置ク次第デアリマス。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "領主の公爵エスカラス、從者多勢を引連れて出る。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園からタクシーを拾い、スカラ座までと云う。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "スカラ座の横でタクシーが停ったが、門がどこも閉っている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "スカラ座出演、ほぅ。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人の健啖10・22（夕）　話はずつと古くなるが、伊太利の詩人ダンテが、ある時カアネ・デラ・スカラ家の食事に招かれた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひろい地域に壮麗な樹木・芝生・音楽堂・劇場――アポロ、スカラ、パレス等――がちらばり、東西に二大料理店あり。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケレド、七五銭、払ウデス――ワタシ、神様｜恐ワイデスカラネ。",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし日本もかなり文化したのだから、僕のようなスカラア・ジプシイの思想と芸術を尊重して、仏蘭西に洋行でもさせてくれる酔狂な金持ちの二、三人位はそろそろ出てきてもよさそうなものだ。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、モスクワできき、ベルリンできき、大いにやかましく云々されるスカラ座のオペラをきいて、オペラという音楽の形式そのものが過去のものになりかかっていて、我々には退屈な部分があるということを云ってもあやまりとは考えられないことを発見したのだ。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはスカラ座のカルメンの舞台群衆と比べると直ぐわかる。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルリンでスカラ座のカルメンを見たとき、スカラとも云われるものが、あんまり群集をぞんざいに扱っているのにおどろいた。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋ニハ電気ガツイテ居マスカラハッキリワカリマス。",
              "citation": {
                "source": "夢の殺人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "デスカラドンナ事ガ起ルカ知リマセンガ、何デモオ婆サンノ話デハ、『アグニ』ノ神ガ私ノ口ヲ借リテ、イロイロ予言ヲスルノダソウデス。",
              "citation": {
                "source": "アグニの神",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "オ婆サンハ何ヨリモ『アグニ』ノ神ガ怖イノデスカラ、ソレヲ聞ケバキット私ヲ返スダロウト思イマス。",
              "citation": {
                "source": "アグニの神",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "オカネハ、イツモノヨウニ、ハンヲ、オシテ、アリマスカラ、コノママキョクヘ、トリニユキナサイ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オカネハ、イツモノヤウニ、ハンヲ、オシテ、アリマスカラ、コノマヽキヨクエ、トリニユキナサイ。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ机の曳出から分厚い強度の近眼鏡と、カルモチンと同じ位のカスカラ錠の瓶を探し出しただけであった。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カスカラ錠は下剤じゃないですか」「そうです。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "近眼だもんですからカスカラとカルモチンを間違えて服んだんですね。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まかり出でたるキチガイ坊主……スカラカ、チャカポコ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "スカラカ、チャカポコ外聞晒す。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
