    "definitions": [
      {
        "index": 1,
        "gloss": "horizon (related to bodies of water)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第一行を読んで、先づ見えて来るのは水平線である。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "地平線と水平線とを別として、我が日本国において見らるべき、有らゆる斜線と曲線の中で、これこそ最大最高の線であろうと、いつも東海道を通行するたびに、汽車の窓から仰ぎ見て、そう思わないことはない。",
              "citation": {
                "source": "日本山岳景の特色",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方見廻す限り陸地の影も見えぬ、ただ水平線上に幾筋かの横雲が静かに横たわっていると想像する。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた船が一直線に進んでいる時遥かな水平線上の雲などを見ていれば雲も動かず船も動かず、いつまでも同じ処で波を切っているような気がする。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "万字は垂直線と水平線との結合した十字形の先端が直角状に屈折しているので複雑な感を与える。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまだそれだけでは美的芸術の水平線に達する事は出来ない。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語に「霧の堤」という語があるが、これは障るという意味よりはむしろ海上などで霧が水平線に堤のように下りて陸と見違えるようなのをいうそうである。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水平線に赤いラインが鬼火のように明滅しだすと機関室からエンジンの廻転が響きだす。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀色の絞られた水平線まで彼女は片脚あげて、恋愛の条約による奥の手を英介氏にひらめかすのであった。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くの水平線は灰色の靄に隱されて、海と空との間に、陸奧の山々が幽かに浮んで見えた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに水平線の上のむくむくした雲の向うから鉛いろの空のこっちから口のむくれた三｜疋の大きな白犬に横っちょにまたがって黄いろの髪をばさばささせ大きな口をあけたり立てたりし歯をがちがち鳴らす恐ろしいばけものがだんだんせり出して昇って来ました。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうタネリは小さくなって恐れ入っていましたらそらはすっかり明るくなりそのギリヤークの犬神は水平線まですっかりせり出し間もなく海に犬の足がちらちら映りながらこっちの方へやって来たのです。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずか数｜浬の遠さに過ぎない水平線を見て、『空と海とのたゆたいに』などと言って縹渺とした無限感を起こしてしまうなんぞはコロンブス以前だ。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれが海を愛し空想を愛するというなら一切はその水平線の彼方にある。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水平線を境としてそのあちら側へ滑り下りてゆく球面からほんとうに美しい海ははじまるんだ。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裾のぼやけた、そして全体もあまりかっきりしない入道雲が水平線の上に静かに蟠っている。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は先ほどの入道雲が水平線の上へ拡がってザボンの内皮の色がして、海も入江の真近までその色に映っていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今太陽の没したばかりの水平線の彼方を眺めている。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験や観測でなくて純粋な理論的の考察であっても、一つの指導的なイデーが頭に浮かぶのは時としては瞬間的であって、そうして、かろうじて意識の水平線の上に現われるか現われないかという場合がある。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海は凪いで、大島の噴火のけむりが、水平線の上に白くたちのぼつてゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "茫々たる海の極は遠く太平洋の水と連なりて水平線上は雲一つ見えない、また四国地が波の上に鮮やかに見える。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "青麦につづく紺青の、水平線上｜雪一山。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九二三ヽ八ヽ一ヽ）津軽海峡夏の稀薄から却って玉髄の雲が凍える亜鉛張りの浪は白光の水平線から続き新らしく潮で洗ったチークの甲板の上をみんなはぞろぞろ行ったり来たりする。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東の空が白んで來て、融々なる朝日の光が水平線の彼方から、我等の上を照して來るのは昨日に變らぬが、變り果てたのは二人の境遇である。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "武村兵曹と私とは、帽を脱して下方を瞻めたが、風は南から北へと、吾が輕氣球は、三千｜數百｜尺の大空を、次第／＼に大陸の方へと、やがて、住み馴れし朝日島も、蒼渺たる水平線上に豆のやうになつて消え去つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚呼、大事切迫／＼と、私は武村兵曹と顏を見合はしたる儘、身體の置塲も知らぬ程心を惱まして居る、時しも忽ち見る、遙か／＼の水平線上に薄雲の如き煙先づ現はれ、つゞゐて鳥か船か見え分かぬ程、一點ポツンと白い影、それが段々と近づいて來るとそは一艘の白色巡洋艦であつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "水平線上は一脈｜金色である。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一朶の珊瑚島のごとく水平線上に浮いた夕日の雲が反射したのである。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "大野裕と一緒に「読書 blog――すいへいせん」を始めた ten。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
