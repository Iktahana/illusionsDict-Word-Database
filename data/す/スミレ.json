    "definitions": [
      {
        "index": 1,
        "gloss": "violet (any flower of genus Viola, esp. the Fuji dawn, Viola mandshurica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その時だ、その壺が花を開く、その花は、夜の部屋にみる、三色菫だ。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "春晝――敍情小曲――萩原朔太郎うぐひすは金屬をもてつくられしそは畔の暗きに鳴き菫は病鬱の醫者のやうに野に遠く手に劇藥の鞄をさげて訪づれくる。",
              "citation": {
                "source": "春晝",
                "author": "――敍情小曲――",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠の詩人宿命生涯を貫く萩原朔太郎　僕は少年の時、島崎藤村氏と薄田泣菫氏の詩を愛讀した。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤村氏と泣菫氏とは、少年時代の僕にとつて共に同じやうに好きであつた。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどつちかと言へばむしろ泣菫の方が好きであつた。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "その理由は、泣菫の詩に於ける特殊な佶屈の言葉と、その詩情に本質してゐる孤獨な憂鬱の陰影とが僕の個性に近く接觸するものがあつたからだ。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし藤村をゲーテとすれば、當時の泣菫はキーツであつた。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣菫の方は、どういふものか、僕にとつて昔の魅力を無くしてしまつた。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "その泣菫氏の自選詩集には、僕が昔愛讀した詩が殆んど皆オミツトされ、僕の嫌ひだつた詩ばかりがしかも多くの斧鉞を加へて集めてある。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣菫氏の詩は、その初期の物（暮笛集・ゆく春）ほどよく、純粹なリリシズムが盛られて居るのに、自選詩集には、却つてその詩情を稀薄にした後期の敍事詩風の作が多く入れられてある。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり言へば薄田泣菫氏や蒲原有明氏やは、或る若い時代だけ詩人であり、後に年を取つてからは、本質的にそのリリシズムを喪失してしまつたのである。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "火に充ちし手のナポリの聖女、心菫に泣ける薔薇、聖ギヂルが花、汝は見しや天の砂漠に汝が十字架？",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨拾ふ人に親しき菫かな　焼場に菫が咲いているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちよつと菫に似てゐますね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁が、草の茵に座って、しずかにその暮山を眺めやるとき、山のむらさきから、事実、ほのかで甘く、人に懐き寄る菫の花の匂いを翁の嗅覚は感じた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに反して、緑、青、菫は魂の薄明視に未だ残っている色である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "島崎藤村……全詩集中の詩大半薄田泣菫……暮笛集・ゆく春蒲原有明……春鳥集・獨絃哀歌三木露風……廢園・白き手の獵人北原白秋……邪宗門・思ひ出（二重圈點◎を附したのは、特に名詩集たるもの。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば名詩集「ゆく春」の詩人泣菫は、後に「白羊宮」や「二十五絃」のやうな駄詩集――熱も色氣もないペダンチツクな駄詩集――を出して得意で居るし、神祕冥想の偉才詩人三木露風も、最近羅風と改名してからロクな詩は作つて居ない。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "重さ五匁ほどもある、にほひ菫のひからびきつた根つ株だ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして本の新鮮なのや褪色した黄色、裝幀本の菫がかつた褐色、それからアルバムの幅の廣い緑色など、それ等すべてのものが調和し、效果を上げ、それぞれの役割をしつつ、何一つ缺くるところのない全體を形づくつてゐるのだ。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁さきは夜を截るほとゝぎす、　　やがてはそらの菫いろ、小鳥の群をさきだてて、　　　　くわくこう樹々をどよもしぬ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔雪げの水に涵されし〕雪げの水に涵されし、　　　御料草地のどての上、犬の皮着てたゞひとり、　　菫外線をい行くもの。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうに光炎菩薩太陽マジックの歌はそらにも地面にもちからいっぱい、日光の小さな小さな菫や橙や赤の波といっしょに一生けん命に鳴っています。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち次の電光は、マグネシアの焔よりももっと明るく、菫外線［※６］の誘惑を、力いっぱい含みながら、まっすぐに地面に落ちて来ました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "※６　菫外線＝紫外線。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、私｜共の眼に感ずる光の波長は、　　　　　　　　　　〇、〇〇〇七六｜粍　　（赤色）　　乃至　　　　　　　　　　〇、〇〇〇四　粍　　（菫色）　　ですからこれよりちいさなものの形が完全に私｜共に見えるはずは決してないのです。",
              "citation": {
                "source": "手紙　三",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "凧のかげ夕方かけて読書かな夕立やかみなり走る隣ぐに沓かけや秋日にのびる馬の顔鯛の骨たたみにひらふ夜寒かな秋ふかき時計きざめり草の庵石垣に冬すみれ匂ひ別れけり　彼の俳句の風貌は、彼の人物と同じく粗剛で、田舎の手織木綿のやうに、極めて手触りがあらくゴツゴツしてゐる。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　すみれ娘　日本の近代映画でも、ＰＣＬの提供するものの中には色々な点で有望な進歩の動向を示しているものがあるように思う。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「すみれ娘」などもその一例である。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主役のすみれ娘はオリジナルな愛嬌と頭脳の持主らしく随所に一種の俳諧を発揮しているようである。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
