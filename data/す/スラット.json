[
  {
    "uuid": "ca7cac31-a354-5a12-96a7-46c15938f0fc",
    "entry": "すらっと",
    "reading": {
      "primary": "すらっと",
      "alternatives": [
        "スラッと",
        "スラっと"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "slender",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ちと気が狂れて血相変り、取乱してはいるけれど、すらっとして中肉中脊、戦慄とするほど美い女さ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が心を惹かれる女は例外無しに背が高くすらっとしている。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒っぽい着物が似合うのは、すらっとした女である。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばりばりと音たててＫの傘が、バスの車輪にひったくられて、つづいてＫのからだが、水泳のダイヴィングのようにすらっと白く一直線に車輪の下に引きずりこまれ、くるくるっと花の車。",
              "citation": {
                "source": "秋風記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "背丈すらっとして色も白い方でちょっとした娘だ。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちど、滝壺ふかく沈められて、それから、すらっと上半身が水面から躍りあがった。",
              "citation": {
                "source": "魚服記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽も抜群であるし、絵をかかせればやはり目をひくだけの才気を示し、人の心の動きを理解する力も平凡ではないのに、桃子にはとことんの処へ行くとすらっと流れてしまうものがあった。",
              "citation": {
                "source": "二人いるとき",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ウルリーケのすらっとした喪服姿が、おりからの潮風に煽られて、髪も裾も、たてがみのように靡いているところは、どうして、戦女とでも云いたげな雄々しさであった。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士は背のすらっとした、どこか花車な所のある老人で、折目の正しい黒ずくめの洋服に、上品な山高帽をかぶっていた。",
              "citation": {
                "source": "開化の良人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その調子で泳いでいきながら、だんだん楽な快い、すらっとしたこころもちが湧いてきた時、フォームがわかったのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばんいい服を着て、背が高く、すらっとしていて、ほがらかで。",
              "citation": {
                "source": "寡婦とその子",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "すらっとしたものなの……志貴子の追悼会をやったあとで、久能徳が本門寺の書院で、いろいろとお助けいただいたご恩にたいしても、生涯、志貴子は東京へ出しません。",
              "citation": {
                "source": "猪鹿蝶",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう見ても、すらっとも、細くなったようにもみえない。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいいちいくらかすらっとして見えるだけでもたしかにこのほうがいい。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "すらっとして優男で、何よりも、その顔だ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩せぎすの、すらっとしたいいようすで、眼だけは例によってちと大きいが、女となるとこれがかえって艶をます。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "初春狸合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、子供の乗る台バカリだったが」「そういえば、お出かけになるときより、ずいぶん、すらっとなすったわ……熱い湯に、たびたびつかると、一時は、やせるといいますから」「そういうね」「おばさま、おやせになるために、温泉へいらしたというわけ？",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あっしゃ、すらっとした後ろ姿を拝見しただけだったが、連中の話じゃ、二十三四のモダン・ガールで、こいつがどうもやけにいい女だったそうでさア。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "すらっとしたものよ……志貴子の追悼会をやったあと、久能徳が本門寺の書院で、いろいろとお助けいただいたご恩にたいしても、生涯、志貴子は東京へ出しません。",
              "citation": {
                "source": "姦（かしまし）",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなかそう、すらっと通じ合うものじゃない」　素子は自分の生家のこみいった父との関係を思いめぐらす風だった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すらっと書いたものには「思う」なんか特別どっさりはありはしないのです、生活と本にしたって。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "おずおず振り向くと、ネズミ色のオーバーを着て、ネズミ色の鳥打ち帽をかぶった、すらっと背の高いおじさんが立っていた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "上背のあるすらっとした躯つきで、色が白く、透きとおるように薄い肌をしていた。",
              "citation": {
                "source": "扇野",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五尺そこそこの小柄な躯つきであるが、ぜんたいの均整がよくとれているので、立ち居の姿はかたちよくすらっとしてみえる。",
              "citation": {
                "source": "つばくろ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女主人のおるいは躯こそ小柄だが、ちょっと珍らしいほどの美貌で、細おもての顔や躯つきが調和がとれているため、すらっとして背丈が高いようにみえた。",
              "citation": {
                "source": "へちまの木",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「背が高くて褐色の肌、目はきらきらしてて綺麗に髪をカットしている、脚がすらっとしていて、しなやかなボディの女だったろう？",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハネて、宿がいけないので、すらっと帰る気せず、すきやき食って帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして不承不承に立った姿は、さいぜんまでのみにくいせむし男とは、似ても似つかない、すらっとした好男子でした。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴったりと身についた、黒のビロードのシャツとズボン、そのすらっとした姿が、なんのさえぎるものもない、広い広い青空のなかに、立ちあがっているけしきは、じつに異様な感じのものでした。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもの黒い背広をきた、すらっとした姿が、そこに立ちはだかっていました。",
              "citation": {
                "source": "魔法人形",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
