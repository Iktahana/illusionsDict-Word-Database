          "literary": [
            {
              "text": "話をしてみると、マーケティングマネージャーのデーブ・スコットは、長時間テストしてベアリングが完全に磨耗した試作装置をスペアーのベアリングを付けて提供してくれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたがいなくなってもあなたの代りにあなたの仕事をやってくれるスペア人間は世の中にいくらでもいる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "光子さんと私とが奥の方い並んで、お梅どんと綿貫とがスペアシートい腰かけて、四人がむうッと向い合うたなり一と言も口をきかんと、車はどんどん走って行きました。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
