        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "snap (of the wrist; in baseball, golf, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そう云えば、あんたから送って来た戦地のスナップショット、どれもこれも、とてもお天気がいいね。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞄のスナップのあまくなっている個所を修繕している。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "片方は糸で修繕した鉄ぶちの眼がねをかけ、スナップ三つあまくなった革のカバンを膝に乗せ、電車で、多少の猫背つかって、二日すらない顎の下のひげを手さぐり雨の巷を、ぼんやり見ている。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東山――こないだ東京駅の待合室で例の事件のあったとき、うちの記者がスナップしたのが運よくカメラにおさまったのです。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "○演出者が大きな椅子にふんぞりかえっているスナップ写真ほど不思議なものはない。",
              "citation": {
                "source": "演技指導論草案",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾崎士郎氏は名調子の感傷とともにではあるが、それとは異った他の人間的情況のスナップをつたえようとしている。",
              "citation": {
                "source": "明日の言葉",
                "author": "――ルポルタージュの問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、そのスナップは一つの「家族写真」で、幸福そうな若夫婦はエリザベス王女とエディンバラ公であった。",
              "citation": {
                "source": "権力の悲劇",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわいらしい男の赤ちゃんはチャールズで、夏別荘に暮している一家のスナップなのだった。",
              "citation": {
                "source": "権力の悲劇",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "数々のスナップのうちで、こんなに自然な若い母の笑顔にとけた彼女の表情はほんとにめずらしい、彼女の女として幸福を感じる瞬間は、その生活のどんなところにあるかということを思わせる写真だった。",
              "citation": {
                "source": "権力の悲劇",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのスナップには「写真班は、救急班の到着を待ちかねた」という意味のスクリプトがついている。",
              "citation": {
                "source": "権力の悲劇",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の十二月、ブダペストで開かれた世界民主婦人連盟の第二回大会では、日本のわたしたちが心をうたれるいくつかのスナップ写真がとられている。",
              "citation": {
                "source": "人間イヴの誕生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その児島君のひとりに頼んで、薔薇を背景に私たちをスナップしてもらう。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者は、たいへん詰らない鬼村博士のスナップを、意味もなくだらだらと諸君の前に拡げたようであるが、これこそは最も意味のある大切なスナップなのであることは、頁を追ってゆくに従ってお判りになろうと思う。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、このスナップに現われたる鬼村博士の調子は、実に博士の性格の全部をものがたるものと云ってよい。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければあんまり早くアメリカ風になったという題でうつされている植民地的ハイカラーな日本娘のスナップがある。",
              "citation": {
                "source": "偽りのない文化を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　そろそろ時間になるので、ミサ子が衝立のかげで仕事着のスナップをかけているところへ、「ちょいと」　廊下かられい子が手招きをした。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其のコダックのスナップシャットと照らし合わせて、若いほうの女は、手紙の主「ヘドウィッグ・サミュエルスン」に相違ないと断定された。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面だの横向だの、或は顔半分など、瞬間のスナップの小さなものだが、そうした人間の顔がずらりと並ぶと、その一つ一つが妙に生きあがってきて、何か意味をもつようだった。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "通三丁目のところ、むつかしい顔して歩いていたら、スナップやが珍しくとった。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "百号のカンヴァスよりもベストの一スナップに受ける感覚のほうに現実性がより鋭くあらわれる。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくその思いがけないスナップ材料に、僕はおもいきり喰い下がって、遂にパシャンとシャッターを切った。",
              "citation": {
                "source": "ヒルミ夫人の冷蔵鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人類は、いま、百号のカンヴァスに描かれたる悲壮な戦場の光景よりも、ライカの一コマによってスナップされた一情景のほうが、何か清新であり、凄壮なる事実感にうたれるのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は学生時代、十字街に弾丸にうち散らばらされている群衆を俯瞰した十月革命の一スナップに、刺し貫かれるような感動を覚えた経験をもっている。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "木綿の洋服の脇のスナップが音をたててはずれた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カレワラのマダムとはあるのでしょう」「何故」「だってお互に好きなのでしょう」　彼女は洋服のスナップをとめながら、仁科六郎にきいてみた。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "からりと晴れた或日の晝さがり、街上でふと見かけた女のスナップである。",
              "citation": {
                "source": "荷風翁の發句",
                "author": "心猿",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
