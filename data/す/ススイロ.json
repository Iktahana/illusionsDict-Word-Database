    "definitions": [
      {
        "index": 1,
        "gloss": "color of soot (colour)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "灰で塗られた雪田は、風の吹きつけた痕らしく、おもてに馬蹄形の紋をあらわしている、焼岳の右の肩から遠くの空へ、飛騨の白山つづきの山脈が、広重の錦絵によく見るような、古ぼけた煤色をぼかしている。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤色と紺の細かい弁慶縞で、羽織も長着も同じい米沢紬に、品のよい友禅縮緬の帯をしめていた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれは全く、作者に未知な絶えざる警異に値する世界自身の発展であつて決して畸形に涅ねあげられた煤色のユートピアではない。",
              "citation": {
                "source": "『注文の多い料理店』広告文",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれは全く、作者に未知な絶えざる驚異に値する世界｜自身の発展であって、けっして畸形に捏ねあげられた煤色のユートピアではない。",
              "citation": {
                "source": "『注文の多い料理店』新刊案内",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朽葉色に垢附きて、見るも忌わしき白木綿の婦人の布を、篠竹の頭に結べる旗に、（厄病神）と書きたるを、北風に煽らせ、意気揚々として真先に歩むは、三十五六の大年増、当歳の児を斜に負うて、衣紋背の半に抜け、帯は毒々しき乳の上に捩上りて膏切ったる煤色の肩露出せり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この四五日、引続く暑さと云うは、日中は硝子を焼くが如く、嚇と晴れて照着ける、が、夕凪とともに曇よりと、水も空も疲れたように、ぐったりと雲がだらけて、煤色の飴の如く粘々と掻曇って、日が暮れると墨を流し、海の波は漆を畝らす。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その幹深く枝々を透して、ぼーッと煤色に浸んだ燈は、影のように障子を映して、其処に行燈の灯れたのが遠くから認められた。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨寺の壁に見るような、雨漏の痕の画像は、煤色の壁に吹きさらされた、袖のひだが、浮出たごとく、浸附いて、どうやら饅頭の形した笠を被っているらしい。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこの肥って善良な七面鳥が奥の室から廉物の蓄音機を、耳環をちらちらで擁え出して来て、窓際の小さな卓子に据えると、煤色の大きな喇叭の口を私たちの方へ差向けたものだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "土人たちは幾つかの煤色の天幕の前に簇っていたが、私たちの舟が通ると盛んに色々の光る布を頭の上でうち振った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうに落葉し盡した榛の枝には、殻になつた煤色の實が點々として其された枝々について居る。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "西浦賀の岸壁に、シルエツトのやうな煤色に塗られた一艘の不思議な船を、誰でも見出すであらう。",
              "citation": {
                "source": "或るハイカーの記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私は、彼の薄い皺のやうな感じが漂うてゐる煤色の顔や、小さく凹んだ眼や、乾いて艶の悪い唇や、へうきんに身軽な挙動や、ちひさく痩せた躯の恰好などに、雀に接するやうな滋味を感じてゐた。",
              "citation": {
                "source": "泉岳寺附近",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "火に入れば熱い焔色、燻りむせる煙に巻かれれば見わけのつかない煤色になって、恐れて逃る人間達を導き導き空気とともに勇気を与え、必要な次の営みにつかせます。",
              "citation": {
                "source": "対話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼の国から吹き上げる風が石の壁の破れ目を通って小やかなカンテラを煽るからたださえ暗い室の天井も四隅も煤色の油煙で渦巻いて動いているように見える。",
              "citation": {
                "source": "倫敦塔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは背の低い眼の凹んだ煤色の男である。",
              "citation": {
                "source": "倫敦塔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は前に穴倉の裏で歌をうたっていた、眼の凹んだ煤色をした、背の低い奴だ。",
              "citation": {
                "source": "倫敦塔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の凹んだ、煤色の、背の低い首斬り役が重た気に斧をエイと取り直す。",
              "citation": {
                "source": "倫敦塔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざわざわ、ざわざわ、不安に西北風が灌木や樹々の梢を戦がせると見るうちに、空は、一面煤色雲で覆われる。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「六日午後実母公得卒中風、昏睡不醒、吐濁唾煤色。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村は「非常持出」と書いた札の張ってある、煤色によごれた戸棚から、しめっぽい書類を出して来て、机の上へ二山に積んだ。",
              "citation": {
                "source": "あそび",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘さうな水分を含んだ、しつとりとしたお菓子が、規帳面に並んだ上を、白い雲の集團が煤色の影を落しながら飛んでゆく。",
              "citation": {
                "source": "梁上の足",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩廊の中にづらりと並んだ店から土産物を勧める声に振返りもせず、左に高い鐘楼を一｜瞥した儘僕はサン・マルコ寺の煤色をした扉を押して入つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」〔無題〕薔薇の花打つ、あな憎し、煤色の雨、砂の風。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "グロテスクな装飾をもった背の高い建物は、煤色の夜霧のなかに、ブルブル震えながら立ち並んでいた。",
              "citation": {
                "source": "ネオン横丁殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "府中へ来ると、煤色に暮れた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、駕籠の中から、駕籠舁に向って注文しました、「尺八を一本求めたいが、新しいのでもよし、古いのでもかまわない」　やがて、その望みが叶うて、とある道具屋で、駕籠舁が一本の煤色した尺八を求めてくれました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "心づくしの柿の葉鮨を、眼を伏せながら口へ運んでいると、去年の秋、見て来た滕県城の煤色の重々しい城壁のすがたがありありと瞼の裏に浮んで来た。",
              "citation": {
                "source": "生霊",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その際は、お騒がせいたしましたな」　と、左門は、削けた、蒼白い頬へ皺を畳み煤色の唇を幽かにほころばせて微笑した。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔色はいつもどおり蒼白かったが、いつも煤色の唇は赤くさえあった。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
