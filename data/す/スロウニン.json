    "definitions": [
      {
        "index": 1,
        "gloss": "poor or lowly masterless samurai",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
