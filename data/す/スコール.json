    },
    "definitions": [
      {
        "index": 1,
        "gloss": "squall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "スコールは右手の西南に去って、市街の出岬の彼方の海に、まだいくらか暗沫の影を残している。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の男の皮膚はスコールの後の野鼠の様に絶えず汗でびっしょり濡れている。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "人夫たちはベンゲット山腹五千フィートの絶壁をジグザグによじ登りながら作業しなければならず、スコールが来ると忽ち山崩れや地滑りが起って、谷底の岩の上へ家守のようにたたき潰された。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗ろうとすると、スコール襲来、再び家に戻り、半時間休んでから、五時出発、またボートとカヌーとに分乗。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途中、又スコール。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の午後、スコールが過ぎたあとの夕方、丘の上を騎乗していた時、突然、或る恍惚たるものが心を掠めたように思った。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "有難いなと思つて、急に眞黒になつた空を見上げてゐる中に、猛烈なスコールがやつて來た。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "椰子の葉を叩くスコールの如く、麺麭の樹に鳴く蝉時雨の如く、環礁の外に荒れ狂う怒濤の如く、ありとあらゆる罵詈雑言が夫の上に降り注いだ。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "有難いなと思って、急に真黒になった空を見上げている中に、猛烈なスコールがやって来た。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "有難いなと思つて、急に真黒になつた空を見上げてゐる中に、猛烈なスコールがやつて来た。",
              "citation": {
                "source": "夾竹桃の家の女",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十吉「南方で僕に会うてもし雨が降っても、もう僕のせいじゃない、南方じゃ毎日雨が降る、スコールという奴だ、もう僕は雨男じゃない、今日は絶対に雨は降らせませんよ」そう言い捨てゝ、また坂を降りて行く。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは例のスコールがやつて來る時だ。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "スコールはひどい夕立だと思へばいゝ。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "スコールの時間は、短いもので大體三十分、長いものになると二時間も降つてをることがあるが、まあ平均して一時間くらゐの長さのものである。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その離れる前からスコールが迫つてゐて既にぽつりぽつりと大粒の雨が顏に當つてゐた。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの乘つてゐた舟艇は約三十分ぐらゐで目的の海岸に到着する筈のところ、スコールに惱まされて約一時間半も海上に漂つてをつた。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時私はスコールによつて海がいかに激しく荒れるかといふことをはつきりこの目で見た。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "スコールの雨粒の一つが頬に當つてもまるで大きな霰が當つたやうに痛い、そこへ持つて來て今申す瀧のやうな海水を頭からかぶるので私たちは舟の上にゐるのだか波の中に漂つてゐるのだかわからないほどであつた。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしかういふ美しい海もスコールが起きて來るといふとまつたく體の色を變へてしまふ。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "スコールに叩かれる海面はその大粒の雨によつて眞白になる、しかし舷から波立つ海面を見れば、海の色は非常に濁つて黒ずむ。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがスコールが引いてしまへばまた元の鮮かな色に返る。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "船醫の話では明け方にスコールが通つたのでかう凉しいのだとの話であつた。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうスコールが來るやうなところまで來たかとちよつと嬉しくなつた。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日猛烈にスコールがあつた。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "豫ねてスコールは激しい夕立だと聽いてゐたが、激しい夕立どころの騷ぎではない。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "スコールだ、愚圖々々してをるとあの瀧のやうなスコールにずぶ濡れになる虞がある。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾花吹くスコール速し雲の峰ペナン行花さす客の口赤し　花の名は書ききれぬ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "スコールでも来てくれれば良いと思うが、それも来ない。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……それからですね……今大きなスコールが来かけていますから、そいつが通過するまで君は甲板に出ないで下さいね」　……果して……と思うと、暴風に慣れない私は少々ドキンとした。",
              "citation": {
                "source": "幽霊と推進機",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
