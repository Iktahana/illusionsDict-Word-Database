    "definitions": [
      {
        "index": 1,
        "gloss": "cutting to pieces",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
