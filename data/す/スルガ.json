    "definitions": [
      {
        "index": 1,
        "gloss": "Suruga (former province located in the central and northern parts of present-day Shizuoka Prefecture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その山脈の道を通って、駿河から甲斐へ運ぶ塩車の列が、遠く穂蓼の隙間から見えるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに駿河町の越後屋（そのころの三井呉服店、今の三越）をいおう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行の汽車は、箱根｜火山彙を仰ぎ見て、酒匂川の上流に沿い、火山灰や、砂礫の堆積する駿河｜小山から、御殿場を通り越したとき、富士は、どんより曇った、重苦しい水蒸気に呑まれて、物ありげな空虚を天の一方に残しているばかり。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "国境に甲斐をまたいで、駿河の領内に入る。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場前の百貨店の食堂の窓から駿河湾の眺望と涼風を享楽しながら食事をしている市民達の顔にも非常時らしい緊張は見られなかった。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "御茶の水橋は中程の両側が少し崩れただけで残っていたが駿河台は全部焦土であった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "打縁流、駿河能国の暮景はかくも雄大であった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふた親にとっては姉に当り、自分にとっては伯母に当る駿河能国の福慈の女神のことについては、どういうものかふた親はあまり多くを語らなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が駿河路にかかったときには花後の樗の空に、ほととぎす鳴きわたり、摺らずとも草あやめの色は、裳に露で染った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃は、駿河国という名称はなくて、富士川辺まで佐賀牟国と呼ばれていた時代のことである。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの山を越す哀しい鳥の数も数え尽した」「もう、いいわ、じゃ、ね」さぬらくは玉の緒ばかり恋ふらくは不二の高嶺の鳴沢のごと駿河の海｜磯辺に生ふる浜つづら汝をたのみ母にたがひぬ",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "業平の、駿河なるうつの山辺のうつゝにも夢にも人にあはぬなりけり、あの昔の宇都の山ですね。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「俺ァ駿河の国は有度郡清水港の長五郎だ」　次郎長の背後の二人が名乗る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「あの……駿河の国の清水港の何とか言ったわ」　「清水港……？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いらっしゃいませ」　「御免なすって……石松つあんのお宅はこちらで御座いますか」　「あの……兄さん今一寸留守なんですけど」　「へえ儂は駿河の清水港の次郎長の身内、大瀬半五郎と申します」　「お父っつあん、お父っつあん」　とお静、奥へ呼ぶ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "海道一の親分は今あるじゃねえか」　「誰です」　「駿河の国は有度郡清水港に住む山本長五郎。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその時はそれきりで、何を考えたという事さえ忘れてしまっていたが、その後二三日たったある日の夕方、駿河台下まで散歩していた時に、とある屋根の上に明滅している仁丹の広告を見るとまた突然この同じ文字が頭の中に照らし出された。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後二三日してまた駿河台下を歩いた。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また駿河湾のすべての魚を数えずとも、一漁場で一つの網にかかったものだけ数えればよい。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「駿河町」の絵を見ると、正面に大きな富士がそびえて、前景の両側には丸に井桁に三の字を染め出した越後屋ののれんが紫色に刷られてある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿河の富士や房総の山も見える日があろう。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私はグデングデンに酔っ払ったふりをしながら朦朧タクシーを拾い直して来て、駿河台の坂を徒歩で上って、午前四時キッカリにお茶の水のグリン・アパートに帰り着いた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "中西が来たとなれば、僕はこれから駿河台の大将に会っておくほうがいいと思う。",
              "citation": {
                "source": "疲労",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は駿河台の友人を訪ねて、夜に入ってその家を辞して赤坂の自宅を指して途を急いだ。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその後に一度｜駿河台の家へ何かの演奏会の切符をもらいに行った事がある。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞享二年十二月二十五日、聖者白隠は駿河国駿東郡原駅で生れた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へ飛脚が来て肌着に添えた駿河からの母親の手紙を一本と、序とあって橘屋の主人からの手紙一本を慧鶴に届け、水をつるべ桶から飲んで帰って行った。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の十月に諸国に地震があり、故郷の駿河も相当ひどかったということは彼の帰心を弥が上にもそそったのであった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶と水とは附いて廻る、駿河台に水車が架ったか、と云う。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆がしらでも中軸でも一味についた連名の、昼鳶がお尻を突く、駿河台の水車、水からくりの姉さんが、ここにも一人と、飛込もうか。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
