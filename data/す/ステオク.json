[
  {
    "uuid": "74d8fcb3-cd81-5ac7-b2f0-37e0abf74ddc",
    "entry": "捨て置く",
    "reading": {
      "primary": "すておく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
