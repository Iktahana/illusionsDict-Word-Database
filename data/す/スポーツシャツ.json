          "literary": [
            {
              "text": "で、仕事に疲れて来ると忽ち室内着を脱ぎ捨てスポーツシャツ一枚の姿で縁側でトレーニングをやった。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場見学団の男女が、樺の木胴籠にスポーツシャツといういでたちで汽車につまれて出て行った。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コバルト色のスポーツシャツを着たいかにもコムソモール風な若者と、黄色と黒の横だんだらのこれもスポーツ・シャツで半ズボン、ズック靴の若者が議論している。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "キングストン・トリオが着ていた赤と白のキャンデー・ストライプのボタン・ダウン・スポーツシャツのように、ニクソンがとなえることはアメリカ的であった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
