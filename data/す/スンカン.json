[
  {
    "uuid": "318806d5-6626-5cc5-a798-12a8e3a0cfe3",
    "entry": "寸簡",
    "reading": {
      "primary": "すんかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
