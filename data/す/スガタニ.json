    "definitions": [
      {
        "index": 1,
        "gloss": "seafood cooked in a way that preserves its original shape",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
