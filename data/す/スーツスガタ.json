        "examples": {
          "standard": [
            {
              "text": "いつもカジュアルな服を着ている彼が、今日はビシッと決めたスーツ姿で現れたので驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プレゼンテーションの会場には、自信に満ちたスーツ姿の若手起業家たちが集まっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "結婚披露宴で、ビシッと決めた友人のスーツ姿を見て、改めて彼の成長を感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "抜け道として公園を使うことにしているらしいスーツ姿がときどき急ぎ足で過ぎていく。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "教授はそのひとつにすわり、その隣の椅子には長身にスーツ姿の年配の男性がいた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の端正なスーツ姿に、落ち着いた自信のようなものを、日比谷は感じた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノーフォークスーツ姿の若い男が白衣女のそばにぴったり。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
