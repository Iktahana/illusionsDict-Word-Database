        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "妾は中央ステイションでおりたのよ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "出発半時間前、中央ステイションのプラット・ホームには、ミサコの夫と彼女の女弟子たち、カリタ夫妻が彼女を見送りにきていた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはコンステイブルの画を一枚思い出している。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "有り合わせの餌を一片二片とだんだん近くへ投げてやると、おしまいには、もう手に持っているカステイラなどをくちばしで引ったくって頬張る事を覚えてしまった。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここの汽車は、ステイームや電氣でうごいてゐない。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "構い手のない肺病娘のホツレ毛に引っかかって、見えるか見えないかにわななきふるえつつ、夢うつつのように紅い紅い血を吐き続けさせ、旧教会のステインドグラスに這い付いて、ありがたいお説教の余韻を薄曇らせ、聖書の黒い表紙の手ざわりにザラめいては、祈る者の悲しみをためらわせる。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャラメルが悪けりゃあカステイラは西班牙の言葉だぞ。",
              "citation": {
                "source": "キャラメルと飴玉",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、二三度訪ねたが、ロジャー氏は屋根を天文台のように蒼穹抜きにしてみたり、ステインド硝子を窓に嵌めたりしていた。",
              "citation": {
                "source": "噴水物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽に酔うているようなたのしみを、その書物のステイルが与えてくれるようなものを、喜んで読みたいと思うのである。",
              "citation": {
                "source": "僕の読書法",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "アランや正宗白鳥のエッセイがいつ読んでも飽きないのは、そのステイルのためがあると思っている。",
              "citation": {
                "source": "僕の読書法",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い天井のステインドグラスから落ちて来る光線が、青ずんだ湯の底の底まで透きとおして、見事に彫刻した白大理石の浴槽から音も立てずに溢れ出していた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "むす子が巴里の北のステイションへ帰朝する親たちを送って来て、汽車の窓から、たしない小遣いの中で買ったかの女への送別品のハンケチを、汽車の窓に泣き伏しているかの女の手へ持ち添えて、顔も上げ得ず男泣きに泣いていた姿を想い出すと、彼女は絶望的になって、女ながらも、誰かと決闘したいような怒りを覚える。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも一時のがれにあつまっていたところから、それぞれのつてをもとめていったり、地方へにげ出すつもりで、日暮里や品川のステイションなぞを目あてにうつッていくのです。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディナーの時間迄ステイヴンスンは独りで寐たまま、休んでは書き、書いては休みする。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディナーの時になると、ステイヴンスンは階下に下りて来る。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ステインドグラスの説明には年号や使徒の名などがのべつに出て来たが、別に興味を動かされなかった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はカーステイアスの、エディス・ウードレー嬢と婚約の間柄であったのを、つい数ヶ月前に破棄となったのであったが、しかしこれも両方の和解の上にやったことであって、別に深い意趣をのこしたと思われるようなことも無いことであった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふん、ステイプルズ、何度言ったらわかるの、研究の最中はボクの邪魔をするなってさァ。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だァから会わないって、ステイプルズ。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、ステイシヨンについたらすぐに、車でお父樣のお墓參りに行かうと思ひますわ。",
              "citation": {
                "source": "追憶",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "来る日／＼に対して広漠たる戦きを覚えると同時に、吾々の瞬時々々は飽く迄も明朗たる力の翼を伸べて、オプテイミステイクでなければならぬ！",
              "citation": {
                "source": "附「歌へる日まで」",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから「シプリア人と処女の話」といふのが本来の題名なのか、それとも「アグリタスとジヤステイナ」が原名なのか、君の意見を訊きたい。",
              "citation": {
                "source": "痴酔記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アグリタスはジヤステイナを意に従へるために終に悪魔の助力を乞ふのであるが、それも無駄になり、アグリタスは悪魔との規約を破つてその洞窟を去り、全く孤独でジヤステイナを訪れるのだが、悪魔は彼の変心を怒つて、何と叫ぶのであつたかね？",
              "citation": {
                "source": "痴酔記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、この酒場を訪れる多くのアグリタス達の「ジヤステイナ」である美しい酒注娘である。",
              "citation": {
                "source": "痴酔記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」愛子はステイシヨンへ向ふ途中、町筋を眺めながら呟やいた。",
              "citation": {
                "source": "歯痛",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗いステイシヨン前には出迎への提灯の灯に照されて、ぴか／＼する自動車や、人の影が見えた。",
              "citation": {
                "source": "歯痛",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　愛子はＮ子につれられて、その辺を一ト廻りして、汽車の時間の間に合ふやうに、ステイシヨンで落合ふことにして、出て行つた。",
              "citation": {
                "source": "歯痛",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "ステイシヨンへつくと、Ｎ子と愛子はもう来てゐた。",
              "citation": {
                "source": "歯痛",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "ステインド・グラスから漏れる光線は、いくつかの細長い窓を暗く彩って、それがクララの髪の毛に来てしめやかに戯れた。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
