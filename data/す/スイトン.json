    },
    "definitions": [
      {
        "index": 1,
        "gloss": "flour dumplings in soup",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今しも、その表に立ち止った一人の武者修業の侍（早水団九郎）　のこのこ門内へ入る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｔ　さて　翌る日――Ｓ＝街道　早水団九郎、荷物を全部、宮本武蔵に持たせて威張り返って歩いて行く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎が、Ｔ「心配致すな　亭主　此の御方は誰あろう」　と武蔵を指さして、Ｔ「新免二刀流の開祖　宮本武蔵先生」　と言って、Ｔ「拙者は先生の高弟で　同じく新免二刀流の　達人」　と威張って、Ｔ「勇名天下に響き渡った　早水団九郎」　亭主も感心した。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "文六、Ｔ「珍しや　父の敵　早水団九郎！",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と汚い病苦の冷汗に……そよそよと風を恵まれた、浅葱色の水団扇に、幽に月が映しました。",
              "citation": {
                "source": "雪霊記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は刈手たちの仲間いりをして大好物の水団を賞味するのも忘れて、じつとひとつ処に立ちつくしたまま、空の彼方に消えゆく鴎を見おくつたり、野良につらなる、刈り取られた麦の堆積を数へたりしてゐるのであつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうとつくに、家からは、母が温い水団を壺に入れて持つて来てゐた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちこちに焚火の火がちらついて、水団の煮える香ばしい湯気が、ひつそりした通路を流れた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "早朝から上野介が登城したあとで、一学は山吉のほかに新見弥七郎と大須賀次郎右衛門を自室に招いて、朝から、ちびりちびりやっているとき、執事役の清水団右衛門が真っ蒼になってとびこんできた。",
              "citation": {
                "source": "本所松坂町",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼跡に出来たライスカレーや水団を食わせる店に寄るのが楽しみだった。",
              "citation": {
                "source": "生い立ちの記",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さと殿に、会いたいが」「お稽古中は、降りて参りませんから、少し、お涼みくださいませ」　水団扇だの、煙草盆だの、座敷において、娘は、麦湯を汲んでいた。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水団扇をのせて、寝顔をかくしているからだった。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると簀戸越しに見える水団扇の蔭から、眼が――女の眼が――じいっと、やはり、自分を見ているのだった。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水団扇を手に、『まあ上られい』　階下を、憚るように、二階へ導いてゆく。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『おのれっ』　吉良家の取次役、清水団右衛門は、打外された杉戸の陰からあらわれて、三村へ向って斬りつけて来た。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "火遁だって、土遁どろどろどろ、すいとんだって、焼鳥だってお茶の子だわ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」上杉先生が、「その隙に、すいとんか、おでんを売れ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "天どんなぞは驕の沙汰で、辻売のすいとん、どうまた悟りを開いたか、茶めし、餡かけ、麦とろに到るまで、食いながら、撮みながら、その色もの、また講釈、芝居の立見。",
