        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あくまでマイクロコンピューターの販売を本業とし、パーソナルコンピューターに割くマンパワーを限られる渡辺の部隊にとって、アスキーはこの分野により大きな力を注いでいくうえで絶好の助っ人となった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな出版の世界で、二つの願いの片割れである「読まれたい」には、助っ人らしきものもいなかった。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃になると、助っ人が続々到着。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日のステージではギターの西田増美とサックスのケリー田口が正規のサイバネテイック・スキゾイドのメンバーに助っ人として加わっていた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今回西田増美とケリー田口の二人を助っ人として調達できたのも彼の顔のおかげだった。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が助っ人になりましょう。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "助っ人は虐待しないものだぞ。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
