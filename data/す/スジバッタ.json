        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "筋張った、意地悪のリアリストだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我知らず声を潜めて、「知ッてる……生紙の紙袋の口を結えて、中に筋張った動脈のようにのたくる奴を買って帰って、一晩内に寝かしてそれから高津の宮裏の穴へ放すんだってね。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つかんでみればたしかに、彼の筋張った痩せた腕が、袖の底に感じられた。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "筋張ったような顔が蒼くなって、目が酔漢のように据わっている。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランプに火を点けてお庄が呼び起しに行くと、叔父は顎の骨をガクガク動かして、細長い筋張った手を蒲団の外へ延ばして、ぐったり寝込んでいた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "信用を墜しちゃ大変です」お島は片意地らしく脅しつけるように言って、筋張った彼の手をきびしく払退けた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は筋張った顳※のところを押えながら、小野田を遣返した。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　支那服は筋張った顔をてらてらさせて笑った。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺絣の洗洒したのが太い筋張った腕にからまっている。",
              "citation": {
                "source": "木曾御嶽の両面",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の筋張った手や、着物の端や、忙しそうに畳の上を這廻る帯の運動で手にとるように分った。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸人の年輩は不明であったが、四十歳から六十歳迄の間で、左の耳の根元の辺りに瘤のあるのが特色であった、陽にやけた皮膚筋張った手足、一癖あり気の鋭い眼つき、気味の悪い男であった。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがわたしのところの伜であったら、わたしはどないな気がするやろと思うと、この胸が痛うなります」婆さんは、そういいながら、さもさも胸の痛みに触るように皺だらけの筋張った顔を一層｜顰めて、そっと胸に手を当てる形をした。",
              "citation": {
                "source": "霜凍る宵",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "筋張ったその手が間を置いてはびくりと震えて、やがて静かになっていった。",
              "citation": {
                "source": "同胞",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "源次郎に呼び戻されて小屋の前を右に下ると、二間とはない河床に乱れ立つ岩の間を筋張った水が奔下している、橋は落ちて跡もない。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東北に派出した山稜は、東又を中に脚の下から弧を描いて、三名引山、滝倉岳（陸測五万、駒ヶ岳）、僧ヶ岳と、低いながらも強弩の余勢は流石に筋張った処がある。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十を少し越した筋張った神経質な武家、一刀を提げて、松が枝のお組と、縁先の平次を当分に見比べた姿は、苛斂誅求で、長い間房州の知行所の百姓を泣かせた疳癖は充分に窺われます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "名馬罪あり",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩せて筋張った、生活に疲れたような中年男を、漠然と想像するだけである。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と亭主は落胆したように縁側に腰を降ろして手を膝に重ねたが、その筋張った手がワナワナと今にも震え出さんばかりの様子であった。",
              "citation": {
                "source": "逗子物語",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
