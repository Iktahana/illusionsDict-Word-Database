        "examples": {
          "standard": [
            {
              "text": "プールに入る前に、水中メガネが顔にフィットしているか確認してベルトを締めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "海辺で拾った水中メガネをかけて潜ってみると、砂地に隠れているカニを見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "水中メガネのレンズが曇らないように、潜る直前に専用の曇り止め液を塗る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、そこに書いてある、さしずに、したがって、八人のはだかの勇士は、水中メガネと、ボンベと、水かきをつけて、海底の洞窟の外へ泳ぎだし、そこに待っていた五人の勇士と、いっしょになって、敵が海底に、姿をあらわすのを待ちかまえていることでしょう。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしっ、それじゃ、こんどはすいちゅうめがねだ」　あけちたんていの声にこたえて、ボートのそこのサーチライトが、ぱっとすいちゅうをてらしました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、ボートのそこのすいちゅうめがねに、まっくろなせんこうていのすがたがあらわれました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
