[
  {
    "uuid": "e29e11a8-12d8-578a-93df-55348022edec",
    "entry": "睡蓮",
    "reading": {
      "primary": "すいれん",
      "alternatives": [
        "スイレン"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "water lily (any plant of genus Nymphaea)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "睡蓮もまだつめたい泥の底に真夏の雲の影を待っている。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄櫨や山葡萄が紅葉しており、池には白い睡蓮が咲いている。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからそろそろ庭へ出て睡蓮の池の水をのんで、そうして彼の仕事の町内めぐりにとりかかるのであろう。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは藁苞のような恰好をした白鳥が湿り気のない水に浮んでいたり、睡蓮の茎ともあろうものが蓮のように無遠慮に長く水上に聳えている事もある。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　睡蓮を作っている友人の話である。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、睡蓮には目もなければ手もないから、水面が五寸上にあるか三尺上にあるかわからない。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの木の下の水面に睡蓮がある。",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの睡蓮は近ごろのものである。",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしは睡蓮が著しく繁殖して来た。",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、もし、睡蓮が他の水草を次第に圧迫して蔓延するか、しないか、これも問題である。",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば水面に浮かんでいる睡蓮の花が一見ぱらぱらに散らばっているようでも水の底では一つの根につながっているようなものである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おゝい、おゝい、母屋に集へる人數の目には、其の盥たゞ一枚大なる睡蓮の白き花に、うつくしき瞳ありて、すら／＼と流れ寄りきとか。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――真夜中の月の大池に、影の沈める樹の中に、しぼめる睡蓮のごとく漾いつつ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まつしろい睡蓮の花に似てゐた。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが歩みは檜の日かげより丘のはづれの小亭へ、その傍の径を下りて睡蓮科の生ひ涵れる小さき池のほとりへゆく。",
              "citation": {
                "source": "春の暗示",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "白鷺白鷺は、その一羽、睡蓮の花を食み、水を食み、かうかうとありくなり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "池畔の撮影小石川の植物園にて睡蓮の葉を、水の池に満ちて。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　睡蓮の花は昔から知っている。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "睡蓮という名の所由がやっとわかったのである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "睡蓮　睡蓮は本当に可憐な花です。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その可憐な表情こそ、睡蓮の花の私達の心を惹いてやまないところです。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　寂しい睡蓮の花は、淋しい情景の中に咲いてこそ、その哀愁的美、詩的情緒が私達の胸にぴったりうつって来るのです。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡礼乙女のお鶴や石童丸のように、親を尋ねて漂泊う少年少女が、村から村へと越える杉杜の中の、それも鬱蒼と茂った森林の中の、そして岸には葦が五六本ひょろひょろと生えていて、緑い藻などが浮き、鏡のように動かない古池に、ぽっつり夢のように浮いている睡蓮の花を見たら、きっと、泣き出したに相違ありません。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀しい少女の心には、睡蓮のあの可哀想な、淋しそうで悲しそうな、あの気持ちがあまりにもぴったりはいって来るからです。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "睡蓮の花はどうかすると、この衰滅の美という言葉に、ぴったりすることがあります。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の栄華を語る古城のほとり、朽ちかけた天守閣には蔦かずらが絡み、崩れかけた石垣にはいっぱい苔が生え、そのお濠に睡蓮の花が咲いていたら、私達は知らぬ間に、涙含ましい気持ちでいっぱいになっているに相違ありません。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　緑滴るころ、東京近郊では、井之頭の池に、あの静かな、原始林のような森林に囲まれ、錆のついた鏡のような池の面に、白い夢のように睡蓮の花が浮いています。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その冠を見れば、ネミの湖にて摘みたる白き睡蓮（ニユムフエア）の花なりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "槐の下の大きな水鉢には、すいれんが水面にすきまもないくらい、丸い葉を浮けて花が一｜輪咲いてる。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま細君にたいする小言のしりを結ばずにしまったことを、ふとおのれに勝ちえたように思いついて、すいれんのことも忘れ、庭を損じたことも忘れて、笑顔を細君にむけた。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
