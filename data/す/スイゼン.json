    },
    "definitions": [
      {
        "index": 1,
        "gloss": "avid desire",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "苦勞を知らぬわがままな處女の、へどが出るやうな氣障つたらしい姿態に對して、ああ青春は純眞だ、なんて言つて垂涎してゐる男たちは、氣をつけるがよい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦労を知らぬわがままな処女の、へどが出るやうな気障つたらしい姿態に対して、ああ青春は純真だ、なんて言つて垂涎してゐる男たちは、気をつけるがよい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四千年住ミ古シタル支那ヲ富源ナルカノ如ク垂涎スル小膽國民ニシテ、如何ゾ世界的大帝國ヲ築クヲ得ベキ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、心の底からそれに垂涎した。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一部をワルソー方向に進めてロシヤの垂涎の地である同地方に露軍を牽制し、東普に集めた主力軍をもってこの敵の側背を衝き、一挙に敵全軍を覆滅して和平を強制する方針であった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にこの紀行を見ると毎日西瓜何銭という記事があるのを見てこの記者の西瓜好きなるに驚いたというよりもむしろ西瓜好きなる余自身は三尺の垂涎を禁ずる事が出来なかった。",
              "citation": {
                "source": "徒歩旅行を読む",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "風景専門の人がいたら垂涎されるに違いない、いい画題がいくらも見あたった。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その空んとした図書室を横切って、突当りの明りが差している扉を開くと、そこは、好事家に垂涎の思いをさせている、降矢木の書庫になっていた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手水鉢を離れた時、私は彼の口から流れる垂涎を見た。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふのは、囲碁春秋には鉢巻の大人も随筆を書くさうだから、大人は随筆の名人だが、棋譜入りの随筆は書けないに極つてゐて、その時全く落胆し、垂涎するに極つてゐるからであつた。",
              "citation": {
                "source": "生命拾ひをした話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "新疆の如きまた彼が多年垂涎する所にして、これがためには新疆の死命を制しある伊犂を併呑するのもっとも捷路たるべきは、彼がすでに看破したる所ならざらんや。",
              "citation": {
                "source": "新疆所感",
                "author": "日野強",
                "note": "青空文庫"
              }
            },
            {
              "text": "それというのがどれもこれも垂涎三千｜丈の価値あるものばかり。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ千年以上の作というにかかわらず、朱の色が、昨日｜硯を発したばかりの色なんです、今時の代用安絵具とは違います、絵かきが垂涎しておりますよ、こんな朱が欲しいものだ、ドコカラ来た、舶来？",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その道の丹青家をして垂涎せしめる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆるお茶人たちが垂涎おかない茶道具といえば、まず三世紀前の人によって作られたものと考えておいて間違いはない。",
              "citation": {
                "source": "茶美生活",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "糞尿を分析すれば飲食した物の何であったかはこれを知ることが出来るが、食った刹那の香味に至っては、これを語って人をして垂涎三尺たらしむるには、優れたる弁舌が入用になるわけである。",
              "citation": {
                "source": "十六、七のころ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又満蒙資源館を見た時、成程ナー満洲の資源は無限だ、米国などが垂涎三尺、この満洲に勢力を延ばそうとして事毎に不愉快なる小刀細工を我国に行ったり、中華民国に行ったりする訳だと思ったよ。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『法隆｜将ニ季ナラントシ、妄庸ノ徒声利ニ垂涎シ、粉焉沓然、風ヲ成シ俗ヲ成ス。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸の集積所にある石黒大尉の倉庫は、かねて抑留者の垂涎の種だったが、身体のいい屈強な囚徒兵たちには耐えられぬほどの魅力で、重刑を覚悟で頻々と襲撃した。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんが心配だとさ」「え」と云いながら顔を上げた独仙君の山羊髯を伝わって垂涎が一筋長々と流れて、蝸牛の這った迹のように歴然と光っている。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "海百合　ウミユリはのような、なんというか H.P.L. ファン垂涎の生物で、いかにも植物っぽい形をしています。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "民衆宮とは日本よりの社会局役人をして垂涎せしむる石造建築と最初建造資金を寄附したミス・某々の良心的満足に向って捧げられている名前である。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには好事家の垂涎三千丈すべき数万金に値する家具家什ばかり。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は心の中で、奴さん達垂涎三千丈だな、とほくそ笑みながら、どうせ俺には保存慾はないのだから、欲しければ与つてもいいよ、と軽く言つて見た。",
              "citation": {
                "source": "書狼書豚",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝石マニヤ垂涎の的として、欧州中にも轟き渡っていたかも知れぬ。",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは氏の話によれば印度のほんとうの美人には、欧州人さえも食指を動かしてこれに垂涎するものが尠くないというのであったが、それだけは私には何としても承服できかねた。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、恐らくは此の方があれより一層誘惑的な鼻であって、ひとたびあの屋根裏の光景を享楽した少年に取っては、確かに垂涎に値いするのである。",
              "citation": {
                "source": "武州公秘話",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし古着好きの老人は、「いや、衣裳は此処の方がいいよ」と云って、あの帯は昔の呉絽だとか、あの小袖は黄八丈だとか、出て来る人形の着物にばかり眼をつけて、さっきからしきりに垂涎している。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「社長が垂涎万丈さ」「寒山拾得って形ですな？",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
