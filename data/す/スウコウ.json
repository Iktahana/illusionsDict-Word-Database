      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lofty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この崇高な山頂に、一つの新しい石碑が建つてる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」妹は、不思議にも落ちついて、崇高なくらいに美しく微笑していました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と呟いて浦島は、はじめて海の底の龍宮の生活に、自分たちの趣味と段違ひの崇高なものを感得した。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲消えて皹も亦拭ひ去らる、山色何の瑠璃ぞ、只だ赭丹赭黄なる熔岩の、奇醜大塊を、至つて無器用に束ねて嶄立せるのみ、その肩を怒らし胸を張れるを見て、淑美なる女性的崇高を知らず。",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の人間には崇高や壮大と名づけられる種類の美は何らかの障礙のために拒まれているのだろうか。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、あの接待者聖ジュリアンが、單なる一時的な慈愛では爲し得ないやうな、そしてその原動力として愛、一切の愛、この世のありとあらゆる愛をもつてゐるやうな、崇高な抱擁をその者に與へてやりながら、あの癩病患者の傍に臥たやうに、君は自分と一緒に臥る覺悟が出來てゐるか？",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども今は崇高な月光のなかに何かよそよそしいものが漂ひはじめた。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、いま眼のまえに少女の美しい裸体を、まじまじと見て、志賀氏のそんな言葉は、ちっともいやらしいものでは無く、純粋な観賞の対象としても、これは崇高なほど立派なものだと思った。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ズンズンと潮が高まって来て、膝の下の海藻を洗い漂わしているのも心付かずに、黄金色の滝浪を浴びながら一心に祈っている、その姿の崇高さ…………まぶしさ…………。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓を構えて、矢を打ち番えて、引き絞って、的に中った音を聞いてから、静かに息を抜くまでの刹那刹那に、言い知れぬ崇高な精神の緊張が、全身に均衡を取って、充実して、正しい、美しい、かつ無限の高速度をもった霊的リズムの裡に、変化し推移して行く事を、自分自身に感ずるであろう。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "千軍万馬を往来した将軍の風格、狂瀾怒涛に慣れた老船頭の態度等に現わるる、犯すべからざる姿態の均整と威厳は、見る人々に言い知れぬ美感と崇高感を与える。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば、ある一つの仕事を熱心誠実にくり返していると、その心境なり、その動作なりが、イツ知らず純一崇高化して来て、自然と能の型の均整美に接近して来るのだ。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それさえ像法時代といって、人々を眼で見ることから、崇高な感じを起させ、道に入れなければならない時代になって来ると立派な寺院を造り、立派な仏具を用いて説法の助けにしました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋愛を人生の崇高な目的である人間完成にまで高めるために、精神的に結合させるのが、一流の恋愛だ」「まア、僕にはむつかしいですな。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九「裁かるるジャンヌ」を見て来た一夜、ちょうどそれが自分と同じ年頃の村の娘の、世の常ならぬ崇高な姿であるだけに、銀子は異常な衝動を感じ、感激に胸が一杯になっていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、芸術における崇高なもの、偉大なものを愛するのと同じように、コロンビーナを高く愛していたのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と呟いて浦島は、はじめて海の底の竜宮の生活に、自分たちの趣味と段違ひの崇高なものを感得した。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――が、この上もなく崇高で好いのであらうが、僕にはそれが厭やでたまらぬ。",
              "citation": {
                "source": "ラヂオ漫談",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに音楽会情調といふ奴は、実に芸術の崇高的厳粛性を漂はして、気分的に強制してくるのだ。",
              "citation": {
                "source": "ラヂオ漫談",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一その科学、哲学、宗教、芸術等に於ける、西洋流の言語感そのものからして、何となく或る威厳的な、勿体ぶった、歴々のものを感じさせ、或る崇高な権威の方へ、意志を高く飛翔させる。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "××より崇高な芸術が見えたら、それがすぐ××だなんて××のような理窟を云い出したら、僕は逃げ出しちゃいます。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "艶消しの珠玉のような、なまめかしい崇高美に、私は一眼で魅了されて仕舞った。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙの権高な気風と、徹底した利己主義に、雪子はやゝ超人的な崇高な感じは受けたが、下町娘の持つ仁侠的な志気はＹにひどい反抗と憎みを持つた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後記）王朝時代の末期になつて、文化の爛熟による人間の官能と情感がいやが上にも発達し、現実的には高度の美意識による肉的なものを追ひ求める一方、歓楽極まつて哀愁生ずる譬へ通り、人々、省己嫌厭の不安から崇高な求道の志を反比例に募らせる。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "デンマークのため、という言葉は、なんだか大きい崇高な意味を持っているようで、私はいつでも、デンマークのためとばかり思って、くるしい事でも悲しい事でも怺えて来ました。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、かえって、そのような富士の姿に、崇高を覚え、天下第一を感ずる。",
              "citation": {
                "source": "富士に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "着手の處着手の處の不明な教は、如何に崇高な教でも、莊嚴な教でも、或は正大圓滿な教でも、教へらるゝ者に取つては、差當り困卻を免れぬ譯である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは最も正大崇高のものである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の底まで透明になってしまって、崇高なニヒル、とでもいったような工合いになった。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
