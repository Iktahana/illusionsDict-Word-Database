[
  {
    "uuid": "3c1a30a6-9b8c-5fdc-818e-10091416456f",
    "entry": "崇高",
    "reading": {
      "primary": "すうこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
