        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "水害で地下室に溜まった泥水を、強力なポンプを使って一気に吸い出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "毒蛇に噛まれた箇所を、専用のリムーバーで慎重に毒液を吸い出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スポイトを使い、試験管の底に沈殿している不純物だけを吸い出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "また、銅球の中の水を強く吸い出すと急に高い音を立てて球がひしげたりした「こと」であった。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気抜けは、室内の空気を上に吸い出すものだ。",
              "citation": {
                "source": "街の探偵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が朗らかにさし、縁側に坐って庭を見て居ると、日の光が魂を吸い出す。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
