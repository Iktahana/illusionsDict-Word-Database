    "definitions": [
      {
        "index": 1,
        "gloss": "hawk moth (any moth of family Sphingidae)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしなんのためにすずめがこんな遊戯をしているか、考えてみると不思議である。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三のすずめがこれに参加することもある。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたき集めた虫を庭へほうり出すとすずめが来て食ってしまった。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いぼくのすぐ頭の上に、すずめが春持って来た鳥の毛やいろいろ暖かいものがたくさんあるから、いまのうちに、すこしおろして運んでおいたらどうだい。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はちすずめが水の中の青い魚のように、なめらかにぬれて光りながら、二人の頭の上をせわしく飛びめぐって、ザッ、ザ、ザ、ザザァザ、ザザァザ、ザザァ、ふらばふれふれ、ひでりあめ、トパァス、サファイア、ダイアモンド。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はちすずめがたびたび宝石に打たれて落ちそうになりながら、やはりせわしくせわしく飛びめぐって、ザッザザ、ザザァザ、ザザァザザザァ、降らばふれふれひでりあめひかりの雲のたえぬまま。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「トパァスのつゆはツァランツァリルリン、　こぼれてきらめく　サング、サンガリン、　ひかりの丘に　すみながら　なぁにがこんなにかなしかろ」　まっ碧な空では、はちすずめがツァリル、ツァリル、ツァリルリン、ツァリル、ツァリル、ツァリルリンと鳴いて二人とりんどうの花との上をとびめぐっておりました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、あめつちを充てる十力のめぐみ　われらに下れ」　にわかにはちすずめがキイーンとせなかの鋼鉄の骨もはじけたかと思うばかりするどいさけびをあげました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき表で見たらね、かあさん、すずめが花火のはじけるたびにとびたって、裏山の方へ逃げてったよ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからもあることだ、しっこいやつを追っ払うにはこうするんだから、よく覚えておきな」「はあてね」「何を感心しているんだよ」「いいえね、向こうの木にすずめが止まっているんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あさおきする子はあの子です」「あさねぼする子はこの子です」すずめがしつてていひました。",
              "citation": {
                "source": "未刊童謡",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "そののりはみんなすずめがなめてしまったことが分かると、いじのわるいおばあさんはたいへんおこって、かわいそうに、小さなすずめをつかまえて、むりに口をあかせながら、「この舌がそんなわるさをしたのか。",
              "citation": {
                "source": "舌切りすずめ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　おじいさんは、すずめが舌を切られてどこへ行ったか心配でたまりませんので、あくる日は、夜があけるとさっそく出かけていきました。",
              "citation": {
                "source": "舌切りすずめ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじいさんは喜んで、声のする方へ歩いていきますと、やがてやぶの陰にかわいらしい赤いおうちが見えて、舌を切られたすずめが門をあけて、お迎えに出ていました。",
              "citation": {
                "source": "舌切りすずめ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と思って、声のする方へ歩いて行きますと、舌を切られたすずめがこんども門をあけて出てきました。",
              "citation": {
                "source": "舌切りすずめ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すずめときつつき　むかし、すずめがせっせと鏡に向かって、おはぐろをつけていますと、おかあさんが死んだという知らせが来ました。",
              "citation": {
                "source": "物のいわれ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あまり押すと先生、小便がもります」と二塁手のすずめがいった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれがこれを着たとき、すずめがそれだけはよしてくれといった、かれは頑としてきかない。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "からかさとられたこすずめが、こなかひにチユウチユウやつてきた。",
              "citation": {
                "source": "トントンピーピ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい弟がすずめがおや鳥がひなにこうしてたべさせるんだと云って私に目をつぶらせて小さい細い白い箸の先にしこたまからしをぬりつけて口中にぬってくれた。",
              "citation": {
                "source": "日記",
                "author": "一九一三年（大正二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一羽のすずめがこのかかしのかさの下をのぞきに行きました。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "からすが飛び去った後、まもなくすずめが二、三｜羽やはり同じ枝にきて止まって、窓の内側をのぞくようにしてないていました。",
              "citation": {
                "source": "残された日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、裏庭の桜の木にすずめが止まって鳴いていました。",
              "citation": {
                "source": "山へ帰ったやまがら",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここには、すずめがたくさん枝に止まって、ふくらんでいます。",
              "citation": {
                "source": "山へ帰ったやまがら",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すずめが鳴いていたので、お仲間入りがしたくなったんだね。",
              "citation": {
                "source": "山へ帰ったやまがら",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "すずめが、その枝の中に巣を造っていました。",
              "citation": {
                "source": "木の上と下の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、子すずめがききました。",
              "citation": {
                "source": "木の上と下の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、母すずめが答えました。",
              "citation": {
                "source": "木の上と下の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　木の上で、母すずめと子すずめが、ねこを見ながら、話をしていると、あちらから、ほかの若いねこがきかかりました。",
              "citation": {
                "source": "木の上と下の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　木の上では、母すずめと子すずめが、じっとそのようすを見守っていました。",
              "citation": {
                "source": "木の上と下の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
