          "literary": [
            {
              "text": "だいぶ離れた所でどたんと戸か何かはずれたような音がしたと思うと、風はまた一しきりうなりを立てて杉叢をこそいで通りぬけた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく二度とは訪ねられないであらうその杉叢が、そゞろに私には振返へられた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく二度とは訪ねられないであろうその杉叢が、そぞろに私には振返えられた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の気なく、黎明の空気を吸いながら散歩をしていると、××寺の杉叢のところから女が出て来た。",
              "citation": {
                "source": "小村淡彩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の水の面、黄金色の葦、その周囲に紅葉した桜の枝と、遠く沈んだ緑色の杉叢、軽い、水彩画風の陵丘の姿が、調った遠景となる。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
