    "definitions": [
      {
        "index": 1,
        "gloss": "several people",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "実は先日、僕の住んで居る鳴滝村のホン屋連中が数名協同してシナリオを一本書き上げた時の事です。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜も此処から三ッ目の駅が襲撃を受けて数名の戦傷者を出して居る。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の旗本、数名の浪人者の立廻り。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同「ドッコイやらぬ」と立廻り――　＝道――　大吉、縄持ってた奴をズバリ斬って、　其処に現れた数名の捕吏と立廻り。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）通り　主膳と一味の浪人者数名とがブラブラやって来た。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（門人数名を供に連れている）　こらッと、その侍白倉源五左衛門、おしまの腕を掴む。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと見れば、立派な数名、自分を取り囲んで居る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その十数名の軍夫の中に一｜人｜逞ましき漢あり、屹とかの看護員に向いおれり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の名はシビリアコフ号、これがソビエト政府の北氷洋学術研究所所属の科学者数名を載せて北氷洋をひと夏に乗り切ったものであるということが新聞で報ぜられた。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、全身にいろいろの刺青を施した数名の壮漢が大きな浴室の中に言葉どおりに異彩を放っていたという生来初めて見た光景に遭遇したのであった。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさにこの稿を書きおわらんとしているきょう四月五日の夕刊を見るとこの日午前十時十六分｜函館西部から発火して七十一戸二十九｜棟を焼き、その際消防手一名焼死数名負傷、罹災者四百名中先日の大火で焼け出され避難中の再罹災者七十名であると報ぜられている。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「藤沢江の島間電車九月一日開通、衝突脱線等あり、負傷者数名を出す」という文句の脇に「藤沢停車場前角若松の二階より」とした実に下手な鉛筆のスケッチがある。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外に、幹事を数名置くことになりますが、これが会社でいふ監査役といふところです。",
              "citation": {
                "source": "私有農場から共産農団へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田村榛沢以下数名の弁護士は今｜正に其任に膺つた。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査の決心と勇気とに励まされ、これに又幾分の好奇心も交って、数名の若者は其後に続いた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "松明を把ったる巡査と他数名の勇者は、頼光の四天王が大江山へ入ったような態度で、再び窟へ引返した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一回の入学生は森律子、村田嘉久子、初瀬浪子、河村菊江ら十数名なり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大阪曾根崎署では十九日朝九時、約五十名の制服警官をくり出して梅田自由市場の煙草販売業者の一斉取締りを断行、折柄の雑沓の中で樫棒、煉瓦が入れ交つての大乱闘が行はれ重軽傷者数名を出した。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の私服警官が粉煙草販売者を引致してゆく途中、小路から飛び出して来た数名がバラバラツと取りかこみ、各自手にした樫棒で滅茶苦茶に打ち素手の警官はたちまちぶつ倒れて水溜りに顔を突つ込んだ。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、中之島公園の暗がりの中を一息に、図書館の前まで駈けつけた時、自分の到着を待っていたのは千日前の喫茶店の前で、自分を掏ろうとしたあの間抜けの掏摸一人ではなく、十数名に及ぶ隼団の団員だと判ると、豹吉は思わずにやりとしたくらい、ゾクゾグとうれしかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は光の会、会者十数名、なか／＼盛況だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "数名の下婢は居てもそういふ高貴の身辺へは、家の秘嬢を侍らすのが、その家の主人の忠勤を象徴するといふならはしが、殆どうごかすべからざる田舎の旧家の何代も続いた掟なのでした。",
              "citation": {
                "source": "処女時代の追憶",
                "author": "断片三種",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他　　学童数名。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで憶い出して頂きたい、フランクリンが友人数名とクラブを作り各自が書いてきた原稿（童話ではなかったが）を作者が読み他の者が聞き、批判しあったことを。",
              "citation": {
                "source": "童話における物語性の喪失",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その十数名の軍夫の中に一人｜逞ましき漢あり、屹と彼の看護員に向ひをれり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四隅に置いたストーヴの暖かさで三十数名の男の社員達は一様に上衣を脱いで、シャツの袖口をまくり上げ、年内の書類及び帳簿調べに忙がしかった。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まった、当院は特に真槍の試合にも応ずるが、当院に於いて命を落した武芸者は既に数名に及んでいる。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "十番館には、戦争犯罪容疑者として収容される前夜、青酸加里で自殺した遠衛公爵の三男坊が憂さばらしか、それとも元来享楽的なのか、時どき踊りに来るほか、数名の華族のいわゆる若様が顔を見せて、ある際物雑誌にその行状記を素ッ破抜かれた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲しろくいゆきわたらふ夏の空｜松蝉の声ぞここにしづけき誠あらば神も哭くべしこの声やしづかにはあれど父の声なりこの子らは共に遊ぶを遊ぶ無しその母と母の何憎みする六月三日長き休校の後、この日連袂辞職したる三沢校長初め三十数名の高等及び中学部の職員たち乗り込み来る。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私服正服の警官四十数名監視、反小原派の帝大教授、その夫人、竝に父兄等活躍す。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
