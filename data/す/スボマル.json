        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "で、処々、張出しが除れる、傘が窄まる、その上に冷い星が光を放って、ふっふっと洋燈が消える。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "干すと窄まる木場辺の渋蛇の目、死んだ頭の火事見舞は、ついおもだか屋にあった事。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、かうした度毎に、身の窄まる思ひがした。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の旧著万葉集辞典と言ふのは、今では人に噂せられるさへ、肩身の窄まる思ひのする恥しい本である。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼尻にしわが集まって来て、唇がすぼまるのである。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
