[
  {
    "uuid": "e1e64b2c-0409-5487-a14a-9f200205d12b",
    "entry": "筋道",
    "reading": {
      "primary": "すじみち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
