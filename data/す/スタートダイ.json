        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ベルリンのオリムピックの放送で、女子平泳の予選の時、支那のヤン嬢（多分さういふ名であつたと思ふが）がひどく派手な緑の水着をきて、外の選手がみんな水へ飛び込んでウォームアップをしてゐるのに、このお嬢さんだけはどこを風が吹くかといふやうにスタート台に悠々腰を下して水面を眺めてゐるだけである。",
              "citation": {
                "source": "相撲の放送",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタート台のあるほうへまわった裕一は、五コースの台に立った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いきなり飛びこんでも、いいかしら」「いいよ」　スタート台のあるほうへ亜紀子は歩いた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ぜひ計ってみたいから」「計って面白いようなタイムなんて、出るわけないわ」「ちょっと、やってみよう」　亜紀子を促した裕一は、スタート台のある縁にむけて、先に歩いた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "五コースのスタート台のかたわらに、裕一は立ちどまった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで帰ってきてこの壁にタッチをすれば、それでいい」「なんだか、どきどきするわ」　そう言いながら亜紀子はスタート台に上がった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタート台のかたわらで、裕一は水にむかって体を構えた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度とできないわ」　納得した裕一は、ストップ・ウオッチをスタート台の上に置いた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すわっている裕一を見下ろして微笑し、スタート台のある縁にむけて彼女は歩いた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "５コースのスタート台に亜紀子は立った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "裕一は立ち上がりスタート台へ歩いた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
