          "literary": [
            {
              "text": "仕事の邪魔をされるの、すっごく嫌なんだけどォ、ワトソン博士、今日だけは本当に例外ですよォ。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに気づいたキミはすっごく偉いけど、そこに因果を見るのは、ちょっと厳しいんじゃ、ない、の。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうなんだ……ひとはすっごくせつなくなると、夕ぐれがこいしくなるんだ……」「その44回ながめた日は、じゃあすっごくせつなかったの？",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのおうち、すっごくさむい。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、小むぎばたけは、すっごくいいものにかわるんだ、きみがおいらをなつけたら、だけど！",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、木ようはすっごくいい日！",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいらのひみつだけど、すっごくかんたんなことなんだ。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼく、キツネと友だちになれてすっごくうれしくて……」　ぼくはかんがえた。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すっごくたのしい！",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、あの子はすっごくかよわい！",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、すっごくむじゃき！",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがすっごくだいじなんだってことを！",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリス　すっごくへんてこりん。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると　ウサギは　ものすっごく　おびえて。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに　すっごく　めんどうだと　おもうんだけど、　どのあしから　うごかしたらいいか　きめなきゃいけないんだってさ。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると　こんどは　ネコも　きえるのが　すっごく　ゆっくりになって、　はじめが　しっぽ、　さいごが　にやにや。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「すっごくへんてこりん！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "読むとすっごく面白い。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ものすっごく懐かしい」　ハチミが言った。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「気持ちはすっごくわかる」　叫ぶように、ハチミが言った。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ、すっごく面白い！",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "着やせして、すっごく美人で、こりゃ何者じゃ、と娘の私だって思うからね」　帆奈美を相手に喋りながら、里里葉は背後の壁に寄せて大きなクッションを積み重ねた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お葉書、すっごくうれしかった」「今日は、駄目だ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっごくうれしい」　顔に手をかざして、ナミが言った。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人達って二人ともすっごくカサカサしてるでしょ、だから喧嘩になってごらんなさい、まるでライターのように直ぐに火がつきそうね」「ミショノー嬢のショールに入っちゃって」ヴォーケ夫人が笑いながら言った。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すっごく楽しいなあ。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
