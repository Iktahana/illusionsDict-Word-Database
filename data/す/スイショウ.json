    },
    "definitions": [
      {
        "index": 1,
        "gloss": "recommendation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "予は是等の歌を、潤いのある歌、味いをもって勝った歌として推奨したい。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが佐藤春夫先生の推奨にあずかり、その後、文学雑誌に次々と作品を発表することができました。",
              "citation": {
                "source": "わが半生を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道衍｜少きより学を好み詩を工にし、高啓と友とし善く、宋濂にも推奨され、逃虚子集十巻を世に留めしほどの文才あるものなれば、道衍や筆を執りけん、或は又金忠の輩や詞を綴りけん、いずれにせよ、柔を外にして剛を懐き、己を護りて人を責むる、いと力ある文字なり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "道衍の少きや、学を好み詩を工にして、濂の推奨するところとなる。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「片言もって獄を折むべきものは、それ由か」などという孔子の推奨の辞までが、大袈裟な尾鰭をつけて普く知れ渡っていたのである。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身に就いて云うならば、斯ういう島民の扱い方に対して別に人道主義的な顰蹙も感じないが、さりとて之を以て最上の遣り方と推奨することにも多分の躊躇を感ずる。",
              "citation": {
                "source": "南島譚",
                "author": "※",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に翁は間拍子のメチャメチャな所謂、我武者羅謡を推奨していたかのように誤解している間拍子嫌いの人も多かったらしいが、決してそんな事ではなかった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "推奨する新人牧野信一井伏鱒二――いつか三田文学で「鯉」といふ作品を見て非常に感心した。",
              "citation": {
                "source": "推奨する新人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "川村の事は只今グラスゴウ市の版元から頼まれて編み居るロンドン大学前総長フレデリク・ヴィクトル・ジキンス推奨の『南方熊楠自伝』にも書き入れ居るから外国までの恥｜曝しじゃ。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、紅葉は芸術本位であった故、仏蘭西の写実派には興味を持っても、人生本位の露西亜の小説はジメジメして陰気だと蔑し、その頃からツルゲネフやトルストイを推奨した私を外道と呼び、私等の主張した人生のための文学説を涅※哲学と嘲っていた。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『平凡』の予告が現われた時、二葉亭が昔しから推奨したゴンチャローフの名作を憶い浮べて題名に興味を持ったので直ぐ手紙を送った。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンチェンコは深く二葉亭に服して頻りに露都への来遊を希望し、かつ池辺三山及び村山龍平に向て露都通信員の派遣を勧告し、その最適任者としての二葉亭の才能人物を盛んに推奨したので、朝日社長村山も終に動かされてその提案に同意した。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に上諏訪町から往復六里で、一日旅行に極ふさわしい此の霧ヶ峰を、第一に推奨した処が、盛に賛成があって、今年長雨期にも係らず、是非連れて貰い度いと云い出したものが二十人許りあった。",
              "citation": {
                "source": "女子霧ヶ峰登山記",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "松平春岳挙げて和歌の師とす、推奨｜最つとむ。",
              "citation": {
                "source": "曙覧の歌",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、お銀が言っていたが、笹村も初めのように推奨する代りに、すべてを悪い方へ解釈したかった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンガー女史が一番有効なものとして推奨しているカプセルは、一つ五十フランするのだが、それも長くは使えない。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまだお茶の水高等女学校に在学中、何の見当もなく、一生懸命に書きました処女作「貧しき人々の群」を坪内逍遙博士に見ていただきました処、意外にも非常なお推奨を受けまして博士のお世話で中央公論に発表されたので、幸い有難い評判をいただきました。",
              "citation": {
                "source": "処女作より結婚まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "趙樹理の作品の紹介も、日本の文化・文学の現実ときりはなされて、民主主義文学の最もかがやかしい典型であるかのように一部から推奨されている。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからといって、それらに付きまとわれるのは推奨されるべきでもない。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "有益な本、考えさせる点の多い本と推奨された。",
              "citation": {
                "source": "今日の作家と読者",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般的標準からいへば、自己の体臭に似通つた香水の使用が推奨されてゐるが、これも結構だ。",
              "citation": {
                "source": "「香水の表情」に就いて",
                "author": "――漫談的無駄話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国は一六五〇年これを喜び迎えて、「かの卓絶せる、かつすべての医者の推奨するシナ飲料、シナ人はこれをチャと呼び、他国民はこれをテイまたはティーと呼ぶ。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに世の中が、あるいは政府が、これが一番だと推奨してくれても、私が好まないものであれば、恋愛は更らに起らないのだ。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は仁田峠と、普賢の絶頂と、高岩岳の展望を、雲仙の三大景観として推奨したい。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく市民は大会を開いて、十五少年｜推奨の盛宴を張った。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤いべべを着たお人形さんや、ロッペン島のあざらしのような顔をした土細工の犬やいろんなおもちゃもあったが、その中に、五、六本、ブリキの銀笛があったのは蓋し、原君の推奨によって買ったものらしい。",
              "citation": {
                "source": "水の三日",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう言つても、われ／＼は、「兼好法師物見車」を推奨しようとしてゐるものと思はれてはいやである。",
              "citation": {
                "source": "由良助の成立",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この初めを説く物語が、さほひめ皇后の推奨によるものとしていたのである。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社のほかに、何ひとつ、これといふ道楽を持たないといふこと――母が、それを、世に稀な美徳として推奨するのは無理もないが、一生を道楽ですりへらしてきた父が、本気でそれを賞美し、推奨してゐようとは、波子は信じることができなかつた。",
              "citation": {
                "source": "波子",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこのすいしょうをはりつめた欄干から、湖水を透かしてすぐ向こうに三上山がそびえていました。",
              "citation": {
                "source": "田原藤太",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
