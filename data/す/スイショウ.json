[
  {
    "uuid": "100f8866-5ee7-5095-932e-2f0a5f36b0e7",
    "entry": "推奨",
    "reading": {
      "primary": "すいしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
