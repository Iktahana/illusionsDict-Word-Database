        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "スティックを使って、一種のスキップをすると考えればよい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四分なんて、スキップしながら階段を二段降りするようなもので、全員がこけつまろびつになってしまう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが　ナトキンは　あたりを　スキップしながら　うたいます。",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            },
            {
              "text": "エプロンドレスを　うしろまえにして　ぴょんぴょん　スキップしながら　いきました。",
              "citation": {
                "source": "ねこぬこタムのはなし",
                "author": "THE TALE OF TOM KITTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "早苗のおでこのかすりきずは、ついこないだ、ミサ子と二人で肩をくんでスキップで走っていて、道路から浜におちたときの怪我だとわかったし、キッチンの家では豚が三匹も豚コレラで死んでしまい、お母さんが寝こんだ、などと話はつきなかった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ビッグ・ブル・ブルーンジー、レッドベリ、スキップ・ジェイムズ、ロバート・ジョンソン。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
