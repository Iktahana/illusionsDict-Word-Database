    "definitions": [
      {
        "index": 1,
        "gloss": "small cake made from sweet potatoes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "文化祭の模擬店で手作りのスイートポテトを販売したら、あっという間に完売してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "卵黄を塗ってこんがりと焼き上げられたスイートポテトは、秋のティータイムに欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お土産にいただいた老舗のスイートポテトは、バターの香りとサツマイモの甘みが絶妙だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その夜、私はスイートポテトの如くパラフィン紙に包まれた象の幽霊と称するものを人から貰った。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "オヤオヤ、大きなスイートポテトを持ってきやがったなア、と思ったら、これがサツマ芋の皮に入れてむした茶碗ムシ（芋ムシですかな）であった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでクラムベークというのは、この貝と蝦と玉蜀黍とスイートポテトなどを、クラントウ風に「浜焼」にした料理である。",
              "citation": {
                "source": "西洋の浜焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "sweet potato",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "幼稚園の行事で芋掘りに行き、大きなスイートポテトをたくさん収穫してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "寒い冬の夜、屋台から流れてくる石焼きスイートポテトの香りに、つい足が止まってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この地域特産のスイートポテトは糖度が高く、蒸すだけで天然のスイーツのような味わいだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
