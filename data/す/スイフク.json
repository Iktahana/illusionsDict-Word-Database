        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "）へ泊りに來てゐて、寢ころんで、誰かの本を讀んでゐた雅量は、推服に値する。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "壮士連はことごとく子路の明快闊達に推服した。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲の壮士連を推服せしめたものは、一つには確かにこうした評判でもあった。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（白人に立てられた傀儡ではない）彼等の心から推服する真の王者へと贈られた・大小酋長からの献上品だ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮部は肥後の産、吉田松陰とは親友の仲であり、尊攘派の錚々たる一人で、同志からは先輩の一人として推服された人物である。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "その齢と深慮と誠実との故を以つて、彼は他の同学の先輩として推服するところたり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅葉美妙以下硯友社諸氏の文品才藻には深く推服していたが、元来私の志していたのは経済であって、文学の如きは閑余の遊戯としか思っていなかった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、瀕死の瀬戸際に臨んでも少しも挫けなかった知識の向上慾の盛んなるには推服せざるを得なかった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、新たに入社するものはこの伝統の社風に同感するものでも、また必ずしも沼南の人物に推服するものばかりでもなかったから、暫らくすると沼南の節度に慊らないで社員は絶えず代謝して、解体前の数年間はシッキリなしにガタビシしていた。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼南にはその後段々近接し、沼南門下のものからも度々噂を聞いて、Ｙに対する沼南の情誼に感奮した最初の推服を次第に減じたが、沼南の百の欠点を知っても自分の顔へ泥を塗った門生の罪過を憎む代りに憐んで生涯面倒を見てやった沼南の美徳に対する感嘆は毫も減ずるものではない。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学を除いては総ての研究は空理であるといいつつも科学にもまた不満足であって、科学に偏するスペンサーの哲学の如きも或る程度以上は決して推服していなかった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にして思うと、三十年前に人種競争の止むを得ざる結果から欧亜の大衝突の当然来るべきを切言した二葉亭の巨眼は推服すべきものであった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "団十郎は心から桜痴居士に推服しているらしかった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿介の所へみんなが集るやうになる最初のきつかけを作つた年少の塚原が、彼らしい純眞な氣持から一番柴岡に推服してゐるらしく、屡々彼のことを云つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "組織を見ても、誰もが推服する指導者なき限り、多くの支部は指導者的支部長をおかず、すべて合議制であつた。",
              "citation": {
                "source": "新日本の進路",
                "author": "石原莞爾將軍の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はその説に大に推服しているものである。",
              "citation": {
                "source": "錯覚した小宇宙",
                "author": "――Our faith comes in moments;",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はすっかり推服した。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、それを聞いた僕の友だちの小説家は、それ以来、大にＭに推服してしまつたぢやあないか。",
              "citation": {
                "source": "創作",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一葉女史の味わった人世の苦味、諦めと、負じ魂との試練を経た哲学――　信実のところ私は、一葉女史を畏敬し、推服してもいたが、私の性質として何となく親しみがたく思っていた。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人に傲らない態度が、伝右衛門にとっては、物足りないと同時に、一層の奥床しさを感じさせたと見えて、今まで内蔵助の方を向いていた彼は、永年京都｜勤番をつとめていた小野寺十内の方へ向きを換えると、益、熱心に推服の意を洩し始めた。",
              "citation": {
                "source": "或日の大石内蔵助",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "惡口黨の旗頭の平田すら、孔子は心も行も我が師翁其儘だと推服して居る。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は襄に推服して置かざりしなり。",
              "citation": {
                "source": "頼襄を論ず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "又同藩士櫻任藏にも推服する所あり。",
              "citation": {
                "source": "遺牘",
                "author": "西郷隆盛",
                "note": "青空文庫"
              }
            },
            {
              "text": "『日本後紀』弘仁三年六月二日条に、その同類のうち心性事を了し、衆の推服するところのもの一人を択びてこれが長となすとある。",
              "citation": {
                "source": "奥州における御館藤原氏",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また以て如何に松陰が象山に推服したる、及びその何故に推服したるを知るべし。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が教授の文章にいたく推服したのはこの時である。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他の諸像には相当に異見があり、特に四天王に至ってはＺ君はほとんど一顧の価値をも認めまいとしたが、しかしわたくしはこの比較的に簡素な四天王にも推服する。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の常識的な言葉には、誰も彼も推服せざるを得なかつた。",
              "citation": {
                "source": "良友悪友",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分より十歳も若い平次と張合つて、手柄爭ひに血を沸かせたのも昔で、今では平次の頭腦と腕と、それよりも功名にも利害にもこだはらない恬淡な人柄に推服して、何時の間にやら若い兄貴に立ててゐる文七だつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お此お糸",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
