[
  {
    "uuid": "9e3ab6c8-8ed4-556b-9181-ae6c8082cc69",
    "entry": "住み込む",
    "reading": {
      "primary": "すみこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to live (in the house of one's employer, teacher, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしいつまでも空寺にして置くと、何時ほかの住僧がはいり込まないとも限らないから、いっそ自分たちが占領してしまう方がいいというので、全達と全真、この二人が住職と納所に化けて住み込むことになったんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "均平は銀子が松の家へ住み込むちょうど一年前に起こった、この哀話を断片的に二三の人から聴き、自分で勝手な辻褄を合わせてみたりしたものだったが、土地うちの人は、この事件に誰も深く触れようとはしなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｈ先生の内弟子に住み込む覚悟でいるんだからね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　三日の目見得もとどこおりなく済んで、お角は津の国屋へいよいよ住み込むことになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手が勤めの女である以上、かれに近寄るには伊勢屋へ入り込むよりほかはないので、勤めあがりのお定はすぐに下新造に住み込むことを考えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも岡の手製の家で、以前彼は此処を木彫室に使つてゐたが、倉閑吉と鶴井大次郎が住み込むやうになつて以来は、二人のために完全に明け渡したのである。",
              "citation": {
                "source": "心象風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は彼女に料理屋にはどんなことがあらうとも住み込むなと云つたのに、それに宿屋へ這入つた自分を見て、何といつて悲しむことかと女は云ふ。",
              "citation": {
                "source": "榛名",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の家に住み込むやうになつては、勝手に出歩くといふことは容易に望めることではないからである。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "住み込むことになつたのは、彼の郷里の出身で、新しい事業家として、近年にはかに産を成したといはれる岡島家だつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お庄ら夫婦がこの家へ住み込むようになってから、もう一ト月と十日余りになっていた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒井様へ小使に住み込む時、勝負事で識合になっていた紀州の亀蔵と云う奴の名を、口から出任せに言ったのです。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日振りに天保山の安宿をひきあげて、バスケット一つの飄々とした私は、もらわれて行く犬の仔のように、毛布問屋へ住み込む事になった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日振りに天保山の安宿をひきあげて、バスケット一ツの漂々とした私は、もらわれて行く犬の子のように、毛布問屋に住み込む事になった。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "間代も払って、やれやれと住み込むと、二週間でお払いばこだ。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに於てノブ子は窮迫の余り、僅かに残った金でタイプライターと簿記を習い覚え、紐育北郊外ハドソン河の傍らなるマハン造船所の前に在る料理店ゴールデン・ハマーの事務員に住み込む事になりました。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから到底住み込むことは出来ない。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "党を組んで、戦国の諸豪族を訪れ、行法と武力とを以て、庸兵となり、或は臣下となつて住み込む事もあつた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで相談の上、お六は長庵と別れて、望み通りにカフエへ住み込む。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "学者と町人とはまるで別途の人間であって、学者が金を予期して学問をするのは、町人が学問を目的にして丁稚に住み込むようなものである」「そうかなあ」と突飛な声を出す奴がいる。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その仏堂に私は住み込むことになりました。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "で私はチベット人としてその寺に住み込むという決心をしたです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ氏は会津人の辛抱づよい性格と、男ながらたまかな生計に達していて、ぼくが住み込むと、台所の水仕事から、味噌醤油、八百屋物の買出しなど、一切はぼくの任にまかせられた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなボロ家に、どんないきさつで僕が住み込むことになったか。",
              "citation": {
                "source": "ボロ家の春秋",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな具合でかけずり廻った甲斐もなくその日は勤め口にありつけなかったが、その翌日石原町のカフェースワンというのへ住み込むことが出来た。",
              "citation": {
                "source": "女給",
                "author": "細井和喜蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　女給を無給で使って看板にしているカフェーでは、彼女にいてほしさにモルモットを伴れて住み込むことを承諾した。",
              "citation": {
                "source": "モルモット",
                "author": "細井和喜蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "とこうするうち、たしか十八か九のとしでござりました、ふとしたことから小谷のお城へ御奉公を取り持ってくれるお人がござりまして、そのおかたの肝いりであの御城中へ住み込むようになったのでござります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左衛門尉は圓一と如何なる縁故があったのか詳かでないけれども、彼のお蔭でたやすく勾当の位を得、姓名を藪原辰一と改めて、文禄二年の頃からとき／″＼聚楽の城中に招かれ、次いで城内に住み込むようになったと云う。",
              "citation": {
                "source": "聞書抄",
                "author": "第二盲目物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもシラミが恐怖を感ずることがあるとしたら彼らの生命にとっての悪夢はいつか発疹チフスに罹ったラットか人間に住み込むことである。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから娘にはよく言いふくめてお嬢さまの名で東京のカフェへ奉公にやり、私は私で、別に籍をこしらえて名前をかえてこのホテルへすみこむことになったのでございます。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "すみこむだけならよかったのだが、即ち、これ宗教なり、よってオイノリをやる、一日中、やるのである。",
              "citation": {
                "source": "本因坊・呉清源十番碁観戦記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
