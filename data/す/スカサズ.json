    "definitions": [
      {
        "index": 1,
        "gloss": "without a moment's delay",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
