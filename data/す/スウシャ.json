        "examples": {
          "standard": [
            {
              "text": "今回のプロジェクトのために、数社から見積もりを取り寄せ、比較検討することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "市場調査の結果、数社が競合製品を開発していることが判明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、希望する職種に就くため、数社に履歴書を送付した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "さて再びその十数社をことごとく他の大字へ合併せしめたり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの行動は日本の出版民主化への方向と対立し、その後用紙融通の魅力によって八十数社を加えている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同氏は米国の大富豪で知られ、五番街に豪邸を構え、ニューポートに別荘を持ち、事業に鉄道会社を数社持ち、その他、米国大富豪の必需品を多数所有している。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどこの話を書くに当って、平行線の定理を数社の若い記者諸君に訊いてみた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
