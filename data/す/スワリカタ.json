        "examples": {
          "standard": [
            {
              "text": "正しい座り方を意識することで、猫背が徐々に改善されてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "茶道の教室で、足がしびれにくい綺麗な座り方のコツを教わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の座り方はいつもだらしなく、椅子の背もたれに深く寄りかかっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「でも、顔ばつかり見てゐないで、その座り方の下手な処も映して見たら何うよ。",
              "citation": {
                "source": "小川の流れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……だがあの座り方は何といったらよいのだ。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「京都で過ごした一年間に、そのようなすわりかたを、私は何度も見たわ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
