        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "燕王兵を率いて至り、河水の渡り難きを見て黙祷して曰く、天｜若し予を助けんには、河水氷結せよと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは「おゝ冷てえ」といひながら竈の口から捲れて出る※へ手を翳して「今朝は芋の水氷つたんだよ」とお袋の方を向いていつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の述懐に曰く、「春浅み野中の清水氷り為て底の心を汲む人ぞなき」。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の水氷りたるに石投ぐる者案外に大人なるも可笑し。",
              "citation": {
                "source": "『団栗』のことなど",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪降りつもり水氷って谷の小川は音もない、峰々から逆巻き吹きおろす風は身を切り、滝の白糸はつららとなって垂れ下がっている。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、扨、四日暮過、茶の下焚ん、と思ひ、瓶水汲んとせしが、瓶水氷り、いごかず。",
              "citation": {
                "source": "三次実録物語",
                "author": "稲生武太夫",
                "note": "青空文庫"
              }
            }
          ]
        }
