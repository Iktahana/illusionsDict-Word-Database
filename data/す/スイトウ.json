[
  {
    "uuid": "0a81885e-2593-5f26-80b2-cc953c43ba94",
    "entry": "出納",
    "reading": {
      "primary": "すいとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "receipts and expenditure (disbursements)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ミサコが廻転扉から出納口につかつかと進むと、コケットな彼女の嬌態に狼狽した行員が自覚を失った指先で紙幣をかきあつめた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚の小切手が一かたまりの紙幣となって出納口からでてくると、銀行を背負ったような女は、ふたたび銀座方面へガソリンの尾を曳いた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵卒は、初年兵の時、財布に持っている金額と、金銭出納簿（入営するとそれを記入することを云いつけられる。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番々頭が持参する日々の出納帳もあまり身にしみては見なかつた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日借覽する本が定まつてゐるので、圖書館の出納係から云へば、まことに手數のかゝらぬ好い閲覽人で、いつとなく燕石十種先生といふ綽名をつけられたが、予輩の如き卒讀亂讀者流の出納係に手數をかけること夥しい厄介ものとは違つて、館の人とも自然に懇にしあつてゐられた。",
              "citation": {
                "source": "淡島寒月氏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "商業学校の夜間部を出ると、出納係に雇われたが、間もなく応召し、五年の後復員して来たが、その五年の歳月はこの実直な青年の実直さを、すこしも変えていなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の扶持米で立ててゆく暮らしは、おりおり足らぬことがあるにしても、たいてい出納が合っている。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホズマ――エインジェルさん――は、レドンホール街の事務所で出納係をしていらして――それで――」「業種は？",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "こはわが出納の事を托したる銀行の主人なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の扶持米で立てて行く暮しは、折々足らぬことがあるにしても、大抵出納が合つてゐる。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "出納の事情は千種万様であれば、いかなる簿記法を調べても、完璧に我が家の事情に合致した簿記法の書が有る筈もなく、また計算の数量も千差万別なので、どのような計算法の書を繙いても完璧に我が家が持つ問題と同じ問題を解く計算法を記載した計算法の書が有る筈もない。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あいつ、××課長奴、社長の前であの尻尾のふり方をみたまへ、振るわ、振るわ、大車輪ぢやないか、あんなに振らんでもネ』『出納部の××君を見給へ、社長の前のあの醜態をさ、おや感極まつて尻尾を股の間に捲きこんでしまつたよ――』　といふ噂をしあふのであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "出納庶務から人事の一切を綜べ、学堂の機密にも参じ外部の交渉にも当って、あたかも大蔵と内務と外務とを兼掌していたから、任務は頗る重くて極めて困難であった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "出納係の若い男は、小切手から離した眼を、窓の外に立っている男に移して、じろじろとその顔に見入った。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　出納係は喜ばしそうに叫んだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベンは出納係に、別に用はないんだ、ただ知人を待っているだけなんだ、と言った。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国の銀行家の説によると、長年出納勘定に熟練してゐる銀行家が一時間に勘定出来る銀貨の金高は大きく見積つて、ざつと四千｜弗といふ事だ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "出納掛の若い男は、小切手から離した眼を、窓の外に立つてゐる男に移して、じろじろとその顔に見入つた。",
              "citation": {
                "source": "茶話",
                "author": "昭和三（一九二八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　出納掛は喜ばしさうに叫んだ。",
              "citation": {
                "source": "茶話",
                "author": "昭和三（一九二八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡便に行わるべき書籍の出納場が、あんなに高い、絵にある閻魔の大机のようなのなどは寧ろ愉快な滑稽だ。",
              "citation": {
                "source": "蠹魚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手元には出納の賭札が手ぎわよく積まれてある。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "金銭出納細目帳のようにまで書かれている。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文庫の出納を厳にするが好いと云つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩田は主に出納の事に当り、わたくしは主に診療の事に当つたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "……十二の時、あんたと一所に祭に出ましたな、あれが出納めだしたんや。",
              "citation": {
                "source": "東光院",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "……眉が保寿官、眼が監察官、鼻梁が審弁官、口が出納官、そうして耳が採聴官。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出納の記帳台に納っていた白板面が、係長の眼を盗んで槇子へ下手くそなウインクを送ってよこした。",
              "citation": {
                "source": "罠を跳び越える女",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
