[
  {
    "uuid": "89e2f946-493c-5297-a1dc-948e765db37c",
    "entry": "昴",
    "reading": {
      "primary": "すばる",
      "alternatives": [
        "すまる",
        "ぼう"
      ],
      "is_heteronym": false
    },
    "grammar": {
