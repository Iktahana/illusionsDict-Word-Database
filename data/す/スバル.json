  {
    "uuid": "98a21e6b-f3da-584d-a9b0-7cac644d38c7",
    "entry": "スバル",
    "reading": {
      "primary": "スバル",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Subaru",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（明治四五・六・八―一〇稿／「スバル」明治四五・七／『畜生道』所収）",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正二・一稿／「スバル」大正二・二／『畜生道』　所収）",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正元・九・四／「スバル」四巻一〇号　大正元・一〇／『畜生道』　所収）",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正元・八・一四稿／「スバル」四巻九号大正元・九／『畜生道』所収）",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "スバル、白樺、三田文学、劇と詩、朱欒。",
              "citation": {
                "source": "夜長ノート",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "一金五圓也　上原政之助氏一金一圓也　柏田蕗村氏（校了の日　印刷所の二階にて　啄木生）（明42・２「スバル」二）",
              "citation": {
                "source": "消息",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に私は『邪宗門』『思ひ出』『桐の花』等の詩歌集を出し、また雑誌『スバル』に外部より声援し、又木下杢太郎、長田秀雄両君と都会趣味と異国情趣を基調とした雑誌『屋上庭園』を二冊発刊し、其後単独でも雑誌『朱欒』を一年有半続刊した。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "スバルや三田文学がそろそろ退治られそうな模様である。",
              "citation": {
                "source": "夏目漱石論",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘のすゝめに従つて、一葉を読み、荷風を読みしてゐるうちに次第に僕も現代小説に興味を持ちはぢめ、「新小説」「中央公論」「スバル」などゝいふ雑誌の読者になつて、潤一郎の新作を待ち兼ねたり、勇の歌を喜んだり、万太郎の作物を愛読しはぢめたりした。",
              "citation": {
                "source": "川蒸気は昔のまゝ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "スバル社までこれを駆け足で持つて行かうか、何処かで貸オートバイを探さうか。",
              "citation": {
                "source": "僕の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "月々執筆されてゐる「第一次スバルの回想」等も僕は月々愛読してゐる。",
              "citation": {
                "source": "なつかしき挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚今月「スバル」の復活号を手にしたことは全く偶然の悦びであつた。",
              "citation": {
                "source": "月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本にてはこれを「スバル星」といい来った。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然派と高踏派或はスバル派、早稲田派と三田派等の間にも可なり鮮明な境界を画することができる。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼ら脱飛者たちの多くが目指すところは、龍骨座密集星図に属するスバル太陽系の七個の惑星であるが、彼らがこの宇宙移住に成功するためには最短路をとるとして約一千光年の距離を翔飛せねばならず、実際に目的地へ到達し得る者は全体の一パーセント程度であろう。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人類はやがて、スバル太陽系の惑星へ宇宙移住し、かの地で繁栄するのだから、明るいじゃないか。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――啄木）〔「スバル」明治四十二年二月号〕",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔「スバル」明治四十二年十月号〕",
              "citation": {
                "source": "葉書",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『スバル』に『三田文學』に、先生の書かれるものは一頃よりは却つて若々しくさへ見えた。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリスト教とソシアリズムを一応パスして当時ショウペンハウエルと仏蘭西のデカダン詩人とに影響せられていた僕は、自然派の人の中では泡鳴が一番好きでスバルの連中が一番自分に近いような気がしていた。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京に「スバル座」を始めとして幾つかのアメリカ映画館がつくられた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人の文学活動の展開される場面も数多くなり『新潮』『文章世界』などのほかに、『スバル』もあり『番紅花』『詩歌』『朱欒』等のほか、片山広子のアイルランド劇研究の載った『心の花』もあるという盛観であった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に『スバル』の象徴派とも、谷崎潤一郎などの色彩つよいネオ・ロマンティシズムとも、又、現実から一歩身を退かした漱石の文学態度とも別種の、人間の新しい肯定としてあらわれたのであった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生で東京にゐられた頃、私達の詩社に加はつて雑誌「明星」や「スバル」に歌を載せた青年であつた浦崎さんが、此地にゐられやうとは思ひがけない事であつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "その空に星を仰ぐ、オリオンでもスバルでも何でもよい。",
              "citation": {
                "source": "どぶろく幻想",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方神田淡路町に琅※洞という小さな美術店を創設して新興芸術の展覧会などをやったり、当時日本に勃興したスバル一派の新文学運動に加わったりしていたと同時に、遅蒔の青春が爆発して、北原白秋氏、長田秀雄氏、木下杢太郎氏などとさかんに往来してかなり烈しい所謂耽溺生活に陥っていた。",
              "citation": {
                "source": "智恵子の半生",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は昼間っから酒に酔い痴れては、ボオドレエルの「アシツシユの詩」などを翻訳口述してマドモワゼル　ウメに書き取らせ、「スバル」なんかに出した。",
              "citation": {
                "source": "ヒウザン会とパンの会",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方神田淡路町に琅※洞といふ小さな美術店を創設して新興芸術の展覧会などをやつたり、当時日本に勃興したスバル一派の新文学運動に加はつたりしてゐたと同時に、遅蒔の青春が爆発して、北原白秋氏、長田秀雄氏、木下｜杢太郎氏などとさかんに往来してかなり烈しい所謂｜耽溺生活に陥つてゐた。",
              "citation": {
                "source": "智恵子抄",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "森鴎外先生が『スバル』その他の雑誌に寄せられた名著の大半もまた籾山書店から刊行せられた。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十一年時分の事で、その頃には丁度森先生のところには常盤會の歌會につゞいて觀潮樓歌會が開かれたり、又雜誌スバルが創刊されやうといふ頃なので、夜晩くまでいろ／＼お話を伺ふことができた。",
              "citation": {
                "source": "鴎外記念館のこと",
