    "definitions": [
      {
        "index": 1,
        "gloss": "(coil) spring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "磨かれた車窓に、西紅葉の横顔がスプリングのついた船舶に乗船する女のように輝いていた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "スプリングの深いクッションへ規矩男は鷹揚な腰の掛け方をした。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老い疲れたる帝国大学生、袖口ぼろぼろ、蚊の脛ほどに細長きズボン、鼠いろのスプリングを羽織って、不思議や、若き日のボオドレエルの肖像と瓜二つ。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠いろのスプリング。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "スプリングの裾がぱっとめくりあげられ、一握の小砂利が頬めがけて叩きつけられぱちぱち爆ぜた。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アムール、サクソン、スプリング、浦塩、アプルツク。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "上って行くと、こぢんまりした一室が、居心地よく装飾され、スプリングの心地よいソファ・ベッドや、三面鏡や、簡単な衣裳箪笥が置かれていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そんな風にぽつ／＼と書いては居たが、本当に文学をやらうと決心したのは、去年「スプリングコート」を書いた前後からである。",
              "citation": {
                "source": "貧しき文学的経験（文壇へ出るまで）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スプリングコート」「父を売る子」「渚」「或る五月の朝」「父の百ヶ日前後」「明るく暗く」「蝉」等七篇書けた。",
              "citation": {
                "source": "貧しき文学的経験（文壇へ出るまで）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹一は虚勢を張りながら、いきなりどすんと腰を下したが、スプリングがついていたので、危く転りそうになった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮地嘉六氏と内藤辰雄氏の鞭撻のお蔭で、かなり力の入れどころも知ったように思ったが、八月号の「新興文学」誌上で、宮島新三郎氏から、内面描写が足り無いという評を受けてからは、私は自分の力がスプリングのように撥ね上がったように思った。",
              "citation": {
                "source": "骨を削りつつ歩む",
                "author": "――文壇苦行記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその仕事は、スプリングか釘のようなものが、ガチャンと嵌まりこんだような音をたてて終った。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄茶のスプリング・コオト。",
              "citation": {
                "source": "指",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベッドは木製でひどく大きく、ちゃちなスプリングなど附いていないのが、かえってたのもしく、両側には引出しやら棚やらがたくさん附いていて、身のまわりのもの一切をそれにしまい込んでも、まだ余分の引出しが残っているくらいだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上の他「スプリングコート」（これは去年の十二月慌しく書き、一月発表。",
              "citation": {
                "source": "予が本年発表せる創作に就いて",
                "author": "沢山書いた",
                "note": "青空文庫"
              }
            },
            {
              "text": "中折帽を眼深にかむって、鼠色のスプリング・コートのポケットへ、何故か右手を絶えず突込んだままでいる。",
              "citation": {
                "source": "香水紳士",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人びとの中に混って、一人の異様な紳士が――満身にすばらしい香水の匂いをプンプンさした紳士が、右手をスプリング・コートのポケットへ入れたまま、なにかひどく腑に落ちかねたような顔つきで、鼻をヒクヒクさせながら、人混みをかきわけるようにして、出口のほうへ歩いて行った。",
              "citation": {
                "source": "香水紳士",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、それじゃあ、なんでお前さんはスプリングフィールドの一件でここにぶちこまれたっていうんだ。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "所長さん、スプリングフィールドになんて行ったことないですって。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんせ、スプリングフィールドが強く言いやがるもんだから、知事だってもうすぐで思いとどまるとこだったんだ。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "スプリングフィールドの一件で知り尽くしていた。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は自分の身のまわりを見、天井を見、スプリングを揺すってみた。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スプリング・ムーンが、別れた恋人のかたちに似てゐるといふセンチメントをうたつたエレヂイである。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "着古したスプリング・コートのポケットに両手を突込んだまま、ゆっくり自分の靴音を数えながら、汝ノ路ヲ歩ケ　と心に呟きつづける。",
              "citation": {
                "source": "遥かな旅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "着ているスプリング・コートは彼が結婚した年に拵えたもので、今では生地も薄れ、裏の地はすっかり破れていた。",
              "citation": {
                "source": "遥かな旅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そのスプリング・コートを拵えたばかりの頃だった。",
              "citation": {
                "source": "遥かな旅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その電波嬢は、あとで解体せられ、スプリングや電池とかわってしまったという。",
              "citation": {
                "source": "人造物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
