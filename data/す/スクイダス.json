    "definitions": [
      {
        "index": 1,
        "gloss": "to bail (e.g. water from a boat)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もうおにいさまたちをすくいだすまでは、いっときもおちつけないのです。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父さまをぶじにすくいだすことができれば、ぼくは、死んでもいいんだ」　島についた高一は、まず船のなかから、りんごのいっぱいはいったかごを上にあげました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "捜索隊は、ただ怪人のすみかを、発見したというだけで、あいてをとらえることもできず、大友少年をすくいだすこともできず、手をむなしくして、引きあげるほかはなかったのです。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大どろぼうが警視総監に化けたばかりか、その部下たちも警官に化けて、にせ総監をすくいだすなんて、じつに思いもよらないはなれわざです。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう二人ずつ三｜組にわかれて、甲府の城下へまぎれこみ、大久保家の内状をさぐったうえにて、間隙をはかって館のうちに捕らわれている咲耶子をすくいだす目的をしめし合わせた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
