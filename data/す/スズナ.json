    "definitions": [
      {
        "index": 1,
        "gloss": "turnip (Brassica rapa)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
