        "examples": {
          "standard": [
            {
              "text": "晩ご飯の買い物をするために、帰り道の駅前にあるスーパーマーケットに立ち寄った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "日曜日のスーパーマーケットは家族連れで賑わっており、レジの前には長い行列ができている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このスーパーマーケットは地元の新鮮な野菜を産地直送で販売しているのが売りだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "うさぎ屋は、いつも彼らが買物にいく、山むこうの食料品店兼雑貨屋、ユニオンは元町のスーパーマーケットだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎は両手に皿をもち、ワラは元町のスーパーマーケットの袋をさげている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "通信販売で電卓キットをさばくのにＭＩＴＳが一台あたり三九ドルを要したにもかかわらず、スーパーマーケットには二九ドルの完成品の電卓が並びはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "スーパーマーケットにさしかかって、僕はカプリースを歩道に寄せて徐行させた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "週末の買物でスーパーマーケットまでいっているという。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
