          "standard": [],
          "literary": [
            {
              "text": "右へ廻れば藤棚の下に「御子供衆への御土産一銭から御座ります」と声々に叫ぶ玩具売りの女の子。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いくらこの山の座り幅が広いたって、三国か四国に亙っているに過ぎまい。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だかわたしが、たった一人、居ずまゐ正してこゝに座り、やつらの仲間がかはるがはる、その二っつの小窓から、わたしを覗いてゐるやうだ。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年はさっと顔いろが青ざめ、たって一ぺんそっちへ行きさうにしましたが思ひかへしてまた座りました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中へ行って座りたい。",
              "citation": {
                "source": "ラジュウムの雁",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "考へて見るとわたしは、ここにおまへの居るのを知らないで、この洞穴のま上の岬に毎日座り考へ歌ひつかれては眠った。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはあしたから灰をかぶって街の廣場に座り、おまへとみんなにわびようと思ふ。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、又お座りね。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤シャツの農夫は炉のそばの土間に燕麦の稈を一束敷いて、その上に足を投げ出して座り、小さな手帳に何か書き込んでいました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "園さまはどうなされた今日はまだ顏が見えぬと問はれてまさかに、今までこれ／＼で次の間に泣いて居られますとも言ひがたければ、少々御不加※で、然しもう宜しう御座りませうほどに、まあお茶を一つなどヽ民は其塲をつくろひぬ。",
              "citation": {
                "source": "經つくゑ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまへの抱かれて居るは誰何、知れるかえと母親の問へば、言下に兄樣で御座りましやうと言ふ、左樣わかればもう仔細は無し、今話して下された事覺えてかと言へば、知つて居まする、花は盛りにと又あらぬ事を言ひ出せば、一同顏を見合せて情なき思ひなり。",
              "citation": {
                "source": "うつせみ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の抱かれてゐるは誰君、知れるかへと母親の問へば、言下に兄様で御座りませうと言ふ、さうわかればもう子細はなし、今話して下された事覚えてかと言へば、知つてゐまする、花は盛りにと又あらぬ事を言ひ出せば、一同かほを見合せて情なき思ひなり。",
              "citation": {
                "source": "うつせみ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の抱かれて居るは誰君、知れるかへと母親の問へば、言下に兄樣で御座りませうと言ふ、左樣わかれば最う子細はなし、今話して下された事覺えてかと言へば、知つて居まする、花は盛りにと又あらぬ事を言ひ出せば、一同かほを見合せて情なき思ひなり。",
              "citation": {
                "source": "うつせみ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　滅相なと徳兵衛「結構で御座ります」　なりひらが、Ｔ「後ほど屋敷へ持参致せ」　と言って立ち上る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ　斯くて――Ｓ＝大広間　殿様の御座へ、殿様がお座りになる。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それから二人は善コのお母さんが持って来た蓆の上に座りました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉ッコは呆れてぼんやりとむしろに座りました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年はさっと顔いろが青ざめ、たって一ぺんそっちへ行きそうにしましたが思いかえしてまた座りました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は二人とも、きっとお宮に帰って、きちんと座り、空の星めぐりの歌に合せて、一晩｜銀笛を吹くのです。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人はお宮にのぼり、向き合ってきちんと座り銀笛をとりあげました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そしてテーブルに座りたいもんだな。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉十は痛い足をそっと手で曲げて、苔の上にきちんと座りました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」子供が足を長くして車の上に座りながら云ひました。",
              "citation": {
                "source": "車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤シャツの農夫は炉のそばの土間に燕麦の稈を一束敷いて、その上に足を投げ出して座り、小さな手帳に何か書き込んでゐました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日須利耶さまは童子と食卓にお座りなさいました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "象はのそのそ鍛冶場へ行って、べたんと肢を折って座り、ふいごの代りに半日炭を吹いたのだ。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある晩、象は象小屋で、ふらふら倒れて地べたに座り、藁もたべずに、十一日の月を見て、「もう、さようなら、サンタマリア。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面を向いた富士は、平べッたくなって、塔形にすわりがいい。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後は来るたびごとに寝台にすわりこんで、この花の名を読まない事はなかった。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人の話であるが、百貨店の食堂へはいって食卓を見回し、だれかの食い残した皿が見つかると、そこへゆうゆうとすわり込んで、残肴をきれいに食ってしまって、そうして、ニコニコしながら帰って行くという人もあるそうである。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
