        "examples": {
          "standard": [
            {
              "text": "健康志向の人は、日常的に水素水を飲んでいることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "スポーツ選手の間で、疲労回復効果を期待して水素水を飲む習慣が広まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この水素水、どこで買ったの？」「近所のスーパーで見つけたんだ。最近よく見かけるようになったね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そして朝夕には過酸化水素水で、含嗽をした。",
              "citation": {
                "source": "マスク",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その水に硫化水素水を通してみると読者は真理は納得するのに困難を見つけないであろう―――70ページ参照。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫は感冒予防の嗽いをしろと云って、わざと度の強い過酸化水素水を拵えて、それで始終彼女に嗽いをさせていました。",
              "citation": {
                "source": "途上",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
