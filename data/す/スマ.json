    "definitions": [
      {
        "index": 1,
        "gloss": "mackerel tuna (Euthynnus affinis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
