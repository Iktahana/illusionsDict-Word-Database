        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すばしっこい火箸のような、痩せッこつの七五郎が、板の橋を渡って公会堂に様子をさぐりに、ぴょん／＼はねとんで行った。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのすばしっこい小さなハツカネズミたちが、ぼくのまわりにすわって、ぼくの話を聞いてくれたときは、ほんとに楽しかったなあ！",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで味方の兵士の中で、いちばん力の強い、そしていちばんすばしっこい者をいく人かお選びになって、「そちたちはあの皇子を受け取るときに、必ず母の后をもひきさらってかえれ。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、四つ足のすばしっこいやつだからな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "すばしっこいんでございますねえ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間、ここで地主のノズドゥリョフと知合いになったが、それは年のころ三十ぐらいの、すばしっこい元気者で、二言か三言、口をきいただけでもう、『君、君』と言うようになった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が、すばしっこいのを自慢にして口のきき方までが、ぞんざいになって来ました。",
              "citation": {
                "source": "やんちゃオートバイ",
                "author": "木内高音",
                "note": "青空文庫"
              }
            },
            {
              "text": "法印の奴、すばしっこいな」　闇太郎、殆ど、押ッ取り刀で、取りかこんで、睨め下ろしている若侍たちの中で、平気で腰をさぐって、莨入を取りだすと、「済まねえな。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すばしっこい目つきをして前に立ちはだかって居る男を見上げた。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにあいつがすばしっこいたって、忍術使いじゃあるまいし……」「いや、そうではない。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すばしっこいのは今にはじめぬことだが、かくまで澄まし返って、脂下っていられると癪です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははア、出たな、裏の方から出たな、出は出たが、今までの悠長さに引換えて、これはまた、すばしっこい飛び出し方だ、と呆れているうちに、その飛び出した大男が、河岸の舟の方へは来ないで、右手の小高い方へ一目散に何か抱えて駈け出して行く。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "すばしっこいやつじゃ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このひと、ちゃんと字引きひいて、云ったのに――」　つや子は、文法ばかりやかましくしつけられた尼僧女学校のフランス語で、洗濯という言葉や、やるという単語を四角四面にならべて、すばしっこいマダム・ルセールに、かえって、やるというひとことを、都合いいように解釈されてしまったらしかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうちょっと言わせてもらうと、オドラデクはめちゃくちゃすばしっこいやつなので、どうにもつかまえられなくて、だからそういうことをどうとも言えんのである。",
              "citation": {
                "source": "家のあるじとして気になること",
                "author": "DIE SORGE DES HAUSVATERS",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれよりはやく、このすばしっこい豪傑は、そばにあった礼拝堂にとびこんで、すぐまた上の窓からピョンとひととびでそとへとびだしました。",
              "citation": {
                "source": "いさましい　ちびの仕立屋さん",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猪之は頭のいいやつで、すばしっこいし手も口もまめで、半年と経たないうちに、大政のにんき者になり、猪之、猪之とみんなから可愛がられるようになりました」　彼は大政の中だけでなく、近所の人たちにも評判がよく、ふしぎと女の子に好かれた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "三度目の正直",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで言ってしまえば、当然このすばしっこい摺抜け者が、がんりきの百蔵という名代のやくざ野郎にほかならないことは、定連はみな感づいていないはずはないのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "農奴の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはまた、小さくてすばしっこい、黒いぶちのある赤黄いろいとかげまで好きでしたが、へびは気味がわるかった。",
              "citation": {
                "source": "百姓マレイ",
                "author": "フョードル・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう四階まで上って、おかみの部屋の戸口へさしかかったとき、ドアがごく細目にあいていて、すばしっこい二つの黒い目が、闇の中から二人をうかがっているのに気がついた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "芦田君は、腕力は私より弱かったが、妙にすばしっこいところがあった。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それまでは黒いだけなのね」「そうらしいね、黒いだけではなく、よく見ると点々があるんだけれどね」「あ、またあそこにいるわ、あそこにも、すばしっこいのね」「いいね」と彼はいった。",
              "citation": {
                "source": "おごそかな渇き",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、すばしっこいガンたちにはいつも負けてしまいました。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "身なりにも氣をつけるようになり、まもなくしやれた、すばしっこい若者だと評判されるようになった。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母の云うとおり、なにしろすばしっこいのと桁外れなことばかりするので、まわりの者のおちつく暇がなかった。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "躯つきは痩せて小さかったが、知恵のまわるのとすばしっこいことは無敵で、たいてい年上の子と暄曄をしても負けたことがない、――いつも着物はかぎ裂き、手足は泥んこ、どこかにひっ掻き傷か瘤をでかしていないことはなかった。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「狡猾と云ったものか、すばしっこいと云ったものかどうか」立原平助が云った。",
              "citation": {
                "source": "半之助祝言",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸助は菓子には、手を出さず、小さなすばしっこい眼で深喜の表情をうかがいながら「お豊さんが会いたがっている」と云った。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すばしっこいポケット小僧は、なにかうまいことをおもいついたらしく、目を光らせて、小林君の耳に、ヒソヒソと、ささやくのでした。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、このポケット君は、たいへんかしこくて、すばしっこいのです。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
