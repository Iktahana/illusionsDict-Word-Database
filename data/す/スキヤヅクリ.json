        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "御堂の裏、田圃の大金の、とある数寄屋造りの四畳半に、膳を並べて差向った折からで。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "表にはご番士のひとりがちゃんと待ち構えていて、城中からほど遠からぬ数寄屋造りの一構えに案内してくれましたものでしたから、まだ虚無僧姿のままの伝六の喜ぶこと、喜ぶこと――。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "小ぢんまりとした日本宿だと人にきいていたので、どんな処かと考えていたが、数寄屋造りとでも云うのだろう、古くて落ちついた宿だった。",
              "citation": {
                "source": "田舎がえり",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十　そこは数寄屋造りの別棟であった。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "六甲の御宅は、阪神沿線から大阪湾を一望に見下した、数寄屋造りの凝った家であった。",
              "citation": {
                "source": "湯川秀樹さんのこと",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「古月亭」は数寄屋造りで、よりつきが六帖、控えが四帖半、そこに猿戸があって三帖の茶席に続いていた。",
              "citation": {
                "source": "薊",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "露路ふうの、敷石みちが、植込のあいだをゆるやかに曲って、数寄屋造りの家の前へと、続いている。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋館は階上階下とも冷暖房装置にし、日本間のほうは数寄屋造り。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
