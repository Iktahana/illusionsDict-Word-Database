      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "store",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分に必要なものを選択して摂取し、不用なもの有害なものを拒否し排出するのが、人間のみならずあらゆる生物の本性だということは二千年前のストア哲学者が既に宣言していることである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう意味でデパートメントストアは一つの公園であり民衆の散歩場である。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは物の作用や性質やまでも物体視せんとするストア派の学者に対する手ごわい論難として書かれたものであるらしい。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもストア派に対する反対だそうである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の室はあまりに明るくあまりに楽に広々としているためにそこに陳列された書物が普通のデパートメントストアの商品のような感じがしないでもない。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは言わば細胞組織の百貨店であって、後年のデパートメントストアの予想であり胚芽のようなものであったが、結局はやはり小売り商の集団的｜蜂窩あるいは珊瑚礁のようなものであったから、今日のような対小売り商の問題は起こらなくても済んだであろう。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　上野のデパートメントストアの前を通ったら広小路側の舗道に幕を張り回して、中に人形が動いていた。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つの証拠にはどこのデパートメント・ストアーでもちゃんと書籍部というのが設けられている。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてデパートメントストアが各区域の商店街を寂れさせ、享楽機関が次第に膨脹するこの大都会の大衆を吸引することになるであろう。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一切の弱々しいもの、柔軟のもの、骨組みのぐにゃぐにゃしたもの、女らしく繊弱なものを跳ね飛ばすところの、男性的ストアの美を要求する。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼等自身は、厳格なるストア的法則による詩形を重んじ、自ら誇って「言語上のゴシック建築」と称していた。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの叙事詩的の精神は、彼の貴族的なる権力感情の発翔から、形式に於てどっしりしたもの、荘重典雅のもの、ストア的に厳格のもの、韻律の規則正しく、骨組のがっしりしたものを欲求することからして、必然にこの結婚が生れるのである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等のそこに求めるものは、ストア的律格の厳正さと、がっしりした韻律の骨組と、そしてあらゆる意志的な抑制とから、すべての生ぬるい主観を圧し、センチメンタルな情緒を殺し、それの痛烈から逆に飛躍しようとする意欲である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は家にあつてはストア學派の禁慾主義者以上の嚴格を保つてゐるので、朝寢だけには例外のづぼらがあつても、そツと構はないで置かれるのが常だ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "――最も名高い二人のストア哲学者は奴隷のエピクテータスと高貴なるローマ皇帝マーカス・オーレリアスでした――斯ういふ風な調子で僕には読み易かつた。",
              "citation": {
                "source": "日記より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎はあるデパートメントストアーへ出ているという夫婦暮らしの家へ、次郎は少し遠方のあるおやしきへ、赤はひとり住みの御隠居さんの所へ、最後におさるは近い電車通りの氷屋へそれぞれ片付いて行った。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "検索エンジンであたってみると、原子爆弾に関連するページがたくさんリストアップされます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったん世界のコンピューターとのリンクを体験した後では、紙の本と同様にせいぜい参考文献をリストアップするくらいしかないこの面での力不足が、浮き上がって見えてきたのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "山間でのストア派的生活のおかげであらう。",
              "citation": {
                "source": "途上日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと彼はトラツク競技の選手だつたゞけに多くの軽業に長けてゐたのは好かつたが、そいつが何うも私達の村のストア生活に於て余りに役立ち過ぎてしまつたのがそも／＼の御難と化した。",
              "citation": {
                "source": "三田に来て",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、面白く、浮れて、やはりその創作の中に現れる酒の名前を叫び、エピキュール学徒と、ストア学徒の声色をつかつて、浮れ抜いた。",
              "citation": {
                "source": "ファティアの花鬘",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、私の倅をストア大学に入れたくありません。",
              "citation": {
                "source": "ファティアの花鬘",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "宜なる哉、ストア尊者のオレリウスは僅かばかりの愁ひの面持で呟いだ。",
              "citation": {
                "source": "凩日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日ニヨリマストアタリノ山々ガ浮キアガッタカト思ワレルクライ空ガ美シイ時ガアリマス。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて漁師町をつきぬけて、この市街では目ぬきな町筋に出ると、冬じゅうあき屋になっていた西洋風の二階建ての雨戸が繰りあけられて、札幌のある大きなデパートメント・ストアの臨時出店が開かれようとしている。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく歩いて例のデパートメント・ストアの出店の角近くに来ると、一人の男の子がスケート下駄（下駄の底にスケートの歯をすげたもの）をはいて、でこぼこに凍った道の上をがりがりと音をさせながら走って来た。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "デパートメント・ストアのある本通りに出ると打って変わってにぎやかだった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きまりきった店のほかは滅多に行かないので、彼等がデパートメントストアを田舎者の店と云うのはこの理由である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも自分ばかりでなく、まわりに大黒様だの何だの彼だのと、数十の神仏に元手要らずのデパートメントストアを出させて、何百年間大繁昌をして御座るのだから恐ろしい。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
