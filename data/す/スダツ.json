    "definitions": [
      {
        "index": 1,
        "gloss": "to leave the nest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "未だ学※を巣立つたばかりの若い私たちですわ。",
              "citation": {
                "source": "〔婦人手紙範例文〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ巣立つたばかりですから……。",
              "citation": {
                "source": "犬",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、學生である彼等はやがて職業人としてそれぞれ社會へ巣立つて行く。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、農業大學では博士たちが、米の栽培について浩瀚な著述をなし、弟子たちは技術者として年々社會へ巣立つて行き、それぞれに農業の實際部門の指導者である。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "安藤や峯岸が、さふいふ確固たる信念を持つて、社會に巣立つて行かうとしてゐるのだとは思へない。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "・死期、死処・残生、余命・巣立つ鳥　老いぼれ鳥八月廿六日　晴。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "由起しげ子のヒューマニズムは、自分で自分のヒューマニティーを劬りつづけて来た生活習慣から、早く強壮に巣立つ必要にせまられている。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕の子が、いつのまにやら巣立つてゐる、それらしいのがをり／＼軒端近く来ては囀づる。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も俳優が、全然違つた方面から巣立つたらば知らないことだが――だが、それほどの人材ばかり出たら、傀儡となつて叫び狂ふ自己の職業に滿足するかどうか？",
              "citation": {
                "source": "むぐらの吐息",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷馬車曳きの父は仕事も出来ない程老いてゐたし、弟妹達はみなそれぞれ巣立つてはゐたが、里子の送つて来る仕送りを当てにして、親達に対しては何一つ報いてやる気もないものばかりにそだつてしまつた。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカハラだつて好いわと彼女は、自分の見つけた鳥の巣の中から漸く巣立つて行かうとしてゐるその小鳥たちを何としても可愛がつてやりたかつた。",
              "citation": {
                "source": "巣立ち",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、それは何んと巣立つたばかりらしいアカハラの雛鳥だつた！",
              "citation": {
                "source": "巣立ち",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうね……」彼女はちらつと彼の手の中のアカハラを見たとき、こりあひよつとするとあの彼等の見つけた巣から巣立つた一羽かも知れないと思つた。",
              "citation": {
                "source": "巣立ち",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すだつは、巣に聯想が向いた為に、巣立つと説いて、主として鳥を聯想するやうになつたが、語根 stu である事を考へれば、すだつ・そだつは同じものであると見ていゝ。",
              "citation": {
                "source": "霊魂の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "巣立つた鴉のやうに、古巣を離れてどこへでも飛び去つてはいけないのか？",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "雛は夏のうちに巣立つて、今は空つぽになつて居る樣子が、下から見ても、葉隱れによくわかります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "凧糸の謎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は三高文芸部の人達が三高を巣立つて、この東京の三高に於て、自分達の青春を生かし切ることを切望する。",
              "citation": {
                "source": "思ひ出づるまゝに",
                "author": "淀野隆三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、世に巣立つ幾羽のうちには、悲運に終る子鳥もある。",
              "citation": {
                "source": "剣の四君子",
                "author": "柳生石舟斎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとうさんはお酒の配給券を配りにいつてるすだつた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親も病人も氣の毒がつてるやうすだつたが、お芳はそのかはりにほしいと思つてゐた「一葉全集」や、その頃評判だつた「その面影」のやうなものを買つて貰つた。",
              "citation": {
                "source": "四十餘日",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、二人の男の前に対座して妙に窮屈そうなようすだつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に今日、さだ子の首をしめたのが林田と判つていてすら警部は未だ信じ切れぬようすだつたじやないか」「それじや娘に警告するという方は？",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつ・すつ・すだつ・そだつ話が多少複雑になつて来たので、こゝらで単純に戻したいと思ふ。",
              "citation": {
                "source": "霊魂の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつ・すつ・すだつ・そだつは、何れもたまの出入に就いて言うた語である。",
              "citation": {
                "source": "霊魂の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すだつ・そだつは其の代表的な言葉だと見られよう。",
              "citation": {
                "source": "霊魂の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "このこんたすだつて此方から見せてやつた事があるわ。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死",
                "note": "青空文庫"
              }
            }
          ]
        }
