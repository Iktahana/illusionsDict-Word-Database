    "definitions": [
      {
        "index": 1,
        "gloss": "to cool oneself",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "うつくしき人の、葉柳の蓑着たる忍姿を、落人かと見れば、豈知らんや、熱き情思を隱顯と螢に涼む。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、いづれも、涼むために立ち停るのではない。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼むんならこういうときじゃないか。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでゆっくり涼むがいいや！",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく久しぶりで気保養しようと思ってやって来たのに、ろくろく涼むこともできゃしねえや。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼むがいいやッ」　ダッと急所の胸当てを一本。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は應擧の畫を見て囘るよりも、庭から好い風の通つてくるところで涼む方が先だつた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "晝より暑いくらゐで、夜遲く石垣の下に出て、そこに繋いである舟に乘りながら涼むものもあつた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで上等の珈琲を飲み、香の高い紙巻烟草を燻らせながら、噴水の音を聞いて涼むことが出来る。",
              "citation": {
                "source": "不可説",
                "author": "UNERKLARLICHT!",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには紫川の東の川口で、旭町という遊廓の裏手になっている、お台場の址が涼むには一番好いと極めて、材木の積んであるのに腰を掛けて、夕凪の蒸暑い盛を過すことにした。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり暑いので、母と夜更けの浜へ涼みに行き、多度津通いの大阪商船の発着所の、石段のところで暫く涼む。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸電気の下で、母と私ははだかになって涼む。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう日は、裸で涼むような、時候でもねえんだし……」「サア、そりゃ、どうとも分らんよ」　その若い巡査は、雨沫を浴びて、黙然と腕組みをしている。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども低い木立は、涼むに足るような蔭をつくっていなかった。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば貴人の馬車、富豪の自動車の地響に午睡の夢を驚かさるゝ恐れなく、夏の夕は格子戸の外に裸体で涼む自由があり、冬の夜は置炬燵に隣家の三味線を聞く面白さがある。",
              "citation": {
                "source": "両国界隈",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか、奥さんが涼むから、おれも涼まなきゃあいやだという訳でもありますまい。",
              "citation": {
                "source": "午市",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スイスに来て時計を買うのも少々月並すぎる話だが、モン・ブランやユングフラウに登って涼むのも、時計屋をひやかすのも、大した変りはないと思ったので、二人は互に第一流の時計屋らしいのを物色して、何か変った時計があったら――ふところと相談しておみやげに買って帰るつもりであった。",
              "citation": {
                "source": "汝自身を知れ",
                "author": "ベルンにて",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋へ帰り、涼むとすぐ蠅たゝきでピシャリ／＼蠅をとる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉本の林弘高と樋口・エンタツで柳ばしへ行き、モーター和船を出して涼む、河風に涼みて二時すぎまで。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらマホガニ色にやけることにはなれても、すずむだけはすずまずにはいられません。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
