        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おせいは水月に切りこむようにこみ上げてくる痛みを、帯の間に手をさしこんでじっと押えた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年冬、建文帝｜永慶寺に宿して詩を題して曰く、杖錫　来り遊びて　歳月深し、山雲　水月　閑吟に傍ふ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月八日の灌仏会の日がきて、阿宝が水月寺へ参詣するということを聞いて、朝早く往って道中で待っていた。",
              "citation": {
                "source": "阿宝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手を丹田に右手を上向きにつきあげた揚心流水月当身の構え！",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　怒りを発した広太郎、柳生の極意、九ヶ必勝、大のしにのすと水月を越し、こぶしさがりに斬り込んだ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "△水月山円通寺跡、大智禅師墓碑、そしてキリシタン墓碑、コレジヨ（キリシタン学校）跡もある。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸田露伴校閲としてある岩波文庫本の李太白詩選を見ると、越女詞五首の第五を、鏡湖水如月　　　　鏡湖、水月の如し、耶溪女如雪　　　　耶渓、女雪の如し。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇甫冉、秋夜会稽の厳維の宅に宿すの詩に云ふ、秋深臨水月、夜半隔山鐘と。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヤレ坊様……あぶない……」　と抱き止めにかかる厩｜仲間を、「エイッ……」　と一と当て、十三四とは思えぬ拳の冴えに水月を詰められて、屈強の仲間がウムムと尻餅を突いた。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大般若転読をする勤行に争ひて降る山の雨かな　十二年五月雨頃奥山方広寺に暫く滞留して水月道場の気分に浸られた折の作。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に心に間を止めず間に心を止めずよく水月の本心と云う也。",
              "citation": {
                "source": "巌流島",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は或日、砂地の影へ身を潜めて水月のやうに音もなく鎔け入るであらう。",
              "citation": {
                "source": "メランコリア",
                "author": "三富朽葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "平馬を、水月に一本入れて、その場に絶気させた雪之丞が、稲塚の方へ突進して行ったときには、もう三町も先きを、黒い影が、風のように、煙のように駆け去っているのだった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だろう、あの本は」「伊賀の水月さ」と碌さんは、躊躇なく答えた。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊賀の水月た何だい」「伊賀の水月を知らないのかい」「知らない。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊賀の水月は読んだが、ディッキンスは読まない」「それだからなお貧民に同情が薄いんだ。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂理想派と雖も、豈徒らに鏡花水月をのみ画く者ならんや、心中の事実、皎として明なる者を写すに過ぎざるのみ、然らば即ち是も亦写実派なり。",
              "citation": {
                "source": "詩人論",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざと水月はさけてくれたのだそうだが、存八の全身が一時にしびれて破裂したかに思ったのである。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "水月寺の尼僧達が盂蘭盆会を行ったので、その日はそれに参詣する女が四方から集まって来た。",
              "citation": {
                "source": "封三娘",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰る時二人は水月寺で待ちあわす約束をした。",
              "citation": {
                "source": "封三娘",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "母というのは、どういうひとですか」「東京女子大を出た才媛で、会社のデパートやクラブで働いている女子職員の監督でしたが、その後軍の嘱託になって、「水月」という将校慰安所を一人で切りまわしていました。",
              "citation": {
                "source": "母子像",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ指頭に挾んだら隠れる位の小さな薄さで、また水月のような柔かさを具えていた。",
              "citation": {
                "source": "掠奪せられたる男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその指先がふと、水月のような耳垂を挾んだ時、山田ははっと胸に大きな衝動を感じた。",
              "citation": {
                "source": "掠奪せられたる男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇津谷峠の雨宿りに、癪で苦しむ旅人の鳩尾と水月へ鍼を打ち、五十両という金を奪って逃げるという筋。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "三人目",
                "note": "青空文庫"
              }
            },
            {
              "text": "あがりぎわに一枚引きめくって来た艫の板をぶらさげて、泰軒は半眼をうっとりと眠ってでもいるよう……自源流水月の相。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "自源流奥ゆるし水月のかまえ……。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "まん中のひらきに突っ立った泰軒、やはり貧乏徳利を左手に右に左馬之介から奪った彼の一刀をぶらりとさげて、夢かうつつの半眼は例によって自源流水月の相……。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そばの一人を蹴倒しながら、長伸、軍之助を襲うと見せかけ、隙に乗じて泰軒、ついに壁を背にして仁王立ち……再び、刀をさげ体を直に、なかばとじた眼もうっとりと、虚脱平静、半夜深淵をのぞむがごとき自源流水月の構剣……。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
