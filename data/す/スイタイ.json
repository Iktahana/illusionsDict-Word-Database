    "definitions": [
      {
        "index": 1,
        "gloss": "weakened condition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "本来俺たち人間は、煙草もすいたいんだ。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の光を見、いい空気をすいたい。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一本、あなたにあげましょうかね」「じゃ、もらおう」　宮川は、煙草をすいたい慾望を制しきれなくて、手を出した。",
              "citation": {
                "source": "脳の中の麗人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "きゅうくつなトランクから飛びだして、おもうぞんぶん手足をのばし、深く息をすいたい。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「タバコがすいたいんだ。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「フフン、タバコがすいたいから、なわをとけというのか。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪者のほうでは、明智がほんとうにタバコがすいたいのだと思って、べつにうたがいもせず、それをくわえさせて火をつけてやりました。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
