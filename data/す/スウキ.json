[
  {
    "uuid": "4080cc5b-3cd7-5046-9226-f3592c019456",
    "entry": "数奇",
    "reading": {
      "primary": "すうき",
      "alternatives": [
        "さっき"
      ],
      "is_heteronym": false
    },
    "grammar": {
