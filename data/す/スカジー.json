          "standard": [
            {
              "text": "古いハードディスクを接続するために、スカジーのインターフェースカードを探している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつてのサーバー環境では、高速なデータ転送を実現するためにスカジーが主流だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このコネクタ、スカジーだよね？」と、懐かしそうに古い機材を眺める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "見当のつかないまま伸子は、「スカジーチェ（おきかせなさい）」と云って、両方の手を、半身おきあがっているかけものの上においた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
