    "definitions": [
      {
        "index": 1,
        "gloss": "fishing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ヘルンが学校に行ってる間、夫人は暇を盗んで熱心に読書をし、手の及ぶ限り、日本の古い伝説や怪談の本を漁りよんだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅き汀に簾様のもの立て廻せるは漁りの業なるべし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（荷繩を投げよはや荷繩）雉子鳴くなりその雉子、　　人なき家の暁を、歩み漁りて叫ぶらし。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一体誰がはじめにそんなものを欲しいと云い出したんだ」と人びとが思う時分には、尾羽打ち枯らしたいろいろな鳥が雀に混って餌を漁りに来た。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "掃溜も毎日のように漁りますが、何と申しましても縁談の取持が一番、収入が多う御座います。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事と言うては元手要らずの掃溜漁り。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう状態で彼は友に招かれたり、また伴れに誘われたりして備後から播州の寺々を漁り歩いた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるほどに得三は高田とともに家内に入り、下枝は居らずや見えざるかと、あらゆる部屋を漁り来て、北の台の座敷牢を念のため開き見れば、射込む洋燈の光の下に白く蠢くもののあるにぞ、近寄り見れば果せるかな、下枝はここにぞ発見されたる。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この黒壁には、夏候一｜疋の蚊もなしと誇るまでに、蝦蟇の多き処なるが、乞食僧は巧にこれを漁りて引裂き啖うに、約ね一夕十数疋を以て足れりとせり。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都の市中や近郊で催されるそれを漁り尋ね見物して来るのだった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらの河原には近所の子供の一群がすでに漁り騒いでいる。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "器用な彼はそれでも少しの間に一握りほどの雑魚を漁り得る。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の事情は語らない母親も「お罪障消滅のため寺方に上った身が、食べ慾ぐらい断ち切れんで、ほんまに済まんと思うが、やっぱりお罪障の残りがあるかして、こればかりはしようもない」この述懐だけは亦ときどき口に洩しながら、最小限度のつもりにしろ、食べもの漁りはやめなかった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は美味な食物を漁りに立上ってしまった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく家へは帰らないが、拓本職人の親方の老人は相変らず、小学校の運動会を漁り歩き遊戯をする児童たちのいたいけな姿に老いの迫るを忘れようと努めているであろうか。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった一つこれだけは漁り続けて来たつもりの食味すら、それに纏る世俗の諸事情の方が多くて自分を意外の方向へ押流し、使い廻す挺にでもなっているような気がする。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども青年はもっと散歩の興味を続け、又は、より以上の興味を求め度いらしく、ズボンのポケットへ突込んだ両手で上着をぐっとこね上げ、粗暴で悠々した態度で、街を漁り進んだ。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には古雛を買ひ集めてみたり、時には筆矢立を漁り歩いたり、奇抜だつたのは昔の千両箱の蒐集であつた。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しなやかな指さきで芍薬の蕾の群れを分け、なかで咲き切つた花の茎を漁り、それを撮まうとしながら少女は言つた。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その軒提燈と同じ赤い提燈をゆらめかして、鮎漁りの扁長い船が鼓を鳴らして瀬を上下してゐた。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」また、商人は倉庫に満す物貨を集め、長老は貴重な古い葡萄酒を漁り、公達は緑したたる森のぐるりに早速縄を張り廻らし、そこを己れの楽しい狩猟と逢引の場所とした。",
              "citation": {
                "source": "心の王者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一株の萩を、五、六羽で、ゆさゆさ揺って、盛の時は花もこぼさず、嘴で銜えたり、尾で跳ねたり、横顔で覗いたり、かくして、裏おもて、虫を漁りつつ、滑稽けてはずんで、ストンと落ちるかとすると、羽をひらひらと宙へ踊って、小枝の尖へひょいと乗る。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……古本｜漁りに留守の様子は知ってるけれど、鉄壺眼が光っては、と跼むわ、首を伸ばすわで、幸いあいてる腰窓から窺って、大丈夫。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が道具類の好きなことは前にちょっと申しましたが、ほとんど毎日、古道具屋｜漁りをして我羅苦多ものを買って来まして、何とか勿体をつけて飾り立てます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝまで一筋に落付き払って運んで来た夫婦乞食は、漁師が定めの漁場に来たように、歩調を緩めると、いくらかずつ右へ左へと漁り歩きをし出します。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁師たちは手網や手掴みで四斗｜樽に一ぱい半ほどの魚を漁り、網を外ずして去りました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは人知れず古謡と古曲を漁り、これを現代の好みに向けて再生産した。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "化物丁場すなどりびとのかたちして、　　つるはしふるふ山かげの、化物丁場しみじみと、　　水湧きいでて春寒き。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなどりびとはまづしくて、むなしく水になげかひぬ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "海士もし知らばいかならむ、すなどりすべく來つる朝、網に死屍を引き揚げて、臂もわななく物怖れ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
