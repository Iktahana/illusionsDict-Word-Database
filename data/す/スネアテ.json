          "literary": [
            {
              "text": "……籠手すね当てのかずを調べ、野郎どもに渡して置け。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "稽古着に剣道用の胴、草ずりをつけ、大刀を差し、うしろ鉢巻、もも引きにすね当て草鞋ばきで、万事小具足仕立てだが、もともと士ではないらしい。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "稽古着に剣道用の胴、草ずりをつけ、大刀を差し、後ろ鉢巻、もも引にすね当て草鞋ばきで、万事小具足仕立てだが、元々士ではないらしい。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがネ、斯う、込み入る敵の兵卒を投げたり倒したりあしらひながら、小手すねあてをつけて、鎧を颯と投げかける。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "手には小手、脚にはすねあてをしているわ……大森彦七じゃ。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも辛抱すると、女はいろいろいたわってくれたが、十日ばかりして、笞のあとがすっかり回復したころ、ある夜、女は男に水干袴と立派な弓、やなぐい、すねあて、わらぐつなどを与えて、装束させてからいった。",
              "citation": {
                "source": "女強盗",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物人は拍手喝采した、すねあてとプロテクターをつけた肩幅の広い小原は、マスクをわきにはさみ、ミットをさげて先頭に立った、それにつづいて眉目秀麗の柳光一、敏捷らしい手塚、その他が一糸みだれずしずかに歩を運んでくる。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄はさび、糸はボロボロになった、きたないよろいですが、すねあても、ちゃんとそろっていて、人間が着て立っているように、かざってあるのです。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
