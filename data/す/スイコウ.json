    "definitions": [
      {
        "index": 1,
        "gloss": "hydroponics",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "水耕法と稱して、純粹の水に植物の養分となるべきアムモニヤとか燐酸、加里、石灰などを適量に溶解し植物を浸して置くと能く生育するが、一つでも養分が不足すれば直ちに發育は停止し、或は枯死する。",
              "citation": {
                "source": "ヴィタミン研究の回顧",
                "author": "鈴木梅太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "進駐軍の野菜の大規模水耕栽培がこの頃もの珍しく報道されている。",
              "citation": {
                "source": "稲の一日",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし巧く稲をだますことが出来たら、第二段として大規模水耕法の問題が出て来るわけである。",
              "citation": {
                "source": "稲の一日",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
