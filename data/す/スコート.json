    "definitions": [
      {
        "index": 1,
        "gloss": "short skirt for playing tennis, etc.",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "海原、離宮、車輛、工場のテニスコート、僕が彼女の乳房のあたりを見つめているうちに、八時四十分、大阪着。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "午后はみんなでテニスコートを直したりした。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ほどの処の地続きは平にならされてテニスコートになっている。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下がテニスコートの平地になっている。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動場もテニスコートのくらいでしたが、すぐうしろは栗の木のあるきれいな草の山でしたし、運動場のすみにはごぼごぼつめたい水を噴く岩穴もあったのです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校といっても入口とあとはガラス窓の三つついた教室がひとつあるきりでほかには溜りも教員室もなく運動場はテニスコートのくらいでした。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "式場は、教会の広庭に、大きな曲馬用の天幕を張って、テニスコートなどもそのまま中に取り込んでいたようでした。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その左手の草原の尽きる処に、青白く一直線に横たわっているのはテニスコートであろう。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは眼の前に重なり合った草の茎の隙間から見るテニスコートの白い一直線の上を、ソロソロと後しざりして来る薄茶色のセイラアパンツであった。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「テニスコートがあって、看護婦さんとあそんで、ゆっくり御静養できますわよ。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と鍵の束持てるポマアドの悪臭たかき一看守に背押されて、昨夜あこがれ見しテニスコートに降り立ちぬ。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "加奈子は何となしの悲哀に薄く涙のにじんだ眼で眺めて、崖の上のテニスコートに落ちる帰朝後四日目の太陽を惜んだ。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち二人はテニスコートを抜け、丘の青木の間を鉄条網の壊れを探して、その上の桑畑へ出た。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちが玄関の戸口に乗りつけると、その前面は、テニスコートの横であったが、黒い戸の建物と、台の上に乗っている日時計が目に止まった。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々こっそり、裏のテニスコートなどに降りてみる事はあっても、正々堂々の外出の許可を得たのは、僕がここへ来てからはじめての事であった。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と大声で言って、「テニスコートで、お江戸日本橋を歌っていらっしゃったのは、どなたです。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は眼を大きく※って、洗面所の窓からテニスコートの黄ばみはじめた銀杏を黙って眺めていた。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と僕と並んで洗面所の窓からテニスコートのほうを眺めながら、ひとり言のように、「ひばりが来てから、道場も変っちゃったなあ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このキャンパスは、そこらじゅうアップダウンばかりで、平らな地面というのはグラウンドと野球場、そして舗装されたテニスコートや、バスケットコートなど、数えるほどしかない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに、左端のテニスコートから、畑のある段丘、寮、工事中の新寮、校舎の屋上をなめた寮わきの低い山へ、というパーンが十二秒。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう日なら、テニスコートの上の、この芝生の小山は最高だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いんじゃねえの、ベースなんだから、なんでも」　服部は枯れ芝をつまんで、下のテニスコートにむかって放り投げた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "外泊のときは、さすがの高志も、兄らしく令子をエスコートして帰り、いっしょに寮にもどってくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "寮のまえで終わりにして、テニスコートでもつくればいいだろう」　改めてそういわれると、たしかにあの道は盲腸だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐにテニスコートの上にたどりついたが、コートへの急な斜面は、令子にはおりられない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "東棟は利用できません）　　生徒寮玄関棟（生徒サロン、テラス、食堂）　　プール（四日一〇時より一五時まで）　　テニスコート（照明設備は利用できません）　　グラウンド（ただし、道路側の半分は駐車場となっています）　女子寮は一号棟、二号棟とも、現在は校舎として使われています。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家は只今でも昔の形のままの杉の垣根に囲まれて、十七銀行のテニスコートの横に地蔵様と並んでおりますから、どなたでもお出でになればすぐにわかります。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "テニスコートの線があきらかに残っていて、宿直室の長い縁側の隅にラケットやボールや網が置いてあるのが見える。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あきる時を知らない様に千世子は自分の手足とチラッと見える鼻柱が大変白く見えるのを嬉しい様に思いながらテニスコートの黒土の上を歩きまわった。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水野は学問は出来ないが、あれでラケットを持ってテニスコートに立つと威厳が付いて見えるね。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
