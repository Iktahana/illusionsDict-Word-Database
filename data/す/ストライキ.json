    "definitions": [
      {
        "index": 1,
        "gloss": "strike (i.e. industrial action)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――滅茶苦茶に手前等は儲けやがって、俺たちを搾りやがるから、いずれストライキだよ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、電鈴が私の耳に亀甲町にある、綿花綿布倉庫会社の事業停止による賃金不払のため、従業員のストライキを報らせた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは何んのためのストライキだ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでストライキをやる。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年の、川崎造船所のストライキに対して、歩兵第三十九聯隊が出動した。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その武器を、ストライキをやった同志や親爺や兄弟達にさしむけるのではなくブルジョアジーにさしむけてやるのだ。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、内地じゃ組合が出来たり、ストライキをやったりして労働者が、そうむちゃくちゃに、ひどい条件でこき使われて黙っちゃいなくなっていますよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "農民の暴動や大ストライキに××が出動するのは、それを裏書きする一つの証拠である。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍ――鉱業株式会社のＯ鉱山にもストライキが勃発した。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつだったか、印刷工がストライキをやって東京じゅうの新聞が休んだ事があった。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "野球は其樣な災難が無いから、毎日／＼盛んなものだ、丁度海岸の家から一｜町程離れて、不思議な程平坦な芝原の「ゲラウンド」があるので、其處で「アウト」「ストライキ」の聲は夕暮の空に響いて、審判者の上衣の一人黒いのも目立つて見える。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おとなりのマメリューク・スルタンの国でパルチザン共がストライキを起こして暴れるので鎮めに行ったのさ」「よけいなことじゃなくって？",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、そうすると我々神聖義勇軍たるものは最初から、他人のストライキつぶしと、そんな映画会社の金儲けのために、だしに使われていたのも同然なんだ。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストライキ、ストライキ、と聲高くさけぶ生徒もあつた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし私一個人のためを思つてストライキをするのだつたら、よして呉れ、私はあの教師を憎んでゐない、事件は簡單なのだ、簡單なのだ、と生徒たちに頼みまはつた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日、その教師が私たちにあやまつて、結局ストライキは起らなかつたし、友人たちともわけなく仲直り出來たけれど、この災難は私を暗くした。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ君は、ただちに同志を糾合して、ストライキを計った。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストライキになりかけたとき、その教師が、私たちの教室にこっそりやって来て、どもりながら陳謝した。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストライキは、とりやめとなった。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンスホールとストライキ。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実兄は、ぼくを中学の寄宿舎に置くと、一家を連れて上京、自分は××組合の書記長になり、学校にストライキを起しくびになり、お袋達が鎌倉に逃げかえった後も、豚箱から、インテリに活動しました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "島に上つて腹一杯芋を喰つたら、船中の憤懣もハンガー・ストライキも凡て忘れて了つて、たゞ少年らしく人々の眞似をして見たくなつたのだらうか。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "島に上って腹一杯芋を喰ったら、船中の憤懣もハンガー・ストライキも凡て忘れてしまって、ただ少年らしく人々の真似をして見たくなったのだろうか。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚市場の若い連中が何かの原因でストライキを起して、幹部連中が持てあましている場面でも湊屋仁三郎が出て行くと一ペンに大笑いになって片付いた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "太平洋からまともにはげしい潮風の吹きつけるある南国の中学にレコードをとどめた有名なストライキのあらしのあった末に英国仕込みでしかも豪傑はだの新しい校長が卒業したての新学士の新職員五六人を従えて赴任すると同時にかび臭いこの田舎の中学に急に新しい文化の風が吹き込んで来た。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　炭坑にはストライキが始まっていた。",
              "citation": {
                "source": "狂馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何処からかストライキ全盛時代に買入れたドスを一本持出して来ると、そいつの鐺でドンと床を突きながら、「じゃ、殿軍を頼みますよ」　云い残して、ひどく悲壮な調子で出掛けて行った。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年電車のストライキのあつた時、あれは何とか云つたつけな、妙な俳句の樣なものを書いてよこしたぢやないか。",
              "citation": {
                "source": "ハガキ運動",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或學校で學生間に教頭排斥が起つて、既にストライキをやらうとしたのだが、ストライキでは犧牲を出す恐れがあると云ふので、ハガキ運動といふ事を誰かゞ思ひついて、有志の學生は毎日一｜枚づつ教頭に宛てゝ辭職勸告の葉書を出さうと云ふ事に申し合せた。",
              "citation": {
                "source": "ハガキ運動",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
