[
  {
    "uuid": "e486f901-f69a-52b6-875d-bede6759b481",
    "entry": "水馬",
    "reading": {
      "primary": "すいば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "crossing water with a horse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「水馬演習でしょう。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢の奥の行きづまりには崩れかかったプールの廃墟に水馬がニンプの舞踊を踊っている。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「水馬演習でせう。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小母さん頂戴な」「其蟲頂戴な」と聞くうちに、蟲は、美しい羽も擴げず、靜かに、鷹揚に、そして輕く縱に姿を捌いて、水馬が細波を駈る如く、ツツツと涼傘を、上へ梭投げに衝くと思ふと、パツと外へそれて飛ぶ。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足腰が、水馬の刎ねるように、ツイツイツイと刎ねるように坂くだりに行く。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "汀には木の葉の滴りが水に大きな輪を描いて水馬が小さな輪を描いて居る。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉分の光はだらに、白き菱の花さして、樹暗もあからむ眞夏日なか、水馬うかべる水隱れ、藻伏小鮒とらへ來て、朱脛やすらふ柳瑞枝、したり顏の若音には、葉守の神さへ醉に入らむ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちる形の見えぬ程小さく降りそゝぐ時には、水の面は水馬かなぞでもゐるやうに、じわ／″＼と筋が入る。",
              "citation": {
                "source": "女の子",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しく打ち絶えていた水馬の競技が、何年かぶりにまた催されることになって、平七もその催しに馳せ加わった。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "水練は言うまでもないこと、早駈け、水馬、ともに、人におくれをとったことのない平七なのである。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗本の中堅ともなるべき若者たちが、婦女子の目をよろこばす以外に、なんの能もないような水馬の遊戯なぞに、うつつをぬかしているから、江戸勢はどこの戦いでも負けるのだ。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "立っていたのは、同じ番町で屋敷を隣り合わせて、水馬のときにも同じ二組で轡を並べて、旗本｜柔弱なりと一緒に叱られた仲間の柘植新兵衛だった。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏はまた唖の水馬、水面にただ彈くのみ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮ぶものゝ影があるならば花の一輪であらうとも、眼にとまる澄明さであるが、私の眼をさへぎる水馬の影さへ見へぬ眺めであつた。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "また東風　菫　蝶　虻　蜂　孑孑　蝸牛　水馬　※虫　蜘子　蚤　蚊　撫子　扇　燈籠　草花　火鉢　炬燵　足袋　冬の蠅　埋火　等はその繊細なる者なり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "弔瓶と石畳との間を忙しげに水馬が走っている。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あばれだすかと思っていた泰文は、意外に素直に勅を受け、二十騎ばかりの伴を連れて宇治の平等院でひとしきり水馬をやったうえ、一糸纏わぬすッ裸で裸馬に乗り、京の大路小路を練りまわしたうえ、悠然と敦賀へ下って行った。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪川から、灌漑用に引かれている堰の縁には、菫や、紫雲英や、碇草やが、精巧な織り物を展べたように咲いてい、水面には、水馬が、小皺のような波紋を作って泳いでい、底の泥には、泥鰌の這った痕が、柔らかい紐のように付いていた。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あばれだすかと案じられた泰文は、意外にも素直に勅を受け、二十騎ばかりの伴を連れて加茂川でひとしきり水馬をやってから、一糸纒わぬすッ裸で裸馬に乗り、京の大路小路を練りまわしたうえ、悠然と敦賀へ下って行った。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "水馬の術などは、その馬の性状を生かすのが主意で、重い鎧を着けた人間が、馬に泳がして貰ふ術といつても宜い――まして音無瀬と言はれた名馬が、橋から落ちたくらゐのことで容易に死ぬ筈はない」「すると」「待つてくれ――平次、落ちるにしても人を乘せた馬が仰向きになるのはをかしい。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "邪戀の償ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の中には何時も茶碗のかけ飯粒菜葉などが落っこちて小魚や水馬が群って居る。",
              "citation": {
                "source": "漁師の娘",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しんとした水の上に、すういすういと走る水馬が、水流を曳いて辷っているだけだった。",
              "citation": {
                "source": "蛾",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "松風に騒ぎとぶなり水馬昭和二年七月なつかしきあやめの水の行方かなよりそひて静なるかなかきつばた昭和二年七月大夕立来るらし由布のかきくもり昭和二年七月　大毎、東日委嘱により別府に至る、日本八景の一に当選したる別府の記事を書く為。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚鼈居る水を踏まへて水馬昭和十年七月十一日　七宝会。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケンジントンからマンションハウスにかけて給水馬車が一台も見られない。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは水馬歯を刻んで、それへ該里の酒を滴らせる。",
              "citation": {
                "source": "雪",
                "author": "高祖保",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しめた」　景季は、巧みに、水馬の技術をこらして、楽々と馬を泳がせながら、後ろの岸をふりかえった。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "畠山庄司重忠は、自分の功名は捨てて義経のそばへ、ひたと駒をよせ、義経の司令と共に、声を援けて、渡河中の全軍へ、始終、水馬戦の注意をさけんでいた。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一兵でも惜しむように、溺れる者や、矢に斃れ去る者を、眼に傷みながら、なお声をふりしぼって、水馬に馴れない兵たちに教えた。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬれるのはすぎなやすいば、ひのきの髪は延び過ぎました。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
