          "literary": [
            {
              "text": "ぬれるのはすぎなやすいば、ひのきの髪は延び過ぎました。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本植物圖鑑ではすいばと云ふのが普通の名稱として認められてゐる。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の拡げた風呂敷の中には、ひずるやたんぽぽや、すいばのようなものまで這入っている。",
              "citation": {
                "source": "魚の序文",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この国では、ひすいばかりでない。",
              "citation": {
                "source": "ひすいを愛された妃",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "子どもらはいつも野に出て、茅花をたべ、いたどりをたべ、すいばをかじった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
