              "text": "悦ちゃんを御馳走してゐた、ポタアジュ、スクラムブルドエグ・ベーコン、ムサカと飯。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂へ、オレンヂ・ジュース、オートミール、スクラムブルエグ、コーヒー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "入浴、食堂へ、スクラムブルエグとコンビーフハッシュ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂へ、オートミールとスクラムブルエグ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "スクラムルエッグ・ウィズ・ハムとチキンソティー・ライスにシユガーコーン。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "スクラムルエグ・ベーコンとソルズベリ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉は無し、オルドヴルにスープ、スクラムルエッグ、アイリッシュ・シチュウ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はミネストロンに、スクラムルエグ・ベーコン。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
