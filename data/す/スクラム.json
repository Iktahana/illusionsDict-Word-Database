    },
    "definitions": [
      {
        "index": 1,
        "gloss": "scrum (rugby)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「きみはスクラムの練習でもしてなさい」　と、高志がまじめな顔でからかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえのことだって――」　ゴールまえのスクラムからこぼれ出たボールをもって、ポストわきに飛びこもうとするナンバー８のように、慶一が高志にむかって突進し、両手で口を押さえこんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――怪し気な泥酔者達は、スクラムを組んで掴み合つたまゝダイアナの立像に素早い視線を投げながら、次第に風車のやうな凄まじい渦巻状を呈して砂の上を回転した。",
              "citation": {
                "source": "まぼろし",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "男のひとも家庭と妻との概念を変え、互に、愛し合う男と女とが生活に向ってスクラムを組む心持でなくては駄目と思います。",
              "citation": {
                "source": "働く婦人の結婚について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、四十｜碼スクラムからスリークォーター・パスになって、それを、私がカットして好｜蹴をタッチに蹴出す。",
              "citation": {
                "source": "一週一夜物語",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この外、コレット Collet、ヴィニェ Vinje、ガルボル Galborg、エルステル Erster、スクラム Skram 等此の時代に著名な作家が輩出してをりますが、此處には割愛しておきます。",
              "citation": {
                "source": "スカンヂナヴィア文學概觀",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フットボール競技に於て、さっとプレーヤーが、さっとスクラムを組みますが、つまりあれと同じように、人造人間が、たちまちスクラムを組むのでございます。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてたちまち人造人間のスクラムによって、一台の戦車が組立てられまして、こいつが、轟々と人造人間製のキャタピラを響かせて前進を始めます。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "電波のスイッチを入れたとたんに、うまくスクラムとやらを組んで戦車になってくれればいいが、万一人造人間の愚鈍な進軍だけが続くようでは、原地人軍は、その間に人造人間の頭の上をとび越えて、わが陣営へ攻めこんでくるであろう。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず第一のスイッチでは人造人間がばらばらと寄り、見事なスクラムを組んで戦車と化します」「早くやれ！",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから怪魚たちはスクラムをくんで、じわじわとこっちへ近づいて来る」「なに、こっちへ近づいて来るって。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし魚眼レンズをラグビーのスクラムの中につっこんで撮ったりして、初めて動く魚眼の映画像を見た時は、これまでの苦労も消しとぶほどの興奮をみなに与えたのであった。",
              "citation": {
                "source": "色彩映画の思い出",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の彼方からは、赤旗の乱舞とスクラムとインターの合唱をやってみせないと気がすまないという宗教団体が船に乗って渡ってくる。",
              "citation": {
                "source": "安吾巷談",
                "author": "麻薬・自殺・宗教",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らのやった仕事の主なるものはと云えば、ナホトカからスクラムをくんで祖国へ敵前上陸の筋金入りの人達をたきつけて益々ダダをこねさせたり、坐りこませたりすることである。",
              "citation": {
                "source": "戦後合格者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲原の描いた日本のメーデーの絵は、赤旗やスクラムを組んだ男女労働者や、ひっこぬき検束をしようとして一人の労働者のまわりにおそいかかっている黒服、サーベル、あご紐をかけて巻ゲートルをした警官隊と、それに抵抗してもみ合う行進者一群を描いて、日本のメーデーの性格を示そうとしていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "急にカメラの角度がかわって、ひろ子たちの方へのしかかって来るように、その門の中からスクラムを組み、旗をかざし、解放された同志たちを先頭にした大部隊が進行して来た。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで拾おうとした刹那、二人の悪党はラグビースクラムに押しつぶされてしまった。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　学生達は、みんな引返して来て、躊躇する彼の腕を左右からとってスクラムを組んだ。",
              "citation": {
                "source": "雲南守備兵",
                "author": "木村荘十",
                "note": "青空文庫"
              }
            },
            {
              "text": "半年ほどして信三は茅ヶ崎へ帰って来た、それからずっと、三人はスクラムを組んだような密接した気持で仕事を続けてきた。",
              "citation": {
                "source": "四年間",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今、私の前で広場の正面に列をつくり、スクラムを組んで恰かも組織された軍隊のように整然と隊伍を整えている学生の表情は一定の法則を保って硬化してしまっているように見える。",
              "citation": {
                "source": "早稲田大学",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、演壇に立っていた指導者らしい男が、またしても咽喉からしぼりだすような嗄れた声で何か叫んだと思うと、正面に陣どっていた一隊が、スクラムを組んだまま前へ進んでゆく。",
              "citation": {
                "source": "早稲田大学",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悦ちゃんを御馳走してゐた、ポタアジュ、スクラムブルドエグ・ベーコン、ムサカと飯。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂へ、オレンヂ・ジュース、オートミール、スクラムブルエグ、コーヒー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "入浴、食堂へ、スクラムブルエグとコンビーフハッシュ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂へ、オートミールとスクラムブルエグ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "スクラムルエッグ・ウィズ・ハムとチキンソティー・ライスにシユガーコーン。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "スクラムルエグ・ベーコンとソルズベリ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉は無し、オルドヴルにスープ、スクラムルエッグ、アイリッシュ・シチュウ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はミネストロンに、スクラムルエグ・ベーコン。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
