    "definitions": [
      {
        "index": 1,
        "gloss": "scrap (metal)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
