    "definitions": [
      {
        "index": 1,
        "gloss": "dumping ground",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "宗十郎夫婦は苦笑してこの池を金魚の姥捨て場だといっていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浄閑寺は廓の女の捨て場所であるということも、今更のように考えられた。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなさ、めんどうなことやってバレたら、ゴミ捨て場に放り出しとくよりヤバいんじゃねえの。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大船よりに十文字の駐車場のような困った交叉点があるし、金沢八景側は有名な予算の捨て場で、年度の後半は片側しか使えない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちにも捨て場所は幾らもある筈だ」「理窟はそうだが、理窟でばかり押せねえことがある」と、半七も首をかしげながら云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蟹のお角",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、猿またの捨て場所にこまって、そっとこの便所へ突っこんで、うんとひもをひっぱってドドドウと水を流して見た。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "横に顕れた千鶴子の膝頸のかすかに揺れるのを一寸見ると、一種無気味な感動の捨て場のない落ちつきなさで、「ふうむ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡は、捨て場のない気持ちで、おせいに涙を流させる仕儀に到つたのではないかと、ゆき子はうたがひ深く考へて見るのだ。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッチの捨て場所のない清潔な道路である。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙にくるんで、さて、捨て場所に困ったが、構うことはない、便所に放りこんでやった。",
              "citation": {
                "source": "或る作家の厄日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一二　うしはきば此は、美濃路から東方に亘つてゐると思はれる、馬捨て場と同じ意味の場処である。",
              "citation": {
                "source": "三郷巷談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩片捨て場の崖の上には、坑夫や掘子が、ズラリと並んで、眼を光らせていた。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして放送所の後庭に掘ってあるごみ捨て場の方へ持っていかれた。",
              "citation": {
                "source": "もくねじ",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日、このごみ捨て場に、舎宅の子供たちが三四人で遊びに来た。",
              "citation": {
                "source": "もくねじ",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "天龍の中流と藁科の上流とに挟まれた駿遠の山地を歩いて知つた事は、山中に柴捨て場の多い事で、其が大抵道に沿うた谷の隈と言つた場所にあり、其処で曾て行き斃れるか、すべり落ちて死ぬかした人の供養の為にして通るのだ。",
              "citation": {
                "source": "餓鬼阿弥蘇生譚",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "行く行くどこかへ捨ててしまおうと、米友は油断なく左右を見廻して行ったけれども、容易にその下駄一つの捨て場がわかりません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　このごろ、どこのごみ捨て場をあさっても、あまり食い物が見つからないので、都会にすむ餓えたからすたちは、弱い鳥をいじめてその肉を食べることを考えついたのでした。",
              "citation": {
                "source": "僕はこれからだ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の女が、長いはしのようなもので、ごみ捨て場をかき返して、落ちている菜っ葉や、新聞紙のようなものを地の上へひろげて、撰り分けていました。",
              "citation": {
                "source": "雪の降った日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人がごみ捨て場にあったのを拾って、とどけてくださったのですよ。",
              "citation": {
                "source": "雪の降った日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか、原っぱのごみ捨て場で、紙くずや、菜っ葉を拾っていた女の人だ。",
              "citation": {
                "source": "雪の降った日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早くから、日暮れ方まで、窓の下や、ごみ捨て場などをあさって、やかましく鳴きたてていました。",
              "citation": {
                "source": "温泉へ出かけたすずめ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "捨て場に窮しているうちに、お巡りさんにつかまってしまった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "音次の奴は狐に化かされただけのこと、事件になんの関係もない」　だが、それにしては、翌朝まで行李を持って廻って、捨て場に窮していたのが、おかしい。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで原子炉などから出る放射性廃棄物の捨て場として、この日本海溝が一つの候補地となっていた。",
              "citation": {
                "source": "科学ブームへの苦言",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、東が門風なのだが、捨て場に困っていたわけなのだ。",
              "citation": {
                "source": "彼が殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の揚句、まづく行つたら身体検査ではねられて、果ては身一つの捨て場に迷ふ者さへある。",
              "citation": {
                "source": "煤煙の臭ひ",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の言う飛び込むところとは、もしも生命の捨て場所を捜してござるなら無産者階級解放の第一線に立って花々しく討死にしてしかるべきだと思います！",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いやいや、匂いと言えば、その穴の中のゴミ捨て場のような臭いだけで、それ以外には無い。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途切れたところは草の生えた空地だの、塵芥捨て場だの、汚ならしい水溜りだの、家を取壊した跡だの、また気紛れに作りかけたまま放りだしたような畑だのになっていて、ぜんたいがじめじめと暗い、陰気くさい、ひどくうらさびれた眺めであった。",
              "citation": {
                "source": "嘘アつかねえ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の、滋幹の父が女の屍骸を見た場所と云うのは、何処のことか明かでないが、蓋しその頃の京都の街には、こう云う風な屍骸の捨て場が方々にあったのであろう。",
              "citation": {
                "source": "少将滋幹の母",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
