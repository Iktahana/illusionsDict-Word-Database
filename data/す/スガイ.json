    "definitions": [
      {
        "index": 1,
        "gloss": "Lunella coreensis (species of turban shell)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
