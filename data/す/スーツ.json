    "definitions": [
      {
        "index": 1,
        "gloss": "suit (clothing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
