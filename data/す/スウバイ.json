    "definitions": [
      {
        "index": 1,
        "gloss": "several times (as large, over)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "次にこの灯の寿命は四千時間以上で普通白熱灯などよりは数倍長く持つという利益がある。",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる電気はこの微粒の整数倍であるという事になった。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス人の画を見てすぐに要領を修得したような軽薄な絵を見るよりは数倍気持がいいと思う。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえこの静穏がもしや「死」の静穏であっても、あるいはむしろそうであったらこの美しさは数倍も、もっともっと美しいものではあるまいか。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは宅から持って来たのに比べて数倍大きくみごとなものであった。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや日没ちかく、残光を浴びて山の峯々が幽かに明るく、線の起伏も、こだわらずゆったり流れて、人生的にやさしく、富士山の、人も無げなる秀抜と較べて、相まさること数倍である、と笠井さんは考えた。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その出発点から自分の力以上のものに頼むのですから、その取捌き方や始末は数倍あるいは数十百倍こちらより上だと思わねばなりません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の舶来の舞踏など、余程高尚な積りでおるかは知らぬが、その変梃な足取、その淫猥らしき腰は、盆踊りより数倍も馬鹿気たものである。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の出米の相場を直接に聞くようになったために電話の忙がしさは数倍に達した。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分には、人間の女性のほうが、男性よりもさらに数倍難解でした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "原稿かいて、雑誌社へ持って行っても、みんな、芥川賞もらってからのほうが、市価数倍せむことを胸算して、二ヶ月、三ヶ月、日和見、そのうちに芥川賞｜素通して、拙稿返送という憂目、再三ならずございました。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉翁の数倍強いのではあるまいかと思はれる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手の声を聞くと同時に、恐怖が数倍したらしかった。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "上意をもって集る官軍は、鍋島元茂の一万、松倉重次の二千五百、立花忠茂の五千、細川光利の一万三千、有馬忠郷の八千を始めとして諸将各々兵を出し、城中の兵数に数倍する大軍である。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "物主競い来たりて、数倍の売償を求む。",
              "citation": {
                "source": "失うた帳面を記憶力で書き復した人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "その電柱の数倍の高さと太さとで、マストは海中、何のさえぎるものもないところに吹きさらしに突っ立っているのだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "この恨は富山に数倍せる富に因りて始て償はるべきか、或はその富を獲んとする貪欲はこの恨を移すに足るか。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽家　新年号は予想の数倍外に皆様のお気に召して私達はどんなに悦んでゐるかしれません。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが誰のよりも数倍高価である紅葉の色紙が誰のよりも一番早く売れてしまったそうだ。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "井侯が陛下の行幸を鳥居坂の私邸に仰いで団十郎一座の劇を御覧に供したのは劇を賤視する従来の陋見を破って千万言の論文よりも芸術の位置を高める数倍の効果があった。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日祖父の家康によって彼の自尊心に蒙らされた傷が、拭い去られたごとく消失したばかりでなく、忠直卿の自尊心は前よりも、数倍の強さと激しさを加えた。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "右まさに受け取り候こと実証なり　　　　久世｜大和守家中　　　　　　小納戸頭　茂木｜甚右衛門」　それすらが容易ならざるところへ、表の文字はさらに数倍の奇々怪々たるものでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "むだ口きくなよ」　がぜん、十兵衛に対する疑雲が数倍の濃度を増してまいりましたので、それと感づかれないようにあっさり引き揚げると、そこの路地奥のへいぎわにぴたりと身を寄せながら、疑問の番頭の行動監視を始めました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時で、果然番頭十兵衛がそわそわしながら姿を見せると、何やらささやき合っていた様子でしたが、きょろきょろあたりを見まわし見まわし、女ともども月影を避けるようにして、小急ぎに向こう横町へ出ていきましたので、疑惑はさらに数倍。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ご後室のおどろきも大きかったが、名人のおどろきはさらに数倍でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに吸い寄せられて来る人々も震災前に数倍した。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その勢が東京市中に数倍の飲食店を作り、安流行、安贅沢品を流行らせると同時に、かような大商店にまでも影響したので、一時は実に物凄い程の売れ行きであった。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時の恐怖や驚愕や戦慄に数倍した渦乱のような激動を、私は身体の凡てで感じたのであった。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙は花壇の上から蠅を追い散らした勢力よりも、更に数倍の力をもって、直接腐った肺臓を攻撃した。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、地球の場合と同様に雰囲気の高さはリッターの計算から期待されるよりは数倍も高いという結果になるのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
