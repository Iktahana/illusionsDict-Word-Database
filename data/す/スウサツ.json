    "definitions": [
      {
        "index": 1,
        "gloss": "several volumes (books)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "テアトロ数冊、コクランの「俳優芸術論」タイロフの「解放された演劇」、それだけ選び出して、包んでもらう。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の隅の一脚には、数冊の詩集、音楽の友、明星、楽譜帖などが花形役者にて、小説もあり、堅くるしき本もあり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の小机には半紙を二枚折にした横綴の帳面を数冊載せてあった。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が使っていた机の上は、キチンと片づけられ、そこに置いてあった数冊の本は影もなく、女郎花と桔梗とを生けてあった花瓶も見当らず、ベッドの上の麻のかけぶとんもなく、棚の上のスーツ・ケースも無くなっていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "本もかなり厚いのばかりが二十数冊読めた。",
              "citation": {
                "source": "骨を削りつつ歩む",
                "author": "――文壇苦行記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋は洗面台と数冊の書籍とをそなえた飾り気のない小さい室である。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の「アラン・ケイ」の訳者である鶴岡雄二は、一九七九年に古本屋で『サイエンス』のバックナンバーを数冊買い求め、その中の一冊にあったケイの「マイクロエレクトロニクスとパーソナルコンピュータ」をたまたま読んだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "寅二郎は、着替えの衣類二枚と、小折本孝経、和蘭文典前後訳鍵二｜冊、唐詩選掌故二｜冊、抄録数冊とを小さい振分の荷物にした。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして汽車の中で、通訳として随行していたＳ氏にノートブックを幾冊となく買わせ、何をするかと思うと、帽子をぬいで、その中へ骰子を二ついれて、帽子を揺り動かしては中の骰子をころがして二つの骰子の表へ出た数の和を記していき、それを記したノートブックが欧州旅行中に十数冊もたまったということである。",
              "citation": {
                "source": "黒岩涙香のこと",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もそのうちの数冊を、わけてもらって読んだことがある。",
              "citation": {
                "source": "黒岩涙香のこと",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは数冊の貯金帖を発見したことだったが、その帖面の現在高は、云いあわせたように、いずれも一円以下の小額だった。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "学者の部屋は八畳で、机の上には算木と筮竹の置いてある傍に、真勢中州伝や文言伝、説卦伝など、易の十翼中の数冊の古本が乱れているだけで、学者は床から這い上って来ると、「どうじゃ。",
              "citation": {
                "source": "馬車",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りすがりの窓から内部の板壁に貼ってある専門地図、レーニンの肖像、数冊の本、バラライカなどが見えた。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地橙孫君徃訪、不在、ふと思ひついて、女学校に支草を訪ふ、句集を数冊売つて貰ふ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "スケッチ外数冊郵送の手続きをした。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし無ければ、僕の本棚の中に黄色の表紙の『ル・ムーブマン・ソシアリスト』という雑誌が十数冊ある。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の背後には、差入れをたのまれた書籍類が数冊ずつ細い紐でしばっておいてある。",
              "citation": {
                "source": "日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る場合一冊の伝記は数冊の小説よりも人の心をうつ。",
              "citation": {
                "source": "まえがき（『真実に生きた女性たち』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三二年前後に邦訳で出版された全集だけでも二十四冊あり、なおその後の文学的活動は更に数冊の本となって現われるであろうと思う。",
              "citation": {
                "source": "私の会ったゴーリキイ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は手早く着換えをし、高畠子爵のそれほど広大ではないが、小ぢんまりと充分居心地よい書斎の机に、大部の書籍を数冊とり出した。",
              "citation": {
                "source": "伊太利亜の古陶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜通読した数冊の著書は一様にジョルジョの作品を一五三七年どまりと断定していた。",
              "citation": {
                "source": "伊太利亜の古陶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき私の手もとにはアンドレ・ジードの小説が数冊あった。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "数冊の本の中に、安成二郎氏の恋の絵巻という本がある。",
              "citation": {
                "source": "樹蔭雑記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロゼッテイは同志の詩人スウィンバーンと一緒に件の店に出かけて行って、ちょっとその本を覗いただけで直ちにその価値を認め、おのおの数冊ずつ買って帰った。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日彼らは友人に贈るためになお数冊買うつもりでまたその店へ行ったが、店の者は前には一冊一ペニイだったのを今度は二ペンスだと言った。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "長女は、この学校の創立者の著書を数冊新島に手渡した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでにも『マイコン基礎講座』をきっかけとして数冊を勉強し、マイコン誌を読みはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "百科事典を数冊重ねたほどの箱形のアルテアの上に載せられたトランジスターラジオが、その瞬間、うなるような歪んだ音を立てはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが吉利支丹の徒の事蹟を記せるを以て、所謂「南蛮もの」を蔵すること多からんと思ふ人々もなきにあらざれども、われは数冊の古書の外に一体のマリア観音を蔵するに過ぎず。",
              "citation": {
                "source": "わが家の古玩",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
