    "definitions": [
      {
        "index": 1,
        "gloss": "plane tree (esp. the Oriental plane, Platanus orientalis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二　青空が広く、葉は落ち尽くし、鈴懸が木に褐色の実を乾かした。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと向きあって路の右側に石の門と土塀の一部が残り、街路に面して二三本の半焼けになった鈴懸の樹のある所があって、その門の敷石の上に、右の手と頭に繃帯をしたシャツに腹掛けの運漕屋の親方らしい男が腰をおろしていた。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作中に出る人々の名は学者上りの若い浪人鈴懸紋弥。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方藩出の青年侍、鈴懸の友人二見十郎。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一上目黒渋谷境、鈴懸の仮寓、小さいが瀟洒とした茶室造り、下手に鬱蒼たる茂み、上手に冬の駒場野を望む。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴懸、炉に炬燵をかけて膝を入れながら、甘藷を剥いて食べている。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（女、鈴懸を指し）とんとこちらを狐にしたような男振り。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜更け、燈火の灯影に鈴懸炬燵にあたって、仮寝している。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "霰の音激しくなる……――こん、こん……、こん……――こん、こん……こん、こん……鈴懸のこん、こん、と藪の中の女の泣き乍らのこん、こん、と交り合いつつ",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄の鈴懸のこずゑにも風はそよげり、あきらかに。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "並木の鈴懸の間を夏の遊蝶花の咲き盛った円形花壇と緑の芝生に添って、たどたどと帰ってゆく幼年紳士の歌声がきこえる。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "塀に沿うて街路樹の鈴懸の若葉があつた。",
              "citation": {
                "source": "あかんぼの首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸の内の街路の鈴懸の樹のこの惨状を実見したあとで帝劇へ行って二階の休憩室の窓からお堀の向こう側の石崖の上に並んだ黒松をながめてびっくりした。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その街路は右の方へ半町ばかり往くと三叉路になって、左は暗いたらたらおりの街路になり、右は電車の停留場前になって、すこしの間ではあるが人道と車道の区別をした広い街路には、その境界に植えた鈴懸の葉に電燈の燈が映えていた。",
              "citation": {
                "source": "女の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竝木の鈴懸の間を、夏の遊蝶花の咲き盛つた円形花壇と緑の芝生に添つて、たどたどと帰つてゆく幼年紳士の歌声がきこえる。",
              "citation": {
                "source": "白帝城",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか、秋はたけ、外には鈴懸樹の枯葉が風とともに舗道に走っていた。",
              "citation": {
                "source": "生きている腸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつであつたかお須美は、学校の庭の鈴懸の木の根もとに穴をほつて、そこへＳさんとＡさんと三人で、思ひ思ひの物をお互に秘密にして小箱へ入れて誰にも知れぬ様に埋めておいた。",
              "citation": {
                "source": "秘密",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時、体操の先生がこの鈴懸の木の下で南極探検の話をなすつた。",
              "citation": {
                "source": "秘密",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴懸けの街路樹が深緑の葉を夕風にそよがせて、見るからに涼しげであつた。",
              "citation": {
                "source": "大利根八十里を溯る",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "大東京の三百万の住民たちは今グウグウ睡っているのに、それに大東京の建物も街路も電車の軌道も黄色くなった鈴懸けの樹も睡っているのに、それなのに敬二少年はなぜひとり目を覚ましているのだろうか。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはなぜかというのに、Ｔ駅の高塔の上の時計は今午前二時三十五分を指し、確かに正しい現在の時刻を現わしていたし、その上に、いま駅の前に一陣の突風が颯々と吹いているのであると見え、そこに植わっている鈴懸けの樹の小枝が風のまにまにユラユラと動いているのさえ認められた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たい空気が頬にあたり、すぐ真下に見える鈴懸の並木がはっと色づいていた。",
              "citation": {
                "source": "秋日記",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は焼けのこった東京の街の爽やかな鈴懸の朝の鋪道を歩いた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴懸は朝ごとに僕の眼をみどりに染め、僕の眼は涼しげなひとの眼にそそいだ。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の鈴懸は夏らしく輝き、人の装いはいじらしくなっていた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は焼けのこつた東京の街の爽やかな鈴懸の朝の舗道を歩いた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の鈴懸は夏らしく輝き、人の装ひはいぢらしくなつてゐた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは岩裂の神という、兜巾鈴懸けを装った、目なざしの恐ろしい大天狗だった。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると大学を卒業した年の秋――と云っても、日が暮れると、しばしば深い靄が下りる、十二月の初旬近くで、並木の柳や鈴懸などが、とうに黄いろい葉をふるっていた、ある雨あがりの夜の事である。",
              "citation": {
                "source": "毛利先生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "通うその学校は、麹町辺であるが、どこをどう廻ったのか、真砂町の嬢さんがこの辺へ来るのは、旅行をするようなもので、野山を越えてはるばると……近所で温習っている三味線も、旅の衣はすずかけの、旅の衣はすずかけの。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
