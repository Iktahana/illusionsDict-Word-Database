  {
    "uuid": "81736bc8-8549-5913-a25e-f6bb2ba6121e",
    "entry": "水注",
    "reading": {
      "primary": "すいちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "vessel for replenishing inkstone water",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「す……み……ませ……ん」　とすきとおるような声で云いながら、枕元にある銀の水注しの方へ力なく手を伸ばした。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達が着くと間もなく、扉船の上部海水注入孔のバルブが開いて、真ッ白に泡立った海水が、恐しい唸を立てて船渠の中へ迸出し始めた。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は大抵私に水注の役を吩附けられる。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は大抵私に水注の役を吩咐けられる。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷川が花瓶を縁側へ持出してゐるところへ、お婆さんが水注をもつて上つて来た。",
              "citation": {
                "source": "倒れた花瓶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十日　曇后晴、行程八里、唐津市、梅屋（三〇・上）八時から六時まで歩きつゞけた、黒川と波多津とで行乞、海岸路山間路、高低曲折の八里を歩いて来たのだから、山頭火いまだ老いず矣（但し途中キツケ水注入）。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "石皿、油皿、油壺、斯ういふものは隨分集められたが、この外普通の小皿類の如き向附の離れ物の如き、水滴、水注、片口、鉢類、日常雜器のものに手をつけてゆけば絶えず研究が出來、且つ安價で、樂しみは豐富である。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣で蓄音器がしよつちゆう泣いてゐたあの松井さんの柏木のお宅ね、あすこのお座敷の隅にあツた本棚、そら、扇のやうな形のね、あの下から三つ目に有ツたわ、キュラソオの罎が罌粟の花を生けた白い水注と並んでね。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尖形のギアマンの水注がある。",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水注の水を飲むことにしよう」　で、咽喉を潤おした。",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから水注の水を鉄瓶に注した。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "時として身のうちに響くこともありけれど、左のみ痛しとも堪えがたしとも思われず、折々、水注ぎ洗うが冷々と覚えらる。",
              "citation": {
                "source": "玉取物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "また捕虜のうち一名は塩水注射で死亡したということだ。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も「あんびん」（水注）の如き小品を作るが、昔はもっと色々作った。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水甕、酒甕、大壺、小壺、鉢、土瓶、急須、茶碗、徳利、花立、湯呑、皿、擂鉢、植木鉢、水注等々々。",
              "citation": {
                "source": "日田の皿山",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に入って見ると、素人手づくりの山小屋とはいえ、相当に入念の木口――炉も切ってあれば、鉄瓶、手桶、水注、流し元、食器の類も一通りは取揃えてある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしっ、それじゃ、こんどはすいちゅうめがねだ」　あけちたんていの声にこたえて、ボートのそこのサーチライトが、ぱっとすいちゅうをてらしました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、ボートのそこのすいちゅうめがねに、まっくろなせんこうていのすがたがあらわれました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
