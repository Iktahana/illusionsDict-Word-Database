          "literary": [
            {
              "text": "お前たちはみんな僕の少将だよ」　りすがきゃっきゃっ悦んで仕事にかかりました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木像はわたしですがきょうはだれにも会えません。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "からすがきたら、私がつえでなぐってやる。",
              "citation": {
                "source": "角笛吹く子",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "明くる日、からすがきたときには、木の根の洞穴の中は、まったく空っぽになっていました。",
              "citation": {
                "source": "からすとうさぎ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さん、きょうもまた、うぐいすがきましたよ。",
              "citation": {
                "source": "子うぐいすと母うぐいす",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うぐいすがきた？",
              "citation": {
                "source": "さびしいお母さん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、うぐいすがきたよ。",
              "citation": {
                "source": "春はよみがえる",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "親がらすがきちがいになって鳴いているので、家にいられたものでない。",
              "citation": {
                "source": "高い木と子供の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けると、雑木林のこちらへ差し出た枝に、からすがきて止まって、鳴いていました。",
              "citation": {
                "source": "風の寒い世の中へ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき、いすがきしむかすかな音と、びんがふれあうひびきが、かすかにきこえるだけだった。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶その他も出来るのだそうですがきのうはまだ備っていなかったので、通りの方の氷店からお茶やお菓子をとって、もって行ったお握りをたべ、十一時頃から七時すぎまで海風にふかれて、松の香を吸っていい心持、様々の思いで午後を過しました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "表をかくはずですがきょうは御免を蒙ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も縁談があったときだし、猪之のようすがきまじめなので、ついそうする気になったのだろう。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "三度目の正直",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがきまりの悪い面をして、それでも兵馬に礼を述べるより先に犬の悪口をはじめます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "女子と小人の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝ごとに裏の川よりあげて捕るウケの山がには黒く太かりき捕りためしバケツの底を山がにの鳴らすがきこゆ秋の夜長を　稲の穂花の白く浮いた田の水が溝川に落とされるころから、どじょうがよく捕れる。",
              "citation": {
                "source": "かき・みかん・かに",
                "author": "中島哀浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからお話しますがきっと驚かれるでしょう、外交官として」　女王は自慢なさらなかった。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
