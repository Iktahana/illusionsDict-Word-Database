        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "北山の法経堂に現れる怪火の話とか、荒倉山の狸が三つ目入道に化けたのを武士が退治した話とか、「しばてん」（木の葉天狗）と相撲を取る話。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神輿の前で相撲がある。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは相撲をとるのではなくて、相撲を取らないのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして結局相撲は取らないでおしまいになるのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その向いに坐った目の赤いじいさんと相撲の話をしている。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは相撲取かも知れぬが髪は二月前に刈ったと云う風である。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世人のわいわい騷ぐものには、ことさらに背を向けたい私の悲しい惡癖から、相撲に就いても努めて無關心を裝つて來たわけであります。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「常山の花」と題する小品の中にある「相撲取草」とは邦語の学名で何に当るかという質問を受けて困ってしまって同郷の牧野富太郎博士の教えを乞うてはじめてそれが「メヒシバ」だということを知った。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の二種類の人間の相撲になれば明白に前者の敗である。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相撲は人間の体力の活技で、一方から見れば霊妙な複雑な器械の戦いである、いずれにしても運用する力はいわゆる器械力で、力の作用する目的物は質量を有する物体だから、やはり相撲も力学の広い縄張の中へ入れても好かろうと思う。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相撲が特有の国技である以上はどうか我国の学者の研究によって四十八手の力学を明らかにしたいものだ。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猪が仔猪をつれて来て相撲って遊ぶところです」　赤土は何度か猪の蹄に蹴鋤かれたらしく、綿のように柔かに、ほかほか暖そうであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は螺の腹にえび蔓の背をした形で、瓜わらべを抱え、いつの間にか、いつぞや、息子の岳神に教えられた山ふところの猪の相撲場に来ていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は相撲場の中へ入り瓜わらべを土の上へ抱き下した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪の相撲場の土には親猪が蝨を落して行ったのだった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父さまは山中の猪の相撲場で、猪の仔の瓜わらべと遊び戯れているとき、猪の親に襲われ、牙にかかってお果てなされた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この討論は到底相撲にならないで終結したらしい。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五回に一回くらいは風船に旗を吊したものや、相撲や兵隊などの人形の出るのがあった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "独り相撲だと思いながらも自分は仮想した小僧さんの視線に縛られたようになった。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが私の独り相撲だとは判っているのです。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人相撲が過ぎたのです。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私の一人相撲はそれとの対照で段々神経的な弱さを露わして来ました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人相撲もこれでおしまいです。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るともう狐の学校生徒が沢山集って栗の皮をぶっつけ合ったりすもうをとったり殊におかしいのは小さな小さな鼠位の狐の子が大きな子供の狐の肩車に乗ってお星様を取ろうとしているのです。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、すもうをとりましょう。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつすもうをとりましょうか。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなに強いポチが殺される気づかいはめったにないし、ぬすもうとする人が来たらかみつくに決まっている。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからもう熊はなめとこ山で赤い舌をべろべろ吐いて谷をわたったり熊の子供らがすもうをとっておしまいぽかぽか撲りあったりしていることはたしかだ。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "商人の息子は、トランクの中へはいって、やすもうと思いながら、森へ帰ってきました。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兵タン、すもうとろうかやァ」と、久助君はいった。",
              "citation": {
                "source": "久助君の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
