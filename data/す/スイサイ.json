[
  {
    "uuid": "13ed95e5-eacb-5e83-8cd1-100151a976df",
    "entry": "水彩",
    "reading": {
      "primary": "すいさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
