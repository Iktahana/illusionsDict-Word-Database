          "literary": [
            {
              "text": "ただ胸ほどある据え風呂の中に恐る恐る立ったなり、白い三角帆を張った帆前船の処女航海をさせていたのである。",
              "citation": {
                "source": "少年",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "保吉はひっそりした据え風呂の中に茫然と大きい目を開いた。",
              "citation": {
                "source": "少年",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "大八車で運ばれてきた据え風呂桶の化け物みたいなこの一斗桝を見て、圓朝は肝をつぶした。",
              "citation": {
                "source": "圓太郎馬車",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん硝子の吊り灯りもない、平凡な据え風呂で、いつかの女などでなく、この家の若者が背をながしに出た。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
