        "examples": {
          "standard": [
            {
              "text": "ワンボックスカーのスライドドアが閉まる時の、独特の電子音が好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "玄関にスライドドアを採用すると、車椅子での出入りがスムーズになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "強風の日にスライドドアを開ける時は、一気に開かないよう注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "サロン入口のむかいは、全面がガラスのスライドドアになっていて、このドアを抜けると、サロンの三分の一ほどの面積があるテラスに出る。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "令子がスライドドアを通り抜けたのを一瞥し、慶一は空いているテーブルにむかって歩きながら、二〇二が視界からはずれるのをたしかめた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
