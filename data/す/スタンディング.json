          "literary": [
            {
              "text": "出席者のほとんどは、縦ノリには至らなかったもののカンビール片手のスタンディングで、イベントの進行を見守る形となった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりで遅れて食堂に入ってきたりしたら、そこらじゅうから口笛もんだよ」　といって、柾生は服部や野瀬と、〈アイ・ソウ・ハー・スタンディング・ゼア〉を歌いながら、非常口から消えた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタンディング・オヴェイション。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すんなりとスタンディング・スティルの状態になり、ニュートラルを出してアクセルを閉じると、エンジンは八〇〇回転で安定したアイドリングへ落ちていった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハネ後一引といふおでんやでおでんを食ひ、ダンスチームの宿へ遊びに行き、アンダースタンディングと、人物当てをやって遊び二時に切り上げてホテルへ帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "川島が今度の本にアンダスタンディングを入れてゐるのに、その遊びを知らないらしいので、教へるのに骨を折った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりでアンダスタンディングをやってみて面白かった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
