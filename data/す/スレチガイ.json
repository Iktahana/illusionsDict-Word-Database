        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "田圃道でスレ違いさまにお辞儀をして行く村の娘の髪毛の臭気を嗅いでも、彼は烈しいインスピレーションみたようなものに打たれて眼がクラクラとする位であった。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "想像もできないようなスレ違いが生じることもある。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "――細川の隊とスレちがいかけた。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
