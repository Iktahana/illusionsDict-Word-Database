    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese plum (Prunus salicina)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
