    "definitions": [
      {
        "index": 1,
        "gloss": "sweet (flavour)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "英語にスイートホームという言葉がある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人蕪村の心が求め、孤独の人生に渇きあこがれて歌ったものは、実にこのスイートホームの家郷であり、「炉辺の団欒」のイメージだった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウ・レ・トアド・パリの唄から“C'est pour mon papa”の唄へ――巴里の感情は最近これらのはやり唄の推移によってスイートソロから陽気な揶揄の諧調へ弾み上ったことが証拠立てられた。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルビーと紫水晶のかけらのスイートピー。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この感情の本質は涙ぐましく、甘くスイートな気分に充ちてヴァイオリンのようにメロディアスのものである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち彼等の新しい詩は、何よりも先ず情緒を重んじ、恋愛を讃美し、そして形式上には、古典詩学の窮屈な拍節本位に反対して、より自由でメロディアスな、内容本位のスイートな音律を創見した。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はスイートな情緒によって、音楽のメロディアスに融けて行く詩を愛した。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽がまた同じく、スイートでメロディアスの抒情的音楽と、荘重でリズミカルな叙事詩的音楽とが、昔から常に対立している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学を卒業してもまだウジウジしていたり、親から月給を貰ってスイートホームを作ったりしている連中とは無論、比較にならない火の玉小僧であった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ベイカー街に目を付けたスイートが。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、幸いにしてそのような性格を持った男性とスイートホームを作り得た婦人は、それこそ例の文化生活を徹底的に味わい得るわけであるが、さもない限りこうした要求は、自分の夫以外の「私のお馬鹿さん」や「お人形さん」に求めねばならぬ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今朝もこう思いました、「私の心に訪るるものの中にありては祈祷の感情が一番深くなつかしいスイートなものである、よし、私は一日じゅう祈りの心持ちより遠い言行はいっさいすまい」と。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はアダムとエバとのごとく、夫婦しての交わりにてのピュアな、天使的な、スイートな境地にあこがれます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "互いを憐れむ、隣人の愛の基礎の上に友としてのスイートな接触をも要求せねばならぬと存じます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ淋しい心地がして、スイートな感じなどちっとも起こりません。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "物置小屋の前の花畑には金盞花、矢車草、スイートピイなどが咲き揃つてゐた。",
              "citation": {
                "source": "火の踵",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "罵られた側も負けてはおらず、会場となったホテルのスイートルームを借りて参加者を呼び入れた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、私はスイートポテトの如くパラフィン紙に包まれた象の幽霊と称するものを人から貰った。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "種痘人の椅子をすべりし羽織かな　　　静廼スイートピー蔓のばしたる置時計　　　かな女等、椅子置時計の如き家具から草花、降誕祭、避暑の如き年中行事、種痘の如き、いずれも文化生活の背景をもった近代写生であるところに力強さがある。",
              "citation": {
                "source": "大正女流俳句の近代的特色",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日アドリナ・パティはアンコールに「ホーム・スイート・ホーム」をうたいました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽屋でパティは、「私は歳をとりすぎたからもうよくはうたえない」とおっしゃいましたが、この「スイート・ホーム」を聴いているうちに心が蕩けそうになりました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが本当の「スイート・ホーム」の美しさだ。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、天下一品と定評のあるパティの「ホーム・スイート・ホーム」をこの耳ではっきりと伺い、深い感銘と強い印象をうけたのでした。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、天下一品の「ホーム・スイート・ホーム」を伺いましたが、その声の若々しくて美しいこと、心がとろけちまいそうな、まるでビロードのような美しい声なのです。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして愛情たっぷりに、ほんとにスイートホームの楽しさをうたいました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはいずれも英国の有名な某会社製のものであって、曲目は「ホーム・スイートホーム」とか「英国々歌」とか「トロイメライ」とかいう通俗なものばかりであった。",
              "citation": {
                "source": "暗号音盤事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いないな短艇浮かび、処女乗り、少年笛ふけど、霧ふかければ、見えざるなりき貴族の家に温室ありきアラセイト――蘭アマリリスレザ白鳥花フリジヤシネンセス蟹手草キクスイートピー霧の中の温室温室の中の花花の中の茶卓茶卓に添える籐椅子籐椅子によれる貴族貴族により添える胸乳房唇しかれども霧！",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし始めより自己のほかに興味を感ずることのできない、他人の愛を欲しない人間であるならば、おそらくその人には隠遁のスイートなロマンチックな気持ちは解らないであろう。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "スイートホームというけれども、恋愛の甘さではなく、こうなってから初めて夫婦愛が生まれてくる。",
              "citation": {
                "source": "愛の問題（夫婦愛）",
                "author": "――生命の法に随う――",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚後の恋愛は蜜月や、スイートホームの時期をへて、次第に、真面目な地についた人生の営みのなかにはいってゆく。",
              "citation": {
                "source": "女性の諸問題",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
