[
  {
    "uuid": "6a426c78-e83e-5445-9475-116338a8a861",
    "entry": "推論",
    "reading": {
      "primary": "すいろん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
