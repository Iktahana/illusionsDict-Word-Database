[
  {
    "uuid": "92bbce9d-4686-5fb0-a15d-2bd3e2672d37",
    "entry": "優れた",
    "reading": {
      "primary": "すぐれた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
