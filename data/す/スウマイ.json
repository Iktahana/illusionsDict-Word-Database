    "definitions": [
      {
        "index": 1,
        "gloss": "several sheets (flat objects)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ダ・ヴィンチは、入れられぬ故郷の町を後に、自作の画数枚を背負つて雪のアルプスを越え………「今に………！",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは瓦が数枚落ちたのと壁に亀裂が入ったくらいのものであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロダンさんは妾に数枚の赤札を買って下さいましたが、みるみるルーレット係の役人の手によって、玉の転げる音と共に消えてしまいました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者が〔以下原稿数枚なし〕　それから「アナタ、タヾノオキャクサンゴザイマスカ。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔以下原稿数枚なし〕　それから松雲閣へ帰って一つ風呂を浴びてやれといふ気持ちで更衣室に行くとこれは又さっきの異人が宿から縞の唐〔桟〕の袷を着せられてかんかんと椅子に座ってパイプをくわいて時事新報を見てゐたもんである。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔以下原稿数枚なし〕　それから松雲閣へ帰らうと例の桜小路をやってくると向ふから黄いろな自働車が事もあらうにシカゴ畜産組合といふ旗をたてゝやってきた。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ林の濶い木の葉がぱちぱち鳴っている〔以下原稿数枚？",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬初めごろまでに小さなスケッチ板へ二三十枚、六号ないし八号の画布へ数枚をかいた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たびたびどうも、複製をお送り下すつて難有う」「地霊…………アスタ・ニールズン」彼はニールズンを好きで、数枚その肖顔を描いてる男である。",
              "citation": {
                "source": "散歩生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなはそれから番号をかけて右向けをして順に入口からはいりましたが、その間中も変な子供は少し額に皺を寄せて〔以下原稿数枚なし〕と一郎が一番うしろからあまりさわぐものを一人ずつ叱りました。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」〔以下原稿数枚なし〕の山にのぼってよくそこらを見ておいでなさい。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルコ人たちは脚が長いし、背嚢を背負って、まるで磁石に引かれた砂鉄とい〔以下原稿数枚なし〕そうにあたりの風物をながめながら、三人や五人ずつ、ステッキをひいているのでした。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ赭ら顔の白髪の元気のよさそうなおじいさんが、かなづちを持ってよこの室から顔〔以下原稿数枚なし〕が、桃いろの紙に刷られた小さなパンフレットを、十枚ばかり持って入って来ました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノンノンノンノンノンといううなりは地の〔以下原稿数枚分焼失〕「今授業中だよ。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あんなに始終つけて置かないのは、〔この間、原稿数枚なし〕永久におまへたちは地を這ふがいい。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ二三十分して余はまた寒気にたえずなれり、今までの着物にてはとてもしのぶあたわず、余はその上にさらに数枚の毛布を重ねたり、毛布を重ねつつ耳を澄ませば、あら不思議！",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵だって僕は、堀木なんかより、ずっと上手なつもりなんだ」　このような時、自分の脳裡におのずから浮びあがって来るものは、あの中学時代に画いた竹一の所謂「お化け」の、数枚の自画像でした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "零の素材から数枚の作品が生ずるという、物理的に不可能なこともここではしばしばあり得る。",
              "citation": {
                "source": "童話における物語性の喪失",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、見慣れぬ木の葉を数枚持って来、それを噛んで狂少年の眼に貼付け、耳の中に其の汁を垂らし、（ハムレットの場面？",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早や数百金にもなりつらむと思ふ頃、その中より数枚を取り出し、丸山の妓楼に上り、心利きたる幇間に頼みて、彼の香煙の器械一具と薬の数箱を価貴く買入れぬ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "新子からの手紙は、もちろん母の宛名、お給金を送って来るには時期が早すぎるのに書留とは、と思いながら、母より先に見たって差支えあるまいと、サリサリと封を切ってみると、手紙と共に数枚の為替証書だった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが済むと、彼女は木人らを元の箱に収め、麺をもって焼餅数枚を作った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜があけると、彼女は果物と、焼餅数枚を皿に盛って持ち出した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "路面には少しの塵芥もなかつた、連日の降雨に奇麗に洗ひ流されたのだらう、数枚の広告ビラらしい小さな紙片が散らばつてゐたが。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡元朝の遺民｜陶宗儀の『輟耕録』四に、往々蒙古人雨を祷るを見るに、支那の方士が旗剣符訣等を用うると異なり、ただ石子数枚を浄水に浸し呪を持て石子を淘玩すと、やや久しくして雨ふる、その石を鮓答といい、諸獣の腹にあれど、牛馬に生ずるのが最も妙だと見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧――（ポケットから数枚の葉書と一通の封書をとり出して渡しながら）これをご覧なさい、なかなか猛烈なのがありますよ。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ここには十数枚のシングルと、六枚のＥＰ、それに三枚のＬＰしかない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてそのやり方であるが、まづ術者は、十枚あるひは十数枚（この数まつたく任意）の、細長く切つた紙片を一枚づゝ観客に渡し、それへ好みの花の名を一つづゝ書いて貰ふ。",
              "citation": {
                "source": "美術曲芸しん粉細工",
                "author": "阿部徳蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
