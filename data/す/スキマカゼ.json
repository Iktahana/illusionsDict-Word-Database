        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "扉には、隙間風が吹きこまないように、目貼りがしてあった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "底冷えの戸の隙間風、さるにても明け近からし。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "外では雨風の音が烈しく、隙間風に燭台の灯がちらちらと揺れる。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのくらい時間が経ったか、隙間風が肌寒くすっかり夜になっていた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "多鶴子の車が霞町から天王寺公園横の坂を登って行くと、佐古は、「寒い、寒い、隙間風がはいって来よる」と、言い出した。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、それからワトソン君、――もし君が、破れた窓から入る隙間風に我慢が出来るなら、せめて三十分も僕の書斎に上って、一服やってくれたら、また何か一興を供することが出来ると思うんだがね」　昔馴染の室は、そのミクロフト・ホームズの管理と、ハドソン夫人の行き届いた注意で、全く昔ながらの儘であった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはどうしても一陣の隙間風を必要とする。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "温かく上衣を脱ぎたいほどだが、うっかり手紙をサロンで書いていると、突然日本海から隙間風が来て咳が出る。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわてて隙間風のこない所へ逃げてまたペンを持つ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは圧えに圧えてもどこからか隙間風のように出て来るものだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」マリアはアトリエの隙間風を防ぐために修道僧のようなずきんつきの大外套をこしらえさせた。",
              "citation": {
                "source": "マリア・バシュキルツェフの日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋の中がぱっと明るくなり、焔はひらひらと隙間風に揺れ出した。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふは仕方がないから、友だちの家へでも行つて借金でもするとしようと肚を決めてゐたが、薄い蒲団ながら、床から出るのが寒いので、首も手足もちぢめ、隙間風を恐れてじつと身動きもしないでゐた。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローソクの灯が板壁の隙間風にゆらゆらとゆれて、時々消えかける。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下の羽目からは鋭い隙間風が頸のうしろにあたって、背中がゾーゾーする。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし隙間風があるとすれば、その風にも太宰をあてまいとする。",
              "citation": {
                "source": "太宰治との一日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "声はひゅうひゅうと隙間風のようにかすれ、またも無意味に濁ったりした。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "隙間風の激しい板敷きの上に半日以上、すわり暮しておいでの時もあり、夜中から曉方まで、冷えあがるやうな夜、三度までお湯をお使ひあそばすこともあつた。",
              "citation": {
                "source": "死者の書　續篇（草稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物にかこまれて深い井戸のようになっている裏庭には、ときどき隙間風が吹き込んできて、蝋燭の光を二人の足もとへあちこちと揺り動かした。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "日野は座ブトンをしいて外套をひッかぶって寝てみたのですが、隙間風がたまらないから、外套をきて壁にもたれて坐り、膝の上にも座ブトンを当て腕をくんで睡りましたが、案外にも夜が明けるまでそのカッコウで睡ることができたそうです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "其が、隙間風の爲であらう。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "其が隙間風の為であらう。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其が、隙間風の為であらう。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其が、隙間風の為であろう。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "山寄りの土地だからただでも寒気がきびしいのに、カラッ風が最高潮に達して吹きまくっているから校舎は鳴動し、ストーブにいくら石炭をついでも、一陣の隙間風が吹き通ると、鋭い刃物で骨のシンまで斬られたような痛みを覚える。",
              "citation": {
                "source": "牛",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケイタイも便利であるが、何よりも隙間風がはいらないから温かいのである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族三人で囲んだ爐の榾火に、どこからともなく忍んできた隙間風が、ちょろちょろと吹いて過ぎた。",
              "citation": {
                "source": "岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "掌をかざしたが、別に隙間風がはいってる様子もなかった。",
              "citation": {
                "source": "白血球",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
