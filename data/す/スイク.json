          "literary": [
            {
              "text": "かような調査を、あらゆる語について行うと、当時用いられた万葉仮名のどの文字はどの文字と同音であるかが見出され、一切の万葉仮名をそれぞれ同音を表わすいくつかの類にわけることが出来るようになる。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤独に親しみやすいくせにどこか殉情的で人なつっこい私の心は、どうかした拍子に、このやむを得ない人間の運命をしみじみと感じて深い悒鬱に襲われる。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十円の入場料だってやすいくらいだ。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのうすいくちびるのさきが、わたしの心臓へささるやうな気がする。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "町名をば順に数ふる早わざを妹達に教へしは誰れ　小娘時代の囘顧で、幼時を思ひ出すいくつかの作の中でも最も罪のないもので、微笑を禁じ得ないがどこか才はじけた作者らしい俤があらはれてゐて面白い。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "感傷的な気分に支配されやすいくせに、彼は決して外表的になれない男であった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "リーズはうすいくつで、その上を歩くことができなかったから、わたしは背中に乗せてしょって行った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹をたたきつけたように」　マスノのうすいくちびるから出たことばにおどろき、だんだん大きく目をみひらいた先生は、顔色さえも少しかえて、「まあ、ソンキさん、うちの人たち、けがしなかったの？",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "音さしたらいかん」　マスノがうすいくちびるをそらして、少しつった切れ長の目にものをいわせると、竹一や正までが声もからだもひそめてしまった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
