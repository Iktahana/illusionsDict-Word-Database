        "examples": {
          "standard": [
            {
              "text": "アクションゲームをプレイする際、画面の引き裂き現象を防ぐために垂直同期をオンにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "垂直同期を有効にすると、グラフィックカードの負荷は減るが、操作にわずかな遅延が生じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最新のディスプレイ技術では、フレームレートに合わせて変動する可変垂直同期が一般的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「知りませんよ」　一〇三のヴェランダにおいたモニターの垂直同期を調整しながら、そうこたえたワラは、怒っていないどころか、むしろ高志の遅刻を歓迎しているらしい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
