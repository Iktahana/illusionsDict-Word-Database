        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし、それも何千人と折り重なっては困るであろうし、また満員のデパートに急な火が起これば階段が人間ですし詰めになって閉塞してしまう恐れがある。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高山以来、毎晩碌々に安眠しない上に、列車のなかに立往生をしたままで、すし詰めになって揺すられて来る。",
              "citation": {
                "source": "指輪一つ",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のためのコンピューターを追い求めようとするホビイストたちの熱気で、すし詰め状態となった会場はむせ返っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車は非常に混雑して便所まですし詰めの有様で、私ども日本人は全部三等車に乗せられました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮舎は辛うじて雨露を凌ぐ程度で、坪当たり数名の、すし詰めの生活だった。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスはすし詰めの満員で、おりてくるのは若い男ばかりだった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "土川春彦の頭脳の中には、いつも大きな事業計画がすし詰めになっていた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――――――――――――貨物列車の中、夜、すしづめの兵隊入口の扉の処に将校来る。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "出るときにはやはりすしづめの人々を押し分けて出なければならないのである。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在学級の法定基準、一学級五〇名を超えているすしづめの学級は、全国の四〇パーセント以上を占めている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この並びたつ両巨豪が折しも議事堂のごつた返す廊下や満員すしづめの食堂ですれ違ひ居並ぶ時は、両々火花を散らすその慇懃なる静寂、狙ひ、優美なる挨拶、壮観これに超ゆる観物は尠いのである。",
              "citation": {
                "source": "総理大臣が貰つた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずぶぬれの服で、伝馬船にすしづめになって、身動きもできず、うずくまりながら、うつらうつら、いねむりをしていた。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸国諸道からここに雲集した人々は、あすの日を待ちかまえて、空を気にしたり、足ごしらえの用意をしたり、またはその日の予想や往年の思い出ばなしなどで、どこの宿屋もすしづめのさわぎ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
