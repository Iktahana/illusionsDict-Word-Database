    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese sea bass (Lateolabrax japonicus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "下つ瀬には網代人が州の小屋に籠って網代に鱸のかかるのを待っている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鱸その他の川魚を漁する人の、豊島の渡よりこゝの渡にかけて千住辺りまでの間に小舟を泛めて遊ぶも少からず。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "時節によって鱸を釣ろうというので、夕方から船宿で船を借りて、夜釣をして居る人がある。",
              "citation": {
                "source": "夜の隅田川",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでさっきの話のつづきだがね、おまえは魚屋の前からきたとすると、いま鱸が一｜匹いくらするか、またほしたふかのひれが、十｜両に何｜片くるか知ってるだろうな。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでさつきの話のつゞきだがね、おまへは魚屋の前からきたとすると、いま鱸が一匹いくらするか、またほしたふかのひれが、十｜両に何斤くるか知つてるだらうな。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "船が下流に落ちると、暮雲岸を籠めて水天一色、江波渺茫、遠く蘆が靡けば、戀々として鷺が佇み、近く波が動けば、アヽ鱸か？",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯛、鱸どころでない。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……宵に鯊を釣落した苦き経験のある男が、今度は鱸を水際で遁した。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "われら此の森の伏屋、小川の芦、海は申すまでも候はず、岩端、松蔭、朝顔、夕顔、蛍、六代御前の塚は凄く涼しく、玄武寺の竜胆は幽に涼しく、南瓜の露はをかしげに涼しく、魚屋の盤台の鱸は……実は余りお安値からず涼しく、ものにつけ涼しからぬはこれなく候。",
              "citation": {
                "source": "逗子より",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鱸は刎ねる、鯔は飛ぶ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋はうなぎや鱸の夜釣りにゆく。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は生洲から上げたばかりという生け鱸の吸ものの椀を取上げて、長汀曲浦にひたひたと水量を寄せながら、浜の椰子林をそのまま投影させて、よろけ縞のように揺らめかし、その遙かの末に新嘉坡の白亜の塔と高楼と煤煙を望ましている海の景色に眼を慰めていた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鱗の落ちた鱸の鰭を真水で洗う、手の悪い魚売人には似たれども、その儀では決してない。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ驚かされたのは、思ひのほか、魚が結構だ、と云つたのを嘲笑つて、つい津居山の漁場には、鯛も鱸もびち／＼刎ねて居ると、掌を肩で刎ねた。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると、非常に大きい鱸が引っかかることもあるんですが……」「すずきが相変らず釣れますか。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "母燕はたまらなくなつて、みんな一しよに抱きしめながら「何てまあ可愛んだろ」　まだ生きてゐる鱸　朝早く、磯で投釣りをしてゐる人がありました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると鱸が「にいさん、私を何處へもつて行くんです」と聲をかけました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と鯉｜呑麩の口、蕪村がいわゆる巨口玉を吐く鱸と相似て非なるものなり。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏道に帰依して、二、三十年の間は、少しもなまぐさいものを口にしなかったが、あるとき、友だちの一人が松江の鱸を煮ているところへ往き合せたことがあった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こないだ鳶が空から取落した奴を、松江の鱸だといって、うまく騙して売りつけてやった、あの露次裏の老ぼれじゃないか。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「半江紅樹売鱸魚」は王漁洋の詩である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鱸は強い魚であることを知っているので、平助も用心して抑えにかかったが、魚は予想以上に大きく、どうしても三尺を越えているらしいので、小さい網では所詮掬うことは出来そうもなかった。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は魚の跳ねる音をたよりに探り寄ったかと思うと、難なくそれを取抑えてしまったので、盲人として余りに手際がよいと、平助はすこし不思議に思いながら、ともかくも大きい魚を小屋の内へかかえ込むと、それは果して鱸であった。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鱸の眼には右から左へかけて太い針が突き透されているのを見たときに、平助は何とはなしにぞっとした。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは淵の主ともいうべき鯉か鱸のたぐいであろうと思ったので、かれは一刀に刺し殺そうとしたが、また考えた。",
              "citation": {
                "source": "鐘ヶ淵",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯉か鱸か知れない魚に撲たれた痕が先刻からときどきに痛むのを、お供先では我慢していたのであるが、家へ帰って気がゆるんだせいか、この時いっそう強く痛んで来て、熱もすこし出たらしいので、かれは夕飯も食わずに寝床に転げ込んでしまった。",
              "citation": {
                "source": "鐘ヶ淵",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の下二尺の鯛が釣れようと、三年の鱸が食いつこうと、あるいはまた間違って糸｜蚯蚓ほどの鮠（註に曰く、ハエをハヤというは俗称なり。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中がいそいそ持ち出して来た膳部を見ると鯛の塩焼だの、鱸の洗ひだのがごたごた一｜所に並べてあつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、わざわざ彼等のあとを尾けて行って、それを確かめる程の好奇心も湧き出さなかったので、僕は再び水の方に向き直って自分の釣りに取りかかったが、市野の言ったような大きいすずきは勿論のこと、小ざかな一匹もかからないので、僕ももう忍耐力をうしなった。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚の配給日が二日おくれて今日になったが、すずき一片が金十七円也。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
