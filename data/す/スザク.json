    "definitions": [
      {
        "index": 1,
        "gloss": "Vermilion Bird (god said to rule over the southern heavens)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "管野すが子は齡卅歳、生れは京都府葛野郡朱雀野村である、春に秋に歌に好く詩に好いこの歴史的匂ひある村に生れた一女性は、小學校を出で世の鹽にもまれる樣になると、種々數奇の運命に弄ばれた、多少の「文字ある女」に能くある慣として、すが子は澤山の男にも關係したし、多くの文學的書籍にも讀み耽つた。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "はては朱雀門、大極殿、大学寮、民部省まで移りて、一夜の程に塵灰となりにき。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山城の朱雀野に来て、律師は権現堂に休んで、厨子王に別れた。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の食を済ませて後、為すこともなければ携えたる地理の書を読みかえすに、『武甲山蔵王権現縁起』というものを挙げたるその中に、六十一代｜朱雀天皇｜天慶七年秩父別当武光同其子七郎武綱｜云々という文見え、また天慶七年武光奏し奉りて勅を蒙り五条天皇（疑わし）少彦名命を蔵王権現の宮に合せ祀りて云々と見えたり。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この十月に朱雀院へ行幸があるはずだった。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱雀院の行幸の日の楽の役と舞の役の人選が今日あるのだそうですから、大臣にも相談しようと思って退出したのです。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに試楽の日に皆見てしまっては朱雀院の紅葉の日の興味がよほど薄くなると思ったが、あなたに見せたかったからね」　など仰せになった。",
              "citation": {
                "source": "源氏物語",
                "author": "紅葉賀",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月二十幾日に朱雀院へ行幸があった。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "御所からすぐに朱雀院へ行ってその次に六条院へ舞い手はまわって来た。",
              "citation": {
                "source": "源氏物語",
                "author": "初音",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏歌の組は朱雀院で皇太后の宮のほうへ行っても一回舞って来たのであったから、時間がおそくなり、夜も明けてゆくので、饗応などは簡単に済ますのでないかと思っていたが、普通以上の歓待を六条院では受けることになった。",
              "citation": {
                "source": "源氏物語",
                "author": "初音",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、朱雀門の傍まで行くと、そこで盗品をわけ合って、この男にも麻袋一枚｜呉れた。",
              "citation": {
                "source": "女強盗",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、朱雀を南の方へと、四条通まで行った。",
              "citation": {
                "source": "女強盗",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "物語に見る朱雀大路のあとなぞも今は尋ぬべくもない。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝風に若菜売る児の声すなり朱雀の柳眉いそぐらむ　この歌は十首中にては第一と存候。",
              "citation": {
                "source": "人々に答ふ",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝は午前六時に御出門になって、朱雀大路から五条通りを西へ折れてお進みになった。",
              "citation": {
                "source": "源氏物語",
                "author": "行幸",
                "note": "青空文庫"
              }
            },
            {
              "text": "御前、中宮、朱雀院へまわるのに夜が更けるために、今度は六条院へ寄ることを源氏が辞退してあった。",
              "citation": {
                "source": "源氏物語",
                "author": "真木柱",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱雀院から引き返して、東宮の御殿を二か所まわったころに夜が明けた。",
              "citation": {
                "source": "源氏物語",
                "author": "真木柱",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の尚侍を朱雀院の母后が厳重な監視をして、源氏に逢わせまいとされた時がちょうどこんなのであったと、その当時の苦しさと今を比較して考えてみたが、これは現在のことであるせいか、その時にもまさってやる瀬ないように思われた。",
              "citation": {
                "source": "源氏物語",
                "author": "真木柱",
                "note": "青空文庫"
              }
            },
            {
              "text": "興の多い日になることを予期されて、主人の院は朱雀院をも御招待あそばされたのであったから、珍しい盛儀であると世人も思ってこの日を待っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "藤のうら葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱雀院の紅葉の賀の日がだれにも思い出された。",
              "citation": {
                "source": "源氏物語",
                "author": "藤のうら葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「宇陀の法師」の昔のままの音を朱雀院は珍しくお聞きになり、身にしむようにもお感じになった。",
              "citation": {
                "source": "源氏物語",
                "author": "藤のうら葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝が、世の常の紅葉とや見るいにしへのためしにひける庭の錦を　と朱雀院へ御説明的に申された。",
              "citation": {
                "source": "源氏物語",
                "author": "藤のうら葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "六条院の御子の源中納言が参院した時に、御病室の御簾の中へお招きになり、朱雀院はいろいろなお話をあそばされた。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人の来た時に妹である乳母が朱雀院の御希望を語った。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母は何かのことを朱雀院へ申し上げたついでに、自分が試みに前日兄の左中弁へした話を申し上げて、「兄が申しますのには院は必ず御承諾あそばされることと思う。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱雀院では院の御病気がそのまま続いてお悪いために、姫宮の裳着の式をお急ぎになり、準備をいろいろとさせておいでになったが、過去にも未来にもないような華美なお儀式になる模様で、だれもだれも騒ぎ立っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "六条院は朱雀院の御病気が少しおよろしい報せをお得になって御自身で訪問あそばされた。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱雀院法皇はこの御訪問を非常にお喜びになって、御病苦も忍ぶようにあそばされて御面会になった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "太政大臣に先を越されてうらやましく思われます」　と朱雀院は仰せられた。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱雀院のは塗り物でない浅香の懸盤の上で、鉢へ御飯を盛る仏家の式のものであった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
