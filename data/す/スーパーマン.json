    "definitions": [
      {
        "index": 1,
        "gloss": "superman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いうまでもなく、明敏神のごとき名探偵や、スーパーマンを意味するのではない。",
              "citation": {
                "source": "日本推理小説の曲り角",
                "author": "十返肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは大魔術師じゃ、スーパーマンじゃ。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニコラ博士は、おそろしいスーパーマンだよ。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみたちは、映画やテレビで、アメリカのスーパーマンが空を飛ぶのを見たことがあるでしょう。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれとよくにたスーパーマンが、日本にもあらわれたのです。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにいる白井保君が、そのスーパーマンの空を飛ぶところを見たのです。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも、スーパーマンが空を飛ぶのを、見たくてたまらなかったのです。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワハハハハ……、スーパーマンとオールマイティーの戦いだ。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、朝やけの空を、アメリカのスーパーマンのように、両手を前につきだして、マントをヒラヒラさせて、ひじょうな速さで空中をとびさってしまったのです。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あいつはスーパーマンみたいなやつですから、宝石のかくし場所を知っているかもしれません。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あっ、スーパーマンだっ！",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "はれわたった月光の空を、黒いマントをひるがえした、スーパーマンが、とんでくるのです。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手をグッと前につきだして、風をきってとぶスーパーマンは、お堂の上までくると、その屋根のまわりを、グルグルと、まわりはじめました。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士はスーパーマンのように、空をとぶためには、どうしても、この木のてっぺんに、かえってこなければならないわけがあったのです。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみがどうして、スーパーマンのように、空をとぶか、その秘密を、ぼくは知っているのだ。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみはそれを使ってスーパーマンのまねをしていたのだ。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜や、うすぐらい日には、プロペラが見えないので、いかにもスーパーマンがとんでいるように思うのだ。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "スーパーマンが飛行の術をうしなってしまったのだ。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きみは、この木のてっぺんから、スーパーマンのように、とびたつつもりだったろうが、そのとび道具のプロペラは、ぼくがこわしてしまった。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで、スーパーマンのように、からだをのばして、およぐように、空高くとびさっていくではありませんか。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "15黒いかげ　明智たんていと、おおぜいのおまわりさんに取りかこまれたかいじん二十めんそうは、屋根に上がって、そこから、まるでスーパーマンのように、空へとんでいってしまいました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十面相はヘリコプターを小さくしたようなフランス製の機械で自由自在に空をとぶことができるので、いざというときには、大きな木のてっぺんに、かくしておいたその機械を身につけて、アメリカのスーパーマンのように、空高くとびさってしまう。",
              "citation": {
                "source": "自作解説",
                "author": "怪人二十面相と少年探偵団",
                "note": "青空文庫"
              }
            },
            {
              "text": "金色のマントが、ヒラヒラとはためいて、映画のスーパーマンと、そっくりです。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "金色のスーパーマンが夕やみの空を高く、高く、とんでいくのです。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "スーパーマンのように、とんでいくのです。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
