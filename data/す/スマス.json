[
  {
    "uuid": "6788424f-35b5-55f0-900e-956270faccc0",
    "entry": "済ます",
    "reading": {
      "primary": "すます",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
