        "examples": {
          "standard": [
            {
              "text": "お二人の末永いお幸せを、友人一同心よりお祈り申し上げます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地域住民の末永い健康を支えるために、新しい診療所が開設された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "伝統技術の末永い継承のためには、若い後継者の育成が不可欠である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてそのような生活がいつまでも妨げられずに平静に続いて行って、その行末永い途上に美しい研究の花や実を齎す事を期望している。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに譬を以って云えば、例えば人が在って、自分の家に前々から根深く関係し、また今後も末永い関係が続く金銭の貸借出入りが、大変複雑である事に心づき、その本末を知るために清算をしようとするようなことである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
