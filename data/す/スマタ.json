[
  {
    "uuid": "fc35ddba-0ba7-557e-8b8c-32d9e4cb8eb3",
    "entry": "素股",
    "reading": {
      "primary": "すまた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bare thighs",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ガランとした部屋の中に、たつた一人、真白な面を緊張めてくるくるともんどりうつ凄さ、可笑さ、又その心細さ、くるくると戯け廻つて居る内に生真面目な心が益落ちついて、凄まじい昼間の恐怖が腋の下から、咽喉から、臍から、素股から、足の爪先から、空一面に拡がり出す。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "年じゅう素股の魚屋から、裸商売の佃から来るあさり売りまで、異国の人に対しては、おのれらの風俗を赤面するかに見える。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすまた、あのお店へ行けば、夫に逢えるかも知れない。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすまた見に来てやるからな。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「然し、もう、お政さんがゐ眠りをし出したし、實際、夜も更けたのですから、あすまた飮み直しましよう」といつて、そこをはづした。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "（羅馬書第八章三十八、三十九節）　汝神を有すまた何をか要せん。",
              "citation": {
                "source": "基督信徒のなぐさめ",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜叉王どの、あすまた逢いましょうぞ。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が自己の要求を充すまたは理想を実現するということは、いつでも幸福である。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に我は神を知らず我ただ神を愛すまたはこれを信ずという者は、最も能く神を知りおる者である。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすまた、もじり、棒、まさかり、こういうものだって馬鹿には出来ねえ、出来るだけ手入れをするがいい」　副頭領の楠右衛門、四人の小頭、十人衆、いわゆる家の子郎党が、クルクルクルクルと立ち働く。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人夫なんどに水を呑ませては困るぢやありませんか」「船では水はやりません」「やりませんと言つても現にやつたのを見た者があるのですまた湯は始終わいてるわけでもないのです」「しかし水はたしかに呑まされんと命じてあるのです」争ひにはてしなければ終には炊事場に番兵を立たしむるに至りぬ。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の花やお正月の雨がしみ／″＼・お正月の鉄鉢を鳴らすまた／＼人が来て金の話をしていつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十七年十二月三十日追記竹田博士の招待にて秀と共に初めて大阪文楽座を観る文楽やでく泣きむせぶ春の霄でく泣くにますらを我も泣きにけり亡びなむ芸とも見えず三業のにほひとけゆく春のゆふぐれ三月十三日福井君に寄すまた来ませいのち短き人の世のいのち短き春なれば。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "手おくれになったら、これは後から言訳がたちまへんさかいな」　署長は、ドクトル邸の燃える白骨事件で、黒星一点を頂戴したのに、この上みすみすまたたどんを頂戴したのでは、折角これまで順調にいった出世を躓かせることになるし、住吉警察署はなにをしとるのやと非難されるだろう辛さが、もう目に見えていた。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あすの朝になれば一体あまさず引取つてもらへるのだから、浄めはまあそれからでもいいではないか、と司祭さんは一おう制したさうですが、「それは如何にもそれに違ひはないが、現に日ましに烈しくなる空襲の模様をみると、あすまたどのやうな事がはじまるものやら分つたものではない。",
              "citation": {
                "source": "死児変相",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は、「とうとう雪子に負けた」と席を外して、宗助の方を向いたが、「どうですまた洞窟へでも引き込みますかな」と云って立ち上がった。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "倒行して逆施すまた可ならずやと云うような事を言っているかも知れない」「なんでござんす、それは」「いえ、何でもないのです。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "お国さんは「あすまた遊んでちやうだいえも」といふ伯母さんに　さやうなら　をして帰るみちみち「かいろが鳴いたからかーいろ」といふ。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕はあすホフラーコワ夫人のところへ出かけますし」とアリョーシャは答えた、「それにカテリーナ・イワーノヴナのところへも、今晩もし留守だと、あすまた行くかもしれません……」「じゃ、これから、やっぱりカテリーナ・イワーノヴナのところへ行くんだね？",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばあさま、我等に向って、「今日は早くけえって、あすまた遊びにおいで。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "また槍や、さすまた、袖搦み、などという道具のほかに、鉄炮が（関所の格によって数の差はあるが）並べてあり、これはその係りの者がいて、中の一｜挺だけはつねに弾丸を充填し、いつでも火繩がかけられるようになっていた。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧野の一戦、血、杵を漂わす朝歌一旦、紂君を誅すまた見ずや高陽の酒徒、草中に起こる長揖山中隆準公高く大覇を談じて人耳を驚かす二女足を濯うて何れの賢に逢わん……　玄徳は、そのまま、雪に埋もれかけてゆくのも忘れて、じっと、聞き惚れていた。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
