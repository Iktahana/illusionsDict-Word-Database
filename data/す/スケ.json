  },
  {
    "uuid": "6c7546fc-b8b7-5f89-a9b7-3ab9d62f7b7a",
    "entry": "スケ",
    "reading": {
      "primary": "スケ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "助数詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "square millimetre (of the thickness of a cable)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところが、それから五六日して、上野動物園で貘の夫婦をあらたに購入したという話を新聞で読み、ふとその貘を見たくなって学校の授業がすんでから、動物園に出かけていったのであるが、そのとき、水禽の大鉄傘ちかくのベンチに腰かけてスケッチブックへ何やらかいている佐竹を見てしまったのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お話したいことがあるのです」へんによそよそしい口調でそう言って鉛筆を取り直し、またスケッチにふけりはじめた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそのうしろに立ったままで暫くもじもじしていたが、やがて決心をつけてベンチへ腰をおろし、佐竹のスケッチブックをそっと覗いてみた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕のスケッチをいちまい二十円くらいで、何枚でも買って呉れるというひとがあるのです」にやにやひとりで笑いだした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「嘘ですよ」一陣の風がスケッチブックをぱらぱらめくって、裸婦や花のデッサンをちらちら見せた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ルフラン附きの文章か」つまらなそうにそう言って、スケッチブックをぱちんと閉じた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はバスケットを車室に置くと、その方へ行つてたのでその吹き出してるところも見せられた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺の詩万歳だ」　彼はバスケットから葉書を出してさう書いて母に送つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規一派の俳人たちは、詩からすべての主観とヴィジョンを排斥し、自然をその「あるがままの印象」で、単に平面的にスケッチすることを能事とする、いわゆる「写生主義」を唱えたのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の断じて立言し得ることは、蕪村が単なる写生主義者や、単なる技巧的スケッチ画家でないということである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スケッチ風のさらりとした句で、しかも可憐な詩情を帯びてる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……王の射手エーナール・タンバルスケルヴェはエリック伯をねらって矢を送ると、伯の頭上をかすめて舵柄にぐざと立つ。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "有田については陶器よりも別な珍奇なものが頭の中のスケッチブックに記録されている。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は東寺に先祖の一海和尚の墓に参って、室戸岬の荒涼で雄大な風景を眺めたり、昔この港の人柱になって切腹した義人の碑を読んだりしたが、残念ながら鯨は滞在中遂に一匹もとれなくて、ただ珍しい恰好をして五色に彩色された鯨漁船を手帳にスケッチしたりしただけであった。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鯨絵巻の写しや、硯石で昔から知られた行当岬のスケッチや、祖先の出身だという一世一海和尚の墓の絵などが郷里の家に保存してあったはずであるが、いつの前にかもう無くなってしまったか、それともまだ倉の中のどこかに隠れているか不明である。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶をのんで粗末なビスケットを二つ三つかじる。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は毛布をかけてねたまま手を出してビスケットを取って食っている。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "千の天使が　　バスケットボールする。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "十幾階の角形の建築物や、工場の煙突の上に、白蝶の翼をひろげたように、雪の粉を吹いて、遠くはこんもりと黒く茂った森、柔かい緑の絨氈を畝ねらせる水成岩の丘陵、幾筋かの厚襟をかき合せたカスケード高原の上に、裳裾を引くこと長く、神々しくそそり立つ姿であった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "茨木君は途々腰に挟んだ矢立から毛筆を取り出して、スケッチ画帖に水墨の写生をされた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "シエラ・ネヴァダの連峰が概して富士山を抜くこと、二千尺の高さがあっても、カスケード火山に、氷河脈が寒剣をきらめかせていても、小社一つ建たず、石塔一つないではないか。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "月見草の花が白い、カケス畑を知らぬ間に過ぎて、自動車はスケッチ帳入りの小嚢を手に下げた茨木君と私と長男隼太郎外、強力一人を大野原に吐き出して、見送りのため同乗せられた大山さんと、梅月の主人をさらって、影を没してしまう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その私たちの登山にしてからが、時間不足のために、絶頂の剣ヶ峰ともいうべき、シャスタ・ピークまでは、達しなかったのだから、一個の予察地形図をスケッチしたぐらいの、軽い気分で読んでいただきたい、何も登山記だからと言って、死に身になってコチコチと緊張しなければならない、というものでもなかろう。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にはバスケット、足には下駄とな。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、座席へバスケットを置くと、そのまま食堂車に入った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が、彼が座席の上に置いてあったバスケットは、そこに無かった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてな、俺のバスケットをどこへ持って行きやがったんだろう。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスケットの中味を覗いたのたあ違うかい？",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃお前のバスケットかい？",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
