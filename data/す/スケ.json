    "definitions": [
      {
        "index": 1,
        "gloss": "assistance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "煉瓦塀に春を発見した福助人形の影法師孤児の下駄が置き忘れてありました公園の入口ペンキのはげた立札心よ！",
              "citation": {
                "source": "（風船玉の衝突）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "車が芝南寺の少し手前まで来ると、助手台に乗つてゐた谷丹三の親友が、急に停車を命じた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "全集が弘く読まれる事を希望しつつ、広告の一助にもと一寸一言申述べます。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔洪積の台のはてなる〕宮沢賢治洪積の台のはてなる一ひらの赤き粘土地桐の群白くひかれど枝しげくたけ低ければ鍛冶町の米屋五助は今日も来て灰を与へぬ。",
              "citation": {
                "source": "〔洪積の台のはてなる〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなたにてきらめく川やさてはまた遠山の雪その枝にからすとまればざんざんと実はうちゆるゝこのときに教諭白藤灰いろのイムバネス着ていぶかしく五助をながめ粘土地をよこぎりてくる",
              "citation": {
                "source": "〔洪積の台のはてなる〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり我が国では、技術家も猶多分に政治家である場合に助かる。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければ、無器用朴訥な愛嬌で助かる。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいかオイ……あんな奴と共同で仕事をして好いことがないのは分りきつてらあ……いいかオイ、俺が出来るだけは助けてやるからなあオイ」「うんうん」　それから猶暫らく彼は同じやうなことを繰返してゐたが、やがて其処を出ようと云ひだした。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物を、運転手と僕とで運び入れて、運転手と助手とが帰つて行くと、僕一人になつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の船は小さかつたであらうし、船はまた非常に揺れて、母も吐き出したのださうだが、不思議に祖母が元気で助かつたのださうである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人跡絶えた山道には、人力車の通う術もなかったので、二人の若い男女は、互に助け合いながら、蔦葛の這う細道を、幾時間となくさまよい歩いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして気味わるく物凄い顔をした、雲助のような男たちに脅やかされたり、黒塚の一軒家のような家に泊って、白髪の恐ろしい老婆に睨まれたりした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンにとっての夫人は、この世にただ一人の愛人であり、永久に『可愛い小さいママさま』であったと共に、またその仕事の忠実な助手でもあり秘書でもあった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は佐藤春夫、室生犀星、北原白秋、千家元麿、高村光太郎、日夏耿之介、佐藤惣之助等の諸君の詩を、たいてい忠實に讀破してゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真暗いので、どんなに助かるかわからない。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場は助かったようであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "危機一髪、団子鼻に墮そうとするのを鼻のわきの深い皺がそれを助けた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの凄惨な一声で、この団欒が滅茶々々になるのだ、と思ったら喉まで出かかった「助けて！",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたにも御助力ねがいたい。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先方の宛名は、小坂吉之助氏というのであった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、玄関の式台には紋服を着た小坂吉之助氏が、扇子を膝に立てて厳然と正座していた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも、いまは、イタリヤ製のいい薬があるそうですし、それに先方の小坂吉之助氏だって、ずいぶん見事な、――」「それは、としとってから禿げるのは当りまえの事だが。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はあ、」小坂吉之助氏は平気である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいわい、山崎氏には、浅見、尾崎両氏の真の良友あり、両氏共に高潔俊爽の得難き大人物にして帷幕の陰より機に臨み変に応じて順義妥当の優策を授け、また傍に、宮内、佐伯両氏の新英｜惇徳の二人物あり、やさしく彼に助勢してくれている様でありますから、まずこのぶんでは、以後も不安なかるべしと思います。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の女を私から奪略した男の所へ、女が行くといふ日、実は私もその日家を変へたのだが、自分の荷物だけ運送屋に渡してしまふと、女の荷物の片附けを手助けしてやり、おまけに車に載せがたいワレ物の女一人で持ちきれない分を、私の敵の男が借りて待つてゐる家まで届けてやつたりした。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃ち類推はそれが十分に行はれない場合の補助手段である。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "福助座が見たいと思つた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "福助座は私がゐた当時の、金沢第一等の劇場であつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストーブの上の薬鑵の湯気をみ入つてゐる時、「電車の救助網にでもかゝつて、今怪我をして病院にゆくとすれば、Ｓ子が見舞に来るんだ……」つてな夢みたいなものを鼻の上で小踊りさせた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼の頭にはさういふ強い印象が刻まれただけだつた、彼は電車の救助網の厄介に早速なつたのだ。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
