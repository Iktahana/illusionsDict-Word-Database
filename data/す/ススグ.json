    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to rinse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "暖かくいつくしみて花を咲かす春の光、燃え焦がし爛らす夏の輝き、寂寥と悲哀とを抱き脱がれて汚れを濯ぐ秋の照り、萬物を同色に化す冬の明り、彼の眼は太陽だつた。",
              "citation": {
                "source": "杉よ！　眼の男よ！",
                "author": "富岡誠",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして置いてあとは充分絞つて石鹸水を切り、最後に桶の中に入れて水で濯ぐのである。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「洗濯ぐらいしてやったらどうだ。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍僕等は、ギーウのために、手を濯ぐものと、新たな酒肴とを運んだ。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水で顔をぶるんとするのであるが、二つあるトタンの洗面器は床にかける雑巾を濯ぐのと共同である。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒を飲んで石に及ぶと雖も、水をもって沙を濯ぐが如き者であったというのであるから、浴びるほど飲んでいたのであろう。",
              "citation": {
                "source": "酒渇記",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「自分のお腰の洗濯ぐらゐ、何で福子にさゝれまへん、なあお母さん。",
              "citation": {
                "source": "猫と庄造と二人のをんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「自分のお腰の洗濯ぐらい、何で福子にさされまへん、なあお母さん。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "劉氏は人の妻なればひとりとり出しわがころも濯ぐべき人もとめねば糸目もふるし古ごろも、秋の灯かげにすわるとき新らしく着る古ごろも膝なる汚点はわりなくもいみじき汝を怨めとぞ。",
              "citation": {
                "source": "我が一九二二年",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、この汚名を濯ぐ爲めに、私は一體何をすることが出來るのか？",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし濯ぐべき衣類食器などあればついでに洗う。",
              "citation": {
                "source": "島守",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "知識でこれを濯ぐのではいけない。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "高さ三寸ぐらいの紫圧製の獅子頭の口を開けると、その中に象牙の丸彫で頼光大江山討入りの光景、峨々たる山中の険路を頼光以下四天王が進み行き、渓流に衣を濯ぐ女に途を尋ねるところ、人物は五分に足らぬほど、しかも山伏姿の主従、容貌風采まことに巧緻を極めたもの。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "是で盃を濯ぐことをアラタメルと謂ったのも、もとは別の盃にするという意味で、「金色夜叉」の赤樫満枝という婦人などが、「改めてございませんよ」と謂って、盃を貫一にさしたのを見ても判るように、本来は同じ盃の中のものを、分ち飲む方が原則だったから改めなかった。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊佐子さんばかりでなく、奥さんまでが本当にそう信じているならば、山岸のために進んでその寃をすすぐのが自分の義務であると思いました。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "広巳はそれを飲んで盃洗ですすごうとしたが、すすぐものがないので躊躇した。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はすすぐことの出来ぬ汚れを身に受けた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　買物の都合で、東京まで帰り、あすすぐ来るというのは、何でもない事かもしれなかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その正体を見とどけた喜平らは岩見重太郎の二代目とまでは行かなかったが、ともかくも弱虫の汚名をすすぐことが出来たので、大手を振って町内を押しあるいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "もやしでも何でも、少々の肉類、玉葱のいい加減にきざんだもの、それを皆一緒に豚油をとかしたものでいため、だしを入れて塩と砂糖、醤油で好みに味をつけ、下すすぐ前にサラダ菜をむしって洗っておいたものをほどよく手でちぎって入れ、ぐったりしたところですぐ下します。",
              "citation": {
                "source": "十八番料理集",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物のために不行儀もできず、人の驚異とする高いにおいをなくしたいと思ったが、すすぐことのできないのに苦しんでいるのも滑稽であった。",
              "citation": {
                "source": "源氏物語",
                "author": "橋姫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地の生み出すすぐれたものには、矢張り絵描き風情の筆先で、生み出したものなどは、及び難い――片里どの、それなる画面は、決してわしの創り出したものではない。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "中尾氏等の為冤をすすぐ次第に候う云々。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでながら、森口君の頒暦師中尾氏等は由緒正しい旧家であって、決して唱門の仲間ではないから、その冤をすすぐようにとの注意を辱うしたことについて一言したい。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒檀の森わけて、白檀の峰越えて、菱の葉うかべる沼にし杖すすぐ阿闇黎に問ひ、苔の花さく古井に阿伽を掬む尼に問へど、怪しみがほの答へに、『知らでや』と過ぎぬれば、脚絆ぞあだに破れ朽つる。",
              "citation": {
                "source": "信姫",
                "author": "末吉安持",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れた石鹸水を棄てて、また温湯をみたしてすすぐ。",
              "citation": {
                "source": "捨てる文化",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君の御憤りを安め、父の恥をすすぐため、戦いを挑んで以来、平家を亡ぼすことは予想通りでござったが、まさか、そこ許とかように対面できるとは夢にも思わなかったことじゃ。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな陶器でも洗いすすぐという事は怠らない、指紋とか手ずれとかはそれを買った時に、洗い落して生地を清めてから眺めるのである。",
              "citation": {
                "source": "陶古の女人",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "川で口をすすぐと歯にしみて、目がさめる。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、みんなが彼に、領主がメルゲルの汚名をすすぐために、故意に噂をひろめた話をすると、緊張して耳をすましていた。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
