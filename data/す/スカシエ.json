          "standard": [
            {
              "text": "額装された透かし絵を後ろからライトで照らすと、幻想的な風景が浮かび上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は透かし絵の技法を駆使して、奥行きのある不思議な絵画作品を制作している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供と一緒に、和紙を切って重ねる簡単な透かし絵を作って遊んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それは、白夜がはじまろうとする白っぽい光の中で、島の頂きを覆う金色の輪が、暈のように広がり縮んでいて、それは透かし絵の、影像のように見られたのでした。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
