    "definitions": [
      {
        "index": 1,
        "gloss": "star (actor, athlete, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "名詞の換言で日が暮れようアスファルトの上は凡人がゆく顔　顔　顔石版刷のポスターに木履の音は這ひ込まう",
              "citation": {
                "source": "春の日の怒",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたたび私は、すごすご出発点に引返して、全身くたくたに疲れ、ぜいぜい荒い息を吐きながら、スタートラインに並んだ。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣りはタカヂアスターゼの兄さんか弟の家で、子供が八人くらゐゐて、ひどく賑かだつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝が来るたびに、隣りのタカヂアスターゼの下から三番目の子供が、「イチオー………コイマー」と何度も／＼呼ぶのであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで妻君は一流の三四人中に数へらるべき所謂スター女優なのである。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "スチクレスタードの野の戦の始まる前に、王は部下の将卒の団欒の中で、フィン・アルネソンのひざを枕にしてうたた寝をする。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその水車風景は、コンスターブルの油絵で見たものとは遠く、小林清親が水彩画から新工夫をして描き上げた、富士を背景とした静岡竜宝山の水車風景の版画（明治十三年版）の方が、ぴたりと胸に来た。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "役場と産業組合と国民学校の対抗リレーで、スタートには村長と、組合長と、校長とが並んだ。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーターマスターは、メーツに、「どうもおかしい」旨を告げた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "――尤も、コーターマスター達は、神経衰弱になるほど骨を折った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ等あ」　ブリッジを歩きまわっていた、一運（一等運転手）は、コーターマスターに云った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「揃って帰っちまやがったじゃないか」　コーターマスターは、コムパスを力委せに蹴飛ばしながら、「サア」と、気のない返事をした。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかしいじゃないか、おい」　一運は、チャートルーム（海図室）にいる、相番のコーターマスターを呼んだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オーイ」　相番のコーターマスターが、タラップから顔を覗かすと、直ぐに一運は怒鳴った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーターマスターは、「おもて」へ入った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーターマスターは、ボースンの耳へ口をつけた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを誤算したフランスの一映画会社が彼女をスターにして大仕掛けのフィルム一巻をこしらえた。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えゝ、けれど、ごらんなさい、そら、どうです、あの立派な川、ね、あすこはあの夏中、ツヰンクル、ツヰンクル、リトル、スター　をうたってやすむとき、いつも窓からぼんやり白く見えてゐたでせう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この仕事にはアーサー・シュスターが加担し、シジウィック夫人も手伝った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この室の両窓にヘリオスタートを取付け、ここへ分光器その他の光学器械を据え付けた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇〇年マンチェスターでの講演では飛行機の原理を論じ、ヘリコプテルや垂直スクリューにも論及した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後ウェストミンスター・アベーに記念の標石を納めようという提議が大学総長や王立協会会長などの間に持出され、その資金が募集された。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃は日本人の顔がだんだんに西洋人に似てくるようで、銀座などを歩いているとあちらの映画スターに似たような顔つきをした男女を見かけることも珍しくないがただ髪の毛だけは、当り前のことだが皆申し合せたように真黒である。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四に近頃やられたのはロチェスターの外科医ウィーゲル博士だという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年二月四日『東京朝日新聞』）　　　　　　　　　六十四　　　　　　煤煙問題　ロンドン地下電鉄会社の発電所で焚く石炭の煙がウェストミンスターの町へ掛かって損害を与えるというので、同市会から会社を相手取って訴訟を起した。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではとお小夜、Ｔ「あたしはこの道から」　なりひらが、Ｔ「俺はこっちから」　半次が、Ｔ「何っちが早いか馳けっくら」　で、なりひらとお小夜がスタートに付く。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "数時間後、僕は岡山で下車すると、巡業中の歌劇団のポスターを横眼で見ながら、車を硝子張りの、「金髪バー」の前でとめて、酒杯の中に沈んで行った。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず現代でいちばん実用的な描写法としては世界的に知れ渡った映画スターなどのいろいろなタイプを借りて記載するのが近道であろうかと思われる。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いてみるとそれがみんな活動俳優のいわゆるスターだそうである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在ではただ与えられたいわゆるスターの生地とマンネリズムとを前提として脚色はあとから生まれるから、スター崇拝者は喜ぶであろうが、できたものは千編一律である。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
