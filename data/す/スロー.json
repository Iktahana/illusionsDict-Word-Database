    "definitions": [
      {
        "index": 1,
        "gloss": "slow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "現象を記載するだけが科学の仕事だというスローガンがしばしば勘違いに解釈されて、現象の背後に伏在する機構への探究を阻止しようとすることがあるような気がする。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小初は掘り下げた櫓台下の竪穴から浅瀬の泥底へ水を掻き上げて行くと、岸の堀垣の毀れから崩れ落ちた土が不規則なスロープになって水底へ影をひくのが朦朧と目に写って来た。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々のスローガンはこうでなければならぬ。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中野重治の「鉄の話その一」には、Ｘの掲げるスローガンを具体的な主要なテーマとしてたくみに、えん曲に生かしている。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「臥薪嘗胆」なるスローガンは、国内大衆の意識を次の戦争へ集中せしめた。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは排日委員会で決議されたスローガンの一ツだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高速度活動写真でとった、いわゆるスローモーションの競走映画で見ると同じような型式の五体の運動を、任意の緩速度で実行できるかというと、これは地球の重力ｇの価を減らさなければむつかしそうに思われる。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも正当なソナタやシンフォニーのように四楽章から成る場合だと、第一章が通例早いテンポのソナタ形式のもの、第二章がいわゆるスロームーヴメントで表情豊かな唱歌形式のもの、第三章が軽快な舞踏曲のようなもので、往々｜諧謔的なスケルツォが使われる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「静かにお帰りください」で引き上げる狩人たちのスローモーションは少し薬がきき過ぎた形である。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、明日は托鉢しようか、魚釣しようか、もし其中庵にスローガンがあるとしたならば――「今日は托鉢、明日は魚釣！",
              "citation": {
                "source": "鉄鉢と魚籃と",
                "author": "――其中日記から――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、おかあさんという人はスローモーションで、どうにも振り廻しにくいですからねえ」　むす子は唇をちょっと噛んで、面白そうに、かの女を額越しにちょっと見た。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は自分の理論性や熱情を、一応否定したり羞恥心で窪めて見るのを、かの女のスローモーション的な内気と、どこ迄一つのものかは、はっきり判らなかったが、かの女は自分の稚純極まる内気なるものは、かの女の一方の強靱な知性に対応する一種の白痴性ではないかとも思うのである。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれが、この男に残された唯一の、せめてもの、行為のスローガンになっていたのである。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "真昼なり、街道のバスの埃、スロープのさみどりに開く※、ああ、八月。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊皇攘夷の代りに、今や公武合体といふスローガンが尤もらしく振りまはされ、幕府は朝廷を擁して、天下の諸侯に昔日の威を以て臨まうとしてゐる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "新劇「レ・ミゼラブル」は、見ないけれども、おそらくたった一口で言えるようなスローガンを頑強にべたべたと打ち出したものかと思う。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はちきれるばかりの精力に満ちた青草は、小屋の裏から起こるなだらかなスロープを、渦を巻き巻き埋めつくしていた。",
              "citation": {
                "source": "土竜",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑のスロープも、高地になるに随って明るく、陰影が一刷毛に撫で下ろされた。",
              "citation": {
                "source": "土竜",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで効いてくるのが、急いで仕事をしろといったって、どうせ人間の処理能力など機械から見れば極超のスローモーションである点だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから『子供のために金』というスローガンはいいさ。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁には争議のスローガンや、組合本部からの激励文、ファッショがかつた文字を書いた張紙などが、壁に所狭いまでに張られてあつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし神泉の真の作家的歩みの興味ある点は、その足取りがおそろしくスローモウションなところであり、能芸術のやうな動きなのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとスローモーションで結構だから、描く対象と取り組んだ仕事をしてほしい。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チエック、スローバック」援助ノ口實ノ蔭ニ國家ノ當然ナル權利ヲ隱蔽スルガ故ニ野心ヲ包藏ストナシテ敵味方ノ警戒ヲ受クルナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふの隅では、これもたつた独りで丘のスロープの上に立上つて、大声を張り挙げて切りに何か怒鳴つてゐる者もあつた。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　柾生と肩をならべ、体育館敷地のスロープをくだっているとき、慶一は、このキャンパスに起こった、ささやかな変化に気づいた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまでは体育館下の、片側がグラウンドにむかって開いたトンネルになっている、かつての通学路のスロープをのぼりきって、右に視線を移動すると、ジャングルのようになった、グラウンドのむこう端を見わたせる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」というのがスローガンである。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "遥かの松林のスロープから、網干の風景をスケツチしてゐた Authony の竹下も、驚いて鉛筆をおいて立ちあがつた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "汀に立つてゐるお雪とスロープの草原に起きあがつた僕との距離は五六ヤードであつた。",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
