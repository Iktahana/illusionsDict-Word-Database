        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "素晴らしき主よ、我々の魂にどうかご慈悲を！",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "素晴らしき実験　彼は、別人のように活撥になっていた。",
              "citation": {
                "source": "生きている腸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんと素晴らしき妃となったことか！",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく寝顔の美しいのは優秀な美人の特質と昔から日本ではきめられているのをみても、なかなか素晴らしき寝顔というものはざらにはないものとみえる。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、蛸もあの素晴らしき足の八本を裸のままで見せている事は真に危険だと私は思った。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "以来、なおそれ以上の破格である処の伝統を抜き去ろうと努力した処の革命期の多くの絵画が侵入して素晴らしき発達を遂げたのである。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、展覧会では絵画は背景であり、見本市場であり、競争場であり常設館であるとすれば、勢い素晴らしき存在と人気が若き画家の常識ともなり勝ちだ。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "窮屈な場所で紳士は羅紗のモーニングを着用し、あるいは女は素晴らしき帯を幾重にも胴体へ捲きつけていると、胸も臍も夕立を浴びているにちがいない。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて油絵は金にも変化せず、見せたあとは永久に積み重ねるものとすると、勢い常設館での素晴らしき存在と人気が若き画家の常識ともなりがちだ。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と素晴らしきアイデアではないか。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ションブルーンへ行ったときもあの素晴らしきパゴーラの柱列を透して彼方に山々を眺めるからこそ、白き建築の優雅で堂々たるプロポーションが活きるのだ。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "角々がことごとく嵌め込みになって、これだけの容積の函が浪に揉まれても、海底の岩にぶつかっても、ビクともせず、しかも水一滴浸透している形跡がないのであったから、これを造った大工の腕前というものは、けだし実に素晴らしきものであったろう。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はすばらしき勇氣を以て、獅子のやうに身構へて居る。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴下の設計になる音楽浴は、すばらしき効果をあげています。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、いつもいふとほりに、名探偵らしくじつくりこれを觀察してゐれば、やがて祕密の扉を開くべきすばらしき鍵を發見することができ、思はずにつこり微笑まるることであらう。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、いつもいうとおりに、名探偵らしくじっくりこれを観察していれば、やがて秘密の扉を開くべきすばらしき鍵を発見することができ、思わずにっこり微笑まるることであろう。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは一面すばらしき詩人でもある。",
              "citation": {
                "source": "錯覚自我説",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "すばらしき芝生、　種々の樹、面白い熱帯植物の葉の形、闊いの、細いの、這い廻るのなど、アンリー・ルソーの虎の絵はいかにもよく熱帯の葉の変化の美を感じて居る。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの変形に、チェスタートンの「秘密の庭園」やライス夫人の「すばらしき犯罪」の型がある。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "終って、東宝支社の試写室へ、東亜商事の好意で「ブルグ劇場」を見せて貰ふ、すばらしき映画、実に唸った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
