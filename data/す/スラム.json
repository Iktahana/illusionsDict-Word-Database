              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "菩薩蠻とはイスラム教徒を指す所の Mussulman 又はそれを訛つた Bussurman の音譯である。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            }
          ]
        }
