    "definitions": [
      {
        "index": 1,
        "gloss": "stamp",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "局員はあわただしげにスタンプを捺し、人人は窓口に群がつてゐる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいにくに又そのスタンプがあいまいで、発信の郵便局もはっきりしないのです。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きるものの証である生命のパスポートの最終ページには、地獄行きか天国かは知らないが、ともかくもあの世行きの出国スタンプがあらかじめ押してある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "止むを得ず、一番たくさん飼っていて、一番沢山減った、飼主が、一匹ずつ引っ捕まえて、スタンプ用の赤インクを、ベタベタと背中へ塗りつけたのだった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはここで絵葉書を買って記念のスタンプを捺して貰いました。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "円い大きいスタンプのような寺の判を捺した領収書を貰うと彼女はすぐに其処を出た。",
              "citation": {
                "source": "棄てる金",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　紫色のスタンプなぞは、まだ見られないのだった。",
              "citation": {
                "source": "議事堂炎上",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお登り木曽駒頂上小屋着、焼印を押し絶頂へ、多くの祠あり、参拝御守を戴き、三角点にて、万歳三唱、眺望よからむに霧にかくれて何物も見えず、右へ主脈を進み中岳を経て、宮田小屋着、三時絵葉書焼印スタンプ等を押し前ヶ岳の三角点に行き万歳三唱し引返し宿泊せり。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人差指のない男が人参や大根を刻む金物を売っていたり、八十八ヶ所めぐりのスタンプ帳を売っている所なぞ、私は歩きながら子供のように面白かった。",
              "citation": {
                "source": "貸家探し",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物を税関に運んで、調べて貰ふ間にパスポートにスタンプを押して貰ひました。",
              "citation": {
                "source": "シベリヤの三等列車",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタンプには六月二十一日の消印が押されていた。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この親爺は信吉が字がよめないもんだから、この前も、何だかスタンプ押した紙を見せて警察がどうとかだから一ルーブリ五十カペイキ出せと云った。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝アリゾナから出した、こんな手紙が妻から届きました」　と、上着のポケットから取り出した手紙は、十月十七日発のもので、スタンプの時間から判断すると、ルウスは女二人を殺した直後、この手紙を書いたものらしいのである。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "切手には例の通り「山代局」のスタンプで、六月十八日の日附があった。",
              "citation": {
                "source": "仙人掌の花",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "切符の日附のスタンプが5, 5, 5, と三つ並んでゐたので、忘れることができないのだ。",
              "citation": {
                "source": "暗い青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、変電所主任土岐健助宛の無名の手紙から足がつき、スタンプの消印で栃木県今市附近に国太郎が潜伏していると判ったのである。",
              "citation": {
                "source": "白蛇の死",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅学士は前にエスペラント語をすこし勉強したことがあったので、博士の会話内容がわかっただけに、正邪曲直いずれを博士の上にスタンプすべきかに悩むところが甚だしかった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏蘭西の出国スタンプ。",
              "citation": {
                "source": "踊る地平線",
                "author": "長靴の春",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊太利入国スタンプ。",
              "citation": {
                "source": "踊る地平線",
                "author": "長靴の春",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒐集狂の一スタンプ一切手一レッテルの存在価値がどの理由から一人の蕗子に劣るであらう！",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "其仕度といえば、お山の大きなスタンプがべたべた捺してある例の白装束で、無論この大事な装束を洗濯する筈はないから、汗臭芬々として馬車にでも同乗しようものなら、全く辟易せざるを得ない。",
              "citation": {
                "source": "登山談義",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、他の書留便に移る寸隙を見て、切手の上に日付のスタンプを捺して前の籠にポンと抛り込む。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼女自身の蔵版とみえ、袋に「うきよぶし家元、石田美代事　初代　橘之助」と紫色のスタンプインクが押してあり、内容な年少断髪の高座姿（圓朝賛、圓橘画）とやや老けている時代と、そうして晩年に近いあの姿とである。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は英字で『スタンプショップ』と書き、日本字で『印章速応』と書いた厚紙の看板を柵にぶらさげ、川べりで釣りをたれて魚のくひつくのを待つこゝろで、静かに照り輝く小春日和の下に時をすごしたが、第一日は全く何の手ごたへもなかつた。",
              "citation": {
                "source": "老残",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キャン、ユー、メーク、スタンプ？",
              "citation": {
                "source": "老残",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな数字のスタンプをこしらへてくれるか……どのくらゐの時間でできるか、料金はいくらだ、と訊ねてゐます」と画伯が通訳の労をとつてくれたので、私は皮きりとして最初の註文に応じたわけだ。",
              "citation": {
                "source": "老残",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が註文をうけた数字のスタンプは M-3194 といふナンバーであつたが、かうした数字のスタンプを彼等は被服類その他におすために入用らしい。",
              "citation": {
                "source": "老残",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
