[
  {
    "uuid": "9d609281-7bbe-5055-9581-f45d78c7c2ba",
    "entry": "睡魔",
    "reading": {
      "primary": "すいま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sleepiness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "が、何時か私も襲つてくる睡魔を堪へきれなくなつてゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日出雄少年は、其泉の流に美麗なる小魚を見出したとて、魚を追ふに餘念なき間、私は唯ある大樹の蔭に横つたが、いつか睡魔に襲はれて、夢となく現となく、いろ／＼の想に包まれて居る時、不意に少年は私の膝に飛皈つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごはんを食べてしまって部屋に一人で端座していると、さむらいは睡魔に襲われるところとなった。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かみの毛ながきあなたのそばに睡魔のしぜんな言葉をきくあなたはふかい眠りにおちわたしはあなたの夢をかんがふこのふしぎなる情緒影なきふかい想ひはどこへ行くのか。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてともすれば肉の締りがほぐれて行くやうな氣持がして、快い睡魔が何時となく體を包んで行くのである。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "睡魔を感じながらも、私は何故か眠りつけなかつた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　睡魔と闘うくらい苦しいものはない。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "考える力もなく、よろよろと迷いに迷うて行く頭が、ふと逃げ込んで行く道の彼方には、睡魔が立ちはだかっている。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中、疲労と睡魔が襲って来ると、以前はすぐ寝てしまったが、今は無理矢理神経を昂奮させて仕事をつづけねば、依頼された仕事の三分の一も捗らないのである。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜の紙帳は広くして、我と老侠客と枕を並べて臥せり、屋外の流水、夜の沈むに従ひて音高く、わが遊魂を巻きて、なほ深きいづれかの幻境に流し行きて、われをして睡魔の奴とならしめず。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上にのぼり尽きたるは真午の頃かとぞ覚えし、憩所の涼台を借り得て、老畸人と共に縦まゝに睡魔を飽かせ、山鶯の声に驚かさるゝまでは天狗と羽を并べて、象外に遊ぶの夢に余念なかりき。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十九男達の部屋の蝋燭は消されいくらか遅れてりん子の部屋の蝋燭も消えた長い時間男達の眼は闇の中で開らかれたまゝであつた男達の瞼を『おやすみなさい――』と柔かい指で睡魔が撫で廻してあるいたが男達の眼は反抗的であつた。",
              "citation": {
                "source": "託児所をつくれ",
                "author": "小熊秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "新米の蜂須賀巡査は、炎熱の中に睡魔と戦いながら、流石にボンヤリ立っていた。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その明滅する灯の下で、鮨詰めの善男善女達が、襲いかかる睡魔を避けようためにか、蚊の唸るような声をあげて、必死とナンミョウホウレンゲキョウを唱えつづけました。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ・Ｃのスプレーで睡魔を防ぎながらヤットここまで書いて参りましたが、もう夜が白けかかって脳味噌がトロトロになりましたから擱筆します。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、やがてのことに、待ちに待つた、あの万人に共通な慰藉である睡魔が彼を訪れた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はだいたい睨み合って、無言の業をつづけていたが、疲労から睡魔の手へ、彼等はなにがなんだか分らないうちに横にたおれて前後不覚に睡ってしまった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うは目ぶたと下目ぶたとがくツつきかけるほど、睡魔は自分の中に押し寄せてゐるのだが、どうしても、一つ、足りないものがあるのを思ひ浮べると、脚下に大きなほら穴が明いてゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠の考へは、かうして、お鳥と敷島と樺太とを幾遍となく巡囘するので、ます／＼睡魔の入り込む透きがない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "少焉して、さあ、睡魔が降伏したら、もう少し遣らうと云つて講説した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤次郎は、健康な肉体が必然に伴って来る烈しい睡魔と戦わねばならなかった。",
              "citation": {
                "source": "夢の殺人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま死のやうな睡魔が彼を捉へてしまつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "打ち克ちがたい睡魔がやがて彼の瞳をとざしはじめ、疲れきつた手足は、今にも知覚を失つて、ぐんなり弛みさうになり、頭が前へこくりと落ちる……。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏教徒は、彼らが長時間の黙想中に、睡魔予防剤として広くこれを服用した。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "睡魔がおそつて來る。",
              "citation": {
                "source": "屋久島紀行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、睡魔はおそつて来る。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも睡魔の襲げきは止まなかった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に来たのは、すいませんが、むしろ学問的な満足感でした。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "すいません大佐、僕のような疫病神に時間を取られてご迷惑かと。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "すいませんが、みなさん、私は家内の部屋へ行って、変わりないか確かめなくては。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
