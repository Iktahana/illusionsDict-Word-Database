        "examples": {
          "standard": [
            {
              "text": "かつてヨーロッパ諸国では、勇敢で忠誠心の高いスイス傭兵が重宝されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "フランス革命の際、王宮を守るために多くのスイス傭兵が命を落とした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スイス傭兵の歴史を学ぶことで、当時の軍事バランスが見えてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "我々の父たちのズボンの（今でもそれはわがスイス傭兵がはいているが）、あの笑うべき形はいったい何を意味したものか。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ウェルギリウス）＊　王党の側ではスイス傭兵を、新教徒側ではドイツ兵を使ったのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
