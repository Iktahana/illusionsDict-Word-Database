    "definitions": [
      {
        "index": 1,
        "gloss": "Sunna (collection of recorded words and actions of the prophet Muhammad)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
