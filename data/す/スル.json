      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to do",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "恐懼修省の工夫が有れば、以て宗廟社稷を守り、以て祭主と為るべきである。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「最早死んだかも知れない」と誰かが気の無い返事を為る。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "無いのが当然で、かく申す自分すら、自分の身が流れ流れて思いもかけぬこの島でこんな暮を為るとは夢にも思わなかったこと。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分達夫婦は最初から母に呑れていたので、母の為ることを怒り、恨み、罵ってはみる者の、自分達の力では母をどうすることも出来ないのであった。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "親を盗賊に為ることは出来ない。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の者を拾ったら直ぐ私の所へ持て出るのが当前だのにそれを自分の者に為るということは盗んだも同じことで、甚だ善くないことですよ。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際自分は放免してくれると否とに関らず、自分には最早何を為る力も無くなって了ったのである。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷も石瓦、古新聞、乃至、懐中は空っぽでも、一度目指した軒を潜って、座敷に足さえ踏掛くれば、銚子を倒し、椀を替え、比目魚だ、鯛だ、と贅を言って、按摩まで取って、ぐっすり寝て、いざ出発の勘定に、五銭の白銅｜一個持たないでも、彼はびくとも為るのではなかった。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これ、馬鹿｜為るでねえ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が不得要領の申立をすれば為るほど、疑惑の眼はいよいよ彼の上に注がれて、係官は厳重に取調を続行した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "△編輯は順番に為ることにしたい。",
              "citation": {
                "source": "鎖ペンを握って",
                "author": "――三月十九日夜――　　山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一日、辛未、晴、若宮辻の人家焼亡す、酉戌両時の間、廿余町悉く灰燼と為る。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "是に於て才子は才を馳せ、妄人は妄を恣にして、空中に楼閣を築き、夢裏に悲喜を画き、意設筆綴して、烏有の談を為る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "加うるに道衍ありて、機密に参し、張玉、朱能、丘福ありて爪牙と為る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生　道を聞くを尚ぶ、富貴　復奚為るものぞ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝孺又｜嘗て筆の銘を為る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "又｜嘗て紙の銘を為る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等の文、蓋し少時の為る所なり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の野原を夏の風が行くに煙が去つた情熱の火が突進するブツカルものもなく――だから不可ない昔からあつたものだのに今新たに起つたものだそれを如何して呉れるい横から眺めてゐるな誰の罪でもない必要ぢやない欲しいだけだ",
              "citation": {
                "source": "情慾",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖書の綱が性慾のコマを廻す原始人の礼儀は外界物に目も呉れないで目前のものだけを見ることでしただがだが現代文明が筆を生みました筆は外界物です現代人は目前のものに対するにその筆を用ひました発明して出来たものが不可なかつたのですだが好いとも言へますから――僕は筆を折りませうか？",
              "citation": {
                "source": "迷つてゐます",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "技巧を考慮する男は吃度価値ある内容を持つてゐます。",
              "citation": {
                "source": "（最も純粋に意地悪い奴）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつらうつらと僕はする……風もある……松林を透いて空が見えるうつらうつらと僕はする。",
              "citation": {
                "source": "蝉",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば夏休みも近づかうといふ暑い日に、唱歌教室で先生が、オルガン弾いてアーエーイーすると俺としたことが、笑ひ出さずにやゐられなかつた。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると先生は、俺を廊下に立たせるのだつた。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると俺としたことが、とど、笑ひ出さずにやゐられない。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれが結果する悲運ときたらだ、いやといふほど味はつてゐる。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "高きより、風のただ中に、思ひ出の破片の翻転するをみたり。",
              "citation": {
                "source": "夏と私",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の日は、干物の匂ひがするよ干物の、匂ひを嗅いで、うとうとと秋蝉の鳴く声聞いて、われ睡る人の世の、もの事すべて患らはし匂を嗅いで睡ります、ひとびとよ、秋の日は、干物の匂ひがするよ",
              "citation": {
                "source": "干物",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "神よ、しかしそれがよく編みなされてゐればゐる程、破れる時には却て速かに乱離することを知つてをります。",
              "citation": {
                "source": "我が祈り",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "……２恋人よ、その哀しげな歌をやめてよ、おまへの魂がいらいらするので、そんな歌をうたひだすのだ。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
