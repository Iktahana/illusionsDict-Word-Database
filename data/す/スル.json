[
  {
    "uuid": "dbdc7b1b-bf1a-565e-b13e-f740b98fff2e",
    "entry": "為る",
    "reading": {
      "primary": "する",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-する"
      ],
