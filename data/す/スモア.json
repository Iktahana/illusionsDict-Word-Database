        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "相手のフランク・チェイスモアは、かつて美男子だったに違いないが、後年大事故に会って、乾燥クルミみたいな傷跡が残り、視力も失っていた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君の発明品を購入しようと思うんだが」　相棒のチェイスモアは苦笑い。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "技術屋のチェイスモアが答えた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし馬鹿者どもが聞いてくれればだが……」　チェイスモアが怒りの余り、体を震わせた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、機械の借り賃だ」　技術屋チェイスモアが感謝して言うことに、もしあんたがこの機械で掘削すれば、同等機械で一メートル掘るよりずっと短時間で、大量の仕事を行うことができる。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「目的は石油かい」　と技術屋チェイスモアが訊いた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう成功が見える……」　チェイスモアの声が次第に消えた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもグライドは盲人チェイスモアの手を取って平然と進んだ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんでコソコソするんだ」　とチェイスモアがブツブツ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし奴らに見つかれば我々二人の命は一日と持つまい」　チェイスモアが巧妙な嘘に納得した。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は背中にしょって下ろすよ」　盲人のチェイスモアは当然嫌がったが、他に方法がないし、グライドが言うように、そうしないと契約不履行になる。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェイスモアは無言だった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "何から始めるか言ってくれ」　目が悪いため、チェイスモアが敏感な手を使って作業し始めた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう技術者チェイスモアの不安は熱中するあまり消えていた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェイスモアがレバーを引いて言った。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "契約の一部は満たしている」　チェイスモアが両肩をすくめた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "技術者チェイスモアは決して大ぼら吹きじゃなかった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「満足したかい」　とチェイスモアが叫んだ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "グライドが地下モグラのようにこっそり作業している間、チェイスモアはとらぬ狸の二万ドルの大金と名声を夢見ていた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどチェイスモアが眠りから不機嫌に起きた時だった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び目覚めた時、ランプが台上にともり、技術屋チェイスモアがかがんでいた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェイスモアは寝ていた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェイスモアが起床後聞いたのは、実験が成功したので、あしたとりあえず南部へ行って、そこで金を渡すということだった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェイスモアは充分満足して、何も訊かなかった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェイスモアを馬車で送り出すまで気が気じゃなかった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "油井関係者の間で、グライドに相棒がいることを知る者はなく、ましては技術屋チェイスモアが発明品を広く知らせたいと知る者もいない。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって盲人のチェイスモアは決して真実を知り得ないからだ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
