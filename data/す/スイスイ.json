    "definitions": [
      {
        "index": 1,
        "gloss": "lightly and smoothly (of movements)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
