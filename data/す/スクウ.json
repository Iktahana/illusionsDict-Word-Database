[
  {
    "uuid": "4f0c4d98-c75e-57bb-adb7-c35c05d4525b",
    "entry": "掬う",
    "reading": {
      "primary": "すくう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
