    },
    "definitions": [
      {
        "index": 1,
        "gloss": "marbling print",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
