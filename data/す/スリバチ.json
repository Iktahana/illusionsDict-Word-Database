    "definitions": [
      {
        "index": 1,
        "gloss": "(earthenware) mortar (for grinding)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四方樹木にかこまれた、すり鉢形の小盆地で、その真ん中に宏大な屋敷、里の長の住居がある。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すり鉢の底のような独特の舞台に約千人の西｜印度扮装者が一時にあらわれる。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には乱暴にも、煮干をすり鉢ですつて、牛乳に混ぜて飲ましたりする事もある。",
              "citation": {
                "source": "幸福の彼方",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うでた人蔘をすり鉢ですつて、牛乳でどろどろにのばして、その瓶を赤ん坊のそばへ持つて行つてやると、赤ん坊は可愛い足をばたばたさせてよろこんだものだ。",
              "citation": {
                "source": "幸福の彼方",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は鞄の中から小さなすり鉢を取出し、その中へ草の根を入れて、ごしごしとすった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "水中灯をさしつけてみると、例の屋根の下が、すり鉢状の形に大きく深くえぐりとられている。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼんやりしていれば、動きだした砂に足をとられて、ずるずるとすり鉢状の爆発跡にすべりおちるところだった。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に立ち上った焦茶の山脈のすり鉢の底につぶれた広島からなんという奔騰！",
              "citation": {
                "source": "原爆詩集",
                "author": "峠三吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い顎ひげを生やし、四角ばった顔で、豚のような小さい眼をしているものもいれば、また、鼻ばかりでできあがっているような顔をしていて、白いすり鉢形の帽子をかぶり、そのうえに赤い小さな鶏の尾羽をつけているものもいた。",
              "citation": {
                "source": "リップ・ヴァン・ウィンクル",
                "author": "ディードリッヒ・ニッカボッカーの遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "すった味噌をそこに置いて味噌こしをさがしたり、洗ったすり鉢に味噌かすが残っていたり、切って出した香の物にぬかがついていたり、ぬか味噌がぬきとったまま押しつけられずにあったりしては、お汁だてもできない、香の物も出せない女といわれても仕方がないのです。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸くのことで四番手渓の上部に当る尾根の側面に残雪のある所まで漕ぎ付けて、すり鉢状の窪地に野営した。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別害にもならず、むしろ滑稽に近いマジナイは、頭痛のマジナイに、すり鉢をかぶりて、その上に灸を点ずれば治するというのがある。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "箪笥、長持、長火鉢のたぐいから笊、みそこし、十能、それこそすり鉢、すり粉木の末にいたる台所道具一切、それは「もちあそび」とはいえない繊細さ、精妙さをもっていた。",
              "citation": {
                "source": "雷門以北",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが石見のこれらの窯では赤瓦のみではない、大甕を焼き、捏鉢、すり鉢、べに鉢、片口、壺類を焼く。",
              "citation": {
                "source": "雲石紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦と大甕と、壺と、すり鉢とがほとんど一切である。",
              "citation": {
                "source": "雲石紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫より寝候へば、庭のはしりの上に棚あり、すり鉢揚げありしが、飛でおり、棚の下、連子に掛たるすり子木、すり鉢の中へ入、所々すりまわりしが、其内に我寝入る也。",
              "citation": {
                "source": "三次実録物語",
                "author": "稲生武太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中というすり鉢の底を這い廻ってきた順吉は、ねっからうだつがあがらなかったが、それだけにまた虚栄というものにわずらわされない暮しをしてきた。",
              "citation": {
                "source": "夕張の宿",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "いはば、すりばちの底の町である。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すりばちの底に、小さい小さい旗を立てた、それが甲府だと思へば、間違ひない。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋のお祭なんかにはよくそんな看板を見るんだがなあ、自転車ですりばちの形になった格子の中を馳けるんだよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん上にのぼって行って、とうとうそのすりばちのふちまで行った時、片手でハンドルを持ってハンケチなどを振るんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、もうここの里人から、すっかり馬鹿にされて、どしどしお金を捲き上げられ、犬の毛皮を熊の毛皮だと言って買わされたり、また先日は、すりばちをさかさにして持って来て、これは富士山の置き物で、御出家の床の間にふさわしい、安くします、と言い、あまりに人をなめた仕打ち故、私はくやし涙にむせかえりました。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くから見るとまるで洗つたすりばちを伏せて、横つちよに葱でも植ゑてあるやうな、そんなひどく味氣ない島です。",
              "citation": {
                "source": "大島行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その仕掛はすりばち山みたいに、うずたかくつみ上げられていた。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この魚ソースの作り方は、崩したアンチョヴィをすりばちですりつぶす。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、硯箱をアタリ箱といい、すりこぎをアタリギといい、すりばちをアタリバチといい、鯣をアタリメというの類である。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "のちにきけば此秋山にすりばちのあるは此家と此本家のみとぞ。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "此地にて近年豆を作りはじめて味噌をもつくれども、麹を入る事をせず、ほだて汁にするゆゑすりばちはもたざるとぞ。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを易々と請合った道庵先生の返答もいよいよわからないが、なあに、それは最初から、問題のすりばちの中をよく見ておきさえすれば、何のことはなかったのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "日蓮宗のお寺に属する坊さんは、驚いて立ち上る途端に、せっかく丹念に擂鉢にすり貯めて、その余汁をもって、道庵先生の揮毫を乞わんものをと用意していた墨汁のすりばちを踏み砕いてしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
