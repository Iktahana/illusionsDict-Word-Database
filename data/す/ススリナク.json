        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たとえば、すすり泣く女の肩の運動でも、実際の比例よりも郭大された振幅で行なわれる。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人は、自分の心のすすり泣く声が、聞えるような気がしました。",
              "citation": {
                "source": "ペンとインキつぼ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま私の心は涙でぬぐはれ閉ぢこめたる窓のほとりに力なくすすり泣くああこのひとつのまづしき心は　なにものの生命をもとめなにものの影をみつめて泣いてゐるのかただいちめんに酢えくされたる美しい世界のはてで遠く花見の憂鬱なる横笛のひびきをきく。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時にふと盃杯を投げてすすり泣くいとほしやと母も流石思へり。",
              "citation": {
                "source": "短歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳優で言えば、彦三郎、などと、訪客を大いに笑わせて、さてまた、小声で呟くことには、「悪魔はひとりすすり泣く。",
              "citation": {
                "source": "一日の労苦",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いてすすり泣く声が聞えたが、その真先だったのは、お蔦のこれを結った、髪結のお増であった。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジプシイの郷愁がすすり泣くようなメロディとなって、弦から流れた。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十年十二月　　なわすれぐさ面※のにほひに洩れて、その眸すすり泣くとも、――空いろに透きて、葉かげに今日も咲く、なわすれの花。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "声もなき国のさかひにすすり泣くそのゆめよ、水のひとすぢかすかにも色映り消えも入る吐息する時、哀れ、さは光匂はぬ色もなく声もなき野に、ただ寒う涙垂れ熟視めぬる女の思。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "すすり泣くオールトーキ」と歌うように言って、「――ショートタイムで帰った客はないんだから」　色の蒼白い男だが、ペラペラと喋る唇はへんに濁った赤さだった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中になって、宿屋にいた人たちがのこらず寝しずまろうというとき、どこかでしくしくすすり泣く声がして、いつまでもやまないものですから、みんな気にして起きあがって、いったい、たれが泣いているのか見ようとしました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "すすり泣く声がすると、鈴が鳴った。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は居酒屋の卓に伏してゐる夢を見ながら呟き、すすり泣くのであつた、それはまつたく聴き手の歯を浮かせるに適当なヴイオロンの音のやうに。",
              "citation": {
                "source": "「学生警鐘」と風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "恥も外聞も忘れ果てて、大空の下ですすり泣く男の姿を見ていると、そこにはかすかな誇りのような気持ちがわいて来た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六畳に達しないうちに痛ましくすすり泣く声が聞こえ出した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室から貞世のすすり泣く声が哀れにもまざまざと聞こえて来るだけだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の澄み切つた色、それは何に例へたらいゝでせうか、白金にも見えます、金色にも見えます……いやいや色彩に依つて区別することはあんまり定り切つた見方です、音楽にも例へませうか、すすり泣くヴイオロンの音、果てはうち悦べる水の精などの楽しげなる舞踏にも例へませうか。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お梶　（すすり泣くのみにて答えず）……。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "街頭廣小路――日は涙くむ……乞食兒の胡弓のすさび、すすり泣く音に………そことなし燒栗のほのかのにほひ………ゆくさくさ、人ふりかへり『は』と笑ふ、……胡弓のなげき……砂ぼこりふと蓬けだち、跳火して栗は汗ばむ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "寢返りをうち向うむきになつたかとおもふと、かすかにすすり泣くこゑがきこえてきた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　第二の場処「すすり泣くピエロの酒場」――モンパルナス羅典区、〔27, Avenue du Che^neau〕。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行勇気りんりんとして直ぐ二階の一室へ通る――「すすり泣くピエロの酒場」。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎに、ほかの「女優」もすべて、「すすり泣くピエロの酒場」や「人魚の家」やその他の場処で今夜見た顔にすぎないことを知った。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしは、わたしは……いくらお嬢さんでも……」　などとすすり泣くばかりでものもいえないほどでした。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "濡れてくだけてしおしおと、ゆうべさびしい楽屋｜入、鬘衣裳も手につかず、幕の下りると待ちかねて、すすり泣くぞえ舞台裏――　彼女の葬式はすべて抱月氏のにならっておこなわれた。",
              "citation": {
                "source": "松井須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の前が暗くなって、子や孫のすすり泣く声が、だんだん遠い所へ消えてしまう。",
              "citation": {
                "source": "黄粱夢",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑いの影には悲しみが息づき歓楽の背後にすすり泣く悲しみがある。",
              "citation": {
                "source": "千世子（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』――悲しみに堪へぬものから、伏しまろび、胸乳おさへて、すすり泣く、あはれ、袁杼理子。",
              "citation": {
                "source": "春鳥集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま室内にひとりで坐つて暮れゆくたましひの日かげをみつめるそのためいきはさびしくしてとどまる蠅のやうに力がないしづかに暮れてゆく春の夕日の中を私のいのちは力なくさまよひあるき私のいのちは窓の硝子にとどまりてたよりなき子供等のすすりなく唱歌をきいた。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま私の心は涙をもてぬぐはれ閉ぢこめたる窓のほとりに力なくすすりなくああこのひとつのまづしき心はなにものの生命をもとめなにものの影をみつめて泣いてゐるのかただいちめんに酢えくされたる美しい世界のはてで遠く花見の憂鬱なる横笛のひびきをきく。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
