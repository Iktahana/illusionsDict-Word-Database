    "definitions": [
      {
        "index": 1,
        "gloss": "regional pickle of Kyoto made from a turnip-like vegetable",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "みなさんの見ていらっしやる処でもうすぐきっと喧嘩するんだもの。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みなさんの見ていらっしゃる処でもうすぐきっと喧嘩するんだもの。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからすぐきりきりと齒ぎしりをします。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがすぐきっとなられて、だれですか、今のは、正直に手をあげなさいと、見まわされた。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "物凄い叫喚の場処はすぐきた。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だれ、愛愛じゃないのか、愛愛なら何故すぐきてくれない、愛愛じゃないのか」　趙はこう言ってまた透して見た。",
              "citation": {
                "source": "愛卿伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此処から入りますよ」　一つの厳めしい門がすぐきた。",
              "citation": {
                "source": "蘇生",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実は、入港するとすぐきいて見たのですがね。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうだ、彼処に限る、もう屹度啼いているよ、……」　私の追っかけて云う言葉と共に、話はすぐきまった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからその男にひどい目に会わされたんで婿なんか取るもんじゃあないとあきらめた様にして今まで一人身で居たけれ共もう年が年だから今度の話は先が承知するとすぐきめてしまったんだと不幸な娘を持った年寄の父親はうるんだ声で千世子に話してきかせた。",
              "citation": {
                "source": "蛋白石",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃太郎もすぐきじの立ったあとから向こうを見ますと、なるほど、遠い遠い海のはてに、ぼんやり雲のような薄ぐろいものが見えました。",
              "citation": {
                "source": "桃太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野下の青石横町に住んでいたころも、根岸のお行の松のすぐきわに、音無川の前にいたころもそうだった。",
              "citation": {
                "source": "木魚の顔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "正らすぐききわけてどこの車か当てよるが、私にゃてんと分らん」「さア……ちがうようにもあるが……」　遠くの角で聞えたクラクソンにつられて、お縫が店先へ見に出た時、一台の乗用がもう暗くて見えない砂塵を捲きあげながら村道を走りすぎた。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すこし茶を始めたかと思うとすぐきいたふうな月並みをならべてら」ぐらいが聞く者たちの落ちである。",
              "citation": {
                "source": "現代茶人批判",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、「この便所も少し油断をするとすぐきたなくなる。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その窓のすぐきわから斜下につき出た屋根、彼はその屋根によじのぼって、しずかに窓をたたくと、中で小さな灯がつきました。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A DOG OF FLANDERS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きさまの飼い犬があすも口輪をしていなかったらすぐきさまを拘引する。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人にはすぐきゅうくつになる田舎書生の私と、いつも高度のハイカラ趣味を持った白秋との、いんぎんにして礼儀のある交際は、そのまま永い間続いた。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際人間は亡くなっても、それを考えるときはすぐきのうお亡くなりになったとしか思われないくらい近い日を考えるようになるものでございます。",
              "citation": {
                "source": "玉章",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども免れようもない反動はすぐきた。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "その泡はすぐきえてしまいます。",
              "citation": {
                "source": "寂しき魚",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だんだん薬喰いをして置かなければ、寒さでからだが持たなくなるのよ、あれ食べたあと、からだ中が燃え、眼なんかすぐきらきらして来て、何でもはっきり見えて来るんだもの、おじさま、慍らないでね、時どき、いただかしてよ。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐききましたら旅行から今朝かえりました由。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私にすぐきてほしいというのでいってみたら誰もいないでひとりっきりぽつねんとねていた。",
              "citation": {
                "source": "妹の死",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦痛の長びいたのに比べて病名は無造作にすぐきまった。",
              "citation": {
                "source": "胆石",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「べつのおなご先生が、すぐきますからね、みな、よく勉強してね。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがつぎに房子さん（ささき・ふさ）に會ふと、「義ちやんに文藝春秋で使ふといつたら、義ちやんは自分を文藝春秋で使ふとはなにごとだ、といつてゐるばかりか、妹のお嫁にいつたのが戻つてきてるから、田端へすぐきて話を聞いてくれといつてゐる。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            },
            {
              "text": "八ツ橋に五色豆、蕪の千枚漬にすぐき漬ぐらいのものさ」　と霊の糧を扱う星野さんは肉体の栄養物に興味を持っていないらしい。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞広告が、帝劇の新国劇、東宝劇場の少女歌劇ばかり出て、有楽座のが出ないので、新聞係りへ何故出さぬのか理由をすぐきかせろと、言ってやった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
