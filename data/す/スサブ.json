    "definitions": [
      {
        "index": 1,
        "gloss": "to grow wild",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "寝ちゃあいかん、軒下で」　おりからひとしきり荒ぶ風は冷を極めて、手足も露わなる婦人の膚を裂きて寸断せんとせり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "烈風、衣服はおろか、骨も千切れよ、と私たち二人の身のまわりを吹き荒ぶ思い、見ゆるは、おたがいの青いマスク、ほかは万丈の黄塵に呑まれて一物もなし。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜に、雪に、長く鎖された上に、風の荒ぶる野に開く所為であろう、花弁が皆堅い。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "沙漠の嵐吹き荒ぶ北は蒙古、滿洲里亞、見よ、長城の嶮にして八達嶺は雲｜鎭む。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸叩く音は後も撓まず響きたりしが、直行の裏口より出でて窺ひける時は、風｜吹荒ぶ門の梅の飛雪の如く乱点して、燈火の微に照す処その影は見えざるなりき。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝平は吹き荒ぶ暴風雨の音に、耳を傾けながら、チビリ／＼と盃を重ねていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "深谷夫人は頭が痛むと云うので主館に居止り、東屋氏と私と黒塚、洋吉の両氏、そして署長を加えた五人は、強い疾風の吹き荒ぶ中庭を横切って、別館の船室――キャプテン深谷の秘密室へ走り込んだ。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝平は吹き荒ぶ暴風雨の音に、耳を傾けながら、チビリ／＼と盃を重ねてゐた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが男は吹き荒ぶみぞれの中に、どこかへ消え失せてしまった。",
              "citation": {
                "source": "玄海灘密航",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ強風の吹き荒ぶ時であったからたまったものではない。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "不羈奔放な、荒ぶる青春の遊び友だちが一人また一人と次ぎ次ぎに世を去つて、つひにはただひとり彼等の仲間を置き去りにするのも、ちやうどこれと同じではなからうか？",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達が丁度自宅の前辺り迄来た時に、遙かに吹き荒ぶ嵐の中から人の叫声を聞いたと思った。",
              "citation": {
                "source": "琥珀のパイプ",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三弦は暴風雨を招んで、相模の海に荒ぶる、洋のうなりと、風雨の雄叫けびを目の前に耳にするのであった。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "父から子に――人間の種子が必ず一度は流転せねばならぬ生死の境、つまり、暗黒に風雨が吹き荒ぶ、あの荒野のことですわ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "閉め忘れた裏木戸が、風のためにバタンバタンと鳴りつづけ、大道を吹き荒ぶ風は、松飾りに浪のような音を立てさせている。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木枯の吹き荒ぶ夜半に、教會の建物のかげから忍び出て、おみつの家の廂に手がかゝると、身輕に屋根に飛上る。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう自分の背後にある陸の生活のことなぞは考えない、又考えたらそんな冒険的な行為が恐ろしくなるが、只この健康、この荒ぶる感情、その行動というものが、得も云われず一種の壮快さを齎らすのだ。",
              "citation": {
                "source": "荒磯の興味",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて娘の「こひさん」に耳をすまされた伴天連は、吹き荒ぶ夜風に白ひげをなびかせながら、「さんた・るちや」の門を後にして、おごそかに申されたは、「悔い改むるものは、幸ぢや。",
              "citation": {
                "source": "奉教人の死",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくよさしまつりし国内に、荒ぶる神たちをば、神訊はしに訊はし給ひ、神掃ひに掃ひたまひて、発言ひし磐根・木根立ち、草の隻葉をも言封めて……天｜降しよさしまつりき。",
              "citation": {
                "source": "日本文学における一つの象徴",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その哀愁の伴ふ時、夫人は「餘計者」の冒頭數頁が持つやうな緊張した描寫を可能にし、その憤懣のみが堪へ難く荒ぶ時、やけになる心地を夫人は切實に感じる人であらう。",
              "citation": {
                "source": "貝殼追放",
                "author": "「八千代集」を讀む",
                "note": "青空文庫"
              }
            },
            {
              "text": "手児呼坂・筑紫の荒ぶる神・姫社の神などの、人｜殺る者は到る処の山中に、小さな常夜の国を構へて居たことゝ察せられる。",
              "citation": {
                "source": "妣が国へ・常世へ",
                "author": "異郷意識の起伏",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫社郷の山途川の門（川口か）の西に、荒ぶる神が居て、道行く人をとり殺すので、其訣を占ふと、筑前宗像郡の人｜珂是胡に、自分を斎はせれば、穏かにならうとあつた。",
              "citation": {
                "source": "幣束から旗さし物へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚、この原作が献ぜられているキャサリン・ディ・マットス夫人は作者の従妹であって、献詩のヒースの生い茂り風吹き荒ぶ北国は彼等の故郷スコットランドをさすのである。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "路で友達に逢うたら羞しうて気持の荒ぶ年頃やさかい、かう言ふ。",
              "citation": {
                "source": "孤独閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがつい先日のことだが、人見角造と云って平作の長女のムコで三百代言をしている奴が訪ねてきての話によると、どうやら近ごろは平作のこの心境までぐらついてきたらしいぞ」　天心堂は荒ぶる神がゴセンタクをくだすようにカッと目をむいて語りつづける。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "生蛮人を畏き神と称した例はあるから、神とおにとの区劃がはつきりすれば、かう言ふ荒ぶる神は、やはり鬼の部に這入つて来る事になつたのであらう。",
              "citation": {
                "source": "信太妻の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　　まぢかしや、それ　　夜は荒ぶとも、喘ぐとも。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにまた、吹荒ぶ風、冷いやりとした、しめっぽい雲、焼けつくような太陽、といったようなものが、交代でハーキュリーズを苦しめるのだから、たまりません！",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しながら、火を親しんで「火のお婆さん」と呼ぶことは、日常取扱われる火であるなら格別、荒ぶる火の山に対して、古代の人がそういう感情を抱いていたかどうか頗る疑わしいもので、寧ろ惶み恐みて崇め尊んでいたと考える方が相応しくはないだろうか。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嵐よ雪よ、荒ぶがいい！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
