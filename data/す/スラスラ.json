        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ナニ、当人は自分の交遊がスラスラ行きさへすれば好いのだ。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈の高い方の蘭人はスラスラ説明をして行つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めの中は変な仮名文字だから読み苦くって弱りましたが、段々読むに慣れてスラスラと読めるようになった。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、読者の度胆を抜くような、そして抜く手も見せぬような巧みに凝られた書出しよりも、何の変哲もない、一見スラスラと書かれたような「弥生さんのことを書く」という淡々とした書出しの方がむずかしいのだ。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ程スラスラと私の頭から辷り出た。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "若侍がスラスラと礼の言葉を陳べたので、思い上っていた平馬は、すこしうろたえた。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ荷物を渡して下さい」　と殆んど疑問の余地を残さないくらい巧妙に、スラスラと説明した。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘトヘトに疲れて、上り框からやっと這い上るくらい猛烈な試練と、夢一つ見ない睡眠を取った翌日、今一度、午睡をしてから眼を醒しますと、例によって例の如く、今までとは打って変った軽快さで、スラスラと原稿が書けるものと思い込んで、机に向ったものでしたが豈計らんや、一行も書けないのです。",
              "citation": {
                "source": "スランプ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても創作が書けないままに、そのお詫びをしようと思って書きはじめたら、ついスラスラと筆が辷ってコンナに長くなってしまったのです。",
              "citation": {
                "source": "スランプ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "スランプに陥っているペンが、スランプに関する事だけはスラスラと書けるというのは何という皮肉な現象でしょう。",
              "citation": {
                "source": "スランプ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖父様のお仕込みで、小学校入学前に四書の素読が一通り済んでいた私は、その振仮名無しの新聞を平気でスラスラと読んだ。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "不審な点なぞも勿体ぶらずにスラスラと滞りなく説明してくれました」　なお六平太氏は只圓翁について語る。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "押頂いて、眼鏡もかけずにスラスラと読んでから又押頂いた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏なぞは弟子に型を演って見せる時素足のままであったが、それでも弟子連中よりもズットスラスラと動いた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "覚えがなければ、たとへ二ノ巻読本でも私には、あんなにスラスラと訳せる筈はないのだ。",
              "citation": {
                "source": "吾家の随筆",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上から紫｜扱帯の古ぼけたのが一すじ、グルグルと巻き付けてあるきりであったが、そのふくらんだ自分の胸に取り縋るように、両方の掌をシッカリと押し当てて、素足のまま寝床を降りると、スラスラと畳の上を渡って、芭蕉布張りの襖に手をかけた。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹のまばら垣に藤豆の花の紫がほかほかと咲いて、そこらをスラスラと飛交わす紅蜻蛉の羽から、……いや、その羽に乗って、糸遊、陽炎という光ある幻影が、春の闌なるごとく、浮いて遊ぶ。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり言うことが多くて、彼の言葉がスラスラと出なかったために、畜生！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "とおっしゃるし、私は深く考えるまでもなく、いやなので、私にはいま結婚の意志がございません、という事を何でもなくスラスラと書けました。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いゝですか、そのつもりで読み返しなどしないでスラスラツと（骨牌を読むやうな調子で）、一息に読み終つて下さい。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公の気持がスラスラとうけ容れられた。",
              "citation": {
                "source": "海浜日誌",
                "author": "六月創作評",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、一画一画ハッキリと書いてあるので、スラスラと読めた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでマダムの御主人は、いつも夕方の五時ごろ（それは御主人のリファインされたアタマで撰定された、最も適当と認められる時間）にお帰りになるのでしたが、出迎えられたマダムは、いつも待合の仲居か、ホテルのボーイのように無感激に……しかも上品にスラスラと御主人の身のまわりのお世話をされました。",
              "citation": {
                "source": "奥様探偵術",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にも街なれた歩きかたでありながら、つつましやかで、人の眼に付かないようにスラスラと影のようにあるく。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――陸の場合のように、住所がチリチリバラバラになっていないこと、それに下地が充分にあったことが、スラスラと運ばせた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウソのように、スラスラ纏った。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "よいか――」　木戸博士は鉛筆を手品師のように何処からともなく取出されて図面の端にスラスラと数字を書き並べられたことである。",
              "citation": {
                "source": "キド効果",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆をつけて居る時の苦心の名残は、つゆほどもなく、スラスラと、江戸前のパリパリの筆の運びには、感歎のほかはないのである。",
              "citation": {
                "source": "紅葉山人と一葉女史",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一段二段の長い記事を字一つ消すでなく、スラスラと淀みなく綺麗な原稿を書くので、文選小僧が先づ一番先に竹山を讃めた。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、前夜、短い手紙でも書く様に、何気なくスラスラと解職願を書きながらも、学校を罷めて奈何するといふ決心はなかつたのだ。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
