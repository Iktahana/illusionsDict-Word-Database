    "definitions": [
      {
        "index": 1,
        "gloss": "white peach",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "冷した水蜜桃の皮を、学者風に几帳面に剥き乍ら博士は云った。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "売られてゆく豚のうめき、水蜜桃の供養、笑顔うつくしい石仏。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷した水蜜桃の皮を、学者風に几帳面に剥き乍ら博士は云つた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りしな、林檎はよくよくふきんで拭いて艶を出すこと、水蜜桃には手を触れぬこと、いったいに果物は埃を嫌うゆえ始終はたきをかけることなど念押して行った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その通りに心掛けたが、しかしどういうものか足が早くて水蜜桃など瞬く間に腐敗した。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "八百屋さん大枇杷、小枇杷、水蜜桃、葡萄、苺や野菜、お籠に入れて、頭に載せて、かつこ、かつこ、行けば、薄紫の、馬鈴薯畑の花盛り。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ汝は贅沢だつたよ、牢屋に居ながら三度三度、スープに洋食を三品宛、それに果実は欠かしつこなし、あまり辛気なので食べ残しの水蜜桃で真紅な自画像をぬたくりつけてひどく叱られたつけな、あの挿話は誰に聞かしたつて腹を擁えるだろう、この悪戯者はその翌日看守長から鹿爪らしく呼び出された、それはかうだ。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「水蜜桃の腐れたので描きました。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その白い顔には、まともに陽が射してゐる為か、頤から頬へかけての輪廓が、水蜜桃のそれのやうにふはりと滲んで見えた。",
              "citation": {
                "source": "或る五月の朝の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして子供たちのお馴染になつてゐる旅館の娘さんが停車場までもつて来てくれた、木から※ぎ立ての水蜜桃を子供たちに食べさせた。",
              "citation": {
                "source": "青い風",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "髭のある人は入れ代って、窓から首を出して、水蜜桃を買っている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が水蜜桃を食べているうちにだいぶ親密になっていろいろな話を始めた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "気をつけないとあぶない」と言いながら、さんざん食い散らした水蜜桃の核子やら皮やらを、ひとまとめに新聞にくるんで、窓の外へなげ出した。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その様子がいくぶんか汽車の中で水蜜桃を食った男に似ている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎がふとその横顔を見ると、どうも上京の節汽車の中で水蜜桃をたくさん食った人のようである。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎は様子を見ているうちにたしかに水蜜桃だと物色した。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎はこの時ふと汽車で水蜜桃をくれた男が、あぶないあぶない、気をつけないとあぶない、と言ったことを思い出した。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもあの水蜜桃の食いぐあいから、青木堂で茶を飲んでは煙草を吸い、煙草を吸っては茶を飲んで、じっと正面を見ていた様子は、まさにこの種の人物である。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、水蜜桃の先生と青木堂の先生に、ひそかに広田さんの名をつけている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで水蜜桃も必ず同先生に違いないと決めた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人とは水蜜桃以来妙な関係がある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "水蜜桃や、林檎や、枇杷や、バナナを綺麗に籠に盛って、すぐ見舞物に持って行けるように二列に並べてある。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも多摩川のあたりから水蜜桃や梨などの果物の籠を満載して、神田の青物市場へ送って行くので、この時刻に積荷を運び込むと、あたかも朝市に間に合うのだそうである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも多摩川のあたりから水蜜桃や梨などの果物の籠を満載して、神田の青物市場へ送って行くので、この時刻に積荷を運び込むと、あたかも朝市の間に合うのだそうである。",
              "citation": {
                "source": "薬前薬後",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　その翌日から妻の顔は急に水々しい水蜜のような爽かさを加えて来た。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "関野氏は水蜜桃の皮を剥くやうな気持で少しづつ白絹をめくつて往くと、なかから顔を出したのは、妙齢の娘で、目鼻立ち何処に一つ点の打ちやうもない大理石像のやうな美人であつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の畑にでもできたらしい紅色した新鮮な水蜜桃が、盆の上に転つてゐた。",
              "citation": {
                "source": "或売笑婦の話",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "水蜜桃の実るところを、彼女は初めて見た。",
              "citation": {
                "source": "或売笑婦の話",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "久し振りに東京の街の有様を見、荷物にゴッタ返した闇い車内、スッカリ変った服飾など見てウタタ感慨が深かったが、夜があけると世界は一変して、妙なる枝振りの林檎、桃、水蜜、杏、牡丹桜八重桜（欝金もあり）、散り残りの山桜、木蓮、海棠さては菜の花、桐の若葉、紅葉など、春をこの一瞬に集めている。",
              "citation": {
                "source": "獄中通信",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
