    "definitions": [
      {
        "index": 1,
        "gloss": "to advance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "云へばいふ程、相手は心理的観察の対象を、益々得るといふわけだし、云ふ方は、益々話の内容自体の中に突き進むといつたわけだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした歌詞本位的流行歌曲の進む所は、結局遂に「アメリカ式掛合万才」の全盛時代になるであらう。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の市電よりのろいくらいの速度で蛇のようにうねった線路を汽笛の代りにチャン／＼／＼と絶えずベルを鳴らして進むのである。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の進むにつれて最早気味悪き音はやんで動揺はようやく始まりて早や胸悪きをじっと腹をしめて専ら小説に気を取られるように勉むればよう／＼に胸静まり、さきの葡萄酒の酔心。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがもう一歩進むと立派な精神病になるのだが幸いにそこまでにはならない。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "牝狐は今にも彼を捕へさうだつたのだが、白樺の間に挟まつてしまつて、進むことも退くことも叶はなくなつた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "進むに従つて両岸の景色が何となく荒涼に峻険になつて来るのが感ぜられた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "進むに従って両岸の景色が何となく荒涼に峻険になって来るのが感ぜられた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛍光のような幽美な光りが女神の身体から照り放たれ、その光りの輪廓は女神の身体が進めば闇に取り残され、取残されては急いで、進む女神の身体に追い戻る。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "房総半島に上り、翁は再び望多の峰ろの笹葉の露を分け進む身となった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "重いニッ〔ケ〕ルの雲が、あの高原を、氷河の様に削って進む日、俺の心は、早くも雲や沢山の峯やらを越えて、馬鈴薯を撰り分ける、君の処へ飛んで行く。",
              "citation": {
                "source": "〔蒼冷と純黒〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんたうにどんなつらいことでもそれがたゞしいみちを進む中でのできごとなら峠の上りも下りもみんなほんたうの幸福に近づく一あしづつですから。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが一歩進むとその歴史に関したあらゆる記録、古文書、古器物に対して丁度骨董家が有つような愛好の念をもってこれを蒐集する人もある。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地震予報をして天気予報のごとき程度まで有効ならしむるには如何なる方向に研究を進むべきかは重要なる問題なり。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二次第三次と進むには多大の努力と時日とを要する事は云うまでもない。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見慣れない人は波の進むにつれて水全体が押し寄せて来るように思う事もあるそうですが、実際はただあのような、波の形が進んで来るだけで、水はただ、前後に少しずつ動揺しているという事は水面に浮かんでいる物を見ていてもだいたいはわかります。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "波の峰が来た時にはからだが持ち上げられると同時に、波の進むほうに押されるが、谷を通る時は反対に引きもどされます。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一歩を進むれば、震源地の判定というような問題に触れる事にはなるが、更にもう一歩を進めるところまで行く暇のないのが通例である。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで塵の層を通過して来た白光には、青紫色が欠乏して赤味を帯び、その代りに投射光の進む方向と直角に近い方向には、青味がかった色の光が勝つ道理である。",
              "citation": {
                "source": "塵埃と光",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一歩進むと結局南画のようなものに接近する可能性を持っているのではないかと思われる。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだんに善いところと悪いところを篩い分けて進むといいかと思う。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年ラジウムの研究が進むにつれ、ヘリウムはラジウムより変化して出来るものだという事が知れ、元素というものは変化せぬ物だという従来の考えを打破ったので科学者の注目をひいている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが二年から三年へと、上級へ進むにしたがつてだんだん平凡なくだらぬ藝術家に變つてしまふ。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その意味は、僕がだれより早く、一足先に登つて行つては、また砂の山をすべり落ち、いつも最初の同じ地位から進むことのできない人間だといふのである。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸を巌流を先頭に進む三十有余名。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを述べて見ることにより、自分の立場が明瞭し、次に進むべき土臺となる。",
              "citation": {
                "source": "講演會　其他（大正十五年二月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮪の中とろから始って、つめのつく煮ものの鮨になり、だんだんあっさりした青い鱗のさかなに進む。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミサコが廻転扉から出納口につかつかと進むと、コケットな彼女の嬌態に狼狽した行員が自覚を失った指先で紙幣をかきあつめた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、私は却く事も、進む事も、耳を抑へる事も、顏を反ける事も出來なかつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも考古學者からトラピストの生活に進むまでの彼の生涯には、何等かの思想上の Struggle があつたではないかと思はれた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
