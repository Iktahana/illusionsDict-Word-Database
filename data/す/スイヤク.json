        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "要するにそれは一種の甘い水薬であったのである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近来杏仁水の匂のする水薬を飲まされた記憶はさっぱりない。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳もさっきおれといっしょにこの水薬をのんだがね、どうして六神丸にならなかったろう。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳はもう丸薬を一つぶつまんで、口のそばへ持って行きながら、水薬とコップを出して、「さあ、呑むよろしい。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳はちょうど丸薬を水薬といっしょにのむところでしたが、あまりびっくりして、水薬はこぼして丸薬だけのみました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳もさつきおれといつしよにこの水薬をのんだがね、どうして六神丸にならなかつたらう。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳はもう丸薬を一つぶつまんで、口のそばへ持つて行きながら、水薬とコツプを出して、「さあ、呑むよろしい。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳はちやうど丸薬を水薬といつしよにのむところでしたが、あまりびつくりして、水薬はこぼして丸薬だけのみました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "得たりと医師は膝立直して、水薬を猪口に移し、「さあこれをお飲みなさい。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "粉薬と水薬をくれたが、随分はやらぬ医者らしく、粉薬など粉がコチコチに乾いて、ベッタリと袋にへばりつき、何年も薬局の抽出の中に押しこんであったのをそのまま取り出して、呉れたような気がして、なにか頼りなかったが、しかし道子は姉がそれを服む時間が来ると、「どうぞ効いてくれますように。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうお一つ……」　とニッコリ白い歯を見せた未亡人の眼に含まれた媚……それをどうしても飲まぬと云い張った時、飲まされた「酔いざまし」の水薬の冷たくてお美味しかったこと……。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "素人らしいが、（と莞爾して、）口移しに薬を飲まして……」　酒井は猶予らわず、水薬を口に含んだのである。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十九　早瀬はその水薬の残余を火影に透かして、透明な液体の中に、芥子粒ほどの泡の、風のごとくめぐる状に、莞爾して、「面白い！",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水銀のやうな空気が歩みに随つて顔や手に当り、涼気が水薬のやうに体中に染みた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十一年十月　　赤き花の魔睡日は真昼、ものあたたかに光素の波動は甘く、また、緩るく、戸に照りかへす、その濁る硝子のなかに音もなく、言……遠くきく、電車のきしり……………棄てられし水薬のゆめ……やはらかき猫の柔毛と、蹠のふくらのしろみ悩ましく過ぎゆく時よ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十一年五月　　秋のをはり腐れたる林檎のいろになほ青きにほひちらぼひ、水薬の汚みし卓に瓦斯焜炉ほのかに燃ゆる。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しつかと握る水薬の黄色の罎の鮮やかさ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣家の隠居の溜飲にクミチンキを飲ますんだって、メートルグラスでためした上で、ぴたり水薬の瓶に封。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お医者は、あの翌日から、おなかをこわしたとかで休んでいらして、私がおくすりを頂きに行って、お母さまのご容態の思わしくない事を看護婦さんに告げて、先生に伝えていただいても、普通のお風邪で心配はありません、という御返事で、水薬と散薬をくださる。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六章　その翌々日なりき、宮は貫一に勧められて行きて医の診察を受けしに、胃病なりとて一瓶の水薬を与へられぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二時近い頃、京子は村川の唇に、小田原から来た医師が残して行った水薬を、与えた後、彼のやや血色をとりもどした顔を、じっと見つめていた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂敷にも包まずに持っている清三の水薬の瓶には、野の暖かい日影がさしとおった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の上には半分ほど飲んだ水薬の瓶が夕日に明るく見えていた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までの水薬と散剤の外にです。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "張作霖は螺旋を巻き忘れた柱時計の顔を見ても、飲み忘れた水薬の香を嗅いでも、直ぐこの合言葉を思ひ出すのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、看護婦はおげんのために水薬の罎を部屋へ持って来てくれた。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "服薬は水薬三度、麻痺剤二度。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる今日の外科道具で銀色の小刀、同じ色の鋏、象牙の箆、鹿の鞣し革、鵠毛の刷毛、鋭い鉄針、真鍮の輪、それと並べて大小の箱が、粉薬水薬を一杯に満たせ、整然として置かれてある。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
