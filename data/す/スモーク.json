        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いわゆるスモークボールを飛ばして打者を眩惑する名投手グローブの投球の秘術もやはり主として手首にあるという説を近ごろある人から聞いた。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛速球スモークボールで昨年プロ入りするや三十勝ちかく稼いだ新人王で、スモーク・ピッチャー（煙り投手）とうたわれている。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オッサン、野球、見ないかね」「野球やったら、メシよりも好ッきやね」「チェスターの大鹿投手、知ってるかい」「スモークピッチャーや。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "象印のグリーン氏にガロン薬缶五十、温め鍋二十、ベイクケトル十五、スモークドタン十枚。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、スモークド・サーモン。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "スモークド・サーモンにベイゲルとクリーム・チーズがついてきた朝食のとき、ぼくはそのクリーム・チーズにウースター・ソースをかけて楽しんだ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だったら、それにスモークド・サーモンをつけよう。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "透明なプラスティックの袋のなかに真空パックしたスモークド・ソーセージが見えた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "トン／＼行かないこと甚しく、スモークをたいてむせ返り乍ら野川君の家の附近七八カットやった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "室内の場面すっかり終ると、露路で、スモークを焚かれて、咳は出る眼は痛い、ひどい目にあひつゝ午前八時すぎに、アガリ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "スモークポークチャップとローストビーフ食ったが、てんでまづかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居は簡単、屁のやうなものだが、スモークを焚くやら、群衆が纏まらないやら、清川虹子のカツラが飛ぶやら余興があり、終ると日比谷公会堂へかけつける。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この雌の子猫は「スモークボール」という名前で、彼の友達だった。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「スモークボール」彼は何も考えずに答えた。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは本当に実在するの……そこのスモークボールみたく。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお上の方を見回しながら、スモークボールはトコトコ駆け寄ると膝の上に飛び乗った。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            },
            {
              "text": "「グレイロック」には彼自身と子猫スモークボールの他にもう一人、ほんのかすかにだが、ディアレストの存在を意識している者がいた。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            }
          ]
        }
