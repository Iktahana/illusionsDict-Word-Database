[
  {
    "uuid": "4539a37f-80ab-50a6-ab4c-1c81ad4fdc4c",
    "entry": "綏撫",
    "reading": {
      "primary": "すいぶ",
      "alternatives": [
        "ずいぶ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lulled into peacefulness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "斯る内政の艱難に際し、民心軋轢の慘状を呈するに當て、其黨派論には毫も關係する所なき一種特別の大勢力を以て雙方を緩和し、無偏無黨、之を綏撫して各自家保全の策に從事するを得せしむるは、天下無上の美事にして人民無上の幸福と云ふ可し。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "越智氏、武臣として、世々王子王孫を奉戴して、地方を綏撫せしものと思はる」ト云ヘリ。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "先住土着の民族の綏撫同化の事蹟については、四道将軍の地方巡察、景行天皇の熊襲親征、日本武尊の西征東伐等、我が古史の伝うる所、またあえて尠少なりというではないが、しかもさらに最も明瞭に、遺憾なくこれを説述したものは、我が雄略天皇が宋の武帝に遣わされたと称せられる、宋書記載の国書の文である。",
              "citation": {
                "source": "「日本民族」とは何ぞや",
                "author": "日本民族の概念を論ず",
                "note": "青空文庫"
              }
            },
            {
              "text": "侯の初めに綏撫手段を採りたるもの、今や一轉して壓威手段を執るの止むを得ざるに至れり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "侯の初めに綏撫手段を採りたるもの、今や一転して圧威手段を執るの止むを得ざるに至れり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもこいつへ腰をかけるようなやつなら、すいぶん小さな猿だ。",
              "citation": {
                "source": "さるのこしかけ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すいぶん遠くまで来たんだねえ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゴットフレト　フォン　ゲーメンといえば、すいぶん古い名まえですね。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日さまが、もうすいぶんたかくのぼったので、ふたりは大きな木の下に腰をおろして、朝の食事にかかかりました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうすいぶん高くとんで、はじめ下でみつけた大きな船は、いつか白いかもめのように、ぼっつり水のうえに浮いていました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのときは、すいぶん、はらがたったがなあ。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆんべ八丁堀のほうにやって来たあのちっこい小娘が、まただんなを名ざしてたずねてきましたぜ」　名ざしといったものでしたから、ますますいぶかしさをおぼえまして、すぐと右門が立とうとすると、しかし伝六が押えていいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな美女を失った人が捜さずに済ませる法があろうか、まただれそれ、だれの娘の行くえが知れぬとか、または人を怨んで尼になったとか自然｜噂にはなるものであるがと返す返すいぶかしく思われた。",
              "citation": {
                "source": "源氏物語",
                "author": "手習",
                "note": "青空文庫"
              }
            },
            {
              "text": "不安な、第三期の戦争の気配すらぷすぷすいぶつてゐる。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　このとき、緑川博士は、すいぶん大きな声をだした。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かくかゝ呑みてば、気吹戸にいますいぶきどぬしと言ふ神、根の国・底の国にいぶき放ちてむ。",
              "citation": {
                "source": "古代生活の研究",
                "author": "常世の国",
                "note": "青空文庫"
              }
            },
            {
              "text": "登志子　　まだぶすぶすいぶつてはゐるらしいですけれど、大体落ちつくと思ひますわ。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すいぶんお脊が伸びましたわね。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「賜はもうすいぶん賢い男になったらしい。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊亮は少し声を落して、「何しろ、ご存じの通りの内輪の事情ですから、誰に来てもらったところで、すいぶんつらいことがあるだろうと思います。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人に十人だと、すいぶんなぐったんだろう。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「すいぶん忙しいね。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "すいぶん手きびしいね。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "すいぶんむずかしいんだから。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃあ、こちらの旦那としちゃあ、すいぶんご迷惑でしょうともさ。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なるほど、ご令息としては、そりゃ、すいぶん言い出しにくいことでしょう。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「永いこといて、一度も川にはいったことがありませんでしたが、すいぶんつめたい水ですね。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん、何が人間の真実かということについては、以前はすいぶん判断を誤ったこともありました。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ぼく、名前がわかっていましたので、とくべつ注意していたんですが、あれですいぶんこまかいことに気のつく人のようですね。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、これまでだって、すいぶんはいって来ていたんだ、塾生自身が、ほとんど一人残らず、病菌の保有者だと言ってもいいんだからね。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
