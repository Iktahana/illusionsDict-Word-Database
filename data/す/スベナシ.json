    "definitions": [
      {
        "index": 1,
        "gloss": "having no choice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "旅順をぢなきや嚢の鼠、ふくろこそ噛みてもやれめ、そびらには矛迫め來、おもてには潮沫湧く、穴ごもり隱らむすべも、術なしにあはれ。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "只だ聖母の御惠を祈らんより外｜術なしといひぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて何とか救済の道もがなと千々に心を砕きけれども、その術なし。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる曠世の尤物を無窮に残し拝ますはアの筆のほかにその術なしとあって、その装束を脱いだ体を画かしめた。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "横車を押し意だけ高に何かを罵って居た時、才覚のある者が、ふみばさみに文をはさんで、これを大臣に奉ると云って擬勢を示したら、「大臣ふみもえとらず、手わななきてやがて笑ひて、今日は術なし、右の大臣にまかせ申すとだにいひやり給はざりければ々々」と大鏡の筆者は記して居る。",
              "citation": {
                "source": "余録（一九二四年より）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また日本にては、貧家の子が菓子屋に奉公したる初には、甘をなめて自から禁ずるを知らず、ただこれを随意に任してその飽くを待つの外に術なしという。",
              "citation": {
                "source": "経世の学、また講究すべし",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "道理を述て解すこと能はざる相手なれば、伐つより外に術なしと云ふ説もあらん。",
              "citation": {
                "source": "亞細亞諸國との和戰は我榮辱に關するなきの説",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "古人の書に曰く、「自責の外に、人に勝つの術なく、自強の外に人に上たるの術なし」　と。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや詮術なしと観念の眼を閉ぢた悪魔の奴は永遠の如き饒舌の虜となり、厭世感を深めたといふ話があります。",
              "citation": {
                "source": "清太は百年語るべし",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれのこれに与うるゆえんのものは他の術なし。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "懲すも改めず罰するも恐れざるに至っては遂に施すに術なし。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "中四尺を隔てて近寄るに力なく、離るるに術なし。",
              "citation": {
                "source": "薤露行",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "』矢疵に惱む豪勇のユウリュピュロスは答へ曰ふ、『＊パートロクロス、神の裔、アカイア軍は今既に防禦の術なし、黒船をさして退き逃るべし、先きに至剛の譽得し諸將こぞりて、トロイアの　825鋭き槍に矢に打たれ、皆船中に横はり起たず、而して敵軍の勇はます／＼激しかり。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝は彼らより恩を受けたれば、その悪口を言わん術なし……。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にせむ」とまをししかば、その王子答へて詔りたまはく、「然らば更にせむ術なし。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれ、あはれ、この旱つづかむかぎり、汝が飢渇癒えむすべなし。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたはた、ああ、はたはた、すべなし、飛び羽うつといくばくも飛ばず落ちぬ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "神ながら、この道にああ我や言ふすべなし、大皇子の生れまして春まさに雲ぞ騰る。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅やどりすべなしや、※に見て日をおくれば。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩まむとする人は、車と車との隙を行くより外すべなし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞間の江や先づ引く汐に背き得ず靡く玉藻はすべなし吾君いたづらに言うるはしみ何せんと君が思はむ思ひ若しも　手古奈は詞には判然と言うて居れど、何分顏には進まぬ色がある。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふるさと人もいや、親もいや、小さな街が憎うて、夜ふけに家を出たけれど、せんすべなしや、霧ふり、月さし、壁のしろさにこほろぎがすだくよ、堀の水がなげくよ、爪さき薄く、さみしく、ほのかに、みちをいそげば、いまだ寢ぬ戸の隙より灯もさし、菱の芽生に、なつかし、沁みて消え入る油搾木のしめり香。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝろしづかにしてしづみゆく、せんすべなし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "○わが心、尼院の中に、尼達に、かくまはれあればすべなし。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふとも、思はるるとも、全くすべなし。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいかしの實の殼は墜ち、風にうらみぬ、――　　　　（さなりわびしや、）『命は獨りおちゆきて拾ふすべなし。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
