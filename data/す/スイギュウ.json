    "definitions": [
      {
        "index": 1,
        "gloss": "water buffalo (Bubalus bubalis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また彼はプノンペンから自動車に搭乗して国境のゴム園に車をカンボジヤの原野、白鷺の飛ぶ直線道路を、水田に遊ぶ水牛のなかを疾走させた。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、水牛となるとだいぶ人間とは流儀が違う。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と娘が、つい傍に、蓮池に向いて、（じんべ）という膝ぎりの帷子で、眼鏡の下に内職らしい網をすいている半白の父を呼ぶと、急いで眼鏡を外して、コツンと水牛の柄を畳んで、台に乗せて、それから向直って、丁寧に辞儀をして、「ええ、浦安様は、浦安かれとの、その御守護じゃそうにござりまして。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンドルが水牛の角のやうな形をし、ブレーキと荷｜掛けとチエーンのカバーがない。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四十年十月作」　　　天艸雅歌　　角を吹けわが佳※よ、いざともに野にいでて歌はまし、水牛の角を吹け。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが佳※よ、鐘きこゆ、野に下りて葡萄｜樹の汁滴る邑を過ぎ、いざさらば、パアテルの黒き袈裟はや朝の看経はて、しづしづと見えがくれ棕櫚の葉に消ゆるまで、無花果の乳をすすり、ほのぼのと歌はまし、いざともに角を吹け、わが佳※よ、起き来れ、野にいでて歌はまし、水牛の角を吹け。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "真白なるゆめの水牛、しかはあれど、なべて盲ひし獣らの重き起伏。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほのかなるにほひのそらに、やや赤く地平は光り、そこここの水面より水牛いづる。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "水牛のしづけさや、しづかなる角の音に物をしおもふ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづかにも坐る水牛、戦慄の、かなしみの唸あげつつ、おもむろにおもむろにあかる不思議のいと赤き西天ながめ、恐ろしき、あるものの迫にふるふ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "『……ああかなし、　　　かなしき光、　　　われらの光、　　　内心のかなしき瞳………』たと跳り逃ぐる水牛あな、赤き血浴びしごとも啼き狂ひ絶望の唸に奔る。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "水牛の声………千万の砥石の響………苦き嘲罵………はたや、なほ奔る足音………ら、りら、ら、りら、ほのかに雲雀。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを一種の不運とか奇禍とか言ってしまえばそれ迄であるが、マラリアに罹かったとか、蕃人に狙撃されたとか、水牛に襲われたとかいうのではなくして、彼が毒蛇のために生命を奪われたということが、何かの因縁であるように私の魂をおびやかした。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを押し進めて行つて、「あの牛が水牛だろかい？",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸し暑く息づまつた空氣の底から、何かの恨みか不滿足かを訴へる沈鐘の響きのやうに、お鳥のいはゆる「水牛」の聲が響いて來るのだ――云ひかへれば、義雄自身のまだこれでは不滿足な戀の恨みがその息ぐるしさを訴へるやうに！",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "その宵黒田長政例の水牛の角の甲を被って宗茂の陣に来り、一方を承ろうと云った。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中の沼地に草が茂って水牛が遊んでいたり、川べりにボートを造っている小屋があったり、みんなおもしろい画題になるのであった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水牛の群が通り過ぎても、あれほど汚くはならない。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "平原の一面たる山々の濃淡いろいろなる緑を染め出したる、おそろしき水牛、テヱエルの黄なる流、これを溯る舟、岸邊を牽かるゝ軛負ひたる牧牛、皆目新しきものゝみなりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そが上、岸近きところには水牛あまたあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "水牛は或は死せるが如く枯草の上に臥し、或は狂せるが如く驅けめぐりたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が住める怪しき家、劫盜の屍をさらしたる處、おそろしき水牛、皆其筆に上りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "水牛　十一月になりぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時戸口を塞ぎたるは、血ばしる眼を我等に注ぎたる、水牛の頭なりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは彼男の烟の中にて、銃把を擧げて、水牛の額を撃つを見たり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふも採集に出でゝ、ポンテ、モルレにて車を下り、テヱエル河に沿ひてこなたへ來しに、圖らずも水牛の群にあひぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ピエトロ」寺の塔をも、水牛をも、肥えふとりたるパアテル・アムブロジオ（僧の名）をもゑがきぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "（頭より血流るゝ、水牛の角を握りて。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯だ聖母、貴き客人、水牛の三つをくりかへしたるをば未だ忘れず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
