        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "海岸に近づくにしたがって、海底に波の底をひきずるようにしてスピードを落とす。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "故意にボードのスピードを落とす。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは、スピードを落とす。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づくにしたがって、スピードを落とす。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、意地があるから、急にスピードを落とすわけにはいかない。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の経験で、読めて読めてしかたがない、又読みたくて読みたくてしかたがなく、御飯の間も手ばなしたくないようで、ハハーンと我から肯き、読書のスピードをおとすことと、一ヵ月に冊数をへらすことに努力した覚えがあります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
