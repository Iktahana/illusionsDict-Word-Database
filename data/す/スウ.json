[
  {
    "uuid": "96c45a53-b63b-5f45-bf7e-698973bd9cc9",
    "entry": "吸う",
    "reading": {
      "primary": "すう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-他動詞"
