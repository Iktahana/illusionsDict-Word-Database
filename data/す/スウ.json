  {
    "uuid": "26313ba2-1bce-55de-80e9-9f00564fee45",
    "entry": "数",
    "reading": {
      "primary": "すう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接頭辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "several",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は数日間の休暇を取って、人里離れた温泉宿でゆっくりと過ごすことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "数十人の参加者が集まったセミナーでは、活発な質疑応答が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "会議の結果が出るまでには、まだ数時間の猶予がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "色々と詩論は毎月の雑誌にも現れてをりますが、此の雑誌に訳載中のアランの論文と、それからこれは直ちに詩論と呼べる限りのものではありませんが、フィードレルの芸術論、まづまづ此の二つが此の数年来に読みました詩論の中で心に残つたものであります。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々あるどころか無数にあつて、空気中のオゾンの量に因ると考へる人だつてないとは云へぬ。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、今仮りにその原因がシカと答解されたとしても、無数の現象の総和である現状は、直ちにどう変るものでもあるまい。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあれ日は過ぎ月は逝き、なれ等血もなく涙なく、よくぞ鬩めげる数千年、さても殺生はての死の、よくぞ好きなる、おゝ永遠の闘争よ、おゝ恩怨の同胞よ！",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば日々報道される様々な事件が、昔人間の数の少なかつた時よりも、人の感動を鈍らせ易いものだといふことが云へるとしても、而も芸術とはさういふ事情の問題ではなくして、さういふ事情の中にあつても猶感動する人がゐたら、その人が感動した感動に基因して表現するに到る所のものである。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "少数のエリット達からは認められてもゐたが、世間からは一向知られなかつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学に、親しんでゐるといふ、まことに文学者にとつて当然のことさへ出来てゐるならば、決して起らない筈の問題が、数々の問題の過半を占めてゐるといふやうなこともあるものであると、今更思ふ人も少くなくて欲しいことである。",
              "citation": {
                "source": "文学に関係のない文学者",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "数にすれば少しでも、文学に無関係な文士なぞといふものが在るのは何れにしろ奇現象であるから、事実上は決して少い感じがするどころではない。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その庭といふのはその後数回築き直されたにも拘らず、その忠魂塔の台石となつた石だけは殆んどその位置を変へず、そしてその忠魂塔も、私が後に出郷してからも、帰省した時には見掛けたやうに思ふが、七八年前帰省した頃から、それは姿を消した。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それの周囲の棚だつた鉛の棒を共に抜取つた弟さへ、今は既に亡き数に入つたのである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳述、私は明治四十年四月の末に生れ、その年十一月三日に郷里を母と母方の祖母と三人で立ち、四日乗船、六日大連着、そこで父に出迎へられ、（その父も今は亡き数、――安らかなれかし！",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "数々の人の意識が、電燈の光と影との中を浮動してゐる。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この道をも私は通る」以下の詩、及び淫売婦に贈つた数篇の詩篇をよむものは、どんなに長い間、彼が霊的に苦しんで居たか、そして今の彼がどんなに健全で高潔な愛の信仰の上に立つて居るかを知るであらう。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚十数年、ヘルン既に五十｜歳を過ぎ、二人の男児と一人の女児の親となってる晩年の手紙である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは本土との交通がほとんどなく、少数の貧しい漁夫たちが、所々の寂しい山蔭に住んでるような、暗く荒寥とした島嶼であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中が二人、書生が一人、老僕が一人、他に抱車夫が一人という大家族であったので、家も相当に広く、間数がいくつもあって廊下続きになっていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜の花が返り咲きをした日から、数日を経てまもなくヘルンは死んでしまった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の友人は、ほんの数えるくらいしか無い。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その少数の友人にも、自作の註釈をした事は無い。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画館の一隅に坐っている数刻だけは、全く世間と離れている。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、兄は、それが出来るかも知れない極めて少数のひとの一人だと思います。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "数十人の智慧ある先賢に手をとられ、ほとんど、いろはから教えたたかれて、そうして、どうやら一巻、わななくわななく取りまとめた。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "円の面積を算出する公式も、鶴亀算の応用問題の式も、甚だ心もとなくいっそ代数でやればできるのだが、などと青息吐息の態とやや似ている。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと、そのＭ・Ｔという人は、用心深く、妹からお友達の名前をたくさん聞いて置いて、つぎつぎとその数ある名前を用いて手紙を寄こしていたのでございましょう。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い質問、「知ることは幸福であるか」　　佐野次郎左衛門様馬場数馬。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、めっきり口数を少くした。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "数日後、大隅忠太郎君は折鞄一つかかえて、三鷹の私の陋屋の玄関に、のっそりと現われた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本有数という形容は、そのまま世界有数という実相なのだから、自重しなければならぬ。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて近代の諸主義が生れるのであるが、要するにそれ等の数々は、要するに根柢に於て一括されるかと思ふ。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹も、そのころは、痩せ衰えて、ちから無く、自分でも、うすうす、もうそんなに永くないことを知って来ている様子で、以前のように、あまり何かと私に無理難題いいつけて甘ったれるようなことが、なくなってしまって、私には、それがまた一そうつらいのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
