    "definitions": [
      {
        "index": 1,
        "gloss": "Suwa deities (esp. Takeminakata and his consort Yasakatome)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
