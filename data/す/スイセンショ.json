        "examples": {
          "standard": [
            {
              "text": "大学院出願のため、恩師に推薦書を書いていただくことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "推薦書には、候補者の学業成績や人物像について具体的に記載される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この推薦書、封筒に入れて厳封してもらわないと、無効になる場合があるんだ。」と、大学職員が説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "今日もちょうど小川博士の講義の日だったが、次郎はその講義がはじまるのを待ち、一まとめにした履歴書と推薦書とをかかえて塾長室にはいっていった。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "会員になるには、まず推薦書を作って、既に会員たる者の幾名かの記名を得てソサイテーに提出する。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファラデーのは、友人のフィリップスがこの推薦書を作り、二十九名の記名を得て、一八二三年五月一日に会に提出した。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、後にファラデーが人に話したのによると、デビーはこの推薦書を下げろとファラデーに言った。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
