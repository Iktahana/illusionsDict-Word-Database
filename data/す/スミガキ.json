        "index": 1,
        "gloss": "inking the outlines of a picture",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その横の壁のうんと高いところに銀三四九〇とアラビア数字で白墨書きがあり、気がついて見ると、その電話のまわりには、謂わばところきらわず、がさつな事務所にでもありそうに番号変更の紙を貼りつけたり、番号をかきちらしたりしてある。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、其も墨書きや彩み画の絵巻若しくは、屏風の構図であつた。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "此句だつて、唯の墨書きではない。",
              "citation": {
                "source": "河童の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天幕の裏はすべて墨書きの雲であつた様に思ふ。",
              "citation": {
                "source": "だいがくの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は蟲の喰つた寫本の肩をいからせた墨書き文字をながめながら、百年前の鬱勃とした知識慾といふか、進歩慾といふか、そんなものを、身體いつぱいに感じながら、當時の世界を想像してゐるうちに、Ｋ・Ｈ氏にきいた木村嘉平のことがつよく泛んできた。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "真面目な墨書きの巻紙で五尺に及んでいるものさえあった。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも尚お墨書きの文字が透いて見えるから、更に墨で抹殺して置いた。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、それへ墨書きがしてあった。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
