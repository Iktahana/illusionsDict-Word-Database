[
  {
    "uuid": "0ef33d5b-bc53-5cac-ac67-9b47c15398de",
    "entry": "透かす",
    "reading": {
      "primary": "すかす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
