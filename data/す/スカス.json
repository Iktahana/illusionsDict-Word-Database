    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to feel hungry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今に自分も犬と一緒に腹を空かすやうになるまでさ。",
              "citation": {
                "source": "犬の八公",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しか、急に出て行くやうなことがあると、晩御飯も食べないぢや、お腹を空かすわよ。",
              "citation": {
                "source": "空の悪魔（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は萱の間からすかすようにして私どもの来た方を見ました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばくてりやが生活するところには、病人の皮膚をすかすやうに、べにいろの光線がうすくさしこんで、その部分だけほんのりとしてみえ、じつに、じつに、かなしみたへがたく見える。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　髪がのびると特別じゝむさく見える柴田が、弟をすかすように、市三の肩に手を持って来た。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬を引いた人はこの時ちょっとうしろをふりかへってこっちをすかすやうにして見ましたがまた黙ってあるきだしました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさえたるわが手には血の色つかぬに、燈にすかす指のなかの紅なるは、人の血の染みたる色にはあらず、訝しく撫で試むる掌のその血汐にはぬれもこそせね、こころづきて見定むれば、かいやりし夜のものあらわになりて、すずしの絹をすきて見ゆるその膚にまといたまいし紅の色なりける。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてはあつらえたまいしごとく家に送りたまうならむと推はかるのみ、わが胸の中はすべて見すかすばかり知りたまうようなれば、わかれの惜しきも、ことのいぶかしきも、取出でていわむは益なし。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "れいによりてのしのしとあゆみながら、茨など生いしげりて、衣の袖をさえぎるにあえば、すかすかと切って払いて、うつくしき人を通し参らす。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶次郎は時々向うをすかすように見て「大丈夫だよ。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが積極的誤解となると、手を尽すか探すかすれば、正解に達し得られるものをいい加減にして置くか、感情に左右されて軽忽に実情を覆う誤解であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中はすかすやうにして彼を見つめた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は萱の間からすかすやうにして私どもの来た方を見ました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶次郎は時々向ふをすかすやうに見て「大丈夫だよ。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すかすと、きめに、うすもみじの影が映る。",
              "citation": {
                "source": "栃の実",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　土間はたちまち春になり、花の蕾の一輪を、朧夜にすかすごとく、お町の唇をビイルで撓めて、飲むほどに、蓮池のむかしを訪う身には本懐とも言えるであろう。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまで散々利用して来たこちらの醜い心を見すかすような笑顔なのだ。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさへたるわが手には血の色つかぬに、燈にすかす指のなかの紅なるは、人の血の染みたる色にはあらず、訝しく撫で試むる掌のその血汐にはぬれもこそせね、こころづきて見定むれば、かいやりし夜のものあらはになりて、すずしの絹をすきて見ゆるその膚にまとひたまひし紅の色なりける。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてはあつらへたまひし如く家に送りたまふならむと推はかるのみ、わが胸の中はすべて見すかすばかり知りたまふやうなれば、わかれの惜しきも、ことのいぶかしきも、取出でていはむは益なし。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "れいによりてのしのしとあゆみながら、茨など生ひしげりて、衣の袖をさへぎるにあへば、すかすかと切つて払ひて、うつくしき人を通し参らす。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "邸にはこの頃じゃ、その魅するような御新姐も留主なり、穴はすかすかと真黒に、足許に蜂の巣になっておりましても、蟹の住居、落ちるような憂慮もありません。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に斜に外れて巴里昼間新聞を買う人の起すかすかな空気のうずまき。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、もうすこしおあがりなさいましよ」　讓は後の酒を一口飲んでしまってコップを置くと、腰をすかすようにして、「折角ですけれど、ほんとうに急ぎますから、これで失礼します」　女はコップを投げるように置いて、立って来て讓の肩に双手を軽くかけて押えるようにした。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お婆さん、もう好いのでしょ、平生くらい出来たのですよ」　コップを持った婢はコップの血をすかすようにして云った。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ねえ」と、すかすやうにして、然し冷かしの意味を含めて、「あの色の黒いところがかい？",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "筋からハグラかされてアクビを出すか、本を投出すかするところがあるのだから、こんなのは先ず遠慮した方が賢明である。",
              "citation": {
                "source": "創作人物の名前について",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあもすこしおあがりなさいましよ、」　譲は後の酒を一口飲んでしまつて、コツプを置くと腰をすかすやうにして、「折角ですけれど、本当に急ぎますから、これで失礼します、」　女はコツプを投げるやうに置いて、立つて来て譲の肩に両手を軽くかけて押へるやうにした。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　おみねはうす暗い行燈の下で一所懸命に手内職をしていたが、ふと其の手を止めて蚊帳の中をすかすようにした。",
              "citation": {
                "source": "円朝の牡丹燈籠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかい窓にはめ込んだあかるいガラスをすかすと、なかのりっぱな広間がみえました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "又幼き兒に、紅晴を付るを犬の子といひ、兒の泣くを犬の子／＼とてすかすも、其心ばへ成べしと。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
