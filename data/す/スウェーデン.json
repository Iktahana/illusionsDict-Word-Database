        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "最近、瑞典マッチの圧迫を受けてぷり／＼している不機嫌な支配人は、彼がむしろ支那人に肩を持つ癖があるのを責めて、皮肉な辛辣な眼つきをした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、内川らはマッチ業界の世界統一を企図している瑞典の資本を結合した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞典蕪、大蕪、銀の鰯がちらかれば、さしずめわたしの雲母集。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判所長の俸給………………………………五〇〇弗政務長官の俸給………………………………四一五弗警察署長（瑞典人）の俸給…………………一四〇弗裁判所長秘書官の俸給………………………一〇〇弗サモア王ラウペパの俸給………………………九五弗　一斑推して全豹を知るべし。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日夜の心配に堪えられなくなった守衛長（若い瑞典人）は、遂に、乱暴極まる措置を思いついた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古スウェーデン三大祭の一たるジサ祭はこの記念のために始められたので、かの国キリスト教に化した後も、毎年二月初めの日曜にこれを祝うて今に絶えぬと、ロイドの『瑞典小農生活』に出づ。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくすると一生嬶旦那で暮し得と信ず（ロイドの『瑞典小農生活』八六頁）。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯学の玉条たるエングレル及びブラントルの自然分科編に、ダリヤの九種みなメキシコの原産とあり、一七八九年にイスパニアの僧カヴアニュスが、瑞典の植物学者ダールの姓に由てダーリアと命名した事、その著西班牙植物図説一と二の説に明かなれば、支那の原産でないは論を俟たず。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "英國で犬又は豚、瑞典で綿羊抔で何れも其靈が墓場を守ると信じた。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "また受苦週（耶蘇復活祭の前週）の間、鼠、蛇等有害動物の名を言わず、これを言わば年中その家にそんな物が群集すると伝う（一八七〇年板ロイドの『瑞典小農生活』二三〇頁、二五一頁）。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "現行書目にしも、英独仏露伊西以外、和蘭、瑞西、波蘭、瑞典、那威、澳太利、匈牙利、葡萄牙、墨西哥、アルゼンチン、将た印度、波斯、中央亜細亜あたりまでの各国書目を一と通り揃えていた。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近の作家では瑞典のドゥーゼや米国のヴァン・ダインなどはこの点で申し分がないように思う。",
              "citation": {
                "source": "現下文壇と探偵小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　ノーベル賞金の受領者、瑞典の女流作家、ラゲルレフの作も多分に猟奇的である。",
              "citation": {
                "source": "他界の味其他",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　ヂュパンやホームズが、近づき難い人間であるに反して、瑞典の作家ドウーゼの創造した素人探偵レオ・カリングは、いかにもなつかしみを感ぜしめる人物である。",
              "citation": {
                "source": "ヂュパンとカリング",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "二万八千弗の祝儀８・16（夕）　ノオベル賞金の創設者として聞えた瑞典のアルフレツド・ビイ・ノオベルの邸に、長年の間まめに女中頭を勤め通した女があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "『諾威も瑞典も旅券の査証は要らないんだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "海峡の嵐　Helsingor は沙翁が発音どおりに Elsinor と書いてから、この名によって多く知られているデンマアク海峡の突端の町で、一脈のふるい水をへだてて瑞典のホルシングボルグに対している。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、これから陸路｜瑞典へ出て、ストックホルムへ行こう。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、ダンスプランという瑞典各地方の踊りのある日でなければ駄目だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかで「瑞典のパンテオン」と呼ばれる、リダルホルムス教会――｜騎士の島という語意だが――この歴代の王様を祀ってある壮麗な拝殿の内部、古い木の尖塔の反対側の角のところに、日本先帝陛下を記念し奉る御紋章が安置してある。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つの王冠――瑞典の国章はどこにでも見受ける――が陽にきらめいている水辺高層の楼閣――ストックホルムが世界に誇る新築の市役所である。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞典国ストックホルム市　ヤポンスカ・マガジネット支配人　　　エスキル・アルトベルグ　アルトベルグさんは学者肌の中老の紳士で、私達が戸を排したときは、ちょうどお客のお婆さんに日本の紡績｜絣を一尺ほど切って売っていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史的、そして地理的関係上、瑞典の影響をいたるところに見受けるのはいうまでもない。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "語尾に街とついているのが瑞典語、おなじく何なに街とあるのが、芬蘭土語で、地図も看板もそのとおりだから、旅行者はすくなからず魔誤々々してしまう。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから、瑞典の神學者スヰデンボルグを、エメルソンの評論と僕が讀んだことのある英譯とに據つて論じようと思ふが，メーテルリンクは神秘説を唱へる者に過ぎない、エメルソンは非常に神秘的傾向があるだけのこと、然しこの人と來ては、その人物が面白いほど神秘家に出來上つて居るのである。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が寡聞なので、今、その他に例となる樣な善い劇を擧げることは出來ないが、小山内薫氏がジエームスヒウンカアと云ふ人の書から抄譯して、新小説に紹介せられた瑞典の劇作者ストリンドベルヒ――これは、前に論じたスヰデンボルグと同國人――の著『伯爵令孃ユリエ』を引いて見よう。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "(8) 瑞典：　スウェーデン。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂の向うの、青い水と救助区域の赤い旗と、向うのブリキ色の雲とを見たとき、いきなり私どもはスウェーデンの峡湾にでも来たような気がしてどきっとしました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "anger はアイスランドの 〔a&ngr〕 やＬの angor などのような「憂苦」を意味する言葉と関係があるそうで、一方ではまたスウェーデンの「悔恨」を意味する 〔a&nger〕 に通ずる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新発明の耳喇叭　スウェーデン政府の電話局で近頃発明された耳喇叭は交換手の耳にさし込んで通話をするためのものであるが、これはまた耳の遠い人のためにも重宝なものであるそうな。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
