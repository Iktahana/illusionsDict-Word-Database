[
  {
    "uuid": "6000985c-363e-58e3-b7db-59b6883b58a1",
    "entry": "酔漢",
    "reading": {
      "primary": "すいかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "drunkard",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "酔漢が一升徳利を抱えて暴れているのもいい。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "連れて来たＭ君はこの意外の光景にすっかり面食らって立ち往生をしたそうであるが、その時先生のこの酔漢に対する応答の態度がおもしろかった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、いや、私が聞いただけでも、何か、こうわざと邪慳に取扱ったようで、対手がその酔漢を労るというだけに、黙ってはおられません。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "老耆の手ぼう爺に、若いものの酔漢の介抱が何、出来べい。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂俗物の眼から見ると、ツネ子は酔漢のキスにも価いしない、ただ、みすぼらしい、貧乏くさい女だったのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場の小路で、酔漢の荒い言葉が、突然起った。",
              "citation": {
                "source": "I can speak",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "I can speak というその酔漢の英語が、くるしいくらい私を撃った。",
              "citation": {
                "source": "I can speak",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "立派な口髭を生やしながら、酔漢を相手に敢然と格闘して縁先から墜落したほどの豪傑と、同じ墓地に眠る資格は私に無い。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」嘉七は、酔漢みたいな口調で言った。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ酔漢の放言として、嘲笑されるくらいのところであろう。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔漢の放言に閉口し切つてゐるといふやうなふうに見えた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻の前を、その燈が、暗がりにスーッと上ると、ハッ嚔、酔漢は、細い箍の嵌った、どんより黄色な魂を、口から抜出されたように、ぽかんと仰向けに目を明けた。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　　　　　　　五　さて酔漢は、山鳥の巣に騒見く、梟という形で、も一度線路を渡越した、宿の中ほどを格子摺れに伸しながら、染色も同じ、桔梗屋、と描いて、風情は過ぎた、月明りの裏打をしたように、横店の電燈が映る、暖簾をさらりと、肩で分けた。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　城を語る時、初阪の色酔えるがごとく、土地｜馴れぬ足許は、ふらつくばかり危まれたが、対手が、しゃんと来いの男衆だけ、確に引受けられた酔漢に似て、擦合い、行違う人の中を、傍目も触らず饒舌るのであった。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "縄暖簾を掻き分けて一人の酔漢がよろめき出ながら、眼に当った夫婦乞食の女の方に向って揶揄いかけます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして酔漢が追い付けない距離まで遠のきますと、そこで男乞食は口惜しい声で仕返すのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥酔漢のおくびと、殺人の温るい計画とにふりそそぐ雨。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱のやうな道路が躍つてゆく、丘から丘へ、谷から畑へ、まるで、人間なら泥酔漢だ。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかげに、紅き襯衣ぬぎ悲しめる道化芝居の触木うち、自棄に弾くギタルラ弾者と、癪持と、淫の舞の眩暈、さては火酒かぶりつつ強ひて転がる酔漢と、笑ひひしめく盲らは西瓜をぞ切る。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "活動写真の酔漢の絹帽に鳴くこほろぎ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "味気なきは折ふしの移りかはり、祭ののち、時花歌のすぐ廃れゆく、活動写真の酔漢の絹帽に鳴くこほろぎ。",
              "citation": {
                "source": "第二真珠抄",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに何時の間にやら重いたどたどしい足どりが泥酔漢めいて来て、時とするとその痛い乳の上から真白な畜生の手でもふいと飛び出しさうなそんな気がしてただもう恐ろしく、抑えては引つ込ませ、抑えては引つ込ませ、益々深い濃霧の中をあてどもなくまぎれ込んで了ふのであつたが……。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なつかしき我が武ちゃんよ、――今様のハイカラの名は敬慕するかはせみの君、外国のラリルレ語酔漢の語でいへばm…m…my dear brethren !――君が文読み、くり返し、我が心青柳町の裏長屋、十八番地ムの八にかへりにけりな。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の威張りくさった白人の酔漢がヘンリに向い山刀を振上げて、「貴様の首をぶった切るぞ」と嚇しつけたのだそうだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポン引が徘徊して酔漢の袖を引いているのも、ほかの路地には見当らない風景だ。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの横丁へ来て、料理屋の間にはさまった間口の狭い格子づくりのしもた家の前を通るたびに、よしんば酔漢のわめき声や女の嬌声や汚いゲロや立小便に悩まされても、一度はこんな家に住んでみたいと思うのであった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃますますいかん。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "台湾では文旦という形の尖ったうちむらさきや普通の丸いざぼんや、ぽんかん、すいかん（ネーブル）等を籠に入れて毎日の様土人が売りにきた。",
              "citation": {
                "source": "朱欒の花のさく頃",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
