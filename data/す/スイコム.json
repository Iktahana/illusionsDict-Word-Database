    "definitions": [
      {
        "index": 1,
        "gloss": "to inhale",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "呼吸を吸い込むと胸の中に枯枝か屑のようなものがつかえ、咽喉はいらいらと虫けらが這うように痒い。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはどういうわけかというと、砂粒が自然のままに落ち着いている時は、粒の間の空隙がなるたけ少ないようになっているが、足で踏んだりすると、その周囲の所は少し無理がいって空隙が多くなり、近辺の水を吸い込むからです。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く走って行こう、かけさえしたらすぐに麦は吸い込むのだ。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（コロナは八万三千十九）　わたくしたちが柄杓で肥を麦にかければ、水はどうしてそんなにまだ力も入れないうちに水銀のように青く光り、たまになって麦の上に飛びだすのでしょう、また砂土がどうしてあんなにのどの乾いた子どもの水を呑むように肥を吸い込むのでしょう。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "座が白けて、しばらく言葉が途絶えたうちに所在がないので、唄うたいの太夫、退屈をしたとみえて、顔の前の行燈を吸い込むような大欠伸をしたから。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "逆に吸い込むとペンと言ってもとの向きに彎曲する。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙山の野原に鳥を吸い込む楊の木があるって。",
              "citation": {
                "source": "鳥をとるやなぎ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥を吸い込む楊の木があるとも思えず、又鳥の落ち込みようがあんまりひどいので、そんなことが全くないとも思えず、ほんとうに気持ちが悪くなったのでした。",
              "citation": {
                "source": "鳥をとるやなぎ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもいまでもまだ私には、楊の木に鳥を吸い込む力があると思えて仕方ないのです。",
              "citation": {
                "source": "鳥をとるやなぎ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白糸が佇みたるは、その裏口の枝折門の前なるが、いかにして忘れたりけむ、戸を鎖さでありければ、渠が靠るるとともに戸はおのずから内に啓きて、吸い込むがごとく白糸を庭の内にぞ引き入れたる。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気と共に花の匂いを一ぱい胸に吸い込むような大きな息もした。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "末造はその姿を目に吸い込むように見て、心の内に非常な満足を覚えた。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」紙巻き煙草の煙を吸い込む友のさまは、鎮静作用がありがたいとでも言うかのようだ。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "大柄なジョーンズの深々と吸い込む息。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "このリスがツラレミア大原病にやられていて、三日間こいつに取り付いていたダニがひょいと腕に飛び付き、その夜ベット上で奮戦中のオレ様の脇の下に潜り込んでＡ型の血を腹いっぱい吸い込む。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "また予は実験しないが、一八六七年パリ版、ゴダールの『エジプトおよびパレスチナ』一四一頁に記したは、エジプトで女奴を買う前、身体検査にその女の身内熱きか否かを識る法あり、大盥に水の冷たいのを入れてその中に坐せしむると吸い込む故、それだけ水面が降る。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこんなに梅が咲いたんだもの、じきに初午が来る」「よし原の初午は賑やかだってね」「むむ、そんな話だ」　箕輪から京間で四百｜間の土手を南へのぼれば、江戸じゅうの人を吸い込む吉原の大門が口をあいている。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれまで自分の心に憂鬱の雲がかかると、いつもきまったように松木立のなかに入って行くことにしているが、松脂の香気に充ちた空気を胸一杯に吸い込むと、憂鬱は影もなく消えてゆき、心はいつのまにか気力と新鮮さとを取り返している。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は自ら飼っている雲雀を朝早く空へ放ち、其れが帰って来て、彼の手の甲へ乗る時、嘴の先に附いている「天の気」――それは何かしら分子の様なもの――を自分の鼻孔へ吸い込むのである。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを合図に、第一番の三上治太郎は鮎を狙う鵜のようにさっと水に飛び込むと、淀んだ水はさらに大きい渦をまいて、吸い込むように彼を引入れてしまった。",
              "citation": {
                "source": "鐘ヶ淵",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "喬介は、煙草に火を点けてぐっと一息深く吸い込むと、眼を輝かせながら言葉を続けた。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お杉は参木の匂いを嗅ぎ溜めておくように大きく息を吸い込むと、ふと、お柳の家を首になった夜の出来事を思い出した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "健康な、多勢な、まだ眠っている活気を、そこで第一に吸い込むのである。",
              "citation": {
                "source": "思い出すかずかず",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二人は馬車にのって五里の間を、森や畑のあいだを、お互いの言葉を吸い込むように、よろこび味わいながら、語りつづけて、火のともる頃に私の家の前に着きました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "船が沈むと、大きな渦巻が起ってボウトを吸い込むというので――少し本船を離れると舷側が、途轍もなく高い黒い絶壁のように見えました。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒盃に酒をつげ、この胸に吸い込む息が出て来るものかどうか、誰に判ろう？",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが研究費だけを吸い込む初期の地固めの段階を過ぎても、コンピューター部門は一貫して収益を生み出せなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方の通人にいわせると、蕎麦は下地をちょっぴりとつけてするすると吸い込むものだというけれど、私はやはり下地を適当につけて口八分目に入れていくのがよいと思っています。",
              "citation": {
                "source": "蕎麦の味と食い方問題",
                "author": "村井政善",
                "note": "青空文庫"
              }
            },
            {
              "text": "咽ぶほど強烈な草いきれや、茸のかおりが鼻につく、私はそれを貪るように吸い込む。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩く毎に死の臭いを吸い込むような無気味さである。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
