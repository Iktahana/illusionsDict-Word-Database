    "definitions": [
      {
        "index": 1,
        "gloss": "to pass (by) each other",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お勘婆さんとすれ違う。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラブラと二三間来た時、又今度は大家の娘さんらしいのとすれ違う。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人ならんで歩いていると、すれ違うひとの十人のうち、八人は、振りかえって、見る。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中、すれ違う電車は一台もなかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆娑とした街路樹がかすかな露気を額にさしかけ、その下をランデ・ヴウの男女が燕のように閃いてすれ違う。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ジャネットは此の人混みにあおられるとすっかり田舎女の野性をむき出しにしてロアール地方の訛りで臆面もなく、すれ違う男達の冗談に酬いた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その男とすれ違う時、ぎらぎらする二つの眼が丹治の方を睨むように光った。",
              "citation": {
                "source": "怪人の眼",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝六時頃、この見附を、客人で通りました時は、上下、左右すれ違うとサワサワと音がします。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで往く人をして往かしめよって気持ちで、すれ違う人を見ないようにするのよ。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "道を歩いていても、すれ違う人のすべてが自分を嘲笑しているように思えた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついぞこれまでなかったことだが、今夜の豹一はすれ違う男たちの顔が眼について仕方がなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには半時間も掛って洗っているようになり、洗って居間へ戻る途中廊下で人にすれ違うと、また引き返して行って洗い直すのである。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "町ですれ違う女の人のように。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "）夫人　（次第に立出で、あとへ引かえしざまにすれ違う。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "船頭は馴れているので平気で棹を突っ張ると、今日はふだんより流れのぐあいが悪かったとみえて、急に傾いてゆれた船はたがいにすれ違う調子をはずして、向うから来た船の舳先がこっちの船の横舷へどんと突きあたった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "すれ違うはずみに綾衣の袖が一人の侍の刀の柄に引っかかって、中身は危うくするりと抜け出そうとしたのを、相手はあわてて押さえようとして、女の袖も一緒に掴んでしまったのであった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すれ違う時にきっと二人を見る。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、別に何事もなかったが、庭先きでふとすれ違うたので、早々に逃げて来た」と、兼輔は笑いにまぎらせた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すれ違う連中の八分通りはトルコ帽をかぶったペルシア人、韃靼人である。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つとして、疲労で蒼ざめ形のくずれていない顔はないのに、気が立っている故か、自暴自棄の故か、此方の列車とすれ違うと、彼等は、声を揃えてわーっと熾んな鯨波をあげる。",
              "citation": {
                "source": "私の覚え書",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むこうから来てすれ違う一人一人の通行人の顔が大写しになってかぶさって来るように感じる位ののろさなのだ。",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると仲間の水兵が一人身軽に舷梯を登りながら、ちょうど彼とすれ違う拍子に常談のように彼に声をかけた。",
              "citation": {
                "source": "三つの窓",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は彼とすれ違う時、肉体的に何かこたえるのを感じた。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時来かかった王冠堂の番頭久四郎は徳市とすれ違うとふり向いた。",
              "citation": {
                "source": "黒白ストーリー",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎさんは彼等とすれ違う時、ちょっと彼等の挨拶に答え、「風呂にお出で」と声をかけたりした。",
              "citation": {
                "source": "海のほとり",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何だかもうずっとたったら男のと女のすれ違う時が来るんじゃないかと思われる。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うから幸福な二人連れが来てすれちがう。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて一人の番頭とすれちがう。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ややあって一人の遊び人とすれちがう。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "友はまた京都にいた時代、電車の窓と窓がすれちがうとき「あちらの第何番目の窓にいる娘が今度自分の生活に交渉を持って来るのだ」とその番号を心のなかで極め、託宣を聴くような気持ですれちがうのを待っていた――そんなことをした時もあったとその日云っておりました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
