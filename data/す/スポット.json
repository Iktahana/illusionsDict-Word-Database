  {
    "uuid": "c7d25f0f-ae6c-5a6e-9bb5-6749eb677f68",
    "entry": "すぽっと",
    "reading": {
      "primary": "すぽっと",
      "alternatives": [
        "スポッと"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
