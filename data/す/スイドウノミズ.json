    "definitions": [
      {
        "index": 1,
        "gloss": "tap water",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あるいは夏季水道の水を汲んだままで実験していると溶けた空気が出て来て器械に附着し著しい誤りを生ずる事なども実験させた方がよいと思う。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手元では鼠が味噌濾や鍋をがたがたさせる音に雑って、水道の水がぽたぽたと落ちる音がした。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の上には東京特有の黄塵が薄くたまつてゐて、汽車の煤煙を水道の水で淨めた私の指先に不愉快な感觸を傳へた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の關係もない物質がごつたかへして秩序もなくころがつてゐる間に、龍頭から絶えず流れ出る水道の水だけが、たゞ一つすがすがしい感じを彼れに與へて音も輕く涼しかつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶以て念の爲に、別に、留桶に七八杯、凡そ湯船の高さまで、凍るやうな水道の水を滿々と湛へたのを、舷へ積重ねた。",
              "citation": {
                "source": "錢湯",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水道の水が、ざあ／＼鳴るのを聞きながら、酒をあまして、蕎麥屋を出た。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "味に精き者曰く、水道の水、礬気ありと。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時はお蔦の機知で、柔｜能く強を制することを得たのだから、例なら、いや、女房は持つべきものだ、と差対いで祝杯を挙げかねないのが、冴えない顔をしながら、湯は込んでいたか、と聞いて、フイと出掛けた様子も、その縁談を聞いた耳を、水道の水で洗わんと欲する趣があった。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば、気高いと申しても、天人神女の俤ではのうて、姫路のお天守に緋の袴で燈台の下に何やら書を繙く、それ露が滴るように婀娜なと言うて、水道の水で洗い髪ではござらぬ。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水道の水を召食ッていらっしゃれば、お色艶もそれ、お前さんのあの方に、ねえ旦那。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "共同水道端の水道の水滴がポトリ／＼落ちて、残置灯の鈍い光に照らされているのが、にわかに夜の更けた感じだ。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "明朝の引き潮にゃいよいよ水もほんとに引き始めるでしょう」　半四郎は飯櫃と重箱とほかに水道の水を大きな牛乳｜鑵二本に入れたのを次ぎ次ぎと運んでくれる。",
              "citation": {
                "source": "水籠",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな風で、金貨がなくなればなくなるで僕に自動車の代りに歩くことも容易く、咽喉を治すには水道の水が最も嬉しく、盛り場へ行かなければ、たゞの散歩をしてゐるだけで満足する。",
              "citation": {
                "source": "途上日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "水道の普及せるも、女の顏を美にする一因にあらずや』と云ふに、『水道の水は白粉とよく調和するかも知れず』と答へつゝ、客は二人なるに、藝者は一人のみなるかと、目を園の一方に移せば、居るは／＼、桃花の奧に、蓮歩を運ぶ一美形、※娜たる後姿のみ見えて、其の顏は見えざりき。",
              "citation": {
                "source": "小利根川の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "花はさくら、さくらは武藏の小金井と、上水の音に聞ゆる關左の名勝、水道の水の香ばしきを汲むにも、心は上流の花に飛ばずんばあらず。",
              "citation": {
                "source": "小金井の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩せた彼の肩や腕が赭く染まりかけてゐたが、四五日水道の水をつかつてゐるうちに、又褪せかけて来た。",
              "citation": {
                "source": "青い風",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "水道の水がボトボト鼻血を流し、柱の火災除けのお守りがかっと口をあけて、焔を吐き出したら。",
              "citation": {
                "source": "針",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間許りで源助は歸つて來たが、先樣の奧樣は淡白な人で、お八重を見るや否や、これぢや水道の水を半年もつかふと、大した美人になると言つた事などを語つた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間許りで源助は帰つて来たが、先様の奥様は淡白な人で、お八重を見るや否や、これぢや水道の水を半年もつかふと、大した美人になると言つた事などを語つた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして須磨子も水道の水を平気で飲まないで、少しは水の味も解るやうな感能の訓練をして貰ひたいものだといふ事を附け加へておいた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と話し／＼叔父さんは水道の水で手を洗つて「――お前達のところへよく髪を結つて貰ひに来た。",
              "citation": {
                "source": "出発",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "なか／＼寒い、水道の水のぬくさよ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてお湯一つくれないので、つい幾度となく水道の水をがぶりがぶりとやっていた。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて涙も一緒に水道の水でごしごしこすった顔を因幡の兎のように赤むけに光らして、しんから切なさそうにそのひとが席へ帰って来たとき、三十二人の全級はどういう感じにうたれたろう。",
              "citation": {
                "source": "歳月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "下宿の狭い薄暗い台所には小さな流場があつたが、鍋に水道の水を満たし指で白米を掻きまぜた瞬間、僕はこの流場が昔の僕の家の流場とそつくりのやうな錯覚がした。",
              "citation": {
                "source": "災厄の日",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸から新らしく此の町奉行として來任してから丁度五ヶ｜月、見るもの、聞くもの、癪に障ることだらけの中に、町醫中田玄竹は水道の水で産湯を使はない人間として、珍らしい上出來だと思つて感心してゐる。",
              "citation": {
                "source": "死刑",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポトリ／＼とバケツに落ちる栓のゆるんだ水道の水音に誘はれて、彼は郷里の家の裏山から引いた筧の水を懷しく思ひ出した。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "話が自然に横道にそれたきらいがあるが、しかし私がここにこれらの話を引き合いに出してきたのはほかでもない、裏棚に住まう労働者でも水道の水などはずいぶんむだに浪費しうるのであるが、それもやはり一種のぜいたくだということを、読者に考えていただきたいためのみである。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　水道の水と一緒に、小父さんの言葉が痛く胸に来た。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
