    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bare hand",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "と云って、立派に受け合って来た以上、今さら素手では帰れない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "せいの低いずんぐりした唐は素手で敵の歩哨に掴みかゝって、のど笛を喰い切り、銃と剣を奪ってくるような男だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルクレチウスは素手でともかくも後代の物理的科学の基礎を置いたことは事実であるのに、頭脳のない書物と器械だけでは科学は秋毫も進められないのである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜目には黄と黒の横縞に感じられる四階建ての店で素手に指環だけ一つ残したような小さい入口の上に foyot の屋号と二筋三筋のイルミナシヨンの細描きがあっさり浮き出ている。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は取附く島も無く、落胆して、「ああ情ない、我あ素手では帰られましねえ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の私服警官が粉煙草販売者を引致してゆく途中、小路から飛び出して来た数名がバラバラツと取りかこみ、各自手にした樫棒で滅茶苦茶に打ち素手の警官はたちまちぶつ倒れて水溜りに顔を突つ込んだ。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "素手の力で勝たないことには、おのれの心がすっきりしない。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを日本軍は、ほとんど素手で攻め落しているじゃありませんか。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は素手だつたのである。",
              "citation": {
                "source": "名人傳",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は素手だったのである。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "行かれるものか、素手で、どうして。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "遂に劇しい素手の拳闘が始まってしまった。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにもわては敲かしまへんぜ」　むしろ開き直り、二三度押問答の挙句、お辰は言い負けて、素手では帰せぬ羽目になり、五十銭か一円だけ身を切られる想いで渡さねばならなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "生生躍動した古代感情のリズムをこそ素手に捉へることである。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "生々躍動した古代感情のリズムをこそ素手に捉へることである」と。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "深い井戸の長い弔瓶縄が冷たいから、梅に気の毒だと云って、お玉は手袋を買って遣ったが、それを一々｜嵌めたり脱いだりして、台所の用が出来るものでは無いと思った梅は、貰った手袋を大切にしまって置いて、矢張素手で水を汲む。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "棘と、弾力ある吸盤とに、大分素手を傷められた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「一人の女は素手で絞め殺して、死骸を逆に煖炉の中にねぢ込んであつた。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内容がどんなものであるかの想像もつかないので、それを木村に読ませるのは、武器を相手に渡して置いて、自分は素手で格闘するようなものだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "序でに便所に入つて、二階の室に歸つて行くと、待ち兼ねてゐたらしい友は自分の素手なのを見て「又か？",
              "citation": {
                "source": "一家",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "百万石のお屋敷へ素手でもはいれまいが、どなたかご家中のかたはいませんかのう……」　つぶやくようにいった声をきいて、群れたかっていた群衆のうしろから、つかつかと影が近よりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "君がスープを拵へて待つてる間に、僕が急いで買ひに行つたまではいゝが、帰りにジプシーの唄うたひがゐたのへ附いて廻つてゐる内に、買つた物をどこかへ忘れて素手で帰つて来た事があつた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――素手で行こうというのです。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "素手は素手ながら三河ながらの直参旗本、早乙女主水之介が両の拳、真槍白刄よりちと手強いぞ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　見たところは凡そ三メートル位ゐの川幅なので、ひと思ひに向ひ岸に飛び越えるかしらと、身構へたが、妙なもので、飛ばうとは思はずに眺める時には、難なく飛び越えさうに見えるのだが、さて本気になつて、いざ飛ばんかと身構へて見ると、決して素手では飛べる川幅ではないのだ。",
              "citation": {
                "source": "ベツコウ蜂",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤグラ岳の麓の鬼塚村を訪れた時私があの木兎は素手で捕へたのだ。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのふ山より摘みてかへれば、紫苑はなしぼみて、すでに秋の愁ひをさそふ。",
              "citation": {
                "source": "立秋",
                "author": "――大沼竹太郎氏ニ捧グル詩――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ尾ばな藤ばかますでに色あせ、手にも料紙はおもたくさげられ、夏はやおとろへ、山頂は風に光る。",
              "citation": {
                "source": "山頂",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕が開くと、「ああ好いですわねえ」とその一人が云つた、「先代萩の序幕……あの舟はしつかり出来てますわねえ、かかりますでせうねえ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときすでに、ひとりの先客があった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
