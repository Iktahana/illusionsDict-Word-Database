        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同じポルツガル人はシヤムにもスポンジケイクの製法を教へた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕を取って、スポンジボオル、枯れなくていい、万年いけの大松を抜いて、（構えました、）を行る。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このプレゼントは、物ではありません」　寮長は袋の口を開き、黄色いスポンジ・ブロックを出して、それをつぎつぎと放り出す。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ドロップ、ミンツ、キャラメル、チョコレート、ウエファース、ワッフル、ドーナツ、スポンジ、ローリング、ボンボン、そのほかいろいろ、ある事ある事……。",
              "citation": {
                "source": "お菓子の大舞踏会",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつれて五色の着物を着た小人のミンツ達を先に立てて、キャラメル嬢をまん中にワッフルの兎、ドロップの道化役者、チョコレートの黒ん坊、ドーナツの大男、そのほかいろいろのお菓子達が行列を立てて行くあとから、スポンジ嬢が手鼓をたたきながらついて行きます。",
              "citation": {
                "source": "お菓子の大舞踏会",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐそばで、ホテルのコックがスポンジボールでキャッチボールをしている音が単調に聞こえる。",
              "citation": {
                "source": "謎の女",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには黄色くなった雑草が生えしげっていて、いつもはスポンジ・ボールの野球をやるのに、近所の小供や大供が使っているところだった。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "インク、紙、ペン、頭のブラシ、着物のブラシ、鏡、石鹸、スポンジ、ポマード、タオル、巻煙草、葉巻、刻み煙草というように、普通の人間の日常要るものは大がいならべてある。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ターニャは石鹸の泡だらけのスポンジで私の背中をこすりつつ、又云った。",
              "citation": {
                "source": "無題（七）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして良い加減、暖たまったところで立ち上るとすぐに、私を流し場の板片の上に引っぱり出して、前後左右から冷めたい石鹸とスポンジを押し付けながら、遠慮会釈もなくゴシゴシとコスリ廻した。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして愈々強直してしまった、艶めかしい姿の白坊主をヤットコサと抱き上げて、寝棺の中にソッと落し込んで、三枚｜襲ねの振袖と裲襠を逆さに着せて、糸錦の帯で巻立ててやりますと、今度は多量のスポンジと湯と、水と、石鹸と、アルコールとで解剖台面を残る隈なく洗い浄めました。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れ切った身体を起して室内に散らばっているガーゼ、スポンジ、脱脂綿なぞを一つ残らず拾い集めて、文房具、化粧品等と一緒に新しい晒布に包み込んで、繃帯で厳重に括り上げてしまいました。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "抽斗や、下着入れを覗いているんだったら、今のうちに蔵うことよ……」　やがて私は、パドミーニが出しわすれていた三角スポンジを手に、把手をやんわりとひねっていました。",
              "citation": {
                "source": "一週一夜物語",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼探偵が例の仕事を胸に畳んで虎の門公園の脇を通行中、公園の中からいきなりスポンジ・ボールがとんで来て探偵の頭に強く当った。",
              "citation": {
                "source": "烏啼天駆シリーズ・４　暗号の役割",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "○スポンジ・ゼリーという菓子あり。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "スポンジソースは玉子一つへ砂糖を軽く一杯の割で黄身も白身も一緒に混ぜて湯煎にしながら玉子廻しで泡を立てたものです。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四十三　米のスポンジゼリー　も前の物に似ていますがお米の粉大匙二杯と牛乳二合と砂糖大匙四杯とをよく掻き廻しながら弱火で四十分間ほど煮てゼラチン七枚を加えて火から卸します。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリームソースにすればフレッシクリーム一合を沸かして砂糖を加えてコルンスタチ小匙一杯余でドロドロにしたもの、スポンジソースにすれば玉子と砂糖を等分に混ぜて湯煎にしながら泡立ててカステラの原料のようにしたものです。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつが転げ落ち床をコロコロと動くのを見れば、それはスポンジボールであった。",
              "citation": {
                "source": "空気男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "迎いの風　清家博士夫妻は、寝室のなかで、別々に空気のように透明となり、空気のようにフワフワ宙に浮いているところへ、そのスポンジボールが飛んできて硝子窓をわったのである。",
              "citation": {
                "source": "空気男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "また心の隅には戦いが初まって以来、かかる意味の大衆の拍手の嵐の中に、生きていつの日にか面し得ると、乾きに乾いたものがあって、今、それが、スポンジがぬれてゆくようにふくれ上ってゆくものがあった。",
              "citation": {
                "source": "実践について",
                "author": "――馬になった話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "凄いウナリじゃないか」「スポンジボールだからね」「なアに別所だって、あんなもんだよ。",
              "citation": {
                "source": "町内の二天才",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱によりかかって、背中をねじくりながら、ゲラゲラ、ゴロゴロと喉の中をスポンジボールがころがるような奇怪な音を発してとめどなく笑いくずれている。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その一　舞踏会殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも　〈キャラウェイシード〉のパウンドケーキや　スポンジケーキ、　バターロールパンだけでは　なかなか　いきてはゆけません　――　ティモシーが　つくるほど　おいしい　スポンジで　あってもです！",
              "citation": {
                "source": "ジンジャー＆ピクルスのはなし",
                "author": "THE TALE OF GINGER AND PICKLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭酸マグネシウムを加えて作ったパンの塊はオーヴンでよく膨れ、焼きあがった後でパンは軽くスポンジのようであり味が良く長いあいだ保存できる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おかみさんが帽子をさけようと、右にむいたとたん、こんどは洗面台のスポンジがとんできた。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴室は天井まで模造大理石を張りつめ、十人もいっしょにはいれるような薄緑の蛇紋石の大きな浴槽のそばに、タオルのおおいをかけたスポンジの寝椅子が置いてある。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯上りに、ためしに寝ころがってみたら、厚いスポンジの層がサト子のからだをフンワリと受けとめ、宙に浮いているような安楽な状態にしてくれた。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
