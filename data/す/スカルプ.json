          "literary": [
            {
              "text": "530ロクリス族の住む處、キノス、オポース、カリアロス、ペーッサ及びスカルプェー、更にいみじきアウゲーア、更にタルプェー、トロニオン、傍へる流はボーグリョス。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "或晩、私はヴィユ・コロンビエ座の新劇を観に行くつもりで、宿の近くのコントル・スカルプの辻から乗合に乗った。",
              "citation": {
                "source": "二人のセルヴィヤ人",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリのパンテオンの裏の方にコントル・スカルプという汚らしい辻がある。",
              "citation": {
                "source": "パリの散策",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実を言えば、突然小銃が三発発射されたのであって、第一発は中隊長ショーレを殺し、第二発はコントレスカルプ街で窓を閉じていた聾の婆さんを殺し、第三発は一将校の肩章にあたった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
