        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "下の方は、足をのせる金属の台があつて、それには透かし彫りの模様があります。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お宮の扉の上にある象鼻や獅子頭の彫刻、それから宮の中の透かし彫りの鳩やにわとりなども、昔手をふれたままなのがたまらなくなつかしい。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "沈の木の透かし彫りの箱に入れて、同じ木で作った上飾りを付けた新味のある御贈り物であった。",
              "citation": {
                "source": "源氏物語",
                "author": "絵合",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさしく、だきみょうがの透かし彫りが見えるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭には朝鮮風の金銅彫りの妙異な冠が飾られ、それから宝石をちりばめた透かし彫り金物の長い飾り紐が垂れている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "振子は、金メッキされて居り、透かし彫りにした朝顔が、その肩のところに花を開いている。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "簀戸の腰板に、観世水が透かし彫りになっていた。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の方は、足をのせるかねの台があって、それにはすかしぼりの模様があります。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一階の上にある長い張出窓には、図456に示すように、松、竹、その他をすかしぼりにした繊美な木細工が、ちょいちょい見られる。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
