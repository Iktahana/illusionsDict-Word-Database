        "examples": {
          "standard": [
            {
              "text": "暑い日は、公園のプールでスイミングするのが一番だ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わーい！ スイミング楽しい！」と子供たちが歓声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "健康維持のために、週に二回スイミングを続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一人の生徒はスイミングワルツの口笛を吹きました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいているスイミング・トランクスはふたまわりも大きく、金髪のうぶ毛がいっぱいに生えた胴体から、そのはき古したトランクスはいまにもずり落ちそうだった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "部室で裸になり、薄いナイロンのスイミング・ショーツを身につけた祐一は、半地下のようなコンクリートの通路を歩いて、プールへ出た。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "外見は良くても、気持ちは冷たいから」「勝手にそう思うだけだろう」「みんなに聞いてみろよ」　口をとがらせてそう言い、中沢はスイミング・ショーツ一枚で部室を出ていった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
