        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こうした「能」のあらわれは、格風を崩さぬ物の師匠の挙動、正しいコーチと場数を踏んだスポーツマンのフォームやスタイルの到るところにも発見される。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日スポーツマンにしてこの自然的動作を活用しているものはほんの僅かに過ぎない。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スポーツマンの内でも水泳の選手が一番自然法を採用している。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は、スポーツマンか？",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スポーツマンだったら、恥ずかしく思え！",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頗るのんきな、スポーツマンである。",
              "citation": {
                "source": "犯人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代的で、スポーツマン・タイプで、清秀で明るい感じのこの青年は、綾子夫人の母方の遠縁に当るという。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄化粧したスポーツマン。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "スポーツマンの朝の充実した感情を描いた『朝』では手堅い仕事ではあるが試みの域を出てゐない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "また肉体だけを見ると、スポーツマンか拳闘手のようにも見える。",
              "citation": {
                "source": "ホオムズの探偵法",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして入口のドーアを背にして、いま声を出したのであろう、立派な顔をしたスポーツマンらしい青年が立っている。",
              "citation": {
                "source": "不思議なる空間断層",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛布の幕の聞から、ゴロリと転げこんできたのは、スポーツマンらしい大きな男だったが、顔色は紙のように白く大きな口をあけてあえぎながら、両手でしきりに咽喉のところをかきむしっていた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、一瞬の間、急に秋蘭の興奮した顔が、屈折する爽やかなスポーツマンの皮膚のように、美しく見え始めた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "子福者小笠原伯爵の何番目かの娘さんが最近スポーツマンであった体躯肥大な某氏と結婚された写真が出ていた。",
              "citation": {
                "source": "新しい一夫一婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸名のあるスポーツマンになるといいぜ、就職が楽だぜ。",
              "citation": {
                "source": "新しい一夫一婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スポーツマンあたし大好きだわ」　私も彼等の健康と気魄の美に打たれていた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために選手たちのスポーツマン・シップは危機にさらされがちであること、及び、各大学の運動部は、その学校の精神水準としては、社会的認識についても素朴な低い面を代表しがちな傾向について書かれていた。",
              "citation": {
                "source": "ボン・ボヤージ！",
                "author": "――渡米水泳選手におくる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさに、蚤のシーズンだ、彼等はスポーツマンだ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、あらぬ疑を身に受けてさんざん苦しみ抜いたが、さすがにスポーツマンらしく朗かさと明るさを失わなかつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高校まで柔道や剣道をやっており、警察でも続けていきたいというスポーツマン。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば素晴らしく平坦な阪神国道、その上を走るオートバイの爆音、高級車のドライヴ、スポーツマンの白シャツ、海水着のダンダラ染め、シネコダックの撮影、大きな耳掃除の道具を抱えたゴルフの紳士、登山、競馬、テニス、野球、少女歌劇、家族温泉等であるかも知れない。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "スポーツマン、均斉のとれた羚羊のような肢体。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　スポーツマン・スピリッツ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がかう考へたのは、私は元来スポーツマンで運動神経が発達してゐるから、肉体の敏活なる反応が訓練によつて非常に大きな差を表すことを熟知してゐるからであつた。",
              "citation": {
                "source": "わが戦争に対処せる工夫の数々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "色は白い方で、背丈も高からず、肉附もふくらかであったので、何となく女性めき、この頃もてはやされるスポーツマンとは凡そ正反対の男であった。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて例の金青年と来ると、身体が大きいばかりで男前がよいというのでもなく、スポーツマンらしい垢ぬけたところがあるのでもなく、どちらかと云えば男として美の要素の欠けた青年だった。",
              "citation": {
                "source": "ゴールデン・バット事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人は、日焼けのした背の高いスポーツマンのような男だった。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "スポーツマンはコーチより先ずそれを学ぶのである。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
