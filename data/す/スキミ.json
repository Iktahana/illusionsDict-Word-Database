[
  {
    "uuid": "f02a5875-418a-5f6b-808e-54e95cbdedec",
    "entry": "剥き身",
    "reading": {
      "primary": "すきみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
