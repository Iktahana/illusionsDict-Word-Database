    "definitions": [
      {
        "index": 1,
        "gloss": "several people",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで月末には吃度数人の被解雇者を見るといふ現象も、遂には此の会社の常習となつてしまつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "その背後に立っていたのは、この未亡人の二人の娘で、とうに他家に嫁いで二人ともに数人の子供の母となっているのであるが、その二人が何か小声で話しながら前に腰かけている老母の鬢の毛のほつれをかわるがわるとりあげて繕ってやっている。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ったら頭の閊える箱の中に数人の客をのせたのを二、三人の人間が後押しして曲折の多い山坂を登る。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良朝の文献は幾つかありますが、その中『古事記』は無論太安万侶一人が書いたものであるが、しかし『日本書紀』のようなものになりますと、数人の編輯者があって、巻ごとに違っているとは言えませぬけれども、巻によって誰かが主になって書いたという違いがあると思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "相続当時計画していたような大規模な研究室を作り、数人の有給助手をおくような望みは絶えてしまった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本劇場の前まで来て見ると、さすがに今日はいつもの日曜とちがって切符売場の前にはわずかに数人の人影が見えるだけであったので急に思い付いて入場した。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃が悪い悪いと年中こぼしながら存外人並以上に永生きをした老人を数人知っている。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて又数人、口々に「喧嘩だ」　と言っているらしい。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その跡には、薄暗いベンチから身を起して、喪服を着た数人の婦人が続いた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、私を愛してくれる数人の女達によって、運命は咲き誇っているのだ。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンスタンチノーブルから乗りこんだ女実業家の数人が談論の花を咲かして、僕を勇気づけてくれたにもあるのだが僕はいまに土耳古が商工業に於ける世界の中心地にさえなると思うのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "サルーンでは数人の英国人が別れの唄を合唱している。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "椰子の樹下のタクシーに英国人十数人が一人の女を胴あげにして一塊になると喚声の間に泣き叫ぶ女の哀調をのこして砂塵をたてて見えなくなってしまった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "同級のＩ君が脚気で亡くなったので、われわれ数人の親しかった連中でその葬式に行った。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石田はそのなかに一つの窓が、寝台を取り囲んで数人の人が立っている情景を解放しているのに眼が惹かれた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこの両者が共同し、その上に機械的の計算や統計を担当する助手の数人の力をかりることができれば、仕事はかなりおもしろく進行しそうに思われる。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲーテの家には制服を着けた立派な番人が数人いましたが、シラーのほうには猫背の女がただ一人番していました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、数人の浪士が、ちょこちょこと駆けずり回る場面がなんべんとなく繰り返される。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "観音の境内や第六区の路地や松屋の屋上や隅田河畔のプロムナードや一銭蒸汽の甲板やそうした背景の前に数人の浅草娘を点出して淡くはかない夢のような情調をただよわせようという企図だとすれば、ある程度までは成効しているようである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂の仕事をしている場処に行ってみると、僕は電気の事を詳しく知らないから十分の説明はできないが、一本の太い鉄柱を擁して数人の人が立っていて、正作は一人その鉄柱の周囲を幾度となく廻って熱心に何事かしている。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かんてらから黒い油煙が立っている、その間を村の者町の者十数人駈け廻わってわめいている。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがそこで下車する数人を降ろして、しかして二十人三十人を新たに収容しなければならない事になる。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても乗れなくて乗りそこねた数人の不幸な人たちは、三十秒も待った後に、あとから来た車の座席にゆっくり腰をかけて、たとえば暑さの日ならば、明け放った窓から吹き入る涼風に目を細くしながら、遠慮なく足を延ばして乗って行くのである。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三年の間にはすっかり一面に広がって、もうとても数人の子供の手にはおえないようになってしまった。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "工兵が数人かかって塔のねもとにコツコツ穴をうがっていた。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和六年四―五月、渋柿）　　　　　三　連句と合奏　連句の文学的作品としての著しい特異性の一つと見るべきことは、それが一つのまとまった全体を形成しておりながらその作者は必ずしも一人の人間でなくてむしろ一般には数人の一団より成る「集合人」であるということである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢詩でもたまには数人の合作になるものはあるようである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろはひとつづきの小説を数人の作者が書き続けて行くのもあるようである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより開墾の初期に草分けとしてはいった数人の人は、今は一人も残ってはいませんが、その後毎年はいってくれた人々は、草分けの人々のあとを嗣いで、ついにこの土地の無料付与を道庁から許可されるまでの成績を挙げてくれられたのです。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
