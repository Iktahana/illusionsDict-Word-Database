[
  {
    "uuid": "0d8561b2-24d8-584b-ba8d-de34cf07a115",
    "entry": "垂楊",
    "reading": {
      "primary": "すいよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
