          "literary": [
            {
              "text": "「捨て犬をもらうところがあると、いつかお父さんがいったよ。",
              "citation": {
                "source": "野菊の花",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生も御承知のとおり、わっしは生得、犬猫がすきでごぜえやして……」　じっさいこのお爺さん、自分で言うとおり、犬や猫がすきで、商売は絵草紙売りなのだが、かせぎに出ることなど月に何日というくらい、毎日のように、そこらの町じゅうの捨て猫やら捨て犬をひろってきて、自分の食うものも食わずに養っているのだが。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまや　すていぬの　わたくしを　ぜひに。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
