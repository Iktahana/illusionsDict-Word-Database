        "examples": {
          "standard": [
            {
              "text": "浅草からお台場まで、近未来的なデザインの水上バスに乗って移動した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "通勤ラッシュを避けるために、水上バスを利用する人が最近増えているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "水上バスの窓から眺める夜景は、デートの締めくくりにぴったりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "水上バスへ御乗りのお客さまはお急ぎ下さいませ。",
              "citation": {
                "source": "吾妻橋",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "水上バスは言問から柳橋、両国橋、浜町河岸を一周して時間は一時間、料金は御一人五十円で御在ます。",
              "citation": {
                "source": "吾妻橋",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "水上バスは言問から柳橋、両国橋、浜町河岸を一｜周して時間は一｜時間、料金は御一｜人五十｜円で御在ます。",
              "citation": {
