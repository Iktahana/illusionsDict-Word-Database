[
  {
    "uuid": "b24fc401-8ff4-5cac-bb66-c2410b946c3c",
    "entry": "荒む",
    "reading": {
      "primary": "すさむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
