        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "スラロームを描きながら、この立木の間を縫って、どこまでも滑って行く。",
              "citation": {
                "source": "大雪山二題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャラコさんは、ちょっと心配そうな顔つきで眺めていたが、梓さんがみごとなフォームで制止したのを見届けると、スラロームを描きながらゆっくりと降りて行った。",
              "citation": {
                "source": "キャラコさん",
                "author": "雪の山小屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い鉄棒の支柱のあいだを、スラロームで抜けた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじように鉄棒でスラロームをし、ぼくの前まで帰ってきて、とまった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の駅前の人通りのなかを、スケートボードのスラロームで降りてくる女の子がいる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "教習所で教えてくれるスラロームのように蛇行しつつ、パトカーをうしろにひきつけた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
