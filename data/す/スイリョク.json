[
  {
    "uuid": "bdffb10d-9962-5b95-b85a-f4568c4b7453",
    "entry": "水力",
    "reading": {
      "primary": "すいりょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hydraulic power",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は水力電気を予想しなかった上に、最も蒸汽の力を借ることを憎んだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その問題ならば、自分が帰つたところで、手ブラで帰つたのでは、邪魔になるだけなのだから、それよりも、年来の目論見である、水力発電所に関する長編でも、書きあげようと、発電所の見おろせる鳥屋にガン張つてゐた。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水力発電所が何箇所かある。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水力発電所が何カ所かある。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この原料を作るには水力電気を用いる。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが動機となって後にこの荘園内にあった「白鳥池」を利用して水道工事が出来、これが後に水力学の実験に利用されるようになったのである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八七五年から七六年にわたる冬の数箇月間ビーチャム・タワー（Beauchamp Tower）というエンジニアーを助手として水力学の実験をした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に述べた「白鳥池」を利用して水力実験室を作り、色々の形の穴から水を流出させるときの孔内の圧力分布を測ろうというのであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石炭や水力を得難い土地では風車を用いた方が石油機関よりは利益だという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、重力に逆らい、風圧水力に抗するようないろいろの造営物を作った。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙は其を横目で見て、「まさか水力電気論の中には説明してあるまいよ。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と甲は水力電気論を懐中に押こんだ。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と「水力電気論」を懐にして神崎乙彦が笑いながら庭樹を右に左に避けて縁先の方へ廻る。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺は鬼怒川水力電気の工事があるので、至る処、鬼のような工夫に逢う。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "星野に小さな水力発電所がある。",
              "citation": {
                "source": "軽井沢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてその渦巻すなわち凹みは広くかつ深くして、もし船舶にしてその吸引力圏内に入るときは、かならず吸いこまれ海底に運び去られて岩礁に打ちくだかれ、水力衰うるに及び、その破片ふたたび水面に投げ出されるなり。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "花屋の前にも、どこかの水力発電所の監督らしい人の、高級なバラックが建っていた。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行は吉本組××地区飯場で、水力電気の土工工事に働くのであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝の尿が水力機を動かすほどの川となり汝の糞が馥郁と芳香を発する時節が来たら汝始めて休み得べしと言った。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "水力電氣の工事の爲に、少し風致を損したれども、なほ天下無類の奇景也。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "水力電気といふものが発達してから、何処の渓谷も皆わるくなつたが、この谷などは中でもひどく壊されてしまつたやうに思ふ。",
              "citation": {
                "source": "あちこちの渓谷",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば、水力は、人間が全然これを利用し得なかつた時代には一つの自然力としては存在してゐたに相違ないに拘らず、社会的価値をもつてはゐなかつたが、人間がこれを水車に利用し、これを利用して発電所を設けるやうになると、社会的価値を獲得して来る。",
              "citation": {
                "source": "諸家の芸術価値理論の批判",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "水力電気は、もうとっくの昔から停まっているが、今まで送電をつづけてきた火力電気も、いよいよ貯蔵の石炭がつきてしまったのであった。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の小父さんから教えられた、水力じかけの工場をな！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍事上どんな役に立つのです」「さあそれは……」と牧山大佐は腕組をして「海水の干満によって水準の変るのを利用し、高い方から海水を低い方に流して、水力発電するためだといっている。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が持って来た密書を見るまでは水力発電説も相当有力だと思っていたがいまはそうじゃない。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "五箇年計画でソヴェト同盟の中には、水力発電所、工場、集団農場、夥しくふえた。",
              "citation": {
                "source": "「鎌と鎚」工場の文学研究会",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
