        "examples": {
          "standard": [
            {
              "text": "画面上のスライダーを動かして、動画の再生音量を調節する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "画像編集ソフトのスライダー操作で、写真の明るさを直感的に変えられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "サイトのフォントサイズを、スライダーで好みの大きさに設定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
