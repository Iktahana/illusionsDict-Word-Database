        "examples": {
          "standard": [
            {
              "text": "彼は伝家の宝刀であるスライダーを武器に、三振の山を築いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "外角へ逃げていく鋭いスライダーに、打者のバットが空を切った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "決め球にスライダーを選択したが、わずかに浮いて長打を浴びてしまった。",
              "citation": {
                "source": "幻辭AI",
