        "examples": {
          "standard": [
            {
              "text": "父が亡くなった場合、長男である私が第一順位の推定相続人となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "遺産分割を円滑に進めるため、あらかじめ推定相続人の範囲を確認しておく必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "推定相続人が著しい非行を働いた場合、家庭裁判所に相続廃除を申し立てることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "我が家の推定相続人が、ハンカチを欲しがってるようだけど、その望みは叶えられると思うわ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
