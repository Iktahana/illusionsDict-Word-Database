        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "隙間なく密生しても活力を失わないという特徴があるために垣根の適当な素材として選ばれたのであろう。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隙間なく水の面を被つてゐる、彼等のかさなりあつた翅が、光にちぢれて油のやうな光彩を流してゐるのだ。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな空想に耽りながら見ていると、簑の上に隙間なく並んでいる葉柄の切片が、なんだかこの隠れた小哲学者の書棚に背皮を並べた書物ででもあるような気がした。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隙間なく水の面を被っている、彼らのかさなりあった翅が、光にちぢれて油のような光彩を流しているのだ。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四枚、五枚、六枚、七枚、」　と数える内に、拾い上げた膝の上は、早や隙間なく落葉に埋もるる。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も金を接ぎ合せた様に寸分の隙間なく寄せてくる。",
              "citation": {
                "source": "『煤煙』の序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "御存じの烈しい流で、棹の立つ瀬はないですから、綱は二条、染物をしんし張にしたように隙間なく手懸が出来ている。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其間舞臺では、強く誇張された人相を刻まれたので、其爲めに一方には頗る漫畫的に見えるが、同時に、巧みなる人形遣の爲めに隙間なく動かされるので、却つて其不安定な動的の表情が運動の眩惑を助ける所の人形が怒つたやうな顏で泣いて居た。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その川の両側つづき、隙間なく枯木つづけり。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "立枯並木の歌霜ふかき野川の堰、あはれよと今朝見に来れば、いつとなく水量涸れつつ、隙間なく氷張りけり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "車のゆきかふこと隙間なく見ゆるに、その餘せる地にはうれしげなる面持したる人肩｜摩るほどに集へり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭は皆白壁なれど、礎より簷端迄、緑いろなる黴隙間なく生ひたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛簷傑閣隙間なく立ち並びて、その翳なきこと珠玉の如く、その光あること金銀の如く、紫雲棚引き星月｜麗れり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "路はその雑木の中に出つ入りつ、糸を引いて枝折にした形に入る……赤土の隙間なく、凹に蔭ある、樹の下闇の鰭爪の跡、馬は節々通うらしいが、処がら、竜の鱗を踏むと思えば、鼈の足痕を辿るよとも疑われた。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御厨子の前は、縦に二十間がほど、五壇に組んで、紅の袴、白衣の官女、烏帽子、素袍の五人｜囃子のないばかり、きらびやかなる調度を、黒棚よりして、膳部、轅の車まで、金高蒔絵、青貝を鏤めて隙間なく並べた雛壇に較べて可い。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "びっしりと隙間なく組まれた本文は、言うまでもなく活字による印刷でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者の富田修二によれば、グーテンベルクはさらに、前の文字と隙間なく並ぶ〈繋ぎ文字〉を再現するために、活字の左側をぎりぎりまで削り込んだものを、特定のアルファベットに関して用意したといいます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も町には隙間なく車が出ていた。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、演壇または青天井の下で山犬のように吠立って憲政擁護を叫ぶ熱弁、若くは建板に水を流すようにあるいは油紙に火を点けたようにペラペラ喋べり立てる達弁ではなかったが、丁度甲州流の戦法のように隙間なく槍の穂尖を揃えてジリジリと平押しに押寄せるというような論鋒は頗る目鮮ましかった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも人形の心に、菊をいちめんにはわせて、花と葉が平に隙間なく衣装の恰好となるように作ったものである。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵は隙間なく追いつめて来ます。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "稽神録",
                "note": "青空文庫"
              }
            },
            {
              "text": "大型の紫檀の書棚には金文字の洋書が隙間なく並んで上段には中世紀の海賊船の模型や銀の燭台やらが並んでゐるし、一方の飾棚を見あげると数十種の洋酒の壜が四段、五段と隙間もなく並んでゐる。",
              "citation": {
                "source": "露路の友",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さても城の主じは窓より外を眺め居て、近付く姫と隙間なく（at all points）物の具つけたゲーレスとを見た。",
              "citation": {
                "source": "アーサー王物語",
                "author": "KING ARTHUR'S ROUND TABLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には二階を開け放して、数十の大燈籠を天井に隙間なく懸けている家がある。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "二本の白木の棒とでも云おうか、腕からかけて指の先まで白布で隙間なく巻き立ててある。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の両足は白い布で、隙間なくキリキリと巻き立てられていた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供を抱いている母親の両手は、布で隙間なく巻かれていた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロコンピューターに取りつかれたマニアたちの息吹を追い風として、ＰＣ―８００１を軌道に乗せようと奮闘してきたこれまで、大内の理と渡辺の熱と後藤の夢の歯車は、隙間なくぴったりと噛み合ってきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は天主閣の建っていた所が平地になって、いつしか姫小松まばらにおいたち、夏草すきまなく茂り、見るからに昔をしのばす哀れなさまとなっています。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学時代にひと夏裏の離れ屋の椅子に腰かけて読書にふけり両足を言葉どおりにすきまなく蚊に食わせてから以来蚊の毒に免疫となったせいか、涼み台で手足を少しぐらい食われてもほとんど無感覚である。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
