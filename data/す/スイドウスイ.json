        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "上水道水源地散歩、蛇が落ちこんで泳ぎまはつてゐる、多分這ひあがることは出来まい、まいまいはいういうと泳いでゐる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "電信工事・秋晴の仕事がいそがしい空間　　　上水道水源地・水底太陽のかゞやいて水すまし　十月十二日　晴、仲秋、月はよからう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か具合が悪いと水道水は時に井戸の頂上から噴出して水路すなわちドブに流れだし、後になって不純物と混じって戻る。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで灌漑用水も、水道水も、工業用水も、自由にとれるようになった。",
              "citation": {
                "source": "アメリカの沙漠",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで廊下には到るところに、冷やした水道水が出るようになっている。",
              "citation": {
                "source": "日本のこころ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳密に言えば、水道水でも飲料には適してません。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
