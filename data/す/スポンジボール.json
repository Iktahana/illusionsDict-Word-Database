        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すぐそばで、ホテルのコックがスポンジボールでキャッチボールをしている音が単調に聞こえる。",
              "citation": {
                "source": "謎の女",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつが転げ落ち床をコロコロと動くのを見れば、それはスポンジボールであった。",
              "citation": {
                "source": "空気男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "迎いの風　清家博士夫妻は、寝室のなかで、別々に空気のように透明となり、空気のようにフワフワ宙に浮いているところへ、そのスポンジボールが飛んできて硝子窓をわったのである。",
              "citation": {
                "source": "空気男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "凄いウナリじゃないか」「スポンジボールだからね」「なアに別所だって、あんなもんだよ。",
              "citation": {
                "source": "町内の二天才",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱によりかかって、背中をねじくりながら、ゲラゲラ、ゴロゴロと喉の中をスポンジボールがころがるような奇怪な音を発してとめどなく笑いくずれている。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その一　舞踏会殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな雑種でも「持ってこい」などははやく覚える、ぼくの家ではスポンジボールを放って持ってこいという。",
              "citation": {
                "source": "犬",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "六メートルも飛んでいた私が、一尺五寸ぐらいのドブをとびそこなって墜落したり、キャッチャーがうけとれなかったぐらいスピードのあった私が、スポンジボールを十｜米も投げることができなくなった。",
              "citation": {
                "source": "世に出るまで",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
