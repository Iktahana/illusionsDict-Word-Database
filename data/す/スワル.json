    "definitions": [
      {
        "index": 1,
        "gloss": "to sit (down)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "Ｓ＝店　次郎長が足を拭き終って上へ座る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "仇討で御座る」　と言って、Ｔ「憎い敵奴残念乍ら取り逃し申した」　と言う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚倉が、Ｔ「盗人で御座る」　と呼んで捕方と共に追う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何で御座ると山左。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍二人付き添って甲の侍が君江に、Ｔ「雲霧主膳様からのお迎えで御座る」　ヘッと長七と君江顔見合せた。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやいや皆まで申されるな」　「では」となりひらが、Ｔ「この連判状は貴殿に進呈致すその代り」　と言って、Ｔ「但馬屋源兵衛を早速放免して戴きたい」　「よろしゅう御座る」と左衛門、　「では」となりひら連判状を其処へ置く。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりひらが、Ｔ「これを早馬で牢屋敷へ届けて戴き度いんだが」　よろしゅう御座ると左衛門。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯が食いてえな」　よろしゅう御座ると左衛門。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「如何で御座る」と団九郎。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍が、Ｔ「先生　只今御病気中に　御座れば」　ナニッ病気、と団九郎、　取次の侍、紙包を取り出して、Ｔ「誠に軽少に　御座るが　ホンの草鞋銭」　と団九郎の前に差し出す。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　武蔵が、Ｔ「先生の門人として　道中御供　致し度う御座る」　ウンウンと団九郎。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言って、Ｔ「だから身共が　そのお顔は」　と言って、Ｔ「女にもてぬと　申したのさ」　と、今度はおしまに向って、Ｔ「これから　男に惚れるなら」　と言って、Ｔ「名前に惚れず　人間に惚れる事で　御座る喃」　と言い捨てて去る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎が、先生何で御座る、と言う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いた庄屋が、Ｔ「巳年の男で　御座いますか」　左様、と武蔵がうなずいて、さて、　Ｔ「聞けば近々　御婚礼との事で　御座るが」　ハッハイと庄屋、心配そうに、Ｔ「相手の男が　巳年でないと」　悪う御座いますかと訊く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵が、Ｔ「天狗の祟りが　怖ろしう御座るぞ」　ハテ困った、と庄屋。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿様は頭に繃帯をして御座る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私達は腕をくむと、附近の青天白日旗の飜っている、支那公使館のまえのインタナショナル・バーの酒卓へ座ると、盃をかちあわした。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は、机のはしに、丸い爪を持った指の太い手をついて、急に座ると腰掛が毀れるかのように、腕に力を入れて、恐る／＼静かに坐った。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この乱暮さを御覧なさい、座る所もないのよ。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "四っ角山にみんなぺたぺた一緒に座る。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の奴に、Ｔ「此処が面白う御座るぞ」Ｔ「では交代致そう」　で今度は隣を覗く。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ナ……何で御座る。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅多に見えませんがなあ、お島どんは……それでも御座るとアノ非人を相手に長い事話し込んで御座ったという話で……」「イヤ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "御座るか御座らんか。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "まかり間違うて大公儀の耳にでもそげな事が入ったなら、直ぐさま、黒田五十五万石のお納戸の信用に差響いて来るやら知れぬ話じゃけに、成る限り大切を取って極々の内密に、しかも出来るだけ速よう下手人を探し出せと言う大目付からの御内達で、お係りのお目付、松倉十内｜様も往生、垂れ冠って御座る。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日田金を日田の材木屋が下請けのようにして、日田の月隈の奉行所に御座る大公儀の御金奉行の監督を受けながら、九州の諸大名の城下城下におる御用金預り……博多で言えば蔵元屋のような主立った商人にソレゾレ貸付ける。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすが明智の川村｜様も弱り切って御座るという話……」「アハハ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から腕前のない、手柄望みの役人は、すぐに弱い正直者を罪に落そうとするものじゃてや」「とは言うものの、蔵元屋の方も、家内の模様さえまだわかっておらぬけに、松倉どんもバッタリ行詰まって御座るが、さればとてほかには何の手も足もない。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "アハハハ……」「何もかも知って御座る限りタネを打割って申上げて下されや」「オッと待ったり。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに膳が出て来て一同その前にすわる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
