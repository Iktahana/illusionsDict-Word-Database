    "definitions": [
      {
        "index": 1,
        "gloss": "light reddish brown",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雀色の夕まぐれ、さっと人波にさらわれてしまった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はまたこういう時に「さあ、もう雀色時になったから」と母の言ったのを覚えている。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀色時という言葉はそのころの僕にも好きな言葉だった。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "沙金は、おれの行く時刻を見はからって、あの半蔀の間から、雀色時の往来をのぞいている。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、雀色時の靄の中を、やつと、この館へ辿りついて、長櫃に起してある、炭火の赤い焔を見た時の、ほつとした心もち、――それも、今かうして、寝てゐると、遠い昔にあつた事としか、思はれない。",
              "citation": {
                "source": "芋粥",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "反動的とでも云うのだろう）　貝十郎はこう思いながら、雀色になった夕暮れの中に、消え込んで行くその人の姿を、尊いもののように見送ったが、やがて藤兵衛へ近寄って云った。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして今は雀色に暮れた夕霧の中へ消え込んでしまった。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し開いている障子の隙から、その黄昏の微光が、部屋の中へ入り込んで来て、部屋は雀色に仄めいて見え、その中にいる若い男女を、悩ましい艶かしい塑像のように見せた。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう追分の鍵屋という旅籠へ、陣十郎と澄江が泊まったのは、「お泊まりなんし、お泊まりなんし、銭が安うて飯が旨うて、夜具が可うてお給仕が別嬪、某屋はここじゃお泊まりなんし」と、旅人を呼び立て袖を引く、留女の声のかまびすしい、雀色の黄昏であった。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう四辺は雀色、昼が夜に移ろうとしている。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　ちょうどたそがれ時、人通りが絶えて、町家も水の上も、一様に雀色に見える頃でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "呪いの銀簪",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の陽は五重の塔の裾から暮れて、やがてこの肩のあたりも雀色の暮色に包まれるのでしょうが、その多勢を迎えに行った筈の八五郎は、まだ影も形も見せません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "お静危難　銭形平次と八五郎を真っ先に、多勢の者が鵯越の逆落しほどの勢いで、一団となって五重の塔の外へ出た時は、あたりはもう雀色にたそがれておりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうしてくれ、八と爺さんと三人で、今晩は少し過すことにしようよ」　平次は大きく伸びをして雀色に暮れて行く秋の街を見やりました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "二階の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "口惜しいが少しも判りませんよ」　ガラツ八が歸つたのはもう雀色時、平次はそれを待ちくたびれて、煙草ばかり吸つてゐるところでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "月の隈",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて四方が雀色になつた頃、紫御殿の裏から、そろ／＼潜り込む隙を平次は狙つて居りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "からくり屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、雀色時、櫻の梢を渡つて、上野の暮れ六つの鐘が鳴ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "花見の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それほどでもないがね、親分、いい女形がなかった日にゃ、狂言にならないじゃありませんか」「馬鹿野郎」「へッ、お出でなすったね」　二人は雀色時の路地を出て、浅草の方へ急ぎました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "敵討果てて",
                "note": "青空文庫"
              }
            },
            {
              "text": "加賀と能登ではタチアイといい、熊野でマジミというなども深い意味があるらしいが、それはなお私には雀色である。",
              "citation": {
                "source": "かはたれ時",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間でない人々が顔を合わす機会は、もとは交易の時ばかりであったゆえに、同じ用語を以ていわゆる雀色時の、人に気を許されぬ時刻を形容したのではなかったか。",
              "citation": {
                "source": "かはたれ時",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうしてくれ、八と爺さんと三人で、今晩は少し過すことにしようよ」　平次は大きく伸びをして雀色に暮れて行く秋の街を見やりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二階の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、雀色時、桜の梢を渡って、上野の暮れ六つの鐘が鳴ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "花見の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　丁度たそがれ時、人通りが絶えて、町家も水の上も、一樣に雀色に見える頃でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "呪ひの銀簪",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや四半刻（三十分）ばかり、四方が雀色になった頃に、平次は勝ち誇った様子で帰って来ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "縁結び",
                "note": "青空文庫"
              }
            },
            {
              "text": "口惜しいが少しも判りませんよ」　ガラッ八が帰ったのはもう雀色時、平次はそれを待ちくたびれて、煙草ばかり吸っているところでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "月の隈",
                "note": "青空文庫"
              }
            },
            {
              "text": "が丘の円屋根は、次第に孔雀色の緑から、青い色にかわって行った。",
              "citation": {
                "source": "青玉の十字架",
                "author": "THE BLUE CROSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "何心なく雀色になつた往來を眺めて居た平次は、いきなり、「八、あれを見ろ」　と指さすのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "乘合舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、増上寺の暮六つの鐘が鳴りますね」　八五郎も平次も、雀色になりかけて居る、夏の夕空を仰ぎました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鐘の音",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　平次の指さした方、輕業小屋の樂屋口には僅かに殘る雀色の夕あかりの中に、ほの白い顏が凝つとこちらを見てゐるではありませんか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "飛ぶ女",
                "note": "青空文庫"
              }
            },
            {
              "text": "市街の中央部には、遠くからでも明らかに皇居の大内裏十二門の一劃とわかる官衙殿堂が、孔雀色の甍や丹塗の門廊とおぼしき耀きを放ッて、一大｜聚落をなしており、朱雀、大宮などを始め、一条から九条までの大路や、横縦三十二筋の道路は、碁盤目のように、市坊を区ぎって整然と見えた。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
