    "definitions": [
      {
        "index": 1,
        "gloss": "smooth (i.e. without problems)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
