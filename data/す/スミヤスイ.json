    "definitions": [
      {
        "index": 1,
        "gloss": "comfortable to live in (of a neighborhood, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "９きょうは朝から気分がいいちょっと特別なことを考えているんだ〈アイム・イントゥ・サムシング・グッド〉ハーマンズ・ハーミッツ　正直いって、定員よりひとりすくない部屋というのは、ただでさえ住みやすいし、いなくなったのが手塚なのだから、それはなおさらのことだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん住みやすい世の中になって御互に仕合でしょう。",
              "citation": {
                "source": "文芸と道徳",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどなあ、いい方法だ、これで世間が暮らせたら、実際浮世は住みやすい。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お高は、金剛寺坂の家を住みやすいと思っている。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "私鉄の駅から歩いて七、八分の、静かな住宅地のなかにある住みやすい家だった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "住みやすい快適な家だった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "変わった家だが、変わっているぶんだけ確実に住みやすいはずだ、と僕は思う。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「住みやすい家ですよ」「売っていただけるかしら」「買い取ってまだ五年たっていませんから、どうかなとは思いますけど、不動産屋さんに話がいってるなら、売らないというわけでもないのでしょう」「私が買えますように」「父親に伝えておきます」「実家はあのお家の近くなの？",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "住みやすい家ですよ」　後藤は日比谷の先に立ち、そのあとに百合子に導かれて恵子がしたがった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「住みやすいですよ」「玄関の靴脱ぎの四角いスペースをホールがＬ字型に囲んで、その延長として、二階への階段が奥にあって。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "住みやすい家ですし、使い勝手のいい間取りですけれど、建物としてはもうとっくに限界です。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような間取りが好きな人にとっては、住みやすい家であるに違いない。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
