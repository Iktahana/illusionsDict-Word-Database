        "examples": {
          "standard": [
            {
              "text": "網膜にある錐体細胞は、色覚を司り、明るい場所での視力に不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "暗闇では錐体細胞の働きが弱まり、主に桿体細胞が視覚を担う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「色が見えにくいのは、錐体細胞に問題があるのかもしれない。」「そうなんだ。一度眼科で診てもらった方がいいかもね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
