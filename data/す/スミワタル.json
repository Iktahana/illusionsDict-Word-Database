    "definitions": [
      {
        "index": 1,
        "gloss": "to be perfectly clear",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
