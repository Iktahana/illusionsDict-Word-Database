  {
    "uuid": "15c9eb73-9e42-5e57-ab87-66d0d51b866a",
    "entry": "縫い取り",
    "reading": {
      "primary": "ぬいとり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
