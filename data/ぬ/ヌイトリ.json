    "definitions": [
      {
        "index": 1,
        "gloss": "embroidery",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "入場してまず眼についたのは、カーテンの下のほうに「松屋」という縫い取りの文字で、これが少し不思議に思われた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は立襟のついた金の縫い取りをした礼服に鞣皮のズボンをはいて、腰には剣を吊っていた。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "上衣の腕ポケットにわざと無雑作らしくつきこんだハンカチは、縁に空色の縫い取りがしてあった。",
              "citation": {
                "source": "塩花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はピカピカする銀製の食器、古代の人物や美しい花鳥の図の縫い取りがしてある掛け毛氈のことを夢みていた。",
              "citation": {
                "source": "頸飾り",
                "author": "モウパンサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「僕アね、僕アね、おとうさま、僕ア算術は甲」　「あたしね、おとうさま、今日は縫い取りがよくできたッて先生おほめなすッてよ」　と振り分け髪はふところより幼稚園の製作物を取り出して中将の膝の上に置く。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僕アね、僕アね、おとうさま、僕ア算術は甲」「あたしね、おとうさま、今日は縫い取りがよくできたッて先生おほめなすッてよ」　と振り分け髪はふところより幼稚園の製作物を取り出して中将の膝の上に置く。",
              "citation": {
                "source": "小説　不如帰",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "安倍川を食べてしまうと、お雪ちゃんは縫取りを取り出して、例の胡蝶の模様を余念なく縫い取りにかかりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「六十年前にも今時分、縫い取りをした上着を着て、｜皇帝の鳥に髪を結った彼女の若い恋人が、三角帽で胸を押さえつけながら、伯爵夫人の寝室から忍び出て、この秘密の階段を降りて行ったことだろう。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "スペードの女王",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま見つかるものは、顔はそれと見分けのつかぬほどに変わり果て、わずかに服の端の縫い取りの名にそれと確かめ、泣くのも忘れ、凝然と、傍に棒立ちになったまま。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と櫛巻の姐御、姐御の本領を発揮して、いきなり、縫い取りの美しいうちかけをぬぎすてるが早いか、パッと地面へ投げすてた。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」それらの家は通常、巧みに作られ縫い取りされた筵が敷いてあり、内側の壁が張られてあり、各種の家具もそなわっていた、と彼は附言している。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど学校で紐かざりを習っていたフサエは赤いカタン糸で麻の葉や鼓などを縫い取りながら自分の家にはカタン糸ばかりでなくいろんな色の絹糸が仰山あると、つい自慢をした。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、覆面にＥという縫い取りのある婦人が、団長の春木夫人のそばによって、なにかしばらく耳うちしていたが、すると団長夫人は、深くうなずいて、一同に向かい、「皆さん、いま医者をむかえることにしましたから、今夜の幹事のＣさんだけのこって、あとのかたは上の応接間に集まってください。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は若者のくつのかたわらに、おのれの小さいぬいとりのあるくつをならべてぬぐと、青いもすそをあとにひいて水面にとんだ。",
              "citation": {
                "source": "おしどり",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、まずランプのおばけを呼んで、香水ぶろと、王さまがお召しになるような金のぬいとりのある着物と、自分のお供をする四十人のどれいと、お母さんのお供をする六人のどれいと、王さまのお馬よりもっと美しい馬と、そして、一万枚の金貨を十｜箇のさいふに分けて入れて持って来いと命じました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            },
            {
              "text": "絹に金のぬいとりした着物を着かざったうつくしい女のどれいたちがでて来て、王子と、王子のご両親の王さま、お妃さまのご前で歌をうたいました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "改めてお嬢さんの金糸銀糸でぬいとりした衣裳や、指に輝く金剛石、金と教養にあかし磨きこんだミルク色の疵ひとつない上品な顔をみると、ぼくはダンスは下手だし、その手をとるのも恐くなり、「駄目です。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、これはラツールおじさんの服だ」　袖のところに、ペンとフランスの三色旗を組合わせたぬいとりがあったから、それはうたがう余地がなかった。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "罠くらべ　黄金の糸で四｜頭の竜のぬいとりをしたすばらしくぜいたくなカーテンが、頭目台のうしろに垂れている。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人のまだ若い母はまどのそばでぬいとりをしていました。",
              "citation": {
                "source": "無題（一）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして十五年むかしの妖女のよげんを思い出しながら、やはりこうなるうんめいだったことをさとって、お姫さまを、そのまま、お城のなかでも、いちばん上等のへやにつれて行かせ、金と銀のぬいとりをした、きれいなねだいの上にねかしました。",
              "citation": {
                "source": "眠る森のお姫さま",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とベスは、ぬいとりの文字をほこらしげにながめました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、この子は、エム・マーチでなく、マザアなんてぬいとりして、おかしいね。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬいとりの　ぬのに　合わせて、　むだなく　ふくの　かたちを　たち切りましたから、　さぎょう台の上に　ちらかるのは、　ほんの少しの　切れはしだけ　――「はしきれすぎて、　どうにもならない　――　ネズミの　チョッキには　なるくらいだ。",
              "citation": {
                "source": "グロスターのふくやさん",
                "author": "THE TAILOR OF GLOUCESTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "コートの　ぬいとりには、　バラと　パンジー、　それから　チョッキには　ケシと　キクが　あしらわれていて。",
              "citation": {
                "source": "グロスターのふくやさん",
                "author": "THE TAILOR OF GLOUCESTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなしい灰水色の制服のカラーに金糸でオリーヴの葉飾りをぬいとりした服をつけた保が、「姉ちゃん、どうして結婚なんて、したの？",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリス風の水兵服は、ふくらんだそでが先のほうでつぼまって、かれのまだ子供っぽいながらもほっそりした手の、きゃしゃな関節に、きっちりとまきついているが、この服が、そのひもだのネクタイだのぬいとりだので、このなよやかな姿態に、あるゆたかな甘やかされたおもむきをそえている。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ　ハシバミさん　ゆれてうごいて金と銀とをおとしてちょうだいな　すると、いつもの鳥が、金と銀の糸で織った着物と、絹糸と銀の糸でぬいとりした上ぐつとをおとしてくれました。",
              "citation": {
                "source": "灰かぶり",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判官たちはお姫さまがいつもきている、うすネズミ色のマントを見ますと、「このマントに金糸、銀糸のぬいとりをおさせなさいませ。",
              "citation": {
                "source": "なぞ",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "すみのほうには、アメリカ製の揺りいすがありますし、窓ぎわのテーブルには、美しくぬいとりをしたビロードのきれがかけてあります。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
