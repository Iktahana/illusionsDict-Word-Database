    "definitions": [
      {
        "index": 1,
        "gloss": "nook (small and oft. secluded space in a home)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
