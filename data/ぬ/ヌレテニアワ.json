        "examples": {
          "standard": [
            {
              "text": "全く苦労せずに大金を手にするとは、まさに濡れ手に粟だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は偶然の機会をものにし、濡れ手に粟の成功を収めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「こんなうまい話があるなんて、濡れ手に粟以外の何物でもない」と彼女は驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "第一の彼の目的はいわば人の弱点に付け込んだこういう犬を売るということによって、濡れ手に粟のごとき莫大な利益を納めることができるからなのです。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「儲け口がそんなにあるのかい」と俺はロクに言ったのだが、百成が、「そりゃ、もう、いっぱい――濡れ手に粟でさあ」とあさましいことを言った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
