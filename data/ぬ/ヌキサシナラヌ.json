    "definitions": [
      {
        "index": 1,
        "gloss": "sticky (situation)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
