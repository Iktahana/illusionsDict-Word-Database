        "examples": {
          "standard": [
            {
              "text": "抜けるような青空の下、ピクニックを楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "都会の喧騒を忘れさせる、抜けるような青空が広がっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅行最終日は、まるで絵葉書のような抜けるような青空だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しばらくキーを叩き続けてふと見上げると、窓の外には抜けるような青空が広がっていた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしオレが連載に区切りを付けたこの時点で、抜けるような青空のリスタート・ボタンは確かに押されたのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
