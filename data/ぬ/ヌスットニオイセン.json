        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "もうこれ以上投資しても、盗人に追い銭になるだけだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "失敗したプロジェクトにさらに資金を投入するのは、まさに盗人に追い銭だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は無駄な努力を続ける友人に、「それは盗人に追い銭だよ」と忠告した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "つまり小菊に芸者屋を出さす相談であったが、彼女も最初に首をひねり、盗人に追い銭の感じがして、ぴったり来ない感じだったが、しかしその割り切れないところは何かの惑かしがあり、好いことがそこから生まれて来るように思えた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "話をきいて打ち笑い、「盗人に追い銭とはそのこと。",
              "citation": {
                "source": "屋根裏の犯人",
                "author": "――『鼠の文づかい』より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗人に追い銭でしょう？",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
