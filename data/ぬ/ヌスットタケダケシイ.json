        "examples": {
          "standard": [
            {
              "text": "証拠を突きつけられても、盗人猛々しく知らぬ存ぜぬを貫いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "自分の過ちを認めず、盗人猛々しく逆ギレする態度に周囲は呆れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そんな盗人猛々しい真似は、二度と許されない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "盗人猛々しいとは、その言い分である」と、思ったが、それはじっと抑えて口には出さず、「はあ、私が藤村の娘を脅迫したために精神に異状を来たしたというのですか。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は僕一人の責任で申込んだんだから」「盗人猛々しいってのは君のことだ。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "求めて、乱賊の名を受けたいか」「盗人猛々しいとは、その方のこと。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
