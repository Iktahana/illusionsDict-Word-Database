    "definitions": [
      {
        "index": 1,
        "gloss": "to sew",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――私はＮセメント会社の、セメント袋を縫う女工です。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "風のない日は縁側の日向へ出て来て、紙の折り鶴をいくつとなくこしらえてみたり、秘蔵の人形の着物を縫うてやったり、曇った寒い日は床の中で「黒髪」をひくくらいになった。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆゑ太郎の着物の綻びも縫うてやるひまがありません。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは書物で読んだことだが、樫鳥や山鳩や山鴫のような鳥類が目にも止まらぬような急速度で錯雑した樹枝の間を縫うて飛んで行くのに、決して一枚の木の葉にも翼を触れるような事はない。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一針縫うのに十五秒ないし三十秒かかるであろうし、それに針や糸を渡し受取り、布片を延べたり、○印を一つ選定したりするにもかれこれ此れと同じくらいはかかる。",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を考えていたのであるが、今年の夏｜房州の千倉へ行って、海岸の強い輻射のエネルギーに充たされた空間の中を縫うて来る涼風に接したときに、暑さと涼しさとは互いに排他的な感覚ではなくて共存的な感覚であることに始めて気が付いたのである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手袋を縫うだけで、腹いっぱい飯が食えるかな。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、黄河を迂回して、側面からここを圧迫する馮玉祥の騎兵部隊と、泰山の南を縫うて、明水平野に出た陳調元の優勢な一部隊に圧迫せられ、又、戦わずに、界首と、黄河の線を抛棄した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "縫うように、細い道を折れ曲った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう子供の贈物にする人形の着物をほとんど一手で縫うたシュエスター何某が、病気で欠席されたのは遺憾でありますというような挨拶もありました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "椰子の木の森の中を縫う紅殻色の大道に馬車を走らせた時の名状のできない心持ちだけは今でもありあり胸に浮かんで来るが、細かい記憶は夢のように薄れて、ただ緑と赭の地色の上に染め出された更紗模様のように混雑してしまっている。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、森の中を縫う、荒れ果てた小径を、あてもなく彷徨い歩く。",
              "citation": {
                "source": "秋の歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い服、白い袴、黒い長靴の騎手の姿が樹の間を縫うて嵐のように通り過ぎる。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "春も闌の遅桜、早桃が見渡す限りの筑紫野の村々に咲き乱れて、吾れ勝ちに揚る揚雲雀も長閑な博多東中洲の野菜畑の間を縫うて行く異様な二人連れがあった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　舟はしばらく大船小船六七｜艘の間を縫うて進んでいたが、まもなく広々とした沖合に出た。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑の間を縫う小道のそばのところどころに黄ばんだ榛の木のこずえも美しい。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大垣米原間の鉄道線路は、この顕著な「地殻の割れ目」を縫うて敷かれてある。",
              "citation": {
                "source": "伊吹山の句について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあとの映画で、不幸なるラート教授が陋巷の闇を縫うてとぼとぼ歩く場面でどことなく聞こえて来る汽笛だかなんだかわからぬ妙な音もやはりそういう意味で使われたものであろう。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "峡の婆、僅に手を解き、頤で襟を探って、無性らしく撮み出した、指の爪の長く生伸びたかと見えるのを、一つぶるぶると掉って近づき、お伽話の絵に描いた外科医者という体で、震く唇に幽に見える、夫人の白歯の上を縫うよ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お千世へだけの事だったら、陰で綻を縫うまで、と内気な女が思直す。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間を縫うて四人は一歩一歩｜辿った。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "客は会場の広室に溢れ、帳場にこぼれ、廊下に流れて、わやわやとざわめく中を、よけるようにして通って、一つ折曲る処で、家内総出で折詰の支度に料理場、台所を取乱したのを視ながら、また一つ細く成る廊下を縫うと、其処にも、此処にも、二三人、四五人ずつは男、女が往来う、彳む。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　で、二台、月に提灯の灯黄色に、広場の端へ駈込むと……石高路をがたがたしながら、板塀の小路、土塀の辻、径路を縫うと見えて、寂しい処幾曲り。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕に、それが消える時、風が擲つがごとく、虚空から、――雨交りに、電光の青き中を、朱鷺色が八重に縫う乙女椿の花一輪。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそ蛍を飛ばすなら、祇園、先斗町の帰り、木屋町を流れる高瀬川の上を飛ぶ蛍火や、高台寺の樹の間を縫うて、流れ星のように、いや人魂のようにふっと光って、ふっと消え、スイスイと飛んで行く蛍火のあえかな青さを書いた方が、一匹五円の闇蛍より気が利いていよう。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで洪水のような見送人の群で、傘、傘、傘、人、人、人の隙間を縫うて、私はＳの姿を探し求めた。",
              "citation": {
                "source": "面会",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "といへば、はや察せられるやうに、口繩坂はまことに蛇の如くくねくねと木々の間を縫うて登る古びた石段の坂である。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "法衣の手入、奥さんが縫うてあげようとおつしやつたけれど、これは綻びを縫ふとか何とかいふ程度のものぢやない、裁縫を知らない人で初めて出来る仕事である！",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　銀子はクリスチャンであったその家庭で日常を躾けられ、多勢の兄弟子に交じって、皮を裁つことや縫うことを覚え、間もなく手間賃をもらい、家の暮しを助けることができたが、やがて彼女の細腕では持ちきれない時が来た。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私だって靴縫うのよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
