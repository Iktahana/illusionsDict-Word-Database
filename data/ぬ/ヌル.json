    },
    "definitions": [
      {
        "index": 1,
        "gloss": "null",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "並ハズレテ、タクマシキガ故ニ、死ナズ在リヌル。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉、家康は勿論の事、政宗にせよ、氏郷にせよ、少し前の謙信にせよ、信玄にせよ、天下麻の如くに乱れて、馬烟や鬨の声、金鼓の乱調子、焔硝の香、鉄と火の世の中に生れて来た勝れた魂魄はナマヌルな魂魄では無い、皆いずれも火の玉だましいだ、炎々烈々として已むに已まれぬ猛※を噴き出し白光を迸発させているのだ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂「たぎり切った人」である、ナマヌルな奴では無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナマヌル魂の木村父子は旅の卦の文に所謂鳥其巣を焚かれた旅烏、バカアバカアと自ら鳴くよりほか無くて、何共せん方ないから、自分が援助するつもりで来た成合平左衛門に却て援けられる形となって、佐沼の城へ父子共｜立籠ることになった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人利家に取っては自分の支持をするものが一人でも多いのが宜い訳だから、子息達も立派な大名である故同座させた方が万事に都合が好いのだが、そこは又左衛門利家そんなナマヌル魂では無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、此の落英の落の字が厄介で、菊ははら／＼と落ちるものではないから、落は先日某君から質問された「チヌル」の事に関係のある落成の落の字と見なして、落英は即ち咲いた花だといふ説もあるが、何だかおちつきの悪い解ではある。",
              "citation": {
                "source": "菊　食物としての",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "足許でヌルヌルする粘土、どうしても抜けない根、恐ろしい暑さ、突然の微風、近くの森から聞える鳥の声、誰かがふざけて私の名を呼ぶ声、笑声、口笛の合図…………大体、昼の生活を夢の中で、もう一ぺん、し直すのである。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「耶蘇教の婚礼なんてナンチいう、フウタラ、ヌルイ（風多羅緩い？",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その父の背中は真白くてヌルヌルと脂切っていた。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲むものはヌルイ湯ばかり。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうなれば、源吉は、自分なら、あんなヘマな、そしてあんな生ヌルイことはしないぞ、と思つた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "釦か鋲の頭かと思ったその小さな丸いものは、ヌルリと彼の指を濡らしたばかりだった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま誰かと立ち話ししている超人ヌルミ。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランニング選手、ヌルミとリトラと無数のその幼虫。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「クヌルプ」（岩波文庫・漂泊の魂）には、この作家の弱点というべきものが典型を示していて、人間の生命の浪費が、当然向けられるはずの疑問もなく美化して呈出されているのである。",
              "citation": {
                "source": "若き精神の成長を描く文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヌル／＼と焼く処で甘く出来るのだ。",
              "citation": {
                "source": "俺の記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してイロハの側から見て同知されないものはヘヌルレウヰオケエヱの十字である。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "患者のヌルヌルした涎だらけの唇の左右へ、拇指を容赦なくグイグイと突込んで、左右の顎の骨を両手で力強く引っ掴んだが、そのまま患者のヒンガラ眼を覗き込むように睨み付けると、室中に響き渡るような大きな声で怒鳴り付けた。",
              "citation": {
                "source": "霊感！",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正六年と云えば正に今より十年前であるが、この時代に於て、アルセーヌルパンの小説物語をそのまゝ地で行くような大胆不敵にして、かくまで奸智に長けた曲者が実在していようとは、種々の空想を逞しゅうして探偵小説を書く私でさえが夢想だにしなかった所である。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右俣を登ったが上部はかなり急でヌルヌルしており油断はならなかった。",
              "citation": {
                "source": "一ノ倉沢",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "このナギヌルの訓は従来からそうであるが、嘉暦本にはイマゾユキヌルと訓んでいる。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "戻つてきて、廊下から、「君、ヌルマユを貰つてきてくれないか」「ハ？",
              "citation": {
                "source": "散る日本",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヌルリと滑った少女の胸部だった。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
