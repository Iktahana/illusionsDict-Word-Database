    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to pull out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すべて原始にあつた如く、今日の人間も尚、冬に於けるあの「先祖の情緒」を記憶して居り、本能の奥深い隅に於て、決して抜くことができないのである。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "引抜くと、きゅうっきゅうっと小気味の好い音を出す。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シエラ・ネヴァダの連峰が概して富士山を抜くこと、二千尺の高さがあっても、カスケード火山に、氷河脈が寒剣をきらめかせていても、小社一つ建たず、石塔一つないではないか。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方で、彼の探偵物には人間の心理の鋭い洞察によって事件の真相を見抜く例も沢山ある。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西鶴の人間に関する観察帰納演繹の手法を例示するものとしてはまた『織留』中の「諸国の人を見しるは伊勢」に、取付虫の寿林、ふる狸の清春という二人の歌比丘尼が、通りがかりの旅客を一見しただけですぐにその郷国や職業を見抜く、シャーロック・ホールムス的の「穿ち」をも挙げておきたい。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また炭は溶液の中にある有機性の色素を吸収する性質がある、殊に獣炭あるいは骨炭がこれに適しているので砂糖の色を抜く事などに使われる。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次には痛みなしに歯を抜くためテスラ電流を用いる事。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲地でも乙の松明の上がると同時に底の栓を抜く。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大刀ズラリと引ッこ抜く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉、笑い乍ら大刀抜く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と叫ぶや、長刀ズラリ引っこ抜く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　長刀ズラリと引ッこ抜く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　長刀ズラリ引ッこ抜く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵も応とばかり、両刀抜く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「抜く手も見せず」というような言葉の聯想が湧いてくる。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "矛盾と我儘に自分を悩め抜く自分の肉体が今は小初に憎くなった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小初が無闇に泳ぎ抜くのは、小初が興奮しているからである。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう男をアジテートすることは、山を抜くほど困難な仕事だ。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "円錐形にそびえて高く群峰を抜く九重嶺の裾野の高原数里の枯れ草が一面に夕陽を帯び、空気が水のように澄んでいるので人馬の行くのも見えそうである。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして脚を抜く時に蹴る雪が、イワンの顔に散りかかって来た。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の眼をくり抜くのみならず、土匪の眼玉だってくり抜いたかも知れない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三百人が僅かかい……」　こいつほど、人の懐中を見抜くことに機敏な奴はなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇敢で、単純で、感情的な重藤は、自分の扱っている兵卒の要求と、本能を直感的に見抜く鋭敏な才能を持っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして腰につけてゐた刀の模型のやうなものを今にも抜くやうなそぶりをして見せた。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうか、で庄兵衛大刀を抜く。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩でぶッつかるようにして横腹へ体をあてた時、ようよう前足を上げたばかりまた四脚を突張り抜く。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……向直つて口を開けたが、笑ひもしないで落着いた顔して、「此の汽車は、豊原と此処を抜くですで……今度が漸く白河です。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "他社を出し抜くためにあらゆる犠牲が払われ、結局は肝心の真実そのものまでが犠牲にされて惜しいとも思われないようである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明和九年の行人坂の火事には南西風に乗じて江戸を縦に焼き抜くために最好適地と考えられる目黒の一地点に乞食坊主の真秀が放火したのである。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて最初に目に入つた玉屋に這入ると、部屋は明るくガランとしてゐて、温室のやうだつた、客の腰掛場になつてゐる、畳二枚を縦に並べた場所の、その中程に置かれた火鉢には其処の主人が如何にも睡げによつかゝつてをり、お主婦さんも割烹着を着たまゝ火鉢で手をぬくめてゐた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
