        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は、ぬるっとした動きで相手の攻撃をかわした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "指輪が指からぬるっと滑り落ちて、床に転がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "油を塗ったようなぬるっとした手触りの石を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "足の裏がぬるっとして滑りそうだったから、てっきり長虫だろうと思ったが……。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬるっと、触れた手には水苔がついてくる。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、戸板にかかった針先をとろうとし、つるりと滑った途端に、菰が摺り落ちて、皮も萎え血もしこり、肉脱した岩の死骸が、ぬるっとばかりに現われた。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "底は平面の長方形で舳の真中に蛇の頭がぬるっと首を出して居るところの彫刻物が食い付いて居る。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かぬるっとするものに触れた。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
