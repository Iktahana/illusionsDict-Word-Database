        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "台所の魚がなくなったのは、きっと近所の盗人猫の仕業だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "うちの猫は賢いけど、隙あらば食べ物を狙う盗人猫だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ああっ、また盗人猫がパンをくわえて逃げていったわ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「何だい、盗人猫のように、唐突に。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして薄暗い背戸口から、盗人猫のやうにこつそり中にはいつて、物の蔭から良寛さんのしぐさを見守つた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から、からからと後歯の跫音、裏口ではたと留んで、「おや、また寝そべってるよ、図々しい、」　叱言は犬か、盗人猫か、勝手口の戸をあけて、ぴッしゃりと蓮葉にしめたが、浅間だから直にもう鉄瓶をかちりといわせて、障子の内に女の気勢。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
