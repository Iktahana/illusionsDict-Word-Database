[
  {
    "uuid": "38ec300b-adfc-5af7-ad0a-69582405beba",
    "entry": "濡れ濡れ",
    "reading": {
      "primary": "ぬれぬれ",
      "alternatives": [
        "ヌレヌレ"
      ],
      "is_heteronym": false
    },
    "grammar": {
