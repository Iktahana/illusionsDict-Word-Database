    "definitions": [
      {
        "index": 1,
        "gloss": "to get hooked (on a video game, TV show, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このゲーム、一度始めたらもう止まらない。完全に沼る予感。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "K-POPアイドルのライブ映像を見て、あっという間に沼ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あー、また新しい趣味に沼ってしまったよ…」と彼は苦笑いした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "金とりて、田沼るる身の、にくさゆゑ、命捨てても、さのみをしまん」「何んだ」　と冬次郎は眉をひそめていった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に、女中頭の菅沼るい（五十歳）白い毛糸のジャケツを、肥つたからだに軽く羽織つて勿体らしく右手のホールから現はれる。",
              "citation": {
                "source": "顔",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "菅沼るいは、ハッとして、起ち上り、急いでスヰッチをひねる。",
              "citation": {
                "source": "顔",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "菅沼るいが、あたふたと現はれ、再び蓄音機の傍らに陣取る。",
              "citation": {
                "source": "顔",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to be in a slump",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
