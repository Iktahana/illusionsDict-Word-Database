        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "最近、仕事で何をしても上手くいかず、すっかり沼ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試験期間中で気分が落ち込み、勉強も手につかずに沼っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はキャリアの長いベテランだが、珍しく今は沼っている状態だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
