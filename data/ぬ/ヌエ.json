[
  {
    "uuid": "aa76a1f9-6825-58f0-9766-0da7cc7f747a",
    "entry": "鵺",
    "reading": {
      "primary": "ぬえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
