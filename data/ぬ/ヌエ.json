    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese chimera",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鵺が來て池で行水を使つたほどに、事大袈裟に立到る。",
              "citation": {
                "source": "怪談女の輪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫の面で、犬の胴、狐の尻尾で、大さは鼬の如く、啼声鵺に似たりとしてある。",
              "citation": {
                "source": "一寸怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「その儀、その儀にござりますが、へい、何か見馴れません綺麗な鳥が、種をこぼして行ったと申して、熱海中の吉瑞、神業じゃと、皆が、大抵めでたがりました事でござりますが、さてこうなってみますると、それが早や魔の業で、種を啣えて来ましたのは、定めし怪鳥、鵺じゃろうかに手前どもが存じまする。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は鵺と云ふは此かと思つた。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高崎中学を終えてから、各地の医専の入学試験を受けている最中、リョウマチにかゝり、少青年期の大事な部分を実家で療養に暮すうち中学生上りともつかず田舎紳士ともつかない鵺の青年になったらしい弟は、せめて生活の業にもと近頃では鍼灸師の資格試験の準備中なのでありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのなかに源三位頼政の鵺退治がある。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼政が鵺を射て落すと、家来の猪早太が刀をぬいて刺し透すのだ。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が大師の茶屋で広言を吐いた頼政の鵺退治も、こんな悲しい結果に終ったのである。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして背中の斑が虎のようだから「鵺」だというものもあった。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鵺だけが雌で、他の三匹はいずれも男性であった。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がそこに書いた理論は、君には鵺みたいな話に思えるかもしれないが、実用も実用――実用的すぎて僕はこれでパンとチーズを得ているくらいだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは獅の首山羊の胴蛇の尾で火を吐く鵺同然の怪物だ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一これは外國語であり、而かもその外國語にしても漢音呉音の差により一は「バンゼイ」と發音さるべく、一は「マンザイ」と發音されねばならぬのにかゝはらず、現在の「バンザイ」ではどちらつかずの鵺語となつてゐる。",
              "citation": {
                "source": "樹木とその葉",
                "author": "野蒜の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが脚本というものに筆を染めた処女作は「紫宸殿」という一幕物で、頼政の鵺退治を主題にした史劇であった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "我国では、先ず鵺や五位鷺を怪鳥の部に編入し、支那ではを怪鳥としている。",
              "citation": {
                "source": "妖怪漫談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "石庵の學問は鵺學問といはれた位で、朱子派でもなく王陽明派といふでもなく、朱子も王陽明もゴツチヤにした樣なものであつたが、町人の要求する所は朱子でも、王陽明でも何でもかまはぬ、唯道徳の修養になればよいのであるから、石庵の樣な學問でも歡迎を受けたものである。",
              "citation": {
                "source": "大阪の町人と學問",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷹の面だ」「鵺を舞う時に着けるんですの」「ワーイ天狗の面があらあ」「ええ、大見とがね」「どう考えても変梃な名だ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と鵺のような鳴き声が聞こえました。",
              "citation": {
                "source": "鵺",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいまつをとぼし、ろうそくをつけて正体をよく見ますと、頭はさる、背中はとら、尾はきつね、足はたぬきという不思議なばけもので、鵺のような鳴き声を出して鳴いたことがわかりました。",
              "citation": {
                "source": "鵺",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵺が退治られてしまいますと、天子さまのお病はそれなりふきとったように治ってしまいました。",
              "citation": {
                "source": "鵺",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ勝峯晉風氏をも知るやうになり、七部集なども覗きたれば、愈鵺の如しと言はざるべからず。",
              "citation": {
                "source": "わが俳諧修業",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して昔を偲ばせる目出度い語句は更に見當らず、年月日の鵺的讀方などは以て證とするに足らないのみか却て打毀しである。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に、鼻筋が蛙みたいに背中から通ってらあ」「兄貴を、じっと見た眼はどうだ、おめかしをして――」「おうおう、誰の仮声だ」「師匠のよう」「笑わせやがらあ、そんなのは、糞色といってな――」「鳴く声、鵺に似たりけりって奴だ」「俺、あの口元が好きだ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺ら、山男というからにゃ、頭の髪が足まで垂れ、身長の高さが八尺もあって、鳴く声｜鵺に似たりという、そういう奴だと思ってたんだが、篦棒な話さ、ただの人間だあ」「そうは云ってもまんざらじゃねえぜ」もう一人の仲間が口を出した。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に鷲鳥の嘯くような、鏑の鳴音響き渡ったが、源三位頼政鵺を射つや、鳴笛紫宸殿に充つとある、それにも劣らぬ凄まじい鳴音が、数町に響いて空を切った箭！",
              "citation": {
                "source": "弓道中祖伝",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて御賓頭顱でも撫でて行こうかと思ったが、どこにあるか忘れてしまったので、本堂へ上って、魚河岸の大提灯と頼政の鵺を退治ている額だけ見てすぐ雷門を出た。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の歌が離れて来た元の形と見える八千矛神の妻訪ひの歌なども、……処女の寝すや板戸を　押ぶらひ、我が立たせれば、引づらひ、我が立たせれば　青山に鵺は鳴き、さ野つ鳥雉はとよむ。",
              "citation": {
                "source": "鶏鳴と神楽と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「待たせはせぬえ、大事な処へ、何や！",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿か、図太いのか、なにしろそんな奴じゃあ、何処へのそのそ這い出して来るかも知れぬえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらも負けず劣らぬえらい力でしたから、えいやえいや、両方で頭の引っ張りこをしているうちに、夜が明けかかって、鶏が鳴きました。",
              "citation": {
                "source": "雷のさずけもの",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
