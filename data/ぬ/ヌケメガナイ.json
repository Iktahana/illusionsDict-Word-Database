        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」そこはＦ君抜け目がない。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも万事に抜け目がない。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり、きみたちは抜け目がないな。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "金持というのが漫画にあるように袋に金を詰めて金庫に溜めて、金鎖の太いのをお腹の上にたらしているような罪のないものならば、漫画にしておけばすむのですけれども、本当の資本家というのはそれはそれは抜け目がない。",
              "citation": {
                "source": "幸福の建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "体の小柄な、黒い顔のテカテカした年より大変老けて見える父親は、素末な紺がすりに角帯をしめて、関西の小商人らしい抜け目がないながら、どっか横柄な様な態度で、主婦の事を、　お家はん、お家はん。",
              "citation": {
                "source": "黒馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小男で胃弱で蒼ざめて猫背で、そのような奴に限って性慾が強くて、強情で、東京のスリのように抜け目がないのだ。",
              "citation": {
                "source": "保久呂天皇",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君のところの老人は金をもうけることにも抜け目がないが、あれでなかなか奇骨がある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは叔母さんも抜け目がない。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "……おもんもなかなか抜け目がない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "永代経",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人が追い立てたあとで、なんと屏風に描きなぐつてあつた松の絵を、さる大名が見つけて千両で買いとつたつていう話を、わしは聞いとるでね」「なるほど、信濃屋さんはさすがに抜け目がないな。",
              "citation": {
                "source": "この握りめし",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃用心棒の八五郎は、鼻から提灯を出して、大福餅の夢を見ていた」「冗談でしょう」「お栄は抜け目がないよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "番頭の周助は五十年配の強か者で、商売には抜け目がないという評判ですが、主人の財産を殖やすと同じ率で、自分の貯蓄も殖やして行くほかには、さして悪巧みがあろうとも思われません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "蜘蛛の巣",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして一般に女学校では、入学志願者の父兄の資産調べには抜け目がないようだ。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊太夫はそれがよくわかっているだけに、人を使うにも、人の慾を見ることに抜け目がないのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "抜け目がない体勢ではある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、クロショイは抜け目がないぞ」「やつのだまし方は？",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京もんは抜け目がないから、ワシらのところまで目当にして、買いだしに来たのが、時々あるからね。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "信者の仲間へ入ると、信者らしくして、未信者の仲間へ入ると、未信者らしくします」「厭な奴だなあ」「抜け目がないんです」「僕はそんな裏表のある人間は嫌いです」　と私は更生一新の発心をしたばかりだったから、無暗に理想が高くて他を律するに厳しかった。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然うと知ったら家へ手紙をやって、醤油の二樽も托けさせるのだったに」「相変らず抜け目がないね」「君は次男坊だけれど、僕は四男坊だもの。",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし先生も抜け目がない。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸火事泥をやって、安達さんを置いて参りました」「成程」「抜け目がないでしょう？",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇道以外にも抜け目がない。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハントお得意の表現で、抜け目がない。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "マザロフは抜け目がない。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まったく、あんたは抜け目がないぜ。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたいは抜け目がないから気づくさ。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "またお前が、そういう方にかけては、諸事抜け目がない奴と思えばこそ、家へ入れたのだからな。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さんざん、金時計を鵜に呑ませておいて、一網に、吐き出させるなんて、警察も抜け目がない」「しかし、いったいそんな高価な金属品を、どうして、あんな河の中へ捨てたのだろう。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、ぬけめがないところもあるんだ。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも、こうした取引にかけては、万事、自分を見まねていて、ぬけめがないとは思いましたが、念のためにきいたのでした。",
              "citation": {
                "source": "トム吉と宝石",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
