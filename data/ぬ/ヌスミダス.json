[
  {
    "uuid": "a58f789d-2f07-53fe-a432-e253c5edfd59",
    "entry": "盗み出す",
    "reading": {
      "primary": "ぬすみだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行"
      ],
      "ctype": null,
