        "examples": {
          "standard": [
            {
              "text": "デザインの指示に従って、この部分は青、あちらは赤と、色を塗り分ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地図上で各地域の特徴を明確にするため、色鉛筆で細かく塗り分けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは塗り絵をするとき、自由な発想で様々な色に塗り分ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "いわんや古代の近東諸国の錯綜した歴史などは、「国家あるいは民族の」などという言葉でごまかして、色で塗り分けるわけにはいかないかもしれない。",
              "citation": {
                "source": "映画『人類の歴史』",
                "author": "中谷宇吉郎",
