      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "salted rice-bran paste for pickling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このあいだ見た蒲田映画「その夜の女」などでも日本映画としては相当進歩したものではあろうが、しかし配役があまりに定石的で、あまりに板につき過ぎているためにかえってなんとなくステールな糠味噌のようなにおいがして、せっかくのネオ・リアリズムの「ネオ」がきかなくなるように感ぜられた。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薪も割ってもらわなくちゃこまるし、糠味噌もよく掻きまわして、井戸は遠いからいい気味だ、毎朝｜手桶に五はいくんで来て台所の水甕に、あいたたた、馬鹿な亭主を持ったばかりに、あたしは十年寿命をちぢめた。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔦ちゃんが、手を突込んだ糠味噌なんざ、打棄るのは惜いから、車屋の媽々に遣りさ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は極端に糠味噌くさい生活をしているので、ことさらにそう思われるのかも知れませんが、五十歳を過ぎた大作家が、おくめんも無く、こんな優しいお手紙をよくも書けたものだと、呆然としました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "糠味噌に漬けた小蕪と鹽鮭の切身が一つ、その上に乘つてゐる。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは外でもない、台所の隅つこにある糠味噌の匂である。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "名香で痺れた鼻の感じは、糠味噌の酸つぱい匂を嗅ぐと不思議によくなる。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し雨でも降り続くと、道といふ道は、まるで糠味噌のやうに濘つてしまふ。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "終には絹｜手※も鼻を拭んで捨て、香水は惜気もなく御紅閨に振掛け、気に入らぬ髪は結立を掻乱して二度も三度も結わせ、夜食好みをなさるようになって、糠味噌の新漬に花鰹をかけさせ、茶漬を召上った後で、「もっと何か甘しい物はないか」と仰るのでした。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "終には絹手※も鼻を拭んで捨て、香水は惜気もなく御紅閨に振掛け、気に入らぬ髪は結立を掻乱して二度も三度も結わせ、夜食好みをなさるようになって、糠味噌の新漬に花鰹をかけさせ、茶漬を召上った後で、「もっと何か甘しい物はないか」と仰るのでした。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れて初めて糠味噌をこしらへる、少々塩が利きすぎたが、うまく出来た、さつそく茄子を漬ける。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "清と云う下総生れの頬ペタの赤い下女が俎の上で糠味噌から出し立ての細根大根を切っている。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして友達の伯母さんと一緒に、糠味噌などを拵えてくれた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "義雄は肉にカイベツのあしらひを、北海道の涼しい夜風と同樣、初めての如く珍らしく思つたと同時に、香の物代りに出てゐたカイベツ並に枝豆の糠味噌漬けを甘いと感じた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田お玉が池の古金買八郎兵衛の家の糠味噌桶の中から、五十両の金子を盗み出しました男をその振舞から即座に御見出しになりました時などは、ほんとうに江戸中の大評判となりましたものでございます。",
              "citation": {
                "source": "殺された天一坊",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉が弟子の句空に送りました句に、「秋の色糠味噌壺も無かりけり」とあります。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは徒然草の中に、世捨人は浮世の妄愚を払ひ捨てゝ、糂汰瓶ひとつも持つまじく、と云ふ処から出て居るのださうでありますが、全くこの庵にも、糠味噌壺一つ無いのであります。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "先祖傳來の糠味噌樽へ螂蛆と一處にかきまぜたる茄子大根の新漬は如何。",
              "citation": {
                "source": "肉食之説",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "糟もそのまま飯の菜に充るが、なお糠を混じて搗いて糠味噌と名付け、そのままにも喰ったが多くは味噌汁にした。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "また煙草飲みはこの糠味噌汁を食べぬと脂が咽に詰るなどといい慣わしていた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "茄子を糠味噌へ漬けるのに色を善く出そうとして青銭を糠味噌へ入れる人もあるが、あれは青銭から緑青が出てそれで茄子の色を善くするのだ。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お裁縫だの、洗ひ張りだの、糠味噌の塩加減、野菜の煮方、その他｜細ま細ましたことが彼女の空想を刺戟した。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○白味噌の有する水分では足りないから、冷酒を加えて、糠味噌ぐらいのやわらかさに溶くこと。",
              "citation": {
                "source": "生き烏賊白味噌漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮だから捨ててしまえばそれまで、糠味噌へ入れれば漬けものになるし、そのほか、工夫次第でなんにでも重宝に使える。",
              "citation": {
                "source": "料理は道理を料るもの",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、だいこんでありましたら、葉をつけたままだと、葉を育てるためにだいこんの方から養分がとられますから、葉を切り放して、葉はすぐ糠味噌に入れるなどした方がよろしいのです。",
              "citation": {
                "source": "日本料理の基礎観念",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな酒樽にどつさり大根が漬けられてあつて、大嫌ひな糠味噌の臭ひが鼻を襲つて逆吐きさうになつた。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "まおかんがへ私とても、一生うちニおりてぬかみその世話致すハいやと存候バ、今日ニてよく御存（知）被成度候。",
              "citation": {
                "source": "続　手紙",
                "author": "坂本乙女あてか（推定、慶応二年夏頃）",
                "note": "青空文庫"
              }
            },
            {
              "text": "漬けものの漬かり加減は非常にむずかしく、気候とぬかみそ漬けの置き場で、漬かり方の速度に非常な差異ができるから、その点、注意深く心がける必要がある。",
              "citation": {
                "source": "胡瓜",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "不精して漬け過ぎると、きゅうりはすっぱくなるから、いい加減の時にぬかみそから取り出しておく。",
              "citation": {
                "source": "胡瓜",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "出し置きの利かないなすは、適当な時にぬかみそから出して食べることだ。",
              "citation": {
                "source": "胡瓜",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
