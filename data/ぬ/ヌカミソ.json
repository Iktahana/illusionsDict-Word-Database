[
  {
    "uuid": "91d19948-d1b9-5a05-9dcd-d2bfcbb4b9a4",
    "entry": "糠味噌",
    "reading": {
      "primary": "ぬかみそ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
