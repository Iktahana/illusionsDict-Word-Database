[
  {
    "uuid": "da50cbaa-9a2f-5b01-b622-37c2a8d3f5f8",
    "entry": "抜き手",
    "reading": {
      "primary": "ぬきて",
      "alternatives": [
        "ぬきで"
      ],
      "is_heteronym": false
    },
    "grammar": {
