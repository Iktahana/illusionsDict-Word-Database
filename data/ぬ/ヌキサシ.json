[
  {
    "uuid": "6a7e35e1-0b31-57f8-adc3-4a368060cc67",
    "entry": "抜き差し",
    "reading": {
      "primary": "ぬきさし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
