    "definitions": [
      {
        "index": 1,
        "gloss": "to coat a surface with something that adheres strongly when hardened (i.e. grout, plaster, lacquer)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "差当りまず崩壊した土蔵の残りの土を除いて丸裸となし、鉄網を張ってコンクリートで塗り固めるという手っ取り早いところから着手する。",
              "citation": {
                "source": "震災後記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "マングースもいよいよ鰐と取っ組むときには、その身のまわりをちょうど鎧を着るように、よくこねかえした泥ですっかり塗り固める。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか、各人は、争ってこの受け入れた信念を、彼の理性のできる限り＊をつくして、いよいよ塗り固めるのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "底をつくっておいて、又土をとりに飛んでいく、二度目に持って来たので、底の上の方を少しぬりかためる。",
              "citation": {
                "source": "智恵の一太郎",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
