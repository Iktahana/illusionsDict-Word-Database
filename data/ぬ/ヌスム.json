[
  {
    "uuid": "4c68b2d3-f573-5c5c-b711-699629e67296",
    "entry": "盗む",
    "reading": {
      "primary": "ぬすむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
