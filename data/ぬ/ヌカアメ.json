          "literary": [
            {
              "text": "置く霜のややに浅くも、こぬか雨ややに繁くも、裏藪や、菫さく辺の、いまだなじまず。",
              "citation": {
                "source": "風隠集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹林の早春わが庵の竹の林に、こぬか雨今朝も湿れり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "春さきのこぬか雨なり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "こぬか雨笹にこもりて、香※けば香もしめりて、事もなし、ただ明るけし。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "こぬか雨ふるがごとくに、こまごまといつくしみてむ春さきの我の思を。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹林の早春　わが庵の竹の林にこぬか雨今朝も湿れり。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こぬか雨笹にこもりて、香焼けば香もしめりて、事もなし、ただ明るけし。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こぬか雨ふるがごとくに、こまごまといつくしみてむ、春さきの我の思を。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　お友達のひやかしや、いろいろなお別れの言葉を背中に聞き流して外へ出ると、まだぬか雨がふりしきっていて、七月とは思えないほどの、うすら寒い夜であった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　しかし、翌朝はきのうと反対に、降りみ降らずみのぬか雨で、また返り梅雨の空もようでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑いながら、そしてその青白い顔を転じると、格子窓からぬか雨にけむる庭先のぬかるみに向かって、伝六の愚痴をさけるように面をそむけました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばしば申しますとおり、二月は二月であっても旧暦の二月なんだから、もう少しはぽかぽかしてもいっこうに不思議はないはずですが、それにしてもちょっと狂い陽気で、おまけに朝からしとしとと、絹糸のような小ぬか雨です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬか雨が音もなく降り出して、さっきからわたしがさんざんそばをぶらついて、今ではもう飽き飽きしてしまった馬鹿げた灰色の丸太の山に、べた一面ちっぽけな黒ずんだ点々をつけた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは大地のぬくもりであり、大地をうるおす春のぬか雨である……」といった調子で、チェーホフがもっとも苦手とした美辞麗句はめんめんと尽きないのである。",
              "citation": {
                "source": "チェーホフ試論",
                "author": "――チェーホフ序説の一部として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かすかな、音も立てないぬか雨。",
              "citation": {
                "source": "恢復期",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "こぬか雨だから降る音は聞えないけれども、夜も昼も絶え間のない雨垂れには気がめいるばかりだった。",
              "citation": {
                "source": "雨あがる",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　こぬか雨のなかで、かれらはみな血相を変え、凄いほど昂奮し、殆んど逆上していた。",
              "citation": {
                "source": "雨あがる",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（連日こぬかあめにとざされて一望すれども明るさもみえず、逆風は海をまき上げるごとく波浪はたかい。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
