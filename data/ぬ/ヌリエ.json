        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "泥色をした浅草紙を型にたたきつけ布海苔で堅めた表面へ胡粉を塗り絵の具をつけた至って粗末な仮面である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒塗り絵散らしの文机に向かわれて、燭台を引きよせ、何やら読書をしていらっしゃる。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽しい塗り絵がちょうどいい。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "正午まで塗り絵をすると、背中は痛くなり、指は固まりブラシを持てなくなった。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
