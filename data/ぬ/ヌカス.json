    "definitions": [
      {
        "index": 1,
        "gloss": "to omit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "肉体の上の極度の疲労と、精神上の異常な打撃とが同時に起ると、「腰を抜かす」と云ふ現象が起ることがある。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワーと山賊、腰を抜かす。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻堂の天狗が（団九郎）、Ｔ「吾こそは　此の仙境に　棲む天狗なり」　そら出たと山賊達、腰を抜かす。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前から酔っていた士が二階にいて頻りに管を巻いていたが、芝居が進んで茶屋場となり、由良之助が酒や女にうつつを抜かす態たらくを見ると、酔った士はそれを義士の首領の反間苦肉の策とは知りながらも、あまりその堕落振りが熱演されるので、我慢が仕切れなくなり、舞台に向って頻りに罵声を浴びせかけ始めた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてお前さんなんざ学者で先生だっていうけれど、からそんな時にゃあ腰を抜かすね。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と家令は腰を抜かす。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おん者ら（和歌山の方言でお前という意）俺の兄弟のこと悪う抜かすことないわい」　伝三郎は兄弟想いであった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おん者らわしの兄弟のこと悪う抜かす権利がないわい。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼前の異様の風景に接して、腰を抜かすなどといふ醜態を示す事は無かつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者の試験を受けに行くのだと知ったら、腰を抜かすかもしれない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂下の酒屋の小僧なら、そのまま腰を抜かす処を、学海先生、杖の手に気を入れて、再び大音に、「頼む。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "抜かすな、抜かすな。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "山高でフロックコートで、お従者を連れてすうと素通りで、や、ＳＳ、気の毒した、御苦労とも抜かすこつじゃねえ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつゝ抜かすと首根つこ、ふんづかまへるぞや。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の或る固執派教会に属する女学校の教師が曾我物語の挿画に男女の図あるを見て猥褻文書なりと飛んだ感違ひして炉中に投込みしといふ一ツ咄も近頃笑止の限りなれど、如何考へても聖書よりは小説の方が面白いには違ひなく、教師の眼を窃んでは「よくッてよ」派小説に現を抜かすは此頃の女生徒気質なり。",
              "citation": {
                "source": "為文学者経",
                "author": "三文字屋金平",
                "note": "青空文庫"
              }
            },
            {
              "text": "濁醪を引掛ける者が大福を頬張る者を笑ひ売色に現を抜かす者が女房にデレる鼻垂を嘲る、之れ皆｜他の鼻の穴の広きを知て我が尻の穴の窄きを悟らざる烏滸の白者といふべし。",
              "citation": {
                "source": "為文学者経",
                "author": "三文字屋金平",
                "note": "青空文庫"
              }
            },
            {
              "text": "二郎次はこれを聞くと腰を抜かすばかりに驚きました。",
              "citation": {
                "source": "三人兄弟",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「かたきのありかを聞いたばかりで、今から腰抜かすやつがあるかッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなに、あれが大事なら、稀には遊び道具位ゐ買つて呉れ――」「未だ抜かすか、こいつ奴！",
              "citation": {
                "source": "泉岳寺附近",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは火を上へ抜かすので、その頃の唯一の消火手段であった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "その頃の消防夫のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "抜かすな」　黒眼鏡はそんな皮肉に応酬するよりも、咽喉一杯に、雑巾のように押し込んだビーフに手古擦っていたのだ。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃至、鳥は空を飛ぶ物だの、飯は食ふものだの、しかも俺等の仲間は生命なきもの、意識なきもの也と、抜かすではないか、チヤンチヤラ可笑しくつて、御臍が御茶を湧かして、煮えてこぼれてしまふは、人間が勝手にこしらへた、一人ヨガリの理窟とか、道理とか云ふものを見給へ、こんな、愚にも付かん事が、よく云はれた物さ。",
              "citation": {
                "source": "俺の記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "このという言葉には非常に穿った名詞がくっついていたが、それはしかし上品な会話にはちょっと用いられない言葉だから、ここでは故意とそれを抜かすことにした。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意討ちにパッとアカリが点いたのを見ると、太陽が二十も三十も一時に出て来たようで今度こそホントウに腰を抜かすところでしたよ。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもここまで深入りしたからにゃトテも生きて日本にゃ帰れめえ……と気が付くと腰を抜かすドコロかあべこべに気持がシャンとなっちまいました。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "上海行だとも言うし又青島と言う噂もあるかと思うと確かに北満じゃとぬかす奴もある。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ナッ、ナニをぬかすと団九郎。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "文六が逃げ乍ら、Ｔ「貴様こそ　拙者の為には　父の敵」　ナッナニをぬかす、と団九郎。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その灯に照らされた行水の湯は真っ紅に染まっていて、それが娘の喉からあふれ出る血であることを知った時に、お伊勢は腰をぬかすほどに驚いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぜいたくぬかすな！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
