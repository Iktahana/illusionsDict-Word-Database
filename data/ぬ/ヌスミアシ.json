        "examples": {
          "standard": [
            {
              "text": "夜中に、家族を起こさないように盗み足で部屋を出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は獲物に気づかれないよう、盗み足で近づいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "忍者は、盗み足で敵の城に侵入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私はコソコソと往きとは反対の盗み足で石段を帰ってきたが、両側の杉や松の枝が後ろから招いてる気がして、頸筋に死の冷めたい手触りを感じた。",
              "citation": {
                "source": "父の出郷",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、宵になると、小さい兄妹達がみなして代わりばんこに、梯子段を盗み足に登って行っては、宴会の灯とお嫁さんを覗きに行った。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
