        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "仕合わせとこれが気立てのやさしい正直もので、もっとも少しぼんやりしていて、たぬきは人に化けるものだというような事を信じていたが、とにかく忠実に病人の看護もし、しかられても腹も立てず、そして時にしくじりもやった。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　たぬきはめをさまして、「なんだ。",
              "citation": {
                "source": "蟹のしょうばい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　たぬきは、いたずらがすきなけものですから、よくないことを考えました。",
              "citation": {
                "source": "蟹のしょうばい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹とくらべたら、たぬきはとんでもなく大きなものであります。",
              "citation": {
                "source": "蟹のしょうばい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "真中に挿しこんである之も鉄のかんぬきは、永遠に絶えざる地上の「悪」を牢く締め切つて居る。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぬきは、へえ、芹川がねえ、と言って、にやりと笑った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぬきは、口鬚を片手でおさえてクスクス笑った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、みんなも、」とたぬきは改まった顔つきをして、みんなを見渡し、「四年から受けるならば、ちょっと受けてみましょうなんて、ひやかしの気分からでなく、必ず合格しようという覚悟をきめて受けなくてはいかん。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」たぬきは嘲笑した。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、たぬきは、わははと笑った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぬきは傍に寄って来て、僕に教えてやろうかと言う。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや教えてやる、と言って、たぬきは、クスクス笑うのである。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲劇を書けばいいんだろう、と僕が言ってやったら、たぬきは、いや羽衣だよ、と言う。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさんだぬきは　こんや　こどもの　たぬきに、ばける　ことを　おしえようと　おもって、あなの　そとへ　でて　きました。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こどもの　たぬきは　それでも　おちちを　すって　いました。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ぼうやの　たぬきは　こまったような　かおを　しました。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おかあさんだぬきは　ぼうやの　たぬきを　だきあげて、「こわいんだよ　お月さんは。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おかあさんだぬきは、こどもの　たぬきを　したに、おろしました。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ぼうやの　たぬきは、いわれたとおり、目を　とじたけれど、りょう手で　しっかり　かあちゃんの　手を　とらまえて　いました。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おかあさんだぬきは、ぼうやが　とう　かぞえられないのを、ちゃんと　しって　いました。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ぼうやの　たぬきは、もう　目を　あいて　しまいました。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさんだぬきは、まだ　すっかり　ばけて　いないから、あわてて　しまいました。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おかあさんだぬきは、あわてて　しっぽを　ころもの　なかへ　かくしました。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼうやの　たぬきは　あっけに　とられて　しまいました。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼうやの　たぬきは　かなしく　なって、「かあちゃん。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かあさんだぬきは、ぼうやを　おろして、もとの　すがたに　なりました。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど　ぼうやの　たぬきは　だめでした。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさんだぬきは　こまって　しまいました。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "石太郎はだまって、依然、土手の声に聞き入っていたが、やがて、土手についていたもう一方の手が、ぐっと草をつかんだかと思うと、土管の中から、右手を徐々にぬきはじめた。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
