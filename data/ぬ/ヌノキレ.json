    "definitions": [
      {
        "index": 1,
        "gloss": "piece of cloth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "繪具箱へスケッチ板を一枚入れて、其れと座蒲團代りの古い布切れとを風呂敷で包み隱したのを抱へて市内電車で巣鴨迄行つた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の布切れがやつぱり今でも引つかゝつて居るかも知れない。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此日かいた繪を見ると、繪の下の方に此の布切れがぶら下つて居るやうな氣がして仕方がない。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが寒い時候にはいつでも袖無しの道服を着て庭の日向の椅子に腰をかけていながら片手に長い杖を布切れで巻いたのを持って、そうしていつまでもじっとしたままで小半日ぐらいのあいだ坊主頭を日に照らしていた。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」壁に布切れやしわくちゃの紙片をだらしなく貼りつけたのをバックにして、平凡な牛乳びんに二本のポインセチアが無雑作に突きさしてあるだけである。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁帽に麻の夏服を着ているのはいいが、鼻根から黒い布切れをだらりとたらして鼻から口のまわりをすっかり隠している。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵の具箱へスケッチ板を一枚入れて、それと座ぶとん代わりの古い布切れとを風呂敷で包み隠したのをかかえて市内電車で巣鴨まで行った。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りに、腰に敷いていた大きな布切れのちりを払おうとした拍子に取り落とした。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この布切れが今でもやっぱり引っかかっているかもしれない。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日かいた絵を見ると、絵の下のほうにこの布切れがぶら下がっているような気がしてしかたがない。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば燃え尽くした残骸の白い灰から火が燃え出る、そうしてその火炎がだんだんに白紙や布切れに変わって行ったりする。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴覚のほうが主になれば役者は材木と布切れで作った傀儡でもよい。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土人の中には大きな石鹸のような格好をした琥珀を二つ、布切れに貫ぬいたのを首にかけたのがいた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱や手すりを白樺の丸太で作り、天井の周縁の軒ばからは、海水浴場のテントなどにあるようなびらびらした波形の布切れをたれただけで、車上の客席は高原の野天の涼風が自由に吹き抜けられるようにできている。",
              "citation": {
                "source": "軽井沢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥は鮮魚を食い尽くしたが布切れの下の腐肉には気づかなかったとある。",
              "citation": {
                "source": "とんびと油揚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木戸をチョップ・ミートのように叩き潰して抑さえつけ、チャンスを与えようとしなかったんだ」（「愚か者は真実に傷つく」李春成『ナンバー』一九九二年五月二十日号）　さらに職業政治家となった以降の猪木寛至も、相変らず鮮烈な布切れを、実に脈絡なく編み続けてくれる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "布切れの真中をつまみあげると布の周囲が寄つてくるやうに――、詩人は女好きだとは頭から決められない詩人は女に対しては相当選り好みがやかましいのだ、一個所欠点があるとその一個所を蛇蝎のやうに憎む詩人やら、他人が欠点と見るところも勝手に美化し合理化し拝み奉る詩人もある。",
              "citation": {
                "source": "託児所をつくれ",
                "author": "小熊秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "青や赤やのいろいろ取り交ぜた布切れがたらりとさがっておって、それをひっぱるとガチャガチャボンボンと変な音を出すものがありまさね」「わにぐちか」「そうそう、わにぐちですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに妙見さまは弁天さまのごきょうだいにしたって、ただの布切れが人ののど笛を食い破るなんてことは、どう考えたってもがてんがいかねえんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度チヤツプリンを引き合いに出すが、「黄金狂」で、チヤツプリンは片方の靴を燃やしてしまつたので、藁か布切れかでトテモ大ツかく足を包んでいた。",
              "citation": {
                "source": "北海道の「俊寛」",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が捨てたとも分らぬ菖蒲の花が、黄色い雛鳥の死骸や、布切れなどの中から、まだ生き生きと紫の花弁を開いていた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その旗の布切れが流れる群衆の足にひっかかったまま、建物の中へ吸い込まれようとした。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "外科的な専門の立場で云うと、千人針を体につけていて弾丸に当ると、弾丸の方は比較的たやすく抜き出すことが出来るが、小さい糸こぶをもった布切れがどうしても傷の奥ふかく食いこんでのこって生命のために危険なのだそうである。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "絹布切れでつくったさいはらい、棕櫚の手製の箒等みな自分専用のものである。",
              "citation": {
                "source": "画室談義",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は側にあつた布切れを彼に与へておき、靴下を二枚重ねて足に穿いた。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は側にあった布切れを彼に与えておき、靴下を二枚重ねて足に穿いた。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、この村にとってもっとも必要なものはだい一に米、以外には塩と布切れだ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "むすめはお母さんの足もとの床の上にすわって、布切れの端を切りこまざいて遊んでいました。",
              "citation": {
                "source": "真夏の夢",
                "author": "ストリンドベルヒ　August Strindberg",
                "note": "青空文庫"
              }
            },
            {
              "text": "税務署の人はその通りにしましたが、辺り一面｜灰神楽になったので、私は布切れで上り口をはたきました。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その一〔判官巷を往く〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　すると　まっくらがりで　いきなり　まっさかさまに　穴へ　おっこちて、　ばっちい　ぬのきれの　山へ　どすん。",
              "citation": {
                "source": "ちょびひげサミュエルのはなし",
                "author": "まきまきパンのまき",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
