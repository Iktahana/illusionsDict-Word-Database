        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの手札は抜け役になりそうだ、と彼は密かに期待していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "途中で抜け役ができそうだったので、勝負に出ることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最後に抜け役が完成し、彼女は大逆転勝利を収めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「なるほど、僕は出番をまちがえて、他の役者の出る幕の舞台へ飛び出した間抜け役者かも知れない。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "年の若い外記が自分から進んで腰抜け役の小普請入りなどを願う筈がないのは、彼が日ごろの性質から考えても判っている。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
