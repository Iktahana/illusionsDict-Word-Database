    "definitions": [
      {
        "index": 1,
        "gloss": "be inextricably involved",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
