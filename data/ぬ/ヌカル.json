  {
    "uuid": "5b4d461c-d441-5d65-9aa0-c0507e4e1353",
    "entry": "泥濘る",
    "reading": {
      "primary": "ぬかる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to become muddy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "背戸の田圃のぬかるみに映る星、籾磨歌が聞える。",
              "citation": {
                "source": "星",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅員の不機嫌顔甚だしきも官線はやはり官線だけの権力とか云うものあるべしと、かしこみて願い奉りようよう切符を頂戴して立ちいずれば吹き上ぐる朝嵐に藁帽飛んでぬかるみを走る事｜数間、ようやく追い付きて取止めたれど泥にまみれてあまり立派ならぬ帽の更に見ばえを落したる重ね／＼の失敗なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔腐植土のぬかるみよりの照り返し〕腐植土のぬかるみよりの照り返し、　　材木の上のちひさき露店。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腐植土のぬかるみよりの照り返しに、　　二銭の鏡あまたならべぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腐植土のぬかるみよりの照り返しに、　　すがめの子一人りんと立ちたり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく掃除せしラムプをもちて腐植土の、　　ぬかるみを駅夫大股に行く。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腐植土のぬかるみよりの照り返しに　　二銭の鏡売るゝともなし。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の降る日に二条の鉄路の中央のひどいぬかるみの流れを蹴たててペンキ塗りの箱車を引いて行く二頭のやせ馬のあわれな姿や、それが時々爆発的に糞をする様子などを思い出すことはできる。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨上の路はぬかるみ、水溜には火影うつる。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は首をすくめ、懐ろ手をしながら、落葉や朽葉とともにぬかるみになった粘土質の県道を、難渋し抜いて孵化場の方へと川沿いを溯っていった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟が泥靴のままでぬかるみの中をかまわず歩いてゆく間に、清逸は下駄をいたわりながら、遅れがちに続いた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽坂の往来はびしよ／＼にぬかるんで夜風が寒かつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲田や芋畑のあいだを縫いながら、雨後のぬかるみを右へ幾曲りして登ってゆくと、その間には紅い彼岸花がおびただしく咲いていた。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬかるみを五里ぐらゐ歩いたらう、くたぶれた、帰庵したのは一時頃、それからお茶をわかして。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "路は狭く暗く、おまけにぬかるみなどもあって、私たちは二人ならんで歩く事が出来なくなった。",
              "citation": {
                "source": "メリイクリスマス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は空に寒くどこでもぬかるみがじめじめした道につづいた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は手に引つ越しの荷物をさげ、古ぼけた家具の類や、きたないバケツや、箒、炭取りの類をかかへ込んで、冬のぬかるみの街を歩き※つた。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は手に引つ越しの荷物をさげ、古ぼけた家具の類や、きたないバケツや、箒、炭取りの類をかかへ込んで、冬のぬかるみの街を歩き廻つた。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "復一はようやくそこの腐葉土のぬかるみで、危く踏み止まった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごんは川下の方へと、ぬかるみみちを歩いていきました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさ、はやく、三木から電話で、戸山が原のことを聞き、男は、いやだねえ、とその踊子の友だちと話合い、とにかく正午に、雪解けのぬかるみを難儀しながら戸山が原にたどりついて、見ると、いましも、シャツ一枚の姿の三木朝太郎は、助七の怪力に遭って、宙に一廻転しているところであった。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさ、はやく、三木から電話で、戸山が原のことを聞き、男は、いやだねえ、とその踊子の友だちと話合ひ、とにかく正午に、雪解けのぬかるみを難儀しながら戸山が原にたどりついて、見ると、いましも、シヤツ一枚の姿の三木朝太郎は、助七の怪力に遭つて、宙に一廻転してゐるところであつた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ぬかるみを目の前にして……さあ、出掛けよう。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の奧に住める人の使へる婢、やつちや場に青物買ひに出づるに、いつも高足駄穿きて、なほ爪先を汚すぬかるみの、特に水溜には、蛭も泳ぐらんと氣味惡きに、唯一重森を出づれば、吹通しの風砂を捲きて、雪駄ちやら／＼と人の通る、此方は裾端折の然も穿物の泥、二の字ならぬ奧山住の足痕を、白晝に印するが極惡しなど歎つ。",
              "citation": {
                "source": "森の紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物の裾を二人とも、だらしなく薄ぬかるみの路面に引摺り、とぼ／＼と歩いて行きます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡ては眩し、痛々し、笑ふよしなし、傷ける鳥と狂へる舟は燦爛｜赫耀、今こそ互に相憎め、言葉なき言葉激しく、さてしばし、深くひそめる鳥はまた飛び去らむとし、たちまちに眼をつらぬかる。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは好いが、先生自分で鞭を持って、ひゅあひゅあしょあしょあとかなんとか云って、ぬかるみ道を前進しようとしたところが、騾馬やら、驢馬やら、ちっぽけな牛やらが、ちっとも言うことを聞かないで、綱がこんがらかって、高粱の切株だらけの畑中に立往生をしたのは、滑稽だったね。",
              "citation": {
                "source": "鼠坂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "八は向側の、五爪竜の絡んでゐる杉垣の処に雨に濡れながら立つて、ぼんやり此様子を見てゐたが、別当が門を締めに出て来るとき、殆ど無意識にぬかるみ道を歩き出した。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して純然たる性格を代表した鼻の表現の批評に「意地悪根性の鼻まがり、ぬかるみ辷ってツンのめろ」という俚謡があります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
