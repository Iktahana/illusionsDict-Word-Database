[
  {
    "uuid": "96f9c2da-6de9-5874-8337-e2c224d53335",
    "entry": "抜け荷",
    "reading": {
      "primary": "ぬけに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
