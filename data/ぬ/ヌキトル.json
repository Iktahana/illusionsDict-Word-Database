[
  {
    "uuid": "926e8e35-d514-54c2-a6c6-9121762b03c6",
    "entry": "抜き取る",
    "reading": {
      "primary": "ぬきとる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
