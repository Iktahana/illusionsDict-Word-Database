    "definitions": [
      {
        "index": 1,
        "gloss": "Chinese sumac (Brucea javanica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
