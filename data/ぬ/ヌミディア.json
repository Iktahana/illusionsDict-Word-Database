        "examples": {
          "standard": [
            {
              "text": "ヌミディアは、古代北アフリカに存在した王国である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ローマ帝国は、ヌミディアを属州として支配下に置いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ヌミディア騎兵は、その勇敢さで知られ、ローマ軍にも雇われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "三五四年タガステ（昔のヌミディア）に生れる。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "（c）ヌミディアの兵士たちは替えの馬を引いて行って、戦いまさにたけなわならんとする頃これに乗りかえた。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ルカヌス）（c）またヌミディア人は轡なき馬に乗る。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
