        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また、幹には苔が蒸して、皮は土より柔く、ぼろぼろに腐っているから、生あるものの肌のようで、ぬらりと滑り、ぐちゃりと触れて、いやな気持がする。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しむときは、鳴沢に小石が滑り落ちる音が止めどもなくしくしくと聞えて来る。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柚木にそうさせて置いてから、老妓はその反対側の腕の皮膚を自分の右の二本の指で抓って引くと、柚木の指に挾まっていた皮膚はじいわり滑り抜けて、もとの腕の形に納まるのである。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度柚木は力を籠めて試してみたが、老妓にひかれると滑り去って抓り止めていられなかった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　月あかりの中にまっすぐに立った電信柱が、次々に何本も何本も走って行き、けむりの影は黒く雪の上を滑りました。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから彼はその異樣な花瓣を自分の軍衣の下に滑り込ませた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから放水路の水へ滑り込んで、舟に護られながら海へ下って行くのだ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とに角、掛布を速にお前の胸に覆ひながら、滑り落ちた氷嚢をお前の額に置きながら、さうしたお前を母や兄や看護婦達にまざまざしく見詰められる事が私には苦しかつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その智は無論叡智と云へる程の神々しさはないが、また時には才智と云へば云へる上滑りした智に堕する傾向を持つてゐるが、それは可成り鋭い発見力と、細かな解剖力と、確かな批判力とを持つてゐる明智だと云へば、一番当つてゐるやうに思はれる。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "銃は、その手袋の指の間から蝋をなすりつけたようにつるつる滑り落ちた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫は嘉ッコの手から滑り落ちて、ぶるるっとからだをふるはせて、それから一目散にどこかへ走って行ってしまひました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水平線を境としてそのあちら側へ滑り下りてゆく球面からほんとうに美しい海ははじまるんだ。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光がその人の高い鼻を滑りました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまでも指を滑り込ませる温かい腹の柔毛――今一方の奴はそれを揃えた後肢で踏んづけているのである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっさの思いつきで、今度はスキーのようにして滑り下りてみようと思った。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体の重心さえ失わなかったら滑り切れるだろうと思った。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋲の打ってない靴の底はずるずる赤土の上を滑りはじめた。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから滑り降りるのだ。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――年老いても二人はその日の雪滑りを忘れなかった。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫薇　猿滑りとは其幹の攀ぢがたく見ゆるよりの名なるべく、百日紅と呼び半年花と呼ぶは其花の盛り久しきよりの称なるべし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私いちど、しのび足、かれの寝所に滑り込んで神の冠、そっとこの大頭へ載せてみたことさえございます。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は湯槽にからだを滑り込ませて、ぬるいのに驚いた。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "行進　（五）　セットの終ったころ、田島は、そっとまた美容室にはいって来て、一すんくらいの厚さの紙幣のたばを、美容師の白い上衣のポケットに滑りこませ、ほとんど祈るような気持で、「グッド・バイ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "檻の底に車輪の脚がついてゐるらしくからからと音たてて舞臺へ滑り出たのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "檻の底に車輪の脚がついているらしくからからと音たてて舞台へ滑り出たのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫は嘉ッコの手から滑り落ちて、ぶるるっとからだをふるわせて、それから一目散にどこかへ走って行ってしまいました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "室子は、自分ながら、どうしたことかと下唇を痛いほど噛んで笑いを止め、五尺三寸の娘の身体を、寝床から軽く滑り下ろした。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オールを入れて左右のハンドルを片手で握り乍ら素早くシートへ彼女は腰を滑り込ます。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーク燈に弾ね返される夜の蝉のように私の魂は滑り落ちてはにじむような声で鳴くようです。",
              "citation": {
                "source": "愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「滑りなはるな」と婆やはかやの手をしっかり握って、湿った足場を探り探り渡った。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
