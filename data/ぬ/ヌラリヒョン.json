        "examples": {
          "standard": [
            {
              "text": "ぬらりひょんは、日本の妖怪の中でも特に有名な存在だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "家に勝手に上がり込み、主人のように振る舞うぬらりひょんの伝説がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "妖怪図鑑でぬらりひょんの絵を見て、子供たちは怖がっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その証拠に、「あらすじ」を言ってみせよというと大抵の者が、「坊ちゃんなる人物が英語の先生として松山に赴任して、赤シャツやら山嵐やら、ぬらりひょんやらいった同僚たちと、マドンナなる婦人をめぐって鞘当てを繰り広げる話」などと答える。",
              "citation": {
                "source": "ぞなもし狩り",
                "author": "円城塔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
