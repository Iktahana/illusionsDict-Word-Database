[
  {
    "uuid": "23499c99-e09f-5281-be44-f0d3c89458e3",
    "entry": "滑々",
    "reading": {
      "primary": "ぬめぬめ",
      "alternatives": [
        "ヌメヌメ"
      ],
      "is_heteronym": false
    },
    "grammar": {
