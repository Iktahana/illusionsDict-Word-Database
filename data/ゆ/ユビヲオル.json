    "definitions": [
      {
        "index": 1,
        "gloss": "to count on one's fingers",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
