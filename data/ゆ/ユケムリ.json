        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　と突然どんつくの諸膚を脱いだ勢で、引込んだと思ふと、髯がうめ方の面當なり、腕の扱きに機關を掛けて、爰を先途と熱湯を注ぎ込む、揉込む、三助が意氣湯煙を立てて、殺氣朦々として天を蔽へば、湯船は瞬く間に、湯玉を飛ばして、揚場まで響渡る。",
              "citation": {
                "source": "錢湯",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に一人、壁の根に跪き、もの打念ずる状して、高く掌を合わせたものの、白き頸の湯煙ほぐれて、黒髪の色と分れた時、夫人の目はやや馴れて、その良人の口に、一点｜煙草の火の燃えつつあるを認め得た。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ二目三目より、本因坊膏汗を流し、額に湯煙を立てながら、得たる祕法を試むるに、僅少十餘子を盤に布くや、忽ち敗けたり。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれも赤い柱、白い壁が、十五｜間間口、十間間口、八間間口、大きな（舎）という字をさながらに、湯煙の薄い胡粉でぼかして、月影に浮いていて、甍の露も紫に凝るばかり、中空に冴えた月ながら、気の暖かさに朧である。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なま暖かいひと間の空気に倦んで、次郎左衛門は障子を少しあけていたが、やがて又ぴっしゃりと閉め切って古びた手あぶりの前に坐って、小さい鉄瓶の口から軽く噴く湯煙りのゆくえを見つめていた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちらへとっととおどきめされッ」　寄ってはならぬといったものでしたから、聞くやいっしょで、湯煙たてながらしゃきり出たのは、だれでもない向こうっ気の伝六です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の湯風呂には、旧式の石榴口と云うものがあって、夜などは湯煙が濛々として内は真っ暗。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉は湧出量が豊富で高温である、雑木山の空へ噴き上げる湯煙の勢よさ。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "その折は十丈も煮え騰る湯煙りの凄じき光景が、しばらくは和らいで安慰の念を余が頭に与えた。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯煙りが上り、靄が白くゆらゆら立ちのぼる中に百六十軒の人家が並んでいる、賑かに歌をうたう声が聞えている。",
              "citation": {
                "source": "木曾御嶽の両面",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯煙りが上り、靄が白くゆら／＼立ちのぼる中に百六十軒の人家が並んでゐる、賑かに歌をうたう聲が聞えてゐる。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　秋ちゃんは何のためらいもなく、乳房を開いて勢いよく湯煙をあげて風呂へはいった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝のせいか、湯煙りが川にたちこめてゐて、山の温泉らしさうです。",
              "citation": {
                "source": "大島行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その燈火のあたりに、もうもうと湯煙が立ちこめてゐる。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせいは誰かと、湯煙のなかで話しあつてゐたが、これもすぐ浴槽へ入つて、ゆるい速度で富岡のそばへ寄つて来た。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆき子は、湯煙を眺めながら、その部屋の佗しさを食ひつくやうにして眺めてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつき、あわてて開けた窓硝子から、南風が湯煙を吹き拂ふやうにしてさつと吹き込む。",
              "citation": {
                "source": "あひびき",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがまるで細引のやうな太い雨で、暑い處なので、雨は湯煙をたててゐるやうな激しさで四圍が乳色に染つてくる。",
              "citation": {
                "source": "ボルネオ　ダイヤ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にまたさまざまの地獄から沸泉が湯煙を立てて流れて行く水路の底が美くしい碧玉の色に染まっていることを見逃すことは出来なかった。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞にも僅か出しまして中絶いたしました霧隠伊香保湯煙のお話で、央からお聴に入れまする事でございますが、細かい処を申上げると、前々よりお読み遊ばしたお方は御退屈になりますから、直に続きを申上げます、足利の江川村で茂之助が女房に別れるとき、横浜へ行くからお父さんに内証で脇差を持って来てくれと頼みました。",
              "citation": {
                "source": "霧陰伊香保湯煙",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十一　さて引続きまする伊香保の湯煙のお話でございます。",
              "citation": {
                "source": "霧陰伊香保湯煙",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "漲ぎり渡る湯煙りの、やわらかな光線を一｜分子ごとに含んで、薄紅の暖かに見える奥に、漾わす黒髪を雲とながして、あらん限りの背丈を、すらりと伸した女の姿を見た時は、礼儀の、作法の、風紀のと云う感じはことごとく、わが脳裏を去って、ただひたすらに、うつくしい画題を見出し得たとのみ思った。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "室を埋むる湯煙は、埋めつくしたる後から、絶えず湧き上がる。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴室の鎧窓から、湯煙の立ちのぼるのも面白い。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴慕の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "手早く、身近に脱ぎっぱなしてあった、団体客のうちから一人の衣裳を奪って、まず切りたての六尺木綿から手早く身に引っかけて置いての芝居と、立ち上ったところを、先方もさるもの、パッと一度に水煙、ではない、湯煙を立てて、「御用だ！",
              "citation": {
                "source": "大菩薩峠",
                "author": "農奴の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが工場裏の排水管の湯煙りにむらがって、その顔や手足を洗っている群れの中には、汚い頬被りが取られる下から、剥き卵みたいな可憐な少女の顔も見えたり、初々しげな人妻らしい、ほつれ髪の顔もあったりするのであった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "と私は、頭から湯煙りを立てた。",
              "citation": {
                "source": "雷嫌いの話",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ナオミは両手にお白粉を溶き、まだ湯煙の立っている肉づきのいい肩から項を、その手のひらで右左からヤケにぴたぴた叩きながら云いました。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああびっくりした」若さまは茹って赤くなった体から、不動明王のように湯煙を立てながら出て来た。",
              "citation": {
                "source": "若殿女難記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは豆南の一角、海をへだてた大島の御神火と対して、町に湯煙のたえない熱海の湯治場。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
