    "definitions": [
      {
        "index": 1,
        "gloss": "snow-laden sky",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
