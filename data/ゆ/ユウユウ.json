[
  {
    "uuid": "ed5c1bb0-def4-5b52-a89a-cc8a0f864787",
    "entry": "悠々",
    "reading": {
      "primary": "ゆうゆう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
