      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "quiet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一巡して、職員たちに見送られ、人力車に乘つて悠々、御歸館。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は、昨年の春、同じ学部の若い教授と意見の衝突があって、忍ぶべからざる侮辱を受けたとかの理由を以て大学の講壇から去り、いまは牛込の御自宅で、それこそ晴耕雨読とでもいうべき悠々自適の生活をなさっているのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きょうはじめてお嫁さんと逢うんだというのに、十一時頃まで悠々と朝寝坊しているんですからね。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には白い雲が浮び、自然の悠々たる時劫の外、物音一つしない閑寂さである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば鶯のあちこちとするや小家がち　　　蕪村春の海ひねもすのたりのたり哉　　　蕪村　の如く、「あちこちとするや」の語韻から、鶯のチョコチョコとする動作を音象し、「のたりのたり」の音調から春の海の悠々とした印象を現わしているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東行西行雲悠々」といふ漢詩を、昔の或る人が和訳して「きさらぎ、やよひ、日のどか。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはどうしても、たいまいの手のやうな廣い鰭状の手で悠々と水を掻きわけてもらはなくてはならぬところだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬上｜悠々、大裾野を横切ったのは、前の大宮口が徒歩（但し長坂までは自動車を借りた）であったから、変化を欲するために外ならなかった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "石から石の上を飛びめぐる鶺鴒と筋交ひに、舟は両崖の迫つた間の急湍を、櫂を休めて悠々と乗つ切る、川には筏に組む材木が漂ひながら岩に堰かれてゐる、王子製紙会社の紙の原料で、中部の支社で、製するのだといふ。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "老妓はすべてを大して気にかけず、悠々と土手でカナリヤの餌のはこべを摘んだり菖蒲園できぬかつぎを肴にビールを飲んだりした。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人特有の真白い素足が、夫人の濃紫の裾から悠々と現われました。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだという返答をたしかめてから後に悠々と卓布一杯に散々楽書をし散らして、そうして苦い顔をしているオーバーを残してゆるゆる引上げたという話もある。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝坊悠々塀に凭れて唄でも唄って居る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉は、悠々徳利のガブ呑み。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉、悠々、Ｔ「今度は　三から二引く」　立廻り。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "広間になりひら悠々と坐している。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりひら悠々と、Ｔ「ちッとやそっとじゃ帰れねえ」　やれやれと左衛門閉口した。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝広間では　なりひらが悠々立ち上る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎、悠々として、門内に入る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵が、悠々、大小の木太刀を掴んで一振り二振り。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "悠々と道場の中央に仁王立ち。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎の天狗は悠々と現れ出て、Ｔ「我名を騙る　憎い人間ども」　山賊達、震え上る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵と団九郎、悠々と村人に近附く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝境内　武蔵が大小の木太刀を手に悠々と腰打ち掛けて居る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は悠々たる行路の人なのです。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、ここにも先生の風｜格は現れて、その突き振りたるや悠々｜重厚の感じがある。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河は、海峡よりはもっと広いひろがりをもって海のように豊潤に、悠々と国境を流れている。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒竜江は、どこまでも海のような豊潤さと、悠々さをたたえて、遠く、ザバイガル州と呼倫湖から、シベリアと支那との、国境をうねうねとうねり二千里に渡って流れていた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時天地｜悠々の感、人間存在の不思議の念などが心の底からわいて来るのは自然のことだろうと思う。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "われと他と何の相違があるか、みなこれこの生を天の一方地の一角に享けて悠々たる行路をたどり、相携えて無窮の天に帰る者ではないか、というような感が心の底から起こって来てわれ知らず涙が頬をつたうことがある。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
