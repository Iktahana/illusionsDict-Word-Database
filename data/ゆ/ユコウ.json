        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕は民子が嫁にゆこうがゆくまいが、ただ民子に逢いさえせばよいのだ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光浴を書いたついでに私はもう一つの表象「日光浴をしながら太陽を憎んでいる男」を書いてゆこう。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいどこまでゆこうとするのだろう。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかに捜して宿をとろうか、それとも今の女のところへ帰ってゆこうか、それはいずれにしても私の憎悪に充ちた荒々しい心はこの港の埠頭で尽きていた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきの路へゆこうとする意志は、私にはもうなくなってしまっていた。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいどこから浮かんで来た空想かさっぱり見当のつかない屍体が、いまはまるで桜の樹と一つになって、どんなに頭を振っても離れてゆこうとはしない。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の治めてゆこうとする家が、大槻の夢に出て来た切符売場のように思えた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇術が何とか座にかかっているのを見にゆこうかと言っていたのを、峻がぽっと出てしまったので騒いでいたのである。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝子は片手を電燈の真下へ引き寄せられて、針を持った姉が、掌へ針を持ってゆこうとする。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして解した髪の毛の先が触手の恰好に化けて、置いてある鉢から菓子をつかみ、その口へ持ってゆこうとしているのです。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、ポチを東京へ連れてゆこうと思うよ。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は、お前にこの銀の小箱をたった一つ遺してゆこうと考えた。",
              "citation": {
                "source": "イワンとイワンの兄",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "コウノトリたちは、いま、ふるさとを去って、暖かい国へゆこうというのです。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍛冶屋のお爺さんはいよいよ慌てて、お金を払って荷物を荷って出てゆこうとしました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ考えてからもの思う葦という題で毎月、あるいは隔月くらいに五六枚ずつ様々のことを書き綴ってゆこうというところに落ちついたのだ。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰るどころか、みんなの顔には、町まで送ってゆこう、という決意があらわれていた。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、今夜は誰も、文六ちゃんのことを忘れてしまったかのように、送ってゆこうとするものがありません。",
              "citation": {
                "source": "狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小説は唄いながら少しずつすすめてゆこう。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつに乗ってゆこう、といった。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで女房は夫のもらう扶持米で暮らしを立ててゆこうとする善意はあるが、ゆたかな家にかわいがられて育った癖があるので、夫が満足するほど手元を引き締めて暮らしてゆくことができない。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふだん往復したことのない者が、なんで私の家へ魂を遺してゆこう」　孫の家の者はそれでも是非招かしてくれと頼んだので、阿宝の父親もやっと承諾した。",
              "citation": {
                "source": "阿宝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから全部を明瞭に発表しましょう」「犯人があがるまでは、ホームズ先生、あなたの御自由におやり下さい」「いや別に秘密主義でゆこうと云う意味でもないのですが、いずれ事件の進行中に、長い込み入った説明をすることは難かしいことですからね。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は我々を見つけ出して、その恐怖で生きてゆこうとしたのだ。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとっさん早くしないかア、早く着物おきかえよ、お妙ちゃんもめいちゃんも髪ゆうてよ、早くゆこうよう、新聞なんかおよしよ。",
              "citation": {
                "source": "浅草詣",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてストキは、ボースンを打っちゃらかしたまま、船長が今おりてゆこうとするその前へつっ立った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、両親のためには、どんな苦しい淋しいことにでも、堪え忍んでゆこうと思っていました。",
              "citation": {
                "source": "燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ためにその紀行文もともすればその場その場の気持や情緒を主としたものとなりがちで、どうしても案内記風のものとは離れてゆこうとする。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ凡俗なセンチメンタリズムが文學の名に於て歴史の事實を朦朧化し、二十世紀の現代に眼を閉じさして民衆を昔し昔しのお伽噺につれてゆこうとする時、唯物史觀は儼然たる事實を示す必要があるのである。",
              "citation": {
                "source": "唯物史觀と文學",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
