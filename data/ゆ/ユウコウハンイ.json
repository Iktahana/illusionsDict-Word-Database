        "examples": {
          "standard": [
            {
              "text": "この法律の有効範囲は、国内のすべての市民に及ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "変数の有効範囲を理解することは、プログラミングの基本中の基本だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の専門知識は広範囲にわたるが、このプロジェクトの有効範囲には収まらない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ラゴーフはこれを試みたものの、ヤー・クの無名村から三十キロメートル以上には有効範囲を伸ばせなかった。",
              "citation": {
                "source": "いえ、いえ、ラゴーフにはもう！",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
        }
