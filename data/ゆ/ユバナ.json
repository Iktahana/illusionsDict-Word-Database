        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "力なく引手に手をかけ、裳を高く掻い取って、ドンと圧すと、我ながら、蹴出の褄も、ああ、晴がましや、ただ一面に鼠の霧、湯花の臭気面を打って、目をも眉をも打蔽う土蜘蛛の巣に異ならず。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩の上には黄色の湯花がたまり、まるで菖蒲池に水浴してゐるやうにも見える。",
              "citation": {
                "source": "摩周湖紀行",
                "author": "――北海道の旅より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "水ぎはの波の色は糸を引いたやうな黄色い湯花の波で、不思議な景色だ。",
              "citation": {
                "source": "摩周湖紀行",
                "author": "――北海道の旅より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯花の匂ひがむつと鼻に来る。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "体が癢くて困るといわれてうちの代診の工夫で硫黄の風呂を立てたこともあり、最上高湯の湯花を用いたことなどもあった。",
              "citation": {
                "source": "三筋町界隈",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "家伝霊薬と銘うって千年も前から伝わっているように云いふらしていたが、万事は三吉の方寸からでたもので、草津の湯花から思いついたものであった。",
              "citation": {
                "source": "保久呂天皇",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "保久呂湯も湯花がでる。",
              "citation": {
                "source": "保久呂天皇",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "部落では湯花と云わずに湯渋と云っているが、この鉱泉は渋の色をしていて、味も渋く、万事渋の表現が適している。",
              "citation": {
                "source": "保久呂天皇",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋シ其温泉或ハ湯花ヲ汲来ツテ之ヲ湯中ニ和スト云フ。",
              "citation": {
                "source": "上野",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "溪川には、湯が湧き出で、白い湯花が漂って、岩に引っかゝっているところもある。",
              "citation": {
                "source": "渋温泉の秋",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "石面に薄い湯花がよどみ、口にふくめば苦味が強い。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
