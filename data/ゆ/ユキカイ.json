        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただ、遊んで行けばいいのよ」　先程からわたくしたち二人の話の遣り取りを眼を大きく見開いてピンポンの球の行き交いのように注意していた雛妓は「あら」と言って、逸作の側を離れて立上り、今度はわたくしの傍へ来て、手早くお叩儀をした。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦横無尽に行き交い飛び交う。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは、こんな心持の行き交いにさえも作用する生活の事情ということ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "異常な胸さわぎと、行き交いの風の匂いを持って帰るだけだった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "行く者、帰る者、罹災者達の蜿※たる流れがまことにただ無心の流れの如くに死体をすりぬけて行き交い、路上の鮮血にも気づく者すら居らず、たまさか気づく者があっても、捨てられた紙屑を見るほどの関心しか示さない。",
              "citation": {
                "source": "堕落論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そばを怪魚が行き交い、巨大なシタガレイは並の食卓よりでかく、エビもどきはハロルドの肩まである。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて男どもが行き交い始め、しばらくして安堵したのはあの男を見たからだ。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りには大勢の新聞売り子が行き交い、口々に叫んでいた。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "使番と、使番とが、矢つぎばやに、行き交いされる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋桁に添って、九尺もいる所をかえていたが、弾と行き交いに、彼の体はそこから敵のかくれている暗がりへ向って一躍した。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "行き交いに、武蔵が出た後を訪ねたところ、隣家の筆職人の女房が、常々、武蔵の身辺に、案じられる節のあったことや、きょう侍の使者が見えたことなど――つぶさに聞かせてくれたので、　さては。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ヘエ、例のお客様へ届いた飛脚で」「どれ」いや応なく取って見ると、桐油紙ぐるみ、上に唐草銀五郎様、出し人の名は裏に小さく「行き交いの女より」としてあった。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は明けて、川ノ辻には毎日の櫓音が、今日も変りなく行き交いしていた。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "此人と右衛門との間には、何様もなみならぬ心のゆきかいが有ったかと見ゆるのである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑司ヶ谷心中と世間にうたわれて、庄司の家から程遠くない寺内にお早と勝次郎とが葬られた後、しぐれ雲のゆきかいする寒い日が幾日もつづいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "うたわれている妻なるひとが、どんなにまめやかであり、自然なこころもちの婦人であるかということや、独特の夫妻としてのつながりのうちに、微妙な情愛のゆきかいのあることなどが、しみじみと感じとられます。",
              "citation": {
                "source": "歌集『仰日』の著者に",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "賑かな馬車のゆきかい。",
              "citation": {
                "source": "大正女流俳句の近代的特色",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "日々を生きている伸子の感興は、耳目にふれる雑多な印象と心におこるその反響との間をただ活溌にゆきかいしているばかりだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近は父というものについても伸子の心にこれまでとちがった判断が加えられて来ていたけれども、まだ伸子は仲のいい父娘としての心のゆきかいを信じていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子が外国へ出発するというだけでさえ人のゆきかいで廊下が鳴るようだった情景を思って、伸子は枕の上でほほえんだ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか変通自在な表現と、お互のわかりあいが出来て、自然の様々な景観の物語などのうちにも、夫と妻との微妙なゆきかいがこめられるようになっているのだった。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「愛情は変通自在なんですもの、本当にどうにだってなるんですもの」　愛するということにきまった形しかないものなら、重吉とひろ子とは、どうやって十二年の間、夫婦のゆきかいを保って来られただろう。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の歌よみは夢の通い路というような表現をもっていたけれど、それはそんな限られた幅の上でのゆきかいではないと思えるのよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
