        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その場を張り守っていた河神は猶予なく姿を掴む。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに恐しき相談一決して、得三は猶予なく、お藤の帯に手を懸けぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の後には、帯も裳もしどけなく、脛も露出に立ったるお葉の艶なる姿が見えたので、重太郎は山猿のような笑い声を出して、猶予なく其前にひらりと飛んで行った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一条の綱を力として猶予なくするすると降りて行くと、彼は中腹の稍扁平い岩石の上に立って、先ず彼の安行の死骸を発見した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は猶予なく返事した。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし行人で二人の姿を見て佇む様子に動くこゝろがあるらしいと見て取れば彼等は、乞食のカンで察して猶予なく歩み寄り、「一銭頂戴な」と掌を差出すのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この水の深いのに感心なことと思いつつ、予は猶予なくその郵便をとりに降りる。",
              "citation": {
                "source": "水籠",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七は猶予なく飛び出して、その女中の腕をつかんで座敷へぐいぐいと引き摺り込んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "山祝いの夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてにもならないことをあてにしているうちに、時は猶予なくたってゆく。",
              "citation": {
                "source": "蟹満寺縁起",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隙をみて、かれは猶予なく飛びかかって敵の真っ向をうち砕くのである。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の中でも水の底でも猶予なく飛び込まなければならない。",
              "citation": {
                "source": "鐘ヶ淵",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は猶予なく、決心した。",
              "citation": {
                "source": "寒の夜晴れ",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこの上は、猶予なく警察へ報せなければならない。",
              "citation": {
                "source": "寒の夜晴れ",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "千枝松は鉈を手にして猶予なく木立ちの間をくぐって行こうとするのを翁はまた引き止めた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑紫育ちの熊武はまさしく彼女を魔性の者と見て、猶予なく鉞を取り直して縁のあがり段に片足踏みかけると、その一刹那である。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイスネルのように戦線にこそ立たなかったが、ソヴェト同盟の新社会建設の文化的事業の中で、一刻の猶予なく活動しているうちに、生活は充実し、見聞と観察とは深まり、小説を書かずにいられないような心持になって来た。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "普段から白眼んでいる市内外の｜悪の巣窟へは猶予なく警官隊が踏み込んだ。",
              "citation": {
                "source": "チャアリイは何処にいる",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "門番は猶予なく潜門をあけて二人の少年を入れた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田孝平氏の財政論にも「人民は給料と費用を出して政府を雇い政をなさしむるものなり」などの語ありてすこぶる自由的論旨を猶予なく発揮したり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由論派は猶予なく自由を唱えて政府の干渉を排斥し、猶予なく平等を唱えて衆民の思想を喚起せり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼貧富智愚によりて権利に差なきを説きもって普通選挙を主張せり、彼また貴賤老少によりて意向に別あるを排しもって一局議院を主張せり、彼自由の文字を尊重して干渉保護の語を忌むことは他の論派よりもはなはだ深し、ゆえに実際の利害いかんを問わずいやしくも干渉政略または保護貿易の類をも猶予なく排したるがごとし。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの方は、隣りの県の知事から来た報告で、その筋の追跡を免れて逃亡中の強盗犯人があるから、もし貴県に、身分証明書及び旅券を所持せざる不審人物が姿を見せたら、猶予なく逮捕して戴きたいというのであった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は猶予なく自動車に飛び乗った。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は猶予なく三尺ばかりの亜鉛壁をヒラリと飛び越すと、恰も係りの者であるかのように落ち着いた態度で、馬をいじり初めた。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に第六感が煌々と、サーチライトを見るように輝き出して、事件の焦点を照し出したり、行くべき方向を示したりするから、それに依って猶予なく敏速な活動を開始する事が出来る。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし今すぐただの願望だけでラスコーリニコフをなきものにすることができたら、ルージンはゆうよなくそれを実行したにちがいない。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はただゆうよなく寸時も早く、そこでは何がどうなっているかを知るのが、必要なのであった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "特にゆうよなく闡明を要するある種の緊急な事実が、かくべつ彼の心に重くのしかかった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、何かゆうよなく解決を要求しているものがあったけれど、それは考えに表わすことも、ことばに伝えることもできないものだった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
