        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いやに熱苦しい、南風がなお天候の不穏を示し、生赤い夕焼け雲の色もなんとなく物すごい。",
              "citation": {
                "source": "水籠",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄藍のやや低い富士、小さい焔のような夕焼け雲一つ二つ。",
              "citation": {
                "source": "金色の秋の暮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く見ると、その赤々とした紫が一続きに見えて、夕焼け雲がおりて居るやうに思はれる。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く見ると、その赤々とした紫が一続きに見えて、夕焼け雲がおりて居るように思われる。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議なことは、いまでもあの最後の日に見た、美しい夕焼け雲の姿が、ありありと目に残っています。",
              "citation": {
                "source": "夕雲",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋が小さいので、中に坐っていても、その高い空に夕焼け雲のたなびいているのを、眺めることができた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄昏の街が、その夕焼け雲のために、いっとき華やかに明るく、家も人も影をなくして、夢幻的なけしきをあらわしていた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "声をあわせて唱歌を歌ったり、口笛を吹いたり、そのほおは夕焼け雲にてりはえて、つやつやと希望の色にかがやいていました。",
              "citation": {
                "source": "大金塊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "昌一君がその時庭へ出たのは、まっかな夕焼け雲が美しかったからです。",
              "citation": {
                "source": "青銅の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕焼け雲に、黒い帆の翼を張りきって、船は潮路を豊前の小倉へ立った。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
