[
  {
    "uuid": "3946a047-1677-58d3-aae3-ead77bc566b0",
    "entry": "誘導",
    "reading": {
      "primary": "ゆうどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
