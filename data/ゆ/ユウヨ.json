        "動詞-サ変",
        "動詞-他動詞",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "postponement",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その場を張り守っていた河神は猶予なく姿を掴む。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまで我慢するものです」　けれども姫は自分の云い出したすがすがしい計画から誘惑され、身体がむずがゆくなって一刻の猶予もなく河水に浸らねば居られぬ気持ちにせき立てられるのでした。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶予自身の如きは、幸に家庭の不快など経験したことがないので、家庭の問題などは、主人の心持一つで、無造作に解決せらるるものと信じて居った。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅に二円金を携えて出京した予は、一日も猶予して居られぬ、直に労働者となった。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この社長室に父が出現するにはまだ一時間の猶予があったので、韻律を踏むように、私は彼女に近づくと、「――君は不景気に処する道を知っていますか？",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "初五が短いためにそのあとでちょっとした休止の気味があって内省と玩味の余裕を与え、次に来るものへの予想を発酵させるだけの猶予を可能にする。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "年紀は若し、お前様、私は真赤になった、手に汲んだ川の水を飲みかねて猶予っているとね。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　ここで百姓に別れてその川の石の上を行こうとしたがふと猶予ったのは売薬の身の上で。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）という時たちまち犯すべからざる者になったから、私は口をつぐむと、婦人は、匙を投げて衣の塵を払うている馬の前足の下に小さな親仁を見向いて、（しょうがないねえ、）といいながら、かなぐるようにして、その細帯を解きかけた、片端が土へ引こうとするのを、掻取ってちょいと猶予う。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処にまた立留って、少時猶予っていたのである。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と手を引張ると、猶予いながら、とぼとぼと畳に空足を踏んで、板の間へ出た。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　看護員は傾聴して、深くその言を味いつつ、黙然として身動きだもせず、やや猶予いて言わざりき。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　神崎は猶予らわで、「さよう、自分は看護員です。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と出しながら、ふと猶予つたのは、手が一つ、自分の他に、柔かく持添へて居るやうだつたからである。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや／＼……」　園は一寸猶予つた。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と猶予いながら、笹ッ葉の竹棹を、素直に支いた下に、鬢のほつれに手を当てて、おくれを掻いた若い妓の姿は、願の糸を掛けた状に、七夕らしく美しい。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、神の御心じゃ、猶予うなよ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　勇美子はこういって、猶予って四辺を見たが、手をその頬の辺へ齎らして唇を指に触れて、嫣然として微笑むと斉しく、指環を抜き取った。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝太郎は、さすがに玉のような美しい手を握って、猶予わず、売物の銀流の粉の包、お験しの真鍮板、水入、絹の切などを並べた女の膝の前に真直に出した。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」お雪はふとその答に支えたが、婆さんはかえって猶予わない。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お兼は抱着くがごとくにして、山腹の土に手をかけながら、体を横たえ、顔を斜にして差覗いて猶予った。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもう一瞬も猶予はならない。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "女がひすてりつくにいきり立つてくると、殆ど押へかかへも出来なくなることは之れまでも度度見て居たことであるから、激しい発作の来ないうちに何とか云つてなだめなきやならないと思つたが、女はほんの僅かな猶予をさへ惜むかのやうにじりじりと男につめよつた。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶予をしちゃ不可ません。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに恐しき相談一決して、得三は猶予なく、お藤の帯に手を懸けぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふとすると先刻遁失せた悪漢が小戻して、奪い取ったかも知れぬ、猶予する処でない。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速探し出しますで、今夜の処は何分にも御猶予を願いたい。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれもこれも一瞬時、得三は眼血走り、髪逆立ちて駈込つ、猶予う色無く柱に凭れる被を被りし人形に、斬つけ突つけ、狂気のごとく、愉快、愉快。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（じゃむこう）といえる飼犬は、この用をすべく馴らされたれば、猶予う色無く頭を回らし、頷くごとくに尾を掉りて、見返りもせで馳走去りぬ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言懸けて少し猶予い「あのの、家の阿魔に犬の皮をの。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
