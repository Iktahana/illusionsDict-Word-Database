[
  {
    "uuid": "9c12f5d4-ad8e-5120-a9cf-e4d554a52afa",
    "entry": "猶予",
    "reading": {
      "primary": "ゆうよ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
