    "definitions": [
      {
        "index": 1,
        "gloss": "to shake",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」眠りを揺さぶるような強い調子だ。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "寮の屋上から撮った、明け方の周囲の光景が、いきなり慶一の心を揺さぶる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "……突如、生の歓喜が、それは電撃の如くこの女を襲い、疾風よりも烈しくこの女を揺さぶる。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "突如、生の歓喜が、それは電撃の如くこの女を襲ひ、疾風よりも烈しくこの女を揺さぶる。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "（これは今でも遠くから僕を揺さぶる不思議な人間像なのだが、……）はじめて僕が彼と知りあひになつた頃、既にその人は家が没落して殆ど無一文で巷に投出されてゐた。",
              "citation": {
                "source": "火の子供",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の席のところの窓は木の窓だったので外の様子は見えなかったが、間もなく外からガタガタと揺さぶる音がきこえ、忽ちそれは乱打となり、あけろ、あけろ、あけろ、と叫喚しだした。",
              "citation": {
                "source": "西南北東",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹きすさぶ暴風が通りを吹き抜け、店の看板をキーキーと揺さぶるか、高い鋼鉄製のランプを揺らす音以外は、ほとんど音もしませんでした。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとでチャンの固い信条を大いに揺さぶることになるが、折り畳みナイフと、足のつかない拳銃をやると、デンが弱みにつけ込んだ。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると大歓声が上がり、すべてを震わせ揺さぶるので、フィールデンも震えて双眼鏡が見えなくなった。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが今そうだ」　独り言中、強烈な風が家を揺さぶるさまは理不尽な暴力だ。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            },
            {
              "text": "お金しか関心のない大衆を揺さぶるのはとても簡単なことだった。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            },
            {
              "text": "その律気な退屈さが、たまらなく、わたしの平和を揺さぶるのだ。",
              "citation": {
                "source": "雪",
                "author": "高祖保",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤兒をおぶつて、それをゆさぶるやうな足取をして、麥の芽をふんで居る母親達の姿が哀れに見えた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤子をおぶって、それをゆさぶるような足取りをして、麦の芽をふんでいる母親たちの姿が哀れに見えた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねずみが動いたりするたびに妙な叫び声を出してはからだをゆさぶるばかりである。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは焦れて邪險に與吉をゆさぶることもあつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日のやうに風がやつて来て、騒がしく落葉樹を吹きゆさぶると、黄葉もみぢ葉は次から次へともろくも散つていつた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたい梵音が大空の月の壁から川床の小石までゆさぶるので、その身につけた鱗の皮が一つ一つ、はららけて落ちるまでおののき上って来たのだろう。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は腕をのばして彼の膝をゆさぶる。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鬼が私をゆさぶる。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その感嘆は、今も、人類の魂をゆさぶるにじゅうぶんな、率直なものをもっているはずである。",
              "citation": {
                "source": "脱出と回帰",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリャ、リャ、リャ、リャ……」　ゆさぶるうちに大地がメリメリとさけてきた。",
              "citation": {
                "source": "曾我の暴れん坊",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆさぶる膝の手応へは太根を張つた大松の木の瘤かと思はれるばかり、なかなか微動を揺りだすことも絶望に見える有様であつた。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょッと、はなれて、くれませんか」　片彦は、ぬき足、さし足、近づいて、花田を、ゆさぶる。",
              "citation": {
                "source": "カストリ社事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お山荒れは、ふたたび勢いを盛り返して、雨と、風と、屋鳴りと――それのなかに、頭巾をゆさぶる出羽守の狂笑が、さながら猿のそれのように、高く、鋭く、つづいた。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "懲りずに叩いて、ゆさぶるうちに、朽ちた扉は倒れました。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月のある日、爽やかな宵、八が來さうな晩でしたが、お仕着せの晩酌を絞つて、これから飯にしようといふ頃になつて、漸く個性的な馬鹿笑ひが、路地の闇をゆさぶるのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "苫三七の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてその一方の鳥が羽をゆさぶる形は、やはり薩摩の海辺で見た磯鵯の挙動と、非常によく似て居たのである。",
              "citation": {
                "source": "家を持つといふこと",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆさぶる膝の手応えは太根を張った大松の木の瘤かと思われるばかり、なかなか微動を揺りだすことも絶望に見える有様であった。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、先生は、ひょいと帽子の上から次郎の頭に手をあて、それをゆさぶるようにしながら、言った。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
