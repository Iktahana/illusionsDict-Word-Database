    "definitions": [
      {
        "index": 1,
        "gloss": "(taking a) bath",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
