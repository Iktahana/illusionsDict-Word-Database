[
  {
    "uuid": "caed0643-3f8f-5772-9fb9-be0ce9f251c8",
    "entry": "優劣",
    "reading": {
      "primary": "ゆうれつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
