    "definitions": [
      {
        "index": 1,
        "gloss": "since the dawn of history",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
