[
  {
    "uuid": "bc5cb150-105c-5730-acbd-d09dfa2d6d46",
    "entry": "勇名",
    "reading": {
      "primary": "ゆうめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
