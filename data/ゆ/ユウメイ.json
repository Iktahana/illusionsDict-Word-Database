      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fame (for one's bravery)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "団九郎が、Ｔ「心配致すな　亭主　此の御方は誰あろう」　と武蔵を指さして、Ｔ「新免二刀流の開祖　宮本武蔵先生」　と言って、Ｔ「拙者は先生の高弟で　同じく新免二刀流の　達人」　と威張って、Ｔ「勇名天下に響き渡った　早水団九郎」　亭主も感心した。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は字がうまいので、天下に勇名であつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後は秀吉の旗の下に就いて段々と武功を積んだが、特に九州攻めには、堀秀政の攻めあぐんだ巌石の城に熊井越中守を攻め伏せて勇名を轟かした。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに比べると、徳川方の連中は、金持喧嘩せずの方で、家康への義理戦で、打算戦であるだけに、大阪方の勇名ばかりが残ることになったのだろう。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏康は川越の夜戦に十倍の敵を破り勇名を轟かした名将で、向う創のことを氏康創と云われた位の男である。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "アドミラル・トーゴーの勇名が世界に轟いたのは、それらの内的外的の特殊な時代的特徴の濃い諸要点の結合の結果であった。",
              "citation": {
                "source": "花のたより",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの勇名は乃木大将の耳にもはいって、敵ながらも天晴とあって将軍から感状をはじめ色々の物を贈られたのを、彼はいまだに大切に保存しているという。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかくの勇名が泣こうというものである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "七年戦争に勇名を馳せた将軍。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――長い間、馬来やビルマ方面に陸軍の参謀としても勇名をとゞろかした人物でね。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "書かれざる作品豊島与志雄　横須賀の海岸に陸から橋伝いに繋ぎとめられ、僅かに記念物として保存されている軍艦三笠を、遠くから望見した時、私は、日本海大海戦に勇名を馳せた軍艦のなれのはてに、一種の感懐を禁じ得なかった。",
              "citation": {
                "source": "書かれざる作品",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "『千種』『吉野』『八島』らはなくなったが、その勇名は、いつまでも国史の花とかがやくであろう。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇名一代を震撼したる旭日将軍もかくして、日一日より死を見るの近きにすゝめり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は小説で云われているような享保年間の人物では無く実に豊臣の晩年から徳川時代の初期にかけて、内外に勇名を轟かせた所の、堂々たる一個の武人なのである。",
              "citation": {
                "source": "赤格子九郎右衛門",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガランドウは今では十一人の子持ちであるが、当時は八人の子持ちで、小田原きっての貧乏で勇名をとどろかしていたのである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵新田のパンパン街というものは、私の勇名なりひびいているところで、古い子で私を知らぬパンパンはいない。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時以来浅草に勇名なりとどろき、私の酒の酔いッぷりに例をとって小安吾、中安吾、大安吾という言葉が行われたそうであった。",
              "citation": {
                "source": "九段",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔っ払って、他の酔っ払いの為し得ない放れ業は数々これを行い、諸方に勇名をとどろかしたものであるが、こういうバカげた大勘定をつきつけられたことはない。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時誰も押入って賊を搦め取ろうというものは一人もなかったのですが、忠清ただ一人立ち向い、一人を討ち取り、残る一人を搦めとって、大いに勇名をはせたものでした。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「阿倍川町に住んでゐる、これも浪人者で高木勇名といふのだ」「へエ？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "父の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "城彈三郎氏は何んかの事で高木勇名といふのと怨を構へ、高木の讒言で浪人したが、間もなく高木の方も祿を捨てゝ、江戸へ來たといふことだ」「――」「不思議な廻り合せで、お互に遠くないところに住んでゐることがわかつたが、城彈三郎氏はひどく高木勇名を怨んで、出逢ひ次第討ち果すと言つてゐたよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "父の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も高木勇名といふ男は、一年ほど前から大病で、身動きも出來ないといふことだ」「すると？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "父の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「高木勇名の方で、機先を制して城彈三郎を討つたといふ疑ひは充分にあるわけだが、大病人が平右衞門町まで行くのはをかしい」　戸倉十兵衞はさう言つて人の惡さうな冷たい笑を片頬に漂はせるのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "父の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "拔荷でも扱はなきやあんな品がふんだんに手に入るわけは無いよ」「それがどんな事になるでせう、親分」「俺にも判らないが、城彈三郎が怨んでゐたといふ、高木勇名といふ人に逢つて見よう」　其處から阿倍川町へ伸して、高木勇名と訊くと直ぐわかりました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "父の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "むさ苦しいところだが――」　破れた唐紙一重を隔てて、主人の勇名は聲を掛けました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "父の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "御病氣のところを飛んだ御邪魔をしますが、實は福井町の城彈三郎樣が昨夜平右衞門町で殺されましたので」「えツ」　主人――高木勇名の驚きは大袈裟でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "父の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "――天罰だな」　高木勇名は疲れ果てた樣子で、ガクリと枕の上に頬を落しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "父の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んの丈夫でさへあれば、城彈三郎如きに後ろを見せる拙者ではないが――」　高木勇名はさう言ひかけて笑ふのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "父の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、緒方洪庵先生といえば、大阪でもゆうめいな医者ですよ。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、そのころ、ふるい考えをもつ人が、西洋のあたらしい学問をしているゆうめいな人をころすことがはやっていたからです。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
