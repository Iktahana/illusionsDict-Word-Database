    },
    "definitions": [
      {
        "index": 1,
        "gloss": "having a dream",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかも宿命的な詩人の悲願は、その有り得べからざる夢の国を、生涯夢見続けることの熱情にある。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢見ることによって生きた詩人等は、また夢見ることの中で死ぬのであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句の咏嘆しているものは、時間の遠い彼岸における、心の故郷に対する追懐であり、春の長閑な日和の中で、夢見心地に聴く子守唄の思い出である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句もやはり、そうした主観的郷愁の一咏嘆であるが、特に心の詩情を動かしやすく、ロマンチックで夢見がちな初夏の季節を、更衣の季題で捉えたところに、句の表現的意義が存するのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのやうな内容のお手紙を受取り、私はへんな、夢見心地に似たものを感じた。",
              "citation": {
                "source": "同じ星",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼がその夢見るような眼をして、そういう処をさまよい歩いている間に、どんな活動が彼の脳裡に起っているかという事は誰にも分らない。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう、それは確かに、それらの半ば夢見心地の、ぼんやりとした器具類にとつては、恐ろしい一時期であつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、もし少し澁味のかかつた年頃にでもなつたら、ちつと大袈裟だが、俯仰天地に恥ぢざるよいものが一つや二つは書けるだらうと夢見てゐる。",
              "citation": {
                "source": "自分のこと",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　奧さんは黒未勝ちな、若々しいひとみを夢見るやうに見張りながら、晴れやかにつぶやいた。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と謂懸けて、夢見るごとき対手の顔を、海野はじっと瞻りつつ、嘲み笑いて、声太く、「うむ、得難い豪傑だ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで夢見たやうな事ではありますまいか。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかまぶたは閉ぢるのぢゃ、昼の景色を夢見るぢゃ、からだは枝に留まれど、心はなほも飛びめぐる、たのしく甘いつかれの夢の光の中ぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかまぶたは閉じるのじゃ、昼の景色を夢見るじゃ、からだは枝に留まれど、心はなおも飛びめぐる、たのしく甘いつかれの夢の光の中じゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手を膝に上げたまま夢に夢見る呆れ顔になった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この音の流れて行く末にシャトーのバルコニーが現われて夢見るような姫君のやるせない歌の中にこの同じ主題が繰り返さるる。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　袖を僅に濡れたる顔、夢見るように恍惚と、朝ぼらけなる酔芙蓉、色をさました涙の雨も、露に宿ってあわれである。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……日を隔てたカアテンの裡なる白晝に、花園の夢見る如き、男の顏を凝と見て、「恐入りました。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とて、年月を經る夜毎々々、殿は美しき夢見ておはしぬ。",
              "citation": {
                "source": "妙齡",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と少年とは夢に夢見る心地。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と武村兵曹とは夢に夢見る心地。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「凶事がある前兆じゃよ、昨夜は夢見が悪かった。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、嘘のような話です――遥に蘆の湖を泳ぐ馬が、ここへ映ったと思ったとしてもよし、軍書、合戦記の昔をそのまま幻に視たとしても、どっち道夢見たように、瞬間、馬だと思ったのは事実です。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうまで、お憧れなさるもの、ちょっと一目お目にかかって、お聞かせ申とうござんすけれど、今顔をお見せ申しますと、お慕いなさいます御心から、前後も忘れて夢見るように、袖に搦んで手に縋り、胸に額を押当てて、母よ、姉よ、とおっしゃいますもの。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しき夢見るお方、」　あれ、かしこに母君｜在ますぞや。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えることのない、夢見ることのない、はてしなくつづくやみの夜だけが、お姫さまを待っているのでした。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は甲板の籐椅子に寐ころび、さうして夢見心地のする葉蘭の影に、いつも香氣の高いまにら煙草をくはへて居た。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄蔵は話に深くひきこまれてゐたので、終つてもしばらくは夢見るやうな眼で、お坊さんの前に立つてゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも軽蔑した顔をして冷淡につけつけものをいい、それでいて自分に肌目のこまかい、しなやかで寂しくも調子の高い、文字では書けない若い詩を夢見させて呉れる不思議な存在なのだ。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏手柑の青む南国薫る日の光なよらに身をめぐりほめく物の香、鳥うたひ、天もゆめみぬ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝がもとに両手をあてて眼病の少女はゆめみ、欝金香くゆれるかげに忘られし人もささやく、げに白き椅子の感触はふたつなき夢のさかひに、官能の甘き頸を捲きしむる悲愁の腕に似たり。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
