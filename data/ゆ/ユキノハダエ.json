    "definitions": [
      {
        "index": 1,
        "gloss": "perfectly white skin (woman)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
