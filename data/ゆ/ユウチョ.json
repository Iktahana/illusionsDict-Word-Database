        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この騒ぎのなかに川上なんぞゆうちょうなまねして捜すとんまがありますものかい？",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、たとい非役であったにしても、このぷきみな怪談を耳に入れて、いまさら出仕などゆうちょうなまねが、なぜにしていられましょうぞ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をゆうちょうなまねをしているんですかよ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうばかりゃゆうちょうに構えている場合じゃねえんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それにしてもゆうちょうな敵ではないか。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしかすると、六部の巣も、あれかもしれぬぞ……」　と勇みたって近づいていくと、はたして、くずれかけた文殊閣の石段のうえに、白衣の六部が、月でもながめているのか、ゆうちょうな顔をして腰かけている。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
