[
  {
    "uuid": "e65c2bd1-4305-5e63-b6b1-9c779e5e80ea",
    "entry": "故",
    "reading": {
      "primary": "ゆえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
