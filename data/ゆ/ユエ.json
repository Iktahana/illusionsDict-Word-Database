      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "reason",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして明日の今頃は　　長の年月見馴れてる　　故郷の土をば見てゐるのですさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら詩性に乏しい現今は、兎角、あまりに貧弱なモチーフを取上げることから、多くの詩が妙な複雑に堕しがちである。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分その何れかであり又、何れかの取合せの故でもあらう。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああかくてもこの故郷に育ちて父母のめぐみ戀しやと歌ふなり。",
              "citation": {
                "source": "秋日行語",
                "author": "〔菊もうららに〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "まひる利根川のほとりを歩めば、二人歩めばしばなくつぐみ、つぐみの鳴くに感じたるわが友のしんじつは尚深けれども、いまもわが身の身うちよりもえいづる、永日の嘆きはいやさらにときがたし、まことに故郷の春はさびしく、ここらへて山際の雪消ゆるを見ず。",
              "citation": {
                "source": "利根川の岸邊より",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、わが故郷にあるの日、終日怒りうゑを感じ、手を高く蒼天のうへに伸ぶ。",
              "citation": {
                "source": "立秋",
                "author": "――大沼竹太郎氏ニ捧グル詩――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは利根川、その氾濫のながめいちじるく、青空に桑の葉光り、さんらんとして遠き山里に愁をひたす、あはれ、あはれ、われの故郷にあなれば、この眺望のいたましさ。",
              "citation": {
                "source": "厩",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "看痾宮沢賢治七月はさやに来れど故しらに人はなほ疾み日過ぎ来し白雲の野はさびしくも掃き浄めらる",
              "citation": {
                "source": "看痾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ひ得てゐない所もあるかと思ふが、何分締切間際の事故、何分の御察しを願ふ。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "新体詩様式は、未だ十分の発達を示してはゐないけれども、人々はその案外に困難なる故を以てかどうか、何時の間にか退却し、昨今再び立向つてゐる状勢だが、猶極めて怠惰な立向ひ方と云へよう。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何故だか萩原氏を思ふたびに、次のポオロの言葉をくちずさみたくなる。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故といつて私の声は泣くやうだつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際文壇に出ることが容易になつた此の頃は、さういつた文学青年も少くないことで、一知半解の故に却て元気がいいといつた風の元気が、本当の元気と間違へられる風景は、毎日のやうに見受けられることである）。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "誤解されたことを忍んで別れるより仕方もなくなると、忍んだ故にもう一段誤解されるのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら、個性といふものが、独自の働きをするものであるからは、対人圏に於て、或ひは人中に於て、所謂「パツとしたもの」、則ち雄弁なものではないからだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら、作品は一つの存在物、従つて一つの姿を持たねばならず、意志といふものから姿は出て来ぬものであるから。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら芸術といふものは其処で休むためのものであつて、其処で生産しようといふやうなものではないからである。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりは暗くなる時刻が来る少し前あたりから人に会ふやうな機会になつてゐたことが不運みたいなもんで、それ故何もかも神秘なやうなものでもある。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思つたら何か知らぬが子供の時に聞き覚えた、故郷の子供等の間で唱はれる、次の文句が浮んで来た。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜はほのじろく明けんとす僕はここに去りまた新しい汽車に乘つて行かうよ僕の孤獨なふるい故郷へ。",
              "citation": {
                "source": "別れ",
                "author": "旅の記念として、室生犀星に",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故ならば『愛の詩集』を懐中にした彼の現実には、あまりに重厚で静謐な中年者の姿を思はせるものがあつたからである。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めからボヘミアンであったヘルンは、晩年においてもなおボヘミアンであり、永遠に故郷を持たない浦島だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故ある人々は、ヘルンがもし悪妻をめとり、意地悪の姑等と同居したら、彼の神国日本観は、おそらく顛倒した結果になったろうと言っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故多くのヘルンの著作は、書物から得た材料ではなく、その妻によって主観的に飜案化され、創作化されたものを、さらにまたヘルンが詩文学化したものであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故にヘルンもまた、自分の著作は皆妻の功績によるものだといって、深く夫人の労に感謝し、ある著述のごときは、実際に夫人の名で出版しようとしたほどであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその故国の友人に手紙を書き、日本での生活｜実況を次のように詳述している。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故彼は、動物を始め植物に至るまで、すべて生物を虐めたり殺したりすることを非常に叱った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　何故に芥川龍之介は自殺したか？",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故人の多數の友人たちは、種々の異つた見解から、夫々の意見を語るだらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故に彼が、あの文壇の大家芥川龍之介君が、私の如き非才無名の一詩人に對して、特別の好意と友情とを――時としては過分の敬意さへも――寄せられたかといふことは、今にして始めて了解出來たのである。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
