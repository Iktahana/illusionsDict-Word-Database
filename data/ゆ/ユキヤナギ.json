        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小手鞠、雪柳は、わたくしは夏の花よりも秋の枯葉を好む。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "連翹の花の垣（三井の前の美しい新緑がそうだ）、桃の花の白と紅、雪柳の白い花、蕾の八重桜――北風にふかれるところにある故幹がっちり枝こんで立派だ。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "午の前後はまた無闇と暖で、急に梅が咲き、雪柳が青く芽をふいた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫の箱根つゝじ、雪柳、紅白の椿、皆真盛り。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近巷の園林に桃李、木瓜、雪柳、小米櫻、其他百花次第に爛漫たらむとす。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は毎朝、躑躅や石蘭や雪柳が崖をなしている坂道を駈けまろんでゆくぼくを家の門から見送って「……まるで鉄砲玉みたい」と、ほほ笑んでいた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
