    "definitions": [
      {
        "index": 1,
        "gloss": "to shake",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "嵩増す潮は、さし口を挟んで、川べりの蘆の根を揺すぶる、……ゆらゆら揺すぶる。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そして瀕死の病人を揺すぶるような音。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "老年に到って、社会生活の溌剌たる摩擦が身辺から次第に遠ざかり、彼に対する敬意から、誰も彼の主観的な冥想を妨げ揺すぶることがなくなった時代、ゲーテの偉大な横溢性においてさえ、自然はその芸術の間に観念化されて表現されはじめている。",
              "citation": {
                "source": "藤村の文学にうつる自然",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お茶ばつかしでは飢ゑは紛れないな」　彼は重さうに頭を揺すぶる。",
              "citation": {
                "source": "飢ゑ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、海気に焼け切った鉤鼻を弟に向けて、髻をゆるやかに揺すぶるのだった。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず肩を揺すぶるものもあった。",
              "citation": {
                "source": "夢",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐柄木は身構えて調子をとり、ゆさりゆさりと揺すぶる。",
              "citation": {
                "source": "いのちの初夜",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "狼たちは、しかし、此の太い杉の木を揺すぶるほどの力がない。",
              "citation": {
                "source": "カルナツクの夏の夕",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて爬虫館の柱時計がボーン、ボーンと、あたりの壁を揺すぶるように午後十時を打ちはじめた。",
              "citation": {
                "source": "爬虫館事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "繁吹をあげてザザザザーッ……と頭を揺すぶる竹藪の音が、激浪のやうに荒れ狂ふ裏手一帯の劇しい起伏を未だ一杯に温気の籠めた朝の部屋に歴々と描き出して見せてしまふ、かと思ふと、突然硝子を射抜くやうな太く真つ直な雨脚がヂヂヂヂヂイーと一頻り窓に噛みつくのであつた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "――と思うと、その瞬間に、あたかも巨人の手をもって揺すぶるように、四方の壁があちらこちらへと揺れ出した。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "貸家",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、負んぶなどして」といいますと、「大木へ蝉が止ったようでしょう」といって揺すぶるので、「大木へ蝉、大木へ蝉」といっては取りつきます。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "消えかかった火鉢に炭火をオコしながら、ときどきガタガタと軒を揺すぶる風の音や、近くの部落あたりかららしい二番鶏の声をきいていた。",
              "citation": {
                "source": "冬枯れ",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワーリカは頭を揺りかごのふちにもたせ、なんとか眠気に勝とうとして、胴なか全体で揺すぶるけれど、眼はやっぱり自然にくっついて、頭が重たい。",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "合爾合の肩を掴んで揺すぶるが、はっと気づいてその手を放す。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどおめえのような――」　話しているうちに、日本一太郎はだんだん興奮してきて、がくがくあせり出しながら、お駒の肘をとって揺すぶるようにするのだ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく、この鎧櫃はひいて来た奴の間違えでお手へはいったんで――どうぞお返しを願います」「わしは何も受け取った記憶はないぞ」　侍がからだを揺すぶるのが、わざと嬌態をつくるとしか見えない、威嚇のきかないことおびただしい。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、あの花環に埋まつた舞台の中央で、嫣然と胸をそらし、豪奢な振袖を重たげに左右に揺すぶる今夜の歌手、鈴原兼子嬢の苦衷に、千種は人事ならず同情した。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の下では、犬が蚤にせめ立てられて、それを追ふために身を揺すぶると、その度にゆれる鎖の音が、がちやがちやと彼に聞えて来た。",
              "citation": {
                "source": "田園の憂欝",
                "author": "或は病める薔薇",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、弥助が私を殺すなら理窟はわかりますが、お静を女房にした私が、何が不足で弥助なんかを殺すもんですか」　そう言いながら平次は手摺から腹ん這いになって、庇へ手を掛けて揺すぶると、猛烈な埃をあげて、朽ちた板が、ポコリと下に落ちてしまいました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "永楽銭の謎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうした」　重ねて平次、お静の肩を揺すぶるようにすると、夢心地のお静は、「外から、――外から突かれました」　黒い瞳に、初めてサッと恐怖の色が浮びました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "永楽銭の謎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの女は幾つ身上をフイにして、幾人の人間を殺しているか判りゃしません、――一番堅そうな男に喰い付いて、自分の思う通りになるまで、手をかえ品をかえ揺すぶるんだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "活き仏",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩を揺すぶると、母の首は、わしの肩から力なくぶら下がった。",
              "citation": {
                "source": "茶漬三略",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "マフチャズは烈しい勢いで、咆哮しながら、檻も破れんばかりにドシンドシンと身体をぶち付けながら、鉄棒を掴んで揺すぶる。",
              "citation": {
                "source": "令嬢エミーラの日記",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁円はあまりのことに、「うむむ……」ややしばらく唸いているばかりであったが、「おいっ」いきなり四郎の肩へ手をかけ、揺すぶるようにしていった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お通、お通」　身を揺すぶると、お通は、われにかえったが、途端に、ふたたび体を床に転ばせて、「痛い。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もしおまえさんたら」　軽く肩を持って、揺すぶると、「なに」　むくりと、寝ていた男は、起き上がった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「白楊の枝の上で体をゆすぶる」セイレネスの妖態や「サチロス仲間に気に入る」バックス祭尼の狂態、すなわち腰部を左右に振って現実の露骨のうちに演ずる西洋流の媚態は、「いき」とは極めて縁遠い。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雪のないとき、ねていると、　西風ゴスケがゆすぶるぞ　ホースケ蜂が巣を食うぞ　トースケひばりが糞ひるぞ。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パー先生は片袖まくり、布巾に薬をいつぱいひたし、かぶとの上からざぶざぶかけて、両手でそれをゆすぶると、兜はすぐにすぱりととれた。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
