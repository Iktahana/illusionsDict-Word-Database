    "definitions": [
      {
        "index": 1,
        "gloss": "orpiment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鞍馬法師は雄黄を鎔いて小瓶に入れ、富子の閨房へ往ってみると、枯木のような角の生えた雪のように白い蛇が三尺あまりの口を開け、紅の舌を吐いて室の中一ぱいになっていた。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "戴先生は間もなく後からやって来たが、手には雄黄を入れた瓶と薬水を入れた瓶を持っていた。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "戴先生は間もなく後から来たが、その手には雄黄を入れた瓶と薬水を入れた瓶を持っていた。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "折り重つて光りの輪を交す大塔――それを※る附屬の建て物、朱と雄黄と緑青の虹がいぶり立つやうに四月に近い山の薄緑を凌ぐ明るさであつた。",
              "citation": {
                "source": "死者の書　續篇（草稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺は、丹も雄黄ももの古りたが、都の寺々にも劣らぬ結界の淨らかさである。",
              "citation": {
                "source": "死者の書　續篇（草稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
