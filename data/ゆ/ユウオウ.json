[
  {
    "uuid": "17961b4f-c3c3-5d9c-850f-4fcbdf309b88",
    "entry": "勇往",
    "reading": {
      "primary": "ゆうおう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
