    "definitions": [
      {
        "index": 1,
        "gloss": "to flicker",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雲が延びると、裾野のぼやけた緑は、水底に揺らめく青草の波になった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉の響きは、ぶるぶると、お妙の細い靴の尖に伝わって、揺らめく胸に、地図の大西洋の波が煽る。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいつつもあればだ、ほぼ疑いなく、その人物は火のついた獣脂を始終取り扱っている――夜中、上の階へあがるとき、片手に帽子、もう一方の手に揺らめく蝋燭。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の低い大机があちこちにあり、上にはレトルトや試験管、青火揺らめく小型のブンゼン・バーナーなどが散らかっている。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "回教徒の信ずる所に寄りますると、この世からあの世へ行く唯一の道は、狭い、揺らめく橋だといふことでございますが、丁度その橋のやうに美しい虹が霧の上に横はつてゐるのでございます。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "またあの柔かな雛罌粟が壺にささって微風に赤々と揺らめくと、妻はかすかな歎声を洩して眺めていた。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々突っ立った太股の林が揺らめくと、射し込んだ夕日が、魚の波頭で斬りつけた刃のように鱗光を閃めかした。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "処女の波は彼の胸の前で二つに割れると、揺らめく花園のように駘蕩として流れていった。",
              "citation": {
                "source": "街の底",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、ふとどこかのカーテンが揺らめくと、鏡の中から青い微光が漣のように流れて来た。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、園のいちばん端れには、他の樹木とは不釣合いに背の高い白楊が四五本、そのさやさやと揺らめくおのおのの梢に大きな鴉の巣をのせている。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その豪華な船室の揺らめく句は、東野と真紀子の航海の愉しいさまを髣髴させているばかりではなく、その夜の二人の危ささえよく顕した艶麗な作だと矢代は思った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが黒い髪毛をテカテカと二つに分けて、贅沢なものらしい黒茶色の毛皮の外套を着て、その間から揺らめく白金色の逞ましい時計の鎖の前に、細長い、蒼白い、毛ムクジャラの指を揉み合わせつつ、婦人用かと思われる華奢な籐椅子の前に突立っている姿はさながらに魔法か何かを使って現われた西洋の妖怪のように見える。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君は腐った空気の中を、カンテラのふらふらと揺らめく光をたよりに、二階、三階、四階、五階と登って行く。",
              "citation": {
                "source": "青年に訴う",
                "author": "AUX JEUNES GENS",
                "note": "青空文庫"
              }
            },
            {
              "text": "風に揺らめく褐色の天幕の下に寝起きする白色アラビア人の住む国へ行ってみよ。",
              "citation": {
                "source": "狂人日記",
                "author": "ギィ・ドゥ・モオパッサン　Guy de Maupassant",
                "note": "青空文庫"
              }
            },
            {
              "text": "その軽い一点から円い波紋が一面に静にひろがつて、井戸水が揺らめく。",
              "citation": {
                "source": "田園の憂欝",
                "author": "或は病める薔薇",
                "note": "青空文庫"
              }
            },
            {
              "text": "その揺らめく光こそ未知の深淵に沈む前の浅くより鮮明な夢の中で常に老女と小さな毛皮野郎の周りを遊び回っていた種類のものであり、自分以外の目覚めた人物がこんな夢の中の光を見うるなどということは、正気の領域を遥かに逸脱していた。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "微かに揺らめくこの縁に向かって古代の台地が迫り上がり、かつて河だったものの凹んだ影が不規則なリボンのようにその台地を横切っていた。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろと階段の最後の段に足をかけ、硝石だか何かがちりばめられた通路を横切るとだんだんと通路に湿り気が増しはじめ、私の揺らめく松明の光が開けた空間を照らすと、滴る地下水とおびただしい水垢の重なった壁が私の旅路を塞いだのです。",
              "citation": {
                "source": "錬金術師",
                "author": "THE ALCHEMIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の頭の上では悪霊が蜻蛉のように舞っていたが、人面人頭で、残りの部分はほうき星の尾に似て緑の炎を燃やし風に揺らめくかの如く明滅していた。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧騒、揺らめく影、奇怪な形、苦悩、恐怖、哄笑、夢、種々の夢……。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段の窓から覗くと、河の真上になっていて、揺らめく空中にいるがようだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝そべった身体の下には、揺らめく小舟の下には、深い水が感ぜられる。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の蒼白いぼんやりした明るみの中に、樅の重い黒い枝が幽鬼のように揺らめくのが、窓の前に見えていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か黄色いものに包まれているようで、物体が震える有様は、夏の盛りの午後、木々が陽炎に揺らめくみたいだった。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "揺らめく蝋燭の炎が、大食堂の彫刻｜垂木や、豪華な飾り格子を照らし、身じろぎしないルースに当たり、大きな眼がきらめいている。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "揺らめく明かりが花嫁支度に当たると、ルースの姿が石材やオーク材を背景にくっきり浮かび上がった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い崖端から向うの大岩へ、長々と架け渡した釣橋で、――荒らくれた無数の泡沫ばかりが、混沌と躍り狂い、わめき立てる谷水を渡って行けば、針金と柴木の橋桁が、あおられるようにゆらゆら揺らめく。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、緑葉と草と苔と小鳥のため息とやさしい影と揺らめく枝とから成ってる一つの殿堂があり、温和と信仰と誠と希望と憧憬と幻とから成ってる一つの魂があった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝋燭の炎はその風を受けて揺らめく。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "揺らめく暖炉の明かりに、顔が真っ青だ。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
