[
  {
    "uuid": "578326b8-b439-5dc0-88b8-c7af09be54ee",
    "entry": "行き方",
    "reading": {
      "primary": "ゆきがた",
      "alternatives": [
        "いきがた"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(one's) whereabouts",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「だつて此の人は行き方がちがふんぢやないの」　Ｓ子が従兄に言つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮓の冷たい、静物的な感じを捉えた純感覚的な表現であり、近代詩の行き方とも共通している、非常に鮮新味のある俳句である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝来の家や田畑を売り払って株式に手を出すと同じ行き方である。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "末広君の研究の行き方や筋道を見ると色々な優れた特徴がある。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして簡易な解析と手軽な実験によって問題の大きい輪郭を明快に決定するという行き方であったように見える。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "分量を少なく、出来るだけ簡易平明にして、しかも主要な急所を洩れなく、また実に適切な例を使って説明するという行き方であり、また如何なる教科書とも類を異にしたオリジナルなものであったという事は同君の講義を聞いた高弟達の異口同音の証言によって明らかである。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の行き方はどこか共通なところがあった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「手製の粗末な器械を愛したのも畢竟同じ行き方であった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」また母への手紙にもこの講義が「例のタムソン式で、つまり情熱的で、取り止めもなく声を出しながら考えるという行き方」であったと評している。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "断えざる研究と努力の結果であることはその作品の行き方が非常な目まぐるしい速度で変化しつつある事からも想像される。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時自分の感じた事は、その鉛筆画が普通のアカデミックなデッサンとはどこか行き方が違っているという事であった。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ今は行き方も知れない。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば一つの自動車を作ってその機械の自己の作用で向かう所にどこまでも向かわせる場合には便宜とか選択の問題は起こらぬ、車は行く所にしか行かぬのであるが、これが解析的な数学の行き方とすれば物理学のはそうでない。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういう行き方では決してドビュシーの音楽のようなものはできないであろう。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この犬を描くのと同じ行き方で正真正銘の人間を描くことがどうしてできないのか。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばごく甘口の行き方をすれば、弦の切れて巻き上がった三味線をちょっと映した次に、上野の森のこずえのおぼろ月でも出しそれに夜がらすの声でも入れておいて、もう一ぺん妹とその情人の停車場へ急ぐ自動車を出すとかなんとか方法はないものかと思う。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『能』というものは人間が形にあらわしてする物真似の無調法さや見っともなさを出来るだけ避けて、その心のキレイさと品よさで、すべてを現わそうとするもので、その能と言う獣の行き方と、おんなじ行き方だというので能と名付けたと言います。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "総て自分のような男は皆な同じ行き方をするので、運命といえば運命。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、死んだのならかえってあきらめがつきますが、別れたぎり、どうなったのか行き方が知れないのですよ。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つのものの行き方のちがいがかなりはっきり対照される。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "格式に拘泥しない自由な行き方の誹諧であるのか、機知｜頓才を弄するのが滑稽であるのか、あるいは有心無心の無心がそうであるのか、なかなか容易には捕捉し難いように見える。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に一応の道理を聴き置き、諸名僧知識と言われる人の人格を信じて、その教えのままに信仰に入られるのは、また賢明な行き方であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり普通の行き方です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもこの行き方ですからなあ。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ファビアン」は第一次大戦後の混乱と頽廃と無気力と不安の中に蠢いている独逸の一青年を横紙破りの新しいスタイルで描いたもので、戦後の日本の文学の一つの行き方を、僕はこの小説に見たと思った。",
              "citation": {
                "source": "土足のままの文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦後大作家まで自分の作品を棚に上げたもっともらしい文学論を書いているが、凡百のそれらの文学論よりは「ファビアン」一冊の方が、どれだけ今後の文学の行き方を示しているか判らないくらいだ。",
              "citation": {
                "source": "土足のままの文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ファビアン」を読んで、次にジョイスの「ユリシーズ」を読み、僕は更に新しい文学の行き方が判り、僕らの野心とは僕らの「ファビアン」を作ることであり僕らの「ユリシーズ」を作ることにあると納得した。",
              "citation": {
                "source": "土足のままの文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭が擧げよ、時足らざればかく思ひに耽りてゆきがたし　七六―七八見よかなたにひとりの天使ありて我等の許に來らんとす、見よ第六の侍婢の、晝につかふること終りて歸るを　七九―八一敬をもて汝の姿容を飾れ、さらば天使よろこびて我等を上に導かむ、この日再び晨とならざることをおもへ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
