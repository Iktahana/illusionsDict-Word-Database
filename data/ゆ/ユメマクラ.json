    "definitions": [
      {
        "index": 1,
        "gloss": "at the bedside where one dreams",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
