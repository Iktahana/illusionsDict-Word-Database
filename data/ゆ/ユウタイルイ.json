        "examples": {
          "standard": [
            {
              "text": "カンガルーやワラビーは、オーストラリアに広く分布する有袋類だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "有袋類は、胎盤を持たない哺乳類として進化の過程で独自の道を歩んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "動物番組で有袋類の育児の様子を見て、そのユニークな生態に驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "すべての猿類はむろんのこと、擬猴類でも、食虫類のあるものや、有袋類のあるものさえも、人間のとおりの手を持っている。",
              "citation": {
                "source": "我らの哲学",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
