[
  {
    "uuid": "bc522e9c-376c-501e-afcd-fa91869f3489",
    "entry": "湯桶",
    "reading": {
      "primary": "ゆとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
