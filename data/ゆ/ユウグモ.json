        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "豐岡から來る間、夕雲の低迷して小浪に浮織の紋を敷いた、漫々たる練絹に、汽車の窓から手をのばせば、蘆の葉越に、觸ると搖れさうな思で通つた。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう思って来ますと先生にまたうかび寄る夕雲の哀れさがあって再び山をも顧る私たちでありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吐血罌粟畑日は紅紅と、水無月の夕雲｜爛れ、鳥鳴かず。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "短い日は村の林の梢に棚引いた土手のやうな夕雲に眞倒樣に落ちつゝある。",
              "citation": {
                "source": "寫生斷片",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都の荒廃「なれや知る、都は野辺の夕雲雀、あがるを見ては落つる涙は」有名な古歌である。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "母に連れられた子供は、遠い夕雲と母親の足どりに氣をくばりながら物悲しく歩いて、お葉と行き違つたのである。",
              "citation": {
                "source": "三十三の死",
                "author": "素木しづ子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天晴夕雲の紅に彩られつと見えたのは、塀に溢るるむらもみじ、垣根を繞る小流にも金襴颯と漲ったので。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱に輝く夕雲のすき間から、今入りかけの太陽が、細く強い光を投げて、稲田の原を照り返しうるおいのある空気に一種の色ある明るみが立った。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "短い日は村の林の梢に棚引いた土手のやうな夕雲に眞倒に落ちつゝある。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "室内の電灯がともり、海上がいつとなくたそがれ、最後までほのかに見えていた天城の連山も、夕雲にとざされ、闇が海上を覆いつくす頃になっても、京子達は帰って来なかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕雲のように紫色に渦巻いた長い髪毛。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "応仁の乱か何かに遇つた人の歌に、「汝も知るや都は野べの夕雲雀揚るを見ても落つる涙は」と云ふのがあります。",
              "citation": {
                "source": "大正十二年九月一日の大震に際して",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕雲と思つた美しい空の色が次第に藍気を帯びて来て鼠色の家の上の窓なども定かに見えなくなつて来た。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い夕雲が出て静かな夕方など、私はよく自転車をとばして、海岸近くの小池へ出掛ける。",
              "citation": {
                "source": "夏と魚",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ夕雲のかけりゆく空のあなたぞなつかしき心の渇きとゞむべきそこに生命の川あらむ眞理のかどを開くべきそこに秘密の鍵あらむ。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚呼夕雲のはねのうへたれか「涙の谷」棄てゝ荒鷲翔けり風迷ふ空のあなたに飛行かむ浮世の暗にしられざる光はそこにてるべきに。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "登高烟は沈み水咽ぶ五城樓下の夕まぐれ高きに登り佇めば遠く悲雷の響あり心の空に吹き通ふ風の恨に誘はれて色こそ悼め夕雲の嶺に歸るもなつかしや。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "定家卿の幽玄体と称する歌には、まゝ象徴詩的のものがあることは、業に述べたが、この雲の色をの語の如きは、部分的に夕雲を借つて来て、心的状態をあらはし、又形式の上にも、聴覚情調を重んじて居るところは、すでに象徴風を帯びた歌というてよからう。",
              "citation": {
                "source": "古歌新釈",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "結句の推量も、赤い夕雲の光景から月明を直覚した、素朴で人間的直接性を有っている。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼のまえの屏風岩のギザギザした鋸歯のようなグラートのうえにはまだ、夕雲はかがやかに彩られていた。",
              "citation": {
                "source": "涸沢の岩小屋のある夜のこと",
                "author": "大島亮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "日はユトリベルクの上に沈んで、向う岸にうねうね並ぶ丘の上には、ほんのりと紅みを帯びた夕雲が、折り重なって湖水の水をのぞき込む。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう日暮に間もあるまい、四時間余りの途のりに、彼これ七時間も費やして、ベールエックのとっつきの、牛小屋まで辿り着くと、今迄いやに薄ぐらく、頭の上に覆いかぶさっていると思った夕雲が、いつの間にかオックスからアイガーの裾へ拡がりかかって、そのうち、どっと細引のような大雨になった。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れが嫩らかな日光に笑み、若くは面を吹いて寒からぬ程の微風にソヨぐ時、或は夕雲の翳に青黒く黙す時、花何ものぞと云いたい程美しい。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両三日来夜になると雷様が太鼓をたゝき、夕雲の間から稲妻がパッと射したりして居たが、五時過ぎ到頭｜大雷雨になり、一時間ばかりして霽れた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山ものどかに、夕雲の中に這入つて行かうとしてゐる。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "山ものどかに夕雲の中に這入つて行かうとしてゐる。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "山ものどかに、夕雲の中に這入って行こうとしている。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鋸はまたゆるく動きぬ、夕雲の照りかへしにぞ小屋ぬちはしばし燃えたる。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
