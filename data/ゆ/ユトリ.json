      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "elbowroom",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただそれを研究しているという事が何より先に感ぜられるので、楽しんで見るだけのゆとりが自分には出て来ない。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "心にはややゆとりが出来たが、足は前と同じ歩調ですたすたと歩いている。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の姿が眼の前から消え去つた事、それは私の心に或る幽かなゆとりを與へた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "均斉、精緻、繊巧その宜しきを得てゐるが、それは人生たるべくは、人間たるべくは、多くの場合何となく真実さ、自然さ、裸さ、ゆとり、柔みの感じを欠いてゐる。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ひ換へると、どうもゆとりが無い、棘棘し過ぎる。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠犬の死を「読む」だけならば、美しい感傷を味わうだけのゆとりがある。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時にあの罪のない俚謡から流れ出た自由な明るい心持ちは三十年後の今日まで消えずに残っていて、行きづまりがちな私の心に有益な転機を与え、しゃちこ張りたがる気分にゆとりを与える。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "年頭の儀式は廃しても春はどこやら春らしくて、突きつまったような心にもいくらかのゆとりができた。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お辞儀、つい目の前に居られたので、向うへ頭を下げるゆとりがなく、頤を引込めて手を支いた。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "天窓がぐらぐらとすると、目がくらんでしまいまして、揺れるか、揺れんか、考えておりますようなゆとりはないのでござります。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいいち、このような型の感傷、このような型の文章は、戦争中「心の糧になるゆとりを忘れるな」という名目で随分氾濫したし、「工場に咲いた花」「焼跡で花を売る少女」などという、いわゆる美談佳話製造家の流儀に似てはいないだろうか。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "性質も沈むでゐるが、顏もくすむでゐる、輪廓の大きい割に顏に些ともゆとりが無く頬は※けてゐる、鼻は尖ツてゐる、口は妙に引締ツて顎は思切つて大きい。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は其を心に捕へて置いて、熟と見詰めて見るだけのゆとりとてもなかツた……、閃めき行くまヽだ。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "のびない護謨もゆとりがあって面白いと云う人を屈服させる訳には行かない。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のこれまでの生涯を追想して、幽かにでも休養のゆとりを感じた一時期は、私が三十歳の時、いまの女房を井伏さんの媒酌でもらって、甲府市の郊外に一箇月六円五十銭の家賃の、最小の家を借りて住み、二百円ばかりの印税を貯金して誰とも逢わず、午後の四時頃から湯豆腐でお酒を悠々と飲んでいたあの頃である。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなたわむれの言葉を交しながら、ゆとりある態度で呑みおわって、それから、大きいひらたい岩にふたりならんで腰かけて、両脚をぶらぶらうごかしながら、静かに薬のきく時を待って居ました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本で一ばん気品が高くて、ゆとりある合戦をしようと思った。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに、わたくしをして、それほど強い羽搏きをしたがらせず、神妙に寮に落付かせている鬱陶しいゆとりをあらしめたのでございましょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはいよ／＼わたくしをして只今の鬱陶しいゆとりに腰を落付かしめるよすがにもなったのでございましたろうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛んなりしこの柳河にての歓迎の一夜も明けて、墨を磨り若かへるでは朝光のすずしきがほどをゆとりもたなむ夏の三柱宮高畠公園の三柱神社は藩祖を祀る。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "老嫗は穏やかなゆとりのある詞で言った。",
              "citation": {
                "source": "賈后と小吏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "引き緊っていた章の心に、ややゆとりが出来た。",
              "citation": {
                "source": "狼の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺から、また横ツ廣がりではなく、體の前後にゆとりを持つた胸膈に移つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何んとも、何人も云はないやうですが、」「さうかね、空耳だつたらうか、」　省三はまた箸を動かしだしたが彼はもう落ち着いたゆとりのある澄んだ心ではゐられなかつた。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度結婚したこともありますが、子供は出来ませんでした、」　省三はその女が事情があるにせよ、独身であると云ふことを聞いて、心にゆとりが出来た。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいくらか心にゆとりができていた。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし幸いに天子は心にゆとりのある方であったから、宮中に留め置いて発表しなかった。",
              "citation": {
                "source": "続黄梁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭は膨らんだ源のその懐をじろりと見て、「何だ、それは、」「ええ、」「下駄じゃあねえか、下駄じゃあねえか、串戯じゃあねえ、何を面啖ったか知らねえが、そいつを懐に入れるだけの隙が有りゃ、敵の向脛をかッぱらって遁げるゆとりはありそうなもんだぜ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
