[
  {
    "uuid": "7d0c734a-4cae-51f7-9a06-d784d5333444",
    "entry": "ゆとり",
    "reading": {
      "primary": "ゆとり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "形容詞-語幹"
      ],
