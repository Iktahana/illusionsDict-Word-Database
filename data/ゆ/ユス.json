[
  {
    "uuid": "9487aa16-9676-5a9f-a9c6-d7c736c4156b",
    "entry": "揺す",
    "reading": {
      "primary": "ゆす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to rock the left hand (to produce vibrato on a koto, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして僕の耳を引つ張つて、僕の頭を揺すぶりながら、「そんなにレモンをかけて食べる人ありますか！",
              "citation": {
                "source": "夜汽車の食堂",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の感情はそっちのけに、養母が動揺するのを気味よしとする皮肉なところがあった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩に乗り上げた舟のように傾いた橇の底では兵士が、でこぼこのはげしい道に動揺するたび、傷を抑えて歯を喰いしばった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶるぶる身慄いして、馬は、背の馬具を揺すぶった。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホーホケキョ」「あ、鶯かしら」　雀が二羽｜檜葉を揺すって、転がるように青木の蔭へかくれた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして顔を洗うために鉢の水が動揺すると、この水の定常振動と同じ週期で一種の楽音を発することがしばしばある。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅の洗面台はきわめて粗末な普通のいわゆる流しになっていて、木製の箱の上に亜鉛板を張ったものであるが、それが凹凸があって下の板としっくり密着していないために、洗面鉢の水が動揺するにつれて鉢自身がやはり少しの傾斜振動をする。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "微力なる私の土地解放で崩壊したり動揺する様な確信であるならば其の根柢が空虚なる為で決して充分に鞏固なるものでない証拠ではあるまいか。",
              "citation": {
                "source": "狩太農場の解放",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嵩増す潮は、さし口を挟んで、川べりの蘆の根を揺すぶる、……ゆらゆら揺すぶる。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　銀子は無器用に抱きかかえ、起ちあがって揺すってやったが、いよいよ渋面作り泣き出した。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあんだ、越後にだつてあるぢやないか、お爺さんやお婆さんが揺籠を揺すりながら、乳母車を押しながらうたふのと同じぢやないか。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "良寛さんはごとんごとんと揺すぶりあげられながら、牛飼と、手綱を持つた子供と、少しづつ首をふりながら、ゆつくり歩いてゐる牛を見てゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何だい、こんな糞坊主が、そばにをつても、些も温くなりやしないぢやねえか、と口の中でいひながら、武助さんは邪険にぐらぐらと船を揺すぶつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　武助さんは、舟をわざと揺すつて、良寛さんを川に落したといふことを話した。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "其内で私は歴史的に読者の過去を蕩揺する、草双紙とか、薄暗い倉とか、古臭い行灯とか、または旧幕時代から連綿とつづいている旧家とか、温泉場とかを第一に挙げたいと思います。",
              "citation": {
                "source": "木下杢太郎著『唐草表紙』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と口口に、巻き、投げ、昇り、立ち騒ぐ刹那か、颯と暴風の襲来迅く、帆の半、帆ばしら、帆桁、折れ、唸り、はためき、倒れ、動揺す、奈落へ、天へ、激瀾の鳴号凄く轟轟と頭上に下に、刻刻の不穏｜等しく一室は歯の根もあはず、惨たりな、垂死の境。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その薫蒸するところ暑く、その蕩揺するところ、日に新にして流る。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも長い汽車旅行と暑さとに疲れているので、僕はそのがた馬車にゆられて新聞をよみながらいつとはなしにうとうとと眠ってしまったと思うと、不意にぐらりと激しく揺すぶられたので、はっと驚いて眼をあくと、僕のからだは腰掛けから半分ほど転げかかっている。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "高山以来、毎晩碌々に安眠しない上に、列車のなかに立往生をしたままで、すし詰めになって揺すられて来る。",
              "citation": {
                "source": "指輪一つ",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い峰から吹きおろす山風が小屋の戸をぐらぐらと揺すって、どこやらで猿の声がきこえた。",
              "citation": {
                "source": "木曽の旅人",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あたい、役者なんか厭だア」と、けいちゃんというのがからだを揺すった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うむきに寝ている女の肩に手を掛けて揺すぶったが、女は此方を向かない。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度揺すると、女が向うをむいた儘言った。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにせよ、我々は、怒鳴っても宥めても揺すぶっても決して脱がせることの出来ぬ不思議な仮面の前に茫然とせざるを得ぬ。",
              "citation": {
                "source": "南島譚",
                "author": "※",
                "note": "青空文庫"
              }
            },
            {
              "text": "北西離島のものは、皆、仏桑華や印度素馨の花輪を頭に付け、額と頬に朱黄色の顔料を塗り、手頸足頸腕などに椰子の若芽を捲き付け、同じく椰子の若芽で作った腰簑を揺すぶりながら踊るのである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "競場で鍛い上げた胴間声を揺すって湊屋一流の怪長広舌を揮い始めた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝頼は、自分の分国の諸将が動揺するのを見、憤激して、天正二年正月美濃に入って明智城を攻略し、同じく五年には遠江に来って、高天神城を開城せしめた。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "れいの低い声で、「きょうは八十八夜」そうひとこと呟いたかと思うともう、てれくさくてかなわんとでもいうようにむっくり立ちあがって両肩をぶるっと大きくゆすった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "要所、要所の手くばりもあらましここにすみぬれば手代が下知の一聲に家臺をゆする物音やたまたま晝の閑寂に庭の椿の落つる頃。",
              "citation": {
                "source": "煤掃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "濠に隣った牧牛舎の柵の中には親牛と小牛が四、五頭、愉快そうにからだを横にゆすってはねている。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
