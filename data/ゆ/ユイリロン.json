        "examples": {
          "standard": [
            {
              "text": "唯理論は、理性こそが知識の源泉であると考える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "デカルトは代表的な唯理論者の一人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は唯理論と経験論の違いについて講義した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "作者いかほど高遠の理想を抱きたりとて人物の描写｜拙ければ唯理論のみとなりて小説にはならず。",
              "citation": {
                "source": "小説作法",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して實際と云ふ事を唯理論の上から計り推してゐる。",
              "citation": {
                "source": "六號室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに曰く、「懐疑論もまた一種の偽論なるのみ」　しかるに、ここに唯物、懐疑のほかに、唯理論と称するものあり。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
