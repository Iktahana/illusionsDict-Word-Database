[
  {
    "uuid": "1c8990bd-a48e-54f2-8ab2-5a6ded408296",
    "entry": "揺する",
    "reading": {
      "primary": "ゆする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to shake",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分の感情はそっちのけに、養母が動揺するのを気味よしとする皮肉なところがあった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩に乗り上げた舟のように傾いた橇の底では兵士が、でこぼこのはげしい道に動揺するたび、傷を抑えて歯を喰いしばった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして顔を洗うために鉢の水が動揺すると、この水の定常振動と同じ週期で一種の楽音を発することがしばしばある。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅の洗面台はきわめて粗末な普通のいわゆる流しになっていて、木製の箱の上に亜鉛板を張ったものであるが、それが凹凸があって下の板としっくり密着していないために、洗面鉢の水が動揺するにつれて鉢自身がやはり少しの傾斜振動をする。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "微力なる私の土地解放で崩壊したり動揺する様な確信であるならば其の根柢が空虚なる為で決して充分に鞏固なるものでない証拠ではあるまいか。",
              "citation": {
                "source": "狩太農場の解放",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其内で私は歴史的に読者の過去を蕩揺する、草双紙とか、薄暗い倉とか、古臭い行灯とか、または旧幕時代から連綿とつづいている旧家とか、温泉場とかを第一に挙げたいと思います。",
              "citation": {
                "source": "木下杢太郎著『唐草表紙』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その薫蒸するところ暑く、その蕩揺するところ、日に新にして流る。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度揺すると、女が向うをむいた儘言った。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝頼は、自分の分国の諸将が動揺するのを見、憤激して、天正二年正月美濃に入って明智城を攻略し、同じく五年には遠江に来って、高天神城を開城せしめた。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "斥候が逃げれば後続の大軍動揺するであろう。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "車掌「お医者様はおられませんか、お客様の中にお医者様はおられませんか」車内、何事が起ったのかと動揺する。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "観覧席、雨で動揺する。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺院の懸灯の動揺するを見て驚き怪しんだ子供がイタリアピサに一人あったので振り子の方則が世に出た。",
              "citation": {
                "source": "知と疑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、もう本船が、酔っぱらいのように動揺する。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "船員たちは、船長から、水火夫に至るまで、自分を、完全に縛りつけている、その動揺する家屋から、解放しようとして、それぞれ準備に忙しかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、その磨き澄ました日本刀のような寒風が揺するのだった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠は敬である、その敬は「心を一つの事に集中させ、他にそらさないこと（主一無適）」と先人が解釈しているが、実に妙釈であって、一を主として他に適かない、散乱動揺すること無く、ただそれ一ツで、夾雑物無く、他念の無いのが忠である。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやくあきらめができた今になって、また動揺することになってはならない危険な会見を避けていたのであるが、予感したとおりに御息所の心はかき乱されてしまった。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "何に動揺することもなく長く留守の間を静かに待っていてくれた人を、源氏はおろそかには思っていなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ高価を支払われて外国へ流出したものも沢山あるらしいから、追付けクルトやズッコのお仲間が日本人の余り知らない傑作の複製を挿図した椿岳画伝を出版して欧洲読画界を動揺する事がないとも限られない。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "道路がわるいために、盛んに動揺するけれど、それが優秀な車体とクッションとのために、快い振動となって、身体に伝わって来る。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　村川は、悲壮な決心をして、動揺する心を押えて眠りに入ろうとしたが、どうしても眠れなかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "遉に、大理石の柱が、並んでいる車寄せに立ったとき、胸があやしく動揺するのを感じた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、皮膚病学の泰斗がそれについてどういう言説をなしているかを知って、自分の激しく動揺する良心を落ち着けたいと思った。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬吉は、動揺するボートの底板を、重く踏みしめながら、女に近づいて女の身体を捕へた。",
              "citation": {
                "source": "海の中にて",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界はかように動揺する。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　首を押さえた手を、そのまま左右に揺する。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何事かをパーリ語で唱えては、体を前後に揺するのであった。",
              "citation": {
                "source": "ラ氏の笛",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、駕籠に乗った場合に、駕籠のなかで無暗にからだを揺する。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "要所、要所の手くばりもあらましここにすみぬれば手代が下知の一聲に家臺をゆする物音やたまたま晝の閑寂に庭の椿の落つる頃。",
              "citation": {
                "source": "煤掃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
