[
  {
    "uuid": "582ff7ab-36d2-5c1e-818b-44b727354006",
    "entry": "勇気",
    "reading": {
      "primary": "ゆうき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "courage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "タンポポの花一輪の贈りものでも、決して恥じずに差し出すのが、最も勇気ある、男らしい態度であると信じます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうかも知れない、しかし、私には人が憎めきれない底の、かの単なる多血質な人間を嗤ふに値ひする或る心の力――十分勇気を持つてゐて而も馬鹿者が軟弱だと見誤る所のもの、かのレアリテがあるのでないと、誰が証言し得よう？",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも折には矢も楯も堪らない程訓辞の必要を感じたが、そしてまた実際腹案を立てゝ登校したこともあつたが、教員室に覗いて教師達から威勢の好い挨拶をされるともうその勇気はなくなつてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとく我儘であるくせにまた甚だしく臆病な彼は、自分で断然年賀端書を廃して悠然｜炬燵にあたりながら彼の好む愚書濫読に耽るだけの勇気もないので、表面だけは大人しく人並に毎年この年中行事を遂行して来た。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せっかく、救けて頂いたようなものの、行先の覚束なさ、途中の難儀、もう一足も踏み出す勇気はございません。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その勇気でありました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを食べるには余程の勇気がいる。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この奇妙さがふたたびリゼットへ稼業に対しての、冒険の勇気を与えて彼女は毎夜のような流眄を八方に配り出した。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも今夜の「新らしい工夫」に気付くと卒然と彼女の勇気が倍加した。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一平　昔の新しい女は勇気はあったが、垢抜けしていなかった。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそこからボートまでのところにはまだまだ小さな子どもたちや親たちやなんか居て、とても押しのける勇気がなかったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの事実は我々に勇気と希望とを与える。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は遂に一口を試むるの勇気もなかった十四日　暖かであるから出産牛のあと消毒を行わせた。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私｜極りわるくてしょうがないわ」「よしとそれじゃ僕が先になろう」　僕は頗る勇気を鼓し殊に平気な風を装うて門を這入った。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな目の子勘定をして紳士淑女の辛抱強いのに感心する一方では自分でこの仲間にはいろうという勇気を沮喪させていた。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "異郷から来た旅人が宿泊した時に、その人が風采も立派で勇気があって優れた人物だと思うと、夜中に不意を襲って暗殺してしまう。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗殺の目的は金や持物ではなくて、その旅人の有っている技能や智慧や勇気が魂魄と一緒に永久にその家に止まって、そのおかげでその家が栄えるようにという希望からだという事である。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで津田君のこの点に対する努力の結果が既にどこまで進んでいるかは別問題としても、そういう態度とこれを実行する勇気とに対して先ず共鳴を感じないではいられないのである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術の世界に限らず科学の世界でも何か新しい事を始めようとする人に対する世間の軽侮、冷笑ないし迫害は、往々にして勇気を沮喪させたがるものである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかと云ってマスクをやめろと人に強いる勇気もない。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく私は、勇気を奮って書いて見よう。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして皆は兄の蒼白な手をとつて親しく微笑して更らに健康と勇気と光との世界を求めるやうになるであらう。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近寄って見る勇気もない。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンスタンチノーブルから乗りこんだ女実業家の数人が談論の花を咲かして、僕を勇気づけてくれたにもあるのだが僕はいまに土耳古が商工業に於ける世界の中心地にさえなると思うのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は勇気を出して翌朝彼が提出した新しい契約を破棄してしまいました。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると牀をける足音と、しばらくしてもの凄い音響が電流をつたって彼女に勇気をあたえた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "母に対しても、お登久に対しても、かれは正直に打ちあける勇気がないので、ここでもまた好い加減の嘘を作って、筋の悪い品物を買った為にその引き合いを受けるのが迷惑だから、当分は世間に顔を出したくないと云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "「庭へ出たらどこか逃げ路が見付かるかも知れない」　お蝶は一生の勇気をふるい起して、息を殺しながらそろりそろりと滑っこい畳の上を忍んであるいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民の輿論、敵がい心、兵士達の向う見ずの勇気、憤激などは、こういう報道から不可避的に作り出されて行くのだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "チュンセがもしもポーセをほんとうにかあいそうにおもうなら大きな勇気を出してすべてのいきもののほんとうの幸福をさがさなければいけない。",
              "citation": {
                "source": "手紙　四",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
