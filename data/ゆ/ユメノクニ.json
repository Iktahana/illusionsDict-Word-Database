        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その頃の彼は、日本をもはや『夢の国』としては見ていなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人がその空想の中で画くような、ファンタスチックな夢の国は、現実の地球上にあるはずがない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも宿命的な詩人の悲願は、その有り得べからざる夢の国を、生涯夢見続けることの熱情にある。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢の国に論理の橋を架けたのが彼の仕事であった。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "永い間胸に抱いてきた罪のない夢の国の美しい夢を冷たい現実でかき乱すのは気の毒で残酷なような気もするのであった。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）を連ねるだけであるからせっかくの現実映画の現実性がことごとく抜けてしまって、ただおとぎ話の夢の国の光景のようなものになってしまうだけである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おはぐろ筆というものも近ごろはめったに見られなくなった過去の夢の国の一景物である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の中の特殊な一群の民族によっていつからとも知れず謡い伝えられたこの物語には、それ自身にすでにどことなくエキゾティックな雰囲気がつきまとっているのであるが、それがこの一風変わった西欧詩人の筆に写し出されたのを読んでみると実に不思議な夢の国の幻像を呼び出す呪文ででもあるように思われて来る。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは今のところでは一場の夢物語のようであるが、実はこの夢の国への第一歩はすでに踏み出されている。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ年少の夢よ、かの蒼空はこの夢の国ならずや、二郎も貴嬢もこのわれもみなかの国の民なるべきか、何ぞその色の遠くして幽かに、恋うるがごとく慕うがごとくはたまどろむごとくさむるがごときや。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実の世界において望んで得べからざる願望が夢の国において実現されるように、人工映画の世界においてはあらゆる空想が安々と実現される。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、自分は、酔って大胆になっているからでもありましたが、「よし、そんなら、夢の国に連れて行く。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢の国で流した涙がこの現実につながり、やはり私は口惜しくて泣いているが、しかし、考えてみると、あの国で流した涙のほうが、私にはずっと本当の涙のような気がするのである。",
              "citation": {
                "source": "フォスフォレッスセンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勝手に夢の国で、ぐずぐずしていて、」と神はさえぎった。",
              "citation": {
                "source": "心の王者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは夢の国に通ずる。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風のない空気の緩んだ街頭はひつそりとして、物音といつては今彼を乗せて来た電車が交叉点を越へて上野の方へと走つてゐる音だけであるが、それさへ夢の国から来る物音のやうに耳には響かなかつた。",
              "citation": {
                "source": "青い紐",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い木橋は夢の国への通路のように、幽かに幽かに、その尾を羅の帳の奥の奥に引いている。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい、懐かしい夢の国として故郷は恋しい。",
              "citation": {
                "source": "妄想",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の眼には美智子の室が夢の国のやうに更に明るく見えました。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも桂月氏はその桜の花を決して明るく描かなかつた許りか、陰気にさへも描いてゐたことは、東洋の詩と夢の国としての『日本』の現実的な是正として成功作だといはなければなるまい。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見ればはるか彼方に夢の国のやうにたつた今乗り出した渚が淡くかすんで居りました。",
              "citation": {
                "source": "初夏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にまた驚く可き事には、此国の人々は凡て、男と女の区別が決して出来ない程美しく優しく何れも夢の国の人々の如くに色が白くて小胆なのである。",
              "citation": {
                "source": "闘戦勝仏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "くやしかったら、夜食でも食べにいってきなよ」　あっさりいうと、策あってのことか、思い余ってのことか、ふっくらと夜具にうまって夢の国を追いました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、暗くなるまで、そこらの草むらの中で、ひと寝入りしようぜ」　先にたってかっこうなくぼみを見つけると、いつもながらの閑日月、すでにもう夢の国の人でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏道仏心｜弥陀の極意はこのひとまくらのうちにありといわぬばかりで名人は、求道弘法の経巻を頭の下にしながら、おりから聞こゆるお山の鐘を夢の国への道案内に、すやすやと心よいいびきをたてはじめました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつらうつらといいこころ持ちそうに夢の国でした。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ごとも知らないものの如く眠っていたかと思われたのに、その浄願寺角までやって来ると、俄然、カッと退屈男が息を吹き返した人のように、夢の国から放たれました。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "早乙女主水之介夢の国にあって吉原の灯りの匂いを知るという奴じゃ。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
