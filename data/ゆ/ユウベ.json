[
  {
    "uuid": "171b03a4-4cb6-5a35-8afa-7cf3eaff1ac5",
    "entry": "昨夜",
    "reading": {
      "primary": "ゆうべ",
      "alternatives": [
        "ゆんべ",
        "よべ"
      ],
      "is_heteronym": true
    },
    "grammar": {
