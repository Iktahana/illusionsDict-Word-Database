[
  {
    "uuid": "fa7928d3-582b-56d5-9cc5-084901961acf",
    "entry": "勇敢",
    "reading": {
      "primary": "ゆうかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "brave",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、その唯一つの道を勇敢に突進した彼であった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくどこへ行っても、行く先々に勇敢な彼等のための天地が開けて行きそうな気がする。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし「勇敢」では少しぐあいが悪い。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇敢にも、過去の一切を投げ出し、鷲のやうに空を飛んだ。",
              "citation": {
                "source": "室生犀星君の飛躍",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に室生犀星の勇敢と正直さとは、彼自ら芥川君について言つた如く、悲壯にもその『風流の假面を肉つきのままで引つぺがした』のである。",
              "citation": {
                "source": "室生犀星君の飛躍",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで我勇敢なる大原隊は来るべき（八尋不二　宛）　（四）　戦に備えて日毎演習を行ッている。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "その争議団が、官憲や反動暴力団を蹴とばして勇敢にモク／＼と立ちあがると、その次には軍隊が出動する。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方には、従順に、勇敢に、献身的に、一色に塗りつぶされた武者人形。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの勇敢なコシャック騎兵までが逃げてきまひた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇敢で、単純で、感情的な重藤は、自分の扱っている兵卒の要求と、本能を直感的に見抜く鋭敏な才能を持っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　珍しい、金目になるものを奪い取り、慾情の饉えを満すことが出来る、そういう期待は何よりも兵士達を勇敢にする。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士は、その××に引っかかって、ほしいものが得たさに勇敢に、捨身になるのだった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼等を勇敢にするのだった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我軍の戦術もよかったし、将卒も勇敢に奮闘した。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中、一人は、非常に勇敢に闘った優秀な将校でありました。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "４６＝本堂　和尚が今度は男達に、Ｔ「拙僧が今、御教え致しました室に」　と云って、Ｔ「貴女の想う御婦人が、貴下の来るのを待って居られます」Ｔ「御仏が御許しなされたのです」Ｔ「勇敢に御進みなさい」４７＝門前　伝六の率いる捕方の一隊ひしひしと詰めかけた。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "46＝本堂　和尚が今度は男達に、Ｔ「拙僧が今、御教え致しました室に」　と云って、Ｔ「貴女の想う御婦人が、貴下の来るのを待って居られます」Ｔ「御仏が御許しなされたのです」Ｔ「勇敢に御進みなさい」47＝門前　伝六の率いる捕方の一隊ひしひしと詰めかけた。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは自ら恃むことに厚く最も勇敢な人々のみの爲し得ることである。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "万物が火より成るとか、地水火風から成るとか、また金は金、骨は骨と、いわゆるホメオメリアより成るとか、そういう考えから来る困難を列挙し、また一方では自説に対するこれら他学派の持ち出すべき論難に対して勇敢に応戦している。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇敢なクジマ、今までに四十人の生命を助け十回も屋根からころがり落ちた札付きのクジマのおやじが屋根裏の窓から一匹のかわいい三毛の子ねこを助け出す。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "粥釣りに来るおおぜいの中でも勇敢なのは堂々と先頭に立ってやって来るが、気の弱いのは先頭の背後に隠れるようにして袋をさし出すのもある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、失敗どころか、かえってこの少女たちに、なにか勇敢な男としての印象を与えたのかも知れない。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる民族の中の勇敢な進取的な連中が自然に寄り集まってできた国だとすれば、日本は世界じゅうでいちばんえらい国でなければならないはずである。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれは「うがち過ぎ」をこわがらないで「言わずもがな」をけ飛ばして勇敢に創作心理の虎穴に乗り込んでみなければならない。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思えば勇敢で殺生好きで利かぬ気の子供でもあった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "要は、苦労は苦労として冷静にその原因、性質を見究め、勇敢にこれを取除く手段や生活法を取って、さて新しい気持ちで次の経験に向うのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "維摩、勝鬘の二経は、一は老熟の男性の口を藉り、一は妙齢婦人の言葉を藉りて、勇敢なる生活の理想化を獅子吼さしている経であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にその晩の夜の十時すぎに勇敢な献身的なこの署長は町の安宿へ行って一晩とめて呉れと云った。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "終に臨んで勇敢なるマットン博士に深甚なる敬意を寄せます。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に英邁勇敢なるルーズヴエルト氏が大統領に就任せし時以来、一部国民の精神は著しく其感化を受けしものゝ如く、表面に黄金を崇拝する事に変りはなけれど、其精神に於ては英雄崇拝を以て本義と為し或者は尚武練胆の気風を皷吹し、或者は米国魂に加ふるに日本魂の精萃をすら吸収し伝播せんと企てつゝあるが如し。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
