        "examples": {
          "standard": [
            {
              "text": "子供にプレゼントとして、安全な素材で作られた遊戯銃を選びました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "本物と見分けがつかないほど精巧な遊戯銃は、誤解を招く恐れがあるので注意が必要です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "庭で、兄弟がそれぞれの遊戯銃で的当てごっこをして遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし形としてはほぼ同じで、丘や凹地や庭があり、池には貸ボートが浮び、遊戯施設も一応ととのっている。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
