[
  {
    "uuid": "e4d3f62e-49c7-5400-8a8e-e0b4f530a9de",
    "entry": "勇力",
    "reading": {
      "primary": "ゆうりょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
