      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "elegant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "象徴派詩人達は殆んど女のやうな優雅さを持つてゐた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木が好きで、學校のぐるりに樣々の植木を、優雅に配置し、ときどき、ひとり、兩手をうしろに組んで、その植木の間を、ゆつくり縫つて歩いてゐた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たうもろこしの葉が、風にさやさやと騷ぐのも、ながなか優雅なものである。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "優雅な和やかな、しかし、やはりうち閉された重くるしさを感じます。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういう訳だか分らないが、あの右の手の何とも名状の出来ない活きた優雅な曲線と鮮やかに紅い一輪の花が絵の全体に一種の宗教的な気分を与えている。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "フェルト草履は、見た眼にも優雅で、それに劇場や図書館、その他のビルディングにはいる時でも、下駄の時のように下足係の厄介にならずにすむから、私も実は一度はいてみた事があるのであるが、どうも、足の裏が草履の表の茣蓙の上で、つるつる滑っていけない。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂々と、ためらわず、いわゆる高級品を選び出し、しかも、それは不思議なくらい優雅で、趣味のよい品物ばかりである。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……突然……部屋の隅の思いがけない方向で……コロロン、コロロン、コロリン……トロロロンンン……という優雅なオルゴールのような音がした。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "優雅と滑稽、貴族的なものと平民的なものとの不規則に週期的な消長角逐があった。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉は、その簡素で優雅な行き届いた利休の作法にむしろ呆れ果て、ただただ感嘆を続けつつ、饗応を受けて帰りました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "優雅、温柔でおいでなさる、心弱い女性は、さような狼藉にも、人中の身を恥じて、端なく声をお立てにならないのだと存じました。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『それにこの上もなく純粋で優雅な気質を持っている。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして薄いレースの窓帷を時々優雅な人影が横切った。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して、、彼女は並木の木蔭からいそいそ走り出ると、ニッコリ笑いかけて、優雅な身振りで可愛らしい両手をさしのべた。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく私にとって、そのような優雅な礼儀正しい酒客の来訪は、はじめてであった。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶望は、優雅を生む。",
              "citation": {
                "source": "女人創造",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは所謂「情緒」であって、優雅に、涙もろく、女性的な愛情に充ちたものである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陰道の優雅な野趣が眼に浮んで來た。",
              "citation": {
                "source": "雜煮",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても上流中流の人達が留守にした巴里の混雑のなかに、優雅な夫人と、鄙びて居ても何処か上品な娘を連れた新吉の一行は人の眼についた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "平常の巴里の優雅さを埋めかくして居る今日の祭の馬鹿騒ぎの中にベッシェール夫人は本当の巴里其のものゝ優雅さで新吉について歩いて居るのだ。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の祭日の粗野な賑わいを追っ払ったあとから本然の姿を現わして優雅に返った巴里の空のところどころに白雲が浮いて居る。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は先生のお手紙を拝誦して、すぐさま外出し、近所の或る優雅な友人の宅を訪れた。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文弱と言つてなげいてゐたひともあつたやうでございますし、なんと優雅な、と言つて口を極めてほめたたへてゐたひともございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまなかの都会人よりも、はるかに優雅な、こまかい思ひやりを持つてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速支配人に面會を求めると、優雅な音樂の響き漂ふ大食堂の方を眺めながら、ソオルは溜間の一隅で首を長くしてゐた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯攝津の年齡と優雅なる其容貌及び絃の廣助の顏などが、予に一種のロマンチツクな崇敬の心をこの藝術家に對して抱かせたと云ふ事は事實である。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "優雅な蒲公英や可憐な赤まま草を、罌粟や撫子と優劣をつけたろう。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、日本の樹木の優雅なたたずまいや、葉の濃かさの裏表に似つかわしく添って建っているのだ。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "賑やかに入って来た客は印度婦人服独特の優雅で繚乱な衣裳を頭から被り、裳裾を長く揺曳した一団の印度婦人だった。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼しい風が吹いて来て榊のゆうがサラサラと鳴り、檜扇がまた散った。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
