[
  {
    "uuid": "59ef07c9-9b5c-5f84-a2ac-c117ccb32603",
    "entry": "優雅",
    "reading": {
      "primary": "ゆうが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
