        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雪の中を草鞋穿いて、蓑着て揖譲するなんざ、惚気て鍋焼を奢るより、資本のかからぬ演劇だもの。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の老若男女の乗客があっけにとられて見ている中で、大声でわめいて互いに揖譲して終らぬうちに、がたんと車体が動くと同時に、その一団は折りかさなって倒れる。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫れ殷湯の夏を奪ひ、周武の紂を伐つ、何ぞ尭舜揖譲の政に同じからん。",
              "citation": {
                "source": "時勢と道徳観念",
                "author": "大賊小賊・名誉の悪党",
                "note": "青空文庫"
              }
            }
          ]
        }
