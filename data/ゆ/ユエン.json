[
  {
    "uuid": "f17c986d-fe3c-508e-ada5-9d1d7badebcd",
    "entry": "所以",
    "reading": {
      "primary": "ゆえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
