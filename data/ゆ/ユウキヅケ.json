        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "コンスタンチノーブルから乗りこんだ女実業家の数人が談論の花を咲かして、僕を勇気づけてくれたにもあるのだが僕はいまに土耳古が商工業に於ける世界の中心地にさえなると思うのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私は暗と寒気がようやく私を勇気づけて来たのを感じた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "応援団の者になぐられたことが彼を勇気づけた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事実がいつも政江を必要以上に勇気づけるのだった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当りまえの考えが、私を異様に勇気づけた。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の恋に対する私の確信が私を勇気づけて、そのような戦慄すべき仕事を敢えてさしたのです。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "新子は、このまま逃げ出してしまいたいような、激しい衝動を感じて、藁をもつかみたい今の気持には、美和子に勇気づけられたことで、やっと心を落着け、メズーサの首のようにも恐ろしく思える夫人に直面すべく、階段に足をかけた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "煮詰まったところで、「病気の話は大切だと思う」と書いてくれた八巻美恵さんのメールには、勇気づけられた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰り際に玄関で私にむかつて、あなたは男性的に拳をあげて私の男を勇気づけてくれました、私の感情は軽蔑されましたあなたは理性を主張しました、私はそれを感謝します。",
              "citation": {
                "source": "小熊秀雄全集-13",
                "author": "詩集（12）その他の詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに全露消費組合中央委員会とその下の組織がいかに活溌に根強く働いてゐるか、想つただけでも俺たちは背中がゾク／＼とし、勇気づけられる。",
              "citation": {
                "source": "小熊秀雄全集",
                "author": "―３―",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は商売に退嬰的な甥を勇気づけた。",
              "citation": {
                "source": "芭蕉と歯朶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、種々の有機物質の合成が成功したこと、生命物質を人工的要約のもとに発育せしめることが成功したこと等は、研究者たちを勇気づけ、その研究の前途に少からぬ光明を投げつゝあるのである。",
              "citation": {
                "source": "文学の本質について（一）",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、幸いな事に、汚染されたのはホンの表面丈に過ぎないと云う新らしい発見が私を何よりも強く勇気づけた。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして此の事が私を勇気づける唯一の力となるに相違ない。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はその女のために非常に勇気づけられた。",
              "citation": {
                "source": "恋愛曲線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人々と遊んだり、喋ったりすると、あとは爽やかで勇気づけられ、意気込んで来る。",
              "citation": {
                "source": "大切な芽",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルスタムは、風景全面から、悦ばしい勇気づける印象を与えられた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実を直視することの正しさに対して示された一般の積極的潮流は、婦人の精神と感情とを勇気づけ押し出して、狭い家庭的環境の内での男女対立の現実へ彼女たちの目を醒させた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エイセルが日本語ワードプロセッサーのＪＷＯＲＤを、ＣＰ／Ｍ―86に加えてＭＳ―ＤＯＳに対応させて製品化してくれたことに、浜田は勇気づけられていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人は僕らを無言の中に勇気づけてくれている日本の伝統まで認めようとしないんだから、困ってしまう。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つのささやかな遍歴の試みが、私をますます勇気づけてくれる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しばかりの金が、こんなに勇気づけてくれる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "元気を出して、一つ、うんと勉強して、皆を吃驚させてやれよ……」波と風とにさそわれて今日も原稿書いている……　啓吉が、ひどく悄気ているのを見て、勇気づけてやろうと思ったのか、勘三が鼻唄まじりにうたい出したのだが、啓吉は、涙よりもひどいしゃっくりが出て困った。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひがけなかつた事だけに、富岡は、そのやうな才能もあつた自分に勇気づけられてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "真実に心の底からスッカリ安心して、勇気づけられている歩きぶりであった。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時大連にゐた私は夫人のこの壮挙を勇気づける為にハルピンに向け電報を打つたことがあるが、よくも決行されたことであつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは、今や時代は野獣である、何がなじっと落着いていては画家に非ずと勇気づけられたりすると、何が何だかよくはわからないながらも、虎は何処だと叫びながら、尻をまくって取敢えず飛び出して見たりする。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのように常に彼をして味気ない淋しさに堕す「貧乏」「家なし」「親なし」という哀れな境遇が彼には、大自然が自分にある使命を齎らしたしるしであるとさえ勇気づけられた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕などは、この遍路からたいへん勇気づけられたと謂つていい、さうして遂に大雲取も越えて小口の宿に著いたのであつた。",
              "citation": {
                "source": "遍路",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
