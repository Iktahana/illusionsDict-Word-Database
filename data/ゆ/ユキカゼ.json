    "definitions": [
      {
        "index": 1,
        "gloss": "snow-bearing wind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
