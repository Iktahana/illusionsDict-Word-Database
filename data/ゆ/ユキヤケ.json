    "definitions": [
      {
        "index": 1,
        "gloss": "being tanned by sunlight reflected from snow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "君の顔は見る見る雪焼けがしてまっかに汗ばんで来た。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして山の雪が解けてしまう頃に、彼れは雪焼けと潮焼けで真黒になって帰って来た。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪焼けした赭黒い顔に、長い間そらなかった鬚が一面にのびていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは、高山生活一か月にまっ黒に雪焼けをし、蓬々と伸びた髯を嶽風がはらっている。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔は嶽風と雪焼けで真っ黒に荒れ、頬は多年の苦労にげっそりと削けている。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪焼けはとうに、もう地色になっていて、彼は自他ともゆるす世界的｜氷河研究家だ。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は強く反射して、昨日からの雪焼けで、顔はただれるくらいにびりびりする。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
