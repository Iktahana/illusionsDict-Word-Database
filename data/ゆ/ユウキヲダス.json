    "definitions": [
      {
        "index": 1,
        "gloss": "to summon courage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕も勇気を出す、そして貴女にも勇気を出してもらうようにする。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうにか考えなおして坐って遠くを眺めるだけの勇気を出すまでには、だいぶ時間がかかった。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、そこでさすがに、足がややためらったが、勇気を出すと、つかつかと玄関に出た。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ代助には是丈の勇気を出すのが苦痛であつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "直吉は、里子のうつむいた額のあたりを暫くみつめてゐたが、今日見た、河底の広告マンの姿を思ひ出して、あれだけの勇気を出す事が出来たら、何とか里子を引きさらつてやつてゆけない事もないだらうと思つた。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お敏さんも勇気を出すんです。",
              "citation": {
                "source": "妖婆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ代助にはこれだけの勇気を出すのが苦痛であった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、私たちは、一方に二人、もう一方に五人、穴を間にして立ったが、だれ一人第一撃を始めるだけの勇気を出す者はなかった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は近づいて戸を敲くだけの勇気を出す前に、何度も戸口を通り越したものだ。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実を云うと、私も皆さんと同なじ意見ですよ」　権威ででもあるような調子で、最後にこう云った夫人の前に、彼はもちろん反抗の声を揚げる勇気を出す必要を認めなかった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いねは側にいて励まし、勇気を出すようにと云った。",
              "citation": {
                "source": "契りきぬ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の奥底では、妻が勇気を出すと思っていなかったが、今や見方が変わった。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
