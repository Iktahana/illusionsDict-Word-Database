        "examples": {
          "standard": [
            {
              "text": "彼は将来、有為の材として活躍するだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社は、多くの有為の材を求めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若くして有為の材と称される彼は、周囲の期待を一身に背負っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "有為の材を抱いて若死にしたものもあります。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "その後の弟子の事",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう有為の材を、ただ小説を読ませておくとは勿体ない。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の左大臣が有為の材を抱いて早死をしたのは、積る悪業の報いであるように当時の人々は見たのであるが、就中その報いの最たるものは、菅公の怨霊の祟りであるとされたのであった。",
              "citation": {
                "source": "少将滋幹の母",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
