[
  {
    "uuid": "1d11cfe0-d31c-520f-931c-22c0bdd33c89",
    "entry": "努努",
    "reading": {
      "primary": "ゆめゆめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "certainly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さあれ、怒ることこそ汝が最後なる目標の前にであれ、この言ゆめゆめおろそかにする勿れ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆめゆめ粗略には致すまじく候。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもしかし彼にとってゆめゆめ不快なことではなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やよ、ハムレット、汝孝行の心あらば此のうらみ、ゆめゆめ忍ぶ事なかれ、と。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一方、習、性となった・あの文字を連ねることの霊妙な欣ばしさ、気に入った場面を描写することの楽しさが、自分を捨去るとは、ゆめゆめ思えない。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私事｜空く相成候とも、決して余の病にては無之、御前様御事を思死に死候ものと、何卒々々｜御愍み被下、其段はゆめゆめ詐にては無御座、みづから堅く信じ居候事に御座候。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "少長どのに仕負けられては、独り御身様の不覚のみにてはこれなく、歌舞伎の濫觴たる京歌舞伎の名折れにもなること、ゆめゆめご油断なきよう御工夫専一に願い上げ候。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆびきり指をむすびて「マリヤさまゆめゆめうそはいひませぬ」おさなききみはかくいひて涙うかべぬ。",
              "citation": {
                "source": "どんたく",
                "author": "絵入り小唄集",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆめゆめ油断すまいぞ」　有明けのともしびに照らされた師匠の顔は、物凄いほどに神々しいものであった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "火事の叫びがございますまで、ゆめゆめ疑いもしませんでした。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といい、また「それ国にあらば守護方、ところにあらば地頭方にをひて、われは仏法をあがめ信心をえたる身なりといひて、疎略の儀ゆめゆめあるべからず。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆめゆめあるまじき事にして、徹頭徹尾、恕の一義を忘れず、形体こそ二個に分かれたれども、その実は一身同体と心得て、始めて夫婦の人倫を全うするを得べし。",
              "citation": {
                "source": "日本男子論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に「我等が往生はゆめゆめ我身のよきあしきにより候まじ。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆめゆめこの御心は。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "白瓜の皮の浅漬けと言い、かつおの中落ちの味噌汁と言い、ともに食通をアッと言わすだけの立派な料理であるから、ご存じなき向きは、ゆめゆめ廃物利用だなんて薄っぺらな頭を持たないで、これこそ立派な意味ある料理だとの首肯から、ぜひとも試みてもらいたいものである。",
              "citation": {
                "source": "夏日小味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれがこの『嘉加伝毛乃記』いささか名は似たれどもゆめゆめさる不都合の下心あるにあらず。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "この思いやりの心、むずかしく言えば博愛心、慈悲心、相愛心があれば世の中は必ず静謐で、その人々は確かに無上の幸福に浴せんこと、ゆめゆめ疑いあるべからずだ。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸葛孔明の顔は一尺二寸あったというが、これは、ゆめゆめそれに劣るまい。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "捨公方",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからの男たちよ、ゆめゆめ褌を忘れるまいぞ、と昔の酋長が物語った。",
              "citation": {
                "source": "性に関するアイヌの習俗",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆめゆめ疎略にはいたしませぬ。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第七巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "真名古警視が検察の事務を執るに当っては、その冷執陰険なることはユウゴオの「噫無情」に登場するかのジャヴェル探偵にもゆめゆめ劣らぬ事はすでに述べた。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来この伏樋の工事は、一定の方針の下に施されたのではなく、必要に応じて次々に増設されたのだから、分樋ははなはだ無秩序に放射され、かのクレエト島の迷宮にもゆめゆめ劣らぬ複雑多岐な大迷路を作り上げている。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は彼の歿後わずか二十数年余りで、彼の意志が造り上げたこの強固な門が、早くも瓦壊せられようとはゆめゆめ想わなかったであろう。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが「即」と「同」とをゆめゆめ同じだと受取ってはならない。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆめゆめ奥方と御仲違いを遊ばしませぬよう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "傀儡名臣",
                "note": "青空文庫"
              }
            },
            {
              "text": "報奨欲しくないということでは、ゆめゆめないが、それなら長らく懸想した女、どこにもおりませんでしたと、嘘ついて手ぶらで帰ってゆこうか。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げられぬよう、ゆめゆめ油断いたされるな。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "拙者、ただ仔細あって助けねばならぬので、あの者を逃がしたが、お咎めがゆめゆめおぬしに向かう事のないよう、手立てを尽くす所存。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
