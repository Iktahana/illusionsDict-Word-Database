    "definitions": [
      {
        "index": 1,
        "gloss": "going up and down",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第三金時丸は、こうして時々、千本桜の軍内のように、「行きつ戻りつ」するのであった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "と笑うがごとく泣くがごとく恨むがごとく嘲けるごとく、様々声の調子を変じて遠くよりまた近くより、透間もあらせず呼立てられ、得三は赤くなり、蒼くなり、行きつ戻りつ、うろ、うろ、うろ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……はじめは蘆の葉に縋った蟹が映って、流るる水に漾うのであろう、と見たが、あらず、然も心あるもののごとく、橋に沿うて行きつ戻りつする。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら、新宿の街を行きつ戻りつ歩いてみても、いいことは、ございませぬ。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の會話は須田町に近づくまでも同じ題目の上を行きつ戻りつしてゐた。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "境内の敷石の上を行きつ戻りつ、別にお百度を踏み居るは男女二人なり。",
              "citation": {
                "source": "彌次行",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "細身の若い女は殆ど足音もなくその面の上を行きつ戻りつしております。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手に抱えている女の衣裳らしいものをとき／″＼月に翳しては見あらため、くしゃ／＼と揉み畳んで元のように手に抱え、また首を垂れて同じ路面を行きつ戻りついたします。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光に弄ばれ河霧に揺られて細身の若い女の身体は、白紗を敷いたような堤の上を行きつ戻りついたします。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは、手付仕方でご新造さんが堤上を行きつ戻りつしたそのわけ、衣裳を拡げて検めたり、すゝり泣きをしたわけを訊ねました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "事件だというのに、ふらふらと、気取ったとさえ思える調子で通路を行きつ戻りつ、ただ地面を見、空を仰ぎ、向かいの家から壁沿いまでにらみつけていく。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "古川重房の『筑紫紀行』十に、丹後の九世渡の犬の堂、これは戒岩寺と智恩寺と両寺して犬一つ飼いけるが、両寺一度に鐘を鳴らすを聞いて、何方にか行かんと行きつ戻りつして労れ死にせしを埋めたる跡なりとて、林道春の文を雕りたる石碑立てりとある。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつ所を行きつ戻りつして暫くは捕手の眼を逃れていたが、その夜の戌の刻（午後八時）頃にとうとう縄にかかった。",
              "citation": {
                "source": "心中浪華の春雨",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そとへ出ると一緒に、その足は、行きつ戻りつして、門から離れなかった。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに師匠の家の隣家遠州屋という外療道具商でも外療器械を出品し、それが鳳紋賞を得たので、一町内から二軒並んで名誉のことだと、町内を行きつ戻りつ『読売』は読んで歩いては、師匠の家の前では特に立ち留まってやっております。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "初めて博覧会の開かれた当時のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "お光はそれにも気がつかないらしく、狭い仮橋の中程を行きつ戻りつしていたが、やがて立ち停まって四辺を見まわしながら、川にむかってそっと手をあわせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "二町許りで、トある角に立つた新築の旅館の前まで来ると、渠は遽かに足を緩めて、十五六間が程を二三度行きつ戻りつして居たが、先方から来た外套の頭巾目深の男を遣過すと、不図｜後前を見廻して、ツイと許り其旅館の隣家の軒下に進んだ。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは夜がふけるまで、眉をしかめたまま、唇をキッと噛みしめて、絶えず部屋の中を行きつ戻りつしながら、熱しきったナイフをポケットのなかで握りしめ、何かしら凄じい出来事にたいする心構えを、あらかじめ整えていた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋敷の前を行きつ戻りつしているとき、ホームズが切り出した。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は一人で室内を行きつ戻りつしながら、古典劇らしく自身の悪計を独白しているのですが、例の舞台の上に落っこって目の前で燃えているローソクには全く目もくれない。",
              "citation": {
                "source": "一つの感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "物思はしげに御門の邊を行きつ戻りつ、月の光に振向ける顏見れば、まさしく齋藤瀧口時頼なりけり。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鋤を押して行きつ戻りつする個人耕作の畦が消えたといっしょに、社会主義的な方法で農業生産に従事する労働者の心持が次第に農民の感情に近いものとなって来た。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の番になるとばア様は二三の仲間を誘ひ、意味ありげに陰険な視線と薄笑ひとを浴びせ乍ら、私の前を行きつ戻りつした。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "『先生はまだ此處にか』と打ち伴れて、行けば行くほど、どうやら通つたことの無き路なりと氣が付き、行きつ戻りつ、漸く本坊の上に出で、『おうい／＼』と二聲三聲、かなたにも、『おうい』と答へて、待つ間程なく、うれしや闇を照らす車夫の提燈。",
              "citation": {
                "source": "夜の高尾山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな永遠に生きてゐられるやうなそぶりで、人波は行きつ戻りつしてゐた。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "序に今一つ御紹介致しますると、あのボール紙の王冠を頭に戴いて、行きつ戻りつしている年増女で御座います。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "屍体の足の処を行きつ戻りつして考え初めていた熱海検事も、その位置に停止した。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士男はとほうにくれて、甲板をゆきつもどりつ思案にふけっていた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、たった今、もりもりと盛り上って来て、胸一ぱいに蔓りはじめた想念を、もっとハッキリ追って見ようとして、ふたたび、暗い小路に戻って、ゆきつもどりつしはじめた。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
