          "literary": [
            {
              "text": "彼は座敷に立てかけてある弓のことをすぐ考えた。",
              "citation": {
                "source": "庭の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "市九郎は、お弓のこの言葉を聞くと、お弓がすでに恐ろしい計画を、自分に勧めようとしているのを覚えた。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "四（一二三）　先師は仲弓のことについて、こんなことをいわれた。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "弦が徒に風に鳴る弓のこころも　ですけれども。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "登が膳に向かうのを待って、半太夫はおゆみのことを話しだした。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "三度目の正直",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
