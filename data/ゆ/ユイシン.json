[
  {
    "uuid": "c89bf588-8a36-5b60-a99a-96bdf8ca82e4",
    "entry": "唯心",
    "reading": {
      "primary": "ゆいしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
