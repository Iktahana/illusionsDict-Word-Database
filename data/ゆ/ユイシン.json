    },
    "definitions": [
      {
        "index": 1,
        "gloss": "doctrine that all phenomena are produced from consciousness (a central teaching of the Avatamska sutra)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "近頃人々は、「唯物、々々」と云つてゐるが、彼等がさう云つてゐる時くらゐ唯心的なものはないやうである。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾はその彫像を見ると、妾に何ものかが唯心的な理解力を生んだのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "表現派は、多く、戦争に反対し、その悲惨、その暴虐を呪咀し、絶叫してはいるが、唯心論的で、たゞ、主観的な強調に終始している。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯心も唯物も現在、塵となりつつ在る。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう唯心論者もまだ少しはいるのである。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六五課　唯物と唯心　みごとな柿の一籠を地方の未知の人から送って来ました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ唯心的の見方であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "落したら其処でよし、失くしたらそれッきりで可んだから……唯心持だけなんだから……」「じゃ、唯持って行きゃ可いのかね、奥さん、」　と聞いて頷くのを見て、年紀上だけに心得顔で、危っかしそうに仰向いて吃驚した風でいる幼い方の、獅子頭を背後へ引いて、「こん中へ入れとくだア、奴、大事にして持ッとんねえよ。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂唯心論と唯物論、観念論と経験論、目的論と機械論等の如き、人間思考の二大対立がよるところは、結局して皆｜此処に基準している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯物論も唯心論も、其の通處を既徹となし、其の塞處を未究となせば、皆成立ち得る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "東　芋の煮えたも御存知ない西　鰯の頭も信心がら　東のは迂闊漢を刺りて骨に入り、西のは一切世界唯心所造の理を片言に道破せり。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "形而上学にてアイデアリスト（唯心論者）といふものは、文芸上にてアイデアリスト（理想家）といふところの者とは全く別物なり。",
              "citation": {
                "source": "内部生命論",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶対的にアイデアなるものを研究するは形而上学の唯心論なれども、そのアイデアを事実の上に加ふるものは文芸上の理想派なり。",
              "citation": {
                "source": "内部生命論",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の唯物論、彼の唯心論、彼の凡神論、彼等は各々其使命を帯びて来れり、而して彼等は各、其使命の幾分を遂げたり、而して彼等は各々其誤謬を残したり。",
              "citation": {
                "source": "頑執妄排の弊",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯心論を以て唯物論を罵るは誰ぞ。",
              "citation": {
                "source": "頑執妄排の弊",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯物論を以て唯心論を罵るは誰ぞ。",
              "citation": {
                "source": "頑執妄排の弊",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "信仰個条彼れ自身は、藪医術にあらず、繩墨彼自身は藪医術にあらず、唯心論も亦た然り、唯物論も亦た然り、然れども個の信仰個条を擁し、個の繩墨を擁し、個の善悪論を擁し、個の唯心論を擁し、個の唯物論を擁し、之を以て宇宙を法規する唯一の真理と迷信する輩の手に於て、藪医術の本源は存するなり。",
              "citation": {
                "source": "頑執妄排の弊",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が「人生相渉論」を難じて君を苦しめたる返報には、唯心的とか凡神的とか、大層なものを持ち出して、十字軍とは余り大袈裟にあらずや、凡神的とは多分、禅道を唱へらるゝ天知翁を苦るしめる積にて、唯心的とは僕をいぢめる積ならむ。",
              "citation": {
                "source": "人生の意義",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は一転して旧来の迷夢を攪破したるボルテイアとなり、バイロンとなり、ゴヱテとなり、カアライルとなり、自由神学派となり、唯心的傾向となりて、今日に至るまでの思想界の変遷はおもしろきこと限りなし。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "』といつも軍人ぶりのこと葉つきあらあらしきに似ぬやさしさに、兼ねてといはむかく答へむとおもひし略、胸にたたみたるままにてえもめぐらさず、唯心のみ弱うなりてやみぬ。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉慾から犯罪へ――文芸趣味から探偵趣味へ――唯物科学から、唯心分析へ――良心から――無良心へ――。",
              "citation": {
                "source": "探偵小説の真使命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから探偵小説は人類が唯物文化から唯心文化へ転向して行く過渡時代の、痛々しい内省心理の産物ではないか。",
              "citation": {
                "source": "探偵小説の真使命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人でも、社会でも、その精神が唯物思想、もしくは虚無思想を根柢とする資本主義文化組織に陥って行くにつれて、その口にしたり発表したりするところが、ますます高尚に、唯心的に向上して行くのとは正反対に、その表面の趣味傾向がグングン低級化して行くのは、争う余地のない厳然たる事実である。",
              "citation": {
                "source": "甲賀三郎氏に答う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この故に探偵小説は人類の思想傾向が、囚われる唯心文化から囚われざる唯物文化に進化し、更に又、囚われたる唯物文化から、囚われざる唯心文化へ反転して行く過渡時代の痛々しい内省心理の産物でなければならぬ。",
              "citation": {
                "source": "甲賀三郎氏に答う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "些と荒唐無稽に過ぎるようですが、真実で、母｜可懐く、妹恋しく、唯心も空に憧憬れて、ゆかりある女と言えば、日とも月とも思う年頃では、全く遣りかねなかったのでございます。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯物論も唯心論も、その通じる処を既知とし、その通じないところを未知とすれば皆成立ち得る。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても唯物、唯心の議論の多きことよ。",
              "citation": {
                "source": "エンジンの響",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
