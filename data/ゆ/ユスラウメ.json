        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "若い門弟は梅桃のやうに真紅になつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう十日もたつたらノリさん、學校へいかれるかも知れない――と思ひながら家へ歸つて見ると、ノリ子さんにあげる筈のチユーリツプの蕾がゆすらうめのかげで綻びかけてゐました。",
              "citation": {
                "source": "チユーリツプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かき、みかん、もゝ、くり、ざくろ、なつみかん、なし、りんご、ぶだう、さくらんぼ、うめ、びは、ぐみ、ゆず、だいだい、あんず、はだんきやう、ゆすらうめ、の十八種に問題のやまざくらの實をも數へる事に話はきまつた。",
              "citation": {
                "source": "たべものの木",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁さきに見ごとなゆすらうめの木があり、ぎつしりなつた實の色づいてゐるのを見てゐるうちに不意にお前は生れたのだ、と母はよくその縁さきの美しい木の實の熟れるのを見ては私に語つた。",
              "citation": {
                "source": "たべものの木",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供心に私はそのゆすらうめが自分の友だちでゝもある樣な氣がしてならなかつた。",
              "citation": {
                "source": "たべものの木",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこれで、特に氣を使つて植ゑつけたゆすらうめである。",
              "citation": {
                "source": "たべものの木",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "四隅に花壇があって、ゆすらうめ、鉄線蓮、おんじ、薊、ルピナス、躑躅、いちはつ、などのようなものが植えてあった。",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の地面うちだけでも、松、杉、楓、銀杏などの外に、椎、樫、榎、椋、橡、朴、槐などの大木にまじって、桜、梅、桃、李、ゆすらうめ、栗、枇杷、柿などの、季節季節の花樹や果樹があった。",
              "citation": {
                "source": "果樹",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ、よくそこいらの若い者たちが歌っている歌に、３ゆすらうめの木花咲きゃまねく、ひらりひらりと色よくまねく。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆすらうめの木花咲きゃ招く、ひらりひらりと色よく招く。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "造麻呂　なんだか確かに聞えたような気がしたんだが………なよたけ　（声のみ）またりすの子がゆすらうめの実でも食べに来たんでしょう。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "川船のぎいとまがるやよし雀昭和三年六月姉妹や麦藁籠にゆすらうめ昭和三年七月十四日　婦人俳句会。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
