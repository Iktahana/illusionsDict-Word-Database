    "definitions": [
      {
        "index": 1,
        "gloss": "favorable treatment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「物質的」に「精神的」は圧へられてゐるので、精神はスキマからチヨツピリ呟くから神秘的に見えたりするけれど、もともと東洋で精神は未だ優遇されたことはない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルマン教授には三学期通じてずっと世話になって特別の優遇を受けたような気がしていた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや他の一般の敵に對しては、すべて皆心から抱擁し、最も憎むべき忘恩者や裏切者でさへも、降參する以上はすべてを許して優遇した。",
              "citation": {
                "source": "足利尊氏",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればと云つて今自分がどんな反抗的計画を企てたところで、彼を痛い目に合はすことも出来ず「白川を優遇しなければならなかつたんだ」と思ひ染ませることも出来ない。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "未決の囚人であるから、かれはいわゆる役附の待遇をうけるわけには行かなかったが、実際はその以上に優遇された。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢内の者にも讃美され、優遇されるのである。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒は加茂鶴、下物は焼鮎、……身にあまる優遇で野衲いさゝか恐縮の体。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "王の優遇知る可くして、孝孺の恩に答うるに道を以てせるも、亦知るべし。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が忠誠で殉死したのである、其子は優遇されなくても普通には取扱われても然るべきだが、主人の意に負いたと云う廉であろう、伯耆は自ら不遇であることを感じたから、何につけ彼につけ、日頃不快に思っていた。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに何様いうものだったか、其時は勢威日に盛んであった丁謂は、寂照を留めんと欲して、切に姑蘇の山水の美を説き、照の徒弟をして答釈を持帰らしめ、照を呉門寺に置いて、優遇至らざるなくした。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "渾沌は二人を歓迎し大へん優遇した。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでも優遇のつもりかも知れん。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「優遇じゃありませんよ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅井長政なと、可なり優遇して娘婿にしたのにも拘わらず、朝倉征伐に行ったときその背後で背かれた。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、その修史の事業は、当時に於ける国史の定本を提供したと云ふだけではなく、水戸三十五万石の財力を傾注したと云はれる編史事業そのものが、学問の奨励となり、学者の優遇となり、国史の研究を促し、国学勃興の動因となり、尊皇精神の昂揚に多方面から寄与してゐるのである＊。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは遊女屋に取って甚だしい苦痛であるので、せいぜい彼等を優遇した上に、ある場合には幾らかの「袖の下」をも遣って、大抵のことを見逃がして貰うのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は学士になると、別に優遇はせられないまでも、ひどく粗末にもせられないようだ。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏もその希望どおりに優遇をしてやってもよいという気になっていることを、若君は聞いて残念に思った。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬を殉葬した人間の思惑は大要ジョンソンと同じく、犬羊馬豕｜斉しく人が飼った物で人に殺さるるは当然ながら、ややその功軽き羊豕等は毎度その用あるに臨んで、たやすく殺しすなわち忘らるるに反し、大事の場合に主君の命を全うすべき良馬は現世で優遇された報恩に、来世までも御供していよいよ尽忠すべしというのだ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "其頃起つた新体詩などには内心侮蔑を与へてゐながら、しかもそれを優遇しなければならないやうになつて居た。",
              "citation": {
                "source": "尾崎紅葉とその作品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし欧羅巴だったら小説家としても相応に優遇され、二葉亭もまた文人たるを甘んずる事が出来たであろう。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　そういう歌や文章が投稿されてくると、会社は殊更に「キャン・クラブ」で優遇した。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　前にもいう通り、従軍新聞記者に対する待遇や規定がハッキリしていないので、その配属部隊の待遇がまちまちで、非常に優遇するのもあれば、邪魔物扱いにするのもある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは感激のためか、眼病がまだほんとうに癒えないためか、わたしにはよく判らなかったが、いずれにしても快癒出勤のために団十郎がわざわざ長い口上を述べてくれたということは、いかに彼が師匠からも愛せられ、劇場からも優遇されていたかを察することが出来る。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "是位に優遇したならば日本でも喜んで來るだらう、體裁上日本に使者をやりさへすれば朝貢するだらうと思つた。",
              "citation": {
                "source": "日本文化の獨立",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の社でも今の樣に破格の優遇はして呉れなかつたが、其代り私は一日として心の無聊を感じた事が無い。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の社でも今の様に破格の優遇はして呉れなかつたが、其代り私は一日として心の無聊を感じた事がない。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "結構な心掛で、詩人ダンテがその傑作のなかで、因業な家主を地獄に堕した事を考へると、岡野氏が馬の顔を士官に似せたのは思ひ切つた優遇である。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おそろしく近代的なお公家さまで、歌よみを優遇するよりも、苛めることを知つてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おそろしく近代的なお公家さまで、歌よみを優遇するよりも、苛めることを知ってゐる。",
              "citation": {
                "source": "器用な言葉の洒落",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
