        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ブンゼン燈のバリバリと音を立てて吹き付ける焔の輻射をワイシャツの胸に受けながらフラスコの口から滴下する綺麗な宝石のような油滴を眺めているのは少しも暑いものではなかった。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "数え挙げれば天目、油滴、柿、飴、黄伊羅保、蕎麦、青磁等、それも火変りがあり片身変りがあり、自然が器物のために余すなく妙技を振う。",
              "citation": {
                "source": "苗代川の黒物",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒釉で有名な油滴天目と称するものがありますが、今でも形や色を実にうまく作ります。",
              "citation": {
                "source": "北支の民藝（放送講演）",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らなかったら、きっと宋代の油滴と間違えるほどであります。",
              "citation": {
                "source": "北支の民藝（放送講演）",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧壁の上では雲塊が集まり、飛行機はギタギタの油滴に覆われた。",
              "citation": {
                "source": "四日闇夜",
                "author": "THE FOUR DAYS' NIGHT",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
