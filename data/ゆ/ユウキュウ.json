      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "eternal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "時間の悠久を現す一種の音象表現である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を悠久に飽かしめない感動点として山は天地間に造られているのであろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ彼等は悠久に山と共に鎮り、峯に纏って哀愛の情を叙することができる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かがり火は、薪木の性と見え、時折、ぷちぱちと撥ね、不平そうに火勢をよじりうねらすが、寂莫たる天地は何の攪き乱さるる様子もなく、天地創ってこのかた、たそがれちょうものの待つ、それは眠るにも非ず覚めたるにも非ざる中間に於て悠久なるものを情緒に於て捉えようとするかれ持前の思惟の仕方を続けている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷の奧には墓場もあるだらう、人生悠久の流が此處でも泡立ぬまでの渦を卷ゐて居るのである。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「銀嶺」のごときは元来実写を主題にしたものであろうが、軒のつららのものうい雫に悠久の悲しみを物語らせ、なべの中に溶け行く雪塊に運命の不思議を歌わせ、氷河の上に映る飛行機の影に山の高さを示揚させたりするのも他の例である。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれはじきに忘れてしまって世界はもとの悠久な静寂に帰る。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或人はかくばかり美しく荘厳な自然の伴侶となるために、人類には如何に希望多き悠久な未来が残されてゐるかを痛感するだらう。",
              "citation": {
                "source": "自然と人",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悠久な天地は悠久なままで、しかも人を置き去りにして過ぎ去って行く。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悠久無限を想わせるようなものに面すると、私たちの欲望、怒り、知識経験の如何に小さく、つまらないものであるかを嘆じ、慎ましくなるか、あるいは、朗らかになって一大勇猛心の湧くものです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳の注意を振り向けるあらゆるところに、潺湲の音が自由に聴き出され、その急造の小｜渓流の響きは、眼前に展開している自然を、動的なものに律動化し、聴き澄している復一を大地ごと無限の空間に移して、悠久に白雲上へ旅させるように感じさせる。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青山愛執の色に塗られ、」「緑水、非怨の糸を永く曳く」などという古人の詩を見ても人間現象の姿を、むしろ現象界で確捕出来ず所詮、自然悠久の姿に於て見ようとする激しい意慾の果の作略を証拠立てている。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つずつ膚に谷の刻みを持ち、ハレーションを起しつつ、悠久に蒼海を流れ行く氷山である。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古今は悠久であるが、やはり人の心の中に存するものである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "悠久なるかな、人心の小さき花。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、悠久なる……　そんな事をいつたつて、わかるやうな女連ではない。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはわたしへ死のように悠久な憩いを与え、底知れずあたゝかく甘い眠りを誘うふだんのわたしから見ればちょろ／＼して、ぴんと弾ねて、ころ／＼笑ってばかりいる何とも目まぐるたくて手に終えない倶楽部の娘が、一たん胸を据えてわたしを受け止めるとき、またどうしてこんなに深味も厚みもある女になるのであろう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悠久の命の流れに寂然と身を委せて居た。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の天にあるかくのごとく、民の仰いで霑ふかくのごとく、悠久二千六百年、祝典の今日が來たのだ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯の千載一遇の好機会に当り、同胞にして若し悠久の光栄を計らず、徒らに一時の旗鼓の勝利と浮薄なる外人の称讃に幻惑するが如き挙に出でしめば、吾人は乃ち伯叔と共に余生を山谷の蕨草に托し候はむかな。",
              "citation": {
                "source": "渋民村より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、悠久なる……　そんな事をいったって、わかるような女連ではない。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "悠久なる天地の間にいかに自己が小なものかということを強く強く考えて見たまえ。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "理想の光が天空一杯に輝いてゐるではないか、「愛」の波が悠久な姿で静かに工場の裾を洗つてゐるではないか。",
              "citation": {
                "source": "工場の窓より",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "古今は悠久であるがやはり人の心の中に存在するものである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あついは泥棒でしかない水は下流にむかつてその喜びに似た白い泡立ちをたてるその泡立の痕跡はすばやくて捉へがたい通りすぎるものよ開くものよ流されるものよ閉ぢるものよ人は街に群れ、ひそひそと語る森は騒ぐ花開く怒り水流れる喜び悠久として真実は騒がしい捉へ難い早さで走つてゆく。",
              "citation": {
                "source": "小熊秀雄全集-9",
                "author": "詩集（８）流民詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の輪郭が取り拂はれて、現在もない、過去もない、未來もない、唯だ無限の一部、無窮の一部として自分が存在してゐる樣な悠久さを覺ゆる。",
              "citation": {
                "source": "樹木とその葉",
                "author": "自然の息自然の聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "敢て母への便りとせずも、遥かな天地の悠久に呼び掛け度い一片の嘆きの感投詞さへもが困難であつた。",
              "citation": {
                "source": "風流旅行",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命の高貴なる工人として、額は輝き心は跳り、新しき光もて忽ち頭腦を照せる、光明をこそ驅使すべく、征服の途にその歩調ますます勇ましく、悠久たる覆載の下、人こそは至上なれと自らの高貴なるに感ずるならむ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
