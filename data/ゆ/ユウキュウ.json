[
  {
    "uuid": "297450b6-e036-5662-8fa3-85c91eb4a3ba",
    "entry": "悠久",
    "reading": {
      "primary": "ゆうきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
