          "literary": [
            {
              "text": "ひと日ベルナルドオは我前なる卓に腰掛けて、しばし故ありげなる笑をもらしつゝ我顏を見つめ居たるが、忽ち我にいふやう。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "成斎が柏軒の机を借りて久しく還さなかつたと云ふも、故ありげな事である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後四時に私は岡田と交代して改札口を出ると今朝大騒ぎのあった隧道のところにまた人が群立って何か事故ありげに騒いでいる。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            }
          ]
        }
