        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人類の精神の流れが、根柢まで破壊された旧友朋の上に、新たな、健かな、生存の意義を見出そうとしている。",
              "citation": {
                "source": "アワァビット",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嶺南の茘枝は帝王の驕奢を語り、摂州の慈姑は友朋の情誼を語る。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "有朋（友朋）遠方より来たる、亦楽しからずや。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
