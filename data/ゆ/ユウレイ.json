[
  {
    "uuid": "c381063b-51ea-538b-ad14-2027e425b422",
    "entry": "幽霊",
    "reading": {
      "primary": "ゆうれい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
