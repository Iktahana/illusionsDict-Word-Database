[
  {
    "uuid": "8cb56060-322d-54d1-a721-fd2a9a7f4ffa",
    "entry": "夕飯",
    "reading": {
      "primary": "ゆうはん",
      "alternatives": [
        "ゆうめし"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "evening meal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "年来の習慣で、彼は夕飯を終へると散歩に出掛けるか誰か知人を訪問するかしなければ気が済まないのであつた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、台所の方からは三十人に近い此の一家の夕飯仕度の煩雑な音が、これは人の胸を包むやうに彼の所に漂ひ寄つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所の方からは、――三十人に近い此の家族の夕飯仕度で騒がしかつた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――恰度百姓娘の、赤いネルの腰巻を思はせるやうな夏の日の夕飯仕度の頃の中でされるには余りに相応しいそれらの話声や物音であつた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へ帰って夕飯の膳についても絵の事が心をはなれぬ。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲の浦沖を過ぐと云う頃ハッチより飯櫃膳具を取り下ろすボーイの声｜八ヶましきは早や夕飯なるべし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　一人前の水夫になりかけていた、水夫見習は、もう夕飯の支度に取りかからねばならない時刻になった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、彼は水夫等と一緒にしていた「誇るべき仕事」から、見習の仕事に帰るために、夕飯の準備をしに、水夫室へ入った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯の膳には名物の岩魚や珍らしい蕈が運ばれて来た。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯の膳には名物の岩魚や珍しい蕈が運ばれて来た。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "承知しながらもとうとう長居になって夕飯をもてなされ七時頃にいとまもうした附記是は赤木格堂が為に先生の病情を見のまま記して送れるなり明治参拾四年二月十五日明治34年３月『俳星』署名　伊藤左千夫",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯の時に母から「お前はもう大きくなったからお松は今年きりで今日家へ帰ったのだよ、正月には年頭に早く来るからね」と云われて自分は平気な風に汁掛飯を音立てて掻込んでいたそうである。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は夕飯をお松の膝に寄ってたべるのが嬉しかった事を覚えて居る。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の人達は今夕飯最中で盛んに話が湧いているらしい。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜は頭も少しくさえて夕飯も心持よくたべた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆が帰っていよいよ夕飯ということになっても民子の姿は見えない、誰もまた民子のことを一言も言うものもない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所で家中夕飯時であったが、ただそこに母が見えない許り、何の変った様子もない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボストンで、とあるチョプスイ屋へはいって夕飯を喰ったら、そこに日本人のボーイが居て馴れ馴れしく話しかけた。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "借家を探しに行った父親の敬蔵が帰って来て雨上りの水泳場で父娘二人きりの夕飯が始まった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会育ちの美食家の父娘は、夕飯の膳を一々｜伊勢丹とかその他｜洲崎界隈の料理屋から取り寄せた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月半ばのある日、おしかは夕飯の仕度に為吉よりも一と足さきに畑から帰った。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、たすき掛けで夕飯の仕度である。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗本は夕飯がのどを通らなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯時に近所の家から「子供の時間」の唱歌などが聞こえて来ても、宅の機械は固く沈黙を守って冷やかにわれわれの食卓を見下ろしているだけであった。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンの宿に同宿していた何とかいう爺さんが、夕飯後ストーヴの前で旨そうにパイプをふかしながら自分等の一行の田所氏を捉まえて、ミスター・ターケドーロと呼びかけてはしきりにアイルランド問題を論じていた。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはその約束を守つて、夕飯を濟ますと直ぐにＫのをぢさんをたづねた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋのをぢさんは役所から歸つて、もう夕飯をしまつて、湯から歸つてゐた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七がいつもより早く家へ帰って、これから夕飯をすませて、近所の無尽へちょいと顔出しをしようと思っていると、小さい丸髷に結った四十ばかりの女が苦労ありそうな顔を見せた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お月夜は、まだよいのくちで、子どもたちは野良からかえったおやたちと、やっといま、ゆうはんをたべおわったばかりなのでした。",
              "citation": {
                "source": "月夜のかくれんぼ",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
