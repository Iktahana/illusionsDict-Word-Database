        "examples": {
          "standard": [
            {
              "text": "秋風が吹く頃、庭の片隅で友禅菊が可憐な花を咲かせ始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "薄紫色の友禅菊は、秋の庭に落ち着いた彩りを添えてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友禅菊の花束を贈ったら、とても喜んでくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "――黎々火さんが予想よりも早くやつてきてくれた、草花の苗をどつさり持つて、――さつそく植ゑる、――縞萱、小米桜、桔梗、雁皮草、熊笹蘭、友禅菊、秋田蕗、等、等。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "友禅菊という、葉や、咲きかたや色の今めかしい品のない花だが、芒のかげに一叢になっているのは、邪魔にもならないのでそのままにしてあるが、初元結にはとてもおよばない。",
              "citation": {
                "source": "紫式部",
                "author": "――忙しき目覚めに",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
