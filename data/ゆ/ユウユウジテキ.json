[
  {
    "uuid": "c3a7e421-e52a-5710-8746-2eca96dbbc05",
    "entry": "悠々自適",
    "reading": {
      "primary": "ゆうゆうじてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
