        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まず録糸にてつくる魚翅、湯葉でつくれる火腿、たまに彼女はかつて母とともに杭州の西湖にある功徳林｜蔬食処へ精進料理を味わいに行った。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　飯沼は大きい魚翅の鉢へ、銀の匙を突きこみながら、隣にいる和田をふり返った。",
              "citation": {
                "source": "一夕話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、僕が此処で、必ず第一番に註文するのは、紅焼魚翅だ。",
              "citation": {
                "source": "神戸",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚翅も随分方々で食ってみるが、こういう、ドロドロッとした、濃厚なスープには、ぶつからない。",
              "citation": {
                "source": "神戸",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京で食うのは、魚翅もカタマリのまんまのや、それの澄汁のような、コンソメのようなの、又は、ポタージュに近くても、濃度も足りないし、色々な、オマケの如きものが混入していて、つまらない。",
              "citation": {
                "source": "神戸",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "平和楼以前に、僕は、戦後二三年経って、神戸のトアロードの、かなり下の方にあった、福神楼というので、紅焼魚翅を食った。",
              "citation": {
                "source": "神戸",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八日　大好きな紅焼魚翅を食いたさに、ハネ後、神戸迄ノシて、Ｈへ行く。",
              "citation": {
                "source": "このたび大阪",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来た魚翅を一目見て、がっかり。",
              "citation": {
                "source": "このたび大阪",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち、神戸平和楼の魚翅を思ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理は命じてあったらしく、魚翅が来た。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
