      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "champion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
