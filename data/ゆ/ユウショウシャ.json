[
  {
    "uuid": "1c3d3970-ee4d-5a2f-8f98-897c4f765b43",
    "entry": "優勝者",
    "reading": {
      "primary": "ゆうしょうしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
