    "definitions": [
      {
        "index": 1,
        "gloss": "to cross (each other)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もし吾々人間にこの半分の能力があれば、銀座の四つ角で自動車電車の行き違う間を、巡査やシグナルの助けを借りずとも自由自在に通過することが出来るにちがいない。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰げば高き絶壁の上に、大勢の人の行き違う姿が見えた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の軋る音、乱れ足で行き違う群集の影。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで行き違う郭の芸人なぞは、「いよう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人乗の人力車が行き違うことの出来ぬ横町に這入るのだから、危険はもう全く無いと云っても好い。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い女どうしは近よりながら、互いに用心深くお互いを偵察し合いながら行き違う。",
              "citation": {
                "source": "軽井沢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "行き違う時に「どうもお邪魔さまで」といって自分の顔をちらと見た。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしわれわれ人間にこの半分の能力があれば、銀座の四つ角で自動車電車の行き違う間を、巡査やシグナルの助けを借りずとも自由自在に通過することができるにちがいない。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた彼女の心に関しては、街で行き違う見ず知らずの女の心と同じように、何も私は知っていなかったんです。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "二台の人力車がらくに行き違うだけの道を隔てて、向いの家で糸を縒る※車の音が、ぶうんぶうんと聞える。",
              "citation": {
                "source": "二人の友",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして髪毛や、眼色や、顔色が赤や、白や、鳶色や、黒等とそれぞれに違った人々が、各自に好きな仕立ての着物を着て、華やかに飾り立てた店の間を、押し合いへし合して行き違う有様は、まるで春秋の花が一時に河を流れて行くようである。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "間違ったのかと思って振り返る――兵站部は燈火の光、篝火の光、闇の中を行き違う兵士の黒い群れ、弾薬箱を運ぶかけ声が夜の空気を劈いて響く。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへゆく」　挨拶なしで行き違うわけにもいかないので、千枝松の方からまず声をかけると、翁はゆがんだ烏帽子を押し直しながら、いつもの通りに笑っていたが、その頤には少し痩せがみえた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "計画したことはみな行き違う。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "禹徳淳　しかし、蔡家溝は小さな駅だが、列車の行き違うところで、停車時間が長いというから降りたんじゃないか。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたに行き違うた残念さも漏してありました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "行き違う人の靴がひどくきらきらと眩く光った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀愁にとざされた露月は、行き違うまで、その人の姿にも気がつかなかったのでしたが、ふと、鼻を撲つ好もしい香りに、編笠をかかげて見返えりますと、僕の肩にかたげられたは、今｜剪り前ての園咲の白つつじが、白く涼しく匂っているのです。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "舎営の門口のきらめく歩哨の銃剣、将校｜馬蹄の響き、下士をしかりいる士官、あきれ顔にたたずむ清人、縦横に行き違う軍属、それらの間を縫うて行けば、軍夫五六人、焚火にあたりつ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりの人が途中で逢えばうぬが人間なら、おれも人間だぞと心の中で喧嘩を買いながら行き違う。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "汀近くで待っていた梶原景時は、ゆうべのうっぷんをこの時に晴らそうというつもりか、行き違う平家の船を熊手で引っ掛け、引っ掛け、敵の舟に乗り移って散々に暴れ廻り、首級をいくつか分捕ってこの日第一番の手柄をあげた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い足場の間に人は夜業する照明燈の蒼白い強い光線を見、行き違う鉄骨の複雑な影のこい錯綜から、これは巨大な何かが地からもり上って来るのを、人間がたかってある一定の大いさまでおしつけ、まとめて、熱心にかためようと働いていると云う感じを受ける。",
              "citation": {
                "source": "子供・子供・子供のモスクワ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フリイデマン氏と行き違うわずかな人々の足音が、歩道の上にこだまを返した。",
              "citation": {
                "source": "小フリイデマン氏",
                "author": "DER KLEINE HERR FRIEDEMANN",
                "note": "青空文庫"
              }
            },
            {
              "text": "行き違う列車はますます数多くなって、その汽笛で空気をつんざき、うとうとしてる乗客の眠りを覚まさした。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "このたびの道中に於ても、米友が――若い娘を見るごとに、それと行き違うごとに、物に驚かされたように足を止めて、その娘の面を篤と見定め、後ろ姿をすかし、時としては、ほとんど走り寄って縋りつくほどにして、そうして、諦めきれないで、言おう様なき悲痛の色を浮べて立つことがある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして二人の風流客が、まもなく関の藤川の橋を渡りかけた時分に、「今晩は、いい月夜でございますねえ、寝物語からおいでになりましたか、へ、へ、御風流なことで……お大事においでなさいまし」　通りすがりに、イヤに丁寧なお世辞を二人の風流客に送って、行き違う旅人がありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国へ行こうとしている伸子の心には、見なれたその通りの夕暮の光景や、ゆきちがう小さな女工たちの姿が永年見なれている界隈の生活だけに印象ぶかく迫った。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへたどり着くまで、左右の妓楼から呼びかける声や、ゆきちがう、ぞめきの客たちの眼が、みな彼を辱しめ、嘲弄するもののように感じられたのである。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
