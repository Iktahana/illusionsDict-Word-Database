    "definitions": [
      {
        "index": 1,
        "gloss": "God (in monotheism)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
