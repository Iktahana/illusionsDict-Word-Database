    "definitions": [
      {
        "index": 1,
        "gloss": "someone who is going",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "空いつの間にか曇りてポツリ／＼顔におつれどさしたる事もなければ行手を急いで上へ／＼と行く。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓より首さしのべて行手を見るに隧道眼前に水色｜縮緬を延べたらんごとく、遠山｜糢糊として水の果ても見えず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石の急壁を登りかけていると、雷鳥が一羽、ちょこちょこと前を歩いている、晃平が、狙いをつけて一発放したが、禽は横に逸れて、截られた羽が、動揺した空気に白く舞った、一行手取りにするつもりで、暫く追いかけて見たが、掌中の物にはならなかった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験室ばかりで仕事をしている学者達はめったに引っかかる危険のないようなこうした種類の係蹄が時々「天然」の研究者の行手に待伏せしているのである。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "行手の連峯は雨雲の底面で悉くその頂を切り取られて、山々はたゞ一面に藍灰色の帷帳を垂れたやうに見えてゐる。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "行手の連峰は雨雲の底面でことごとくその頂を切り取られて、山々はただ一面に藍灰色の帷帳を垂れたように見えている。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右から木立の茂った山の崖裾の間をくねって通って行く道は、ときどき梢の葉の密閉を受け、行手が小暗くなる。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生時代には学期試験とか学年試験とかいうものがやはりそうした峠になっていたが、学校を出ればもうそうしたものはないかと思うと、それどころか、もっともっとけわしい山坂が不規則に意想外に行手に現われて来た。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして行手の闇の中にまたたく希望の灯影といったようなものを作家とともに認めてささやき合うような気がする。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、わたしはどこへ行くのか知らない、おほきな、いきもののやうな月が、ぼんやりと行手に浮んでゐる、さうして背後のさびしい往来では、犬のほそながい尻尾の先が地べたの上をひきずつて居る。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりひらの行手に覆面が跳び出す。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、とろんとして來た眼を見張りながら、私は水島君の視線の行手を追つた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎ原の行手はまだ遠かつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とも角も思ふ処は思ふ処として、私は氏のその道程の行手を静に見守つてゐたいと思ふ。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "從つてその思想や人生觀の凡てを愛を以て裏づけて行かうとする氏の作家としての今後は、どんな轉換を見せて行くかも知れませんが、その理智の人としての弱點から釀されて來る何物かは、可成り氏の行手にいろ／＼な曲折を出すだらうと思はれます。",
              "citation": {
                "source": "三作家に就ての感想",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は頭を轉じて行手を見た。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "教育家為政者は行手の橋の袂の所在を充分に地図の上で研究しておかなければならないと思う。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでわれわれは身を投げるか、弁慶の薙刀の※となるか、夜鷹に食われるか、それともまた鍋焼うどんに腹をこしらえて行手の旅を急ぐかである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "行手に白い電燈がついている。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは行手の白い電燈と道のほんのわずかの勾配のためである。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒ぐろとした杉林がパノラマのように廻って私の行手を深い闇で包んでしまっている。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "行手は如何ともすることのできない闇である。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそのとたん、道の行手にパッと一箇の電燈が見える。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の神経は暗い行手に向かって張り切り、今や決然とした意志を感じる。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は行手の青く光ってゐる仙人の峡を眺め、それからふと空を見て、思はず、こいつはひどい、と、つぶやきました。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その工夫の人は立ちあがって窓から顔を出し手をかざして行手の線路をじっと見てゐましたが、俄かに下の方へ「よう、」と叫んで、挙手の礼をしました。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉の間に深い皺をよせ、血眼になって行手を見つめて駆けっているさまは餓えた熊鷹が小雀を追うようだと黒田が評した事がある。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "行手の堤の蔭には不格好に尨大な黒ずんだ建物がごつちやになつて平らな麥畑の中に建つてゐた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の前の展望は段々狹まつて、行手の右側には街道と並行に山の裾が逼り出した。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船から落っこっても、大丈夫ね、犬掻き位は出来るわね」　蓑吉はもう、行手に心を蒐めていた。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
