    "definitions": [
      {
        "index": 1,
        "gloss": "to come and go",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして行き交う厚い外套と雪靴の街、子供達の雪合戦の街、橇の其処にも此処にも散ばる街――その街はクリスマスの仕度の賑わう街なのです。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それの飛んで行った方角には日光に撒かれた虻の光点が忙しく行き交うていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、二人の胸の中に行き交う想いは、ヴァイオリンの音になって、高く低く聞こえている。",
              "citation": {
                "source": "秋の歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドリアンは公園の中を漫ろ歩くにしても、ピカデリイを散歩するにしても、行き交う人々の顔をいちいち、彼等が一体どんな生活を営んでいるものかと怪しみながら、狂いじみた好奇心でながめた。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は幾度もピントを合せ直しました、併し、あまり焦立ったために、却って最初の正しい焦点をなくして一層うろたえている中に、情ないことにも、彼女の姿はやがて行き交う人々の蔭へかくれてしまいました。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、果して、行き交う人の殆んど全部が、私の帽子に目をひかれて、私を振り返って見てくれた。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "遉の銀座通りではあったが、行き交う人々はみんな身を竦めながら忙しそうにして歩いていた。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の物音や、眼の前を行き交う人々が何だか遠い下の方にあるように思われた。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐藤さんしっかりやれえ」　師走の風が銀座通りを行き交う人々の足もとから路面の薄埃を吹き上げて来て、思わず、あっ！",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "島民家屋の丸竹を並べた床の上に、薄いタコの葉の呉蓙を一枚敷いて寝ていた時、私は、突然、何の連絡も無く、東京の歌舞伎座の、（それも舞台ではなく）みやげもの屋（あられや飴や似顔絵やブロマイドなどを売る）の明るい華美な店先と、その前を行き交う着飾った人波とを思出したのだ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "石垣に寄する小波の音といい、朝あがりの日かげに忙がしげに行き交うておる船頭や仲仕や客人や泣いてる子供や、聞きわけかぬるふれ声の女の魚売やの姿が、惶しい自分の心に如何にも粗雑な新開港であるという感じを抱かせた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座の鋪道の行路樹には、軽い微風がそよいでいたが、塵をたてるほど強いものではなく、行き交うている会社員たちの洋服はたいてい白っぽい合着に替えられて、夏には適わしい派手な色のネクタイが、その胸に手際よく結ばれていた。",
              "citation": {
                "source": "青木の出京",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕が開くと、狂言方や下回りの役者たちが、五、六人左右に忙しく行き交う。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時の間にか入り込んで来た外客のために、辺りは平常のざわめきに立ち返り、階下の楽器部から明朗なジャズの音が、ギャラリーを行き交う人々の流れを縫ってゆるやかに聞えていた。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "壮麗な建物の打ち続いた、美しい花魁の行き交うている、錦絵にあるような色街だったのです。",
              "citation": {
                "source": "島原心中",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り返つて見あげると、皎々と灯りのついた部屋／＼の窓が、一勢に外に向つて開け拡げられて、多くのゾイラス共の影が縦横に行き交うてゐた。",
              "citation": {
                "source": "ゾイラス",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな町ながらちまたには車馬が行き交うてゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "女達が華やかに笑いさざめいて行き交う街道の一重彼方には、まるで忘られたような、祖先のインディアンが、黒い着物に包まれて、森の中に暮して居ります。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりが南国的な雰囲気にあったせいか、その美少女の色鮮やかな原色の紅と黄と青との大胆な洋装が、いかにもしっくりと合って、銀座などで相当行き交う美少女には見馴れていた筈の私が、はあっと眼を見張った位であった。",
              "citation": {
                "source": "脳波操縦士",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリでは、一時日華の戦争いよいよ開始という大見出しの記事さえ掲げられ、行き交う人人の眼を奪った日のことも、実は、今日の予震のようなものかもしれなかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、深く行き交う友達がない。",
              "citation": {
                "source": "生活",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宏子は、歩道のない路を行き交う自動車に悩まされながら、大通りへ出て、三丁目の方へ向って行った。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松の温泉に景勝の第一を占めて、さしも賑わい合えりし梅屋の上も下も、尾越しに通う鹿笛の音に哀れを誘われて、廊下を行き交う足音もやや淋しくなりぬ。",
              "citation": {
                "source": "書記官",
                "author": "川上眉山",
                "note": "青空文庫"
              }
            },
            {
              "text": "親父は行き交う子供の顔をいちいちのぞきこみながら、いなくなっては生き甲斐もないという大切な子供について、語り止まなかった。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生さまあ――」と親爺は行き交う人間の顔に眼を光らせながら、なおも語りつづけた。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "車窓からは高層な建築、広い道路の石畳、街路樹の濃い常磐葉、電燈と瓦斯の赤光白光の入りまじり、行き交う市民の群、自動車の攻撃的で威嚇するような探光と轟音。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "行き交う往来の人々など、その娘の際立った風姿に、すき心を刺戟されたと見え、振り返ったり横目で見たりした。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "行き交う多くの人々は、いいあわせたように帽子もかぶっていなければ、オーバーも着ていない。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "又分らせ様とも仕ないけれ共、漸う育ち掛けて来た感情の最大限の愛情を持って対した私と、宗教的に馴練されたどちらかと云えば重苦しい厳粛な愛情を注いで居た彼との間に行き交うて居た気持は、極く単純ではあったにしろ他の何人の手出しも許されない純なものであった事を思い出す。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当を言えば地上にはもともと路はあるものではない、行き交う人が多くなれば路はその時出来て来るのだ。",
              "citation": {
                "source": "故郷",
                "author": "魯迅",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
