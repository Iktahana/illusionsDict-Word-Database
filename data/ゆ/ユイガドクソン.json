[
  {
    "uuid": "3b1b3b28-3c03-54c8-ba33-1b58aedbc5a0",
    "entry": "唯我独尊",
    "reading": {
      "primary": "ゆいがどくそん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "throughout heaven and earth, I alone am the honored one",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "誰れに恐れる事も諛う事も入らぬ、唯我独尊の生涯で愉快だろうと夢のような呑気な事を真面目に考えていた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何先生は、どうだって、あなたは唯我独尊のお態度で、てんで無関心の御様子だったではありませんか。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大般涅槃経あたりに行くと、世尊がいかに唯我独尊であつたかといふことが愈わかつて来る。",
              "citation": {
                "source": "孤独と法身",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの偉大なる釈迦は、「天上天下唯我独尊」を主張し終せたばかりで、あれ程の者になつたのではないか。",
              "citation": {
                "source": "親孝行",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」答「いまだに象牙の塔に住み、唯我独尊主義を奉じている、偉い人達のご託宣でしょう」　問「此処で問題を変えましょう、探偵小説が流行って来ましたね。",
              "citation": {
                "source": "大衆文芸問答",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぎんは釈迦が生まれた時、天と地とを指しながら、「天上天下唯我独尊」と獅子吼した事などは信じていない。",
              "citation": {
                "source": "おぎん",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "天上天下唯我独尊に落ちつくこと、そこが人間知識の相場市場だ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういえば、釈迦が天上天下唯我独尊と唇から発した日は、十二月八日だった。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（それは母胎を離れた後、「唯我独尊」の獅子吼をした仏陀よりもはるかに手よりのないものである。",
              "citation": {
                "source": "続西方の人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、「先駆的」なる美名をかかげ、徒らに晦渋な表現、幼稚な気取り、唯我独尊的理論を押しつけないこと。",
              "citation": {
                "source": "新劇の始末",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけの条件の下でこれだけの秩序が保てれば見上げたもので、日本人のたのもしさ、力強さに気づくことを知らないようでは、その人の方が暗愚であり、つまり敗戦と共に亡びて然るべき誤れる憂国者、誤れる道徳家、唯我独尊的愛国自認者であるにすぎない。",
              "citation": {
                "source": "男女の交際について",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "我儘で、唯我独尊、一杯の茶のサービスが人格にかゝはる問題だつた。",
              "citation": {
                "source": "古都",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　信長は生来の性根が唯我独尊、もとより神仏を信ぜず、自分を常に他と対等の上に置く独裁型の君主であつたが、晩年は別して傲慢になつた。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "濡手拭を頭にのせたまゝ、四体は水の滴るゝまゝに下駄をはいて、今母の胎内を出た様に真裸で、天上天下唯我独尊と云う様な大踏歩して庭を歩いて帰る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして、専制君主の専横をもって一切の外界を撥無するところの、自我の唯我独尊的な新しい自由への衝動は、馬鹿馬鹿しいほどな気儘な、皮肉な空想的な若い天才たち、半天才、四分の一天才の連中を陶酔せしめた。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして、唯我独尊とは対蹠的なものである。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "托胎の月満ちて、唯我独尊を叫ぶ産声があがる。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣方の如きは、却って客の方から教えてやるといった工合に、唯我独尊の境地に遊ぶ事が出来るという関係から、博士三十数年来一貫して利根川の鱸釣に終始して来た。",
              "citation": {
                "source": "釣聖伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、学者どもの偏狭さ、唯我独尊振りには、聊かあきれたよ。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜麻拉亜の景色如何と人問はゞ天上天下唯我独尊岳勢巍巍圧四陬、摩天積雪幾千秋、人間一接斯光景、豪気将呑五大洲。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "）雪峰巍立碧雲間、鎮圧閻浮幾万関、鶴林一夜煙散後、空留唯我独尊山。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "沙羅双樹の林の一夜、煙の散り消えたのちは、ただ唯我独尊の山が残ったのであった。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己満足、唯我独尊、驕慢、自慢、自家広告、自分免許………何れも皆禁物である。",
              "citation": {
                "source": "霊訓",
                "author": "SPIRIT TEACHINGS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云われて見れば、この唯我独尊主義も、決して簡単な妄想ではなくて相当複雑な虚妄であることに、戒心しなければならないだろう。",
              "citation": {
                "source": "道徳の観念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に天上天下唯我独尊の釈迦牟尼｜如来が至尊の王位と金殿玉楼すなわち天下の富貴を捨てて破衣乞食の出家となって我ら一切｜衆生のために身命を抛って御修行せられたことを思いますと、我らの苦労は何でもないことと容易に決心がつきます。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時分は一番ヒマラヤ山を見るの好時期ではあるけれども、それでも大抵九時か十時頃からは雲が出て見えなくなるのが例ですから、先生を早く起して案内したので井上先生をして「只看唯我独尊山」というてエヴェレストに三嘆せしめたです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに於てか、蘭学の研究は益々盛んになり、兵書といわず、解剖学といわず、病理学といわず、更に博物学、地理書を問わず、あらゆる方面のものが翻訳され、これらの知識に依って、日本は唯我独尊ではならぬこと、日本以外に勢力強大にして、而かも野蛮ならざる文明開化の国々のあることが知れた。",
              "citation": {
                "source": "東西両文明の調和を論じて帝国の将来に及ぶ",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども彼はなお、クリストフが唯我独尊主義者の真似をしている――（彼は本心から唯我独尊主義者たり得る者があろうとは想像だもしなかった）――のだと考えた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "利己主義的な無政府主義は、人間を本質的に利己主義者だとしながら、しかも無政府を唱えるのであるが、それはすなわち強者の利己的な唯我独尊の対立状態をよいとすることになろう。",
              "citation": {
                "source": "政治学入門",
                "author": "矢部貞治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
