        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たけは、油断大敵でせえ、と言つただけで格別ほめもしなかつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "油断大敵のれいである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はここで、いい気持になっているが、油断大敵ですぞ！",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつとなくどこからとなく鼠が来てゐる、猫はお先に来てゐる、油断大敵ですぞよ！",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮沿海からドンの音が一掃されたので、最早大願成就……金比羅様に願ほどきをしてもよかろう……と思ったのが豈計らんやの油断大敵だった。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "油断大敵、用心せざるべからず。",
              "citation": {
                "source": "学者安心論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "油断大敵といふ洒落ではありませんが、正に、それに類する大敵であります。",
              "citation": {
                "source": "文芸の側衛的任務",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "油断大敵とは、よくいったものですなあ」",
              "citation": {
                "source": "宇宙尖兵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "餌をやつても食ひつかぬところに怪しい節々があると睨んではゐたが、油断大敵さ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "油断大敵は、そこのところだ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを果すまでは油断大敵と心得、いっそう気を緊めてやって貰いたい、あの馬鹿者のことは宙野と金吾に任せるから、ぬかりなきよう特に注意して頼みたい、ではこれで――」　そして密会は終った。",
              "citation": {
                "source": "若殿女難記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
