    },
    "definitions": [
      {
        "index": 1,
        "gloss": "covered",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "○扉を細めにあけて、そこに繩をはった有蓋貨車に人がのって走って行った。",
              "citation": {
                "source": "無題（十二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "物件が空家になると即座に購入し、大型の有蓋貨物車に屋根裏実験室の全ての物品を載せ、夜陰に乗じて運んでしまった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "復員兵と解除になった徴用工とを満載した有蓋貨車、無蓋貨車とすれ違いながら那須の荒野にかかった。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、ぼくの乗るのは、たいてい、当時一列車に三台ぐらいはかならずはさみこまれていた、有蓋貨車の代用客車だった。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらを見失って、のぼせて、へとへとになりながら、橋を渡ったり、汚ないふくろ小路へはいりこんだりしてさがし求めては、かれらがいきなり、さけようのないせまい有蓋街路でむこうからきかかるのを見ると、死ぬような苦悩の数分間をたえしのんだ。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭坑行の坑木が積んである、有蓋貨車なので、光丸の姿は見えない。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
