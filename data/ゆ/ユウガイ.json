  {
    "uuid": "b12167d5-1156-5d52-af74-90dd493dc20d",
    "entry": "熊害",
    "reading": {
      "primary": "ゆうがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "damages caused by bears (on human settlements, including attacks on humans)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "現塲に至り、彌吾吉は馬匹の群を一見して馬匹中に異動あり、或は不足なりとて、尚調査するに、仔馬一頭は熊害にて臀部に裂傷あるを見たり。",
              "citation": {
                "source": "関牧塲創業記事",
                "author": "関寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜熊害は仔馬一頭を傷めたるのみなり。",
              "citation": {
                "source": "関牧塲創業記事",
                "author": "関寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れ熊害にかかりたるものなり。",
              "citation": {
                "source": "関牧塲創業記事",
                "author": "関寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月、土人イコサックル我牧塲内の熊害を防ぐ為めに居ると定めて、橋畔に小屋をかける。",
              "citation": {
                "source": "関牧塲創業記事",
                "author": "関寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日、馬、熊害にかかる。",
              "citation": {
                "source": "関牧塲創業記事",
                "author": "関寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
