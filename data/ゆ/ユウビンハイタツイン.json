        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は縁側に出て日向ぼっこをしながら、郵便配達員の近づく足音を一秒でも早く聞き当てようと骨を折った。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便配達員にもう一つ質問して終わります。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで郵便配達員、その召使いの名前を知りませんか」証言人「申し訳ありませんが、知りません。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙が非常に薄く、米国では滅多に使いません」　郵便配達員の後にほかの証人が続いたが、ほとんど話に中身はなかった。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便配達員が店に手紙を投げ込むと、棚に置かれる。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
