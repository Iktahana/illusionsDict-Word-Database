    "definitions": [
      {
        "index": 1,
        "gloss": "lingering light of evening",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二尺三寸ばかりの刀の中心に彫った文字を庭先の夕明りに透かしてみた。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は暮れたけれども、まだ夕明りである。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてお二階の私の室に帰りますと夕明りのさす窓際に坐って、怖いものでも見るようにソッと開いて見ました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は猶も力を込めて戸を推したが、メリメリと蝶番が毀れて戸は下の屋根へ落ち、室の中が一時に明るく成った、とは云え夕明りで有るから昼間ほどには行かぬが幽霊の正体を見届けるには充分で有る。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕明りで見るのであるからこまごまとした所はわからなくて、後ろにはもう闇が続いているようなのが飽き足らず思われた。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "植え込みの花草が虫の音に満ちた野のように乱れた夕明りのもとの夜を大将はながめていた。",
              "citation": {
                "source": "源氏物語",
                "author": "横笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕明りも霞んだ日のことでさやかには物を見せないのであるが、つくづくとながめているうちに、桜の色を着たほうの人が恋しい姫君であることも見分けることができた。",
              "citation": {
                "source": "源氏物語",
                "author": "竹河",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い女房たちの打ち解けた姿なども夕明りに皆美しく見えた。",
              "citation": {
                "source": "源氏物語",
                "author": "竹河",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮れがたになり時雨の走るのも趣があって、菊へ夕明りのさした色も美しいのを御覧になって、蔵人を召して、「今殿上の室にはだれとだれがいるか」　と、お尋ねになった。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "東の高欄によりかかって、叢の中に夕明りを待って咲きそめる花のある植え込みを薫はながめていた。",
              "citation": {
                "source": "源氏物語",
                "author": "蜻蛉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、下には唯青い山々が夕明りの底に見えるばかりで、あの洛陽の都の西の門は、（とうに霞に紛れたのでしょう）どこを探しても見当りません。",
              "citation": {
                "source": "杜子春",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は近親の喪を弔ふやうに、何時の間にかまつ白な裳を夕明りの中に引きずつてゐた。",
              "citation": {
                "source": "老いたる素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕明り　　　　　　――Eunice Tietjens――　乾いた秋の木の葉の上に、雨がぱらぱら落ちるやうだ。",
              "citation": {
                "source": "パステルの龍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "又同じ時の歌に　梅の実の黄に落ち散りて沙半ば乾ける庭の夕明りかな　山の湯が草の葉色を湛へしに浸る朝も物をこそ思へ　などがある。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕明り葉無き木立が行く馬の脚と見えつつ風渡るかな　疎らな冬木立に夕明りがさして歩いてゆく馬の脚の様に思へる、そこへ風が吹いて来て寒むさうだ。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、下には唯青い山々が夕明りの底に見えるばかりで、あの洛陽の都の西の門は、（とうに霞に紛れたのでせう。",
              "citation": {
                "source": "杜子春",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその刹那にこの女が、夢の中にのみ見る事が出来る、例えばこの夏の夕明りのような、どことなくもの悲しい美しさに溢れている事を知ったのであった。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはちょうど榕樹の陰に、幼な児を抱いていたのですが、その葉に後を遮られたせいか、紅染めの単衣を着た姿が、夕明りに浮んで見えたものです。",
              "citation": {
                "source": "俊寛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣道具を日本から携へて来られた佐藤さんは、その夕明りの下で草の上に蹲がみながら鮒を釣られた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "たそがれの青き光に半面を空に向けつつ泣ける石像　青味のある夕明りの射して来る方へ半面を向けて居る石像は泣いて居ると云つたのであつて、その如く見えると云はず、其れであると云ふ手法を用ひたのである。",
              "citation": {
                "source": "註釈與謝野寛全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は吊り革につかまったまま、夕明りの中に電燈をともした麹町の家々を眺め、今更のように「人さまざま」と云う言葉を思い出さずにはいられなかった。",
              "citation": {
                "source": "冬",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "初夏の夕明りは軒先に垂れた葉桜の枝に漂っている。",
              "citation": {
                "source": "十円札",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその夕明りの中にしみじみこの折目のついた十円札へ目を落した。",
              "citation": {
                "source": "十円札",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから庭先の夕明りの中へ長ながと巻煙草の煙を出した。",
              "citation": {
                "source": "十円札",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "……陳は卓子に倚りかかりながら、レエスの窓掛けを洩れる夕明りに、女持ちの金時計を眺めている。",
              "citation": {
                "source": "影",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると房子は夕明りの中に、もう一度あでやかに笑って見せた。",
              "citation": {
                "source": "影",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に咲き始めた薔薇の花は、木々を幽かにする夕明りの中に、薄甘い匂を漂わせていた。",
              "citation": {
                "source": "神神の微笑",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし後には夕明りが、径を挟んだ篠懸の若葉に、うっすりと漂っているだけだった。",
              "citation": {
                "source": "神神の微笑",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
