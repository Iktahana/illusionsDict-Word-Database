        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つつましき尿の香の滲み入るほとり、腐れたる酒類の澱み濁りてそこここの下水よりなやみしみたり、白粉と湯垢とのほめく闇にも青き芽の春の草かすかににほふ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の前の湯の中に動いてゐる微塵に似た湯垢の一つ／＼にはかすかに虹の樣な日光の影が宿り、湯槽の縁から溢れ出る湯は同じくほがらかに日が當つて乾き切つてゐる流し場の一端に細い小波をたてゝ流れて行つてゐます。",
              "citation": {
                "source": "樹木とその葉",
                "author": "伊豆西海岸の湯",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが湯垢やら硫黄やらでヌラ／＼になつてゐた。",
              "citation": {
                "source": "湖畔手記",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯垢の香に私はしみた。",
              "citation": {
                "source": "ふるさとに寄する讃歌",
                "author": "夢の総量は空気であった",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯垢が窪み窪みに溜つてぬるぬるして居ます。",
              "citation": {
                "source": "佐渡が島のこと",
                "author": "江南文三",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴槽の底は天然の岩、その間から噴き出すのと、浴槽の辺を越して流れ込むのと、両方なので、底に湯垢がたまるということは無い。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "崕からも二、三箇所湯がにじみ出して、岩面に湯垢が木目のように附着している。",
              "citation": {
                "source": "秋の鬼怒沼",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "孰れも湯垢が岩壁の面に奇怪なさまざまな線を描いている。",
              "citation": {
                "source": "黒部川を遡る",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平家のころは、ここは「湯垢離の場」といっていたから、熊野｜行幸の随身たちが、わんさと、泊ったことだろうと思う。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕日さびしき　岩角の道御神楽のねりゆく山も　昏み来て、級田の氷光り顕つ　見ゆあか／＼と　燎火は燃ゆる。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
