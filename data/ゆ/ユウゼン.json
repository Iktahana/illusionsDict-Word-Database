  {
    "uuid": "3b9f380c-73aa-51f5-adff-9fc1ca722d1b",
    "entry": "悠然",
    "reading": {
      "primary": "ゆうぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "calm",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と断じて、悠然と引上げ、「ああ、やっぱり、ヒットラーに限る！",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後から彼が悠然と歩んだ。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙ君は、持つてゐたステツキを振り上げて、悠然とその犬を撃退してくれたのですが、私は一時、死ぬばかりでありました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとく我儘であるくせにまた甚だしく臆病な彼は、自分で断然年賀端書を廃して悠然｜炬燵にあたりながら彼の好む愚書濫読に耽るだけの勇気もないので、表面だけは大人しく人並に毎年この年中行事を遂行して来た。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝道場内　用意万端整えて白倉、悠然と進み出る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵、木太刀を捨てて塵打ち払い、悠然と立ち出でんとする。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と石井翁、一ぷくつけてスパリスパリと悠然たるものである。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後から悠然と覆面の右門。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚が立派な風体で悠然と現れます。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "態に似合わず悠然と落着済まして、聊か権高に見える処は、土地の士族の子孫らしい。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ユツタリと……」とか「悠然として……」とか書いても、其文の音律が沒却されてゐては、讀んで見ると悠然でも何でもない、文字には悠然として何とか書いてあるに拘らず、其悠然が駈つこしてるなどがある。",
              "citation": {
                "source": "文章の音律",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿波の六郎澄元は与一の方から何らかの使者を受取ったのであろう、悠然として上洛した。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "利休以外にも英俊は存在したが、少であって、利休は衆星の中に月の如く輝き、群魚を率いる先頭魚となって悠然としていたのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "口をいっぱいにあいて下へ落ちたせんべいのありうる可能性などは考えないで悠然として次のを待っている姿は罪のないものである。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより私は畜犬に対しては含むところがあり、また友人の遭難以来いっそう嫌悪の念を増し、警戒おさおさ怠るものではなかったのであるが、こんなに犬がうようよいて、どこの横丁にでも跳梁し、あるいはとぐろを巻いて悠然と寝ているのでは、とても用心しきれるものでなかった。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日もこれから寄附金のことで出掛けるところでした」「そうかね、私にかまわないでお出かけよ、私も今日は日曜だから悠然していられない」「そうでしたね、日曜は兵隊が沢山来る日でしたね」と自分は何心なく言った。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『オヤいないのだよ』と去ってしまった、それから五分も経ったか、その間身動きもしないで東の森をながめていたが、月の光がちらちらともれて来たのを見て、彼は悠然立って着衣の前を丁寧に合わして、床に放棄ってあった鳥打ち帽を取るや、すたこらと梯子段を下りた。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この騒がしい場所の騒がしい時にかの男は悠然と尺八を吹いていたのである。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人は悠然としてズボンのかくしに手を入れ空を仰いで長嘯漫歩しているふぜいである。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　飛つくお千世を葛木に縋らせて、ひとり褄を挙げて、悠然と前へ立って、「大丈夫、そうすりゃ、途中で、誰かに逢っても安心でしょう。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯見ると、驛員は莞爾として、機關車の方へ、悠然として霧を渡つた。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "呆氣に取られた彼を一人室内に殘して、悠然と扉を出たのである。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（今度は悠然として階を下る。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉も実もすつかりおとしてしまつた木のゆうぜんたるすがたはよいかな、うらやましいかな。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九ばかりの品のあるお嬢さんが、しっとり寂しいほど、着痩せのした、縞お召に、ゆうぜんの襲着して、藍地糸錦の丸帯。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、緋羽の蹴込敷へ褄はずれ美しく、ゆうぜんの模様にない、雪なす山茶花がちらりと上へかくれた。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　紅入ゆうぜんの裳も蹴開くばかり、包ましい腰の色気も投棄てに……風はその背後から煽っている……吹靡く袖で抱込むように、前途から飛着いた状なる女性があった。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の端となって見たがいい、時を得顔の梅柳が、行ったり来たり緋縮緬に、ゆうぜんに、白いものをちらちらと、人を悩す朝である。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房がまた、背筋や袖をしなり、くなり、自由に揉まれながら、どうだい頬辺と膝へ、道士、逸人の面を附着けたままで、口絵の色っぽい処を見せる、ゆうぜんが溢出るなぞは、地獄変相、極楽、いや天国変態の図だ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だのに、すこぶる不思議、ふたりの太刀持ち露払いが姿を見せた以上は、当然そのあとに名人右門が、あの秀麗かぎりない面にゆうぜんとあごをなでなで立ち現われるだろうと思われたのに、どうしたことかその姿がないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
