    "definitions": [
      {
        "index": 1,
        "gloss": "being unmatched (unparalleled) for bravery",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は、どんな困難にも勇敢無比の精神で立ち向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "勇敢無比な騎士が、国を守るために戦場へ向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「まさしく勇敢無比な行動だ！」と、敵も味方も彼を称えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "はじめのうちは、構造や性能などがあらまし分かれば、あとは勇敢無比を世界に誇るわが海軍の爆撃機や軍艦でもって、とにかくぶっ潰せるものと思っていた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに勇敢無比なわが海軍の精鋭をもってしても、これは相当の犠牲を出さないでは攻めおとすことができないと分かった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝うるところによりますと、あの小男はあれで、勇敢無比なる手利きであるそうですな、捕方に向った一方も、その方では名うての腕利きであったが、すでに危なかったそうです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "農奴の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
