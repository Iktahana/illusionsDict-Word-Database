    "definitions": [
      {
        "index": 1,
        "gloss": "bottle gourd (Lagenaria siceraria var. hispida)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
