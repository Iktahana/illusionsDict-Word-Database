        "examples": {
          "standard": [
            {
              "text": "彼の哲学は唯我論に傾倒しているようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "唯我論は、他者の存在を否定する極端な思想だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は唯我論について熱く語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "君の認識論はほとんど唯我論に帰着して、自他を峻別して自己に絶対の権威を置くの結果、三之助なる者の君の内的生活において占有する地位は淡い、小さい影にすぎなくなった。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "惨澹たる思索の果て、ついに唯我論に帰着し、利己主義に到達したる君はまっ蒼な顔をして「君を捨てる！",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯我論は動揺せねばならない。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は唯心論が行くところまで行くとき必ず帰着しなければならないように唯我論に陥ってしまった。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が唯我論から利己主義に達する過程は論理的必然の強迫である。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれらのことは唯我論の基礎の上に立ってはとうてい不可能な望みであることを感ぜずにはいられなかった。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は唯我論に私のできるだけ周到な吟味と批判とを加えてもみた。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私はどうしても唯心論の帰着点を唯我論に見いだすほかはなかった。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
