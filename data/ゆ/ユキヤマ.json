        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "即ち「世界の屋根」と呼ばれるヒマラヤ山は、最高峰エヴェレスト Everest は、海抜三万尺の高さに達しているが、ヒマラヤは梵語「雪あるところ」という意義であるそうで、そこから「雪山」という漢訳語も、起因しているのである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠に晩春より初夏へかけ（ここの赤裸々となるは、夏期わずかの間に候）最も歴々と仰がるべく、夏にても、形は明確に、白雪山を埋むる今にても、こを恋人とせる小生の目には、同じ雪に蔽われながらも、この鳥形のみは粗き山の膚（元より白色）の中に、滑らかに平に浮び出で居候が、認められ候。",
              "citation": {
                "source": "雪の白峰",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皚々たる白雪山川を封じ了んぬ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿四日、乙酉、白雪山に満ち地に積る。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無人の雪山に呼び出される人間の笑い声。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はるかに瑠璃色の空を刻み取って雪山の雪が王城の二つ櫓を門歯にして夕栄えに燦めいて居た。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、私は一人の倭人が、雪山のように高い、白い白い破損紙の層を背に負って、この大伽藍の中を匍うように動き出したのにも驚いた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、紙の入道雲が歩行く歩行く、光り輝く紙の雪山が。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪山村暮鳥きれいなきれいな雪だこと畑も屋根もまつ白だきれいでなくつて　　　　　どうしませう天からふつてきた雪だもの",
              "citation": {
                "source": "雪",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり苦労のない摩耶夫人様だから、大方｜洒落に、ちょいと雪山のという処をやって、御覧遊ばすのであろう。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "光線の工合でインド北方の雪山など紺青色に見えるはしばしば聞くところで、青と等しく紺青色も白と縁薄からねば、白馬の白を一層荘厳にせんとて紺青色の馬を想作したのだろう。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラウズ英訳『仏本生譚』一九六に、仏前生飛馬たりし時鬼が島に苦しむ海商どもを救うた事を述べたるにも、その飛馬全身白く喙烏に似、毛ムンジャ草のごとく、神力を以て雪山よりセイロン（鬼が島）まで飛んだとあれど翼の記載はない。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱地の猴故雪山を楽土と心得たのだ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "小猿雪山に登りて大薬王樹という樹の枝を伐って、帰り来りて酔い臥したる猿どもを撫ずるに、たちまち酔醒め心｜猛くなって竜を責む。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "大雪山に登って、山岳の大さを語れ。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "大雪山は北海道の中央に磅※して、七、八里四方の地盤を占め頂上の偉大なること、天下に比なく、群峰｜攅って天を刺し、旭川の市街を圧す。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "石狩川平原の中を貫き大雪山の数峰面に当る。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "石狩川は名だたる大河、中流にて神居山脈を貫き、上流にて大雪山の腰を貫く。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "大雪山の腰を貫く処、即ち層雲峡也。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたりは河原広く、かつ長く、川の中に巨大なる蓬莱巌ありて、二つの丸木橋にて、彼岸に達すべく巌頭に立てば、大雪山の数峰の頂も見えて、川を見上げ、見下す風致も、浮世のものならざる也。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　大雪山の第一夜　層雲峡は石狩川の有する一大偉観なるが、その鬼神の楼閣と思わるる巌峰は、大雪山の腰なれば、大雪山の有する一大偉観なりといいても可也。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "山水に徹底せむには、その楼閣の上に登りて、大雪山の頂を窮めざるべからず。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "留辺志部小学校の校長なるが、幾度も登攀して大雪山を我庭園の如くに思えり。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が大雪山の登攀を企つと聞き、嘉助氏という豪の者を伴えりとは思いもかけず、あるいは目的を達すること能わざるべきかと危ぶみ、自から進んで嚮導とならんとする也。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　大雪山の第二夜　塩谷温泉の連中は、日帰りの出来るぐらいに思いて、食物も十分に用意せず、草鞋も代りを持たず。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "さても大雪山の頂上の広きこと哉。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は大雪山に登りて、先ず頂上の偉大なるに驚き、次ぎに高山植物の豊富なるに驚きぬ。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "大雪山は実に天上の神苑也。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            }
          ]
        }
