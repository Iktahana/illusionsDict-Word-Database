          "literary": [
            {
              "text": "神田の夜店を漁りに行つて、有斐閣の前あたりだつたと覺えてゐるが、蓙の上に積重ねてある雜誌の間に、手垢で汚れた「笈摺草紙」の出て居る「文藝倶樂部」を見出した。",
              "citation": {
                "source": "貝殼追放",
                "author": "購書美談",
                "note": "青空文庫"
              }
            },
            {
              "text": "有斐閣注文しました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○有斐閣の本、代金引かえで送るよう注文したから明日あたり着くでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "多賀ちゃんは今、動物園と有斐閣へ行っているのよ、動物園で面白いグラフィックを売っているの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
