    "definitions": [
      {
        "index": 1,
        "gloss": "lily (Lilium spp.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夏祭の日には、家々の軒に、あやめや、菖蒲や、百合などの草花を挿して置くので、それが雨に濡れて茂り、町中が忽ち青々たる草原のようになってしまう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足袋裸足で痛痛しい、胸が開張けて、雪の肌が白百合の匂ひ、島田の根が外れて忙しい呼吸である。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しおれた白百合やカーネーションが流しの隅に捨ててある。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢車草、車百合、ドウダンなどが、栂や白樺の、疎らな木立の下に、もやもやと茂っている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖の端には、車百合の赤い花が、ひときわ明るく目立つ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は平原の草野において、山百合の花を愛し、深山の灌木において、もっとも白花石楠花を愛する。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "車百合、稚子百合、白花蛇イチゴ、コケモモ、ゴゼンタチバナ、ヤマオダマキなどが、陰森たる白ビソ、米ツガ、落葉松などの下蔭にうずくまっている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "今東光を、藤森成吉を、片岡鉄兵を、中条百合子を、信用しようとも、しもしなかつた私たちである。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "教春の一人娘｜早百合姫は三年前、京都の戦禍がやや鎮まっていたとき、京都｜滞陣の父の館に呼び寄せられ、まだ十四｜歳の少女であったが、以来日々、茶の湯、学問、舞、鼓など師匠を取って勉強していました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、早百合姫に附添っていた家来の男女は、薄情なもので、両人｜諜し合せ、館も人手に売渡し、金目のものは残らず浚ってどこかへ逃亡してしまいました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭青年は苫を破り分けて早百合姫をその中へ入るよう促しました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに諭さなくとも早百合姫は、道に志ある身となって、しかし、これは逆に塵中へ引返し、舞いの天才を発揮して京町の名だたる白拍子となりました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソロモンの栄華も一輪の百合の花に及ばないという古い言葉が、今の自分には以前とは少しばかりちがった意味に聞き取られるのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでは黒百合のような貴婦人が、オペラバッグから紙幣束を出して、百｜法の青札を買い、二十歳にもならないしとやかな娘が、赤札に自分の運命を賭けているのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "名を百合と呼び、大入島の生まれなり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾きし月の光にすかし見ればかねて見知りし大入島の百合という小娘にぞありける。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸助五六歳のころ妻の百合が里帰りして貰いきしその時｜粘りつけしまま十年余の月日｜経ち今は薄墨塗りしようなり、今宵は風なく波音聞こえず。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の島宮沢賢治海鳴りのとゞろく日は船もより来ぬを火の山の燃え熾りて雲のながるゝ海鳴り寄せ来る椿の林にひねもす百合掘り今日もはてぬ",
              "citation": {
                "source": "火の島",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソハヒマビマニトリテ来シ、　　木ノ芽ノ数ヲトリカハシ、アルイハ百合ノ五｜塊ヲ、　　　　ナガ大母ニ持テトイフ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガドルフの百合宮沢賢治［表記について］●底本に従い、ルビは小学校１・２年の学習配当漢字を除き、すべての漢字につけた。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ははは、百合の花だ。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども窓の外では、いっぱいに咲いた白百合が、十本ばかり息もつけない嵐の中に、その稲妻の八分一秒を、まるでかがやいてじっと立っていたのです。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おれの恋は、いまあの百合の花なのだ。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまあの百合の花なのだ。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてガドルフは自分の熱って痛む頭の奥の、青黝い斜面の上に、すこしも動かずかがやいて立つ、もう一むれの貝細工の百合を、もっとはっきり見ておりました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかにガドルフはこの二むれの百合を、一緒に息をこらして見つめていました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい百合の憤りは頂点に達し、灼熱の花弁は雪よりも厳めしく、ガドルフはその凛と張る音さえ聴いたと思いました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗が来たと思う間もなく、また稲妻が向うのぎざぎざの雲から、北斎の山下白雨のように赤く這って来て、触れない光の手をもって、百合を擦めて過ぎました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもガドルフは、その風の微光の中で、一本の百合が、多分とうとう華奢なその幹を折られて、花が鋭く地面に曲ってとどいてしまったことを察しました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女神の顔は氷花のように燦めき、自然のみが持つ救いのない非情と、奥底知れない泰らかさとが、女神の身体から狭霧のようにくゆり出す。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
