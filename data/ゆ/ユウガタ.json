    "definitions": [
      {
        "index": 1,
        "gloss": "early evening (usu. from 3pm to 6pm)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "宗教に入つて、尠くも朝と夕方に、帰依する気持があれば、謙譲は持続しやすく、さうであれば、詩的恍惚もミツチリと感じられ、漸次に味の深いものが、生れるやうになる筈だと思つた。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "教会の附近の黄色い土塀つづきの、夕方はしづかり下りて来る彼処へ、ではまた落付いたな、あゝあゝと、僕は思ふのだつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方弟と二人で近所の子供が集つて遊んでゐる寺の庭に行つた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは好いが君、君その指の繃帯は如何した」「一寸ナイフで切りましたから……」「Ｓ子は今内にゐませんから夕方いらつしやい……」　さう言つて二人は別れたが、彼にはその従兄の言葉が何時までも問題になつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だつてね、太つたくせに顔の陰が尖るつて質の女は一度ツンとすると其の後はもう理由もなしにツンとし通すものだから……」「こいつ大した苦労性だな、気の小さい……」　夕方行くとＳ子は最も他人行儀を示した。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "凧のかげ夕方かけて読書かな夕立やかみなり走る隣ぐに沓かけや秋日にのびる馬の顔鯛の骨たたみにひらふ夜寒かな秋ふかき時計きざめり草の庵石垣に冬すみれ匂ひ別れけり　彼の俳句の風貌は、彼の人物と同じく粗剛で、田舎の手織木綿のやうに、極めて手触りがあらくゴツゴツしてゐる。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三日経て後の夕方、荒物屋の座敷には隣家の誰れ彼れが大勢集まって酒を酌んでいた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "心よく晴れた夕方など、亭主はこの幼時を大事そうに抱いて店先をあちこちしている。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の夕方、ホテルの食堂で食事のあとに出した菓物鉢の数々の果物の中にただ一つ柿の実がのっかっていた。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが夕方が来ると、先生ははだしになつて家のまはりや庭に水を撒かれる、奥さんはかひがひしく夕餉の仕度をされる。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月二十六日　曇、夕方雷雨　月蝕雨で見えず。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方珍しい電光 Rocket lightning が西から天頂へかけての空に見えた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方の汽車で帰る頃、雷雨の先端が来た。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方藤田君が来て、図書館と法文科も全焼、山上集会所も本部も焼け、理学部では木造の数学教室が焼けたと云う。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方に駒込の通りへ出て見ると、避難者の群が陸続と滝野川の方へ流れて行く。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方から、そのなかのＳというプロレタリア党が「俺達の教会」へ私を連れて行こうと言うのです。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初秋の薄ら冷たさも身に泌みなれた九月下旬の或日の夕方、いよ／＼それを取はづさうとして手をかけた。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それであたしはこの辺を散歩すると云って寮を出るし、男はまた鯉釣りに化けて、この土手下の合歓の並木の陰に船を繋って、そこでいまいうランデブウをしたものさね」　夕方になって合歓の花がつぼみかかり、船大工の槌の音がいつの間にか消えると、青白い河｜靄がうっすり漂う。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さみだれが煙るように降る夕方、老妓は傘をさして、玄関横の柴折戸から庭へ入って来た。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、ひばりも、あまり美しい鳥ではありませんが、よだかよりは、ずっと上だと思っていましたので、夕方など、よだかにあうと、さもさもいやそうに、しんねりと目をつぶりながら、首をそっ方へ向けるのでした。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夕方、とうとう、鷹がよだかのうちへやって参りました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柏はざらざら雲の波、早くも黄びかりうすあかり、その丘のいかりはわれも知りたれどさあらぬさまに草むしり行く、もう夕方だ、はて、この沼はまさか地図にもある筈だ。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでおれは美しい正方形のつめくさの絨氈の上で夕方までいろいろ踊るといふのはどうだ　あんな単調で暑苦しい蔬菜畑の仕事にくらべていくら楽しいかしれないと考へた。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の晩方おそく私たちはひどくまわりみちをしてうちへ帰りましたが東北長官はひるころ野原へ着いて夕方まで家族と一緒に大へん面白く遊んで帰ったということを聞きました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなも前からそう思っていましたし、きのうの夕方やってきた二わのカラスもそういいました。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方ぶらりと上野公園から根岸の方へ歩いて行ってみると「根岸盆踊」という広告が方々に貼ってあった。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から十一年前、寛政四年の暮春のゆうがたに、ことし七つのひとり娘お元が突然そのゆくえを晦ました。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の机に向って、ゆうがた、独り物案じに沈み、見るともなしにそとをながめていると、しばらく忘れていたいちじくの樹が、大きなみずみずした青葉と結んでいる果とをもって、僕の労れた目を醒まし、労れた心を導いて、家のことを思い出させた。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯ともし頃とはいいながら、賑やかな真夏のゆうがたで、両側には町屋もある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "由松は七月三日のゆうがたから俄かに顔色が変って苦しみ出したので、母のお花はおどろいて町内の医者をよんで来たが、医者にもその容体が確かには判らなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "少年少女の死",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
