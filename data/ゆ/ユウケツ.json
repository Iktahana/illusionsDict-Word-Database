        "examples": {
          "standard": [
            {
              "text": "リーダーの勇決な判断が、プロジェクトの成功に不可欠だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「よし、勇決しよう！」彼は深呼吸をして、重要な決断を下した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その場での勇決な行動が、多くの命を救うことにつながった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "然れども此時の勢、ただ退かざるあるのみ、燕王の衆意を容れずして、敢然として奮戦せんと欲するもの、機を看る明確、事を断ずる勇決、実に是れ豪傑の気象、鉄石の心膓を見わせるものならずして何ぞや。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と部隊長は、言葉にそういいながら、いずれ劣らぬ忠勇決死の、我が兵士の精神に感心しました。",
              "citation": {
                "source": "とびよ鳴け",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
