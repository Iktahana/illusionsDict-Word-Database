        "examples": {
          "standard": [
            {
              "text": "新しいことに挑戦するには、失敗を恐れない勇気を持つことが大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は常に弱者を守ろうとする勇気を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "困難な状況でも、希望を失わない勇気を持つことが、生き残る鍵となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "春部にはなんだかそれがたいへんいじらしく見え、はからずも勇気を奮い起こす縁となった。",
              "citation": {
                "source": "千早館の迷路",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "にんじんは勇気を奮い起こす。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            }
          ]
        }
