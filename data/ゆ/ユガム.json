        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "居眠りなんぞをすると花輪が歪むからな。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎は、小山の下顎骨の落ちこんだ口元が、苦るしげに歪むのを見た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "指揮刀が歪むほどひッぱたかれた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも面の歪むのがいやなら、風通しの悪いその脳味噌に、風穴を一つあけてやろうか」　拳銃を握った手がいきなり豹吉の頭へ伸びて来た。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち解けたような、また一物あるような腹がまえと、しゃべるたびごとに歪む口つきとが、僕にはどうも気になって、吉弥はあんな母親の拵えた子かと、またまた厭気がさした。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、時々、かの女の口が歪む工合は、お袋さながらだと見えた。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでその直接の貸主と謂ふのは何処の誰ですか」　満枝は彼の遽に捩向きて膝の前むをさへ覚えざらんとするを見て、歪むる口角に笑を忍びつ、「貴方は実に現金でゐらつしやるのね。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから或る無頭児の罎詰の前迄行くと、令嬢の顔が不意に歪むのを私は早くも発見した。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそんな光景を眺めると大概刈手の方へ反感を持つのが常なのに、倉の場合に限つては、その顔が歪めば歪むほど胸のすくおもひで、態ア見やがれとでも嗤つてやりたい位ゐだつた。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、環境に応じてどんなに浅猿しくも歪むであらう自分の性情の悲惨なフレキシビリチが怖ろしかつたが、あたつて砕ける程の環境などがある筈はなかつた。",
              "citation": {
                "source": "鶴がゐた家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆は歪むだ顔をして、吸ひつけられたやうに鮨の折を見詰めてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すれば体のいゝ事を言つて自分達の国のためばかり計つてゐる講和委員に、その顔を見せることも出来るし、時折はまた、空色のネクタイの歪むだのを直すことも出来るから。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃尊敬していた男が暴力に逢うとどんな態度をとるものかとまるでユダのような好奇心が湧いて来て冷淡にじっと歪む屋敷の顔を眺めていた。",
              "citation": {
                "source": "機械",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本において民主化の諸問題が歪むのには、すこぶる深刻な後進的、半封建的条件が作用しているわけですが、それがまたある場合には外部的な力と結合されて、いっそう複雑になって来ました。",
              "citation": {
                "source": "一九四六年の文壇",
                "author": "――新日本文学会における一般報告――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウォツカの雫で濡れ放題のカウンターを、その団扇みたいな手で歪むほど打ちのめすと、尻尾を踏んづけられた狼のような唸り声をたてて、蹴倒した木椅子を両脚で突き飛ばしながら、亭主が巨大な図体を癇癪の筋だらけにして飛び出して来た。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことにこの下の街街に荒れ狂っている左翼と右翼のさまを、こうして怪獣の姿で眺めていると、世放れのした気持ちが乗り移り、自然に顔の筋肉も妙に歪むのが感じられた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は口元が歪むほどの冷笑を湛えて、背後の書架から、ウォルター・ハート（ウエストミンスター寺院の僧）の「グスタフス・アドルフス」を取り出した。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ口がぴくぴくと顫えて歪むと、なぜか泪がはらはらと落ちた。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう狂っては、却ってお身の不為――あぶれ者の目にも触れなば、いのちがござらぬぞ」五　哮り狂う長崎屋の形相は、いよいよ物すごく歪むばかりだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「い、ち、ち――」　と、法印の盤台づらが、闇の中で歪むのだった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたんに仙太の顔がキューッと苦悶に歪む。",
              "citation": {
                "source": "疑問の金塊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "働くのは遊ぶためだと考へてをり、より美しいもの便利なもの楽しいものを求めるのは人間の自然であり、それを拒み歪むべき理由はないと信じてゐる。",
              "citation": {
                "source": "欲望について",
                "author": "――プレヴォとラクロ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "と又も此時振下したニキタの第二の鐵拳、背骨も歪むかと悶ゆる暇もなく打續て、又々三｜度目の鐵拳。",
              "citation": {
                "source": "六號室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまたもこの時振下したニキタの第二の鉄拳、背骨も歪むかと悶ゆる暇もなく打続て、またまた三｜度目の鉄拳。",
              "citation": {
                "source": "六号室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "読みすすむにつれ、夫人の眼はきらきらして、美しい唇が引きつるやうに歪むのであつた。",
              "citation": {
                "source": "垂水",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで球を平面の上にのせた場合には、平面の接点附近がその圧力のために少し歪み、球の接点附近もまた少し歪む。",
              "citation": {
                "source": "立春の卵",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「われ巨人を切る事三｜度、三度目にわが太刀は鍔元より三つに折れて巨人の戴く甲の鉢金の、内側に歪むを見たり。",
              "citation": {
                "source": "幻影の盾",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯りの中へ引立てて行くと、それは甥の千次郎の忿怒と悔恨とに歪む顏だつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "荒神箒",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八、その野郎だ、逃すな」　續いて押入から飛出した平次、八五郎の組敷いたのを見ると、それが何んと、忠義酒屋の看板で奉公人の龜鑑のやうに思はれて居た、喜三郎の絶望と屈辱に歪む恐ろしい顏ではありませんか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "酒屋忠僕",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜吉さんは、本当に人に殺されたのでしょうか」　処女の頬はもう濡れて、グミの唇が、激しい悲しみに、捻れたように歪むのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "凧の糸目",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
