        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ああ丹念に油彩で為上げると、モナ・リザの神秘な微笑も硬くいかめしいものになる。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "極彩色、生け彩色、俗にいう桐油彩色など。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫刻修行のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "桐油彩色は、雨にぬれても脱落ないように、密陀油に色を割って、赤、青と胡粉を割ってやるのです。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫刻修行のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄刃のナイフでもう少し試してみると、大きな油彩の肖像画に遭遇したのだと判った。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "書齋の次ぎの間は、佛間になつてゐたやうに思ふが、そこの鴨居のうへにあつた油彩、安井曾太郎の、十號程の風景畫を見ながら、芥川は、「夏目先生は、自分には、丁度このくらゐの細かさの畫がいいといつてゐた」と、教へてくれた。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
