          "literary": [
            {
              "text": "ひとくちにいや、みんなゆすり取るんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "富裕な人間の裏側を見たときには、それを武器として、相手から多額の金銭をゆすり取ることができた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある金持ちの道楽者が妻を殺したいと考えている心理を見抜いて、その男のために殺人罪をおかしてやり大金をゆすり取る。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは金銭をゆすり取る手段であったかも知れない。",
              "citation": {
                "source": "恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
