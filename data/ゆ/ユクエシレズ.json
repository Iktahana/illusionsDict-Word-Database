    "definitions": [
      {
        "index": 1,
        "gloss": "missing (of a person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
