    "definitions": [
      {
        "index": 1,
        "gloss": "kami of the three main Kumano shrines",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは都の大臣殿から熊野権現に奉ったもので、そのころ盗まれた神宝の一つであった。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから熊野権現の近所へまわって、羅生門横町の現場をも取り調べた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七はそれを考えながら、熊野権現の社のあたりをひと廻りして、実相寺門前の文字吉の家をたずねると、五十六七の雇い婆らしい女が出て来て、三角な眼をひからせながら無愛想に答えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "『熊野権現宝殿造功日記』新宮に竜落ちて焼けたとあるは前述天火なるべく、『今昔物語』二十四雷電中竜の金色の手を見て気絶した譚は、その人臆病抜群で、鋭い電光を見誤ったに相違ない。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう五本流せば、熊野権現様にたてた誓いのとおり、千本という数になります。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊野権現は霊験あらたかな神でございます。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "康頼　きょうも熊野権現にお参りなされました。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしはきょうも熊野権現に日参して祈りました。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "霊験あらたかな熊野権現の利益によって――俊寛　もうよしてください。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは熊野権現の前にひざまずいて一心不乱に祈ろう。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "康頼　迎えの船の来たのは熊野権現の霊験と思われる。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで熊野権現に参拝した。",
              "citation": {
                "source": "遍路",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、此浄瑠璃もすぐ一つ前の形は、遊行上人の慈悲で、他人の屍に移して此世の者とせられた上、開祖以来関係深い熊野権現の霊験に浴して、肉身までも其人になり変ると言ふ筋であつたものと見る方が、手の裏反す様に小栗土葬・家来火葬と、前段に主従火葬とした叙述を顧みないでゐた点の納得もつく。",
              "citation": {
                "source": "小栗外伝（餓鬼阿弥蘇生譚の二）",
                "author": "魂と姿との関係",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠江の国久野の作仏房という山伏は、役の行者の跡を訪い、大峯を経て熊野へ参詣すること四十八度ということであるが、熊野権現の前で祈っている時、法然房に出離の道を尋ぬべしというお示しを受けたというので都へ上って法然の教化を受けて念仏の行者となった。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの国の海辺をまもる熊野権現も、鹿取鹿島、塩釜、さういふ海辺の神たちもみんな海洋族の英雄であつたのだらう。",
              "citation": {
                "source": "ミケル祭の聖者",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其烏も亦熊野権現の使者に倣ったものであろう。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「人間ばなれしていたようだが」「明日起こる事件を今日知るには、とうてい人間｜業ではない」「熊野権現のお使いかな」「狐狸のまどわしではあるまいか？",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは日本の神社のうちでも最も有名なものの一つである熊野権現の縁起物語であるから、その流布の範囲はかなり広汎であったと考えなくてはならない。",
              "citation": {
                "source": "埋もれた日本",
                "author": "――キリシタン渡来文化前後における日本の思想的情況――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ首なき母親に哺育せられた憐れな太子と、その父と伯父とのみが熊野権現になるのである。",
              "citation": {
                "source": "埋もれた日本",
                "author": "――キリシタン渡来文化前後における日本の思想的情況――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを霊験あらたかな熊野権現の前身としてながめていた人々にとっては、十字架上に槍あとの生々しい救世主のむごたらしい姿も、そう珍しいものではなかったであろう。",
              "citation": {
                "source": "埋もれた日本",
                "author": "――キリシタン渡来文化前後における日本の思想的情況――",
                "note": "青空文庫"
              }
            },
            {
              "text": "平氏の繁昌振りをみて、これは、熊野権現のご加護だと誰からとなくいい出した。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗り合せていた案内人は、この時とばかり、「こりゃめでたい、熊野権現のおしるしですぜ」とお世辞をいった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "予想通り、この話が、巷に伝えられて、熊野権現加護説を生み出したのだから、まさに清盛の思う壺だったというべきである。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊野権現の一つ、若王子のご本尊を乗せ、旗の横上には金剛童子を書いた、この湛増の兵船が現れると、源氏も平家も、共に手を合わせて拝んだ。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "道々熊野権現を祭ってある所ごとに、参拝しながら千里の浜の北、岩代の社まで来た時であった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「熊野権現の本地、阿弥陀如来、願わくは、摂取不捨の本願をば誤たず、浄土へお導き下さい。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "少将と康頼は、前から熊野権現の信者であったから、何とかこの土地にも熊野権現を祭って、一日も早く帰京のかなうように日夜祈参しようという相談が持ちあがった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、熊野権現がわれらの願をおきき入れになったしるしかも知れぬぞ」「今後は一層の精進をいたそう」　暫くして、又ある晩夢を見た。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
