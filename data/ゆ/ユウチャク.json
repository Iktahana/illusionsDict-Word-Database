          "literary": [
            {
              "text": "いわば善悪が融着してしまった世界である。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命と生命とが融着して自他の区別を消磨しつくし第三絶対者において生きんとする心である。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉と肉との有機的なる融着よ！",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "融着を促進するために縫合や固い包帯をすることはある部族では知られている。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
