        "examples": {
          "standard": [
            {
              "text": "彼女の描いた絵は、地域の美術展で優秀賞を受賞した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新入社員の彼は、わずか半年で優秀賞を獲得し、周囲を驚かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この大会では、最優秀賞の他に複数の優秀賞が用意されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私が展覧会で優秀賞を貰うと、塾の仲間の人達が、嫉妬で私の絵具や絵具皿や大事な縮図本を隠したりしました。",
              "citation": {
                "source": "今日になるまで",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると群馬県単位で催された学生科学賞の、優秀賞に選ばれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
