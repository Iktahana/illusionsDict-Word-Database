[
  {
    "uuid": "c566e34d-3fdf-5d9a-882f-c6aaa2fb0a18",
    "entry": "有意義",
    "reading": {
      "primary": "ゆういぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
