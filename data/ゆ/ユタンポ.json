    "definitions": [
      {
        "index": 1,
        "gloss": "hot-water bottle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
