        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は「必ず目標を達成する」と宣言し、まさに有言実行の男だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "口約束だけでなく、有言実行を心がけることが信頼につながる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「おー、すごい！まさか本当に有言実行するとはね。」と彼は友人の行動に驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "座ってしばらく休もうぜ」　ハウスマンが有言実行。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだ、有言実行のわしなら何でもできる。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "名誉にかけて、有言実行するから」　メアリが両手をわなわなとラルフに差し出した。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
