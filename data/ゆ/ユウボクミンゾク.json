        "examples": {
          "standard": [
            {
              "text": "歴史の授業で、遊牧民族がユーラシア大陸を移動した話を聞いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "モンゴル帝国は、強力な遊牧民族によって築かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遊牧民族の文化は、現代の私たちの生活にも様々な影響を与えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "けれども、四世紀に入るとまもなく、アジヤ大陸の東北部における遊牧民族の活動によってその地方のシナ人の政治的勢力が覆えされ、半島におけるそれもまた失われたので、ヤマト（邪馬台）の君主はその頼るところがなくなった。",
              "citation": {
                "source": "建国の事情と万世一系の思想",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊牧民族のパオなんかがあって、それが珍しかったくらいなもんです」　勤務は暇であった。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々遊牧民族のパオなどにも遊びに行った。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
