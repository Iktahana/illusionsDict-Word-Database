        "examples": {
          "standard": [
            {
              "text": "この地域では、米作りと並行して、牛を育てる有畜農業が盛んに行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "持続可能な農業を目指し、農家は有畜農業の導入を検討している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "有畜農業によって生産された堆肥は、土壌を豊かにし、作物の品質向上に貢献する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、これでは、有畜農業の新しい経営といふ事業さへも中途半端なものに終り、ある点で行きづまることは目に見えてゐる。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓弥之助は有畜農業を是非する訳ではないが、新百姓であり、かたがた動物性の方は成るべく避けて、植物性農業を主とする方針であった。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
