        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは雪催いの寒い日で、わたしは受付の火鉢へ無遠慮に手をかざして、奥へ呼び込まれるのを待っていると、やがて二階の編集局へ呼び上げられて、関氏自身が大勢に紹介してくれた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川町から駿河台下に通う電車通り、空はドンヨリとして、どちらかと云うと雪催いの鬱陶しさだったが、今宵は十五日で職人の休日でもあれば、五十稲荷の縁日でもあり、割合に人通りがあった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいま、東北の或る田舎を旅をしているのだが、この地方では、三月の半ば過ぎていると言うのに、まだ空は雪催いだ。",
              "citation": {
                "source": "月見草",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節は極月にはいったばかり、月も星もない闇の夜で雪催いの秩父｜颪がビューッと横なぐりに吹いて来るごとに、思わず身顫いが出ようという一年中での寒い盛り。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丑満時であったから、将軍お膝元の大江戸もひっそりとして物寂しく、二十日余りの晩い月が雪催いの空に懸かっているばかり往来には犬さえ歩いていない。",
              "citation": {
                "source": "紅白縮緬組",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田部さんがリュックを背負って帰って行かれた七日の夕方も、そんな雪催いだった。",
              "citation": {
                "source": "雉子日記",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪催いの曇った空に、教会堂のとがった三｜角形の屋根は、黒く描き出されていました。",
              "citation": {
                "source": "青い星の国へ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪催いの寒い風が、ピューッと河から吹き上がった。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
