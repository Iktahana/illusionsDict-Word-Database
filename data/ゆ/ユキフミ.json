          "literary": [
            {
              "text": "金眸は朝より洞に籠りて、独り蹲まりゐる処へ、兼てより称心の、聴水といふ古狐、岨伝ひに雪踏み分て、漸く洞の入口まで来たり。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪踏みて乾ける落葉現はれぬ一月八日　長野ホトトギス会員来る。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしの山　峰のしらゆきふみわけて入りにし人のあとぞ恋しき　あとぞ恋しき　眼にはいっぱいな紅涙があった。",
              "citation": {
                "source": "日本名婦伝",
                "author": "静御前",
                "note": "青空文庫"
              }
            }
          ]
