        "examples": {
          "standard": [
            {
              "text": "大会の最終日、優勝杯を手にするのは一体どのチームだろうか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年の努力が実を結び、彼らはついに優勝杯を掲げることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "優勝杯は歴史あるもので、歴代の王者たちの名前が刻まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "又のものには、優勝杯をさゝげたキャプテンの傍らに大きな花環を抱へた彼が慎ましやかに立つてゐた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
