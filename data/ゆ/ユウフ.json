  {
    "uuid": "38297a8d-90da-544a-bacf-102e833284ae",
    "entry": "有夫",
    "reading": {
      "primary": "ゆうふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "having a husband",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は、私を思って呉れていた有夫の女と情死を行った。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "有夫の婦人と情死を図ったのである。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は或る有夫奸事件の裁判の記録を読んだとき、賤しい男が、「底がはいつてゐるから好いと思ひました」と申し立てるところになつて、覚えず独で吹き出したが、忽ち顔を蹙めて記録を手から釈いた事がある。",
              "citation": {
                "source": "魔睡",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "有夫の女郎、素人の女郎！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "家は近畿地方に在り、暮しはいいところの有夫の婦人であつたが、出張の日がかなり多くて、郷里には殆んど居ないやうであつた。",
              "citation": {
                "source": "心靈研究會の怪",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏蘭西文学に出てくる不安を、有夫姦の多いためと見てゐる。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "古人の言う二夫云々は、有夫の婦人が同時に第二の男子に接するの意味ならん。",
              "citation": {
                "source": "新女大学",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "我国の現在の程度の職業婦人｜殊に有夫有子の女教師たちにはそういう弊害が折々あるのを私も認めます。",
              "citation": {
                "source": "平塚・山川・山田三女史に答う",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は巴里で幾人かの有夫女子の会社員や工場労働者の家庭を見ましたが、朝は子供を学校まで送って行き、正午は勤め先から学校へ子供を迎えに行って、同時に他の勤め先から帰って来た良人と、夫婦子供｜揃って一所に食卓に就くのです。",
              "citation": {
                "source": "平塚・山川・山田三女史に答う",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶対の恋愛をもつものならば妥協の生活は出来ないであろうし、有夫の身だから罪となるのを悲しんで死のうとしたならば、易きにつこうとした謗りはあるとしても、それは醒きらぬ婦人の無自覚から来た悲しい錯誤であると言わなければならない。",
              "citation": {
                "source": "芳川鎌子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がとる態度は、有夫｜姦の告訴、白蓮は愛人をともなって法廷に立て。",
              "citation": {
                "source": "柳原※子（白蓮）",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏蘭西文学に出てくる不安を、有夫姦の多いためと見ていた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "有夫が三割、未亡人が二割、あとは独身ですが親を養ったり、兄弟を学校へやったりする感心な人が多く、みんな生活のためですよ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十歳の有夫の老女を、この浦島太郎は一体どうしようと言うのでしょう。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "白髪の恋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はあまりに貞節であって、有夫姦については清教徒的な恐怖の念をいだいていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "（これが映像と音声とそれに触感まで組合はされて電送される幻影で、産児制限の最も確実なる方法として、政府が最近に奨励してゐるものであつたことを、薔薇はまだ知らなかつたのだ）さうして薔薇は有夫の婦人を好まない性質であつたので、この女ではなく売子の娘の方を愛することにした。",
              "citation": {
                "source": "のんしやらん記録",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう考えても有夫姦だ。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
