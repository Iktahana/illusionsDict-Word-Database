          "literary": [
            {
              "text": "しかも彼のごとく悠揚迫らずして、おのずから軽妙洒脱の趣を具えている俳優は、殆んど見当たらないように思われる。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "来てみなさい」　金博士は悠揚迫らず、更に奥の部屋に案内する。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしには彼の徳が勝ち誇った歩調で、堂々と、悠揚迫らず、何らの障害にも遇わずに濶歩するさまが、目に見えるように思われる。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
