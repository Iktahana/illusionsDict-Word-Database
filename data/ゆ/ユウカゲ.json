    "definitions": [
      {
        "index": 1,
        "gloss": "light of the setting sun",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
