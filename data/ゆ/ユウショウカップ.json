        "examples": {
          "standard": [
            {
              "text": "選手たちは、優勝カップを掲げてスタンドの観客に応えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年の夢だった優勝カップを手にし、彼は感無量の面持ちだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大会閉幕後、優勝カップは次の開催地へと運ばれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし外科の方が大変好きなのでありましたので部屋の本箱の上には、外科につかう色々なメスがまるで優勝カップのように並べてありました。",
              "citation": {
                "source": "清修館挿話",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀の優勝カップを取り落すまいとして、高く空に右手をあげている島崎を目がけて、女、男、白色、黄色、あらゆる人種と階級のファンたちが、彼の握手を争奪した。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
