          "literary": [
            {
              "text": "で、　はなしあうひとが（ほら、　はこがたの　ざせきに　カエルと　アヒルの　ふたりが　みえるよね）　そいつの　「ゆうざい」「むざい」　どっちかに　きめるってわけ。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "キングが　１２にんに　ハートの　ジャックの　ゆうざい　むざいを　きめろと　いってね　――　つまり　タルトを　ぬすんだのは　そいつなのか、　ほかの　やつが　たべたのか　きめるって　ことなんだけどね。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            }
          ]
        }
