[
  {
    "uuid": "901c3eab-ed86-5bd9-9187-e8206df73602",
    "entry": "夢",
    "reading": {
      "primary": "ゆめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
