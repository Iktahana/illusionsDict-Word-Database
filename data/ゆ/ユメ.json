      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dream",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夢のうちなる遠近法、夏の夜風の小鎚の重量、それ等は既になし。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、午睡の夢から覚めてみると　　みなさん家を空けておいでだつた　　あの時を妙に思ひ出しますさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはつちを掘り、つちをもりて、日毎におんみの家畜を建設す、いま初夏きたり、主のみ足は金屬のごとく、薫風のいただきにありて輝やき、われの家畜は新緑の蔭に眠りて、ふしぎなる白日の夢を畫けり、ああしばし、ねがはくはこの湖しろきほとりに、わがにくしんをしてみだらなる遊戲をなさしめよ。",
              "citation": {
                "source": "初夏の祈祷",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いづこぞ夢の序樂のぽろねえず、會社は河岸に涙をひたし、花店の飾窓つゆにぬれたり、しばしまたつりがね鳴らむ、あさまだきにほふ葉影に、しろじろとかざし泳がせ、この列をなす少女らあゆむ。",
              "citation": {
                "source": "若き尼たちの歩む路",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは夢多かりし幼時を過ごしたフランドルの哀愁にも因るのであらう。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いとも近代的な鬱憂の調子、即ち一種の夢みるやうな調子を備へ、この調子がその胸を刺すやうな悲痛の表現に魅力を添へてゐるのであつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまれ私は今書きながらフトその忠魂塔の模型をだつて思ひ出したのだが、それが現に在つたといふことは非常に慥かなのだが、また却つて夢のやうでさへある。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説家なんかの部屋を夢闇に片附けるのは却て不可ないことだつて。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（男一足下つて首をクネクネ廻して、頸の凝りを直す）夢だ…………常識主義者だ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで私自身では、いくら元気である時にでも、もしその時に佗しげな夢を見てゐたとしたら、尠くとも直ぐにニコニコはしないであらう。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して私は常に夢みてゐる。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは恰かも青い色が青い色であり、赤い色が赤い色であるやうに、夢をみようともみまいともしないで私は夢みてゐるのである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は口に人道と博愛を称へ、自ら求め得ざる夢想の愛を求めんとして、苦しき努力の生涯を終りたる、あの悲しいトルストイの徒ではなくして、真にその肉体から高貴な人義的の愛を体得して生れた「生ける愛の詩人」である。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして私と彼とは、互にその欠陥せる病癖を悲しみ、互にその夢想せるしかも正反対の性情の美しさを交換した。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私共は、既にかうした青春時代の花やかな、とはいへいくぶん狂気じみた創造の夢を過去に微笑して観ることさへもできる。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の彼は、日本をもはや『夢の国』としては見ていなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人がその空想の中で画くような、ファンタスチックな夢の国は、現実の地球上にあるはずがない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも宿命的な詩人の悲願は、その有り得べからざる夢の国を、生涯夢見続けることの熱情にある。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "新婚まもなく若い稚気のぬけなかった夫人は、恐らく恐怖にふるえながらも、人生の最も楽しく忘れ得ない夢を経験したのだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬ前の日に、彼は不思議な夢を見たと妻に話した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは日本でもない、支那でもない、大層遠い遠い見知らぬ国へ、長い旅をした夢であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今ここに居る自分が本当か、旅をした自分が本当かと夫人に問い、『ああ夢の世の中』、と呟いて寂しげに嘆息した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが漂泊の詩人｜芭蕉は『旅に病んで夢は枯野をかけめぐる』といって死んだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢見ることによって生きた詩人等は、また夢見ることの中で死ぬのであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の国々を漂泊して、ついに心の郷愁を慰められなかった旅人ヘルンは、最後にまたその夢の中で漂泊しながら、見知らぬ遠い国々を旅し歩いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての印象が惡夢のやうに感じられた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ自分は、荒唐無稽の夢にうなされてるやうな感じもした。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹脂の香に　朝は悩まし　　うしなひし　さまざまのゆめ、森竝は　風に鳴るかなひろごりて　たひらかの空、　　土手づたひ　きえてゆくかなうつくしき　さまざまの夢。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあれ、怒ることこそ汝が最後なる目標の前にであれ、この言ゆめゆめおろそかにする勿れ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆめゆめ粗略には致すまじく候。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
