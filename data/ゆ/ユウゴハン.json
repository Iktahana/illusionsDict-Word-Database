        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "家族みんなで食卓を囲み、温かい夕ご飯を食べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「今日の夕ご飯は何にしようかな？」と母が献立を考えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "仕事が終わって帰宅すると、いつも美味しい夕ご飯が待っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "軽井沢へ来てから、昼間あまり、かけずり廻るので、夕ご飯がすむ頃には、もう眠くなってしまう小太郎だった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちにゃ米粒一つだってないのに、私だってこの子供たちだって夕ご飯も食べられないって始末だのに、よくもこんなにのびのびと酒を呑んだり花を引いたりしていられたもんだね……」　父も腹立たしそうに血相を変えて立ち上った。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリちゃんは、すっかり胸が軽くなって、兄さんがまだ生きてでもいるような心持がして、嬉しくってたまらなかったので、機嫌よく家へ入って、夕ご飯を食べました。",
              "citation": {
                "source": "杜松の樹",
                "author": "グリム",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕ご飯のときに、その話が出ると、兄さんは、笑って、「役にも立たぬものを、体裁だけでごまかすなんて、ほんとうにわるいことだな。",
              "citation": {
                "source": "正二くんの時計",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お母さんは、やっと夕ご飯の後片付づけが終わって、良ちゃんをつれて、市場へいかれました。",
              "citation": {
                "source": "少年の日二景",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とお母さんは夕ご飯の時もおやしきの話でもちきった。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、夕ご飯もまだ差上げませんし」　お豊は、「何てまあ罪のない」と云いたげに、涙の顔を少しほころばせた。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕ご飯がすみますと、その四人と、ふたりのお客さんが、洋室に集まって、大きなテーブルを囲んでいました。",
              "citation": {
                "source": "おれは二十面相だ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
