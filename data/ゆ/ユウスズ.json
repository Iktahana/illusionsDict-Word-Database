[
  {
    "uuid": "89317535-0d3e-5a77-8a95-8f39850f711b",
    "entry": "夕涼",
    "reading": {
      "primary": "ゆうすず",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
