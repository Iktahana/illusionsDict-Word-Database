[
  {
    "uuid": "02222c02-be81-58e5-bdb2-36f07261ff7f",
    "entry": "優良",
    "reading": {
      "primary": "ゆうりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
