        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "赤い車海老はパセリの葉の蔭に憇ひ、ゆで卵を半分に切つた斷面には、青い寒天の「壽」といふ文字がハイカラにくづされて畫かれてゐた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い車海老はパセリの葉の蔭に憩い、ゆで卵を半分に切った断面には、青い寒天の「壽」という文字がハイカラにくずされて画かれていた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度ゆで卵を取り落して壊した後は、卵を得るごとに堅い物で打ち欠き指もてその殻を剥ぐ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "わきの寝台に腰をかけ、前へ引きよせた椅子の上に新聞をひろげ、バター、キューリ、ゆで卵子二つ、茶でファイエルマンが夕飯をたべる。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しわざわざめし屋に入る気もしなかった藤次郎は、池の角の所に出ていたゆで卵屋の所で、四ツばかり卵を買うとそれをそのまま袂に入れた。",
              "citation": {
                "source": "夢の殺人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつとの思ひで、荷物を持ち上げ、廣場を横ぎり、あかあかと灯のついてるレストランに入り、何か食はせてもらはうとしたが、ゆで卵二つのほか食ふものとては一つも手に入らなかつた。",
              "citation": {
                "source": "大戰脱出記",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝から支度をして、ナージャ台所でカツレツをつくるやら、ゆで卵をつくるやら、急な洗濯の火熨をかけるやら、九時頃立った。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆで卵子を二つで腹を拵へたんですから疲れも何もなく、何時の間にかグッスリ寝こんでしまひました。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆで卵や、やいた魚や、酒のびんなどが、出てきました。",
              "citation": {
                "source": "雲のわくころ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間にゆで卵の方が出来上った。",
              "citation": {
                "source": "立春の卵",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "倹約するためにわたしたちは荒物屋で買ったゆで卵と、パンを食べた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "注射――猛烈な毒物や、空気の静脈注射と言うことも考えられますが、全身の皮膚は剥いたゆで卵のように綺麗で、蚤に螽された痕も見付かりません。",
              "citation": {
                "source": "葬送行進曲",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼食の時、奥テル子のお膳の上を見て、そこに海苔で巻いたおひたしの緑、ゆで卵、焼ざかなのあぶりの照りを眺め、なかんずく若さぎの酢和えが眼をとらえた。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆで卵にしたり、また、シャベルにかめの油をたらして、火にかけ、シャベルをフライパンの代用にして、魚肉入りのオムレツをつくるなど、料理当番は、かわるがわるうでをふるって、毎日、卵ばかりごちそうした。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が出発する前に、平常から親しくしていた、たつ子さんと三｜人で、あすこの石の上で、なつみかんや、ゆで卵を食べて、形ばかりの送別会をやった、そのとき、ちょうど、ほおのきの花が咲いていたのを覚えていないか。",
              "citation": {
                "source": "風雨の晩の小僧さん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "細長いテーブルの上には、ゆで卵を盛った皿、袋入りのバター・ピーナッツを入れた瓶、それから、ドーナツ、ワップル、シュークリーム、渦巻カステラの類いを収めたガラスの菓子箱がならんでいる。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドギついドーラン化粧をおとすと、ゆで卵をむいたような、つるつるの、といっても卵のように白いわけではなく、過労からか、陽に当らないからか、黄色い、いやな色をした顔が出てくるのだが、眉も何もないその顔は、あれ？",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "行儀の悪い俺を見て、びっくり仰天の顔だったが、それはまるで、ゆで卵をむいたのに目鼻をつけたみたいな、いやにツルツルした丸い顔だった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスプレッソを二杯に固ゆで卵をいくつ？",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスプレッソと固ゆで卵なのよ、いっつも。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "固ゆで卵にタイミングを合わせてエスプレッソを二杯作って、食べるわけ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかにも野菜やトーストを食べるんだけど、まず最初は、ほかのものは邪魔くさいからどかしておいて、エスプレッソと固ゆで卵を恵子さんは楽しむのよ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスプレッソと固ゆで卵を食べ終ってしばらくしてから、野菜とパンを食べてる。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆで卵を作るミルク・パンに彼女は水を満たした。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "食べるものはポテトチップスをひとつかみ添えた胡瓜のサンドイッチと、かたゆで卵だけだ。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたゆで卵はエッグ・カップに入れて皿に載せ、小さなふたつの容器に塩とマヨネーズをそれぞれ入れ、エッグ・カップに添える。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お店で出すゆで卵が、ふたつ残ってるのよ。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれかが　みずを　くもうとしたのか、　いしのうえに　ブリキの　バケツが　おかれてありましたが　――　みずは　どばどば　あふれっぱなしで、　それというのも　おおきさが　ゆでたまごたてくらいしか　なくって！",
              "citation": {
                "source": "チギウィンクルおばさんのはなし",
                "author": "THE TALE OF MRS. TIGGY-WINKLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
