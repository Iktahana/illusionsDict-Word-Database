        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "救急車はＵターンして、速力を上げて走り去った。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "海沿いの道路に出て、大きくＵターンをした。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかで東にむけてＵターンをしなくてはいけない。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人が乗ったセダンは、Ｕターンをしたのだね。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｕターンし、家へ戻った。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてＵターンした。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえは、あっち」　言われるままにカワサキにまたがり、道幅いっぱいにＵターンし、三〇〇メートルほど走った。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "再びＵターンし、センター・ラインのすぐわきにカワサキをつけた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしておいて気持を落着かせてから、道幅をいっぱいに使い、Ｕターンした。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢田を乗せたライトバンはＵターンし、ぼくの目の前をとおり抜け、東雲のほうへスピードをあげつつ、走り去った。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっすぐいき、陸橋を二本くぐったさきで、Ｕターンした。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
