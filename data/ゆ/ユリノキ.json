    "definitions": [
      {
        "index": 1,
        "gloss": "tulip tree (Liriodendron tulipifera)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やや黄なる風景白き猫枝にかがやき、ゆりの木の病葉黄なり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジュピターは主人の指図によって、途方もなく高い一本のゆりの木の根もとまで、我々のために道を切りひらきはじめた。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのゆりの木というのは八本から十本ばかりの樫の木とともにこの平地に立っていて、その葉や形の美しいこと、枝の広くひろがっていること、外観の堂々たることなどの点では、それらの樫の木のどれよりも、また私のそれまでに見たどんな木よりも、はるかに優っているのであった。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカの森林樹のなかでもっとも荘厳なゆりの木、つまり Liriodendron Tulipiferum（訳注「ゆりの木」の学名）は、若木のときには、幹が奇妙になめらかで、横枝を出さずにしばしば非常な高さにまで生長する。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ勝負はつかないんだ」そして彼はふたたび先に立って、あのゆりの木の方へ行った。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "路の真中に大きなゆりの木が立って、巨人のように、あたりの木立の上にそびえ、一種の道標になっていた。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
