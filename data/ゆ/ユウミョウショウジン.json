    "definitions": [
      {
        "index": 1,
        "gloss": "engage in ascetic practices with dauntless spirit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
