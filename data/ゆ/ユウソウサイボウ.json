        "examples": {
          "standard": [
            {
              "text": "免疫反応において、遊走細胞は病原体や異物を認識し、排除する役割を果たす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "体内で活発に動き回る遊走細胞の働きによって、私たちの体は病気から守られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "研究者は、遊走細胞の運動メカニズムを詳細に解析している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしこの受身の抵抗に加えて能動的なものを遊走細胞である白血球すなわちリューコサイト、および主として侵入された組織だけでなく脾臓およびリンパ腺の細胞が行っている。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
