[
  {
    "uuid": "48b980b5-51ce-58cc-8338-6c6a4ee3e503",
    "entry": "融雪",
    "reading": {
      "primary": "ゆうせつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
