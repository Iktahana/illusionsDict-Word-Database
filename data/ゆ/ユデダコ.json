        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大道で鍋を煮立たせて、ゆでだこを売っている男がいました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどは用吉君が、得意の手で相手の首をしめにかかったが、反対に自分の首をしめつけられ、ゆでだこのようになってしまった。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぜんたい、お湯屋というものは、だんなを前において講釈いうようだが、人間をゆでだこにするためにこしらえてあるんじゃねえ、からだをあっためるためにこしらえてあるんだからね、さっそくあっしがぱんぱんと啖呵をきってやったんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう伝六がゆでだこのようにふらふらとなりながら音をあげました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝湯に来たのもそれがため、てんぐぶろを選んだのもそれがため、伝六をゆでだこにしたのもまたそれがため、すべてが右門流のあざやかな機知によって、名人十八番からめ手詮議のつるは、ついにかくのごとく今みごとにたぐりよせられたのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "その色はへんに青く、その大きさは、大きなゆでだこぐらい――つまり、大きな猫か、中ぐらいの犬ほどの大きさしかなかった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
