          "literary": [
            {
              "text": "但し、神経の浪費を防ぐために、郵便小包で送ろうと考えたのである。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　と持つて来た郵便小包を受取つた主人は直様、紐を解き初めた。",
              "citation": {
                "source": "若芽",
                "author": "島田清次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃郵便小包のシステムがかわりましてね、市内小包六銭というまことに親愛なものがお廃しになったのよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "光から郵便小包出ないらしいのよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
