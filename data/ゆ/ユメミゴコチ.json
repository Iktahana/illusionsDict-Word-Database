[
  {
    "uuid": "364f1127-ba99-554c-b5af-7df676d1018f",
    "entry": "夢見心地",
    "reading": {
      "primary": "ゆめみごこち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
