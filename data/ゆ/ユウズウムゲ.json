    "definitions": [
      {
        "index": 1,
        "gloss": "free, unfettered and flexible",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
