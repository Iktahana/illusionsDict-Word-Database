[
  {
    "uuid": "7069c154-1309-542e-9cd6-90ac15d748f8",
    "entry": "夢の世",
    "reading": {
      "primary": "ゆめのよ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
