        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "秋になると都会の各地から遊覧客がやって来る。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊覧客や病人の眼に触れ過ぎて甘ったるいポートワインのようになってしまった海ではない。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊覧客たちの、そんな嘆声に接して、私は二階で仕事がくるしく、ごろり寝ころんだまま、その天下第一のながめを、横目で見るのだ。",
              "citation": {
                "source": "富士に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那でおいしい所謂支那料理を食べているのは、少数の支那の大金持か、外国の遊覧客だけです。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここのバスの女車掌は、遊覧客のために、格別風景の説明をして呉れない。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊覧客相手の贅沢品屋は防火扉をおろしてまだ深々と眠って居た。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏でもここまでの遊覧客はさして見えないらしい。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "真夏でもここまでの遊覧客はさして見えないらしい。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "またそのあいだを幾艘の大きい遊覧船が満艦飾というように燈籠をかけつらね遊覧客を乗せて漕ぎ廻っている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "時局のために遊覧客は多くないらしいが、それでも二千や三千はあるらしい。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "国をあげて遊覧客のためにのみ存在す。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを近処の子供たちや遊覧客がかこんで見物していた。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "別にウインクしたのでもないが、服装が態度が遊覧客らしかつたのだらう、若い売笑婦に呼びかけられた！",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間はお上りの遊覧客で賑ふその辺も、夕方から急に人足が絶えて了ふのが常で、まだ宵少し過ぎたばかりだつたが、戸の開いてゐる家もなく、四方はもう真夜中のやうにひつそりしてゐた。",
              "citation": {
                "source": "乳の匂ひ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう東山遊覧客も少くなつた季節ではあつたが、それでも清水から高台寺円山の方へ通ずる往還にあたつて居る其の坂を上り下りする人の足音が昼の間は絶えなかつた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の初め、地方から遊覧客が次第に多くなつて来る頃に、二階建の大きな建築が愈※竣成した。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東山遊覧客も日一日と殖えて来て、前の坂を上下する人の下駄の音や車の響も、終日｜長閑に麗に聞えた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿の角細工店でも出して看板娘にすると、よう儲かるで」　と、諸国遊覧客の懐を相手に暮している奈良町人碌な事を云わない。",
              "citation": {
                "source": "傾城買虎之巻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念柱の下にはアメリカ人らしい遊覧客が車を二三台乗り捨てて眺めていた。",
              "citation": {
                "source": "ヴェルダン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "他にも一台バスが来て、部屋の中は遊覧客で一ぱいになった。",
              "citation": {
                "source": "エトナ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギゼーの町は小さくはあるが、街の中央の道路には、軽快な電車も通っているし、小綺麗な旅館も櫛比しているし、椰子の樹蔭も諸所にあって、金字塔見物の遊覧客に、気に入られそうな町である。",
              "citation": {
                "source": "木乃伊の耳飾",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅館が遊覧客で混み合っているのもいけなかったかも知れない。",
              "citation": {
                "source": "山上湖",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "レジナから乗込んだ外国の遊覧客は幾組かゐた。",
              "citation": {
                "source": "ヴエスヴイオ山",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、さういふ思想が贋物にすぎないことは彼等自身が常に風景を裏切つてをり、日本三景などといふが、私は天の橋立といふところへ行つたが、遊覧客の主要な目的はミヤジマの遊びであつたし、伊勢大神宮参拝の講中が狙つてゐるのも遊び場で、伊勢の遊び場は日本に於て最も淫靡な遊び場である。",
              "citation": {
                "source": "デカダン文学論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう人達が、期節に入った今頃はよくこの辺をうろうろするが、いずれも流行で山奥までまぐれ込んだ遊覧客である。",
              "citation": {
                "source": "続スウィス日記（千九百二十三年稿）",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しその為には通り一遍のこういう遊覧客の多い町にばかりいない方が宜しい。",
              "citation": {
                "source": "続スウィス日記（千九百二十三年稿）",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、そういう思想が贋物にすぎないことは彼等自身が常に風景を裏切っており、日本三景などというが、私は天の橋立というところへ行ったが、遊覧客の主要な目的はミヤジマの遊びであったし、伊勢大神宮参拝の講中が狙っているのも遊び場で、伊勢の遊び場は日本に於て最も淫靡な遊び場である。",
              "citation": {
                "source": "デカダン文学論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱海は熱海市民のものだけではなく、日本人全体のもの、遊覧客全体の所持物でもあるのだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくとも、熱海の復興は、かなり多く自分の利害をすて、遊覧客全部のもの、という奉仕精神を根本に立てることを忘れていないので、復興が完成すれば、熱海の発展はめざましいだろうと思われる。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "この水泳場を利用して、温泉場の余興として、遊覧客を吸収しようという計画がいろいろと考えられた。",
              "citation": {
                "source": "宝塚生い立ちの記",
                "author": "小林一三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
