        "examples": {
          "standard": [
            {
              "text": "先生の退職祝いとして、有志一同で記念品を贈った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このイベントは、地域の有志一同の協力によって実現した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "寄付の呼びかけに、有志一同が快く応じてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "止むなき儀につきまして、言上致したく、幸い、国許より、この両名、有志一同に代って見えましたにより、参上致しましたるところ、拝謁仰せつけられ、忝なく存じ奉ります」　と、名越が、型の挨拶をした。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして小半日も歩いたころ、戴宗は「先へ行って有志一同を迎えに出させる」という口実のもとに、姿を消してしまった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
