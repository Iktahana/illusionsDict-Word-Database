        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "浴衣一枚の胸をハダケて、恐らく我々が来るまで、彼は頭をカカへてゐたに違ひなかつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいつも和服――特に浴衣を好んだ――を着、畳の上に正坐し、日本の煙管で刻煙草を詰めて吸ってた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子の浴衣でした。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりかうした作家たちが、詩や俳句を作るのは、飽食の後で一杯の紅茶をのんだり、或は労作の汗を流し、一日の仕事を終つた後で、浴衣がけに着換へて麻雀でもする気持なのだ。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "恍惚としていた時に雨を侵す傘の音と軽い庭下駄の音が入口に止んで白い浴衣の姿が見えた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は父の机の前に足と投出したままで無心に華車な浴衣の後姿から白い衿頸を見上げた時、女は肩越しにチラと振り向いたと思う間に戸をはたとしめた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなれば宿帳つけに来し男の濡れ髪かき分けたるも涼しく、隣室にチリンと鳴るコップの音も涼しく、向うの室の欄干に倚りし女の白き浴衣も涼しげなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を拍ちて床をのべさせ横になれば新しき浴衣の肌さわりも快く、隣室の話声遠きように聞えし後は魂いずこへか飛んで藻ぬけの殻となり電燈消しに来し事もいつか知らず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらの氷店へはいって休んだ時には、森の中にあふるる人影がちらついて、赤い灯や青い旗を吹く風も涼しく、妹婿がいつもの地味な浴衣をくつろげ姪にからかいながらラムネの玉を抜いていた姿がありあり浮ぶ。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴衣を着て、あの人縁側に立つてそれを見てるのよ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "明朝の登山準備を頼んで、宿の浴衣を引っかけたまま、細長い町を散歩する。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "女学生の登山隊が、百人ほど、町の宿屋にいるのだそうで、チンチクリンの男の浴衣を、間に合せに着て、歩いているのもある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴衣が泥水でも浴びたかのように黄色く染まっている。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘時代のある時、歌舞伎の舞台で見た若い芸妓のちりめん浴衣にすつかり魅せられました。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて見かへるに暴れ者の長吉、いま廓内よりの歸りと覺しく、浴衣を重ねし唐棧の着物に柿色の三｜尺を例の通り腰の先にして、黒八の襟のかゝつた新らしい半天、印の傘をさしかざし高足駄の爪皮も今朝よりとはしるき漆の色、きわ／″＼しう見えて誇らし氣なり。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸体を回想として近接の過去にもち、あっさりした浴衣を無造作に着ているところに、媚態とその形相因とが表現を完うしている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「歩く拍子に紅のはつちと浅黄縮緬の下帯がひらりひらりと見え」とか「肌の雪と白き浴衣の間にちらつく緋縮緬の湯もじを蹴出すうつくしさ」とかは、確かに「いき」の条件に適っているに相違ない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "円タクで白山坂上にさしかかると、六十恰好の巌丈な仕事師上がりらしい爺さんが、浴衣がけで車の前を蹣跚として歩いて行く。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "匂ひのいい蚊帳と糊のよく利いた浴衣。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オヤ好い月だね、田川さんお上がんなさいよ」という女は今年十九、歳には少し老けて見ゆる方なるがすらりとした姿の、気高い顔つき、髪は束髪に結んで身には洗曝の浴衣を着けて居る。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "兼ねて此部屋には戸棚というものが無いからお秀は其衣類を柳行李｜二個に納めて室の片隅に置ていたのが今は一個も見えない、そして身には浴衣の洗曝を着たままで、別に着更えもない様な様である。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、日本へ来ている西洋人が夏は好んで浴衣を着たり、ワイシャツ一つで軽井沢の町を歩いたりすることだけを考えても、和服が決して不合理なものばかりでないということの証拠がほかにもいろいろ捜せば見つかりそうに思われる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚いなりをした、眼のしょぼしょぼした干からびた婆さんと、その孫かとも見える二十歳くらいの、大きな風呂敷包の荷をさげた、手拭浴衣の襦袢を着た男が乗っていた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴衣の膝頭に指頭大の穴があいたのを丹念に繕ったのが眼についた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "筒袖の、平常着ていたゆかたで彼の一番眼に慣れた着物だった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴乎とした役者が、ゴム底の足袋に卷きゲートル、ゆかたの尻ばしよりで、手拭を首にまいてやつて來た。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今木綿の単衣をゆかたといふも、つまり湯上りの衣といふことなり。",
              "citation": {
                "source": "当世女装一斑",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "青扇は茶碗をむりやりに僕に持たせて、それから傍に脱ぎ捨ててあった弁慶格子の小粋なゆかたを坐ったままで素早く着込んだ。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろに、あたまの小さい、白ゆかたを着た細長い十五六の男の児が立っている。",
              "citation": {
                "source": "悶悶日記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北国の夏の夜は、ゆかた一枚では、肌寒い感じである。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
