        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしながら、自己の力によりたのむ自力主義は、すぐに実践上の障害に行き当たる。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "斜路を登りつめるとその胸壁に行き当たるようになっていたのだ。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、息苦しさ、雑踏、いたるところに行き当たる石灰、建築の足場、煉瓦、埃、別荘を借りる力のないペテルブルグ人の誰でもが知り抜いている特殊な夏の悪臭――これらすべてが一つになって、それでなくてさえ衰え切っている青年の神経を、いよいよ不愉快にゆすぶるのであった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、たまにマンチェスターやリバプールでは行き当たるけれども。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「戦列兵か郊外兵かの前哨に行き当たる。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い壁にゆきあたると彼等はじつとその前に坐つてゐて、何時までも待つてゐた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々は女と自分の目がゆきあたることもあった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あきらかな資料はないが、およそこういう局面にゆきあたるのは軍政上ままある慣いだ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
