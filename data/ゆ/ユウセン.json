      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "preference",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一面親切、一面指導という優先者の態度を以て臨むのが、いまの外交官として妙訣ではないかと僕は睨んでいる。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は断言しますが、私こそは彼の女に対して、第一の優先権を持っている者で、ただ私はその正統の権利を要求しただけです」「夫人は君のそう云う人となりを知ったので、君の把握から遁げ出したのだ」　ホームズは厳しく云った。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいか、俺にはあいつへの優先権がある、おれはそれを主張しただけだ。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "上手な作文を標準語で書くことよりもまず、しっかりと目を見開いて自分たちの生活を直視することを優先させようとしたのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどこのままの体調では、後書きを片づけられないのではないかとの思いもあり、再刊を優先する気持ちに傾きました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、身の安全を優先したいのなら、読む気になったページは紙に打ち出してしまうのが賢明です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "できるだけたくさんの人が利用できるものでありたいという基本精神は、デジタル化の優先順位にも貫かれ、人気の高い、古典的な作品から手が付けられました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の前の商品開発が優先されるだろうから、この技術の公開にはもう少し時間がかかるだろう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "最優先の課題として意識していた青空文庫の作業マニュアルは、ＢＢＡの原文入力ルールにそってまとめることにした。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「書式や体裁にこだわらず、内容を伝える」ことを優先するＢＢＡに対して、青空文庫は「底本の保存」を重視した。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "法制問題小委員会の最大の役割は、「優先して対応すべき著作権法上の検討課題の抽出・整理」におかれている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "二〇〇四年一一月二六日の第四回小委員会からはいよいよ、法改正に向けて、何を優先して取り上げるかに関する論議が始まった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化庁長官官房著作権課が中心になってまとめたこの素案の段階で、著作隣接権の延長は、優先すべき課題からは落とされた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の事業規模拡大を優先して、公有作品の樹から二〇年分の作者と作品を奪うのか。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械のつごう優先で、先へ先へと進みたい人の気持はお預けだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ太公望や管子は「物」や「力」を優先し、周公や孔子は「礼」や「楽」を優先されたのだが、物事上に注意されたことは同じである。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお又新しい仕事がある時は、会社としては皆さんに採用の優先権を認めますから、お含み下さい。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "決戦戦争に於ては主義として戦略は政略より優先すると同じく、戦略と戦術の利害一致しない時は、戦術に重点を置くのを原則とする。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子への優先権というようなものをも、曖昧な計算のなかへそれとなく入れてもいたのであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国に対する諸外国人の抱いている優先の偏見に向って、中国民衆のハートをひらいて見せ、そこにある声の響きをつたえようとしているのである。",
              "citation": {
                "source": "若い婦人のための書棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "物は特殊である故に「存在の仕方」であることが出来なかった、そして正に此の点で空間関係が「存在の仕方」と想像される優先権を有つわけである。",
              "citation": {
                "source": "範疇としての空間に就いて",
                "author": "――之は一つの習作である――",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論彼は、産めよ殖せよ、という人口国策の線などに沿って、公益優先の見地から、独身者の優位な特権を犠牲にしたのではない。",
              "citation": {
                "source": "友情に関係あるエッセイ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "団体さえ組めば何でも優先権をとれる、という昔とはちがった世渡り上手のこつを会得させることでもないと思う。",
              "citation": {
                "source": "女の行進",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの八月九日の夜、新京から真先に遁走を開始した関東軍とその家族とは、三人の子をつれて徒歩でステーションに向う著者にトラックの砂塵をあびせ、列車に優先してのりこみ、ときには飛行機をとばして行方のわからない高官の家族の所在をさがさせまでした。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間のいのちの受け身の考え方の優先権、自主的生活の不徹底性がここに根ざしている。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械の利用効率を最優先したこうした使い方が一般化する中で、やがてコンピューターの世界にも人間の使い勝手を優先しようとする試みが現われた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗戦後間もない当時、アメリカからの特許出願には特別な優先権が認められていた事情もあって、電子計算機に関する同社の特許は、日本ではきわめて強力な形で成立していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "開発スケジュールを最優先していた京都セラミツク側はこの提案に難色を示したが、結局は押し切られた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
