[
  {
    "uuid": "a9bd9060-a216-51c3-95cb-83bdfe79d361",
    "entry": "優先",
    "reading": {
      "primary": "ゆうせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞",
