      {
        "index": 1,
        "gloss": "traditional hairstyle worn by unmarried women",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
