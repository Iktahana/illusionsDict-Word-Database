        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ちゆうひやら／＼と角兵衞獅子、暢氣に懷手で町内を囃して通る。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "別当も大よろこびで、五六ぺん、鞭をひゆうぱちつ、ひゆうぱちつ、ひゆうひゆうぱちつと鳴らしました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひゆうひゆうひゆう、ひゆひゆう、降らすんだよ、飛ばすんだよ、なにをぐづぐづしてゐるの。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひゆう、ひゆう、ひゆう、ひゆうひゆう。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひゆうひゆうひゆう、ひゆひゆう。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひゆう、ひゆうひゆう、ひゆひゆう。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところへ、子供が飛んで出た、黐棹ひゆうひゆう飛んで出た。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああかい、ゆうひに、てらされて、とうもは、のずえの、いしの、した、――まっさき、かあけて、とっしんし――」「ひろぼうか」　男の子をからかっているのか壮い男の声が軍歌に交りあった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "息をいたす度に、創口でひゆうひゆうと云ふ音がいたすだけでございます。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "何處かでひゆうひゆうと口笛を吹くやうな渡鳥の聲が聞えてゐたが、それもいつの間にか默つてしまふと、四邊はひつそりしてそこらに散らばつた枯つ葉の寐返り一つ打つ音までが、はつきりと耳に響く……　私は以前何かの基礎だつたらしい、平べつたい石に凭れて、じつとそこらを見まはした。",
              "citation": {
                "source": "飛鳥寺",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま開けてやる」　扉を開けると、外は真暗で、嵐を呼ぶ物凄い潮風が、ひゆうひゅうと鳴っていた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　北原ミユキがはつと思う瞬間に、相手は泣きだしそうな顔になり、「なんちゆうひと、あんたは？",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨もよひの風がひゆうひゆうと松を鳴らしてなにかの湧いてくるやうに虫がなく。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
