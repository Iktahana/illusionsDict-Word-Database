    "definitions": [
      {
        "index": 1,
        "gloss": "sportfishing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いよ／＼遊漁鑑札を受けた、これから山頭火の釣のはじまり／＼！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "湊、大貫、竹岡には数多い遊漁船があって、四季いつでも釣れる魚がいる。",
              "citation": {
                "source": "水の遍路",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "鱸釣専門の遊漁家に、「河の水温と鱸釣について」とでもいう研究を、是非やって頂き度いと思う。",
              "citation": {
                "source": "河鱸遡上一考",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他道綸には麻糸、綿糸、ワイヤーなどがあるが、これは主として職業漁師が用いるのであるから、遊漁者は知らんでもよろしい。",
              "citation": {
                "source": "道具と餌と天候",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども鳥の遊漁八して、御大の前に往きて、いまだ還り來ず」とまをしき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
