[
  {
    "uuid": "6924ad16-33e1-58e9-bd96-31d18c1e2dfd",
    "entry": "誘因",
    "reading": {
      "primary": "ゆういん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
