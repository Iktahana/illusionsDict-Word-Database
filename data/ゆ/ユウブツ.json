    "definitions": [
      {
        "index": 1,
        "gloss": "something superior",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あの花売は未曾有の尤物じゃ、また貴様が不可なければ私が占めよう。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この八角に築きたる室には、實に全廊の尤物を擢でゝ陳列せり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどその尤物の皆けおさるるは、メヂチのヱヌスの石像あればなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "不満家の貴方が一寸好いと有仰る位では、余程尤物と思はなければなりません。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるところ相師あり、衆と同じく往き観て諸人に語る、この女後まさに五百男子と歓愛せんと、衆曰くかかる尤物は五百人に愛さるるも奇とするに足らずと、三七日経て長者大歓会を為し、彼女を妙光と名づけた。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前ローマ人は、半男女を不祥とし、生まれ次第海に投げ込んだが、後西暦一世紀には、半男女を、尤物の頂上として求め愛した。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる曠世の尤物を無窮に残し拝ますはアの筆のほかにその術なしとあって、その装束を脱いだ体を画かしめた。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その節集古会員上松蓊君も同行したから彼女の尤物たる事は同君が保証する、あの辺へ往ったら尋ねやってくれたまえ。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七代連綿として相つづき、その最後の第十七代｜松平上野介忠敏こそは、幕末剣客中の尤物で、神田講武所の師範代を長らく勤め、かの清川八郎なぞと共に、新徴組を組織して、その副隊長に擬せられた一代の風雲児です。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この外『新古今』の「入日をあらふ沖つ白浪」「葉広かしはに霰ふるなり」など、または真淵の鷲の嵐、粟津の夕立の歌などの如きは和歌の尤物にして俳句にもなり得べき意匠なり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣のの側に銃もある、而も英吉利製の尤物と見える。",
              "citation": {
                "source": "四日間",
                "author": "ガールシン",
                "note": "青空文庫"
              }
            },
            {
              "text": "「したが、女中は山猿でも、当家の娘は竜宮の乙姫が世話に砕けたという尤物。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほほう、これは、尤物だ」　有村が、入ると、深雪を見て、益満へ、こういった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「不思議なこともある」　益満が、いつにない真面目な、腕組をして「この姉が、矢張り、牧の手にかかって、相果てた」「ふむ、矢張り、尤物であろうの。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史の遺した尤物とはそこに大なる相違があります。",
              "citation": {
                "source": "陶芸家を志す者のために",
                "author": "―芸術における人と作品の関係について―",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅の花は天下の尤物だといわれます。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところがその中にただ一人だけ、眼を奪うばかりの麗人が混っておりましてございます」「ほほう、そんなに美人かな」「大した尤物でございます」「それもやはり婢女かな？",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古歌にちなんで足曳と命名されたこの駿馬は、野に放したが最後、山鳥のように俊敏に、草を踏みしだき、林をくぐり、いや、鳥のごとく天空をも翔けんず尤物。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　また、ひとりが、「いや、じつに尤物！",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、逸物、尤物――なんぼ人形食いの殿様でも、これがお気に召しませんようでは、今後こういう御相談は、平茂、まっぴら御免、なんて、前置きが大変。",
              "citation": {
                "source": "元禄十三年",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "三渓の蒐集品は文人画ばかりでなく、古い仏画や絵巻物や宋画や琳派の作品など、尤物ぞろいであったが、文人画にも大雅、蕪村、竹田、玉堂、木米などの傑れたものがたくさんあった。",
              "citation": {
                "source": "漱石の人物",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝え聞く、悪源太義平の寵愛を受けた八重菊、八重牡丹の姉妹は、都にも稀れなる尤物であったそうな。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、これほどな尤物が一生涯彼の偉業に奴隷的感謝をささげ、彼の前にうやうやしくおのれをむなしゅうする。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
