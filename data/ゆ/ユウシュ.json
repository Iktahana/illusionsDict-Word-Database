[
  {
    "uuid": "adbf9e2d-053d-5574-9593-f25f9b565d63",
    "entry": "幽趣",
    "reading": {
      "primary": "ゆうしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
