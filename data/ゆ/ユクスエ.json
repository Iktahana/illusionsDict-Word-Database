          "standard": [],
          "literary": [
            {
              "text": "今に眼に物を見せてくれようで……」「その上に、これも松倉どんから聞いた話じゃが、あの蔵元屋の後妻が野西の尻に付いて、場所もあろうに大目付の役宅へシャシャバリ出て『可愛い娘を祝言前に殺されて妾ゃ行く末が暗闇になりました。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この哀れなる姿をめぐりて漂う調べの身にしみし時、霧雨のなごり冷ややかに顔をかすめし時、一陣の風木立ちを過ぎて夕闇｜嘯きし時、この切那われはこの姉妹の行く末のいかに浅ましきやを鮮やかに見たる心地せり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "たれかこの少女らの行く末を守り導くものぞ、彼ら自ら唄いて自ら泣く時も遠くはあるまじ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ、こしかた行く末を語らば二夜を重ぬとも尽きざらん、行く末は神知りたもう、ただ昨日を今日の物語となすべし、泣くも笑うもたれをはばからんや。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年互いに知りてついに路傍の石に置く露ほどの思いなく打ち過ぐるも人と人との交わりなり、今日見て今夜語り、その夜の夢に互いに行く末を契るも人と人との縁なり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "行く末のかれが大望は霧のかなたに立ちておぼろながら確かにかれの心を惹き、恋は霧のごとく大望を包みて静かにかれの眼前に立ちふさがり、かれは迷いつ、怒りつ、悲哀と激昂とにて一夜を明かせり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただむやみと私が可愛いので、先から先と私の行く末を考えては、それを幸福の方には取らないで、不幸せなことばかりを想い、ひとしお私がふびんで堪らないのでございました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時、母は私の行く末を心配するあまりに、善教寺という寺の傍に店を出していた怪しい売卜者のところへ私を連れて参りました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "売卜者はうまく私の行く末を卜い当てたのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私は自分の子供らの行く末を思うなら、そういうふうに今から教育しなければさきで困るのではないかと思う事もしばしばある。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで絵画におけるキュービズムやフュチュリズムの運命が、おそらくはこの種の映画の行く末を見せてくれるであろう。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この音の流れて行く末にシャトーのバルコニーが現われて夢見るような姫君のやるせない歌の中にこの同じ主題が繰り返さるる。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説や芝居ならば、浅井親子の捕物や、お角さんの行く末や、いろいろの面白い場面があるのでしょうが、実録は竜頭蛇尾とでも申しましょうか、その結末がはっきりしないのが残念でございます。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "過ぐ世をも顧りみない、行く末も気にかけない。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども今夜は、先刻のラジオのせいもあり、気が弱っているところもございましたので、ふいとその辻占で、自分の研究、運命の行く末をためしてみたくなりました。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お酒を飲まずに寝て、静かに、来しかた行く末を考へるのも、わるくないものだよ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "襖の次にちょっとした更衣の控室もあって、そこへわたくしは寝道具や鏡台を取寄せて、もはや生涯家を脱け出たつもりの仮りであるのか実であるのか行く末判らないこの世の住家を定めました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "越し方のことを考えても縹眇とした無限の中に融け、行く末のことはいよ／＼思い定められぬ晦冥の中に暈けております。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "親たちもまたこんな山奥に一生を送らせるよりも、京鎌倉へ出してやった方が当人の行く末のためでもあろう。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前はもしかすると、そんな処置を取る私たちの無慈悲さを怨むかもしれないけれども、よく考えてみると私たちの前途と、お前の行く末とは、どちらが幸福かわからないのだ。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は特にかわいがっていた太郎がわりに好運でなかった事を残念がっているらしかったが、私はどういうものか芋屋の店先に眠っているおさるの運命の行く末に心を引かれた。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてお前を泣かせるのも決して親自身のためでなくみんなお前の行く末思うての事だ。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一知れたところで、尋常に助太刀の務めを果たすほどのしっかりした覚悟をもっていない彼等は、時の過ぎゆくに従って自分たちの行く末を考えなければならなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "この様な人の行く末は、仕出かすこと少なくて何も出来ないで終る人が多い。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "真情の行く末を探れば、情の海は広々と果てしなく、水面は遠い暗みに入り見えなくなる。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の世の契り知らるる身のうさに行く末かけて頼みがたさよ　と女は言った。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "生ひ立たんありかも知らぬ若草をおくらす露ぞ消えんそらなき　一人の中年の女房が感動したふうで泣きながら、初草の生ひ行く末も知らぬまにいかでか露の消えんとすらん　と言った。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣けもせずキョトンとしているのを引き取ってくれた彦根の伯父が、お前のように耳の肉のうすい女は総じて不運になりやすいものだといったその言葉を、登勢は素直にうなずいて、この時からもう自分のゆくすえというものをいつどんな場合にもあらかじめ諦めておく習わしがついた。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一、景清が仕損じても、平家一門の呪詛によって、源氏のゆくすえも大方は知れて居りまする。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんの一週間前には、ゆくすえは楽しい名誉ある老年を迎えることのできそうな、あらゆる望みで微笑していたのであった。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            }
          ]
        }
