  {
    "uuid": "6b60e0bb-54e1-55e1-8924-06c7dedb69f3",
    "entry": "遊園",
    "reading": {
      "primary": "ゆうえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
