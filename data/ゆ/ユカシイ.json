[
  {
    "uuid": "12a6138c-6acb-5e0c-87e6-68c40a64dfdb",
    "entry": "床しい",
    "reading": {
      "primary": "ゆかしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
