        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "高うして吹雪すらしか、かすかにも雪煙り立ち、その煙絶えずなびけり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "高うして吹雪すらしか、かすかにも雪煙立ち、その煙絶えずなびけり。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪煙りかと思って堀部君は眼を据えてきっと見つめていたが、それが煙りかまぼろしか、その正体をたしかめることが出来なかった。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々、雪煙が、パツ／＼と上つた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十二日　雪後晴　滞在　午後雪がやんで常念や大喰が雪煙を上げている。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風が少し出てきて天狗平の尾根は小さい雪煙を上げている。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "根元へ斧を入れられた樹は先ず頭から振れ出し、細かい雪煙をたてて四辺の下枝を折りながら倒れる。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったとき氷塊を飛ばし、どっと、雲のような雪煙があがったのである。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪崩※　と思ったとき氷塊を飛ばし、どっと、雲のような雪煙があがったのである。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来には夜目にも白々と、時々雪煙りが揚るほかには、どこにも動いているものは見えません。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "地図にお花畑と印してある付近一帯は、両側を小尾根が取り囲んでいるので小康を得たが、ふり仰ぐ上河内の絶嶺は怒髪天をつく、といった恰好で物凄い雪煙を碧空に吹き上げており、その烈しさが思いやられる。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "登りにかかると果してえらい雪煙で、砂漠の嵐のように細かい雪粒が、目といわず、鼻といわず、息のできないほど吹きつける。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "その分岐点まで来ると、ますます雪煙はひどく、頂上まで行けるかと心細くなった。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖の方は雪煙にわざわいされてあいにく眺めることができない。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺岳の双峰が新雪に輝き、鹿島槍がヒマラヤの山のように雪煙を上げる美しい夕景だった。",
              "citation": {
                "source": "槍ガ岳",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッと立つ雪煙り、静かに橇は辷り出た。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スキーから雪煙が立って、音のない谷にシューという快い音をたてて風をきって下りた。",
              "citation": {
                "source": "春の上河内へ",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちになんとなく危げな腰つきだなと見るまに、身体が雪の上を落下してきて雪煙が勇しく立って、小池の姿は見えなくなった。",
              "citation": {
                "source": "五色温泉スキー日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々ぱっと雪煙が上ってひっくりかえるのが見える。",
              "citation": {
                "source": "五色温泉スキー日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち「ほーい」と声を上げ給いつつ雪煙が立つ。",
              "citation": {
                "source": "五色温泉スキー日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初、雪煙がさあっと上がって、それが風と共にひとしきり冷い炎のように走りまわった。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちまた次ぎの風が吹いて来ると、新しい雪煙が上がって再び冷い炎のように走り、前の毳立ちをすっかり消しながら、その跡に又今のと殆ど同じような毳立ちを一めんに残していた……。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんども前脚を雪のなかから引き抜こうとしてば、そこらじゅうに雪煙りをちらしていた。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦慮｜瘠身幾時間ののち、やがて、ミューレの平場へ届こうとするころ『グーテの円蓋』の頂きに、ふと一｜抹の雪煙りが現われた。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "アルプスの潜水夫　――モンブラン登山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪煙もこの辺でなければ見られないものだ。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　直滑降マニア　六十度の斜面――実はせいぜい六度か七度――を、雪煙り立てゝ直滑降した時の気持が忘れられず、酔っぱらっては場所錯誤で、天婦羅屋の二階から、段々をドサドサと墜ちるマニア。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身をかくすほどの猛烈な雪煙を立てながら滑降して行くと、間もなく樹林地帯にはいる。",
              "citation": {
                "source": "大雪山二題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑らかな直滑降に、スキーはすばらしくよく走り、後には高く雪煙りが揚がる。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑らかな直滑降に、スキーの先端は水晶の粉を散らすように走り、後には高く雪煙りが揚がる。",
              "citation": {
                "source": "粉雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やれイ――」「やッつけろ――イ」　梓さんは身体をかがめると、銀色に光るスロープにあざやかなシュプールをひきながら、一団の雪煙りになって弾丸のように滑降して行った。",
              "citation": {
                "source": "キャラコさん",
                "author": "雪の山小屋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
