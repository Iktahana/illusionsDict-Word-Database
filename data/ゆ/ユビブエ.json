    "definitions": [
      {
        "index": 1,
        "gloss": "whistling through one's fingers",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ぴゆう――指笛だ、俺のだ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」Ｎ老人が、そして、ひゅうと指笛を鳴らした。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴゅうと指笛でも吹きそうだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビュービューと熱狂的な指笛を鳴らす者さえ居た。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分の心持をかくす為めに丸田は此の練兵場の隅々までも響くやうな指笛を鳴して見せた。",
              "citation": {
                "source": "煤煙の臭ひ",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "目を輝かせ、めちゃめちゃ嬉しくなり、デンは小屋の入口へ進み、指笛を鳴らした。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉岡方のものは、野犬が野犬を募るように、指笛を鳴らしたり、呼号をあげたりして、見る間にここへわらわらと集まって来た。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "人相の悪い用心棒が裏口を閉め、妙な指笛を吹くと、中の明かりがパッとついた。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "数秒間、方向を失い途方に暮れていると、また奇妙な指笛が鳴るや、魔術のように部屋がギンギンに明るくなった。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、奇妙な指笛が聞こえ、部屋が真っ暗になった。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "後で説明してもらうけど、フェンウィックがここにいる事実だけで奴が張本人だと分かる」　フェンウィックが唇に指を当て、指笛を甲高く吹いた。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾たびか、指笛を、彼は繰返していた。",
              "citation": {
                "source": "御鷹",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "印籠まで抛り上げた、そして指笛を吹いた。",
              "citation": {
                "source": "御鷹",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のすがたを、何ものの障害もない枯野のまっただ中に起たせて、ふたたび、指笛を吹きぬいた。",
              "citation": {
                "source": "御鷹",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるが故に、小柴角三郎は、肺も心臓も、へとへとになるまで、指笛に息を費した。",
              "citation": {
                "source": "御鷹",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……じゃあ呼ぶぜ」　小二の吹く指笛が、水に谺してもの凄い。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピューッ、ピューッと指笛を鳴らしてくる。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するともう、さっきの鋭い指笛がまた近くで闇をツンざいた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄叫子の楽和は、頃あいをみて、「余興に一つ」　と、得意の歌をうたい、さらにまた、求められて、諸葛孔明の“五｜丈原ノ賦”を指笛で吹いて聞かせた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽和はまた、人目を忍んで、折々城壁の堤から濠の彼方へむかって、のん気な指笛を吹いて逍遥していた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頃から逗留中のお客衆、それっ、思い思いの膳につけ」　と、病尉遅孫立の大音声につれて、とつぜん、鉄叫子｜楽和のするどい指笛が祝朝奉の耳を驚かせた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピューッ、ピューッ、さかんなる賊兵の指笛がどこかでつンざく。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、数えていると、どこか遠い外の方で、するどい指笛が二度ばかり聞こえた。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ――たった今、郵便箱の蔭で、指笛を吹いたトム公だけがすぐにそれを見つけて、にこッ、と笑った。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "各個の監禁室にいる不良児たちは、バンザイのかわりに、指笛をふいて、監視に叱りつけられた。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
