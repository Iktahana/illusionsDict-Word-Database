        "examples": {
          "standard": [
            {
              "text": "結納品には、鯛やスルメなど縁起物が並んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "デパートの結納品コーナーで、美しい漆器を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は結納品を風呂敷に包んで持参した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "正式の結納品が部屋に飾られたのを見た途端、紀代子はまるであっさりと心が変ってしまった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "密造酒をつくることも、仲介人が結納品のかけ合をやる婚礼もすぐには絶えなかった。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "結納品のことなどは、矢代は母と相談の結果、東野に一任することとした。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ継母おまんも例の生家へ世話しようとしたお粂の縁談を断念し、残念ながら結納品をお返し申すとの手紙を添え、染め物も人に持たせてやって、稲葉家との交渉を打ち切った。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
