        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そう云えばだんだん娘の性情の不平均、不自然なところも知れて来かかっていたし、そういう揺り返しが、たまたま起るということも、今更、不思議に思われなくなっていた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その揺り返しは必ずや、仮りの乞食のマスクを奪い、折角の憩いも空しくされるでしょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、再び揺り返しが、彼の周囲へ襲って来た。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "過ぐる東京での震災の日には、打ち続く揺り返し、揺り返しで、その度に互いに眼の色を変えたことが、言わず語らずの間に二人の胸を通り過ぎた。",
              "citation": {
                "source": "食堂",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "揺り返しの間を見、私は、いそいで階子を降りた。",
              "citation": {
                "source": "私の覚え書",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は、一日、揺り返しが続き、私は二階と下とを往来して暮してしまった。",
              "citation": {
                "source": "私の覚え書",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園に蚊帳をつり、二人の子供が膝に突ぷし「母様、地球の終りじゃあないの、終りじゃあないの」と、強い揺り返しが来る度に云ったとき「其那ことがあるもんですか、大丈夫！",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「揺り返しは初めのよりひどいと云うから、此度は大変よ。",
              "citation": {
                "source": "変な男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は雪になったが、揺り返しはなかなかやまなかった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "揺り返し、揺り返しで、不安な日がそれから六日も続いた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからの昼夜幾回とない微弱な揺り返しは、八十余里を隔てた江戸方面からの余波とわかった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく変事があったに相違ない、家族の安否いかんと、まだ揺り返しに踏む足もフラフラしながら屋内に飛び込んでみると、妻と次男以下の三子とは、書庫にしている石蔵の隅に、小さくなって固まっている。",
              "citation": {
                "source": "震災日誌",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "強い揺り返しは相変らずやって来る。",
              "citation": {
                "source": "震災日誌",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえしばしば酷い揺り返しが来るので屋内に入ることが出来ぬ。",
              "citation": {
                "source": "震災日誌",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変らず揺り返しが繰り返される。",
              "citation": {
                "source": "震災日誌",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "揺り返しは相変らずやって来る。",
              "citation": {
                "source": "震災日誌",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と云う叫びがまだ唇を離れないうちに、今の今まで見えていた人の寝姿を押し隠して、陰気に重々しく二三度ゴロッ、ゴロッと揺り返した。",
              "citation": {
                "source": "禰宜様宮田",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「揺り返しが来もんでな、明晩もあんまか指圧師にかかりやった方がよろしゅござんそ」「揺り返し？",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのゆりかえしが今やって来て、以前の東京の約一倍半位にはなっている。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日中時々ゆりかえしがあり、自分は不安で仕事が手につかず。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで又ゆりかえした時「時計出しましょうか」で大笑い。",
              "citation": {
                "source": "日記",
                "author": "一九三一年（昭和六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（村子を見、それから周囲を見まわす）村子　……（不安そうに天井を見た目を花岡に移す）ゆりかえしだわ。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
