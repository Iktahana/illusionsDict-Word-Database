        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……一体が、天上界の遊山船に擬らへて、丹精籠めました細工にござるで、御斉眉の中から天人のやうな上※御一方、と望んだげな。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秀の家ではだん／＼持船を人に譲って、残した小綺麗な船だけにオールのクラッチを取付け女子供でも漕げるような遊山船にしました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊山船にでも乗ったような顔をしている。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊山船にでも乘つたやうな顏をしてゐる。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "……墨堤の桜……ボート競漕……川開きの花火……両国の角力や菊……扨は又、歌沢の心意気や浮世絵に残る網舟……遊山船、待乳山の雪見船、吉原通いの猪牙船……群れ飛ぶ都鳥……。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "白鳥号に似た大きな遊山船が、この道を通ったが、左のほうへ曲がって、セーヌ川をずんずん上って行った、というのであった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から花は真っ盛り、日和は上々、向島の土手の上は人間で盛りこぼれそうで、川面は遊山船でいっぱい、小僧の一人や二人が向島へ駈け出したところで、花見船を見付けることなどは思いも寄りません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "花見の留守",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から花は眞つ盛り、日和は上々、向島の土手の上は人間で盛りこぼれ相で、川面は遊山船で一杯、小僧の一人や二人が向島へ駈け出したところで、花見船を見付けることなどは思ひも寄りません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "花見の留守",
                "note": "青空文庫"
              }
            },
            {
              "text": "「放つて置くが宜い、武家の遊山船だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "兵庫の眼玉",
                "note": "青空文庫"
              }
            },
            {
              "text": "落着いた先は小梅の大きな寮、隅田川から水を引いた池の上には、見事な遊山船を浮べて、春宵一刻を惜しむの長夜の宴を、昨日も今日も開いているのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "不死の霊薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "大川の水が近く光つて、遊山船の櫓の音も聞えますが、あたりが靜かなので、ひどく田舍びた感じです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "浮世繪の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「放っておくがいい、武家の遊山船だ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "大村兵庫の眼玉",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い川は見渡すかぎり、各種のボートや遊山船で埋まっていた。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊山船は美しく建造され、底は広くて楽に坐れ、完全に乾いている。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは見事な遊山船で、芸者、立派な昼飯、その他この航行を愉快にするものがすべて積み込んである。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
