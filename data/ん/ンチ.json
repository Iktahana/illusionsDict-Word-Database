    "definitions": [
      {
        "index": 1,
        "gloss": "'s house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕、午睡の夢から覚めてみると　　みなさん家を空けておいでだつた　　あの時を妙に思ひ出しますさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学の殿堂と言っても、その建設はもちろん家屋の建築とはわけがちがう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん家族の皆からかわいがられ、あらゆる猫へのごちそうと言えばこの三毛のためにのみ設けられた。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "署長はもうみんなも帰る時分だしと思って自分も一ぺん家へ帰るふりをして町をぐるっとまはりみんなが戻ったころまた役所へ来て小使に自分の室へ電燈をつけさせて待ってゐました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰る家がなかったら俺ん家へ来い。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しは母の機嫌も取って、だんだん家事向きの勉強もしてもらわなきゃなるまいと思うがね。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん家には最近迎えたばかりの新妻はあり、夫婦生活の味もまだ身に染む間もないころのことだったが、銀子にも嫉妬に似た感情の芽出しはありながら、それを引きとめる手もなく、双方物足りぬ感じで別れるのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいぢや、角ちやん家は旦那衆だね。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで弥助さんも、兎も角一ぺん家へいつて見る気になつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧弱な奴等だ」　鼈四郎は、軽蔑し切った顔をしたけれども、ふだん家族のものには廉価なものしか食べることを許さぬ彼は、家族が自分の掟通りにしていることに、いくらか気を取直したらしい。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼈四郎はだんだん家へ帰らなくなった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」氏「あんまり遅く家の者共を、驚かしてはいけないと思って、昨夜はホテルへ泊り、今日あっちこっちの本屋へ行って金でも集めて、一たん家へ帰ってからまたこっちへ来ようと思ったんですけど、今朝起きたら面倒になっちまって万事｜放擲して来ちまいました。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん家に残した娘達への回避の念、物質本位の家業に対する倦厭の情は、いつもの通りくりかへして述べられた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三男　　かあさん、お医者さん家のかどんとこで、去年の綿砂糖のおじいさんが売ってたら、買ってきてね。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "和太郎さんは縄きれを持ったまま、とんでいって、おかあさんの手をつかむと、だまってぐんぐん家へひっぱってきました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「じゃあ貢さん家に猫は居ないのかい。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは風呂敷包を持って、一たん家に帰りましたものゝ、まるで落付いた心はありません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん家元へ向ってのわたくしに花嫁候補の資格が欠けるためでしょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾佐は千代重がだんだん家庭に慣れて来たとき、珍らしく嬉しそうな顔をして彼女にいった。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、年二回の昇給のほかに賞与もあり、さらに主任の話によれば、「なんし、広い大阪やさかい、電話をもってながら、申込んでさえ置けば、ちゃんと消毒婦を派遣してくれるちゅううちのような便利なもんのあるのを、知らん家がある。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために、町の外へは、どんどん家がたちつまりました。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん家主の酒屋へ聞合せなどに行こうとする気はなく、顫えあがって足早にそこを立去ったが、だんだん落ちついて考えてみると、八月の真っ昼間、暑い日がかんかん照っている。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階のとたん家根を雀が歩いても、そのぼと／＼といふ音から、渠の胸には父の思ひ出が押し迫つて來るのである。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が、働かないと、だんだん家中干ぼしになる怖れあり、貴君は家庭教師など、不賛成かもしれませんが、どうかあしからず。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「校長先生のお言葉ですし、一ぺん家の者に相談してみます」こう言った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　するとおばあさん家鴨が、「どれ私にその割れない卵を見せて御覧。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん家ではあばれるのさ」　やがて子どもらはまた出てしまう。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつは、いそぎんちゃくだよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手の車庫のトタン屋根に雀が二羽、一羽がちょんちょんと横飛びをして他の一羽に近よる。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく幼少なる「加八」君はここでそのありたけの深謀をちゃんちゃんこの裏にめぐらして最後の狙いを定めて「ズドーン」と云って火蓋を切る真似をする。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
