    "definitions": [
      {
        "index": 1,
        "gloss": "suffix used at sentence end for humorous effect",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
