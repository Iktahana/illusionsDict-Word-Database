        "examples": {
          "standard": [
            {
              "text": "「これ、どっちの色がいいと思う？」「んん……左の方が落ち着いてていいかな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「明日の予定、空いてる？」「んん、ちょっと確認してみるね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この計算、どこか間違ってるかな？」「んん、この部分の符号が逆じゃない？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "最後に吉彦さんがじぶんで、大きく大きく撞木を振って、がオオんん、とついた。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええら、いい凪だな、沖ぢやまだ眠つてゐるだが、俺ちの崖の下は真蒼だ、――そうれ、また、さらさら、ざぶん、ざぶん、んん……尖んがり岩に波がぶつかる、怖かねえほど静かぢやねえかよ、まるで、はあ、鮑の殻見たいにチラチラするだね。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾らだとか言ったっけな、んんどうだろう、うむ、豪儀な。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対して一体どんんな武器があるだらうか。",
              "citation": {
                "source": "柊の垣のうちから",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「正昭さんは酒は好きかい」「んんん」　首をふる高子にいねは、「そんなら一人で淋しかろ、早う帰ね、早う帰ね」といった。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
