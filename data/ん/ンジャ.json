        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "はっきり言ったっていいんじゃないかしら。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場はかるく狼狽の様子で、「くらべたりするもんじゃないよ」と言って笑ったが、すぐにけわしく眉をひそめ、「いや、ものごとはなんでも比較してはいけないんだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「朝顔みたいなつらをしやがって、と来るんじゃないかね？",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北京は、こんなもんじゃないぜ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御自分の嫁さんと逢うんじゃないか。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな家庭は、めったにあるもんじゃない。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前の方から喧嘩を吹っかけたんじゃねえか」　私は、実は歩くのが堪えられない苦しみであった。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな自棄を云うもんじゃないよ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴あ泣寝入りと云いたいんだが、泣寝入り処じゃねえや、泣き死にに死んじゃったじゃねえか。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、お前気でも狂ったんじゃないのか」　セコンドメイトは、ポシャッと云った水音で振りかえってそう云った。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、この野郎白っぱくれて、網を張ってやがるんじゃねえかな。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、どうだい、危ねえ処に乗り込んだもんじゃねえか。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお、いい子、いい子、泣くんじゃねえ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒じゃあるめえし、夜中に踏み込まなくたって、逃げも隠れもしやしねえよ」（此儘行ったんじゃ困る。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆やられたんじゃ仕方がないからな。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は、「それゃ表面のこった、そんなもんじゃないや、坊ちゃん奴」と云おうとしている。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が予め読者諸氏に、ことわって置く必要があると云うのは、これから、第三金時丸の、乗組員たちが、たといどんな風になって行くにしても、「第一、そんな船に乗りさえしなければよかったんじゃないか、お天陽様と、米の飯はどこにでもついて、まわるじゃないか」と云われるのが、怖しいためなんだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "強い奴を腹ん中へ入れといて、上下から焙りゃこそ、あの位に酔っ払えるんじゃねえか」「うまくやってやがらあ、奴あ、明日は俺達より十倍も元気にならあ」「何でも構わねえ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "――俺が踏み殺したんじゃあるまいか？",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく続けている観測も上長官が交迭して運悪く沿革も何も考えぬような後任者が来ると、こんな事やっても何にもならんじゃないかの一言で中止になるという恐れがあった。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、親子の縁は切り度くないもんじゃよ」　とその言葉の下から縋り声で寄り戻した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいえさ、勉強しろとか、早く成功しろとか、そんなことをいうんじゃないよ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お座敷の出がけだが、ちょっとあんたに云っとくことがあるので寄ったんだがね」　莨入れを出して、煙管で煙草盆代りの西洋皿を引寄せて「この頃、うちのみち子がしょっちゅう来るようだが、なに、それについて、とやかく云うんじゃないがね」　若い者同志のことだから、もしやということも彼女は云った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "六原に居たんじゃ馬は使えるだろうな。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、あちこちちらばったんじゃさがし出せない。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のこったやっぱり民子を見に来たんじゃないかと、自分で自分を嘲った様なことがしばしばあったのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "来月から千葉の中学へ行くんじゃないか」　民子は年が多いし且は意味あって僕の所へゆくであろうと思われたと気がついたか、非常に愧じ入った様子に、顔真赤にして俯向いている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに政夫は学校へ行ったんじゃないか、暮には帰ってくるよ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全地帯に立って見ていた二、三人連れの大学生の一人が運転手の方を覗き込んで、大声で、「ソートーなもんじゃー」と云った。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男の変った所説の一例を挙げると、自分が風邪を引いて熱を出したりしたとき「アンマリ御馳走を喰べ過ぎるんじゃあないですか」と云ってはにやにや笑うのであった。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
