    "definitions": [
      {
        "index": 1,
        "gloss": "such (about the actions of the listener, or about ideas expressed or understood by the listener)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
