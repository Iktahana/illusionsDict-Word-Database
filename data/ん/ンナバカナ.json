    "definitions": [
      {
        "index": 1,
        "gloss": "such a stupid ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
