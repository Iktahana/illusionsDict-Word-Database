    "definitions": [
      {
        "index": 1,
        "gloss": "to endeavor to",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "城の塀乾きたり風の吹く草｜靡く丘を越え、野を渉り憩ひなき白き天使のみえ来ずやあはれわれ死なんと欲す、あはれわれ生きむと欲すあはれわれ、亡びたる過去のすべてに涙湧く。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの場合にわれわれは彼の言わんと欲するところをかなりの程度まで確かに具体的に捕えうるように思う。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の問うところは自分の言わんと欲するところ。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう言ってもおそらく私の言わんと欲するところは容易に通じないだろうと思う。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に殷に命じて鏡中雙鸞の圖を造らしむ、圖する處は、陽王其の寵姫の肩を抱き、頬を相合せて、二人ニヤ／＼として將に寢ねんと欲するが如きもの。",
              "citation": {
                "source": "聞きたるまゝ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一団の烟が急に渦いて出るのを、掴んで投げんと欲するごとく、婆さんは手を掉った。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそれが静まらないと、浮世の波に乗っかってる我々、ふらふらと脳が揺れる、木静まらんと欲すれども風やまずと来た日にゃ、船に酔う、その浮世の波に浮んだ船に酔うのが、たちどころに狂人なんだと。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "本社はさらに深く事件の真相を探知の上、大いにはりがねせい、ねずみとり氏に筆誅を加えんと欲す。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ実に祭司長が述べんと欲するものの中の糟粕である。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その愈々鋭利なるほど、愈々公明に我等はこれに答えんと欲する。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日｜此処に集まりました人人はあながちクリスト教徒ばかりではありません、されどいずれの宗教に於てもこれを云わんと欲するものであります。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "豈それ辟易せざらんと欲するも得んや。",
              "citation": {
                "source": "鑑定",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後で水車のごとく杖を振廻していた訓導が、「長蛇を逸すか、」　と元気づいて、高らかに、「たちまち見る大蛇の路に当って横わるを、剣を抜いて斬らんと欲すれば老松の影！",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『心』広告文夏目漱石　自己の心を捕へんと欲する人々に、人間の心を捕へ得たる此作物を奨む。",
              "citation": {
                "source": "『心』広告文",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、伸びんと欲するものは、なぜ屈しなければならぬのか！",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "己れ只一人｜智からんと欲するは大愚のみ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十、数奇好み無からんと欲するも得ざるなり。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六日、丁亥、天晴、安念法師の白状に依りて、謀叛の輩を、所々に於て生虜らる、凡そ張本百三十余人、伴類二百人に及ぶと云々、此事、濫觴を尋ぬれば、信濃国の住人泉小次郎親平、去々年以後謀逆を企て、輩を相語らひ、故左衛門督殿の若君を以て大将軍と為し、相州を度り奉らんと欲すと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、それは既に過去の奥州であつて、人もし現代の奥州に就いて語らんと欲すれば、まづ文芸復興直前のイタリヤに於いて見受けられたあの鬱勃たる擡頭力を、この奥州の地に認めなければならぬ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの佐藤理学士の言説の如く、「人もし現代の奥州に就いて語らんと欲すれば、まづ文芸復興直前のイタリヤに於いて見受けられたあの鬱勃たる擡頭力を、この奥州の地に認めなければならぬ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王、徳州の城の、修築｜已に完く、防備も亦厳にして破り難く、滄州の城の潰えるゝ」］こと久しくして破り易きを思い、之を下して庸の勢を殺がんと欲す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "将士の父兄子弟｜之を見て、皆感泣して、王の為に死せんと欲す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦わんと欲すれば力足らず、帰らんとすれば前功｜尽く廃りて、不振の形勢｜新に見われんとす。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども此時の勢、ただ退かざるあるのみ、燕王の衆意を容れずして、敢然として奮戦せんと欲するもの、機を看る明確、事を断ずる勇決、実に是れ豪傑の気象、鉄石の心膓を見わせるものならずして何ぞや。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝｜大に怒って、命じて其舌を断らしめ、曰く、吾周公の成王を輔くるに傚わんと欲するのみと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝怒りて之を殺さんと欲す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "三たび登ると　九たび到ると、古徳と与に同じうせんと欲す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "古徳と同じゅうせんと欲するは、是れ仮にして、淮楚浙東に往来せるも、修行の為なりしや游覧の為なりしや知る可からず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "苟も徒に　文辞に溺れなば、蛍※　妍を争はんと欲するなり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "建文の草庵の夢、永楽の金殿の夢、其のいずれか安くして、いずれか安からざりしや、試に之を問わんと欲する也。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
