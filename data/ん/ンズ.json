    "definitions": [
      {
        "index": 1,
        "gloss": "will (probably)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なかんずくヘルンを最も悲しませたのは、盆踊等の農村行事や風俗やが、明治政府によって禁圧されたことから、自然に衰褪して来ることだった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから面喰つてゐる私に對して、ずんずん次のやうなことを話し出した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ君｜倦んずる額をあげて不滅の生命をさとり得なば胸うちたたいて大神には讚美と感謝をささげてずや。",
              "citation": {
                "source": "感謝",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは潮の關係で、ずんずんうしろに流されてゐます。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷風がさやさやと、川楊の葉に衣擦れのような音をさせて通行する、雲はずんずん進行して、山の緑は明るくなったり、暗くなったりする。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎坊附近の、黄紅朱樺の疎らな短木の中を、霧は幾筋にもなって、組んず、ほぐれつして、その尖端が愛鷹山の方向へと流れて行く、振り返れば、箱根｜火山彙には、雲が低く垂れて、乙女峠から金時山の腰へかけて、大河の逆流するばかり、山と山との間は、幾つにも朝雲が屯ろして、支流が虚空の方々に出来る。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち船はもうずんずん沈みますから、私はもうすっかり覚悟してこの人たち二人を抱いて、浮べるだけは浮ばうとかたまって船の沈むのを待ってゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大内は夏服の上に黄色な実習服を着て結びを腰にさげてずんずん藪をこいで行く。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうずんずん瀑をのぼって行く。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずんずん近づいて来たのです。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と思いながら、ずんずん進んで行きました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくはいちばんはじめにあんずの王様のお城をたずねるよ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでぼくはでてきてあんずのおひめ様をつれてお城に帰るんだ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその半面の随伴現象としていわゆる骨董趣味を邪道視し極端に排斥し、ついには巧利を度外視した純知識慾に基づく科学的研究を軽んずるような事があってはならぬと思う。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学者が第一次近似をもって甘んずる時、世人は却って第二次近似あるいは数学的の精確を期待する場合もあり。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰の成分は主に種々の軽金属の酸化物で、なかんずく水に溶ける分は強いアルカリ性でいわゆる灰汁になる。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから友はくるりと背後を向き、いかにもすげない冷やかな顏付をして、一人でずんずんと歩いて行つた。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は詩を思ふと、烈しい人間のなやみとそのよろこびとをかんずる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十字巷路に秋のふんすゐ、はやひとり探偵はうれひをかんず。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆景春夏すぎて手は琥珀、瞳は水盤にぬれ、石はらんすゐ、いちいちに愁ひをくんず、みよ山水のふかまに、ほそき滝ながれ、滝ながれ、ひややかに魚介はしづむ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間が人間の生殖器を醜悪にかんずること。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世にも稀有な鬼才をもちながら、不幸にして現代に認められることが出来ないで、あまつさへその若い生涯の殆んど全部を不治の病床生活に終つて寂しく夭死して仕舞つた無名の天才画家のことを考へると、私は胸に釘をうたれたやうな苦しい痛みをかんずる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その音は上方にずんずん押し擴がりながら、狹いヴァル・フルウリィぢゆうに一ぱいになつてしまひました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故、すべてのものが私の中にずんずん深く入つてゆき、そしてこれまで何時もそこに止つてゐた場所にもはや止らうとしないのか、私には分らない。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことに捉われていたから、東京人は田舎者にずんずん追いこくられてしまったのよ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "用のない者はずんずん前進する‥‥」と、騷ぎの最中に小隊長の大島少尉ががみがみした聲で呶鳴つた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕先づ出｜陣に及んで何と四｜勝一｜敗、すつかり得｜意になつてゐると、つい二三日前には口｜惜しさの腹癒やさんずと向うから來｜戰に及んで何と三｜敗一｜勝、物の見事に復讐されてしまつた。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『そんなことを言わないで、ずんずんやりたまえよ。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の対自然観が外国人なかんずく西洋人などのそれと比較していかなる特徴をもっているかということについては最近に他の場所でやや詳しく述べたからここでは詳細の解説は省略するが、その要点をかいつまんで言ってみると次のようなものである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日常生活の拘束からわれわれの心を自由の境地に解放して、その間にともすれば望ましき内省の余裕を享楽するのが風流であり、飽くところを知らぬ欲望を節制して足るを知り分に安んずることを教える自己批判がさびの真髄ではあるまいか。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
