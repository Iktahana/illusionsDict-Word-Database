      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "joint",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "那須野が原へかかつて雨煙が野を籠めて路に塵も無く、一路坦々、砥の如く平らかに矢の如く直くして、目地遙かに人影を見ざる中を、可なりの速力で駛らせると、恰も活動寫眞を觀るが如くに遠くの小さな物が忽ち中位になり、大きくなつて、そして飛ぶやうに背後へ、抛げ遣るが如くに過ぎ失せてしまふのも一種の快味がある。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くは手織の麻か盲目地の無尻に同じ股引を穿いたそれ等の服装は、彼の教へてゐるＳ村の子供とさしたる違ひはなかつた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の不安に堪えずして目地を検べ、床を叩き、よろめきながら地下室に踏み込む。",
              "citation": {
                "source": "レンズとフィルム",
                "author": "――それも一つの性格である――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こころの不安に堪えずして目地を検べ、床を叩き、よろめきながら地下室に踏み込む。",
              "citation": {
                "source": "物理的集団的性格",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、暗い闇の夜に高知から郷里に向かっての帰途、岩目地というところの低い岡の南側を通るように道がついている。",
              "citation": {
                "source": "火の玉を見たこと",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかんずく、錦明宝という剣葉畝目地白覆輪の万年青をなめずらんばかりに大切にし、どこの町端の『万年青合せ』にも必ず持って出かけて自慢の鼻をうごめかす。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "稲荷の使",
                "note": "青空文庫"
              }
            },
            {
              "text": "盲目地の袷に、豆絞りの頬冠りで、懷中に呑んでゐた匕首を拔いて、脅しながら――俺は黒雲五人男の一人だ、岡つ引の家を承知で入つたが、ジタバタすると命が危ない。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "群盗",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子ノ桟、便所ヤ風呂場ノタイルノ目地、ソレラガスベテ二重ニ見エ、カツ少シズツ歪ンデ見エル。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば埼玉県の野島の浄山寺の片目地蔵などは、あまりよく出て行かれるので、住職が心配して、背中に釘を打って鎖でつないで置くと、たちまち罰が当って悪い病にかかって死んだといいます。",
              "citation": {
                "source": "日本の伝説",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "静岡県｜田方郡｜函南村仁田）　しばられ地蔵というのにはいろいろあって、京都の壬生寺の縄目地蔵などは、一つは身代り地蔵でありました。",
              "citation": {
                "source": "日本の伝説",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何となく陰気に薄暗くじめじめして、妙に気味の悪い厭な感じがしたので、夫人が直覚的に反対したにもかかわらず、ヘルンは一見して大いに気に入り、『面白いの家』『面白いの家』と、子供のように嬉しがって、是非それを買おうと言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の夏に特有な、梅雨時の暗い天気と、畳の上にカビが生えるような、じめじめした湿気と、そうした季節に、そうした薄暗い家の中で、陰影深く生活している人間の心境とが、句の表象する言葉の外周に書きこまれている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてじめじめする肌の汚れも洗って清浄な心になりたくなるので、手拭をさげて主婦の処へ傘と下駄を出してもらいに行く。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしたじめじめした池沼のほとりの雰囲気はいつも自分の頭のどこかに幼い頃から巣くっている色々な御伽噺中の妖精を思い出すようである。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ん坊のめじろが巣から落ちていたときは、助けて巣へ連れて行ってやった。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたらめじろは、赤ん坊をまるでぬす人からでもとりかえすように僕からひきはなしたんだなあ。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならば君の今の生活や心境には、僕の正面から敵としてゐる自然主義的の人生觀――東洋的なあきらめや、じめじめしておつけ臭い俳句趣味――やがあるからだ。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの階上の、破風の下の眞白な部屋には、いま、女中どもが睡つてゐる――夜中から朝まで、その重苦しい、じめじめした眠りを睡つてゐるのかも知れないのだ。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "商店の倉庫らしい建物の立ち並んだ、高い、じめじめした煉瓦塀の兩側から迫つた、二三間幅の道。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方が国の為めじゃ。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその谷に当ったところには陰気なじめじめした家が、普通の通行人のための路ではないような隘路をかくして、朽ちてゆくばかりの存在を続けているのだった。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは、私が東京へ出て一年くらい経った、なんでもじめじめ雨の降り続いている梅雨の頃の事と覚えていますが、柄でも無く、印刷所の若いほうの職工と二人で傘をさして吉原へ遊びに行き、いやもう、ひどいめに逢いました。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水がじめじめしてその表面にはあちこち赤い鉄の渋が湧きあがり見るからどろどろで気味も悪いのでした。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にも雀ややまがらやみそさざい、めじろ、ほゝじろ、ひたき、うぐひすなんといふ、いつまでたっても誰にも見まちがはれるてあひなどは、きゃっきゃっ叫んだり、手をつないだりしてはねまはり、さっそくとんびの染屋へ出掛けて行きました。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへばめじろは眼のまはりが染まらず、頬じろは両方の頬が染まって居りません。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はめじろや頬じろは、自分からたのんであの白いとこは染めなかったのだらうと思ふよ。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうするとどうしてあんなにめじろも頬白も、きちんと両方おんなじ形で、おんなじ場所に白いかたが残ってゐるだらうね。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道が林の中に入り、しばらく道はじめじめして、あたりは見えなくなりました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の朝は霧がじめじめ降って学校のうしろの山もぼんやりしか見えませんでした。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とじこめちまえ、畜生めじたばたしやがるな、丸太をそこへしばりつけろ。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
