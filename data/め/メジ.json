[
  {
    "uuid": "f98b1269-6b3b-567a-a484-054bb1231d1c",
    "entry": "目地",
    "reading": {
      "primary": "めじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
