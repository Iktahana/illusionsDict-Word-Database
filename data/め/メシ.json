      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "summons",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しっかり、ひとつ召し上って下さい。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時の女の顔は不思議な美しさに輝いて、涼しい眼の中に燃ゆるような光は自分の胸を射るかと思ったが、やがて縁側に手をついて、宜しくば風呂を御召しあそばせと云った時はもう平生のお房であった。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん御拝の長かったは母上で、いちばん神様の御気に召したかと思われるはせいちゃんのであった。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年、應召して、あちこち轉戰して、小閑を得る度毎に、戰爭を題材にした小説を書いては、私のところに送つて來ました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お氣に召しましたか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお鈴さんは口調を改めて言ひ、「せめて、雀の里のお土産のおしるしに、この葛籠のうちどれでもお氣に召したものをお邪魔でございませうが、お持ち歸り下さいまし。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇室ではそれをよみせられ、召し上げられて飽衣美食でもてなしました。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二荒の山にまします女神だち歌のわく子にさちあらせたまへ翌日朝早く案内者一人｜召し具し二人きおいにきおいて滝壺に下る。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子可哀相と思召したら、どうぞ民子が今はの話も聞いて行って下さいな。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでゴルドンがいよいよ最後の「仕上げ」にかかる頃には、早速召し上げて行って使った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年一月三十日『東京朝日新聞』）　　　　　　　　　六十三　　　　　　マホメットの墳墓　トルコ皇帝陛下は近頃メジナにある回々教祖マホメットの墓に電灯をつけて神聖な墓地の闇を照らそうという事を思し召し立たれて英国の某会社に右の工事一切を御下命になったと伝えられている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眺め渡した処「御気に召した題」が一つも見つからぬので面倒臭くなって片っ端から一瀉千里に片付けてやる決心をする。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "主膳が、Ｔ「同じ一味の但馬屋源兵衛を召し捕って戴き度い」　と言う。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「木ッ葉役人の二十三十束にして」　とづかづか近寄り乍ら、Ｔ「なりひら小僧を召し捕るたァ」　と言って、Ｔ「虫が好すぎるぜ大将」　で主膳グーの音も出ない。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "七兵衛が云う、Ｔ「確かになりひら小僧」　よしッ、と左衛門、Ｔ「連判状を受け取った上で召し取って了え」　と、云う。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは今日お互に顔を合せてどう致すと思召していらっしゃいましたの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一｜度生きられるものだと思召していらっしゃるの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほんとに、これをふだんにお召しなさいましな。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "越前屋の亭主はすぐに召し捕られて吟味を受けた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お徳の白状もあるのですから、すぐに宇三郎を召し捕ってもいいんですが、宇三郎という奴はなかなか食えない老爺らしいので、下手に当人を引き挙げて強情にシラを切っていられると面倒ですから、まず料理番の富蔵をおさえて、こいつの口から動かない証拠を挙げてしまおうと思ったんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙屋の亭主こそ実に迷惑で、それがために思いもよらない災難をうけて、一旦は召し捕られたり、その後もたびたび番所へ呼び出されたり、どうもひどい目に逢いましたが、右の事情が判って無事に済みました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店の娘だって容貌のぞみで大名の御部屋様にもなれねえとも限らねえが、それなら又そのように打ち明けて召し抱えの相談もありそうなもんだが、少し理窟が呑み込めねえな」と、半七はしばらく考えていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "祈祷料は思召しなんですけれど、ひとりで二｜歩三歩も納める奴があるそうですから、たいしたものです」「それはまあそれとして、その行者は工面のよさそうな信心ものを奥へ連れ込んで、なにか秘密の祈祷をして多分の金を寄進させるというじゃあねえか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "式部は容易にそれに手を触れなかったが、結局お姫様の思召しをうけたまわるまで、ともかくもお預かり申して置くということになって、その二百両を受け取って帰った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた方のような立派なお方が兎の茶色の団子なんか召しあがるもんですか。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いかがです、今日は一つ、お風呂をお召しなさいませ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょうがありませんね、それじゃご一所に召しあがれ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうです、いま召し上りませんか。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから十日ほど経って十二月の四日に、白石はまたシロオテを召し出し、日本に渡って来たことの由をも問い、いかなる法を日本にひろめようと思うのか、とたずねたのである。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山賊仲間に聖者のゐたためしは先づないが、修道院の中には天使から悪魔までがずらりとゐる。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
