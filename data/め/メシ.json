[
  {
    "uuid": "3202ca0a-7e41-5714-bf80-807163df4c27",
    "entry": "召し",
    "reading": {
      "primary": "めし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
