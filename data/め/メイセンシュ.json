        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "またしばらくすると、経済逼迫のために、古橋その他の有名選手たちが夏休みのアルバイトとして、銀座辺で漬物屋の店をひらくとか、そういう店に働くとかいうニュースがでた。",
              "citation": {
                "source": "ボン・ボヤージ！",
                "author": "――渡米水泳選手におくる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "金徳一は、知る人ぞ知る、先のバンタム級の世界ベストテンに数えられた名選手でした。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "見給え、世界の名選手さへ大抵は得意の微笑のかげに渋面を隠しているではないか？",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "見給へ、世界の名選手さへ大抵は得意の微笑のかげに渋面を隠してゐるではないか？",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙はＢ級の無名選手だが、このレースでは一着を出している。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、川崎で起った大紛擾、売り上げ強奪事件は、内山という名選手、当然優勝すべき本命選手が、車の接触か何かで反則し、除外されることによって起ったものだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "人名は分り易く二人の有名選手の名をかりたが、この二人は八百長をやる人ではない。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "レースを棄てない名選手でもある。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に、田川、これ又、名題の名選手で、対抗は充分である。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女に内幕をあばかれると、たいがいの名選手が家庭争議を起して、神経衰弱にならざるを得ない。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二つが大資本に物を云わせて、名選手を縦横無尽にひッこぬいている。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "水泳の名選手はすぐ起上りましたが、蝋燭はどこかへ流されてしまった様子です。",
              "citation": {
                "source": "水中の宮殿",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
