        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "半七もその以上には、差し当って目串のさしようがなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんと云っても下総屋の番頭さんに目串をさされるんですが、あんな堅い人がよもやと思うんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時にどうして小柳に目串を差したかと云うんですか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水無瀬女よ、めぐし姪姫よ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "石臼は其儘幾つかごろ／＼とめぐして此れで蕎麥挽はやめた。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことを考へ出しながら梨はめぐし／＼はがすうちに鋲の頭は落ちては落ちて甲板に積つた。",
              "citation": {
                "source": "佐渡が島",
                "author": "波の上",
                "note": "青空文庫"
              }
            },
            {
              "text": "花のをとめ　　　ハインリッヒ・ハイネ妙に清らの、あゝ、わが児よ、つくづくみれば、そゞろ、あはれ、かしらや撫でゝ、花の身のいつまでも、かくは清らなれと、いつまでも、かくは妙にあれと、いのらまし、花のわがめぐしご。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへそれ、「真」は「恋」の真心を夙に知る可く、「望」こそそを預言し、「誉」こそそがためによく、「若き世」めぐし、「命」惜しとも。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハインリッヒ・ハイネ花のをとめ妙に清らの、あゝ、わが兒よ、つくづくみれば、そゞろ、あはれ、かしらや撫でゝ、花の身のいつまでも、かくは清らなれと、いつまでも、かくは妙にあれと、いのらまし、花のわがめぐしご。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへそれ、「眞」は「戀」の眞心を夙に知る可く、「望」こそ、そを預言し、「譽」こそそがためによく、「若き世」めぐし、「命」惜しとも。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "忍許呂別、押別命、押勝、忍の海といふ風の語法は、いかし穂、うつし身、めぐし子、こひしの人、などゝ、おなじであるが、此語の活用の鈍い事は、自分とても認めて居るが、さりとて、これを、わか・しと対して居る語でないと、一概に却ける、といふわけにはゆかない。",
              "citation": {
                "source": "わかしとおゆと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "忌々しき「死」の大君は貴なる人も憚らず、さすがに徳を避けたれど、なべての人が、たをやめの譽とふもの、めぐしくも、毀ちたるこそ無殘なれ。",
              "citation": {
                "source": "泣けよ戀人",
                "author": "ダンテ・アリギエリ　Dante Alighieri",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋夕暮『秋』はしばしがひま、やさしき眼をあげ、微笑さへ浮べ、やすらふとき、鴿あり、めぐし、かたへの水盤より玉水をりをり羽うつ、いとかすかに。",
              "citation": {
                "source": "春鳥集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "死なざるもののめぐし子に幸いあれ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "子をなさぬ二人がなかのめぐし子と守りてぞ行かな敷島の道　これは子どものないある歌人の詠だ。",
              "citation": {
                "source": "愛の問題（夫婦愛）",
                "author": "――生命の法に随う――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなし妹　　めぐし子くはし女　　うまし国かたし磐　　まぐはし児ろとほ／″＼し高志の国うらぐはし山（？",
              "citation": {
                "source": "形容詞の論",
                "author": "――語尾「し」の発生――",
                "note": "青空文庫"
              }
            },
            {
              "text": "長歌の方は、「父母を見れば尊し、妻子見ればめぐし愛し、世の中はかくぞ道理」、「地ならば大王います、この照らす日月の下は、天雲の向伏す極、谷蟆のさ渡る極、聞し食す国のまほらぞ」というのが、その主な内容で、現実社会のおろそかにしてはならぬことを云ったものである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うつくし」は愛することで、「妻子みればめぐしうつくし」（巻五・八〇〇）の例がある。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "へんぶり＜へいぬぶり＜はひのぼり（這上り＝上框）くまじん＜くまぜむ＜くまぢぇもん（熊治右衛門）まつらげる＜まつりあげる（献上）しまりぶし＜しまいぶし＜しめぃぶし＜しめぐし（標串）　　　　　七私は、壱岐の文明に、三つの時を違へて渡来したものゝ、大きな影響を見てゐる。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "8415　　　　ドオリス族めぐしき童等。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "きよき處女にめぐしみどりご今日｜生れましぬ。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
