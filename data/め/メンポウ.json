[
  {
    "uuid": "5ca428cd-c017-5081-8650-109208efcb4f",
    "entry": "麺麭",
    "reading": {
      "primary": "めんぽう",
      "alternatives": [
        "メンパオ"
      ],
      "is_heteronym": true
    },
    "grammar": {
