[
  {
    "uuid": "dcd60074-b1f8-55b5-b7c9-c1bc12d0de1f",
    "entry": "明色",
    "reading": {
      "primary": "めいしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
