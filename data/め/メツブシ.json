[
  {
    "uuid": "1e502e72-fe91-5b03-a200-7ecc8a509f58",
    "entry": "目潰し",
    "reading": {
      "primary": "めつぶし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sand, ash, etc., thrown in the eyes to blind someone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その癖、熱海一という別嬪でござりますが、から野鳥でござりまして、よく御存じでいらっしゃらないで、悪く御串戯をなさるお客様は、目潰しの羽ばたきをされてお怒りなさります。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いものが、ばっと来て、目潰しを打ちますように、翼を拡げたと思いますと、その指環を、奥様の手から攫いまして、烏が飛びましたのでございます。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "でまあ、その何だ、私も素人じゃねえもんだから、」　と目潰しの灰の気さ。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いものが、ばつと来て、目潰しを打ちますやうに、翼を拡げたと思ひますと、其の指環を、奥様の手から攫ひまして、烏が飛びましたのでございます。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀麿が心からでなく、人に目潰しに何か投げ附けるように笑声をあびせ掛ける習癖を、自分も意識せずに、いつの間にか養成しているのを、奥さんは本能的に知っているのである。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は惨澹たる目潰しを喰つて、窒息しかゝるのだ。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と私は歯ぎしりして、辛うじてＺの顎の下から逼ひ出して蒸汽の目潰しから逃れたかとおもふと、やがて奴の鼻息は三尺も五尺も伸びて私の首筋に襲ひかゝつた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」馬の目潰し９・21（夕）　馬政局長官浅川中将の談によると、陸軍当局では、先年の失敗に懲りずに、今度また馬券を売出さうと計画中だといふ事だ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちえつ、悪魔めが、なんちふ雪塊を吹きつけて、目潰しを喰らはしやあがるこつた！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「霧隠れ雲隠れ、と申しても、つまりは火遁の術、煙遁の術、薬品にて煙を急造し、目潰しを大袈裟にするまでじゃ。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「砂が目に入ったので御座ろう」「いや、虫の群をなしたのが、あの風に巻込まれて、運悪くも眼の中に」「それならば未だ宜しいが、曲者有って、一時に目潰しでも投げたのでは御座るまいか、ヒリヒリ致してどうも成り申さぬ」　大名行列の大勢ことごとくが、一時｜盲目になって立往生をしたのであった。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧隠れ雲隠れの秘薬、かつてこれは洞斎から真田幸村にも教えて、風を利用して薬粉を散らし、敵の大軍へ一時に目潰しを食わせるという計画をも立てたのだが、大阪夏之陣の風の吹き方が、巧く注文に適らなかったのであった。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "長四郎があべこべに眼を潰されて了いました」「向うから目潰しを投げたのか」「いいえ、指を眼の中へ突込みやあがったので」「酷い事をするな」「とうとう私一人になってしまいました。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年出るやうな事があると、予め之をはぐらかして、呪術の目潰しを喰はせようとする。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……イスパニア人がカランス殿を通して、珍しいというところから、田沼の殿様へ献上した、西班牙の捕り物の一つだそうで」「卵の殻へ灰を入れて、目潰しとして投げるという、日本にもある捕り物の……」「さようさよう、それと同じじゃ。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあ、どうやら誰かが誰かを、斬ろうとしたようでございますな」　不意の目潰し、濛々とした白粉、それに姿を眩まされ、互いに互いを見失い、一斉に四方へ散じたと見え、濛気が消えて晴れた後には、一人の姿も見えなかった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宙に上がる棍棒、空にうねる捕り縄、紅色の火事の遠照りを縫って、霰のように飛ぶ無数の目潰し！",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これぞ早速の目潰しである。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ付け込んだ悪獣の群はヒラリヒラリと空に飛び翔け、武兵衛の頭上を向こうへ越えそのつど目潰しを打ち付ける。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすが悪獣の狼の群も彼に向かっては泥の目潰しを、投げ付けることは出来なかった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま見付かつたり、退路を斷たれたりすると何處に忍ばせたか、目潰しの一丸を叩きつけるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鼬小僧の正体",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御用ッ」　正面から飛付いた一人は、半分食いかけの、昼飯の茶碗を目潰しに叩き付けられてのけ反りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "竹光の殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次の顔へ、目潰しに叩きつけて、その場から逃出そうとした者があったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "黒い巾着",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰の目潰しの中に、ひるむガラッ八。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "「抜きやがったな、しゃら臭え」　松五郎が石を拾って目潰しをくれる、それを合図に、身内の若いのが、同じように目つぶしの雨を降らせる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、別所一族が七千余人を以て守る三木城の本拠そのものは、いわゆる天嶮を占めているし、一族郎党の血にむすばれている強兵だし、加うるに、海路毛利方から新鋭の武器兵糧も充分に籠め入れてあっただけに、到底、短期間にこれを攻めつぶし得る見込みはなかった。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「信長公が自身攻めつぶして行かれた後は、草木も枯れてしまう酷しさだが、筑前守が攻め陥したあとには、何となく寒土から木や草の芽が萌え出るようなものが残る。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……折あらば、官軍を手引きして、梁山泊を攻めつぶし、それを手柄に官へ媚びんとしているもの。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、油断ならぬことには――総領の曾塗、二男の曾密、三男の曾索、四男の曾魁、五男の曾昇――これらがみな、なかなかの者でして、将来の栄達を誓い合い、いつかは梁山泊を攻めつぶし、その功をもって、朝廷のご嘉賞を得んものとしていることです。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場｜美濃守信房の息、昌房のたてこもっていた要害｜深志城も、またたくまに陥ちてしまい、これへ迫っていた織田｜長益、丹羽｜氏次、木曾義昌などの合流軍も、燎原の火のように、次々と甲州の外廓を攻めつぶして進んだ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
