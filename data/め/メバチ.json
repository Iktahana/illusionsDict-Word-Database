[
  {
    "uuid": "611f4498-4505-5488-b50f-5f7c9112668a",
    "entry": "目撥",
    "reading": {
      "primary": "メバチ",
      "alternatives": [
        "めばち"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bigeye tuna (Thunnus obesus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "スズメバチの巣に頭を突っ込むとなれば躊躇しますよ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "アプリアでは咬まれたスズメバチや雄鶏は踊るので不思議なことであった。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "オヴィディウスはウェルギリウスと同じような考えをもっていて、ただスズメバチはウマの死体から、カブトムシはロバの死体から生じると考えていた。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたがその女と過ごす楽しいはずの家庭は何とスズメバチの巣のような鬱陶しい所なんだ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "スズメバチの巣に、頭を強引に突っ込むようなものだ。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
