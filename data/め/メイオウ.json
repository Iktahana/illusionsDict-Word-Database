    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Meiō era (1492.7.19-1501.2.29)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "明応年中、近衛尚通の子政信、家を継ぐ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "応仁、文明、長享、延徳を歴て、今は明応の二年十二月の初である。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "永享五年一月には、伊勢、近江、山城に、同年九月には相模、陸奥、甲斐に、宝徳元年四月には山城、大和に、文正元年四月には山城、大和に、明応三年五月にはやはり大和、山城に大地震があったが、明応三年五月の地震は大和が最も強く、奈良の東大寺、興福寺、薬師寺、法花寺、西大寺の諸寺に被害があった。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その明応には九年六月にも甲斐の大地震があった。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若宮の祭神若宮様は、元は畏い神でおありになつたのかどうかと言ふことだが、これについては、明応七年十二月三日、昨夕自九条殿御書到来。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "連歌の最盛時代とも称すべき文明、明応は僅に昨日と過ぎて、余勢なほいまだ衰へざる永正、天文の間にありて、早く既に一転機の動かんとするを見る。",
              "citation": {
                "source": "古池の句の弁",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに同書明応三年六月十二日条に、於鳩垣内、唱聞与専当有舜喧嘩事出来。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　明応年間に木曽義元、小笠原氏と戦って、戦い勝利を得たるをもって、華表を建てて鳥居峠と呼ぶ。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明応九年に記したという高倉神社の勧進帳の文は、文化六年の序ある『新編会津風土記』に載っている。",
              "citation": {
                "source": "尾瀬の昔と今",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて明応四年（一四九五）には小田原城を、永正十五年（一五一八）には相模一国を征服した。",
              "citation": {
                "source": "埋もれた日本",
                "author": "――キリシタン渡来文化前後における日本の思想的情況――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『実隆公記』の明応七年五月十八日の条に、中山家の雑色が黄昏ごろ武者小路において、何者のためにか疵を蒙ったことを記して、その割註に「この亭垣を築く前」としてあるところを見ると、この時分の三条西家は武者小路に在ったらしい。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは三条西家の東隣には正親町三条家がおったらしく、実隆のみならず家族までもそれと往来しているが、その東隣の宅地の巽の角に、諏訪信濃守の被官人某が、明応七年に地借りをして、小屋を造ったということがある。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実隆の家は明応九年六月下旬の火災に類焼したのであるから、おそらくはこれが移転の原因となったものであろうと思われる。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母屋の西の方には、独立の小家屋があったが、これは三条西家で久しく召使った老官女の扣家であって、明応九年の類焼の前年に取り毀ちになった。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の後を承けて三条西家に奉仕しておったが、父の功をかさに著てか、我儘の振舞多く、過言などもしばしばあったと見え、明応五年には実隆も堪忍しかねたらしく、一旦は召仕わぬと申し渡した。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれまでの好みを考えると、そうもできなかったらしく、明応八年四月、元盛の十三回忌に、盛豊が形のごとく僧斎を儲けた時に、実隆は家計不如意のため、志があっても力が及ばぬ、十分な補助ができぬのは遺憾だと歎いている。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日記明応五年四月の条に、東隣すなわち正親町三条家から三栖庄内で鷹にとらしたという青鷺をもらった記事がある。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代官に関しては、明応ごろに中村宮千世丸という名前が同五年三月の日記に見えておる。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "淀の魚市の年貢、これもまた収入の一であったが、これに関してもまた西園寺家との間に紛争のあったことは、明応五年の日記にしばしば見える。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この魚市からの収入は別に雑掌あるいは代官をしてこれを取り立てさせておったが、その代官の名には、明応四年ごろ玉泉という者をもってこれに任じたことがあり、永正元年には和泉屋すなわち四条烏丸太志万平次郎といえる者補任されて請文を出したとある。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお丹波にはこの今林庄のほかに桐野河内という所から莚の年貢があり、土著の代官として、明応四年に片山五郎左衛門、同六年に月山加賀守という者が見えている。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明応五年に広岡入道道円という者をその代官職に補したところが、その年には恒例の千疋のほかに、補任料をも添えて大昌院経由で送って来たので、実隆はいよいよ喜んだ。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが明応元年になって宗祇の取次で千疋を送ってよこしたので、実隆はこれ「天の与えしところというべきものなり」とて大いに悦んだ。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに明応五年美濃の喜田城陥落し、土岐九郎は切腹、左京太夫は没落したので、この国衙料もまた不知行となること三十年ばかり、大永四年に至り持明院の周旋によりて、また納入さるることになった。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土岐の明応五年の没落を報じて来たのもまたこの男である。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "年貢としては明応五年に飯米三俵の収入があったほかに何もわからぬ。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明応五年正月からして阪本に苧課役を月俸にして沙汰をすることにしたと日記に見えているが、それ以前は年二回の徴収であったかも知れぬ。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明応七年五月の春成公用は二千疋とあるが、五年十二月の条には千二百疋とある。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度目に出ている奈良旅行の記事は、実隆の長子で東大寺公兼僧正の弟子となり、西室公瑜と称した人が、京都から奈良に戻る時に同道した際のことで、明応五年閏二月中旬、花の早きは散り遅きは未だ開かぬころであった。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
