    "definitions": [
      {
        "index": 1,
        "gloss": "ending a sentence with a noun",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
