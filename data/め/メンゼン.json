  {
    "uuid": "c09be325-6d1d-511e-964b-71f5bb3cd785",
    "entry": "門前",
    "reading": {
      "primary": "メンゼン",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one's hand being completely concealed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "園に達すれば門前に集う車数知れず。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとて傘持たぬ一同、たとえ張子ならずとも風邪など引いては面白からねば大急ぎにて雷門前まで駈け付く。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前田邸の門前近くで向うから来る一人の青年が妙に自分の注意を引いた。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規の葬式の日、田端の寺の門前に立って会葬者を見送っていた人々の中に、ひどく憔悴したような虚子の顔を見出したことも、思い出すことの一つである。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしただ一度ある小春日のわが家の門前で起った些細な出来事だけがはっきり印象に残っている。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分七、八歳くらいの自分と五、六歳くらいの丑尾さんとが門前のたたきの斜面で日向ぼっこをしていた。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "楼上と門前とに女が立ってうなずいている。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿坊の造りは一定していないが、往還から少し引ッ込んだ門構えに注連を張り、あるいは幔幕をめぐらせ、奥まった玄関に式台作りで、どうかすると、門前に古い年号を刻み入れた頂上三十三度石などが立っている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "小流れを門前に控えたどこかの家の周りには、ひまわりの花が黄色い焔を吐いている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつと宿の物音があらかた靜まつた後は、門前のカフエーから蓄音機の奏する流行小唄の甘酸つぱい旋律が流れ出して居た。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後には森を背負ひ、門前の小川には小橋がかゝつて居る、何となしに閑寂な趣のある好い土地だと思ふ。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "良久しうありて奧さま大方醉も覺めぬれば、萬におのが亂るゝ怪しき心を我れと叱りて、歸れば盃盤狼藉の有さま、人々が迎ひの車門前に綺羅星とならびて、何某樣お立ちの聲にぎはしく、散會の後は時雨に成りぬ。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはと思い午後の四時じぶんに先生の門前迄往ったが。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "門前に躊躇しながら内をのぞいてみると。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とはなしに陸さんの門前の方へ廻り何とか云う人の門につきあたり左の方を注視したけれども先生の庭の方へ出でる道はない　仕方はないから又もとへ戻って先生の前へ来た。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたたび内をのぞいた　下駄もさきに見た通りでかわらない　愈ほんとうの決心がでて門前を東へ過ぎて吾躰を運転した。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "躊躇する暇もない、忽門前近く来てしまった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢のように二里の路を走って、太陽がようやく地平線に現われた時分に戸村の家の門前まで来た。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "キングは名代を遣わして参列させ、その他ケンブリッジ大学や王立協会の主要な人々も会葬し、荘園の労働者は寺の門前に整列した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「三次さんッ」Ｓ＝棚倉宅の門前　三次疾風の如く飛び込んだ。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）大きな門前　羽織袴の徳兵衛刀箱を持って門内へ入る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）雲霧の門前　先刻からさんぴん山左と二ツ目左膳が、ブラブラしている。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "主膳、近侍を呼び止めて、Ｔ「門前にふんぞり七兵衛と申す御用聞がうろうろ致して居る」　と言ってなりひらの方をジロリと睨んで、Ｔ「その七兵衛に斯う申せ」　と言って、Ｔ「お尋ね者のなりひら小僧が拙宅に忍び込んだ」　えッ、となりひら油断なく大刀を掴む。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝門前　左膳と山左が七兵衛の手と足を持って一、二、三で側の小川へボチャンと投げ込んだ。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝門前　文箱持って走り出た侍。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝牢屋敷門前　一同が到着した。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "門前で待っていた君江達大喜び。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝別な道場の表　今度は一刀流の先生、浮田源兵衛の門前だ。",
