        "examples": {
          "standard": [
            {
              "text": "将軍は側近を近くに「召し寄せ」、耳元で密かに指令を伝えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "魔法使いが杖を振ると、遠くにいた黒猫が足元へと「召し寄せられた」。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "母親が子供を「召し寄せ」、泥だらけになった服を優しく拭いてやった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "では城中へ召し寄せるがよい」　彼は好色の男であった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "難波経遠、瀬尾兼康を召し寄せると、「きゃつを庭へ引ずり下せ」　と言いつけた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "平等院に入った三位入道頼政は、渡辺｜長七唱を召し寄せると、「わが首を打て」　と静かな声で命じた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
