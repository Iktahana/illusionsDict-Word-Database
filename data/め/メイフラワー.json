        "examples": {
          "standard": [
            {
              "text": "メイフラワー号に乗って新世界を目指した人々の勇気を称える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "春になると、森の地面にメイフラワーの可憐な花が咲き始める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女のドレスはメイフラワーの刺繍で飾られ、とても美しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この商品化された巨大な流れの中に、ローマ法王からのがれて、新大陸にメイフラワー号で上陸した人々から生まれでたアメリカが一九五〇年代にいたって、世紀の新しい担い手となってくるということを、幾人の人が予見しえたであろう。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もそのむかし、われわれの先祖ピルグリム・ファーザース〔一六二〇年メイフラワー号で米国にわたった清教徒の一団〕がそれだけで荒涼たる岩のうえで寒いひと冬をすごしたからといって、いつまでも一人の訓導と一人の牧師、一人の寺男、一つの教区図書館、三人の委員でいつまでもとどまっていないでもよかろうではないか。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "メイフラワー号で移住したピルグリムファーザーズの一員でした」「統計によれば現在、25万人もの米国家族がピルグリムファーザーズの直系と称しています。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
