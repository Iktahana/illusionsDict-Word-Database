    "definitions": [
      {
        "index": 1,
        "gloss": "dazzlingly beautiful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
