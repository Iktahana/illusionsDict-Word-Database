    },
    "definitions": [
      {
        "index": 1,
        "gloss": "master",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なにせ相手は槍の名人の子孫である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍の名人の子孫に対して私は極度に用心し、かじかんでしまったのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何せ、お嫁さんのおじいさんは、槍の名人だそうですからね、大隅君だって油断は出来ません。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそのヒイキにした蕪村でさえも、単なる写生主義の名人としか解さなかった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々｜宅の庭の手入れなどに雇っていた要太という若者があって、それが「鴫突き」の名人だというので、ある日それを頼んで連れて行ってもらった。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれも昔は、舟の漕ぎ方にかけては名人とか、または達者とか言はれたものだが、けふはまあ寢轉んで拜見といふ事にしようかな。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして西鶴は、さまざまな貯蓄の名人の逸事を報告してゐるのである。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "騒がれることなしに名人になりたい人はこれらの端役の名優となるべきであろう。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生君は今隨筆を盛んに書き、その方でも小説家以上の名人といふ定評を取つてゐるし、僕等が讀んでも非常に面白い文章であるけれども、その隨筆の精神は全く東洋風のものであつて、芭蕉等の俳句とも共通した情趣をもつものである。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "逆に君が小説家として成功し、今の文壇で名人呼ばはりをされる時は、逆に君の中の自然性や純眞性やが、次第に消滅されてゐる時であるのを感知したから。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "太田ミサコは売あびせのために底値を入れた××新株の反撥を予想して買いあつめると、雑株安をねらって、引たたぬ××百貨店株を後場引値で、これを指名人に買わすとさっさと場内を引あげた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夏もお互に旅先や何かで久しく顏を合せなかつた二人、さて新秋になると、向うは熱海で勉強して大に強くなつたと自｜信を持ち、僕は僕で名人｜决定｜戰の觀戰記を書き棋力に相當加ふるものありとうぬ惚れて、共に張り切つてゐるのだからたまらない。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝２＝痛まし專門棋士　名人｜决定｜戰の金、花田｜兩八｜段の對局、相踵いで大崎、木見｜兩八｜段の對局を觀戰して、僕は專門｜的な棋戰の如何に苦しく辛きものであるかをつくづく思ひやつた。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝３＝老齡と棋力　今は隱退してゐる小菅｜劍之｜助老八｜段が關根金次郎名人に向つて、年をとると落手があり勝ちになる。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "假りにも名人上手とうたはれた者は年をとつてつまらぬ棋譜を殘すべきでない――と自重を切｜望したといふ。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は今も壯者に伍していさぎよく戰ふ關根名人の磊落性を寧ろ愛敬し、一方自｜負しつつ出でざる坂田三吉八｜段に或る憐憫さへ感じてゐる者だが、將棋だけは若い者には勝てないものらしい。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、畢竟それもまた名人上手とかいふ風な古來の形｜式主｜義が當｜然作り出す型に捉はれた觀念と見られぬ事もない。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "從つて、今度の實力主｜義の名人｜制度は、たとへ幾分えげつない感じはあつても、たしかに棋界の進歩といふべきであらう。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく舊式の名人｜制打｜破は甚だいい。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが江戸じゅうの噂になったので、狂言作者の名人南北がそれを清玄桜姫のことに仕組んで、吉田家の息女桜姫が千住の女郎になるという筋で大変当てたそうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなのが大きくなって、掏摸の名人なんかになるものだ。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は先生が、大学でも有名な御本集めの名人でおいでになる事を、法文科の中江先生からズット以前に伺っておりました。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度、○○科へ本集めの名人が来たぜ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一流の名人が演じても、容易に共鳴出来ないので、坐り直して、深呼吸をして、臍下丹田に力を籠めて正視しても何処がいいのかわからない場合が多い。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかあの女房が据物斬りの名人では通りますまい」「な……な……なるほど……」「ハハハ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さようで……蔵元屋のお熊は天下御法度の袁彦道の名人で御座いました。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンと申すと……」「たとえば名人のお医者が、小便の色を見て病人の寿命を言い当てるようなもので、私どもは掃溜の色をタッタ一目見ますると、その家の奥の奥の暮し向きまで包み隠しのないところが、ハッキリとわかりまする」「うむ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "謎々の名人が出て来た。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "老船頭が櫓柄につかまって沖合の一点を白眼みつつ、悠々と大浪を乗り切る、その押す手引く手や腰構えの姿態美は、ソックリそのまま名人の仕カタ開キであるまいか。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それですから自然と若い者の中でも私が一番巧いということになり、老先生までがほんとに稽古すれば日本一の名人になるなどとそそのかしたものです。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
