          "literary": [
            {
              "text": "さあれ日は過ぎ月は逝き、なれ等血もなく涙なく、よくぞ鬩めげる数千年、さても殺生はての死の、よくぞ好きなる、おゝ永遠の闘争よ、おゝ恩怨の同胞よ！",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "危険にめげるものではない。",
              "citation": {
                "source": "寡婦とその子",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の光は水の底の世界のように澄み渡って、寒さは更くる夜と加わりますが、老異人も、美しい婦人も、少しもめげる色はありません。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第一夜　初夜を盗む",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも彼らはめげることなく、湯けむりの彫刻を実現させようと奮闘していると聞いた。",
              "citation": {
                "source": "湯けむり",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの専門は学問の方だから、けっして失敗なんかにめげるようなことはありゃしません！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
