    },
    "definitions": [
      {
        "index": 1,
        "gloss": "clear writing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さうする位ならば「旅行案内」などの廣告にちやんと其旨を明記しておく方が親切であらう。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今頃『徒然草』でもあるまい」と云うが、そういう諸君の現在していることの予報がその『徒然草』にちゃんと明記してあるのである。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは今でも明記して居る人が有らうが、「たんたん、たん／＼、田の中で……」といふ謡で、「おッかあも……田螺も呆れて蓋をする」といふのであつた。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の名は、いまになっては、少し有名になってしまって、ここには、わざと明記しない。",
              "citation": {
                "source": "あさましきもの",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十一年のこと、九段竹橋の近衛歩兵第一連隊第四中隊（特に明記して置く）に一年志願兵としているうちに、或る晩の事、私の私物筥に風呂敷に包んだ餅が隠してあるのが発見された。",
              "citation": {
                "source": "ざんげの塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまで劇場の開演時間に一定の制限なく、単に多年の習慣に因って、「早朝より相始め」というに過ぎざりしに、中村座が初めて開場と閉場の時間を番附に明記したり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、その母親として仕えていたのは、実は子供の時から可愛がられていた情婦に過ぎないのであったが、最近に至って有名な箱師のお玉という、これも変態的な素質を持った毒婦が、模範兵士の新聞記事を見て、大胆にも原籍本名を明記した封筒に、長々しい感激の手紙と、五拾円也の為替を入れて聯隊長宛に送って来た。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにその美しい音樂があるか、我等は之れを分析的に明記することができない。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩以外の文学は、小説でも、感想でも、論文でも、すべて「描写――もしくは説明記述――を本位とする表現」である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、巧な化粧で変貌したＸ夫人を先年某料亭で見て変貌以前を知って居る私が眼前のＸ夫人の美に見惚れ乍ら麻川氏と一緒に単純に讃嘆出来なかった事、その気持ちでその時の麻川氏を批判した随筆を或る雑誌に絶対に氏やＸ夫人の名前を明記しないで書いたのが、矢張り麻川氏は読んで感付き気持ちに含んで居たのだと判った。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に悪口を言われても、その人の敵意には気が附かず、みんな僕の為を思って、言いにくい悪口でも無理に言ってくれるのだ、ありがたい、この御厚情には、いつの日かお報いせずんばあるべからずと、心の中の手帳にその人の名を恩人として明記して置くという始末なのだ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し燕の兵を挙ぐるに当って、史｜之を明記せずと雖も、韃靼の兵を借りて以て功を成せること、蔚州を囲めるの時に徴して知る可し。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲生方では政宗が氏郷を茶讌に招いたのは、正に氏郷を数寄屋の中で討取ろう為であったと明記して居る。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらから戦をしかけたのだか明記はないが、源の扶、隆等が住地で起つたのでも無く、将門の田園所在地から起つたのでも無い。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "合祀濫用のもっともはなはだしき一例は紀州西牟婁郡近野村で、この村には史書に明記せる古帝皇奉幣の古社六つあり（近露王子、野中王子、比曽原王子、中川王子、湯川王子、小広王子）。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に上に引いたポールの書にも、ヒンズ人が狼に養われた児を礼拝して、一族狼害を免がると信じた旨明記しある。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "花開く時、聲ある由を明記した例は是ばかりだ。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "先人の著作物に、広く、容易に触れられることの保証なくして、憲法に明記されたこれらの権利と自由は、実効性のあるものとはなりえない。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "『労働者が退職して行く時に、積立金が賃銀と同時に支払われるのは、当然なんだ、それは工場法にも明記されてあることなんだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は何故か、その詩人の名前を明記するのが憚られてならぬのだ。",
              "citation": {
                "source": "凩日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰一は謬忌から稱道されたと史上に明記されてゐるが、謬忌が突然として秦一神を稱へても、恐らくは其前から何か存在してゐて其主張の依據を爲すものが有つたのでなくては一世に認めらるゝには至るまいから、今日其考證は明白を得難くても、謬忌以前に泰一若くは泰一の如きものは夙くから存してゐたらしい。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ等の地の気の湿潤・乾燥などということは、望気術の気のように目に触れるものではないが確かに人に対して作用するもので、その湿気が水辺に親しむ釣客をしてリューマチに悩み勝なことは外国の釣書にも明記され、乾気の強い土地が或る病者に快癒を与えることなどは実験者によって強調されているところである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ予のみならず、友人グリェルマ・リスター女の『粘菌図譜』、昨年新版を贈り来れるを見るに、Diderma Subdictyospermum の胞嚢は雪白と明記され、D. niveum も、種名通り雪白なるべきに、図版には両ながら淡青に彩しあり。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "白犬と明記されぬが、犬が人に生まれた譚は仏経に多い。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "是等は人屍を築き込むと城が堅固だと明記はし居らぬが、左樣信じたればこそ築き込んだので、其信念が堅かつたに由つて極めてよく籠城したのだ。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "余計なお手数をかけてすみませんが、十月号十一月号両誌の懸賞当選者は、何月号の何々に当選といふ事を、御住所姓名を明記して十一月二十日迄に記者宛に御通知を願ひます。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃はマダ右眼の失明がさしたる障碍を与えなかったらしいのは、例えば岩崎文庫所蔵の未刊｜藁本『禽鏡』の（本文は失明以前の筆写であっても）失明の翌年の天保五年秋と明記した自筆の識語を見ても解る。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　行ってみると、果然、訴状箱の中には、恒藤権右衛門とこそ明記はしてありませんでしたが、朝ほど子どもを連れた女が、夫の討たれた旨を訴えに来たことがちゃんとご記録帳にのせられてありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽織はかまに幅広の大小、青月代を小判型にぐっとそりあげたぐあいは、お奉行からのお差し紙にもそれと明記してあったとおり、紛れもなくどこかの藩の禄持ち藩士たることは、ひと目にして明らかです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ためいき　　河上徹太郎にためいきは夜の沼にゆき、瘴気の中で瞬きをするであらう。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
