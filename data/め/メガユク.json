          "literary": [
            {
              "text": "最近どうしてもＡＭＤに目が行くのは、そのためだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと目が行くと、慌てて目をそらし、そしらぬ顔をするといふテイタラクで、さういふ時、窓へ目をそらし、窓から見た京都の山々のクッキリと目にしみる切なさは、その山影をだいて死にたいやうであつた。",
              "citation": {
                "source": "再版に際して〔『吹雪物語』〕",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は見まいとしても、机の上の脅迫状へ目が行く。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、狭い部屋のことであり、見まいとしても、自然その方に目が行くのだ。",
              "citation": {
                "source": "Ｄ坂の殺人事件",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
