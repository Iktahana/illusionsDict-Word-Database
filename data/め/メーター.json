      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "meter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ポアンカレのいわゆるゲオメーター型の学者と思われた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また器械の廻転軸の捻れを直接光学的に読み取るトーションメーターの考案も最も巧妙なものとして帝国学士院から授賞されたものである。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "片方の仕切りにはテプラーポンプや附属のマノメーターなどを置いた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年九月三日『東京朝日新聞』）　　　　　　　　　二　　　　　　罪人を発見する器械　近頃サイコメーターすなわち測心器とでも名づくべき器械を作った人がある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "健康のバロメーターになる。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "字引きで見ると杖の字は昔は尺度の意味であったという話があるから、昔もやはりメーターの一種であったのである。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸皿形のボルタメーターで、皿の内面に沈着する銀がやはりこの「シャボテン式」の放射線状の縞を成すは周知のことで、この場合は、濃度差による対流渦の結果であることは疑いもないことであろう。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "望遠鏡の焦点面に平行に張られた五本の蜘蛛の糸を横ぎって進行する星の光像を目で追跡すると同時に耳でクロノメーターの刻音を数える。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日午前十一時とかに東京天文台から放送される時報を受け取ってクロノメーターの時差を験するためである。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそのタタキ加減がその日の低気圧のバロメーターになるので、これは老幼を問わず同様の感想であったらしい。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、柳吉が紋附をとりに帰って来ると、ガスのメーターがチンチンと高い音を立てていた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ／＼て末は海行野分哉　　　　　猿雖　七百三十ミリメーターの颱風中心は本邦を斜斷して大平洋へ拔けた。",
              "citation": {
                "source": "天文と俳句",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔いのバロメーターみたいなものだね」「恋は？",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "警句は天才の最も得意とする武器であって、オスカー・ワイルドもメーターランクも人気の半ばは警句の力である。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その背後には、たくさんの丸いメーターがベタベタ並んでいて、黒い目盛盤の上に白い指針がピクピク動いていた。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下道の音響タンクのメーターを、斯んなに一時に昇らせたならば、市長がやがて俺を音響会社の重役に抜摘するであらう。",
              "citation": {
                "source": "ラガド大学参観記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンク・メーターのガラスの破片が、飛散しながら裸体の肉塊へ突き刺さった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "印象はその人の眼の高さのバロメーターである。",
              "citation": {
                "source": "所謂批評の「科学性」についての考察",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜市××町二ノ八、横浜メーター計量株式会社、としるしてある名刺を見詰めて私は、額に生汗をにじませ口をもぐ／＼させてしどろもどろの受け答をしたが、何んとかして早く此場が逃げたくなつた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーマには完成品を買えば当時数十万円はしていた、電圧、電流、抵抗を測ることのできるデジタル式のマルチメーターを選んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するにマイクロコンピューターは、これまでデジタルマルチメーターや電卓を作る際に使ってきたデジタルＩＣの親玉である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "野蛮人は磁石なしに方角を知り、バロメーターなしに悪天候を前知する。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に登第者の多寡は、其地方の文運を卜すべき一つのバロメーターともいへる。",
              "citation": {
                "source": "歴史上より觀たる南支那の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒鼠色で、かすんだような大きなかまの前に、背を丸くして黒赤い着物、オリーブの袴をつけた彼の姿は、日本のこう云う芝居よりも、ビョルンソンか、メーターリンクの舞台に出て来そうな色の調和があった。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい車輪をつけて、合成軽金の支柱を建てると、荷物をつんで、走っても行くし、場所を指定して、距離メーターをかけておくと、一定の角へ行くと、曲りもするらしい。",
              "citation": {
                "source": "ロボットとベッドの重量",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はいま五十五、六歳、まだ老人という歳でもないが、頭とひげは雪のように白くそれと共に左の眉に二寸ばかり長い毛が一本つきでている、おこるときにはこの長い毛が上に動き、わらうときには下にたれる、町の人はこの毛をもって先生の機嫌のバロメーターにしている。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢中になることが出来れば、アンペアメーターの針の微動のやうな呼吸が、金属からも電流からも感じられるのである。",
              "citation": {
                "source": "道化芝居",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちえつ、だらしがねえ、三メーターぢやないか。",
              "citation": {
                "source": "柊の垣のうちから",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして餞別の金高はその碼頭の匪徒の格式を計るバロメーターとなるのであるから各匪は挙って出来るだけ沢山進物をする。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
