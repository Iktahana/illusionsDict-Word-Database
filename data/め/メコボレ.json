        "examples": {
          "standard": [
            {
              "text": "多くの受験者の中で、彼の答案の小さな間違いは目溢れされてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "厳しい検査基準だが、たまには目溢れで合格品として出荷されることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "警備員の目溢れにより、不審者が敷地内に侵入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "歌うぞ、後を』こぼれて袖に露のよすがの憂きつとめこぼれて袖に――つらきよすがの浮身か憂身か『よう！",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――露のよすがのうきつとめこぼれて袖に辛きよすがの憂きつとめ　こう又、手拍子で口誦さむと――『若い生命さえ、そのとおりみじかい人の世、又之丞も、唯七も、幸右衛門も、すこしは、知らぬ世界を見ておいたがよかろうぞ。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
