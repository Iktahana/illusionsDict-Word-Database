[
  {
    "uuid": "84a69a4a-e0c4-52a6-8585-df325ba57ce2",
    "entry": "明哲",
    "reading": {
      "primary": "めいてつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
