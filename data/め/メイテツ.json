    "definitions": [
      {
        "index": 1,
        "gloss": "Nagoya Railroad Co. (abbr)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "名鉄の電車を乗り捨てて、差しかかった白い白い大鉄橋――犬山橋――の鮮かな近代風景の裏のことである。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "白帝城に登ったのは、その上の麓の彩雲閣（名鉄経営）の楼上で、隆太郎のいわゆる「香いのする魚」を冷たいビールの乾杯で、初めて爽快に風味して、ややしばらく飽満した、その後のことであった。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に棹さすのが一人、後に櫓をこぐのが一人、客は私と案内役の名鉄のＭ君である。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "土田は名鉄の犬山口から分岐する今渡線の終点に近い。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "名鉄の電車を乗り捨てて、差しかかつた白い白い大鉄橋――犬山橋――の鮮かな近代風景の裡のことである。",
              "citation": {
                "source": "白帝城",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "白帝城に登つたのは、その上の麓の彩雲閣（名鉄経営）の楼上が、隆太郎の所謂「香ひのする魚」を冷いビールの乾杯で、初めて爽快に風味して、ややしばらく飽満した、その後のことであつた。",
              "citation": {
                "source": "白帝城",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に棹さすのが一人、後に櫓を榜ぐのが一人、客は私と案内役の名鉄のＭ君である。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途端｜篆刻家の桑名鉄城氏ががつしりした肩を揺がしながら入つて来た。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時すぎ、タクシー、すぐ近くの名鉄ホールへ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "名鉄ホールも立派なり。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "屍を埋めて日が暮れ、とぼとぼ小屋に戻って行く道は暗く、しぜん気持も滅入ったが、まず今日いちにちは命を拾ったという想いに夜が明けると、もう仇討に出る気持めいてつよく黙々と、鶴嘴を肩にした。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "屍を埋めて日が暮れ、とぼとぼ小屋に戻って行く道は暗く、しぜん気持も滅入ったが、まず今日いちにちは命を拾ったという想いに夜が明けると、もう仇討に出る気持めいてつよく黙黙と、鶴嘴を肩にした。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
