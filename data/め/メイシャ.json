[
  {
    "uuid": "4214c5ac-88ac-56d8-8f33-bc7c8765dd55",
    "entry": "目医者",
    "reading": {
      "primary": "めいしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "eye doctor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "最近目が疲れやすいので、明日の午後に近所の目医者に行こうと思う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "目医者から処方された目薬を差すと、充血が少しずつ治まってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供の頃は、目医者で受ける視力検査がなんとなく苦手だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "埴生は江戸の目医者の子である。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど二、三か月前、正月休みにあちこちの目医者をまわって診てもらった。",
              "citation": {
                "source": "大根の葉",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「火星兵団」について、一生けんめいしゃべっていた蟻田博士の放送が、なぜその時、ぷつんと聞えなくなったのであろうか。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもまっさきにイワン・イワーヌィチが目をさまし、すぐに、おばさんかねこのところへ近づいて、首をのばし、あいかわらずちんぷんかんぷんなことを、熱心に、一生けんめいしゃべり始めた。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
