    "definitions": [
      {
        "index": 1,
        "gloss": "to sink (into)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "外では今年の初雪が降つて居るらしく、めり込むやうな静かさの中に夜が更けて行つた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈は遠し、手探りを、何の気もなく草鞋を解いて、びたりと揃えて、トンと船底へ突込むと、殊勝な事には、手拭の畳んで持ったをスイと解き、足の埃をはたはたと払って、臀で楫を取って、ぐるりと船の胴の間にのめり込む。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "高校時代から映画にのめり込むようになった萩野さんは、早稲田大学の第一法学部に入学すると稲門シナリオ研究会という伝統のあるサークルに入りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「『パソコン創世記』では、やりがいのある作業にのめり込めばのめり込むほど金銭との縁が薄れていくというどつぼにはまった。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ小生は常に悪酔の失策と後悔に身をやかれ、生活の軒を傾け、やがては自堕落の淵にめり込むやも知れません。",
              "citation": {
                "source": "僕の酒",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は古沼を覗く時のやうな――云ふならば弱少の身のうつゝが疑はれ、水底に映る空の雲の眼近く遠い不思議の奈落にのめり込む戦きに襲はれた。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "車輪のめり込むような霜どけ道を幾たびか曲りまわって、よう／＼に杉の生垣のある家を探しあてると、三浦老人は自身に玄関まで出て来た。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが、降り坂に勢ひを得て電車の終点までは一息に達したが、坂の途中から体力に逆つた単なる慣性で止むなく二本の脚が猛烈な威勢で空滑りしたやうなものであつたから、待合室にのめり込むがいなや、ベンチに倒れてフイゴのやうに激しい呼吸のまま目を瞑るより他はなかつた。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はその近くの土壌がめり込むらしく軽く水のはぜ返る音が聞え、再び大きな轟音が静けさを突きやぶって響いて来た。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "『パソコン創世記』では、やりがいのある作業にのめり込めばのめり込むほど金銭との縁が薄れていくというどつぼにはまった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターにのめり込むようになったウォズニアックとボームにとって、スタンフォード大学の線型加速器センターは情報の泉だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、反絵の片眼は瞑むられたまま砂の中にめり込むと、二人は長く重なったまま動かなかった。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い穴のなかへ体がめり込むやうだつた。",
              "citation": {
                "source": "幸福の彼方",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "附近の地図でいうと、下駄の歯入れやはそこから斜めうしろに拡っている何百戸かの苦しい世帯の最前列で、真向いに建ったコンクリートの塀の内側へのめり込むことだけはやっと数尺の距離でもちこたえているという風な活計であった。",
              "citation": {
                "source": "朝の風",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それでも暫く行き過ぎてから、やや小さな「黒焼屋」の前に通りかかつて、やつと決心して、のめり込むやうに店の中へ這入つて行つたのだつた。",
              "citation": {
                "source": "イボタの虫",
                "author": "中戸川吉二",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は全く困惑して部屋の片隅へ頭を抱えて縮こまつてしまつたら、ドカドカと一隊の酔ひどれ共が押寄せて来て僕を忽ち取り囲み、壁の中へめり込むくらひポカポカ僕を蹴つ飛ばしてしまつた。",
              "citation": {
                "source": "霓博士の廃頽",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "小杉未醒氏の随筆に、故梅坊主の深川を踊るとき、上る衣紋阪アレワイサノサと指したら、五十間のなぞへが見えてその料亭の畳、忽ちにメリ／＼とめり込むがごときものをおぼえたとあるが、春団治の場合も正にこれであつた。",
              "citation": {
                "source": "初代桂春団治研究",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "２．吾々はこれで一時間も兩脚が胴體にめり込む程立ちつゞけてゐる。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルックサックが肩にめり込む……それだけに山での休息が有難く、うれしく、生きていることをしみじみと感じる。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自転車の輪が半分めり込む始末です。",
              "citation": {
                "source": "ママ先生とその夫",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩がめり込むわ、めり込むわ」　丑松は周章てて押し戻す。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上流｜奥鐘山の絶壁の突端から、際どく身を交しながら忽然と走り出した黒部川は、茲に全容を曝露して、白泡を噛んで六、七町の間を躍り狂って来るが、一度足元の崖下にのめり込むと、ワーッと声を揚げた儘もう何処へ行ったか判らない。",
              "citation": {
                "source": "黒部川を遡る",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腦天を打たれて、首が胴へめり込むほどですから、大した傷が無くとも、目鼻口から鮮血が吹出して、四方の薄暗い中に、二た目とは見られない物凄さを漂はせて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "一枚の文錢",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに相違あるまい」「…………」　仁三郎は畳にめり込むように崩折れます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二服の薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　神田から上根岸まで行くうちに、春の淡雪は大方解けて、足駄のめり込むような凄まじい泥濘になりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれエ」　蘭塔場の中へ潜んでいたらしい別働隊の二三人、バッタのごとく飛出すと、「え、しぶとい女だ、今度は命がねえぞ」　二三人折重なって、そのまま大地へめり込むように、お雛も一緒に消えてなくなりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幽霊にされた女",
                "note": "青空文庫"
              }
            },
            {
              "text": "脳天を打たれて、首が胴へめり込むほどですから、大した傷が無くとも、目鼻口から鮮血が吹出して、四方の薄暗い中に、二た目とは見られない物凄さを漂わせております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "一枚の文銭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ痛え、畜生ッ、ほ、骨がめりこむようだ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、まだ、はしごの中ほどをおりかけていた大男が、切れた豆のつるをつかんだまま、大きなからだのおもみで、ずしんと、それこそ地びたが、めりこむような音を立てて、落ちてきました。",
              "citation": {
                "source": "ジャックと豆の木",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん、俺、たうとう令状來た」　蝶子はずうんと地のなかへめりこむやうな驚きかたで暫く口をあけたまゝ默つてゐた。",
              "citation": {
                "source": "うき草",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
