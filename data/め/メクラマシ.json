    "definitions": [
      {
        "index": 1,
        "gloss": "blinding someone's eyes (to make an escape)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "例えばへっぽこレストレードの発見だが、あれは単なる目くらましで、社会主義者か秘密結社をにおわせて、警察を誤った方へ向かわせたいだけだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリシタンバテレンの目くらましでもそううまくはいかぬぞ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「実験室」と称するものは貧弱で、見え透いた目くらましだった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "電灯を減光し前方の迷宮の中央部にいるペンギンを躱していく前に目くらましをくれてやれ、というわけだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "「目くらまししてやった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔法つかいの目くらましか、それとも、おれはさいぜんから、ずっと夢を見つづけていたのか。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにこの目くらましのいっさいの秘密があった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この目くらましの秘密について、少しおたずねしてもいいでしょうか。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたさまはひょっとしたら、目くらましの種を見破っていらっしゃるのではないかと心配しておりましたが……」「やっぱり、種があるのですね。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもパノラマ式の目くらましだったのですか」「いや、ほんとうに血を流しました。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん、この世界の経営者の巧みな目くらましにちがいない。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもきっとパノラマふうの目くらましだよ。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの幻術『目くらまし』に過ぎないのです。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それが犯人の考え出した巧みな目くらましだからです。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "友達として忘れるなとか、許しを請うとか、人生をやり直せたら、どんなに違ったろう、うんぬんです」「たぶんそれは単なる目くらましだ。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシアから追放されますが、これは目くらましで、いままでロシア警察が雇った中で最高に頭の切れるスパイなのです。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの下宿という看板は目くらましだな。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "数シリング入りの現金箱も盗まれたが、これは目くらましだ。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "密輸は単なる目くらましで、もっと重大事を隠しているのも知っている。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "シティの事務所は巧妙な目くらましであり、手下を使う手法には賞賛します。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
