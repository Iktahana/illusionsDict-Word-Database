[
  {
    "uuid": "fa45d111-ad7a-51a7-aeaf-99e5bcae97fb",
    "entry": "目を引く",
    "reading": {
      "primary": "めをひく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
