          "literary": [
            {
              "text": "そして三人でしばらく快活に四方山の話をしていたが、ふと思い出したように葉子を顧みて、「これからまた当分は目が回るほど忙しくなるで、その前にちょっと御相談があるんだが、下に来てくれませんか」　といった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「……目が回る見たいだ。",
              "citation": {
                "source": "Ｆ村での春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "クイーン　やめい、目が回る。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつだってまずもって目が回る。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とかなきり声のクイーン、「目が回る。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日は目が回るように忙しく、ある日には遊び半分という様では能率は上がりません。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互いにぐるぐる突進し、目が回るぐらい燕より早く空気を切り裂き、しかも音が全くしない。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            }
          ]
        }
