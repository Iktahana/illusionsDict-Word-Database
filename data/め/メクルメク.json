    "definitions": [
      {
        "index": 1,
        "gloss": "to dazzle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "生意氣に杖を持つて立つて居るのが、目くるめくばかりに思はれました。",
              "citation": {
                "source": "雪靈記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "合せ鏡のように、無限に内に畳まれて行く不気味な記憶の連続が、無限に――目くるめくばかり無限に続いているのではないか？",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生意気に杖を持って立っているのが、目くるめくばかりに思われました。",
              "citation": {
                "source": "雪霊記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "久寿玉のやうな包みは彼の胸に命中して、首尾好く両腕に抱へられたが、何処まで遡つても渡れさうな気色もなく、奔湍は岩に砕けて、目くるめくばかりの水煙りをあげてゐた。",
              "citation": {
                "source": "繰舟で往く家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……非常にたよりない、せつぱつまつた危急の感じが目くるめくやうな氣持のなかに來た。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふのは、羅馬では、市中は巴里以上に雜沓して居り、しかも季節がきびしい冬から突然目くるめくばかり百花の咲き亂れる夏に交代してしまふからである。",
              "citation": {
                "source": "或外國の公園で",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "四幕目、誘惑の魔の岩屋にて、目くるめく遊仙窟の舞台、妙なる楽の音につれて現れ出し時、君は、明き灯の下に、あまた居並び、横りたる妖女の頭に立ち給ひき。",
              "citation": {
                "source": "舞姫",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "その目くるめく光りは捲き返す波の上を渡り、搖らめく炬火のやうに、動搖するこの病院を照らし出した。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "石材の状態と散乱具合は目くるめく時間の循環と残酷なる宇宙の地殻変動とを沈黙のうちに物語っていた。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Corona Mundi ……世界の屋根……」この目くるめく驚くべき壮観を見下ろす我々の口をついてありとあらゆる現実離れしたフレーズが飛び出した。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び行く速度の印象は、ただ辛うじて、この固体に近い大泥流の面の、目くるめくばかりな、刹那刹那の変転から得られるだけだ。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その目くるめく印象はボーセアンの荘厳な邸の前にあっという間に打ち砕かれてしまった。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "野は野のかぎりめくるめく、　　　　青きかすみのなかにして、まひるをひとらうちをどる、　　　　袖をかざしてうちをどる。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とめくるめくばかり背を拍ちて宙につるしながら、走りて家に帰りつ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "内心の苦きおびえか、めくるめく痛き日の色眼つぶれど、はた、照りひびく。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "めくるめく変化と成長は巨大な幼児をますます肥らせ、彼の飢餓感をいっそう深めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "木暮山中腹の八段歩の草原までよぢのぼる難路のあひだ、青年はめくるめく想念の断続のために遂に一言も発することができませんでしたが、初夏の光燦然たる緑の草原へ現れでたとき、彼の胸に発止と突き当つた想念は矢張り強姦を遂行せずに山を降ることは決してできないといふ片意地な決意だつたのでした。",
              "citation": {
                "source": "淫者山へ乗りこむ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と見えるのは、目酔ふと解したものか、眩く（めくるめく）のまよふであらう。",
              "citation": {
                "source": "言語の用語例の推移",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "涯もなきこの靜けさや、めくるめくおそはれごこち、涯もなき夢のとろろぎ。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "こぼれた飯の惜しさにも価ひしない見棄てられた傷が、自分にかくも堪へがたい苦痛を与へてゐることが、奇妙な皮肉に思はれて、自虐的な滑稽感とめくるめく憤怒を覚えた。",
              "citation": {
                "source": "老嫗面",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「意地わる……」とささやく由子のいぢらしさに曠野の雪にも比すべきやうな情炎を見いだし、瞬時感動のめくるめくものを意識したと信じながら、心は然し悲しいまでに醒め果ててゐる水の思ひと対座してゐた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて鳩らそを我が額に被けるとみるや空は展かれ、めくるめく我が眼には、フ※ビュス親しく雲の上、黄金の雲の上、飛び翔けり舞ふが見られた。",
              "citation": {
                "source": "ランボオ詩集≪学校時代の詩≫",
                "author": "VERS DE COLLEGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "けがれた寺院の半分だけ見える柱は、空間の下の名状しがたい岩を足場として、光と闇の全域を超えた、めくるめく何もない空に向かってそそり立っています。",
              "citation": {
                "source": "ニャルラトホテプ",
                "author": "NYARLATHOTEP",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸と岸の間は、鳥も通わぬ断崖絶壁で、その下は、めくるめくばかりの深谷を、白水が泡を噛んでいる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな考えがめくるめくメイフィールドの心に去来した。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男の地位には、めくるめく恋がある。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄金の時間がめくるめく過ぎて、至福の刹那はまるで浮かれた蝶々が花々を飛び回るかのようで、しめて一時間が過ぎた。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は……私は……」お綱はついて歩く足もともうつろに、めくるめくばかりな熱情でこう思った。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
