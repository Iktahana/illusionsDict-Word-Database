          "literary": [
            {
              "text": "江戸じゅう残らずの者の目をかすめることができても、むっつり右門だけはできが違うぞッ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "美は、飛んでいく鳥が、目をかすめるほど、たまゆらを閃くものであるというのはそれである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "○月のすつかり冴えた草生に兵士の中に坐つて談し合つてゐると、しきりに先生のことが目をかすめるのです。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "百五十五　単に盗人兇状で、御用役向の目をかすめる手段、或いは足段ならば相当に覚えもあるが、じゃの道は蛇の相当な奴が意地になって、腕にかけ、面にかけて、捕り方に向って来ようというのでは、相手が悪いと七兵衛が考えました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前気がつかなかったかい」　焚き口の戸は開いたままになっていて、湯殿の窓に近づく為には、その戸の前を通る外に道はないのだから、そこにいた女中の目をかすめることは出来なかった筈だ。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "道誉は、直義に会うとすぐ言った、「ご苦戦もさぞと、心はせいていましたが、船手の準備に日がかかり、途中敵の舟陣の目をかすめるなども容易でなく、思わぬ日時を費やしました」と。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            }
          ]
        }
