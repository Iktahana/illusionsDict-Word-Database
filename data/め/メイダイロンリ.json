        "examples": {
          "standard": [
            {
              "text": "命題論理の基礎を理解することは、プログラミングの条件分岐を学ぶ上でも役立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はベン図を使って、命題論理における包含関係を分かりやすく説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "記号論理学の第一歩として、まずは命題論理の真理値表から勉強し始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "カリキュラムで命題論理学の基礎を取り扱う時期になって、桜井はこのテーマならエレクトロニクスに対する松本の興味と数学の授業への関心を結びつけてくれるのではないかと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターの論理回路は、命題論理学の演算をエレクトロニクスの素子によって実行させたものである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ならばコンピューターをきっかけとすれば、松本は学校の命題論理学の授業に興味を持つのではないか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
