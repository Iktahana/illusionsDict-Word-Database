[
  {
    "uuid": "a5a58966-05bb-58b7-9af3-df412d3c0af1",
    "entry": "目つき",
    "reading": {
      "primary": "めつき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
