    "definitions": [
      {
        "index": 1,
        "gloss": "blind snake (esp. the Brahminy blind snake, Ramphotyphlops braminus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
