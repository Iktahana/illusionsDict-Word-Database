        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「枝まで、折っちまっちゃア、駄目じゃないか！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「七人あるというから、私は八号目じゃないか。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ペンは錆るのが役目じゃない。",
              "citation": {
                "source": "ペンとインキ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（矢庭に食卓をひっくりかえす）久しぶりの平目じゃないか。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはこの番頭にはじめて興味ある関心を持ち出しまして、試に、「いくら耳だけ、福耳にしたって、眼尻に泣｜黒子があっちゃあ駄目じゃないの」　と突き崩してみます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっかりしなくちゃ駄目じゃないの」　隣町の婚家先から駈けつけて来た多可子は二階に昇るなり政枝の右肩を掴み、優しくゆすって叱った。",
              "citation": {
                "source": "勝ずば",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなところへ車を曳いてきちゃ駄目じゃないか？",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私からすれば、この都のややこしさは断トツで、今まで設計されたどんな迷宮も目じゃない。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「這入らなきゃ、駄目じゃないか。",
              "citation": {
                "source": "死者を嗤う",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度で三度目じゃないか、しかも、同じ町内で同じような事件が三度も起こっているのに、それで目星がつかんなんて。",
              "citation": {
                "source": "少年探偵　呉田博士と与一",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "シルヴィーにくらべれば、レズリー・ゴーアも、コニー・フランシスも、「ゼーンゼン目じゃない」のだそうだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの娘の実家が裕福だって言うのも、当てにならない気がするし、年齢が十九だって言うのも出鱈目じゃないかと思うの……」「驚いた。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に人殺しをしたように、がたがた慄えていなくちゃ駄目じゃないか。",
              "citation": {
                "source": "不思議なる空間断層",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けれど、俺は解剖のことをちっとも知らないんだから駄目じゃないか。",
              "citation": {
                "source": "稀有の犯罪",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたなんか、少しはあたしたちと共謀して、外国人からお金をとらなきあ駄目じゃないの。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「駄目じゃないの、あたしを叩き起して自分が眠るなんて、まだあたしはあなたの奥さんじゃないことよ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを思想だけ整理しても駄目じゃないか。",
              "citation": {
                "source": "私は懐疑派だ",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "菅はそれを受取って見て、「希臘道徳より基督教道徳に入るの変遷――好い題目じゃないか」　と捨吉にささやいた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きないんなら母さんに起きて貰わなくちゃ駄目じゃないの」　姉がうんともすんとも云わないのを見て、登美は隣室へ襖越しに叫んだ。",
              "citation": {
                "source": "縫子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、貴方の診断が出鱈目じゃないかと疑ったくらいです。",
              "citation": {
                "source": "誤診",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「半月ほどしたら行きたいと思うんだけど、でも、あなたは駄目じゃないの。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれたちは死ぬのが役目じゃないか？",
              "citation": {
                "source": "将軍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "めそめそしちゃ駄目じゃないか。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "うん」「駄目ですかね」「なに駄目じゃない」「外交官の女房にゃ、ああ云うんでないといけないです」「そこでだて。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "口が巧者に働いたり、手が小器用に働いたりするのは、いくら働いたって真面目じゃない。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "（未納を壁際へ押しつける）未納　あらあらそうじゃないんだったら、痛いじゃないの、蓄音機が駄目じゃないか。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　妾達不真面目じゃないわ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "インキはなくなるのがつとめじゃない。",
              "citation": {
                "source": "ペンとインキ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな事を言うなんて、まるでだめじゃないですか。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しぶとい人ったらありゃしないよ、何故はいと云わないの、いくらお前さんが強情張ったってだめじゃないの、早くはいと云いなさいよ、いくら厭だと云ったってだめだから、痛い思いをしないうちに、はいと云って、奥様に可愛がられたら好いじゃないの、はいと云いなさいよ」　讓は少年の顔に注意した。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
