        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうしてそれが今滅亡に瀕しているような悲しみを感ずる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして滅亡するか復興するかはただその時の偶然の運命に任せるということにする外はないという棄て鉢の哲学も可能である。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう日が来れば我国の俳諧は滅亡するであろう。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "複製の技術としての絵画はとうの昔に科学の圧迫を受けて滅亡してしまった。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人の説によれば、鳥類が農作物の害虫を駆除する功は非常なもので、もし鳥類濫殺の結果有益な鳥が絶滅に近づく暁には、地上の植物は大半滅亡するに至るであろうというている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事件は洪秀全の太平天国以来組織的に築かれた支那共産党の一つの滅亡であった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――メラ、ヴェルレーヌの詩に、　余は滅亡を知る帝国なり。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――メラ、ヴェルレーヌの詩に、　　　余は滅亡を知る帝国なり。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分では、滅亡へと急ぎつゝあるのだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち人と家とは、栄えるので、恁る景色の俤がなくなろうとする、その末路を示して、滅亡の兆を表わすので、詮ずるに、蛇は進んで衣を脱ぎ、蝉は栄えて殻を棄てる、人と家とが、皆｜他の光栄あり、便利あり、利益ある方面に向って脱出した跡には、この地のかかる俤が、空蝉になり脱殻になって了うのである。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彗星の表現はあまりにも真実性の乏しい子供だましのトリックのように思われたが、大吹雪や火山の噴煙やのいろいろな実写フィルムをさまざまに編集して、ともかくも世界滅亡のカタクリズムを表現しようと試みた努力の中にはさすがにこの作者の老巧さの片影を認めることもできないことはないようである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、以上の、われにも似合わぬ、幼き強がりの言葉の数々、すべてこれ、わが肉体滅亡の予告であること信じてよろしい。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は東海道でも有名な宿場であったようですが、だんだん寂れて、町の古い住民だけが依怙地に伝統を誇り、寂れても派手な風習を失わず、謂わば、滅亡の民の、名誉ある懶惰に耽っている有様でありました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、そのたんびに、あの憐憫なアヤ子の事を思い出しては、霊魂を滅亡す深いため息をしいしい、岩の圭角を降りて来るのでした。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでひょっと、気がつくことは、慧鶴が宗教によって救われ度いと僧になった原因は何かといえば、彼の現実の肉体を苦痛や滅亡から救い度いという慾望からであった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのもののために自己が存在し、そのものの滅亡は取りも直さず自己の滅亡である時、当然犠牲になるべきだと信じます）以外には通用しないことです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は滅亡の中からいま店の名物となって居る dortsch というスープと「スウヴァロフの鶉」という二いろ料理を持ち出した。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ武田家に旗下として武名遠近に轟きしが、勝頼滅亡の後年を經て徳川氏に歸順しつ。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち人と家とは、榮えるので、恁る景色の俤がなくならうとする、其の末路を示して、滅亡の兆を表はすので、詮ずるに、蛇は進んで衣を脱ぎ、蝉は榮えて殼を棄てる、人と家とが、皆他の光榮あり、便利あり、利益ある方面に向つて脱出した跡には、此地のかゝる俤が、空蝉になり脱殼になつて了ふのである。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとく一般旅客に不親切なる旅館は、一刻も早く滅亡すべし。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "独り三太夫は御家の滅亡近きにあらんと、夜の目も合わず心痛なし、追放案を提出して、しばしば綾子に迫るといえども、ちと仔細ありてと、おおするのみ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その縁故に因って大野は浅野家滅亡の後ここに来て身を落付けたらしい。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯は菖蒲の湯で、伝説にいう源三位頼政の室菖蒲の前は豆州長岡に生れたので、頼政滅亡の後、かれは故郷に帰って河内村の禅長寺に身をよせていた。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の三座随一たる中村座の櫓もここに滅亡せり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句の理想は俳句の滅亡である。",
              "citation": {
                "source": "夜長ノート",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅亡の風景であります。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の結論によると英國人が神經衰弱で第一番に滅亡すると云ふのだが名論だらう。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "趣味として滅亡の一歩前の美じゃなくって」「でも、どうしてもそうしたくって仕方がないのよ」「真佐子さん、あなたは変ってるわね」「そうかしら。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば浅井のお家は、一代のすけまさ公、三代のながまさ公、ともにぶそうのめいしょうでいらっしゃいましたのに、二代の久政公の御りょうけんがつたなく、御思慮があさかったばっかりにめつぼうをまねきました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
