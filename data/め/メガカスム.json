        "examples": {
          "standard": [
            {
              "text": "徹夜で仕事をしたせいで、朝には目が霞んで文字が読めなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近、老眼のせいで近くのものが目が霞んで見えにくい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長時間のパソコン作業で目が霞んできたので、休憩を取ることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（行年二十七）として、名を刻んだ地蔵様が一体、菅笠を――ああ、暑い、私何だか目が霞む。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして誰が何とも云いもしないのを、「年をとると、とかく目が霞む、目が霞む」と、自分に弁解していたのであった。",
              "citation": {
                "source": "日は輝けり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
