    "definitions": [
      {
        "index": 1,
        "gloss": "to meet (someone of higher status)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし昼間お目にかかるのは初めてでございますからね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで今夜はごたごたして居るから明日お目にかかる積りでいましたの。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこれまで彼女に会いたいなど夢にも思わなくなりましたが、貴女には会いたいと思っていましたから……」「それではお目にかかる事が出来る縁を待ちましょうね。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お目にかかるのじゃなかったんです。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえはね、この森をはいって行ってアルキル中佐どのにお目にかかる。",
              "citation": {
                "source": "ありときのこ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "確に、……何ですか、一つまくってお目にかかるとしますかね。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今初めてお目にかかる景色でもないが、とにかくに筆を執るに当って、その実地を一度見たいというような考えで、わざわざここまで足を運んだのである。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわいいぼっちゃまには、食事のあとで、お目にかかることになりました。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年前のお正月に、本当に久し振りにお目にかかる事が出来て、うれしゅうございました。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言う口の下から、もう此の逢い度い心は、……ええ、も、いっそ、今日は、お上人さまにお目にかかるのはやめてしもうて、源兵衛さんに逢う一筋に骨を折ってみましょう。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さまのところへ、挨拶に行くのが何となくおっくうで、不快で、しばらくの間ぼんやりしていると、さっきの女中が来て、「奥さまが、お部屋でお目にかかるといっていらっしゃいます。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、もしきょうの夕方、あの男がもう一度様子を見にいって、やっぱりまだ空家のままだったら、お目にかかるよ。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後お目にかかるのをお待ち致しております。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどは二枚目にかかるところです。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たびたびお目にかかるね」と、半七は笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一人の柄本家の被官天草平九郎というものは、主の退き口を守って、半弓をもって目にかかる敵を射ていたが、その場で討死した。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで来年またふたたびどこかでお目にかかるときまでには少くとも幾何の遺物を貯えておきたい。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨時放送は、さらに続いて、「きょうの夕食後に、それぞれお化粧を洗い落し、おそくとも今晩七時半の摩擦の時には、アメリカの人たちにへんな誤解をされない程度の簡素なよそおいで、塾生諸君にお目にかかるそうでございます。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう私は死んでもよいと見られる人間なんでございますが、少しこの世に未練を持っておりましたのはこうしてあなた様にお目にかかるということがあの世ではできませんからでございます。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "東宮にお目にかかると、ずっとお身大きくなっておいでになって、珍しい源氏の出仕をお喜びになるのを、限りもなくおかわいそうに源氏は思った。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもお目にかかるたびにあなたのきれいなのに驚いてばかりいましたよ。",
              "citation": {
                "source": "源氏物語",
                "author": "朝顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれほど恨んだかしれない方にお目にかかることになりました」　おとどはこう言って幕の所へ来た。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方にね、近ごろお目にかかることができましたからね。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は絵島丸まで行って見る勇気もなく、そこを幾度もあちこちして監視補たちの目にかかるのもうるさかったので、すごすごと税関の表門を県庁のほうに引き返した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まででも時々いらしったんだけれどもついにお目にかかるおりがなかったわね。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「始めてお目にかかるが、愛子さんおいくつ」　倉地はなお愛子を見やりながらこう尋ねた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕はあなたにお目にかかる気にはなりません。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よ、南海に巨人あり、富士山をその裾に、大島を枕にして、斜めにかかる微妙の姿。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の恋人の娘をむす子の許嫁にした御都合主義も、客に茶菓ばかりむやみにすすめにかかる夫人の無智と同列なのではなかろうか、といよいよかの女は興覚めてくると、其処へ規矩男が、ふざけた子供のようなとぼけた顔をして入って来た。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも余りに斎田氏の稽古振りが酷烈なので、夫人が襖の蔭からハラハラしながら出て来て、「そんなにお叱りになっては……」　と諫めにかかると斎田氏の癇癪が一層高潮した。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
