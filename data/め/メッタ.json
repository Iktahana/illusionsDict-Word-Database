        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "本を読んだら理性を恢復するかと思つて、滅多｜矢鱈に本を読んだ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意を打たれて芳は危く昏倒せんとして、僅に身を支へた、其處を、勝に乘じた群衆はなほ、執念強く、取り包んで、凡そ息のある限り、滅多無性に打ちすゑんとする、刹那の急。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "双親はまた、自分たちの眼からしてたいしたものに思い做している娘を、滅多な縁談にやれないといい張った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老妓も笑って「いつの時代だって、心懸けなきゃ滅多にないさ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだ、二人で旅へ出ることも滅多にない。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これほど自然なことは滅多にあるまい。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに景色のよいことは滅多にありません。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（中略）……この辺りコレラが流行してますので、此処の患者は滅多に済南とか青島とかの病院へは送ってくれないそうです。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "（稲垣浩　宛）　（三）　（村長、村会を開き村民どもを集めよ）雨が滅多に降らないから空が澄み渡ッて綺麗である。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は鮮人と云えば、皆同じようなプロフィルと表情を持っているとしか見えない位い、滅多に接近したことがなかった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "読んでそういう感じを覚える作家や、本は滅多にないものだ。",
              "citation": {
                "source": "愛読した本と作家から",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会では滅多に見られぬ強烈な日光がじかに顔に照りつけるのが少し痛いほどであった。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし滅多に鯉なんぞは釣れませんでした」「そりゃあ失礼ながら、あなたが下手だからでしょう」と、老人はまた笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅多なことを云うもんじゃあないよ」　眼で知らされて、熊蔵はあわてたように口を結んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御承知の通り、こんなに人家が建て込んでいるところですから、蛇も蛙も滅多に出るようなことはありません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "金を出さずに只でいくらでも得られる太陽の光さえ、彼は、滅多に見たことがなかった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎左衛門が、Ｔ「私は生れつき物覚えのよい方で」Ｔ「一度聞いた約束は滅多に忘れません」　右門が、Ｔ「ところがこの俺も」Ｔ「生れッつきやけに物覚えがいい方でなァ」　「一度見た面ァ滅多に忘れねえッ」　「おッ大将」Ｔ「お前の額のその傷ァ何だい？",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は滅多に口を利かない。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが狐の方は大へんに上品な風で滅多に人を怒らせたり気にさはるやうなことをしなかったのです。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと見ると梟は、いつでも頬をふくらせて、滅多にしゃべらず、たまたま云へば声もどっしりしてますし、眼も話す間ははっきり大きく開いてゐます、又木の陰の青ぐろいとこなどで、尤もらしく肥った首をまげたりなんかするとこは、いかにもこゝろもまっすぐらしく、誰も一ペんは欺されさうです。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが狐の方は大へんに上品な風で滅多に人を怒らせたり気にさわるようなことをしなかったのです。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖書なんてものは信心でもしない限り滅多に読んでみる気がしないものですし、その本を持ち伝えた先祖代々の人も、それがソンナ本だって事を云い伝える事も出来ずに、土蔵の奥に仕舞い込んで御座ったんでげしょう。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく滅多に出て来っこない珍本ですからドウゾお大切にお仕舞いおき願いますよ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅多に見えませんがなあ、お島どんは……それでも御座るとアノ非人を相手に長い事話し込んで御座ったという話で……」「イヤ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手が相手じゃけに滅多な事は考えられぬ」「それはそうじゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の信用に拘わってはならぬとあって、役人体の者なぞは滅多に近寄らせんように取計ろうておったものじゃが……言語道断……」「ヘエヘエ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "饑死する者は世間に滅多にありや仕ないから、食って生きてるだけなら誰だってするよ。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな家庭は、めったにあるもんじゃない。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "凍結した霜夜の街を駆け行く人力車の車輪の音――またゴム輪のはまっていなかった車輪が凍てた夜の土と砂利を噛む音は昭和の今日ではもうめったに聞くことの出来ないものになってしまった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝はこの椎茸が恐ろしく長くて、露にしめった道傍の草の上を大蛇のようにうねって行く。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
