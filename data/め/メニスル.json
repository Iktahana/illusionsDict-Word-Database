    "definitions": [
      {
        "index": 1,
        "gloss": "to see",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "張ったばかりの天井にふんの砂子を散らしたり、馬の眼瞼をなめただらして盲目にする厄介ものとも見られていた。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不真面目にすると、お前のためにならんぞ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "張ったばかりの天井に糞の砂子を散らしたり、馬の眼瞼を舐めただらして盲目にするやっかいものとも見られていた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し吾人は吾人の肺臟や心臟が何の状を爲して居るかをも解剖學の圖畫、若くは模型、又は他人の實物を目にするより以外には知らぬのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "日常目にする凡てのことに、この疑いが、からみつく。",
              "citation": {
                "source": "セトナ皇子（仮題）",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「自分の手紙を行つた先で目にすると、何んだか具合が悪いからな。",
              "citation": {
                "source": "エハガキの激賞文",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが松洲先生やお嬢さんは、私の身体のことを心配してくれて、読書さえも控え目にするように言ってくれた。",
              "citation": {
                "source": "骨を削りつつ歩む",
                "author": "――文壇苦行記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて今日あの谷に立ち入る旅の者が　赫々たる窓二つから目にするは狂いうごめく無数の大影、　外れ調子の旋律に乗りながら。",
              "citation": {
                "source": "ポオ異界詩集",
                "author": "エドガー・Ａ・ポオ　Edger A. Poe",
                "note": "青空文庫"
              }
            },
            {
              "text": "アップルの例の訴訟に関するニュースを目にするとき、脳裏をよぎるのもこの問いだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の頃では不廉な酒は容易に席上へは運ばれなく成つて居たので隨つて他人の買つたのでも皆控へ目にする樣に成つて居た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ雪が路傍に残っているのを目にするようになった。",
              "citation": {
                "source": "穂高岳",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし我々は我々の肺臓や心臓がどんな状態をしているのかも解剖学の図画や模型または他人の実物を目にすること以外には知らないのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は私の乗つた軌道車が、樋田あたりから夜になつて、渓を一々仔細に目にすることの出来ないのを憾んだが、しかしその車に燈火がなく、外はおぼろ月夜であつたために、却つて両岸のを見得たことを喜ばずにゐられなかつた。",
              "citation": {
                "source": "耶馬渓の一夜",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは広い海に面した室で、長い縁側と、スロオプになつてゐる広場とを隔てゝ、向うに波の白く凄じく岩に当つて砕けてゐるのを目にするやうなところであつた。",
              "citation": {
                "source": "波の音",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "をりをり昔のまゝに残つてゐる町の角や、新しい家屋に挟まれた古い二階などを目にすることがあつても、それは極めて稀である。",
              "citation": {
                "source": "半日の閑話",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "醜悪なる恋愛と云ふものはかくも青年を盲目にするものであるか。",
              "citation": {
                "source": "遍歴",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのなかから詩味の和やかなのを見つけると、丁度人参や茯苓の口当りが甘いのに出会つたやうに、また格調の激越なのを目にすると、まるで薑や肉桂の辛烈舌を刺すやうなのを味はつたやうに、どちらも内臓を癒すにききめが少くない。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "心をとらえて真面目にする力はそこから湧いていると思われる。",
              "citation": {
                "source": "次が待たれるおくりもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだ、君ちつと金を借して僕を真面目にする了見はないかと聞いた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども考へのない彼女等の昂奮は先生をます／＼盲目にするらしく思はれました。",
              "citation": {
                "source": "編輯室より（一九一五年五月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の發する言葉にも、いつも身づから感じて控へ目にする強い、明確な調子がなくなつてる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺を盲目にするつもりか。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "背を引け目にするどころか、てんで頓着しているふうも見えない。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　孫文氏に限らず、支那人はよく日本の侵略を攻撃して排日の題目にするが、その實日本は支那に對して毫も侵略を行つて居らぬ。",
              "citation": {
                "source": "支那猥談",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼七分目に捧げたら、低すぎると叱られ、八分目にすると、高すぎると罵られ、その夜の湯殿で、肩を流しようが悪いと、湯を、肩からぶっかけられた時、明日にも、暇をとって戻ろうかとさえ思った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "予等には初めて目にする妓館の室内が珍しかつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう云ふ荒寥とした沙の世界を目にすると、初めて蒙古の内部へ一歩踏み入つたと云ふ気がする。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "目にする木は大抵楡である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍隊内における組織的活動、軍国主義と資本主義のためにする軍隊の使用に反対する啓蒙的な宣伝は、兵営に這入ろうとする革命的な青年たちのやらねばならぬ仕事である。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（いえもう何でございます、実はこの先一町行け、そうすれば上段の室に寝かして一晩｜扇いでいてそれで功徳のためにする家があると承りましても、全くのところ一足も歩行けますのではございません、どこの物置でも馬小屋の隅でもよいのでございますから後生でございます。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
