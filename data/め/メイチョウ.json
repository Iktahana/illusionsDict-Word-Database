  {
    "uuid": "4c2549a9-aded-5ba9-a08f-bb2422cf4760",
    "entry": "名帳",
    "reading": {
      "primary": "めいちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "register of names",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "主人は署名帳を出して、私に物書けというから、三、四行したためた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんど同時に出来た『延喜式神名帳』、加賀に野蛟神社二所あり。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "近江國の竹生島は今「チクブシマ」と發音するが、延喜式の神名帳によれば都久夫須麻神社とある。",
              "citation": {
                "source": "平安朝時代の漢文學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに一方に於て、古事記には、綏靖天皇の兄神八井耳命は阿蘇君の祖なりとあり、又舊事紀の國造本紀には、崇神天皇の御代に、神八井耳命の孫の速瓶玉命を阿蘇の國造に定め賜ふとあつて、神八井耳命の子は健磐龍命と云ひ、延喜式の神名帳に祭られて居る神であるといはれてゐる。",
              "citation": {
                "source": "女眞種族の同源傳説",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち天照大神遙宮と延暦儀式帳、延喜式神名帳等にいへる者なり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "神名帳考證にも棒は欅字の誤也、久奴木の略語奴木原也、長谷街道也とあり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "伴氏の考に魚見社は神名祕書に機殿、儀式帳云、魚見社三前、月讀命、豐玉彦命、豐玉姫と見えたり、延喜式神名帳にも多氣郡魚見神社見えたり、麻積と關係ありげにも見ゆ。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "倭姫命世記にも御櫛落し賜ひて、櫛田社、定賜ふことあり、儀式帳にも櫛田根椋の神御田奉ること見え、神名帳には多氣郡櫛田神社、櫛田槻本神社、大櫛神社等あり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "間智は宇麻志麻遲命の麻遲に同じく、荒木田守良が鹿龜雜誌富岡氏藏本に麻遲の名の古書に見えたるを擧げて、宇麻志麻遲命の外に神名帳の遠江國佐野郡｜己等能麻知神社、近江國高島郡麻知神社、及び中臣壽詞に麻知弱韮由都篁生出とあるを引き、其の釋義は明かならずといへり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の長は阿波國那賀郡なるべきが上に、此國には又美馬郡といふもあり、神名帳には此國名方郡に御間都比古神社ありて、栗田氏は即ち觀松彦色止命を祀るとせり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "神名帳に出雲國出雲郡阿須伎神社同社神伊佐我神社あり、又同郡に伊佐波神社、伊佐賀神社あり、栗田氏の神祇志料に皆出雲國造の祖、天夷鳥命の子伊佐我命を祀るとせり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊佐我命に縁ある者としては、神名帳に出雲國出雲郡に都我利神社あり、栗田氏の志料に武夷鳥命即ち天夷鳥命の孫、津狡命を祀るとせり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "載斯烏越　　載を戴の訛とせば、武内に近しといふ説あれど、今は字を改めずして解釋を試みんに神名帳に出雲國飯石郡須佐神社あり、今須佐郷に在り、又大原郡佐世神社あり、今佐世郷に在り倶に須佐能袁命を祀ると栗田氏の志料に見えたり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "延喜式神名帳によれば、本郡に比都佐神社あり、又此地方に鳥坂長峰あるによるなり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡禮や參詣人が二三人も來て、神名帳や神符を頂きに社務所へ來たけれど、門が閉まつてゐるので、暫く扉を叩いては、ブツ／＼言ひながら立ち去つた。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「門人連名帳へ署名血判なされ」　というと同時に、若者は「御免」　と、いって、脇差から、小柄を抜いて、左の親指へ当てた。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "神名帳に、賀茂別雷神社、亦若雷とあるのは、有力な証拠である。",
              "citation": {
                "source": "わかしとおゆと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしおもしろいことに、壁も天井も一面の落書で此の上もう記入する余地がなくなったので、署名希望者は誕生日に来て別に一シリング出せば、壁の代りに記名帳に署名させることになってるそうだ。",
              "citation": {
                "source": "シェイクスピアの郷里",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この美和神社は平安朝の神名帳にも記載のあるユイショある神社であった。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は県社であるが、大昔の神名帳では大社になっているそうで、この辺の豪族だった国ツ神を祭ったものではないかと考えられている。",
              "citation": {
                "source": "牛",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは延喜式の神名帳などで見ますと「出雲｜井於」と申す神社であります。",
              "citation": {
                "source": "近畿地方に於ける神社",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで又延喜式の神名帳に據りますと、小野神社といふものが其の邊にあつたといふ事であります。",
              "citation": {
                "source": "近畿地方に於ける神社",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の外方々にあるといふことでありまして、信友の延喜式の神名帳の考證に據りますと、大分是が其處らぢうにある、近江國の野洲郡、同國伊香郡の兵主神社、播磨國の飾磨郡の射立兵主神社、「いだて」が付くことがあります。",
              "citation": {
                "source": "近畿地方に於ける神社",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてホンモノのヒダの神様にはなかなか位をやらなくて貞観九年にはじめて従五位下をやり、延喜式神名帳では、ヒダは全部でたった八ツの神で、それも全部小ですよ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "参拝の人々の記名帳をひらくと、阿佐ヶ谷文士一行が来ておって太宰治の署名もあったが、呆れたことには、参拝者の大部分が政治家で、特に総理大臣級が甚だ多く参拝している。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り山の手の芸者が売淫この時よりいよいよ公然黙許の形となり芸者連名帳にれいれいと枕金の高を書出す勢とはなりけり。",
              "citation": {
                "source": "桑中喜語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も延喜の「神祇式」には斯波郡内の官社一社が載せられてあるが、これはおそらく古い「神名帳」のままを収録したもので（「延喜神名帳」は他にも往時のまま改めざる証少からず）、当時の実際ではない。",
              "citation": {
                "source": "奥州における御館藤原氏",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "続紀『天平神護元年、名草郡大領紀直国栖』と云ふは、紀伊国神名帳『名草郡正一位紀氏栗栖大神』と相因む所あらん、云々。",
              "citation": {
                "source": "国栖の名義",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "砲台のある上総の富津、『延喜式｜神名帳』及び『三代実録』天安二年十月の条に見えている伊予｜越智郡の布都神社の布都などもおそらくは右のフトであろう。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
