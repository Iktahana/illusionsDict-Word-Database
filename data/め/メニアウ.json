    "definitions": [
      {
        "index": 1,
        "gloss": "to experience (something unpleasant)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このやうなひどい目にあうて、何悪いことしたむくいぢゃと、恨むやうなことがあってはならぬ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、昔話のまね爺と同様によほどひどい目にあうのが落ちであろう。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、この世の中で不幸な目にあうように生れてきたわけではありません。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それがいい、あんた何も堂島さんにこんな目にあうわけないでしょう」　磯子が、そう訊いたとき、磯子自身ですら悪いことを訊いたものだと思うほど加奈江も明子も不快なお互いを探り合うような顔付きで眼を光らした。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざわざ、もっとひどい目にあうために、この島へ来たようなものだ。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなおそろしい目にあうのは、とてもがまんができないと思ったものですから。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、そんなことをすると、きっとあとでこわい目にあうにちがいないから、およしなさい、およしなさい、と言ってとめました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち、またこわい目にあうことになりました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうもう一晩だって、あんな目にあうのは、いやだと思ったものですから。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、こんな悲しい目にあうのは、きっとまほうのランプがなくなったせいにちがいない、だれがぬすんだかを見とどけなければならぬ、と、かたく決心しました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは堅牢な造りで、がっしりした扉がついていて、「先生」の留守中にその扉をあけようものなら、私たちはまったくいっそあの peine forte et dure（強い厳しい刑罰（６））で死んだほうがましだと思うくらいの目にあうのだった。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "「年が行ってしまうと恥ずかしい目にあうものです。",
              "citation": {
                "source": "源氏物語",
                "author": "朝顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子はそんな目にあうと軽蔑しきった冷ややかなひとみでじろりと見返してやりたいような気になった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたと離れて、いろいろいやな目にあうのはいやですわ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "退かねえとうぬも一緒に痛え目にあうぞッ」　どッと口々に犇めき叫びながら襲いかかろうとしたのを、「控えろと申すに控えおらぬか！",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちかが、ひでえ目にあうかなんかしそうだ」「どっちかって、だれとだれのどっち？",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は人ごみの中でつかまったすりのように、大勢の中へ曳きずり出されて、ひどい目にあうにきまっている。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、これがとんだ感ちがいで、実はそのとき僕は、世にも恐ろしい目にあうための地獄行の運命船にのりこんでいたのだとは、ずっと後になってやっと分ったことである。",
              "citation": {
                "source": "地球を狙う者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからまだどういう目にあうかもしれないから、水の用意はしておかないといけないんだ」「なるほど。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって捉ってはどんな目にあうかもしれない。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様が余計なおしゃべりをするから、杉田がこんな目にあうんだぞ」「なんだって、俺が余計なおしゃべりをしたって。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっとつかまってひどい目にあうにきまっています。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう目にあうと、すっかり不愉快になって、その次からあまり見知らぬ雑誌から注文されると、原稿料のことはともかく、またあのような不愉快な目にあうのかと思い、ペンがうごかなくなる。",
              "citation": {
                "source": "『十八時の音楽浴』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "およし　わしもなあ、長生きしたおかげで、食うや飲まずの辛い目にあうことじゃ。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚作　（同じく手を貸して、担ぎ上げながら、二人の兄のよりは、やや優しく）盗み食いやこしするけに、こなな目にあうのじゃ。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時、下手まごつくと首が飛ぶし、それかというて、後込みしとると一揆からひどい目にあうしのう。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし今度この指輪を取ると、ひどい目にあうのだぞ』　僕は、お主婦が何か畏っていっているのを聞き流して、梯子段を降りたのです。",
              "citation": {
                "source": "島原心中",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それからお母さんは豊さんに向かって、『お前がいつもお母さんを嫌うから、こういう目にあうのだよ。",
              "citation": {
                "source": "塵埃は語る",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "少数ではやった者がひどいめにあうばかりだ。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたずらな子どものことだから、つかまったらどんなめにあうかしれません。",
              "citation": {
                "source": "子どものすきな神さま",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
