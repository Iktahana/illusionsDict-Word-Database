        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もちろん家には最近迎えたばかりの新妻はあり、夫婦生活の味もまだ身に染む間もないころのことだったが、銀子にも嫉妬に似た感情の芽出しはありながら、それを引きとめる手もなく、双方物足りぬ感じで別れるのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "境遇に負けて人臆れのする少年であった鼈四郎は、これ等の人気を避けて、土手の屈曲の影になる川の枝流れに、芽出し柳の参差を盾に、姿を隠すようにして漁った。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "堤の芽出し柳の煙れる梢に春なかばの空は晴れみ曇りみしている。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども長堤も対岸の丘もかなり青み亘り、その青みの中に柔かいうす紅や萌黄の芽出しの色が一面に漉き込まれている。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝折戸の外は、上の方より下の方へかけて小さき流れありて、一二枚の板をわたし、芽出し柳の立木あり。",
              "citation": {
                "source": "近松半二の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝可憐なる意気地なき、心臓の鼓動しやすき、下腹のへこみやすき青年文士よ、汝の生るる事百年ばかり早過ぎたり、今の世は文士保護論の僅かに芽出したる時にして文士保護の実の行はるる時にあらず、我汝が原稿を抱いて飯にもありつけぬ窮境を憐んで汝を一刀両断せんとす、汝出直して来れ。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "この三つは何れもアシの事ではあるが、しかし支那の説では初生の芽出しが葭でそれがもっと生長した場合が蘆で、そして充分成長したものが葦であり葦は偉大の意味だと書いてある。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "植込みのなかに突きだした『ご不浄のサロン』は、芽出しの若葉に三方から囲まれ、ソファに坐って窓のほうを見ると、いぜん、われわれが、しゃがみながらながめたその位置に、むかしどおりの布袋竹と丁字の葉むらが、そよそよと風にそよいでいる。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままで洋服箪笥のあった壁の上に、芽出しの白膠木の葉繁みがレースのような繊細な影を落しているのが、なぜかひどく斬新な感じがした。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "春は草が青あおとしげって、白い小ぎくが碧玉をしきつめたもうせんの上に白い星をちりばめていたし、芽出しやなぎやポプラの若木からはねっとりとやにが流れていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "145＊樹の緑葉のそれのごと人の素生も亦然り、風は樹葉を吹き去りて大地に散らし、森林は春の新たに囘る時他をまた芽出し長ぜしむ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると、右の手が煙草箱の方へ動いてその太い指が煙草を丸めだした。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "※子の家と家との間では、耳輪をチラ／＼させた女が、奇怪な微笑を始めだした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全世界に於て、プロレタリアートが、両手を合わすことをやめて、それを拳に握り締めだした。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しめだしを食っちゃった。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日没にはまだ半時間もあろうに、モウゆうやけがほの赤く天末を染めだした。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻姉さん所にもお前を探しに来たんだよ」　と云ふのを冒頭に、裏に怒りを潜めながら、表は優しい口調で、お末に因果を含めだした。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座が鎮まると貴女は薔薇の話は放りやって、父や母とロスタンのシャンテクレールの噂を始めだした。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女はほほえんでしばらく口をつぐんでいたが、また平気で前の話を始めだした。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫大将は、「ハッハッハ、先生もだめだし、生徒も悪い。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文科に入ったのも友人のすすめだし、教師になったのも人がそう言って呉れたからだし、洋行したのも、帰って来て大学に勤めたのも、『朝日新聞』に入ったのも、小説を書いたのも、皆そうだ。",
              "citation": {
                "source": "処女作追懐談",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "永らく孀暮しをしていて、一人で豆をひいていたのだったが世話する者があって夫婦養子をしたところが入籍してしまってから養子たちは養母をひどくいじめだしたという近所の噂だった。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近｜丸ノ内辺りの会社に勤めだしたらしい。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お邪魔じゃないのですか」「家は、今、何人もおりませんから、何時までおいでくださいましても宜しゅうございます」「そうですか」　益雄があがって蒲団を持って入ると、女は起って雨戸を閉めだした。",
              "citation": {
                "source": "草藪の中",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけで、カイはまごころをささげて、じぶんをしたってくれるゲルダまでも、いじめだしました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸く昨年の春から集めだしたものである。",
              "citation": {
                "source": "たべものの木",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲虫を振りまわしたのもそのためだし、あれを木から落させたのもそのためなんだ。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋が深くなったこのごろの風の音が身にしむのを感じる、そうしたある夜明けに、白菊が淡色を染めだした花の枝に、青がかった灰色の紙に書いた手紙を付けて、置いて行った使いがあった。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            },
            {
              "text": "手近なところで、俺の信じてゐる彼女の態度はどうだ、だんだん世間なみに嘘をおぼえこみ、なんにもないところから、鶏を飛び出させたりする手品師のやうな真似を始めだした。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "上機嫌になつて、酒場の中で、おしやべりを始めだしますと、同じ酒場のお客さんたちは、『そろそろ、吃りの男に、油が乗つてきたぞ。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
