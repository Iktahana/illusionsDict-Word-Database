        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "目茶目茶なんですのよ、それが。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会制裁の目茶目茶は医師のはんらんと、小市民の医師の良心に対する盲目的信仰より起った。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　それと同時に、宿酔に縺れた中田の頭も、今日一日の目茶目茶な行動から、漸く加わって来た寒気と共に、現実的な問題に近寄って来た。",
              "citation": {
                "source": "自殺",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人ったら、人が目茶目茶に撲られるのが大好きなんだって、方々に血が滲んで、ぐったり倒れているのを見ると、縋りつきたいようなんですって、あの人、いまに人殺しするかもしれないわ。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カッと逆上した黒吉は、松葉杖を振りかぶると、渾身の力をこめて、目茶目茶に、葉子を撲りつけた。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「恋しい恋しい」という文字や「嬉しい嬉しい」という文字も、目茶目茶に恋文へ書き込んだ。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああそうかい、何んでもないんだねえ」　そう云って萩丸は「木」を書いたが、今度は旁を目茶目茶に書き、けっきょく「様」という字は書けなかった。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の病人の悪いと云う事で旅先から帰ると云うのは私にとっては今度が初めてで口に云い表わせないワクワクした気持がそう云う事に経験のない私の心を目茶目茶にかき廻した。",
              "citation": {
                "source": "悲しめる心",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "19．彼は自働車を電信柱に乘りあてたので、自働車は目茶目茶に壞れてしまつた。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "１．彼は自動車を電柱に乘り當てて、目茶目茶に毀してしまつた。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "目茶目茶に痩せた耕地であって、その上を雪が蔽うていた。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯火が無数にともし出され、酒肴が目茶目茶に運び出された。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日二夜の長きに渡って、目茶目茶に愛慾をそそられたのである。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄一はその中に三ノ宮筋によく乞食に出て居る目茶目茶女を見付けた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな変な音を出すピアノなんて、聞いたことがない」　蘭堂は云いながら、今度は両手の指で、鍵盤の端から端まで、目茶目茶にかきならした。",
              "citation": {
                "source": "恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはこの愉快な創造の数時間をめちゃめちゃに壊した窓のたくさんの顔をできるだけ強い表情でにらみまはした。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "体裁よく飾りつけられた屋内のさまざまなものが、片ッぱしからめちゃめちゃに放り出された。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、人の三倍も四倍も復讐心の強い男なのであるから、また、そうなると人の五倍も六倍も残忍性を発揮してしまう男なのであるから、たちどころにその犬の頭蓋骨を、めちゃめちゃに粉砕し、眼玉をくり抜き、ぐしゃぐしゃに噛んで、べっと吐き捨て、それでも足りずに近所近辺の飼い犬ことごとく毒殺してしまうであろう。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとあいつのゴム靴がめちゃめちゃになるだらう。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとあいつのゴム靴がめちゃめちゃになるだろう。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな木などは根こぎになり、藪や何かもめちゃめちゃだ。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の人ならせっかくの日曜をめちゃめちゃにしてしまったと不平を並べるところだが、時田先生、全く無頓着である。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして一同が高く笑い崩れるにしたがって、片方の牡蠣のように盲いた眼までを輝かして顔だけでめちゃめちゃに笑った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後は場内上を下への大混乱となって芝居はめちゃめちゃとなった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後の生活がめちゃめちゃになってしまうことがあります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時節もので、めりやすの襯衣、めちゃめちゃの大安売、ふらんねる切地の見切物、浜から輸出品の羽二重の手巾、棄直段というのもあり、外套、まんと、古洋服、どれも一式の店さえ八九ヶ所。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると異教席はもうめちゃめちゃでした。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの三羽のうみがらすそのなき声は波にまぎれそのはゞたきはひかりに消され　　（燈台はもう空の網でめちゃめちゃだ。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」左隊右壁に沿い足踏み（銅鑼）曹長特務曹長（互に進み寄り足踏みつつ唱う）「糧食はなし　四月の寒さストマクウオッチももうめちゃめちゃだ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため御者はめちゃめちゃに馬に鞭をあてたり、手綱をぐっと引きしぼったりしました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            }
          ]
        }
