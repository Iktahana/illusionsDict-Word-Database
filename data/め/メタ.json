    },
    "definitions": [
      {
        "index": 1,
        "gloss": "meta",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この句の詩境には、宇宙の恒久と不変に関して、或る感覚的な瞳を持つところの、一のメタフィジカルな凝視がある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の亡き母に対する愛は、加賀千代女の如き人情的、常識道徳的の愛ではなくって、メタフィジックの象徴界に縹渺している、魂の哀切な追懐であり、プラトンのいわゆる「霊魂の思慕」とも言うべきものであった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ一つの現象が、その隠された「秘密の裏側」を持ってるということほど、メタフィジックの神秘を包んだ問題はない。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人の直覚する超常識の宇宙だけが、真のメタフィジックの実在なのだ。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "横腹押さえて三次シメタと思った。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "スメターニンは、」また息切れがした。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには武石と、道案内のスメターニンとが彼を待っていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、スメターニンと共に、また歩きだした。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山へ登ってみよう、とスメターニンが云いだした。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "スメターニンはやはり見当がつかなかった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　スメターニンは、毛皮の帽子をぬいで額の汗を拭いた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人兵士諸君　日本帝国主義ブルジョアジーハ、諸君ヲシテ、銃ヲ携エ砲ヲ持チ、急速ニ山東ノ地ニ来ラシメタ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那ノ労働者農民ノ国民革命運動ヲ、血ヲ以テ窒息セシメタ各国ノ帝国主義ハ、干渉カラ土地掠奪ニ移ロウトシテイル。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本帝国主義ハ、真先ニ掠奪スルタメニ有利ナル戦略的状勢ヲ利用シテ、諸君ヲコノ地ヘ来ラシメタ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍、独裁官田中ハ、諸君ヲ山東ニマデヨコサシメタル田中ハ諸君ノ階級ノ最悪ノ敵デアルコトヲ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然も今日多數の同人雜誌、同人雜誌作家の大部分は今尚今後幾度のメタモルフオーゼを行はなければ、その發芽にも至らぬやうに思へる。",
              "citation": {
                "source": "「青空語」に寄せて（昭和二年一月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこの上にメタセシスを許し、またＡ語の一子音に対すべきＢ語子音の転訛範囲を拡張すればこれはさらに増加する。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に比較の標準を少し下げて、メタセシスを許容すると、Ｐの展開式のｉ項に※が乗ぜられる事になるが（ただし子音が皆異なるとして）、これでは少なくもｎがあまり小さくない限り、明らかに最後の結果の桁数に変化は起こらない。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてやって来たボーイ頭をつかまえて「このアイスクリーム、チトモツメタクナイ。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "チトモツメタクナイ。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツメタイノ持って来てください。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツメタイアイスクリーム持って来てください」というのである。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一等賞から九等賞まではぼくが大きなメタルを書いて、明日枝にぶらさげてやる。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一とうしょう、白金メタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第二とうしょう、きんいろメタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第三とうしょう、水銀メタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第｜四とうしょう、ニッケルメタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第五とうしょう、とたんのメタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第六とうしょう、にせがねメタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「よせ、よせ、にせものだからにせがねのメタルをやるんだ。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
