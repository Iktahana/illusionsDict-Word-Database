        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あれば貸すんだがと弁解すると、いや、構めへん、構めへんとあっさり言う。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うちもうここに居られしめへん。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はい、お名前はお言いはれしめへんどした」「なんぜ、あたしに黙って通したの？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「好きだ」「ほな、あて、あした、べにやの※みつおごらせて貰てもかめしめへんどっか」「※みつ……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "財布持ったはれしめへんどしたさかい」　小田はにやりと笑って、司法主任の顔を見た。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから……」「だから、どうだっていうんだ」「だから、あんたが何をしてもかめへんと思ったのよ」「そんなお礼返しは真っ平だ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "片一方磨き終ると、豹吉は、「それでええ」「まだ片足すんどらへんがな」「かめへん」　と、金を渡すと、豹吉はこんどは大きい方の少年の方へ、「こっちの足はお前磨け」「…………」「心配するな。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんぼ戦争に負けた云うたかテ、珈琲の味ぐらい覚えてもかめへんぞ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "運ばれて来るたびに、靴磨きの兄弟――「うわッ、うまそうやな」　と、唾をのみ込み咽を鳴らしながら、しかし、「――これ食べてもかめへんか。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "けッ、けッ、けッ……」　黒い顔じゅう皺だらけにして笑うと、「――チケットも持ったはれしめへんでしたか」「チケット……？",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハナヤできいても分れしめへんか」「うん。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「刺青はして貰わんでもかめしめへん」　次郎はあわてて言った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴きはれしめへんか。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲人ももう一押し押せば、十に一つは動く振りもおたかには充分あったところだが、もはやそんな痛いところを突かれては、おたかの気持はいつものところへ落ち着いて、「格式が違うことあれしめへんか」　意固地な声であった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そら、行かれんことあれしめへんけど……」「そんなら、待ってます」　次郎は伝票を掴んで、「――出ましょうか」　立ち上りざまに言った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人で、苦労してこれだけの人間になりました言うて、お父さんの前へ早よ出られるようにしよ思て、一所懸命になってるわての気持は、あんたには判れしめへんのんか。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんぼえらそうなこと言っても、やっぱり歳は歳やさかい……」「――隠居してくれ言うても、なかなか隠居してくれしめへんねん。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「肝腎の私に一寸も抱かしてくれはれしめへんねん」　持子の声は明るかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「夜道は物騒やさかい、そこまで送って行ってくれたかテ、かめへんやろ」「そこまでって、どこまでだ……？",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ横になったかテかめへん……？",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しても、ドジ踏めへん」「あんた泥棒したの……？",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんまりええ写真機持っとるさかい、こんなン盗んだったかテ構めへんやろ思って、アパートまでついて行って、笑って来たってん。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かめへんか」「かめへんわい。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あ、螢、螢と登勢は十六の娘のように蚊帳じゅうはねまわって子供の眼を覚ましたが、やがて子供を眠らせてしまうと、伊助はおずおずと、と、と、登勢、わい、じょ、じょ、浄瑠璃習うてもかめへんか。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "わては一生本屋をやめしめへんぜ」　と、言った。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたとこは昔から五割安だからね」　というと、お内儀さんはうれしそうに、「千日堂の信用もおますさかいな、けったいなことも出来しめへん。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉芸者を揚げようというのを蝶子はたしなめて、これからの二人の行末のことを考えたら、そんな呑気な気イでいてられへんともっともだったが、勘当といってもすぐ詫びをいれて帰り込む肚の柳吉は、かめへん、かめへん。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
