        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし日光に透かして見るとこれとはまた独立な、もっと細かく規則正しい簾のような縞目が見える。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか死ぬまでちんばでいたいものだ」「おれも人なみに目が見えるようになっちゃ大変だ。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャンの目はすこしずつあかるくなって、綾目が見えるようになってきました。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャンはそれを見るとおどろいて、「やいピエール、おまえの足はどうしたんだ」　といいますと、ピエールも始めて気がついたようにおどろいて、ジャンを見かえりながら、「といえばおまえは目が見えるようになったのか」　と不思議がります。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "療治が達しやで、すこし目が見える、夜話が實に巧い、職がらで夜戸出が多い、其のいろ／＼な話であるが、先づ水口園の前の野原の眞中で夜なかであつた、茫々とした草の中から、足もとへ、むく／＼と牛の突立つやうに起上つた大漢子が、いきなり鼻の先へ大きな握拳を突出した、「マツチねえか。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "百五十円あれば、それで目が見えるようになるのかね？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "療治が達しゃで、すこし目が見える、夜話が実に巧い、職がらで夜戸出が多い、そのいろいろな話であるが、先ず水口園の前の野原の真中で夜なかであった、茫々とした草の中から、足もとへ、むくむくと牛の突立つように起上った大漢子が、いきなり鼻の先へ大きな握拳を突出した、「マッチねえか。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう満三年やが、ちつとでも宜い目が見えるのなら勢もあれど。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠は夜目が見えるだろうのに！",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三四年（昭和九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには自分の目が見える。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしゃ、気が短いからね」「何奴だ、きさまは」「まっくらやみで、目が見える猫女と申す者でござる。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟻田博士は、くらがりでもよく目が見えるらしく、立上ると、何かしきりに機械を廻している様子だ。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、私も答礼に行こうと言ったら、その方は「いや、私のところは石段が沢山あるし、私は目が見えるから、上り下りのことはよくわかるが、目の悪い方に来られて、怪我でもされては困るから、来て戴かなくても宜しい」と言われた。",
              "citation": {
                "source": "垣隣り",
                "author": "宮城道雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "目が見える人は、進駐軍の服がよいとか、帽子がよいとか、靴がスマートだとかそのすがたを見るようであるが、私は声を聞いてやさしい親切な心を感じた。",
              "citation": {
                "source": "私のすきな人",
                "author": "宮城道雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで幾日か過ごすうちに、子ねこは、やっと目が見えるようになりました。",
              "citation": {
                "source": "どこかに生きながら",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、小犬たちは、だんだん目が見えるようになりました。",
              "citation": {
                "source": "森の中の犬ころ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お繁さんも、この頃のように、ああ無駄目が見えるようになっては長くあるまい。",
              "citation": {
                "source": "夜の喜び",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "深く頭巾をたらしているから、かすかに目が見えるだけで、まったく人相は分らなかった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十五　赤罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "噴煙が左右に揺れる隙間から、時々岩の割れ目が見える。",
              "citation": {
                "source": "天地創造の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "池辺君の容体が突然変ったのは、その日の十時半頃からで、一時は注射の利目が見えるくらい、落ちつきかけたのだそうである。",
              "citation": {
                "source": "三山居士",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "所々が薄くなって日に透かして見ると裏からつぎを当てた針の目が見える。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしがおまえだけに目が見えるといいのだがなあ。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方の目が見えることはたいへんありがたいことです。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで夫は妻にその話をしたところ産婦も静かに落ち着いて、「片方の目が見えるのはたいへんありがたいことです。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく似た子だと思うとあの子は目が見えるような顔をして、弟さんと一しょにいたの。",
              "citation": {
                "source": "童話",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の人は私を魔法使いと呼びますが、貴方の目が見えるようにして差し上げられるわけではありません――もしそんなことができるならば、私はそれを捧げるために心のすべてを注ぎますのに。",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん　榮養が惡いだと」「そいで君はあの小屋で目が見えるようになるまで待つていたんだな？",
              "citation": {
                "source": "捨吉",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お目が見えると、この花を御覧に入れるのだけれど」　柱に凭れていた竜之助の前へ、お銀様はその花を持って来ました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "慢心和尚の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
