        "examples": {
          "standard": [
            {
              "text": "夏休みのキャンプで、子供たちが広場で目隠し鬼をして遊んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "目隠し鬼は、声だけを頼りに相手を探すのが面白い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔、よく近所の友達と目隠し鬼をして日が暮れるまで遊んだものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あたかも四通の手紙の間の目隠し鬼になってからかわれてるような気がした。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
