    "definitions": [
      {
        "index": 1,
        "gloss": "and they all lived happily ever after",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もっともその時に万一、私が過去の経歴を思い出していたら、話はソレッ切りで、目出度し目出度しになっていたかも知れません。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでお仕舞い……目出度し目出度しかね。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らば、民衆には、散々人を泣かせて置いて遂に目出度し目出度しで終るメロドラマでなければいけないと云うのか。",
              "citation": {
                "source": "新しき世界の為めの新しき芸術",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "空想的な扮装したレヴューの土人みたいな「赤紫島」の住民が何かのキッカケで、至極安直に革命を遂行し、ツァーの追っ払いをやり、目出度し目出度しとなるのだが、ソヴェト同盟のルバーシカを着た観衆はゾロゾロ、カーメルヌイ劇場から出て来ながら、この劇全体から受けた何だかいやな印象について議論した。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それで目出度し目出度しさ」「危いところでしたね、親分」「お桃を縛つた日にや、十手捕繩返上しても追付かなかつたよ」「のべつに縮尻つて居る萬七親分や清吉は平氣でやつて居るぢやありませんか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "梅吉殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年の出で行きし後、翁は庭の中をかなたこなたと歩み、めでたしめでたしと繰り返して独言ちしが、ふと足を止め、眼を閉じ、ややありて、されど哀れの君よと深き嘆息をもらしぬ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君めでたしめでたし。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なくなったしろものが出てきたんだったら、橋の上にあろうと、うなぎ屋の二階にあろうと、めでたしめでたしでけっこう話ア済んでいるんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな話ばかりでは人情話どころか、不人情話と云うべきであるが、さきに殺された助右衛門の娘おまきと忰重次郎、この姉弟が父のかたきを尋ねる苦心談があり、結局は丈助が前非を悔いて切腹し、めでたしめでたしに終わることになっている。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉はほんとによい、湯上りのよい気持で、例の安い安い定食で二本飲んで、七時の汽車で帰庵、めでたしめでたしであつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎさん来庵、いつしよにほどよく飲んで食べて、それから歩く、ほどよく酔うて別れた、めでたしめでたし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……うまい酒だつた、うまい鮒だつた、まことによい酒盛であつた、めでたしめでたし（樹明君万歳！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、樹明君来庵、例年の如く餅を頂戴する、有合の下物で飲む、――かうして、こゝで、年を送り年を迎へる、めでたしめでたし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "万事めでたしめでたし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "残つた酒、残つた肴で、めでたしめでたし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、買物がてら街へ出かけて、一杯また一杯、すつかり酔つぱらつたが、おとなしく戻つて寝た、めでたしめでたし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "めでたしめでたし、大いにめでたし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋから女子出産、母子共健全とのたよりがあつた、めでたしめでたしと独り言をいふばかりである！",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は二百三十日、厄日を無事平穏に通り越して、めでたしめでたし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡々居には生れたばかりの赤ン坊がゐた、阿弥坊居では奥さんが産むばかりの前で寝てゐられた、とにかく、めでたしめでたし。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "）、街へ出て、鮹、蒲鉾、酒、煙草、葉書を買うて来る、二人でやつてゐるうちに、冬村君もやつてきて、三人で大に愉快にやつた、めでたしめでたし、万歳万歳。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで芬夫人はその由来をこの絵巻物に手記して子孫に伝えた……めでたしめでたしというわけだ」「じゃその名文は芬夫人が書いたんですね」「イヤ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、私の教えている学生は、私の講義を真面目に聴かなくなったばかりでなく、私の教室の黒板に、私と妻とのカリカテュアを描いて、その下に「めでたしめでたし」と書いて置きました。",
              "citation": {
                "source": "二つの手紙",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "かのめでたしめでたしとやるところだ」と語る声斎藤の耳に入りたれば。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな声にてめでたしめでたし。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "長与善郎氏の小説、めでたしめでたし、妻君が流産したことをああ云う風に書いて平気で居られるのは（そのお坊ちゃん的変さに於て）彼一流だ。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ面白いのは、マライ映画はたいがい恋愛が悲恋に終って、めでたしめでたしのあべこべに終るばかりでなく、例外ないほど一方が自殺してしまう。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "妊娠のほうはやがて赤ちゃんが生まれたらめでたしめでたしだが、私の脾臓は出てゆかない。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、下らない意地は捨てる方が得、ね、ウンと承知すりゃあ、万事万端めでたしめでたしで納まろうってもんだ。",
              "citation": {
                "source": "禰宜様宮田",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まアめでたしめでたし。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
