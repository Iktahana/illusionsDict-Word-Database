[
  {
    "uuid": "1cfe83ac-24d0-54ad-b3b6-0256c3ea3d58",
    "entry": "馬頭",
    "reading": {
      "primary": "めず",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
