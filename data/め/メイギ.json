[
  {
    "uuid": "5884eae3-e533-5702-92b1-18eb4a433e69",
    "entry": "名義",
    "reading": {
      "primary": "めいぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
