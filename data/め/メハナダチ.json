    "definitions": [
      {
        "index": 1,
        "gloss": "(set of) facial features",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
