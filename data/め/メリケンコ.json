    "definitions": [
      {
        "index": 1,
        "gloss": "wheat flour",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "メリケン粉の袋のようなズボンの一方が、九十度だけ前方へ撥ね上った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は萱の葉の混んだ所から無理にのぞいて見ましたら二人ともメリケン粉の袋のようなものを小わきにかかえてその口の結び目を立ったまま解いているのでした。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云いながらあとからしなびたメリケン粉の袋をかついで来た黒服に云いました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺服の役人はメリケン粉のからふくろを手に団子のように捲きつけていましたが少し屈むようにしました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」二人はメリケン粉の袋を私たちに投げました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "メリケン粉の中へしのびこましたり、外の薬品にまぎれ込ましたり、一人、一人の腹に巻きつけたり。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さきに、砲台牌を要求したデボチンは、足の鎖を鳴らし、縛られた自由のきかない手を、ぱたぱたやって、メリケン粉の皮に豚肉を入れて蒸した包子をほしがった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君がどんなに頑張って、馬鈴薯とキャベジ、メリケン粉ぐらいを食っていようと、海岸ではあんまりたくさん魚がとれて困る。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は萱の葉の混んだ所から無理にのぞいて見ましたら二人ともメリケン粉の袋のやうなものを小わきにかゝへてその口の結び目を立ったまゝ解いてゐるのでした。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ひながらあとからしなびたメリケン粉の袋をかついで来た黒服に云ひました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺服の役人はメリケン粉のからふくろを手に団子のやうに捲きつけてゐましたが少し屈むやうにしました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニュウヨウクのメリケン粉株式会社から贈られたのだ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前はひよろひよろ痩せてゐたのが、久しぶりで去年逢つた時からメリケン粉の袋のやうに肥つてゐる男である。",
              "citation": {
                "source": "第十八號室より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもだぶ／＼ですから、はたの見る眼には、さぞ芝居の鼠がメリケン粉の箱に落ちたような形でしたろう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "足許にはメリケン粉のやうに白い踏んでも音のしない砂があつた。",
              "citation": {
                "source": "あかんぼの首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから Geld Suchen im Mehl というのは、洗面鉢へ盛ったメリケン粉の中へ顔を突っ込んで中へ隠してある銀貨を口で捜して取り出すのである。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はもう一度厳重な身体検査を受け、外套と帽子と上衣とは参考品として没収され、一言も言わずに、まるでメリケン粉の袋か何かのように荒々しく留置所へ入れられた。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの百姓も、どの百姓も、入つてくるときはメリケン粉の中から出て來た人のやうに身體中眞白だつた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしは、メリケン粉袋のような身体を同じところに横えたまま、ただ夫がするのを待つより外なかった。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が○○獣の生擒の話で夢中になっているとき、二人の傍には、いつ何処から現れたかしらないが、例の黒眼鏡の断髪の外国婦人が忍びよって、そこらに散らかっている雪のように白い木屑を、せっせと掃きあつめてはメリケン粉袋にぎゅうぎゅうつめこんでいた。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とタフトはメリケン粉の粉袋のやうに、はち切れさうな顔を歪めて笑つた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さほ子はメリケン粉をこねながら、千代が、来た時と同じ華やかなメリンス羽織を着ているのを認めた。",
              "citation": {
                "source": "或る日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その満足をひとに強要し得る時代の柄のわるさとして反映する代用食のようなものは実際上のこころみなのだから、炭の不足、砂糖、メリケン粉の不足な現在を考慮してはじめて実質な意味を持つのであると思う。",
              "citation": {
                "source": "私の感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　人間の死体をバラバラにした事件や、またコマ切れにした事件というのは聞いたことがあるがこの話のように、吹けば飛ぶ位のメリケン粉か灰のようにするという事件は未だ耳にしたことがなかった。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか、アメリカから買い込んだメリケン粉袋が埠頭に積んであるというデマさえ飛んだ。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（これはメリケン粉だな。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡麻油などをつかう並みの天麩羅とちがって黄檗のは古い種油と鼠の糞のようなボトボトの堅いメリケン粉を用いる。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "底の方の凍り固まった、上ッ面のフワフワしたメリケン粉のようにゆらめく雪を、村の人々が踏み固めて行った痕跡が、早くも凍りかかっている上から踏み破り踏み破り蹴散らし蹴散らし急いで行くので、狭い絶壁の上の岨道を行くのに、さほどの困難は感じなかった。",
              "citation": {
                "source": "眼を開く",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
