  {
    "uuid": "51e2174d-d223-5a57-baf8-4310675dc177",
    "entry": "明度",
    "reading": {
      "primary": "めいど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
