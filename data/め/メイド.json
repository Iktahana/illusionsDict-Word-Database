      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "brightness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それが、空の光の照明度がある限界値に達すると、多分細胞組織内の水圧の高くなるためであろう、螺旋状の縮みが伸びて、するすると一度にほごれ拡がるものと見える。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "溝の底の汚泥を掴み出すのは世態に通じたもののすることでは無い、と天明度の洒落者の山東京伝は曰ったが、秀吉も流石に洒落者だ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると氣層は其透明度を増して、特に雨のあとなど一層さうである。",
              "citation": {
                "source": "天文と俳句",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、空の光の照明度がある限界値に達すると、たぶん細胞組織内の水圧の高くなるためであろう。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この軽さ、この透明度から見て、水に溶けるのではないかな。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活といふものに対して、随分と凝つた眼の所有者であり、淡々と叙してゐる中に、実にも鋭敏なる神経が隈なく行き渡り、理解力の典雅さに充ち、透明度も深く、そして視野計の狂ひなどは何処にも見出せなかつた。",
              "citation": {
                "source": "月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私小説にしろ客観体のものにしろ要は作家の情感に於ける燃焼の透明度に帰着するものであらうが、豊島与志雄氏の「人の小屋」（文藝春秋）や広津和郎氏の「青空」（改造）など、客観的私的の問題もなくそれぞれ読み応えが深かつた。",
              "citation": {
                "source": "月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "珊瑚礁の上に乘つてゐる海水はさらに鮮明度を増す。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮮明度、速力ナドニ関シテハモチロン、資材ノウエカラ労力ノウエカラ大変ナ経済ダト思ウガコノ種ノコトハ私ニハヨクワカラナイ。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三に画面の大きさや鮮明度など我々の観賞欲を満足せしめる諸条件において館と家庭では著しい径庭があることが予想される。",
              "citation": {
                "source": "映画の普及力とは",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "磁器は透明度があり釉藥があつて水を吸はない、九谷、伊萬里、支那の染付、青磁等種類は多い。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七官青磁といふのは天龍寺手よりもキメが荒いやうな感じのするもので、透明度はあるが青味が少し玄味がかつてゐる、釉面に氷裂がある。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は小笠原の母島から父島へかけて、三週間ばかり磯釣をした時に、透明度の高い海底をよく覗いて、三十二種の珍らしい魚を釣ったが、珊瑚礁に附いている魚は、実に静かで、まるで水中の牧場のようである。",
              "citation": {
                "source": "荒磯の興味",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十×年八月八日　室内温度、湿度、照明度すべて異状なし　配給も正確なり　本日は、地下千メートルを征服し、現在われわれの棲んでいるこの極楽地下街建設の満三ヶ年の記念日であるので、ラジオは朝から、じゃんじゃんと楽しい音楽を送ってくる。",
              "citation": {
                "source": "今昔ばなし抱合兵団",
                "author": "――金博士シリーズ・４――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺の湖心の深さ、三百五十メートルほどもあり、水の透明度は高く、しかも美しい藍色なのだ。",
              "citation": {
                "source": "山上湖",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮮明度はさまざまで、全身がくっきり浮き出すこともあれば、ただぼんやりした薄ら影がさすこともある。",
              "citation": {
                "source": "蔵の二階",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に今の舞台の照明度は相当明るいから、随分思い切った色目の隈取りでないと、飛ぶものではないでしょうか。",
              "citation": {
                "source": "役者の顔",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界中の学者、政治家などから、色々な項目について「文明度の点数」をつけて貰って、それを地図の上に書き込んで作ったものである。",
              "citation": {
                "source": "清々しさの研究の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海水はそのためにいくぶん濁り気味で、前日の透明度十一メートルが、今日は六メートルに減っている。",
              "citation": {
                "source": "海底の散歩",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海水は濁っているので、透明度は悪い。",
              "citation": {
                "source": "海底の散歩",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この海は雨のせいもあって水の透明度が低い。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある色の色合いは、明度や彩度を変更しても同じ色相を保つが、その他の変更を生じさせれば、同じ色相ではなくなる。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときは古い人はとられ（四人）あずま、かめいどから応援　労救の人のおくさん。",
              "citation": {
                "source": "「乳房」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「千ちゃん、ぼくたちは、めいどへ来たんだ。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
