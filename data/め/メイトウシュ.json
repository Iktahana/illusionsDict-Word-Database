        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いわゆるスモークボールを飛ばして打者を眩惑する名投手グローブの投球の秘術もやはり主として手首にあるという説を近ごろある人から聞いた。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は、常に無邪気そうな、しかし時々気むずかしそうな、名投手の球勢変化を思わせるような抑揚のある態度で夫人に対しているのであった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一人の名投手が現われればいつでも甲子園へ行けるだけの実力は常にある。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが一人の名投手がめったに現われてくれないのである。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の名投手というものは結局カネやタイコで探す性質のものらしい。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、その恋人が、職業野球チェスター軍の名投手｜大鹿だという。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
