        "examples": {
          "standard": [
            {
              "text": "命題論理学においては、個々の命題の内容よりもその論理的な構造が重視される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "哲学専攻の学生たちは、命題論理学の体系を用いて推論の妥当性を検証している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "命題論理学の歴史を辿ると、古代ギリシャのアリストテレスまで遡ることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "カリキュラムで命題論理学の基礎を取り扱う時期になって、桜井はこのテーマならエレクトロニクスに対する松本の興味と数学の授業への関心を結びつけてくれるのではないかと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターの論理回路は、命題論理学の演算をエレクトロニクスの素子によって実行させたものである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ならばコンピューターをきっかけとすれば、松本は学校の命題論理学の授業に興味を持つのではないか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
