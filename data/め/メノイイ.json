    "definitions": [
      {
        "index": 1,
        "gloss": "having good eyesight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ことしは四月にはいってから毎日のように降ったり曇ったりばかりしていて、したがって寒いので少しも春らしい気持をしなかったが、きょうはしばらく目のいい天気だ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしが立つ」「夜は、目のいいわかい者の方がいい。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおお使いに持たせての練香水……早速使ってみましたが、なるほど仰るとおり効き目のいいのにはお世辞でなく驚きました。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも目のいい者のことばでは、あの高い、登りようもない上でのんきに書物を見ているという。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャフェでは給仕男たちが眺めのいい窓の卓子へ集まってゆっくり晩飯を食べていた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が昔現在の家を建てたとき一番日当りがよくて庭の眺めのいい室を応接間にしたら、ある口の悪い奥さんから「たいそう御客様本位ですね」と云って、底に一抹の軽い非難を含んだような讃辞を頂戴したことがあった。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこんな電気屋が栄え、こんな呼び鈴がよく売れるとすると、その責任の半分ぐらいは、あまりにおとなしくあきらめのいい使用者の側にもありはしまいか。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五平　諦めのいい事もあるまいが、まあ、まあ、そう思って無理に諦めるより外はあるまいよ。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "諦めのいい幽霊と言わなければならない。",
              "citation": {
                "source": "妖異むだ言",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩に背負つた風呂敷包には、二宮金次郎の道徳のやうな、格安で、加之に「お為めのいい」石鹸や白粉がごたごた包まれてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お為めのいい」石鹸は眇のやうな眼附で、利いた風な事を喋舌る大学生の顔を見てゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校の教室や、寄宿舎は、どれも眺めのいい窓を持っていましたのに、図書室だけは陰気で、運動具の亜鈴や、鉄の輪のようなものまで置いてありましたので、何時行ってもこの図書室は閑散でした。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏がだんだんひどくなってきますと、珍らしいくらいにあきらめのいい年寄りもたまには愚痴も小言もいいます。",
              "citation": {
                "source": "成長が生んだ私の恋愛破綻",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あきらめのいい人たちは初めから廊下の窓ぎはに竝んで立つてゐた。",
              "citation": {
                "source": "大戰脱出記",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に俳優として熱心であつた如く、兵士としても戦場にあつて、例の負けず嫌ひの一本気であきらめのいい、江戸ツ子｜気質を充分に発揮して、大いに奮闘しただらう姿がホウフツと想像出来る。",
              "citation": {
                "source": "戦死した友田恭助氏",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸太郎　どうもお前の諦めのいいのには驚かされる。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り諦めのいいことはまず誰にも負けないし――といってこれは余り自慢になる性格じゃないが――しょっちゅう早合点をして頭を掻いてばかりいるのだ。",
              "citation": {
                "source": "宇宙尖兵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私は当然拒絶を承知した諦めのいい集金人のように、その頃私は仏教を勉強する堕落生であったが、さながら魚のように機嫌よく街を泳いで埃を浴びていた。",
              "citation": {
                "source": "母",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、あまり、あきらめのいいのを、かえってものたりなくさえ感じました。",
              "citation": {
                "source": "時計と窓の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "つばめのいいと思った家は、ほんとうにいい家であったから、巣をつくるのは、無理もなかったのでしたが、もう一つこれには、町の人が、なぜこんなにつばめを愛するかという話があります。",
              "citation": {
                "source": "南方物語",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事にも諦らめのいい女々しい事は一度も言われたことのない母堂も今外から戻って来た余を見ると急に泣き出された。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこにまだ残るためのいい機会でした。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもお社を見物で大分足が痛んだので湖畔へ出たら、お母さんもさすがに泊っていいお気持になり、又湖の眺めのいい宿がとれたので、早速一風呂二人一緒にあびて、一泊に決定。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああら、眺めのいいこと、ちょっとォ……」　てすりのそばからだれにともなくふりかえった小ツルは、きゅうに口をおさえてあとをいわなかった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "諦めのいい家庭の二三は既にそれぞれ他へ住居を契約して、長屋からして泣く泣く移転したくらいである。",
              "citation": {
                "source": "長屋天一坊",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "波乗りのためのいい波の出来る場所が、沖にはいくつもあった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このきめのいい肌の香も、もう他の男性に盗まれた後のものかとつい思うのだった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを棒に振って、絞首台に上る程、あきらめのいい男でもあるまい。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この辺で、一服やるとしましょうか」　すると、六部がソッと袖をひいて、道ばたにいる侍を目で知らせながら、さりげない調子で、「いや、もう一息まいりましょう」「そうですか、じゃあ……」「下りへかかる岐れ路に、たしか、眺めのいい場所があった筈で……」スタスタと通り過ぎてしまった。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "眺めのいい所という意味と、源次をひっぱたくにはいいお白洲だという二様の意味にとれる。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "剣山の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
