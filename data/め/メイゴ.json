[
  {
    "uuid": "fcd72b2e-b843-598b-aa15-94a21532341b",
    "entry": "姪御",
    "reading": {
      "primary": "めいご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(another person's) niece",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それが、貴方が御兄弟や姪御さんに尽すべき義務です。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯行は男爵の姪御のモニカ・シユワルツ孃によつて三十分ほど前に發見されたんでありますが、裏側の部屋にも同樣な手口で殺害された死體がございます。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お師匠さまのお姪御さんとやらが、三味線のじょうずなかたで、近所のお子ども衆にお手ほどきしているとかいうことでござりました」　がぜん事件の秘密はここに一道の光明をもたらして、いよいよ熊仲和尚の身辺はいっそう濃厚な疑惑の雲に包まれだしたものでしたから、きくや同時に、右門の口からは鋭い声が発せられました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちくしょうッ、ふざけたことぬかしやがって、姪御さんが聞いてあきれらあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラセンシオー殿、同じく可憐なる姪御達。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "大庭先生の姪御さんは」「ええ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "長平さんの姪御さんだけのことはあるよ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は承知をしてその百兩の金を受取りましたが、それを見て居たのは姪御のお道さんだけ――」「――」「私はフト、氣が變りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "權八の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "お二人の姪御さんは、負けず劣らず綺麗ですが、御主人は姉の子だからといふので、お縫さんの方を若旦那に娶合はせ、三國屋の跡取にするおつもりだつたと思ひます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "二人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は承知をしてその百両の金を受取りましたが、それを見ていたのは姪御のお道さんだけ――」「…………」「私はフト、気が変りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "権八の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれが本當の姪御さんでなかつたら、をかしいと思はれたかもわかりません」　と言つたことが、平次の心に深く刻み付けられました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鍵の穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エー、此方は殿様のお姪御様で瑛子様と仰しゃいます。",
              "citation": {
                "source": "死の予告",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたきの人質をさえゆるしておやりになりながら、御夫婦と申してもみじかい御えんでござりましたのに、だいおんのある先君のいもうと御と姪御とを死出のみちづれになさるおつもりか。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このおかたは総見院さまのおんむすめ御でいらっしゃいまして、小谷どのには姪御におなりなされ、やはりお顔だちが似ていらしったと申しますから、おおかたそれゆえでござりましたろうか。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、ミラノ公はむしろローマ皇帝＊の方に深い関係があり、特に皇帝の姪御で現在はロレーヌ公の未亡人となっておられる、あのデンマーク王の御息女と御婚約中でもあったから、我々と少しでも交際があるように見られては大変御都合が悪かったのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それはさておき、モートン氏は金持ちでしたから、全財産をあなたに残されたと思いますが」「そうよ、どうぞお続けになって」「むかし、モートン氏は姪御さんに財産を残そうとされたとか」　ウェイクフィールド叔母が冷たくコックリ。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも外交官の姪御さんだから、沈黙の価値をご存知ですね」「外交官の姪として大いに学びました」　とジェシが冷静に答えた。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "姪御さんはお気の毒に」「おや、姪がどうしたのですか。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの姪御さんが全てを話されたのなら、認めなくては」　メリヘイブン閣下が続けた。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "姪御さんが言ったのは事実です。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には「奥さんの御めいごさん」なんかとおどろいて頓死しそうな間ぬけな呼び方をする男さえあった。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
