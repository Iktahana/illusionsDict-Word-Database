    "definitions": [
      {
        "index": 1,
        "gloss": "to be dizzy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これは畢竟量を見るに急なために質を見る目がくらむのであり、雑魚を数えて呑舟の魚を取りのがすのである。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠い昔に建てられて、目がくらむほど真っ白な大理石でできていました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見た源氏は目がくらむような悲しみを覚えて煙になる最後までも自分がついていたいという気になったのであるが、「あなた様はさっそく二条の院へお帰りなさいませ。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "目がくらむような大閃光とともに、大地が海のようにゆらいだ。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして下を見おろすと目がくらむほどだ。",
              "citation": {
                "source": "鹽原日記",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "仄暗い廊下のようなところに突然、目がくらむような隙間があった。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "仄暗い廊下のやうなところに突然、目がくらむやうな隙間があつた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても悲しい色でね、目がくらむ気がします。",
              "citation": {
                "source": "源氏物語",
                "author": "柏木",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝夕に読誦される阿弥陀経は支那の紙ではもろくていかがかと思召され、紙屋川の人をお呼び寄せになり特にお漉かせになった紙へ、この春ごろから熱心に書いておいでになったこの経巻は、片端を遠く見てさえ目がくらむ気のされるものであった。",
              "citation": {
                "source": "源氏物語",
                "author": "鈴虫",
                "note": "青空文庫"
              }
            },
            {
              "text": "木端ぶきの書斎の屋根では、頭がへこむほどひどい音をたてて居るし、雨だれも滝の様で見て居ると目がくらむ。",
              "citation": {
                "source": "無題（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "裕福なおれは、彼女の屍体から発見された数フランの金なんかに目がくらむわけはないのだ。",
              "citation": {
                "source": "ピストルの蠱惑",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋品店の四月の窓飾りは、金と銀と桜の花で目がくらむなり。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "以来私は絵の道具を担いで坂路を登ることを大変｜厭がるようになった、坂路を見ると目がくらむ心地が今もなおするのである。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "――○――　自分の愛するものに、絶望や嫌厭や、否定の言葉を放つとき、二人が苦しんで居るという意識で、彼女は目がくらむようになり、夢中になって、尚一層苦々しい激しい、ぞっとするような言葉、「いや」とか「きらい」とか「思い違い」という言葉を洩す。",
              "citation": {
                "source": "日記",
                "author": "一九二〇年（大正九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでもう目がくらむ！",
              "citation": {
                "source": "金談にからまる詩的要素の神秘性に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "目がくらむ」　ふらふらとして、らんかんにしがみついた。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダイヤモンドに目がくらむのは貫一お宮の昔からの話だぜ。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "高座で喋りながら逆上するようでは芸術家の資格がないと心得ていても、税務署に話がふれると、目がくらむのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎さんは、胸がわく／＼として目がくらむやうな気がしました。",
              "citation": {
                "source": "身代り",
                "author": "土田耕平",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに僕は、あいにく午年生れで、高いところへ登れば、たちまち目がくらむようにできているんだ。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "アルプスの潜水夫　――モンブラン登山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんですか、あんなにお母さんが心配していらっしゃるものですから、自分まで目がくらむような気がしますよ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "２．失敗をすると世の中を見る目ができるが、成功するとその目がくらむ。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕もきっとくるから、そして海の底の都には、こんな真珠や、紫水晶や、さんごや、めのうなどが、ごろごろころがっていて、建物なんか、みんなこれでできているから、電気燈がつくと、いつでも町じゅうがイルミネーションをしたようで、はじめてきたものは目がくらむかもしれないよ。",
              "citation": {
                "source": "海の少年",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんながこれを鉄扇鉄扇と云うが、これは甲割と称えて鉄扇とはまるで別物で……」「へえ、何にしたものでございましょう」「兜を割るので、――敵の目がくらむ所を撃ちとったものでがす。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "えい、えい、と武士たちは忍び声で馬に力をつけながら馬を静かに落して行くのだが、下を見れば目がくらむ。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の届くかぎりどこも目がくらむような白色であった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光線は白い雪の上に落ちて、まえの晩あれほどさびしくどんよりしていた森が、きょうは目がくらむほどのまばゆさをもってかがやき始めた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "光度は発光地点に近い所では、目がくらむほどであったようである。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は目がくらむほど吃驚して、指定された柱のところへ行って棒立ちになった。",
              "citation": {
                "source": "幼年時代",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは目がくらむような気がしていた。",
              "citation": {
                "source": "はやい秋",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
