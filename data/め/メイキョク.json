  {
    "uuid": "bd9e0317-2738-5bc8-9e20-7f97e7180ad9",
    "entry": "名曲",
    "reading": {
      "primary": "めいきょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
