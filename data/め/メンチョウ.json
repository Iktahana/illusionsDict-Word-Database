        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "聞けば母の腫物は面疔だと申すのでございますから。",
              "citation": {
                "source": "雛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "……もとより面疔も手術さへ出来れば、恐しい病気ではございますまい。",
              "citation": {
                "source": "雛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十二日にとめやのきぬやが面疔で死んだ、と云う知せである。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大貫は面疔、恒川は慢性中耳炎で、孰方も急劇な死に方だつた）しかし大貫のことは、前に何かに書いたこともあり、私よりは岡本かの子女史の方が適任であらうと思ふから、茲には略する。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「面疔は一刻を争うと申しますからね。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金平ちゃんの家には、しちめんちょうを二わかっていて、どうかすると、庭に出してあることがありました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しちめんちょうにまで、聞こえなくてもよかったからです。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "モコウが倹約に倹約をかさねてたくわえたかも、しちめんちょうの肉、塩づけのさかな、サクラ号から持ってきたかんづめ類も、今後どれだけのあいだつづくか、はかることができない。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはしちめんちょう、野がん、ほろほろちょう、きじの類をとらえしだいにはなちがいにした。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "病は、不治のめんちょうだといわれ、いまや重態だという者すらある。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
