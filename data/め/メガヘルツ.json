        "examples": {
          "standard": [
            {
              "text": "ラジオ放送の周波数は、通常メガヘルツ単位で表示される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この無線機器は、数メガヘルツの周波数帯を使用する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "コンピューターのCPUクロック周波数は、ギガヘルツ単位が主流だが、昔はメガヘルツだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "パーソナルメディアに潜入していじってきた印象では、16メガヘルツの３８６ＳＸ上でかなり軽快に動く。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡＭＤは一九九一年九月、イギリスに本社を置くエデン・グループがペン・ベースのＶＰｉ３８６に二十五メガヘルツ版のＡｍ３８６ＳＸＬを採用したと発表した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十メガヘルツ版の３８６ＳＸに変えて二十五メガヘルツ版のＡＭ３８６ＳＬを採用したことで、ＶＰｉ３８６の性能は二十五パーセント上がり、電池寿命は十五パーセント長くなったという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
