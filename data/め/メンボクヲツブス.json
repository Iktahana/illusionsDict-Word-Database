          "literary": [
            {
              "text": "だが、内匠頭は、わしの面目を潰すようなことをしている。",
              "citation": {
                "source": "吉良上野の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘を衝きたくないからと云って、相手の面目を潰すには及ばないのである。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これまで水車小屋の主は、経川の作品を売却する使いを再参自ら申出て、街へ赴くとそれを抵当にしてあっちこっちの茶屋や酒場で遊蕩に耽っては、経川に面目を潰すのが例だったが、相変らずさようなことに身を持ち崩していると見える。",
              "citation": {
                "source": "ゼーロン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
