        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　滅相なと徳兵衛「結構で御座ります」　なりひらが、Ｔ「後ほど屋敷へ持参致せ」　と言って立ち上る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿様が「分らん奴だＴ「其の方が、誰かに　斬られて死ぬのじゃ」　あの拙者が、と老臣「メッ、滅相も無い」　殿様が「イヤイヤＴ「心配致すな　其の方の娘に　立派な仇討を　させてやる」　老臣も呆れ果てた。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いて求めれば唯有一乗諸法寂滅相という言葉だけであった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、滅相な、お世辞ではございませんが、貴女方に誉められます処を、亡くなった亭主に聞かしてやりとうございます。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「滅相な、何の貴女。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "千助、頸許からぞく／＼しながら、「滅相な、隱藝など、へゝゝ、就きましてでござります。",
              "citation": {
                "source": "片しぐれ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元二、頸許からぞく／＼、「滅相な、隱藝など、へゝゝ、其に就きましてでござります。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「滅相な、お前様、この湯の谷の神様が使わっしゃる、白い烏が守ればといって、若い女が、どうして滝まで行かれますものか。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒物屋から婆さんが私の姿を見ると、駆けて出て、取次いで、その花のことについて相談をされたのは私ばかり、はじめは滅相なと思ったが、情を察すると無理はないので、泣の涙で合点しました。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、滅相な……奥方様、唯今ではござりません。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大助は驚きて、「ええ、若様滅相な。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「滅相なことを謂わあ、飛んでもねえ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「滅相なことをおっしゃる、飛んでもない、こんな者をお邸へ入れますのは、疫病神を背負込むと同じです。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お宝……ま、滅相な。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「滅相なことをおっしゃりまし。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と亭主驚いた眉を動かし、「滅相な。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房が竊と睨んで、「滅相な、あの、言いなさる。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんた所が焼けたので、雑誌が手にはいらんようになったよ」　すると三ちゃんは、滅相もないという口つきを見せて、「何言うたはりまんねん。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしや滅相草臥れた。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代　あれ滅相な、滅相なこと。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真顔に、熟と肩を細く、膝頭に手を置いて、「滅相もない事を。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "序に火打袋も』幸子坊円『滅相な。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅相もない』源右衛門（妙な顔して）『なに。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「滅相もない、お女中様、そりゃおよしなさいませ。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれ滅相な、其の方は、まあ武士の女房に」　宅悦はいやしい笑いかたをした。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅相に大きな甜瓜があつたので、手拭に包んで比叡山へ擔ぎ上げたことがある。",
              "citation": {
                "source": "旅行に就いて",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いえ、滅相もない！",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「滅相もございません。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "外に出ようなんて滅相もない。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月　――めっそうな。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
