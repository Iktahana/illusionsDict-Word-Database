        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "町にで、記念のために買った本や、メキシカンの手製の元始的な壺などを並べた中で、する生活。",
              "citation": {
                "source": "無題（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごく下層階級のメキシカンなど、例えば農場の日傭労働者たちの間では、或いはあるのかもしれないが、日本でいう普通の労働者の家庭でも、ぼろをつづくるというようなことは、例外的のことである。",
              "citation": {
                "source": "捨てる文化",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界中からの移民の寄合世帯で、しかも黒人やメキシカンを三割近くももっている。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "農場の片隅に黒い箱型のシボレーがあって、その前でメキシカンの子供たちが遊んでいた。",
              "citation": {
                "source": "コロラド通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、当時、住民の大多数を占めていたらしいメキシカンやインディアンを手懐け、教え、毎日生命を危険に曝して、ところどころに修道院を建てた。",
              "citation": {
                "source": "南路",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "メキシカンのように首の太い、栗いろの髪の縮れたずんぐりとした男だった。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロジータという名前のメキシコ料理店の、メキシカン・サラダとサングリア。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼食＝マカロニ・メキシカン、車海老のカレーライス。",
              "citation": {
                "source": "富士屋ホテル",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "マカロニ・メキシカン、プローンのライスカレー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
