    "definitions": [
      {
        "index": 1,
        "gloss": "visiting or office hours",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
