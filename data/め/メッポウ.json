[
  {
    "uuid": "ab37f8a7-8896-54d0-8c92-a45073b0e29b",
    "entry": "滅法",
    "reading": {
      "primary": "めっぽう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
