    "definitions": [
      {
        "index": 1,
        "gloss": "metre (unit of length)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
