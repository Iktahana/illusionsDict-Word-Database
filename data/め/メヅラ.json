        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だから、お曾與殺しの下手人が擧らなきや、神田中の綺麗な娘が、種切れになると、大眞目面で思ひ込んでやがるから世話はない」　かう言つて、ペツペツと唾を吐くのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "許嫁の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "後見役の仏頂寺はじめ三人は、やれやれと目面でけしかける。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女等がかざしの玉の赤玉に似たるいちごを採りつゝありく奧山の道のへに咲く草花をうらめづらしみ見せまくもとなおぼつかなき歌なり。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しこんな稼業のものにはめづらしい正直な淡白した江戸兒風の男で、御用を嵩に着て弱い者を窘めるなどといふ惡い噂は曾て聞えたことがなかつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、今度のイーハトブの旅行中で、私は大へんめづらしいものを見ました。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く平太の大トランクがめづらしかったのです。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたらさっきから仕度ができてめづらしさうにこの新らしい農夫の近くに立ってそのやうすを見てゐた子供の百姓が俄かにくすりと笑ひました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日いっぱい葡萄ばかり見て、葡萄ばかりとって、葡萄ばかり袋へつめこみながら、それで葡萄がめづらしいと云ふのなら、却って耕平がいけないのです。",
              "citation": {
                "source": "葡萄水",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども堕ちるひとのことや又溺れながらその苦い鹹水を一心に呑みほさうとするひとたちのはなしを聞いても今のあなたにはたゞある愚かな人たちのあはれなはなし或は少しめづらしいことにだけ聞くでせう。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ところで、前段にいつた通り、この日はめづらしく快晴した。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、今日とは違つて、その昔は一文の飴を買ふのもめづらしくないが、所詮一文は一文であるから、それを売ると売らないとが一日の収入の上、左ほどの影響のないのは、亭主にもよく判つてゐたが、彼はその女の来ないうちに店を仕舞ふ気になれなかつた。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "△今日はめづらしくコヤトといふ方言を聞いた、コヤトは餓鬼とおなじく、子供に対する親愛と軽蔑とを意味する言葉である、ホイトといふ方言のやうにおもしろいと思ふ。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝飯のとき、庵の料理はまづいなあとめづらしく思つた、何しろ昨夜の今朝だから。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "めづらしや女性来訪、Ｆ屋のおばさんとちいちやん、水仙もらひに寄つたのです、紅茶を御馳走する。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "めづらしき、さたを、きく。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしわ、めづらしきつみを、たんと、つくりたなあ。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふるへる　めづらしい野路のくさばなおもたく雨にぬれた空氣の中にひろがるひとつの音色なやましき女のなきごゑはそこにもきこえて春はしつとりとふくらんでくるやうだ。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな或る日、鳥右さんはめづらしくおむすびをつくつて腰にぶらさげました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "克巳は、からうすをめづらしがつて、米をつかせてくれとせがみました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかお涌も子供達に交つて「蝙蝠来い」と喚きながら今更めづらしく毎夜の空の友を目で追つてゐると、蝙蝠も今日の昼に水替へした井戸の上へ、ひら／＼飛び近づき、井戸の口を覗き込んではまた斜に外れ上るやうに見える。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体が、さういふふうな女でもあるし、京都生れで、辛抱強いのに生れの性といふ考へが、こつちの頭にあるものだから、ただかういふ風に苦労をするやうにできて来た女が老婆になつても、根よくことこと働いて居る家具のやうで、その点が、めづらしかつたのだ。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分で自分を葬る気持は、生涯何度も繰返したので、一向めづらしいことではない。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、僧正さまが御坐禅の余暇に御自身でお書きになつた御本だとか、めづらしい本をお書きになつたものだと、けげんさうにお首を傾けて居られたお方もございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりのめづらしければ起きむとする夜着の肩、ながく柔かにおさへたまへり。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さちよが、四年生の秋、父はさちよのコスモスの写生に、めづらしく「優」をくれた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」助七は、めづらしくきびしい顔つきで、さう言つた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつき程は彼も新妻をめづらしがつた。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してこの種の情調の中に、凡てを破壞する現代文明の波にも破られずに、尚能く昔の面影を止むる祭典及び其他の年中行事を殘して居ると云ふ事はめづらしい事である。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清長の珍らしい浴泉圖は二枚あつて、その一枚がドガアの手に入つてゐると云ふ事は上田柳村先生の「渦卷」で承知してめづらしい事と思つた。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "露臺の欄にもたれてもの思ふうたびとの眼のやわらかさかなあはれにも宴あらけてめづらしき異國の酒の香のみ殘れるゆふぐれの河岸にただずみ水を見る背廣の人よ何を思へる諸聲の流行の小唄身にぞ染む船の汽笛の玻璃に鳴る時いまも汝は廣重の繪をながめつゝ隅田川をば戀しとおもふや（明治43・９・23「東京朝日新聞」）",
              "citation": {
                "source": "吉井君の歌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
