            {
              "text": "昼も夜も目が離せない。",
              "citation": {
                "source": "オランウータン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が来られると面白いのだが……ナニ今夜はオリオン星座から目が離せないって。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あぶなくて目が離せないんですよ」　親ゆずりの性質かしらと、これは兄貴に言った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちらちら奥部屋を見ているさまは、あたかも目が離せないかのようだ。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "○じつは、いずれも真説らしく、夫人も少しも目が離せないといった次第だが、小康を得るとすぐ仕事場へいくというのを止める訳にもいかず、さて仕事場へ行ってもアルコールが切れているときは、構想も浮ばないとあっては、止むなき原罪でもあろうか。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            }
          ]
        }
