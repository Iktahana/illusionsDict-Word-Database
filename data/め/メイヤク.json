[
  {
    "uuid": "82b935d1-5a2d-5abd-b01f-0d0a9b603bd7",
    "entry": "盟約",
    "reading": {
      "primary": "めいやく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "oath",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "室生と私とはここに一つの盟約を立てた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "交通規則や国際間の盟約が履行されている間はまだまだ安心であろうが、そういうものが頼みにならない日がいつ何時来るかもしれない。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）姥　もし、お前様、その浅ましい人間でさえ、約束を堅く守って、五百年、七百年、盟約を忘れぬではござりませぬか。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "盟約を忘れませねばこそ、朝六つ暮六つ丑満つ、と三度の鐘を絶しませぬ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘さえなくば盟約もあるまい……皆が、あの鐘、取って落して、微塵になるまで砕いておしまい。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、開けない以上は、誓って、一冊の旅行案内といえども取出さない事を盟約する。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "又攘夷論者も、鎖国主義的攘夷論でなくて、国家の面目を傷け、国体の尊厳を毀り、国民の意気を挫く脅迫的開国、城下の盟約開国に悲憤慷慨する尊皇愛国的な攘夷論者であつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "交通規則や国際間の盟約が履行されている間はまだまだ安心であろうが、そういうものが頼みにならない日がいつなんどき来るかもしれない。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その盟約の調印を長びかせろとの指令が来た。",
              "citation": {
                "source": "人造人間殺害事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも彼はこの盟約を実行せざるによる、ふたたび兵を出して是を征服しようとしている。",
              "citation": {
                "source": "秀吉・家康二英雄の対南洋外交",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "卿の戀の盟約は内容の無い空誓文、なりゃこそ養育まうと誓うた戀をも殺してのけうと爲やるのぢゃ、卿の分別は姿や戀の飾ぢゃが、本體が善うないので不具となり、愚な卒が藥筐の火藥のやうに、扱ひかたがわるいので爆發し、我れと我が武器で身を滅す。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして分派の永続を保証すべき男女名取の盟約書を作らせようとした。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし勝四郎を領袖としている男名取らは、先ず師匠の怒が解けて、師匠と勝四郎との交が昔の如き和熟を見るに至るまでは、盟約書に調印することは出来ぬといった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時勝久は病める師匠の心を安んずるには、男女名取総員の盟約を完成するに若くはないと思って、師家と男名取らとの間に往来して調停に努力した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、カークとのあいだにかたい盟約が成りたった。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、二人のあいだに盟約が成りたった。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自ら、盟約を破って――有村は、いつもあれだ」　見張が呟いた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども我藩の使者は幕府の指令もあるから、この盟約は断然謝絶した。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「米連と欧弗同盟とは、戦闘開始の一歩前に、このどんでんがえしの盟約を行ったのである。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は一五三七年ヴェネティアに會合して、將來のヂェズイタ派運動の基礎となるべき盟約を結んだ。",
              "citation": {
                "source": "聖ロヨラ",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去の盟約、累代の情義の如きも、この大勢の赴く前では水の泡に異ならぬ。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲隠才蔵はサルトルとツル子が盟約を結んだ同志とは知らない。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがの半平も、ツル子がサルトルと盟約をむすんだ同志とは気がつかない。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "このＨ編輯長がなんとか組のなんとか氏とカンタン相てらしたと称し、兄弟の盟約をむすび、兄貴、わるいところがあったら、だまってオレの頭をなぐれ、などゝオイオイ泣き、こういう低脳がでゝくると、もうダメである。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは日本の政体の復古した事、帝自ら政権を執りたもう事、外国の交際も一切朝廷で引き受ける事は過日兵庫において布告したとおり相違のない旨を告げ、今回外国事務局を建てて交易通商一切の諸事件をことごとく取り扱うから、今日改めて朝廷守護の列藩と共に、各国公使に会同してこの盟約を定める旨を告げた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「兄上」「男らしく、盟約の義を貫いて……」「兄上」「それとも……それとも……思い切って……」　この時｜嗄れた女の声が、どこからともなく聞こえて来た。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等に優りし羅馬の軍は、盟約不賛の諸国をば、その民等をば攻め立てた。",
              "citation": {
                "source": "ランボオ詩集≪学校時代の詩≫",
                "author": "VERS DE COLLEGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――という欺誑と譎詐に満ちた休戦状でありまた誠に虫のいい盟約の申し込みでもあった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
