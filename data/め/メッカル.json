        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「や、何か目っかるよ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな処に僧正さまもめっかるめえからな。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "めっかると面倒だぞ。",
              "citation": {
                "source": "土地",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "天秤棒をキシませながら、ふれ声をあげて、フト屋敷の角をまがると、私と同じ学帽をかぶった同級生たちが四五人、生垣のそばで、独楽などをまわして遊んでいるのがめっかる。",
              "citation": {
                "source": "こんにゃく売り",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこでもバンドはここんところは目がまわるようにいそがしいし、どうせ、そんなにすぐ僕にもドラマーがめっかるわけじゃないんだ。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、門のすき間から光がもれていぬにめっかるかも知れないからな。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな小僧っ児がめっかるもんか。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "人穴城がなくなったと思えば、こんないい棲家がたちまちめっかる。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
