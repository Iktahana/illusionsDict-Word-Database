[
  {
    "uuid": "1faaa747-7634-514a-93c2-1d27b1e905cd",
    "entry": "明眸",
    "reading": {
      "primary": "めいぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bright or beautiful eyes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "』と明眸に露を帶びての諫言、私は實に殘念であつたが其儘思ひ止つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と明眸に露を湛えて天を仰いだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、明眸に凛乎たる光を放つと、聽く日出雄少年は、プイと躍立つて。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は明眸に露を帶びて『可愛相にねえ貴方。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、語り終つて、春枝夫人は明眸一轉※かの空を仰いだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "引添つて、手拭を吉原かぶりで、艷な蹴出しの褄端折をした、前髮のかゝり、鬢のおくれ毛、明眸皓齒の婦人がある。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　明眸の左右に樹立が分れて、一条の大道、炎天の下に展けつつ、日盛の町の大路が望まれて、煉瓦造の避雷針、古い白壁、寺の塔など睫を擽る中に、行交う人は点々と蝙蝠のごとく、電車は光りながら山椒魚の這うのに似ている。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とばかり吐息とともにいったのであるが、言外おのずからその明眸の届くべき大審院の椅子の周囲、西北三里以内に、かかる不平を差置くに忍びざる意気があって露れた。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　明眸の左右に樹立が分れて、一条の大道、炎天の下に展けつゝ、日盛の町の大路が望まれて、煉瓦造の避雷針、古い白壁、寺の塔など睫を擽る中に、行交ふ人は点々と蝙蝠の如く、電車は光りながら山椒魚の這ふのに似て居る。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　振り向いて見ると、月光を浴びて明眸皓歯、二十ばかりの麗人がにっこり笑っている。",
              "citation": {
                "source": "竹青",
                "author": "――新曲聊斎志異――",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠してしまうには惜しいくらいな明眸皓歯のりりしい男まえを深々と天蓋におおって、間道を今度こそは板橋口へ一刻を争うように足を早めました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "山海の珍味を尽し、美を尽し、善を尽し、出るに自動車あり、居るに明眸皓歯あり、面白い書籍あり、心を蕩かす賭博あり、飽食し、暖衣し、富貴あり、名誉あり、一の他の不満不平あるなくして、それでも猶ほ魂に満されざる声を聞くのは何の故か。",
              "citation": {
                "source": "ある僧の奇蹟",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればかの明眸の女詩人も、この短髪の老画伯も、その無声の詩と有声の画とに彷弗たらしめし所謂支那は、寧ろ彼等が白日夢裡に逍遙遊を恣にしたる別乾坤なりと称すべきか。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "明眸絳脣、香肌白き事｜脂の如し。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "明眸皓歯とはまさにこの君の御事と思わせられた。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に一人、清く痩せて、脊のすらりとした三十歳ばかりの、色の白い、明眸の道士が芥川龍之介さんの風※を聯想させるのであつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから西洋の美人の形容詞には、東西共通の、沈魚落雁、閉月羞花とか、花顔柳腰明眸皓歯とかといふ美人に共通の資格の外に、「動」といふものが美人の美人たる資格の内に含まれてゐるのである。",
              "citation": {
                "source": "東西ほくろ考",
                "author": "堀口九萬一",
                "note": "青空文庫"
              }
            },
            {
              "text": "明子の明眸、猶六年以前の如くなる可きや否や。",
              "citation": {
                "source": "開化の殺人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車の窓より洩るる燈光に、明子の明眸の更に美しかりしは、殆予をして傍に子爵あるを忘れしめぬ。",
              "citation": {
                "source": "開化の殺人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その明眸は笑っている時さえ、いつも長い睫毛のかげにもの悲しい光りをやどしている。",
              "citation": {
                "source": "金将軍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "色彩の濃艶、声調の婉柔は泣菫氏が擅長なるものから、ただ詩中明眸皓歯の人のおもかげ薄きが、情熱の麗句にふさはぬこゝちす。",
              "citation": {
                "source": "『行く春』を読む",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は禿頭にして肥満すること豚児の如く愚眛の相を漂はし、その友人は黒髪明眸の美青年なりき、と。",
              "citation": {
                "source": "風博士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒髪明眸なる友人こそ即ち余である。",
              "citation": {
                "source": "風博士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌子式多津以後の高座の明眸は、大正末年ちよつと現れてすぐ廃めた稲の家芝子であらう。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里は圓朝と別れて失意落魄の境涯に入り、その母を求めて朝太郎の悲劇は展開されてくるのであるが、そういえば大利根へ入水する悲しき明眸またお里である。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほほの色まで感じさせる明眸のパールが耳かくしの金髪に胸のふくらみを白いブラウスに包み、腰のあたりがキュウーと張ち切れそうな長靴姿には、僕はあの真暗な客席でほほを赤らめ面はずかしげに上気してスクリーンのパールに気もそぞろであったのです。",
              "citation": {
                "source": "私の洋画経歴",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "錦の直垂に緋縅の鎧、明眸皓歯の大若衆、眼も覚めるばかり美しい中に勇気と気高さとを兼ね備えた、天晴れ勝れた大将振りに、一同はハッと頭を下げた。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "プシヘの明眸皓歯、天下に比いなく、世人相伝えて、美の女神エヌスの化身なりとし、敢て婚を求むる者なし。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「プロテア」の上映も恐らく同じころだつたらう、黒い海水着のやうなものを着た明眸の女探偵（だつたらう）が、屋根から屋根を這ひ廻つた。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころの帝劇には森律子、村田嘉久子、初瀬浪子らの女優劇があり、益田太郎冠者の「ドッチャダンネ」「唖の旅行」系列のボードビルめいた喜劇があり、若い女優の中では小原小春、原光代の明眸が歌はれたが、何れも終りはよくなかつた。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
