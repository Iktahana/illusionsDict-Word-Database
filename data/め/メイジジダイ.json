    "definitions": [
      {
        "index": 1,
        "gloss": "Meiji period (1868-1912)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
