        "examples": {
          "standard": [
            {
              "text": "殿様が、戦功のあった若き武士を広間に「召し出した」。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "有能な職人を「召し出し」、城の改修工事の指揮を執らせることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "罪を認めるよう、役人が容疑者を尋問室へと「召し出した」。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "原田家から物頭を一人召し出す、ということは、その人間が伊達の直臣に出世すると同時に、一ノ関の与党の「人質」にされる意味をもっている。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            }
          ]
        }
