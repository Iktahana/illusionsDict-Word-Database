    "definitions": [
      {
        "index": 1,
        "gloss": "visitor (esp. at a hospital)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "支配人が妾に面会人を告げたのですが、妾は機械的に首を横にふりました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとこの青年はどう見ても面会人のお客さんです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ青年でありながら、ある時は立派な面会人のお客さん、ある時は狂人か白痴。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この三つの不適当のために面会人のお客さんと同じ青年が、狂人か白痴に間違えられました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私が書斎に入って、五分も経つか経たない中に、女中が面会人があると云って来たのであった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らには面会人も差し入れもなかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに面会人の多いことは多い日には三十人もある。",
              "citation": {
                "source": "書斎と星",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お頭、お頭、面会人で」「誰だ？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "解熱剤を飲んで部屋に寝転んでいたが、面会人があれば起きて出た。",
              "citation": {
                "source": "遥かな旅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "深夜のこととて他に面会人も歩いていず、そのあたりは湖水の底のようにしーんと鎮まりかえっていた。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨はショボショボ降るし、事件も何もなし……というので、仲間と一緒に警視庁の溜りで雑談をしていると、給仕が面会人を取次いで来た。",
              "citation": {
                "source": "近眼芸妓と迷宮事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "這入つて左へ突き当つた廊下へ上る扉口と入口を除いた外は、此の九尺に三間の細長い室の三方の壁には面会人の腰をかける為めの幅の狭い木の腰掛けが、恰度、棚のやうな工合に取りつけてあつた。",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の内には、傘や、下駄や、スリツパが、二三足おいてあつたが、面会人はＭを除いた他には、三つか四つ位の子供を縞目もわからないやうな汚いねんねこで背負つた女房が一人隅つこにうづくまつてゐる外には誰もゐなかつた。",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍子が『七十二番』と云ふ番号札を受取つて控所に戻つた時には、外の控所から這入つて来た面会人が十人近くもゐた。",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼んな奴等の眼には、此処の門を這入ると、誰でももう囚人に見えるんだわね、面会人まで囚人扱ひしなくつてもよささうなものだわね。",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども労働者の面会人はその母親だけだった。",
              "citation": {
                "source": "道づれ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、患者面会人がやすむ部屋のほうで、微かにごそりごそりと音がする。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「患者面会人室の廊下の羽目際だ。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから余り門と離れていない、庇に厚い苔の乾いた面会人控室へつれて行って貰った。",
              "citation": {
                "source": "冬",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、大勢の面会人は誰も存外平気らしかった。",
              "citation": {
                "source": "冬",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし大勢の面会人も看守の呼び出しに来る度にだんだん数を減らして行った。",
              "citation": {
                "source": "冬",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にまた博奕打ちらしい男も二三人の面会人と一しょに看守のあとについて行ってしまった。",
              "citation": {
                "source": "冬",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕はＴの面会人です。",
              "citation": {
                "source": "冬",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "面会室の正面にこれも狭い廊下越しに半月形の窓が一つあり、面会人はこの窓の向うに顔を顕わす仕組みになっていた。",
              "citation": {
                "source": "冬",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その谷博士のところへ、ある日曜日の朝、にぎやかな面会人が来た。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "院長から許可が出たので、面会人の少年たちは、一人の看護婦にみちびかれて、谷博士がやすんでいる丘の上へ行った。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
