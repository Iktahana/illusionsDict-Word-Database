        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ゴリゴリ、ゲリゲリと鋸の目立てをするような音はほとんど聞かれなくなった。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは結局は弦の美しい音を出すための争闘過程であって、決して鋸の目立てのような、いかなる人間の耳にも不快な音を出すためではないのである。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰つて来ると、鋸の目立ての様な声を出して御浚ひをする。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏町の黄色い空にのこぎりの目立ての音がしている売春の町にほのめく桜　二月の桜水族館の水に浮く金魚色の女の写真牛太郎が蒲団を乾しているはるばると思いをめぐらした薄陽に二階の窓々に鏡が光る。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて、目立たぬやうにして、目立てと云ふのが、彼の信条らしいな」　ゆき子は、昔の伊庭の性格が、すつかり変つてしまつて、まるで狂人のやうな人物になつてゐるのが薄気味悪いのである。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「越後でがアんすが」「ふん、越後の生れならば、雪には馴れとるじゃろう、何の商いに行くのか」「鋸でがんす、鋸、刃もの、――都合によっては鋸の目立ても教えたり」「それは勿怪の幸いというもの、売れるに相違ない――おお、そう、そう――」と彼は東京から廻って来た阿賀妻の手紙を憶いだした。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って来ると、鋸の目立ての様な声を出して御浚いをする。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らに丸鋸の目立てをさせると、一日に十三、四個つくる。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱の剥げ落ちた箱枕が、永田杢次のビリケン型の禿頭の横にころがり、うつぶせになった半裸体の中老人は、奇妙な恰好に、腕と足とをよじらせて、鋸の目立てのような鼾を、かいている。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "一たび石臼の目立ての村に入り込む時代がくると、是が彼らに調法がられ、手杵が純乎たる兎の持物になってしまった事情も想像するに余りがある。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は薬材・絵具や茶の類に限られ、僅かに上流の家だけに使用せられていた石の小さな挽臼が、どんな田舎でも手に入り、また目立て屋という職人まであるようになった。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "石臼の目立てを業としてあるく者は、信州北部その他に少しずつはあったようだが、それの全く巡って来ない村も多く、石が軟かくて早く目の潰れた臼などは、まことに始末の悪いものだった。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝はまた、いやにくまなく箒目立てて、きれいに掃ききよめてあるじゃないか」「いぶかしいぞ」「なにが」「奥の中門も開いている。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジリジリ石垣島を攻めたてた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母と、だぶ／＼の詰襟の支那人が、咎めたてる巡警をつきのけて、いきなり事務室へとびこんで来た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "憎いと云うては、悲しいと云うては、人のものが欲しい、おのれの身がかはいいと云つては、寝ると起きると、心の鬼が責めたてる。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィナスのこの美しさに魅せられた神々たちは、このひとこそは愛と美の女神であると言ってあがめたて、心ひそかに怪しからぬ望をさえいだいたのである。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇受女命はさっそくかけつけて、きびしくとがめたてました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の女は何かかわるがわるその少年を攻めたてているようであった。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七日、官軍の援兵大いに来って、歩兵は三十二個中隊に及んだので、新手をもって次ぎ次ぎ攻めたてた。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の女は、何か代る代るその少年を攻めたててゐるやうであつた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　高利貸には責めたてられるし、食ふ物はなし、亭主は相変らず将棋を指しに出歩いて、銭をこしらへようとはしないし、いつそ死んだ方がましやと思ひ、家を出てうろうろ死に場所を探してゐると、背中におぶつてゐた男の子が、お父つちやん、お父つちやんと父親を慕うて泣いたので、死に切れずに戻つて来たと言ふ。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "友は敵と化して、その鋭峻なる論理を武器として彼を責めたてる。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云つて見物人は皆秀ちやんのお手柄を誉めたてました。",
              "citation": {
                "source": "泣き笑ひ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "りっぱな態度だなどとほめたてられると、図に乗ってどうかすると尼なんかにもなります。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し此花、大山川谷に生じ好家名処にあらずと叙べ、ばら刺あるを嫌ひ、芍薬光りなきを愧づと無上にほめたてた。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に予は、帝釋が毘沙門をクベラと呼で佛の供養を佐けしめたてふ經律留相の文を引て、クベラは實名、毘沙門は通稱の如くみえると云た。",
              "citation": {
                "source": "再び毘沙門に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "その楽の日に若島は常陸山につり出されて負けたが、若島としてはなかなか分のいい相撲をとったので、ひいき客のある人が祇園下の料理屋へこの力士を招いて、言葉を極めてその日の相撲ぶりを賞めたてたものだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "せがれに譲りたい、譲るには弥七郎がおってはじゃまじゃ、なんぞ罪着せて破門するが第一と、もともとありもしない秘伝書を盗んだであろう、かすめたであろうと責めたてたのがこんなことになりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいうやつには、動かぬ証拠をつきつけて責めたてるよりほかには手がねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
