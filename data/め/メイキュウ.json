[
  {
    "uuid": "079d31a7-007c-5242-9f67-e482cc2bb8d0",
    "entry": "迷宮",
    "reading": {
      "primary": "めいきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
