[
  {
    "uuid": "086e561d-9daa-521a-8176-b514a43da1d2",
    "entry": "芽ぐむ",
    "reading": {
      "primary": "めぐむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
