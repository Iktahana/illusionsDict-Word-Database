    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to bud",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その後、春になって、街道に青く角芽ぐむ柳の糸を見るたびに、大井川上流の深谷に秘められて、黙々と、皺だらけな、深刻な顔を、水に覗かせている老楊が……ああ、今もなお、鮮やかに眼に。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝飯が済むと、彼は縁側に寝転んで、芽ぐむばかりになった鴨脚樹の枝の間から、薄緑に晴れ渡った早春の空を眺めて居た。",
              "citation": {
                "source": "大島が出来る話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の中にはもう一片の空想も芽ぐむ余地がなかった。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "七『深山姥の使ひ姫、鷽が落した蠱の實の粒のひとつや含まれて、野木の叉枝の巣ごもりに、芽ぐむや、禍の妖惑。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "芽ぐむ青桐の梢を見あげ、私は、独特の愛らしさ、素朴、延びようとする熱意を感じずにはいられない。",
              "citation": {
                "source": "透き徹る秋",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前田河広一郎の「三等船客」中西伊之助の「赭土に芽ぐむもの」藤森成吉の「狼へ！",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前田河広一郎の「三等船客」、宮嶋資夫の「金」、中西伊之助の「赭土に芽ぐむもの」などは、題材において、これまでの作家が扱わなかった領域に進出した。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「赭土に芽ぐむもの」は、殖民地としての朝鮮とその民衆が自由をもとめるたたかいを描いたし、「金」は、無産者の側から資本主義社会の金融・株式市場を、「三等船客」は、色彩のつよい手法で太平洋航路の三等船客の姿を、上甲板の船客たちの華美贅沢と対立する社会群として描いた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間で別々に立っている時には競争心というようなものも双方の心に芽ぐむのであるが、一堂に集まってみれば友情のよみがえるのを覚えるばかりであった。",
              "citation": {
                "source": "源氏物語",
                "author": "行幸",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか林の樹々の枝が、決して摺れ合わないように一定の距離間隔を保っているのを見ても、春に先立って地下茎が芽ぐむのを見ても、その他一切の造化の微妙な作用を観察するに付け聞くにつけて、何かしら人間の五官を超越した、或る偉大なる『霊感』の存在を肯定せずにはいられないのである。",
              "citation": {
                "source": "霊感！",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦も青く芽ぐむに相違ない。",
              "citation": {
                "source": "転機",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが翌年になって、春の末の温気と共に、河に張りつめた氷がとけると、何しろ天地万物が芽ぐむ春のことだ、鴨の足からも芽を出して、立派な鳥となる。",
              "citation": {
                "source": "話の屑籠",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はどんなに芽ぐむこの春を歓び迎る事であろう。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "和津が野に馬のりすてて青丹よし奈良路を近み徒歩ゆわれきぬふるさとに芽ぐむ柳も浄御原きよき昔の鞠場なるらん夢三首。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓からは晴れやかな青い五月の天と、軽げな白い雲の群と、樹々に芽ぐむ春の生気がのぞかれた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の中には、庭前に芽ぐむ芝生の緑と共に、広い春が吹き込んで来る。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "関口君の作品にかの『偉大なる皮肉屋』がもつ一種の｜寛大さが芽ぐむであらう時、彼は一層魅力に富む作家となるに違ひない。",
              "citation": {
                "source": "戯曲集『鴉』の印象",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「桐花さんのフィルムを映してみせてくれないか、この人が見たいというので……」　というと、木戸という編集員が出てきて、「じゃあ、いま撮影中だけれど『銀座に芽ぐむ』の前半を見せましょうか」と気軽に引受けてくれた。",
              "citation": {
                "source": "獏鸚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて小さいスクリーンに、ぶっつけるような音が起ると、現代劇「銀座に芽ぐむ」が字幕ぬきでいきなり映りだした。",
              "citation": {
                "source": "獏鸚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その表紙には「銀座に芽ぐむ」と大書せられてあった。",
              "citation": {
                "source": "獏鸚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に靜まれる日の朝け、曾て覺えぬ悦に痩屈み冷えしわが胸は、雪消に濕り、冬過ぎて、地の照斑と蒲公英の花、芽ぐむ外の面のつつましき春さながらの若萌にきざす祈誓ぞほのかなる。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面は物の芽ぐむのを許さない冷え切った土、空は暗澹とした冬の雲。",
              "citation": {
                "source": "二つの途",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒廃の中に蔵されてる芽ぐむ力といったようなものに。",
              "citation": {
                "source": "二つの途",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かげろうの上る、かがやかしい田畑や、若草の芽ぐむ往来や、隣家の垣根に咲く桃の花や、いろいろの景色が浮かんで、なつかしい思い出にふけると、あのきれいな鳥が田圃の中のかきの木にきて止まったのが、まだ昨日のことであるように、いきいきと思い返されるのです。",
              "citation": {
                "source": "心の芽",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、まだ木が芽ぐむには早く、風も寒かったのであります。",
              "citation": {
                "source": "星の子",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い言草かも知れんが、嵐のあとに芽ぐむもの……か、つまり新旧の交替だな。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "見い、植木屋でも、緑に芽ぐむ木を見れば、310翌年は花が咲き実がなるのを知るではないか。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "1470芽ぐむ蔓草あり。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、人通りがなく、ほんのりと暗い土の路と空との間に、芽ぐむ樹々の芳ばしいしとやかな香を漂わせた小路の散策は、心を和らげた。",
              "citation": {
                "source": "我に叛く",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夫婦再婚」　夫の発病によって新しい愛が妻との間にめぐむいきさつは、もっとしっくりとした筆致で描かれてよい。",
              "citation": {
                "source": "『健康会議』創作選評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
