[
  {
    "uuid": "aa91ed86-fdac-5ee5-a379-e105cc85210d",
    "entry": "面々",
    "reading": {
      "primary": "めんめん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
