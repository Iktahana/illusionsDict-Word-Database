    "definitions": [
      {
        "index": 1,
        "gloss": "principal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "折からこの地の祇園祭で樽神輿を舁いだ子供や大供の群が目抜きの通りを練っていた。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奉天城内の四平街と云えば目抜きの場所だ。",
              "citation": {
                "source": "防備隊",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲橋は下町でも目抜きの場所であるから、市などの景況も下町気分で浅草とはまた変った所がありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "歳の市のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "目抜きのつかい手の肝心な腕切ってかたわにしておきゃ、雑兵ばらの二、三百は物の数じゃねえんだから、さすが真田幸村の息がかかった連中だけあって、しゃれたまねしたものだが、ところがそれが大笑いさ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "たったこの間まで目抜きの場所へ店を構へて、彼は山と積んだ負債を切抜けてゐたのだった。",
              "citation": {
                "source": "難船",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の一つに、ジャパンというのが、市中目抜きの場所にある。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つのうち二つは目抜きの場所にあり、そのうち新栄座というのが一流で寿座というのが二流どころであつた。",
              "citation": {
                "source": "私の活動写真傍観史",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪をよごして零下十二度の夜焚火をする樅の木売りも、モスクワの目抜きの広場からは姿を消した。",
              "citation": {
                "source": "モスクワの姿",
                "author": "――あちらのクリスマス――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけの用件さえあれば彼女は殆ど半日を活々と、楽しく、東京では目抜きというべき街路の舗道を彷徨えた。",
              "citation": {
                "source": "心の河",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中尾の伯父に、京橋目抜き通りの地所持ちがいることを知っていたから、保証人は、この人にしてはどうかと勧めてみた。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはともかく、少くとも、その役人が市中でも目抜きの場所に住んでおり、従ってアカーキイ・アカーキエウィッチのところからは、かなりの道程があったということだけは確実である。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴巻町通りは、何といっても早稲田で唯一の目抜きの大通りである。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷には騒擾が起り、電車焼打ちがあって、市内目抜きの場所の交番、警察署、御用新聞社の打｜壊しなどがはじまり、忠良なために義憤しやすき民衆は狂暴にされ、全市に戒厳令が布かれて三々五々、銃をもち剣を抜いた兵士が街路に屯し、市中を巡羅するようになった。",
              "citation": {
                "source": "一世お鯉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の目抜き通りの上町下町をとおして、両側に、物売りが並ぶ。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞紙は勿論、目抜きの通りのスカイサイン、ラジオ、それらはルウス・ジュッドの名で充満している。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場は隆盛になったけれどマドリッド市中はその代り拠所ない恐怖に包まれて次第に人心が険しくなって夜も十時を過ごした頃には目抜きの町のＡＥ街をさえ人っ子一人通らないようになった。",
              "citation": {
                "source": "物凄き人喰い花の怪",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦後十年くらいまでは、京橋、日本橋あたりの目抜きの場所といえば、相当やかましい寿司屋もあり、やかましい食い手もあった。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は宮殿から程遠くない、目抜きの大通りに宿をとりました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園の周囲は目抜きの街路で、十二時を過ぎても尚人通りが賑やかにゾロゾロ続いていた。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本橋、京橋、神田というような目抜きの場所は悉く焼尽してしまって、わが丸の内だけが無事であったのだもの。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦労して二流どころの医専を出たのだが、それが日本橋の目抜きの場所に、小粒ながらも、がつしりした地歩を固めるまでの苦心は、たとへ訊かれても笑つて答へない。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもいゝから当つてみないことにはと、やつと腰をあげた彼女は、Ｉ市の目抜きの通りを、行きつもどりつした。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座の如き目抜きの場所に、支店向きの適当な譲店が出たなどと誘惑をたびたび受けましたが、私は主義として、一人には一つの店で充分なりとの信念をもって終始一貫してまいりました。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一流の地とは歴史的にすでに東京の目抜きの場所といわれている所で、実際上にも海陸とも交通の便利最もよく、銀行、問屋、運送店等にも至極便利のよい地を選まなくてはならぬ。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反してその人の朋輩であった所の一歯科医は、人物も技術も前者に比してはるかに劣っていたが、機敏にも大奮発して中央の目抜きの場所へ開業したため今は堂々たる歯科院長として、非常な盛大を致しているようになった。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "お辻　だつて、みんな権利金や立退料が一度にドカツとはいつたら、結局、その方が得なんですよ、こんな目抜きの場所を、腐れかかつた小売店がふさげてゐると言ふ法はないよ。",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし人がこの町を歩きまわって真実のみを見るとしたら、諸君は目抜き通りのミル＝ダムがどこにふっ飛んでいってしまうことと思うか。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、なるべく日本官憲の手にかけさせ、死体は東京の目抜きの場所へ投出して置くという条件付なのである。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "一と口に橋の欄干と堂宮の玉垣と言っても、江戸中のを調べるのは容易の業ではありませんが、幸いに落書のあったのは、江戸の盛り場や目抜きに限られ、平次とガラッ八が、多勢の下っ引を使って、一日の骨折りで集めた落書の数は、たった一つしかなかったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "火の呪い",
                "note": "青空文庫"
              }
            },
            {
              "text": "慾にころんで空葬まで出さしたくらいだから、金高次第では、娘を返す気になるかも知れない――」　物持の人の親らしい考えで、平次が止めるのも聴かず、役所の許しを得て、江戸の目抜きの辻々に、真新しい「尋ね人」の高札を建てさせました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幽霊にされた女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
