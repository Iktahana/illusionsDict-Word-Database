        "examples": {
          "standard": [
            {
              "text": "映画のクライマックスは、涙なしには見られない名場面だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "劇場のカーテンコールで、観客は名場面を演じた俳優に拍手を送った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スポーツの歴史に残る名場面を、私たちはテレビで何度も見返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "君臣の義相発して情景｜相具った歴史の名場面ではないか。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "近松門左衛門（江戸時代の歌舞伎作者）はその戯曲で、美人の温情が難与兵衞をして奮って気を張らせたことを描いて、一場の名場面を作らせている。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
