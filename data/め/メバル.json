        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "）（若い坊様連れて川へ落っこちさっしゃるな、おらここに眼張って待っとるに、）と横様に縁にのさり。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "露地から急いで、……あのお千世さんが心づかい、台所から長火鉢、二階を股に掛けて、眼張っている、ものがもの。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど尾花の背景もある、牛頭馬頭で眼張りながら、昔の式を遣ってみべいと、」「おじいが言うのは私の図星。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、眼張魚は、蟇だと諺に言うから、血の頬白は、※になろうよ。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三原伝内が眼張ってれば、びくともさせるこっちゃあねえ。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おら此処に眼張つて待つ居るに、）と横様に椽にのさり。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日暮頃から空は戛々に晴れて、氷結したやうな夥しい星屑が象眼張りのやうに光つた。",
              "citation": {
                "source": "白明",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから扉の隙間などには、眼張をしていただきます。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼張の材料が十分でございませんので、一つ皆さんで御相談の上、適当にやっていただきます」　これを聞いて、乗客たちは又色を失った。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、まず眼張の材料だ。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを手頃の大きさに裂く係ができ、材料を分ける係ができ、そしていよいよ全員が手分をして、眼張作業が始まった。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この協力のかいあって、僅か十分たらずで眼張ができあがった。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次は、畳をあげて、床板の隙間に眼張をはじめた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄弟三人ともお習字の会に入っていたので、手習につかった半紙の反古がたくさんあったから、これに糊をつけて、二重三重に眼張をした。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉が二つあったが、一つは諦めて眼張をした。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどは、防毒室の前の部屋に、同じような眼張をした。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで急いで」　旗男は、さらに竹男と晴子とをうながして、前室にあてた八畳の部屋にある押入の中のものをドンドン外に出して、この押入に眼張をほどこした。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖ルイスふうをした騎士たちは婦人たちに手を差しのべていると、相手の婦人たちは隈取りをした顔を扇にかくしていて、ただ白粉のついている額と、眼のふちに眼張りをしているのだけが見えるのでした。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "聖餐祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしたら、鼻の尖つた、眼張りの強い、脣をへの字に曲げてゐる顔が、うす暗い雲母摺を後にして、愈気味悪く浮き上るだらう。",
              "citation": {
                "source": "動物園",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "年は四十ばかりで、軽からぬ痘痕があッて、口つき鼻つきは尋常であるが、左の眼蓋に眼張のような疵があり、見たところの下品小柄の男である。",
              "citation": {
                "source": "今戸心中",
                "author": "広津柳浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰹に眼張、白すに里芋、豆腐に生揚、蛸ぶつに鰊。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "かごやの客",
                "note": "青空文庫"
              }
            },
            {
              "text": "笠ははね飛ばされて、月代の青い地頭が出て居りますが、白粉を塗つて、引眉毛、眼張りまで入れ、手甲、脚絆から、笈摺まで、芝居の巡禮をそのまゝ、此上もない念入りの扮裝です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "花見の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "笠ははね飛ばされて、月代の青い地頭が出ておりますが、白粉を塗って、引眉毛、眼張りまで入れ、手甲、脚絆から、笈摺まで、芝居の巡礼をそのまま、この上もない念入りの扮装です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "花見の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "晝間ハダーク・ブラウンノ鉛筆デ、夜ハ墨ニアイ・シャドウヲ交ゼテ眼張リヲスル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "魴※の鰭は虹を刻み、飯鮹の紫は五つばかり、断れた雲のようにふらふらする……こち、めばる、青、鼠、樺色のその小魚の色に照映えて、黄なる蕈は美しかった。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは、海辺近くだから春はめばる、夏は鱸と魚にこと欠いた経験はなくて何十年来暮していたところ、今度行ってみると、母は魚買いに苦心している。",
              "citation": {
                "source": "主婦意識の転換",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お縫のうちの方は、こことはちがって、海辺に近い半農半漁の村暮しで、寺の山にのぼると、小笠島というめばるのよくとれる島のまわりからずーっと瀬戸内海が見渡せた。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさやは、湯気の立つめばるの汁をよそってやりながら、「どうじゃった、長瀬へもまわれたか？",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まとうの次にはめばるを描いてみたが、これも大した傑作にもならず片付けてしまった。",
              "citation": {
                "source": "雑魚図譜",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の魚であるめばるもそんなものを釣っているよりは「稼いだ金で魚買うた方がやすくつく」そうで、めばる売りも来ません。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
