[
  {
    "uuid": "eaf9e2a5-a421-5450-a4d9-0e0a04df08f9",
    "entry": "面倒",
    "reading": {
      "primary": "めんどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
