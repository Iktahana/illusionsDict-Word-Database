        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "染分の総だけも、目障りになるまいという、しおらしいんだね。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきでも目障りになったろう。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "天狗党に居た時は、潮来の宿で、気に食はぬ事があつて、部下三名を並べて首を斬つたり、鹿島神宮へ参詣して、拝殿の太鼓が大き過ぎて目障りだと云つて、これを鉄扇で叩き破つたと云ふ程の乱暴者であつた。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "目障りで……」　河上は地主仲間に言っていた。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "坐つて周圍を見ると、壁の落書や襖のぼろ／″＼に煤けたのが目障りだけれど、その内には馴れて來よう。",
              "citation": {
                "source": "胡瓜の種",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "佛さんなんかそんなところへ置いては目障りでいけない。",
              "citation": {
                "source": "胡瓜の種",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "御目障りでござんしょうが、通らせておくんなせえまし！",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に邪魔だとか目障りだとかいうに過ぎないのである。",
              "citation": {
                "source": "二階から",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡國の髯だ、朝鮮人と昔の漢學の先生と今の學校教師にのみあるべき髯だ、黒子が總計三箇ある、就中大きいのが左の目の下に不吉の星の如く、如何にも目障りだ。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒子が総計三箇ある、就中大きいのが左の目の下に不吉の星の如く、如何にも目障りだ。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "時とすると目障りでもあったが、しかし加世子がいなかったら、神経の疲れがちな庸三は、ぎごちないその態度で、どんなに客を気窮らせたか知れなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの女が島田などに結うのは目障りだね。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこしも目障りにならない。",
              "citation": {
                "source": "新刊紹介",
                "author": "〔伝説の時代〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "きんは、ふっと、気にもかけなかった女中の若さが目障りになった。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きんは、ふつと、気にもかけなかつた女中の若さが目障りになつた。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "源三が余りに呑気な闘士であろうと、犀太郎が余りにひねくれた少年であろうと、そんなことは目障りにならない。",
              "citation": {
                "source": "性格批判の問題",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "目障りにならないどころか、そのために却って性格の重みがまして、どこかその辺にいそうな人間のような気を起させる。",
              "citation": {
                "source": "性格批判の問題",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人形芝居にしても、今日は明るいためにかえって人形遣いの方が邪魔になってよほど趣きを打壊すが、昔は暗い上に八つ口だけの赤い、真黒な「くろも」というものを着附けていたので目障りではなかった。",
              "citation": {
                "source": "亡び行く江戸趣味",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "評判程の名園でも何でも無く、殆ど荒廃に属して居て、つくね芋の様な入為的の庭石が目障りになる許りだ。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この隣と自分の居る家との間には平家になつた此処の食堂があるのであるが、高い処からは目障りにもならない。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ながい論議のうちに、目障りで堪らぬと思っていた阿賀妻に対する考えに、ひびがはいった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「目障りじゃないか――何か用か？",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間にはこの目標を目障りだと言って見まいとするものもあるが、自分にはどうしても見えると言う方が正直としか思われない。",
              "citation": {
                "source": "序に代えて人生観上の自然主義を論ず",
                "author": "島村抱月",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩餐会の席上で、私は官邸が誠に立派なのに目の前に高い塀が建っていて大変目障りになるので、どうしてあんな所に高い塀がありますかと質問いたしますと、総督がお目障りになって甚だ恐縮ですが、あれは監獄なのです。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "和市の幇間は目障りなりき。",
              "citation": {
                "source": "両座の「山門」評",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "目障りだ目障りだ持って行け！",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂人じみた目付きをして、秀次は大広間を見廻したが、「目障りになる！",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "友谷さんの旦那さんだと云うことがめざわりで仕方がない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
