    "definitions": [
      {
        "index": 1,
        "gloss": "mechanic",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "車の故障で困っていたら、親切なメカニックが助けてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はレーシングカーの専属メカニックとして、世界中を飛び回っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そのメカニックは、熟練の技でどんな問題も解決してくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "白い洲の上流は、河になつてゐると見えて、高い堤の上に、珍しい程メカニックな大きい吊橋がアーチのやうに架つてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは制帽をかむり、制服をつけ、そしてサァベルをさげた一人の巡査というよりも、そのゼスチュアのあざやかさと、正確さと、メカニックな点においてむしろ一個の機械としての興味を私に感じさせる。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれはメカニックなリズムを持つ動くものの美しさだ。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "感情をメカニックに動的に、肉体的に表現して行くところ、（云い表しがうまくないな）心理モノローグなどせず、主人公イリンスキーが笑劇の大道を踏みつづけて、女主人公が比較的リアリスティックに正面からやって居る。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔パポフ君〕君はもう少し垢ぬけして、メカニックになって装飾なき美を理解しなくちゃたすからぬ。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お台所のメカニックがすっかり残っていて、とても便利にやっていらっしゃるわ……電気冷蔵庫があって、電気洗濯機があって、お料理は、みな電気調節器のついたレンジとオーヴンでやるの……あなた、聞いていらっしゃる？",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の先耳のはたの声をそのまま片はじからメカニックに模写するものとして。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
