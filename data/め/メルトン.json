        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところで、あの窓枠はペンキが少しはげかかって、ところどころ材木の生地が出てざらざらしていますから、強く摩擦すれば被害者の着ていたメルトン（羅紗の一種）の服地から細かい毛がかすりとられて、窓枠に付着するに相違ありません。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "因みに、その時同人は新しき革足袋を穿き、古きメルトン製の釜形帽を冠りおりたる由……おわり……」「それだけかね」「それだけです。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と案内も待たずにどんどんと二階へ上つて来たのは、鼠色の褪めて皺の寄つた背広を着た執達吏と、今一人は黒の綿入のメルトンの二重｜廻を来た山田と云ふ高利貸であつた。",
              "citation": {
                "source": "執達吏",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "着なれないせいか、メルトンに対して妙に遠慮する傾きがある。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "小野さんの胴衣の胸には松葉形に組んだ金の鎖が、釦の穴を左右に抜けて、黒ずんだメルトン地を背景に燦爛と耀やいている。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その教師はついこの間英国から帰ったばかりの男であったが、黒いメルトンのモーニングの尻から麻の手帛を出して鼻の下を拭いながら、十九世紀どころか今でもあるでしょう。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "田中はまんまと去年一部甲に無試驗で入つたのだが、メルトンの制服が羨しい程似合つてゐた。",
              "citation": {
                "source": "受驗生の手記",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「痛い」「メルトンかしら」「痛いよ。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
