          "standard": [
            {
              "text": "世の中には目明き千人盲千人で、物の本質を見抜ける人は意外と少ない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「誰が評価しようとも、目明き千人盲千人さ」と、彼は自分の信念を曲げなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "流行に流される人々を見て、祖父は「目明き千人盲千人だな」と苦笑いした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "言っちゃ悪いが熱海のような温泉場――講釈場じゃない、目明き千人盲千人のお集まり、遊び半分に聴かっしゃる場所だ。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
