        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この曲は「メジャー」キーで書かれているので、聴いているだけで元気が湧いてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "悲しい曲調から一転して「メジャー」に転調する瞬間、パッと世界が開けたように感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ピアノの練習で、まずはハ長調の「メジャー」スケールを完璧に弾けるようにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 4,
