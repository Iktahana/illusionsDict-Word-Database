        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "インディーズで地道に活動してきたバンドが、ついに「メジャー」との契約を勝ち取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「メジャー」からのデビューが決まり、プロモーションの規模が格段に大きくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「メジャー」に行っても自分たちの音楽スタイルを変えない、と彼らはファンに誓った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
