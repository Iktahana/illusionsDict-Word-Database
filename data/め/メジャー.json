        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は子供の頃からの夢を叶え、ついにアメリカの「メジャー」のマウンドに立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "日本のプロ野球で活躍した投手が、「メジャー」でどこまで通用するか楽しみだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "毎朝、スポーツニュースで「メジャー」の結果をチェックするのが日課になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "major (key, scale, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
