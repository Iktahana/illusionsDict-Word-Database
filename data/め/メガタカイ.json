        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "利休が心窃かに自ら可なりとして居た茶入を氏郷も目が高いので切りに賞美して之を懇望し、遂に利休をして其を与うるを余儀無くせしめたという談も伝えられている。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "母様はね、君、目が高いんだ、いわゆる士を知る明ありだよ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし間違いはない、そこは母さんの目が高いもの。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは、やっぱり目が高いや。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "花魁も……」「傷の御前も……」　婢たちは、目が高いと言っていいか、低いと言っていいか、主水之介をそれと看破って成田屋、おいらん、二人が取巻きの川涼みと思ったらしく、忽ちそこへ見る目もさらに涼しい幾品かの酒肴を運びました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "流石におけいさんは目が高いよ、やあ、お帰んなさい。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がジッドやヴァレリイを選んでやるから、お前は目が高いと言つてゐるですよ」「なるほど、お前は目が高い。",
              "citation": {
                "source": "朴水の婚礼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さすがは大どころで育った学者だけあって、目が高い。",
              "citation": {
                "source": "村芝居",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "「看護役は居候に限るにしても、オヤジ殿は目が高いや。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十八　踊る時計",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬草村のアンチャンは目が高いやア」「アドルムのみてえよなア」　一同ヤケを起して大声で喋っている。",
              "citation": {
                "source": "文化祭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに太平洋新聞は目が高いや。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのところへゴキゲン伺いは今日がはじめて、御降嫁以来御無沙汰していたが、うん、こうして御対面、シミジミ拝顔すると、さすがに正司君は目が高い。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その五　万引家族",
                "note": "青空文庫"
              }
            },
            {
              "text": "久世喜善は目が高いというもっぱらの大評判だぜ」　まったく、世事にはうとい通太郎であった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十四　ロッテナム美人術",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉三郎は支配人面をして威張つて居ても、主人の佐兵衞は目が高いから、跡目は人の好い金次に繼がせるつもりだつたのさ」「へエー、どうしてそんな事がわかつたんです、親分」「俺は小僧の三吉に頼んで、吉三郎の道中差を盜み出させたよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "遺言状",
                "note": "青空文庫"
              }
            },
            {
              "text": "「刀の鞘だらう」「親分は目が高いね、匕首の白鞘ですね。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "凧糸の謎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉三郎は支配人面をして威張っていても、主人の佐兵衛は目が高いから、跡目は人の好い金次に継がせるつもりだったのさ」「ヘエー、どうしてそんな事がわかったんです、親分」「俺は小僧の三吉に頼んで、吉三郎の道中差を盗み出させたよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "遺言状",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに錢形の兄哥は目が高いや」　金六は平次に競爭心がないと見ると、中年者らしく露骨な世辭などを言ふのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "矢取娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに銭形の兄哥は目が高いや」　金六は平次に競争心がないと見ると、中年者らしく露骨な世辞などを言うのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "矢取娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の目が高いことを誇って、顔を輝かせていた。",
              "citation": {
                "source": "判決",
                "author": "DAS URTEIL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私、あんな人、問題にしていませんわ」　と豊子さんは矢張り目が高い。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新太郎もナカ／＼目が高いとお母さんにも言ったことさ」「…………」「俺等には異存がない。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "姐さん達は商売柄で流石に目が高い」　と団さんはそのまゝ旦那様に成り澄ました。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私、何故警察へ早くお届けになりませんのって、女中さんに訊いたら、御主人さまが局長さんと御一緒に御出張中ですからって」「宣伝ね、何でも」「オホヽヽヽ」「流石に佳子さんはお目が高いですな。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八年前に彼女を彫刻のモデルにしたあの彫刻家は目が高い。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「岩国の佐々木小次郎、さすがに目が高い。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さすがに、お目が高い」　耕介は後の刀を、仕舞いながらいった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
