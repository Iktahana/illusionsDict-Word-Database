        "examples": {
          "standard": [
            {
              "text": "今月の光熱費の明細表を家族で共有し、節電について話し合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プレゼン資料の付録として、各経費の項目を網羅した明細表を付けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "在庫管理システムから、最新の入出荷明細表を出力する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私は、その二百五十円を何人に依って何処の郵便局で盗まれたかを検べるために、貯金局に願って、出入の明細表を作って貰った。",
              "citation": {
                "source": "易と手相",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その明細表で見ると、盗まれた形跡は少しもないのである。",
              "citation": {
                "source": "易と手相",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
