[
  {
    "uuid": "57cd34b0-5691-5ae7-a7f6-adaec33a4675",
    "entry": "メッセ",
    "reading": {
      "primary": "メッセ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "trade fair",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つまりこうだ、もし私の読み通り、これがあのご婦人と昔親密にしていた者からのメッセージだとすれば、この両端にＥがあり、中に三文字ある組み合わせは、ＥＬＳＩＥ、『エルシィ』という名前をまさに指しているのかもしれぬ。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母の筆跡は、それ自体がさまざまな思い出を揺り起こすメッセージです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした文字の揺らぎを、我々はメッセージとして受け取っているはずです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一日付の最初の書き込みは木津田さんによるもので、その日のうちに古野さんからのメッセージが続きます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "木津田さんはさらに、紙の出版社がすくい取ってくれないメッセージを残す作業を、電子出版社を起こして、組織的に進められないかと考えを進めました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分でメッセージを書き込んでいくと、知り合いも増え、気心の通じた人もできてきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "お読みいただければ明らかなとおり、本書は皆さんのメッセージを糧として生まれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本電気がその後の独走の基礎を固めるＰＣ―８００１の発売に踏みきった一九七九年八月から一年半をさかのぼる前年三月にはすでに、Ｔ―４００と名付けた試作機を西ドイツのハノーバー・メッセで開かれたショーに展示するところまでこぎ付けていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて一九八九年十二月十三日から二日間、電通という広告屋さんは次の儲けのねたはなんじゃいなというわけで「マルチメディア国際会議」を千葉は幕張メッセでぶちかました。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同一時間内にマシンガン古川は通常の二倍の情報量のメッセージを叩き込み、テープ起こしの作業量はそれゆえ四倍を覚悟せざるを得ない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ＤＯＳ／Ｖ万歳」の雄叫びはなぜかマッキントッシュの博覧会に響き渡る　地の果ての幕張メッセで開かれたマッキントッシュの博覧会、マックワールド・エキスポの会場で、マック使いのライターのＴ田とバッタリ会った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこのショーの協賛社には、日本のハードウエア・ベンダーのほとんどが名を連ねているだろう」　幕張メッセの天井も裂けよとばかり、オレは心の中で唐突にそう叫んだのであった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "柴谷さんの断言から当時のオレは、「見逃しているのだから遺伝子操作は恐ろしいぞ」とする危惧のメッセージのみを受け取った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレが世間様に向けて投げ掛けたメッセージは、一般書からの撤退という旺文社の方針変更によって、あわれデスクトップのゴミ箱直行となった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんのちっぽけなメッセージではあったが、ゴミ箱行きを免れた内の一冊は間違いなく、正面から受けとめてくれる人に出合ったのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界に向けたＢＴＲＯＮのメッセージがまず日本で問われることになったのなら、オレはけなすにしても褒めるにしても背筋を伸ばして正面から向き合いたい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがその前に、ＢＴＲＯＮの開発に取り組んだ皆さん、紆余曲折はあったけれど、あなた達のメッセージがユーザーに直接とどく日が来たこと、本当におめでとうございます。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来なら引き続いて、両親の離婚騒動に胸を痛める全世界のまるちゃんへのメッセージなども書きたいところだが、今回ベスト１を書かずに終われば『パソコン・マガジン』にオレの席はない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつのメッセージを伝える」「へえ、ワラも高志をメッセンジャーボーイに使うようになったのか、エライもんだな」「いいから、きけ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「慶一、柾生からメッセージとプレゼントがあるよ」「へえ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスマスカードをよこすくらいで、たいしたことは、いってこないんだ」「メッセージは、『元気かい、いけなくてゴメン。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その報告は人々の期待を裏切って遷延し、やっと五日後になって発表をみたが、それによると超音波によるメッセージも効果が見えず、映画は届くより前に水中にて焼きつくされ、御馳走船は例の海域の三キロの近くまで行ったときに、突然大閃光と共に火の塊となって空中にまいあがり、跡片もなくなったそうである。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い布をかけた机に向っている五人の書記が、順ぐり出て、「日本プロレタリア作家同盟第三回大会へのメッセージ！",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と声を張りあげ、情熱をもって、各友誼団体からのメッセージを読みあげた。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、大会へのメッセージは、トヨタマ刑務所の内から、朝鮮プロレタリア作家同盟（カップ）から送られたばかりではない。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ・ナップ支局からメッセージが来た。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが「ナップ」は、第三回全国大会に各国からのメッセージをうけとっただけで安閑としてはいられない。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大会は、朝鮮プロレタリア作家同盟ばかりでなく、他の友誼団体へのメッセージ起草をも決議した。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
