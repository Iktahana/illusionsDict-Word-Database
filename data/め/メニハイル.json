    "definitions": [
      {
        "index": 1,
        "gloss": "to catch sight of",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "老人の坐っているところは、それが往来の目に入るにはあまりに近すぎた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親の医者というのは、頬骨のとがった髯の生えた、見得坊で傲慢、その癖でもじゃ、もちろん田舎には刈入の時よく稲の穂が目に入ると、それから煩う、脂目、赤目、流行目が多いから、先生眼病の方は少し遣ったが、内科と来てはからッぺた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい、気がつかずにいたけれど、この紫色の鉛筆は、粉が目に入ると、目が潰れて、見えなくなってしまうんですって。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「殿下には、なにかがあまりはっきりお目に入るのが、ご病気だということにしょうちいたしておりますが、もうそれならばとうにご全快です。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟲　　散文詩といふよりは、むしろコントといふ如き文學種目に入るものだらう。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "プールが目に入ると、復一はひやりとして、心臓は電撃を受けたような衝動を感じた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今得たまどかな気分は忽ち破壊せられたので、不安の眸を放つて、市街ををちこちと見廻はしてゐると、斜日に照らされて、夢の如く浮び出てゐるニコライの銀灰の壁が目に入る……神田の古風な大時計がぢん、ぢん……と四時をうつ。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親の医者といふのは、頬骨のとがつた髯の生へた、見得坊で傲慢、其癖でもぢや、勿論田舎には苅入の時よく稲の穂が目に入ると、それから煩らう、脂目、赤目、流行目が多いから、先生眼病の方は少し遣つたが、内科と来てはからつぺた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま下の洗面所に顔でも洗いにゆくと、目に入るものは、赤錆いろの鉄分の強い坪ばかりの池の水と、萎えきって生色のない八つ手の一、二本である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、書き落したが、その漆の花が目に入るまでに、石床の大きなでこでこの岩、お富与曾松の岩というのがあった。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、〔Gen-gen, byo_-soku-byo_〕 …… 〔Gen-gen, byo_-soku-byo_〕 ……　急に寂しくなつて、まじまじと下を向く、とまた生憎な、目に入るでもなく庭の垣根越しに向ふの長屋の明け放した下座敷が見える。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この茶店は少しく勾配ある土地、即ちいくらかの坂垂れに成つて居るかと思ふやうで、極めて茫漠たる野が、この茶店のほとりに立つて見ると目に入るのである。",
              "citation": {
                "source": "竹の里人〔三〕",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が振り返ると、犯人が卓上に投げていった、くちゃくちゃの紙切れが目に入る。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "目に入るものみんな、何もかも、子家鴨にとっては悲しい思いを増すばかりです。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨を含んだ雲が時々遮るとはいへ、暑い日のもとに黄熟した麥が刈られた時畑はからりと成つて境木に植られてある卯木のびつしりと附いた白い花が其處にも此處にも目に立つて、俄に濶々としたことを感ずると共に支へるものが無くなる丈目に入る女の姿が殖えるのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の目に入るものは此も一｜心に灰の始末をして居るおつぎの外にはなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "一杯につまつた松魚船が暗の底にぼんやりと眠つて居る外何にも目に入るものがない。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "恨むと見ゆる死顔の月は、肉の片の棄てられたるやうに朱く敷ける満地の瓦を照して、目に入るものは皆伏し、四望の空く寥々たるに、黒く点せる人の影を、彼は自ら物凄く顧らるるなりき。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "目に入る限りのもの、手に触れる限りのものがまたけがらわしく見え始めたのだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちが完成したらもうしめたものさ」と相変らず元気なことをいっていたが、ふと「△△△△」が佐竹君の目に入ると、「山野君の『廃人』が載っていたね。",
              "citation": {
                "source": "無名作家の日記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、この六十日目に入るお湯が、俺をまるで夢中にさせてしまった。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "庫裡の横手に小鐘の荷車が梶を上にして立てかけてあるのが目に入ると、私と輝子は思はず手を握り合つて、吻つと溜息を衝いた。",
              "citation": {
                "source": "奇友往来",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "時ならず早う起出でめされたが、目に入るものは、時ならず早う臥た息子どのゝ寐姿ぢゃ。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人会などで、若い大人達の丸髷姿が目に入ると急に気難しくなつて、「夫人、あなたの頭に載つかつてゐるのは何ですね。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何か訊き返さうとして口をもぐ／＼させてゐたが、ふと時計の針が目に入ると、その儘慌てて飛び出した。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」車掌はどつちに従つたものかと一寸途方に迷つたらしかつたが、ひよいと上司氏のニツケル側と友人の金側とが目に入ると、初めて判断がついたやうに金側時計の持主の方に向きなはつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれほど不人情な仕向けをしておきながら、のこのこ嫁入り先へやって来た男の愚かしい心持が腹立たしいようであったが、床柱のところに胡坐を組んで、団扇遣いをしているその姿が目に入ると、何のことも考えていられなくなった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そうなる時の自分の行く末のために、金や品物などを用意することを怠らぬらしい、お増の箪笥の着物や、用箪笥の貯金の通帳などの目に入るたんびに、浅井はそういって、不断は苦笑していたが、嫉妬喧嘩の時などには、忌々しげにそれが言い立てられた。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "君たちの元気が消滅するにつれ、君たちの思想が諦めにはいるにつれ、君たちの誠意が働きを止めるにつれ、君たちの血が無駄に一滴ずつ涸れてゆくにつれて、祖国は死んでゆくのだ……。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、かれらが止めにはいる隙もなく、彼は奪い取ったショベルで、仰反けに倒れている相手を殴りつけていた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
