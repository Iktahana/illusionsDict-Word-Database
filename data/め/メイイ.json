[
  {
    "uuid": "bd5c04eb-644a-5a8d-84d8-a35d0758b021",
    "entry": "名医",
    "reading": {
      "primary": "めいい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
