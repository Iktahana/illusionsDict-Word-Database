        "examples": {
          "standard": [
            {
              "text": "罪人は、額に黥されて追放されたという記録がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "江戸時代には、重罪を犯した者の顔に文字を黥す刑があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の顔には、かつて罪を犯した証として黥された跡が残っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あやめさくとはしほらしやといふその花は極めて稀にしか見えないが堤の青草の蔭には薊の花がいつぱいだ。",
              "citation": {
                "source": "水郷めぐり",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御ひょろたかアしまア、まこものーなアかでエ　あやーめさくとはー　しおらしーい」　歌も古いし人も古いけれども、その歌だけは新しい力のある、いきな声である。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
