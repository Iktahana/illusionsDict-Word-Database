        "examples": {
          "standard": [
            {
              "text": "忠臣蔵の銘々伝を読んで、それぞれの義士の生き様に感動した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "卒業文集に、クラスメイトの銘々伝を載せることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の著書は、幕末の志士たちの銘々伝が詳細に記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "もう一つ痴遊の言を引用させて貰ふならば、屡々彼は昔の名人が演じた義士銘々伝は、上は城代家老の大石から下は足軽下郎の寺坂に至るまで、その身分の高下によつて自らそこに生じて来る人柄の相違をひとりひとり、即ち四十七人分立派に描写し分けたものだと嘆称してゐる。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "何方も負けず劣らず成績が悪くて、仮級ばかりやって来ました」　と安部君は級友の銘々伝を大略果した。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同僚の銘々伝を書くのではないが、もう一人五味君を挙げたい。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
