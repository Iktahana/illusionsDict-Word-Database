[
  {
    "uuid": "8e95498c-27b4-5947-a257-a0700a7594b3",
    "entry": "目まぐるしい",
    "reading": {
      "primary": "めまぐるしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
