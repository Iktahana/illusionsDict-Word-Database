[
  {
    "uuid": "b91cac0b-f7b2-5434-92bd-7a7cc44bc044",
    "entry": "芽",
    "reading": {
      "primary": "め",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
