        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ショーウィンドウに飾られた美しいワンピースに、彼女の目がとまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "本屋で探していた専門書に目がとまり、思わず手に取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "雑踏の中で、ふと見慣れないポスターに目がとまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "子爵と喋りながら、暖炉前のぽかぽかする場所から何心なく室内の装飾を眺めていた日下部太郎は、ふと側棚にある一枚の皿に目がとまると、覚えず眼を瞠って椅子からのり出した。",
              "citation": {
                "source": "伊太利亜の古陶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙に不安なくせに、そこに目がとまる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう興味もあって素子は、たまに見かけるラデックやその現在の妻であると思われる婦人に目がとまるのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
