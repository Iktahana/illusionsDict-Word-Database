        "examples": {
          "standard": [
            {
              "text": "教授は数名の教え子を「召し連れて」、遺跡の発掘調査に向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大名が多くの家来を「召し連れて」街道を行列する様子は壮観だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "猟師は忠実な犬を「召し連れ」、雪深い冬の山へと分け入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "今度の鎌倉下りにも、この腹心の宗清を供に召し連れるつもりでいたが、宗清はどうしてもうんといわなかった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大司教となり得る司教は、更に枢機官となり得る大司教は、汝を随行員として召し連れるであろう、そして汝は宗務院にはいり、汝は肩布を賜わり、やがて汝は聴問官となり、法王の侍従となり、司教となる。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
