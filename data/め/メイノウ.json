          "literary": [
            {
              "text": "そしてみんなは下のみちまでいっしょにおりて、あとはめいめいのうちへ帰ったのです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてみんなは、雨のはれ間を待って、めいめいのうちへ帰ったのです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦後日本にも平和をめざす婦人団体がいくつかつくられたけれども、それらの婦人団体の目標は多くの場合「まずめいめいのうちに心の平和を」とか「平和のために労資協調を致しましょう」とかいうものです。",
              "citation": {
                "source": "求め得られる幸福",
                "author": "――今こそ婦人の統一を――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　さて、四人組の楽隊なかまは、おなかができると、あかりをけして、めいめいのうまれつきとすきずきにまかせて、いいぐあいの寝床をさがして休みました。",
              "citation": {
                "source": "ブレーメンの町楽隊",
                "author": "DIE BREMER STADTMUSIKANTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろな推移の中にめいめいのうけようというものが又あるのね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、近くのめいめいのうちへかえったのですが、ミドリちゃんは、すぐにこのことをおとうさんと、にいさんの敏夫くんに知らせました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年団員たちは、こわくなって、そのまま、めいめいのうちへ逃げかえり、おとうさんに、そのことを話しましたが、「そんなばかなことがあるもんか。",
              "citation": {
                "source": "夜光人間",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
