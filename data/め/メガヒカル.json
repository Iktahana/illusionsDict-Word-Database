          "literary": [
            {
              "text": "すぽりと離れて、海へ落ちた、ぐるぐると廻っただがな、大のしに颯とのして、一浪で遠くまで持って行った、どこかで魚の目が光るようによ。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "君がいわゆる実家の話柄とて、喋舌る杢若の目が光る。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪にもみじとあざむけど、世間稲妻、目が光る。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのぶら下った毛の中に、両方の、目が光る。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、そこへ絶えず集まる者には、たとえばぼくらなどにも、時々警察の目が光るようになって来たんだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦の穂ちら　ほら　麦の穂出る頃はこんこん狐の目が光る十六　酒屋の姉　娘こんこん狐についてつた酒屋のうしろの篠籔に狐がまた来て覗いてる。",
              "citation": {
                "source": "別後",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝てゐた豹の目が光る。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うむ」　キラリと、老臣の目が光る。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "安逸が嫌いで波瀾をこのむ、ぼんやりと物を見流さないで探奇心の目が光る。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
