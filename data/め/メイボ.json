[
  {
    "uuid": "9f464d8c-df4e-530d-9192-025d1965165e",
    "entry": "名簿",
    "reading": {
      "primary": "めいぼ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
