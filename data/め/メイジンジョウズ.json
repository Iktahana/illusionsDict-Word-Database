    "definitions": [
      {
        "index": 1,
        "gloss": "person who is a cut above the rest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "假りにも名人上手とうたはれた者は年をとつてつまらぬ棋譜を殘すべきでない――と自重を切｜望したといふ。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、畢竟それもまた名人上手とかいふ風な古來の形｜式主｜義が當｜然作り出す型に捉はれた觀念と見られぬ事もない。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる名人上手でも細工の出來不出來は時の運。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "碁・将棋のような些細な技においてすら、自己流では上達せず、昔の定石を学び、昔の名人上手の碁譜棋譜を究めることに努める者の方が、上達が遅いようでいて実は早いのである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "名人上手の心掛けはまた別なものだと私は心｜私かに石川氏の心持に敬服したことでありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "石川光明氏と心安くなったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる名人上手でも細工の出来不出来は時の運。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな名人上手でも、世にためしのないことは詠まれまい。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからは古人の名作なり、また新しい今日の名人上手の人たちのものについて充分研究を致し、自分の思う所によっていろいろと工夫し、そうして自分の作をせねばならぬ。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "年季あけ前後のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "名人上手と呼ばるゝ人も初作より世にもてはやさるゝべきにはあるまじ。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上達して名人上手と言われるようになればなるほど、ますます変化を試みるが、それは決して定石を無視して差すのではなくして、定石に基づき、その上で変化を試みるのであって、いわば定石をさらに発展させて新しい定石を生み出すのである。",
              "citation": {
                "source": "名人上手に聴く",
                "author": "野呂栄太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぞれ方面は異なっても、その道の名人上手と言われるほどの人びとの言動には、すべての人の心を打つ、教えられるところの多いものがある。",
              "citation": {
                "source": "名人上手に聴く",
                "author": "野呂栄太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故かというと、この位の名人上手同志の試合になると、勝負といってもほんの一｜分か二分早く剣が届くか届かぬかで決まるものである。",
              "citation": {
                "source": "巌流島",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、多くの世の名人上手がそうであるように、師匠も芸にかけては恐しく傲岸で、人を人とも思わず、時には意地の悪い、眼に余るような仕打ちもあったそうだから、そこらから案外他人の恨みを買ったのではないかとも思われる。",
              "citation": {
                "source": "助五郎余罪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云う次第でございますから、大殿様は何かにつけて、武張った事を御好みになりましたが、若殿様はまた詩歌管絃を何よりも御喜びなさいまして、その道々の名人上手とは、御身分の上下も御忘れになったような、隔てない御つき合いがございました。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに名人上手というても、やはり上つ方の、ひいきが無いと、人気は持ちつづけられぬもの――そなたのようにおとなしい気持でいれば、一生、現在の評判をもちこたえること疑いなしじゃ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に名人上手のやうに言はれるのも、多くはかうした場合を捉へて言ふやうである。",
              "citation": {
                "source": "手習鑑雑談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪の人達の自分の手元に名人上手のゐたことを、他人から指摘せられて快い驚きを喫したわけである。",
              "citation": {
                "source": "日本の女形",
                "author": "――三代目中村梅玉論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事でも芸に秀でて名人上手と云われるものは何うも変人が多いようで、それも決して無理のない訳だろうと思われるんでございます。",
              "citation": {
                "source": "根岸お行の松　因果塚の由来",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "大芳棟梁も矢張この名人上手の中に数えらるゝ人ですから、何うも一風流変っておりますが、仕事にかけたら何んな大工さんが鯱鉾立して張り合っても叶いません。",
              "citation": {
                "source": "根岸お行の松　因果塚の由来",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しかういふ特殊な畸形児はせゐぜゐ四五段ぐらゐでとまるやうで、名人上手となるほどの人は他の道についても凡庸ならぬ一家の識見があるやうである。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "気のきいた名人上手が山猿などを相手にするはずはない。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しこういう特殊な畸形児はせいぜい四、五段ぐらいでとまるようで、名人上手となるほどの人は他の道についても凡庸ならぬ一家の識見があるようである。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日都会の料理店に来る材料は、来る前にもう死んで居るのである、如何に名人上手の庖丁でも死んだものを活かす訳には行かぬ。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、パッとせぬ小藩だから、天下名題の名人上手は来てくれない。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "神伝魚心流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこのくらいの用意あってかからなかったらいくら名人上手といえども最高潮場面に達する以前に心なき文明開化のお客たちの笑殺するところとなってしまっててんで相手になんかされなかっただろう。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その頃寄席へ行って名人上手の至芸に接するたび、つくづくアベックで聴きに来ている人々がうらやましかった。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、此がなか／＼の講談通で、当代講談界の名人上手を月旦して、一々、その芸評がまた肯綮に当つてゐる。",
              "citation": {
                "source": "落語家温泉録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界のどの国の人が名人上手になつたところで、私らは大いに歓迎したいと思つてゐます。",
              "citation": {
                "source": "呉清源",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
