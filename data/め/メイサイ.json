[
  {
    "uuid": "c259b26c-c9e6-5399-bd5a-6d499758f540",
    "entry": "明細",
    "reading": {
      "primary": "めいさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
