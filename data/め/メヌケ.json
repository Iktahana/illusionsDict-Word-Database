    "definitions": [
      {
        "index": 1,
        "gloss": "any large, red, deep-water scorpionfish with big eyes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "折からこの地の祇園祭で樽神輿を舁いだ子供や大供の群が目抜きの通りを練っていた。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奉天城内の四平街と云えば目抜きの場所だ。",
              "citation": {
                "source": "防備隊",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下町の目抜という場所で、正月の往来は賑っている。",
              "citation": {
                "source": "牛",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲橋は下町でも目抜きの場所であるから、市などの景況も下町気分で浅草とはまた変った所がありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "歳の市のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "刻限も丁度頃なら、場所も目抜の場所であるのに、客の姿はひとりも見えないのである。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "目抜きのつかい手の肝心な腕切ってかたわにしておきゃ、雑兵ばらの二、三百は物の数じゃねえんだから、さすが真田幸村の息がかかった連中だけあって、しゃれたまねしたものだが、ところがそれが大笑いさ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸ビルというのは東京で丸の内ビルディングの事、銀座は同じく目抜の通りと云ったら笑われるかも知れぬ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇妙な喫茶店　以上述べたのは東京の目抜の処の一例であるが、それ以外の低級な処へ行くと、こんな心配も気兼ねもいらぬ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽坂のような震災後の目抜の処でもこの流儀のがある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真、絵、彫刻、ポスター、技芸品といったようなものを、目抜の町の或る家の階上や階下、わかり易い横町の空屋などに並べて見せる。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブル階級の江戸ッ子……すなわち御隠居や若旦那の一人二人、鳶の頭位はいつでも飼っておくからという連中は、もうとっくの昔に東京目抜の通りに帰って来て、古いのれんの蔭から盛に芽を吹いている。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ日本目抜の商店が、「サア来い。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、辻待ちは殆ど東京市の目抜の通りにしか居ないので、ちょっとオックウな場合が多い。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにこの不景気も、日本橋から銀座という東京目抜の通りに来ると、余り眼に付かない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たったこの間まで目抜きの場所へ店を構へて、彼は山と積んだ負債を切抜けてゐたのだった。",
              "citation": {
                "source": "難船",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の一つに、ジャパンというのが、市中目抜きの場所にある。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つのうち二つは目抜きの場所にあり、そのうち新栄座というのが一流で寿座というのが二流どころであつた。",
              "citation": {
                "source": "私の活動写真傍観史",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方がないから、自分たちは目抜の通りへ出て地図を買い、通行人に交って街をぶらつきはじめた。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがね、面白いことには、それから数ヵ月経ってパリへ行ったら、シャンゼリゼーの目抜な映画館で、その「アジアの嵐」をやっているのだ。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワ目抜の大通りに、七階の美しい大建築がある。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪をよごして零下十二度の夜焚火をする樅の木売りも、モスクワの目抜きの広場からは姿を消した。",
              "citation": {
                "source": "モスクワの姿",
                "author": "――あちらのクリスマス――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は町の目抜の商店に勤めてるんだ。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけの用件さえあれば彼女は殆ど半日を活々と、楽しく、東京では目抜きというべき街路の舗道を彷徨えた。",
              "citation": {
                "source": "心の河",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車はそれから国泰寺の方へ出、住吉橋を越して己斐の方へ出たので、私は殆ど目抜の焼跡を一覧することが出来た。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "中尾の伯父に、京橋目抜き通りの地所持ちがいることを知っていたから、保証人は、この人にしてはどうかと勧めてみた。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはともかく、少くとも、その役人が市中でも目抜きの場所に住んでおり、従ってアカーキイ・アカーキエウィッチのところからは、かなりの道程があったということだけは確実である。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴巻町通りは、何といっても早稲田で唯一の目抜きの大通りである。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷には騒擾が起り、電車焼打ちがあって、市内目抜きの場所の交番、警察署、御用新聞社の打｜壊しなどがはじまり、忠良なために義憤しやすき民衆は狂暴にされ、全市に戒厳令が布かれて三々五々、銃をもち剣を抜いた兵士が街路に屯し、市中を巡羅するようになった。",
              "citation": {
                "source": "一世お鯉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の目抜き通りの上町下町をとおして、両側に、物売りが並ぶ。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "目に其形は認めぬけれども周圍は皆讎敵のやうな心持がしてゐる矢先にこの南京蟲が現はれた。",
              "citation": {
                "source": "續俳諧師",
                "author": "――文太郎の死――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
