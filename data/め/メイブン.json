  {
    "uuid": "155dde50-1ebe-59ea-8d59-9a8befd858ed",
    "entry": "銘文",
    "reading": {
      "primary": "めいぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
