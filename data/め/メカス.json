    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to adorn oneself",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "男でも化粧する人はある。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そういう人も化粧すればなお美しくなる。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "化粧するのが面倒でしないのは仕方がない。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜田川守貞の『近世風俗志』に「首筋に白粉ぬること一本足と号つて、際立たす」といい、また特に遊女、町芸者の白粉について「頸は極て濃粧す」といっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝内部　泣きの涙で化粧する君江。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は火を使用する動物なりという定義とほぼ同等に化粧する動物なりという定義もできるかもしれない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを七ツ道具として別に鶯の糞と烏瓜とこれを糠袋に和して用ふ、然る後、化粧すべし。",
              "citation": {
                "source": "当世女装一斑",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はよく晴れて、沼を囲んだ、樹の袖、樹の裾が、大なる紺青の姿見を抱いて、化粧するようにも見え、立囲った幾千の白い上※が、瑠璃の皎殿を繞り、碧橋を渡って、風に舞うようにも視められた。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　　鵠わかうどなゆめ近よりそ、かのゆくは邪宗の鵠、日のうちに七度八度潮あび化粧すといふ伴天連の秘の少女ぞ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、街を歩いていて、さる人に会った時、相手を少し口惜しがらせるお化粧するの。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫は譯もなき戲言をも、面白くいひ出でゝ、我をも人をも興ぜさせ居たりしが、俄にこゝろ付きたるやうに※を見て、はや化粧すべき時こそ來ぬれ、今宵は樂劇の本讀のうちなる役に中り居ればとて座を起ち、側なる小房のうちに入りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "橘作次郎――「化粧する女」「鮒」私は後者に好感をもつ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "化粧することを心得、スカートの長さがいつも変って、ノートの隅に小さな字で詩人の名ばかり書き並べていようという。",
              "citation": {
                "source": "寒の夜晴れ",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡に向かって化粧する。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "か　賢い鴉は黒く化粧する。",
              "citation": {
                "source": "藤村いろは歌留多",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は――これも好奇心を呼び起す或る原因だったと云えるが――割に、夜化粧することの好きな外国婦人としては粗末な服装であった。",
              "citation": {
                "source": "三鞭酒",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学ずきさえも、もし美しく化粧することを忘れない程度ならサロンの風変りな花形として黙認した。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、ここに問題なのは、その文学の中に女心を装っている婦人作家たちが、今日男に「かえっていとおしく」思われる効力を自覚しないで、無心に、鏡に向って余念なく化粧する女のようなこころで、女心をその作品のうちに装っているであろうか、ということである。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "17鵞毛のやうにゆききする　風にさそはれて朝化粧する薔薇の花。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "京の女は鴨川の水で化粧するので色が白い、といふことは物の譚にも聞いてゐたし、また実際、ついその頃まで田舎の漁師村の、日焼け汐焼けのした女ばかり見てゐた私の眼には、誰も彼も皆その様に思はれたが、併しお信さんはまた格別だつた。",
              "citation": {
                "source": "乳の匂ひ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局此文字は後世の文字で、瞞著を化粧する第二の瞞著に過ぎないものであるとの判斷に歸着する。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "化粧すれば、そうみっともない女でもなかったが、素顔の時は呆れるほど平凡な泥臭い百姓の娘さんだった。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は此女連中の化粧する所を興味を以て観て居るが、いろんな白粉を顔から胸や背中へ掛けて塗り、目の上下にはパステルの絵具のやうな形をした紫、黒、群青さまざまの顔料を塗るのは、随分思ひ切つた厚化粧だが、仕上を見ると大分に容色を上げて居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは辞退して其女と一緒に歩いたことは無かつたが、おれは其女の巧に素早く化粧する所を彼れの部屋で見せて貰つたことなどもあつた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんならお化粧すりゃあいいワ」　雨の音にききほれてぽかんとした声で云った。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡くなつた歌右衛門が、小杉天外の「はつ姿」か「こぶし」かの女学生を演じて、舞台で上半身肌脱ぎになつて化粧する場面を見せたなどは、芝居の方からは謂はゞ邪道である。",
              "citation": {
                "source": "役者の一生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡くなった歌右衛門が、小杉天外の「はつ姿」か「こぶし」かの女学生を演じて、舞台で上半身肌脱ぎになって化粧する場面を見せたなどは、芝居の方からは謂わば邪道である。",
              "citation": {
                "source": "役者の一生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "従者　何故、そんな不吉の歌をお化粧する間もお歌いなされたのでござりましょう。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）わが家へと入りてみれば　　なごやかにうちまじりつつ秋の日の夕陽の丘か炊煙か　　　　われを暈めかすもののあり　　　　　　　　　　　　古き代の富みし館の　　　　　　　　　　カドリール　ゆらゆるスカーツ　　　　　　　　　　カドリール　ゆらゆるスカーツ　　　　　　何時の日か絶えんとはする　カドリール！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "想う刹那に、山々の方から健在のしるしの応答えが翁の胸をときめかすことによって受取られた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
