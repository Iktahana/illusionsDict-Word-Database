    "definitions": [
      {
        "index": 1,
        "gloss": "to order",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "伯はかたわらのフィンを呼んで「あの帆柱のそばの背の高いやつを射よ」と命ずる。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで庄屋になった人が「カアチ／＼鉄砲打て」と命ずると、「カアチ（加八）」になった子が「何を打ちましょう」と聞く。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "義務は、私に努力を命ずる。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "休止の無い、もつと、もつとの努力を命ずる。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は野の獸のやうに、何物の理性にも捉はれないで、眞の本能が命ずるままに、純眞の感情生活を送つてゐた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつのまにか私の片隅の卓子に私の夜の恋人があらわれるとボーイにシャンパンを命ずる。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「地球圖」序太宰治「新潮」編輯者楢崎勤氏、私に命ずるに、「ちかごろ何か感想云々」を以てす。",
              "citation": {
                "source": "「地球圖」序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の科学と芸術とは見たままに描けと命ずる一方で、なんだか絵として見た時に不自然ではないかという気もするし、年取った母がいやがるだろうと思ったので、とうとう右衽にごまかしてしまったが、それでもやっぱり不愉快であった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "解散を命ずる」　かうして事務所は廃止になりました。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の意気地なさを冷笑するかのように……私を圧迫して絶対の服従を命ずるかのように……。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二郎はかの方に顔を負け、何も知りたまわぬかの君は、ただ一口に飲みたまえと命ずるように言いたもう、そのさまは、何をかの君かく誇りたもうぞと問わまほしゅうわが思いしほどなりき。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その仕組みがおもしろい、甲の手紙は乙が読むという事になっていて、そのうちもっともはなはだしい者に罰杯を命ずるという約束である。",
              "citation": {
                "source": "遺言",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初父はこれを許さざりしも急にかれの願いを入れて一日も早く出立せよと命ずるごとくに促しぬ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく躊躇していたがファニーはやがて私の命ずるままに私の側近くすわった。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、お前に命ずる処のものは、お前に取って堪え得られる分際のものでしか無い。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "くめ子は苦笑して小女に「うるさいから薬味でも沢山持ってって宛てがっておやりよ」と命ずる。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "依って今日より七日間当ムムネ市の街路の掃除を命ずる。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "依って明日より二十二日間、ムッセン街道の見まわりを命ずる。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此遊歩の間、武村兵曹の命ずる儘に、始終吾等の前になり、後になつて、豫め猛獸毒蛇の危害を防いで呉れた、一頭の猛犬があつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう云ふときにじたばたしない修練は或は必要かもしれないが、さもないことで、神経の昂ぶるに任せて、目の前に見るやうな一幕ものの舞台を考へると云ふことなど、その光景から恐怖や欝憂を握まされると云ふことなど、みんな意思の命ずる処ではないのだ。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は大正の初年から松竹興行会社の専属となって、会社の命ずるままに働いていた。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも東京生れの、言葉使いの歯切れよい、分に過ぎた女房であったが、千恵造は兄の命ずるまゝに従った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしがこの盗人を生き埋めにせよと命ずるのだ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（母親、目顔で祭にいく子どもたちにだまっておいでと命ずる）母　　　にいちゃんたちはね、学校で式があるので、いかなきゃならないんですよ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親、身ぶりでいきなさい、と長女に命ずる。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜田博士は、さらに奥羽の沿革を説き、「頼朝の奥羽平定以後と雖も、その統治に当り自然他と同一なること能はず、『出羽陸奥に於いては夷の地たるによりて』との理由のもとに、一旦実施しかけた田制改革の処分をも中止して、すべて秀衡、泰衡の旧規に従ふべきことを命ずるのやむを得ざる程であつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰そあれ、水を持て、と氏郷が命ずる。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくよく事情を察するに、当時は恋愛至上主義の行われていた世で、女は愛情の命ずるがままに行動して、それで自から欺かぬ、よい事と許されていた惰弱時代であったから、右衛門の母は兼盛と、手を繋いで居た間に懐胎したが、何様いう因縁かで兼盛と別れて時用の許へ帰したのである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "奉儒の国は子孫なからざるべからずと命ずるに因れり。",
              "citation": {
                "source": "愛と婚姻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "神主はしかつめらしくそれに和田津海の神社と云ふ名を命ずる。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
