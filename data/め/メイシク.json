          "standard": [
            {
              "text": "「青い海」という名詞句が、この詩の冒頭で象徴的に使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "複雑な修飾語を伴う名詞句を解析し、文全体の意味を読み解く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "翻訳の際、一単語では表現できないニュアンスを名詞句で補う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それが、「鳴かむ」といい、「山ぞ」で代表せしめられている観があるのも、また重厚な「高野原の上」という名詞句で止めているあたりと調和して、万葉調の一代表的技法を形成している。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            }
          ]
        }
