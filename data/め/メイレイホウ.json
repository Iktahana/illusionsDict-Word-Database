        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "命令法５・２東京日日（夕）　文典といへば、どんな学生でもが虫下しの薬のやうに厭がる学科である。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれをどんな風にいひかへたなら、命令法になるかためしてみますから。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それを命令法にいひ替ると……」　未来の将軍は腹一ぱいの声でわめいた。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの法律の規定は概ね皆な因果法の規定となっておって、命令法の体裁をなしているものは殆んどない。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やすらへ」は「やすらふ」の命令法であつて、ぐづ／＼する事である。",
              "citation": {
                "source": "花の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "命令法の練習であったとは情けなし。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルナアルさんは、しどろもどろになり、自動詞と他動詞を間違えたり、不定法の現在と命令法の複数を間違えたりする。",
              "citation": {
                "source": "葡萄蔓の束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
