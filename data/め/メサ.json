        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この鳥が、たとえば「モシモシカメヨカメサンヨ」というのが、一応はいかにもそれらしく聞こえる。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奉行ヲヤメサセナサイ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青煙突は英吉利の貨物船・黄地にＱ字の検疫旗を揚げたメサジェリイのふらんす船・デラクサ号は伊太利船だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏国メサジュリイ・マリチイム会社に属するその汽船は四月十三日の晩に神戸を出て十五日の夜のうちには早や上海の港に入った程の快よい速力で、上海から更に香港へ向け波の上を駛りつつある時であった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年後に、ある婦人記者が、マルヴィ氏を追った軍閥の一人、大戦当時の陸軍大臣メサミイ元帥―― Messimy から驚くべき告白を取った。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "マグロ、イカ、タコ、シメサバ、タイラガイにて近頃になき豪華のもの。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "イケノカメサンタチモ　ウツラ　ウツラト　ヒナタボツコヲ　シテヰマス。",
              "citation": {
                "source": "オマツリ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カメサン　ノ　サウダン村山籌子　ポカポカトアタタカイ　アキノヒデシタ。",
              "citation": {
                "source": "カメサン　ノ　サウダン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オイケノカメサンタチモ　ウツラ　ウツラト　ヒナタボツコヲ　シテヰマス。",
              "citation": {
                "source": "カメサン　ノ　サウダン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレデ　ミナサンモ　ゴランニナルヤウニ　カメサンハ　ミンナ　イマダニ　ハダカデ　クラシテイルト　イフワケデス。",
              "citation": {
                "source": "カメサン　ノ　サウダン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一塩のシメサバにすると魚屋の店頭にあったものとは比較にならない。",
              "citation": {
                "source": "小鰺釣",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "不二男君も結婚に早いという年でもないのですから、よいオヨメサンでも見つけてあげると落ちつくかも知れませんよ」　署長はおだやかにこうとりなした。",
              "citation": {
                "source": "山の神殺人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはオヤジのオヨメサンにすぎないです。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "オメサン助けてくんなれや」　と云って、馬吉のオカカが庄屋のところへ泣きこんだ。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "花天狗流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "古歌では松にイロナグサ、オキナグサ、ハツヨグサ、トキワグサ、チエダグサ、チヨギ、ソチヨグサ、スズクレグサ、タムケグサ、メサマシグサ、コトヒキグサ、ユウカゲグサ、ミヤコグサ、クモリグサ、ヒキマグサ、モモクサなど沢山な名がある。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはササユリの小形な一変種で葉緑がやや白く、私はこれをフクリンササユリと名づけておいたが、ヒメササユリと別称しても悪くはない。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右のほかヒメサユリ、タケシマユリ、タツタユリ、ハカタユリ、カサユリなどの種類がある。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "オシラサマという言葉は東北でも北の三県にしかなく、南の方ではオクナイサマ、トウデサマまたはトデサマ、シンメサマなどという所がある。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はクラウディウス帝の夫人であるメサリナのみだらな友達の１人であり、紀元後48年に処刑された。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "オカシナヲ自分ノ日記ニ書イテイルカドウカ知ラナイガ、書イテイタトシテモ僕ガソレヲ読マナイデ（アルイハ読マナイフリヲシテ）イルヲ認メサセルタメニ敏子ヲ使ッタ？",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何べん言ってきかせてもダメであるばかりか、そんなオメサマ、何千里も海を渡ってとんできて、こんな山奥へ、そんなムダなこと、しませんテバ、と口ごたえする。",
              "citation": {
                "source": "淪落の青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "カメの枕をけとばして、このヤローなぜ消さんか、なんべん言ったら納得するんだ、するとカメは、ねむたい時は返事もせず、枕をけとばされてもグウグウねむり、起きてる時は、「なアにさ、オメサマ、ここへ落ちれば、いゝもんだ。",
              "citation": {
                "source": "淪落の青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "オメサマも兵隊に行って性根直すといゝもんだ」「キサマ、オレが戦死すればいゝと思っているな」「ハア、戦死せば忠義なもんだ。",
              "citation": {
                "source": "淪落の青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "オメサマみたいな慾タカリのイクジナシれも神様にしてくれるもんだ。",
              "citation": {
                "source": "淪落の青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "オメサマ、敵のタマが尻ッペタから前の方へぬけたもんでは、恥なもんだガネ」「キサマ、主人を慾タカリのイクジナシと言ったな」「言うたもんだ。",
              "citation": {
                "source": "淪落の青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "オメサマが火つけたもんだがネ」「お前らの緊張が足りんから、オレが火をつけて、ためしたのだ。",
              "citation": {
                "source": "淪落の青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョンソンのカウボーイ・ブーツがアメリカの好戦的保守主義のシンボルではありえないとおなじく、ボブ・ディランもまたアメリカの若い世代のメサイアではなく、『風に吹かれて』であやうくメサイアになりかけたディランは、自分がメサイアになることの不当性と不可能性に気づくと同時に電気ギターをとりあげた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "包帯だらけの顔を見た、東宝の一事務員曰く、「ロッパとホウタイ」僕曰く、「ロッパのトビヒメサマ」四月十八日（木曜）　今朝も、口を洗ひ、眼を拭いたゞけだ、気色悪し。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
