[
  {
    "uuid": "fe73cbba-d1eb-54a7-9731-840896475f73",
    "entry": "巡らす",
    "reading": {
      "primary": "めぐらす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
