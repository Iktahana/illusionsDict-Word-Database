    "definitions": [
      {
        "index": 1,
        "gloss": "absurd",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やり切れねえなあ、嬶は又腹を膨らかしやがったし、……」彼はウヨウヨしている子供のことや、又此寒さを目がけて産れる子供のことや、滅茶苦茶に産む嬶の事を考えると、全くがっかりしてしまった。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、猫入らずまで混ぜてあったのだが、兎に角私は、滅茶苦茶に甘いものに飢えていた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は頭を抱えながら、滅茶苦茶に沢山な考えを、掻き廻していた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗くて、暑くて、不潔な、水夫室は、彼が「静か」になったにも拘らず、何かが、眼に見えない何かが、滅茶苦茶に暴れまくっていた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "――滅茶苦茶に手前等は儲けやがって、俺たちを搾りやがるから、いずれストライキだよ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドドーン、ドドーン、ドーン、バラバラ、ドワーン　小林の頭上に、丁度、彼自身の頭と同じ程の太さの、滅茶苦茶に角の多い尖った、岩片が墜ちて来た。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅に、滅茶苦茶に涙を流しながら、引き起そうとする子供の力だけ、その冷たい首を上げるだけであった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝棚倉宅　三次門弟相手に、　滅茶苦茶に暴れ廻る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉、尚も舞台を歩き廻り乍ら平土間に、Ｔ「此村大吉が芝居を　滅茶苦茶に　ブッ壊したんだ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓硝子、扉、壁、屋根、すべてが滅茶苦茶だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "波※伯部は戸倉を打って四十二歳で殺された主の仇を復したが、管領の細川家はそれからは両派が打ちつ打たれつして、滅茶苦茶になった。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅茶苦茶に、それこそ七花八裂である。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この後の三、四年間の生活は滅茶苦茶で、写真をとってもらうような心の余裕も無かったし、また誰か物好きの人があって、当時の私の姿を撮影しようと企てたとしても、私は絶えずキョトキョト動き廻って一瞬もじっとしていないので、撮影の計画を放棄するより他は無かったでしょう。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年、佐渡へ御旅行なされて、その土産話に、佐渡の島影を汽船から望見して、満洲だと思ったそうで、実に滅茶苦茶だ。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅茶苦茶に、ぶん殴りたい。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにまた、味の素を振りかけるとは滅茶苦茶だ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雫石、橋場間、まるで滅茶苦茶だ。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して滅茶苦茶に酔つぱらつて、勃凸の例の研ぎすましたジヤック・ナイフを自分の脚に突き刺して、その血を顔中に塗りこくつて、得意の死の踊りといふのを気違ひのやうに踊つた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角証拠不十分といふことで放免になる朝、写真機の前に立たされた勃凸は、シャッターを切られるはずみに、そつぽを向いて、滅茶苦茶に顔をしかめてしまつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……おんつぁんがゐねえばもう俺は滅茶苦茶さ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "座敷はまるで滅茶苦茶だつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前ん、誰も知るまいし、また知らせるようにもせんですだが、俺はお前ん、二階から突出されて、お孝の内に出入りが出来なくなってからは、天に階子掛けるように逆せ上って、極道、滅茶苦茶、死物狂いで、潰れかけた商会は煙にする、それがために媽々は死ぬ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と一聲吾等は周章狼狽て鐵檻の車の中へ逃込んだが、危機一髮、最後に逃込んだ武村兵曹はまだ其半身が車外にあるのに、殆んど同時に飛付いて來た雄獅子のために、ズボンは滅茶苦茶に引裂かれ、片足の靴は無殘に噛取られて、命から／″＼車中に轉び込んだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は滅茶苦茶に不満なんだ。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と郷右衛門めかしておおせを伝え、直ちに御前を退散して、御供の車夫に様子をたたけば、三吉がらてきという鬱いだ顔色、ほっとせし気味にて長歎息吐き、「何だってお前様、滅茶苦茶に真闇だあ、どうも人間｜業じゃねえぜ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "花壇には和洋の草花の種を滅茶苦茶にまいた。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の私服警官が粉煙草販売者を引致してゆく途中、小路から飛び出して来た数名がバラバラツと取りかこみ、各自手にした樫棒で滅茶苦茶に打ち素手の警官はたちまちぶつ倒れて水溜りに顔を突つ込んだ。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――というよりは、むしろ、今夜の小郷はもうそんな滅茶苦茶なことでも強引に押してしまわねば、ひっ込みがつかぬぐらい、物狂おしく乱れていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、とにかく滅茶苦茶であった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからＳ署の前まで来た時、さすがにいきなり飛び込んで行くような、滅茶苦茶な真似はしなかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
