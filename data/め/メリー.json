          "standard": [],
          "literary": [
            {
              "text": "（明治四十年十二月二十九日『東京朝日新聞』）　　　　　　　　　五十七　　　　　　婦人と動物学者　テキサス大学のモントゴメリー教授は、衣服その他の粧飾に鳥類の羽毛を使用する事を絶対的に禁じたいと論じている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女皇陛下の電話　昨年の暮ポルトガルの女皇アメリー陛下がパリに御滞在中の出来事である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "交換手は「七十五番ですからも少し御待ちなさい」とやると失望の嘆声が聞えてやがて「アメリー女皇から英皇へ御話しがしたいのだが」と云った。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "××開始、ウェートレスの英国の少女、メリーをからかってしたたか膝を折られ泣面をしている男。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、メリーは僕を見ると恋愛相談所めがけて夢中に走り出した。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "奔流、ごろつきのような波の音が僕に英国少女メリーの靴の踵と、乳房に鬘をかむったような女主人を思い出させた。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に控え室となっていた教場の机の上にナイフでたんねんに刻んだいろいろのらく書きを見ていたら、その中に稚拙な西洋婦人の立ち姿の周囲にリリアン・ギッシュ、メリー・ピクフォードなどという名前が彫り込んであった。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると花子さんもねむったままで、「メリーさん、メリーさん」　と呼びました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポチもメリーちゃんも焼けずにいて、早くお迎えに来て頂戴っておまねきをしていましたから」　と言いました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は悲しくなってシクシク泣き出しましたが、やがて花子さんはばあやのお庭の隅に、「メリーさんのお墓」と書いた木の札を立ててコスモスやケイトーの花を上げて拝みました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎さんは、「ポチが生きていればメリーチャンもきっと焼けないでいるよ。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "りんごをかじりながら街頭をあるくよりも、環視の中でメリーゴーラウンドに乗るよりもむしろいい事かもしれないのに、何かしらそれを引き止める心理作用があって私の勇気を沮喪させるのであった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかおおぜいで先生を引っぱって浅草へ行ってルナパークのメリーゴーラウンドに乗せたこともあったが、いかにも迷惑そうではあったが若い者の言うなりになって木馬にのっかってぐるぐる回っていた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこのナンバーワンのメリーという女を彼は月六十円で世話しているのだった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "メリーは仲々いゝ体を持ってるが、狡い。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに負けまいとメリーゴーラウンドの台が浪を打って廻転する。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸行無常のメリーゴーラウンドに乗っているこどもです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も人生を諸行無常のメリーゴーラウンドと感じて、楽みを恣にするときの人間の哀れさを胸に覚え出したためでしょうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にメリー女王殿下の閲兵を受けるエンパイヤ・デー（帝国紀念日）の女軍観兵式にはアグネスは女士官として佩剣を取って級友を率いた。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の黒く塗られた板塀について曲るとだらだら坂になり、丘の上のメリー皇后の慈善産院の門前へ出た。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は立派な物理学の機械に優って、立派な天文台に優って、あるいは立派な学者に優って、価値のある魂を持っておったメリー・ライオンという女でありました。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "男同志時々眼と眼とを見合せて、一寸微笑むだけで、各々取り済した円陣をつくつて「メリーゴーラウンド」を保つた。",
              "citation": {
                "source": "明るく・暗く",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『メリー・ポピンズ』の予告が出ている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「メリークリスマス。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ワラさんが、早くコーヒーをもってこいって」39もうメリーゴーラウンドからは降りたんだそうするしかなかっただけさ〈ウォチング・ザ・ウィールズ〉ジョン・レノン　局で、ワラとふたりで楽しそうに笑い声をたてていた令子は、シャワーでも浴びてきたのだろう、すっきりした表情だった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、その後に、「電波嬢」一名メリー・ウェルズなる人造人間を作るが、これが世にもまことに麗しい妙齢の婦人の相貌を備え、しかも機械力で二十人力の腕力があり、要所要所に六個の耳を備えて居り、時速六十｜哩の快速力で、駈け出すことができるという鬼神のお松そっちのけの人造人間である。",
              "citation": {
                "source": "人造物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "このメリー・ウェルズを助手のピーターが操縦盤と一緒に盗み出し、強盗殺人をやらせるが、その働きは実に非凡である。",
              "citation": {
                "source": "人造物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンシルバニア地方を代表したフイラデルフイア大学はタフトを、ニユーハンプシヤイア地方からのハーバード大学はマツキンレイを、そしてメリーランド地方としてはワシントン大学がルーズベルトを支持した。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
