[
  {
    "uuid": "3378ef8e-cf47-5deb-ad45-dc90f282d801",
    "entry": "名盤",
    "reading": {
      "primary": "めいばん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "famous (musical) recording",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あのたおやかな古文の妙、たとえば真名盤の香を瑰の芳烈なる薫か、ヘリオトロウプの艶に仇めいた移香かと想像してみると、昔読んだままのあの物語の記憶から、処々の忘れ難い句が、念頭に浮ぶ。",
              "citation": {
                "source": "『新訳源氏物語』初版の序",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の中の照明は薄暗く、壁には名盤のレコードジャケットがポスターがわりに貼られている。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の管弦楽で、メンゲルベルクの指揮した「アルキーナ組曲」（ビクターＪＥ一八七―八）は名盤の一つだ。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァイオリンでカール・フレッシュのひいた勇しくも楽しい「行進曲」などは、いつまでも名盤の声価を保つ傑作だろう（ビクターＥＷ六七）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブッシュの端麗さと、その室内楽的なまとまりのよさを特色とし、わけても第二番（ロ短調）のフリュートの組曲は、フリュートを名人モイーズが受け持った名盤であるが、この曲に限り、吹込みは古くとも、コロムビア盤のメンゲルベルク指揮（Ｊ七八九一―三）に捨て難い良さがある。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに第二のホ長調の協奏曲にはＨ・Ｍ・Ｖの旧盤にティボーの名演奏があり、市価数百金と称せられ、複協奏曲にはビクターの旧盤にクライスラーとジンバリストの組合せによる名盤がある。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "レコードはやや吹込みの古きを我慢すれば、ビクターにアルバート・コーツがフィルハーモニック合唱団とロンドン交響管弦団を指揮した名盤がある。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イギリス組曲」も六曲のうち第二番のイ短調のが、ランドフスカの演奏でバッハ協会の第五集に含まれているが、これなどは名盤にかぞえられるものだろう。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの一つ一つは名盤にかぞえられるもので、ハイドンの良さを満喫させるであろう。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "クライスラーには電気以前の吹込みでこの曲の名盤があったが、今は手に入れる見込もない。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ティボーのモーツァルトは一種の風格と情愛を持ったもので、これも名盤であったが、吹込みが非常に古い（ビクターＶＤ八〇四八―五〇）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、やや古い吹込みではあるが、コロムビアのワインガルトナーも捨て難い名盤である。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界名盤集にワルターの指揮したのがあるが、ロンドン交響楽団は少し質が落ちる。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "作品一三一の「四重奏曲｜嬰ハ短調」は後の二曲と共にベートーヴェンの最大傑作だが、演奏はカペエとブッシュと二つの名盤がある。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "カサルス（チェロ）とシュルホーフ（ピアノ）の「チェロ・ソナタ＝イ長調作品六九」は絶対的な名盤で、吹込みの古いにかかわらず、この広大な気魄と、堂々たる威容に帽子を脱がせる。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し古いがポリドールのベルリン・フィルハーモニーを指揮したフルトヴェングラーのもの（Ｓ四〇四一、フルトヴェングラー名盤集）と、新しいのではコロムビアにワルターがロンドン交響楽団を指揮したのがある（ＪＳ一一五）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "レコードはビクターにシュナーベルの名盤がある（ＪＤ一〇八七―九一）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「楽興の時（作品九四）」には、シュナーベルの名盤がある（ビクターＪＤ一五八四―六）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファウストの劫罰及び声楽レコード　ベルリオーズの一代の傑作で、ゲーテの詩によった劇的物語「ファウストの劫罰」は、ビクターから全曲十枚物の名盤が出ている（ＪＨ七四―八三）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つの即興曲と幻想即興曲はこれもビクターにコルトーの名盤があり（ＪＤ二六四、ＪＤ二六五）、なんといっても他の追従を許さない。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この曲の演奏ではコルトーと違った意味で女流のタリアフェロ（コロムビアＪ八三六九）やロン（同名盤集）やシャーラー（同ＪＷ一二六）に面白さがある。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロムビアのロンも女らしさを買われようか（名盤集）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "このレコードはビクターに名盤が二つある。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "レコードではビクターにコルトーの名盤がある（ＤＡ二一〇九―一二）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "レコードではビクターにコルトーの名盤がある（ＪＤ三四七―五〇）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヴァイオリン・ソナタ」には良いのがなく、「ピアノ三重奏曲＝ニ短調（作品六三）」にコルトー、ティボー、カサルスの名盤がある（ビクターＶＤ八二三二―五）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちで私は五年前の旧著「ロマン派の音楽」に書いたことをもう一度繰り返して、メンゲルベルクがコンセルトヘボウを指揮したレコードを名盤として挙げたい（コロムビアＪ七六一一―二）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二番のハンガリー狂詩曲を管弦楽に編曲したのは、少し古いがビクターにストコフスキーがフィラデルフィア管弦団を指揮した名盤があり（ＪＤ一二三六）、吹奏楽ではコロムビアにデュポンの指揮したギャルド・レピュブリケーヌの名演がある（Ｊ三二三四）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけてもエリッツァの「歌の殿堂」は名盤の一つであったと思うが廃盤になっている。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「前奏曲」と「イゾルデの愛の死」と一緒にしたのが、フルトヴェングラー指揮、ベルリン・フィルハーモニック管弦団で、ポリドールにも（六〇一九六―七）、コロムビアにも入っている（Ｓ一〇四四―五、名盤集第三集）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
