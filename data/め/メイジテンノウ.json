    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Emperor Meiji (1852-1912, reigned 1867-1912)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "○七月、明治天皇御不例に付き、各劇場は二十日頃より相前後して休場。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦悩の年鑑太宰治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）狐｜：ルビの付く文字列の始まりを特定する記号（例）明治天皇｜崩御の時の思い出である。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　これは明治天皇｜崩御の時の思い出である。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間うちは文部省出版の明治天皇御集をよんでいました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "石井氏は明治天皇の臨御になつた三條公の邸宅を買つて白鬚橋畔に之を奉安し、自もまた傍に住んだが、この家の後ろ横にも、その土藏を移した。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "石井氏は明治天皇の臨御になつた三条公の邸宅を買つて白鬚橋畔に之を奉安し、自もまた傍に住んだが、この家の後ろ横にも、その土蔵を移した。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "此年一月末明治天皇は畝傍御参拝の為軍艦に召されて神戸に御着、京都にあらせられた。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治維新と国体観念　慶応三年十二月九日、明治天皇小御所に出御、諸卿諸侯を召見し給ひて、皇政復古のことを諭告し給うた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時に於て、明治天皇は三條｜実美を召されて、徳川家の旧勲を失はざるやうに処置せよ、との有難き宸翰を賜うてゐる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶喜、西郷などの立派な国体観などもさることながら、一たび、明治天皇の御洪大なる大御心に思ひ及ぶ時、明治維新史の花を観る心持がするのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、五箇条の御誓文に依り、憲法を制定し、立憲政治を行ふといふことは、明治天皇の叡慮であつたと拝察してよい。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば、明治十二年の夏、アメリカのグラント将軍が来朝するや、明治天皇は、将軍を浜離宮に召されて、政治上の事を、いろ／＼御下問になつたが、将軍の、「承るところに依れば、日本にも国会開設の議論がある由、いづれ憲法を御制定になることと存じますが、何事も忌憚なく言上せよとの御沙汰であるから、申上げます。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば、憲法制定、立憲政体の実施については、政府に於ても、明治天皇の大御心に依つてその大方針が確立してゐたのであるから、当時に於ける自由民権運動の騒ぎは、藩閥政府の強権に対して、不平分子が国会開設の名を利しての抗争とも見るべきであらう。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治二十一年四月、憲法草案は、明治天皇の御前に奉呈された。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鋒刃の威を仮らずして、坐ら天下を平げん」と考えられた神武天皇は、遂に度々武力を御用い遊ばされ、「よもの海みなはらから」と仰せられた明治天皇は、遂に日清、日露の大戦を御決行遊ばされたのである。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "終ると先方から、「現在の日本の財政では無理である」「無い袖は振られない」というようないろいろの抗議的説明や質問があったが、私は「私ども軍人には明治天皇から『世論に惑わず政治に拘らず只一途に己が本分』を尽すべきお諭しがある。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉の句碑二つ、明治天皇聖績碑（東郷大将題）。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは十一月三日、明治天皇の天長節で、恰度菊の盛りの頃にあった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは八月二十七日にあった明治天皇の即位のために、八人のものが特赦を受けたので、兵士とは並の兵卒である。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも彼女の手紙によれば、それは明治天皇の愛用し給うたネク・タイであり、彼女のそれを送つて来たのは何年か前に墓になつた母の幽霊の命令に従つたものだとか言ふことだつた。",
              "citation": {
                "source": "変遷その他",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "又彼等の或ものは明治天皇の愛用し給うた――これだけは正直に白状すれば、確かに僕にも難解である。",
              "citation": {
                "source": "変遷その他",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と畳へ米という字を書くと、坊主は金がほしくなったので、ひとの葬式を待っていると笑ったが、八十八歳の三月、明治天皇銀婚の御祝いに、養老金を頂いて、感激して、みんなにお赤飯をふるまい、ずらりと並べて箸をとらせ、見ていて死ぬともしらずに死んでいった。",
              "citation": {
                "source": "西川小りん",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "大元帥を兼ねさせられた明治天皇の御製を拝見しても、世界人類を一視同仁の中に包容し給う御聖旨をしばしば示されているにかかわらず、侵略主義征服主義の覇王的な御精神は少しも窺うことが出来ません。",
              "citation": {
                "source": "三面一体の生活へ",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は講和条件に現われたような思想が到底明治天皇の「教育勅語」の道徳と一致するものとは考えられません。",
              "citation": {
                "source": "非人道的な講和条件",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勧進帳」その他が、明治天皇陛下、皇后宮、皇太后の宮と、天覧につづき台覧になったことは、劇界ばかりではない、諸芸の刺戟になったのだ。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な天下を巡行したのも、全く同樣の趣旨で、近くはわが明治天皇が、維新以來、或は東海、或は奧羽、或は北陸と巡幸せられたのも、或は同一の理由に本づくことと拜察されるのである。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "この順治・康煕二帝の上諭は、實に新時代の支那の教育勅語で、丁度我が國の臣民が、明治天皇の教育勅語に對すると同樣に、當時の官民は、この上諭の主旨の宣講と貫徹とに全力を盡くした（『清國行政法』卷三、三九八―四〇〇頁參看）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "去る者は日に疎しといふが、千古の大英主たる明治天皇の御鴻徳のみは、深く我が國民の腦裡に印して、決して忘るることが出來ぬのみか、却つて時を經る儘に、愈※景仰の念を増すばかりである。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は茲に明治天皇の御一週年祭に際し、東洋史上より觀たる明治時代の發展を述べて、聊かその御鴻徳の一端を偲びたいと思ふ。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
