    },
    "definitions": [
      {
        "index": 1,
        "gloss": "chance meeting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし前回での男とのめぐり合いののち、富士を眺め上げて、それはただ血の気の做すわざなんだか、もっと深く喰入るべきものがあるような気がしたのを想い出して、自然と抑止するものがあった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はそういう局面にめぐり合いたくない」「が、それが、やがてわれら地球人類の迎えなければならない運命なんだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、ここにこれが、とめぐり合いのよろこばしい感じで心を打って来る刹那の瑞々しさは、作品の世界の一般に欠乏している。",
              "citation": {
                "source": "人生の共感",
                "author": "――求められる文学について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三人が、東京が首府だから自然そこに落ちあったというばかりではない歴史の動きにめぐり合いの機会を与えられたということも、女同士の友情、また婦人作者たちの間にある友情として、やはり新しい性質を含んでいるのだと思われる。",
              "citation": {
                "source": "なつかしい仲間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台の上では、心にない結婚をした女が、永年の後昔の愛人にめぐり合い、蒼白となって地獄と叫んで卒倒していた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五十年｜前に秋山図を見たのは、荒れ果てた張氏の家でしたが、今日はまたこういう富貴のお宅に、再びこの図とめぐり合いました。",
              "citation": {
                "source": "秋山図",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきからいぶかしそうに見ていたダン艇長と酋長ロロも、それと気がついて、ふしぎなめぐり合いにおどろいた。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし幸いなことに、非常に運がよくて、思いがけなくよい下宿にめぐり合い、それですっかり落ちつくことができた。",
              "citation": {
                "source": "サラダの謎",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スミレも、タンポポ、ヒナギクも、広場いっぱいに咲きほこるなかに、ふたりの少女とひとりの少年が、おもわず手をとり合って、ふしぎなめぐり合いに、しばらくは泣きぬれております。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こうしためぐり合いの場所を提供できましたことは、本船の光栄とするところです。",
              "citation": {
                "source": "火夫",
                "author": "DER HEIZER",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑稽でも空巣とのそういうようなめぐり合いは恐縮です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――すでに牢番｜藺仁のみちびきで、呉用、宋江、そのほかも空井戸の口をめぐり合い、中を覗いて、その底知れぬ深さに暗澹と顔見合せている態だった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この爾迦夷さまは、早くから梟の身のあさましいことをご覚悟遊ばされ、出離の道を求められたじゃげなが、とうとうその一心の甲斐あって、疾翔大力さまにめぐりあい、ついにその尊い教を聴聞あって、天上へ行かしゃれた。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "現世でのふたりの思いは、めぐりあいました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや光の増し来れる半輪の月を背に、黒き姿して薪をば小脇にかかえ、崖よりぬッくと出でて、薄原に顕れしは、まためぐりあいたるよ、かの山番の爺なりき。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『浮雲』は私の当時の愛読書の一つで、『あいびき』や『めぐりあい』をも感嘆して何度も反覆していたから是非一度は面会したいと思いながらも機会を得なかった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　『あいびき』及び『めぐりあい』　丁度同時代であった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて『都之花』の発刊と共に『めぐりあい』が五号に渉って連載された。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "国木田独歩の如きは実にその一人であって、独歩一派の自然主義運動は実にこの『あいびき』と『めぐりあい』とに発途しておる。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ翻訳をするにも『あいびき』や『めぐりあい』時代と違って余り原文には拘束されないで、自由｜気儘にグングン訳し、「昔のような糞正直な所為はしない、拙い処はドンドン直してやる」と、しばしば豪語していた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あいびき』や『めぐりあい』を訳した時は一刀三礼の心持で筆を執っていた。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは自然のめぐりあいで、まことに余儀ない破目であるが、これを機縁に再び彼女と親しゅうするなど夢にもならぬことじゃと思え。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれが偶然のめぐりあいではないように千枝太郎には疑われた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ぼくやミドリをさらっていってどうする気なんだろう」　高一は、なんとかしてミドリにめぐりあいたいと、それを思いつづけました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "めぐりあい「しめしめ、電気鳩をうごかすきかいが手にはいったぞ。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び近づくまいと堅く心に誓っていた繁子――坂道――日のあたった草――意外なめぐりあい――白い肩掛に身を包み無言のまま通過ぎて行った車上の人――一切を捨吉はありありと自分の胸に喚起すことが出来た。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "びっくり農場　思いがけない母親とのめぐりあいに、正吉少年はたいへん元気づいた。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、あれから一時間ほど後、四少年は廊下でビル・マートン青年にめぐりあい、意外な真相をきくことができた。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らぬめぐりあい　房枝が目を閉じている間に、三輪車は、どさりと大きな音をたてると、房枝の横を通りぬけた。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……四郎、お前は誰に殺されたのだ」　屍体は肉親の兄｜西一郎にめぐりあい、おのれを屠った恨深い殺人者について訴えたいように見えたが屍体はもう一と口も返事することができなかった。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
