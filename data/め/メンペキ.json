    "definitions": [
      {
        "index": 1,
        "gloss": "meditation facing a wall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "正面壁右隅に隣室に通ずるドアあり。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからマントを正面壁に掛け、机に来て甘味さうに吹かす。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」正面壁に沿い左向き足踏み。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "「達磨は面壁九年やけど、私は三年の辛抱で済むのや。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者よ許せ、我が面壁独語ははしなくも余岐にわたりぬ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "斬るか、斬られるか、真剣抜打の応酬なくんばあるべからざる処を、面壁九年、無言の行だ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "面壁イ九年とやら、悟ったものだと我あ折っていたんだがさ、薬袋もないことが湧いて来て、お前様ついぞ見たこともねえ泣かっしゃるね。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞面目に考へても亦さうだ、子供に對しては怖い點に於て――また、思索家として長年孤獨の情味を味はつて來たのは、面壁九年の心持ちに似てゐる點に於て。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "面壁九年といって、釈迦一代の説法、各宗の精髄どころを達磨という蒸溜器に容れて煎じて、煎じて、煎じ詰める事九年、液体だか気体だかわからない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳業にいそしんで九年面壁した鼻がありました。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "九季面壁非遇然苦行即意志玄旨信道無天然達磨天下文人飯袋子　酔客が腕をふるつたといふこんな七言絶句が壁に誌されてある空々庵といふ彫刻家のアトリヱである。",
              "citation": {
                "source": "ブロンズまで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この暑さに、ぢつとかうしてゐるのは実際「九季面壁」の思ひだね――とＹはよく壁の文字を指差して笑つたものだ。",
              "citation": {
                "source": "ブロンズまで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、僕等の「九李面壁」を回想し得る、今年の彫刻家の制作をながめて、様々な「動」に想ひ走らせよう。",
              "citation": {
                "source": "ブロンズまで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "達磨大師九年面壁の時、眠くてならぬから自分で上下のまぶたを切つて捨てた処に翌朝この草がはえあつた、花が肉色でまぶたの様だつたので、眼皮と名づけたと、和漢三才図会に俗伝をのせある。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "師僧｜般陀羅の遺示により、はるばるインドから唐土に渡って、河南のほとり崇山に庵室をいとなみながら、よく面壁九年の座禅修業を行ないつづけたと伝えられている、あの達磨禅師をかたどった紋様です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればこそ、達磨大師の、面壁九年になぞらえて、わちきも操を守るための修業をしようと、朋輩からさげすまれるほど、あのようなひょうげたものの姿を身のまわりにつけていましたが、お恥ずかしゅうござります……ついここの清さんばかりには心からほだされまして、守りの帯も解いてしまいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "九年面壁非遇然　天下文人飯袋子　私がハチスのトンネルをすかして桃の花を眺めてゐると鳥籠を携へて現れて来た和尚が、こつちを認めて、直ぐに、飲まうぢやないかといふ意味を通じながら、盃を傾ける手真似を示した。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボウイが正面壁間の黒板へ何か書き出す。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、香気と名流と大飾灯と八面壁画とに、帝室アルバアト歌劇場のように天井の高いこの「機会の市場」だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……達摩は面壁九年にして、少林の熊耳と云われました。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に吾人は九年間面壁して弁論を練り、糊塗縦横の政界を打破りまして、あらゆる不平等を平面にすべく……来るべき普選の時代に於て……即ち、その……吾人が……」　と大声をあげるかと思うと、思い出したように右手を高くあげて左右に動かしております。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "面壁三年の例は云うまでもなく、沈黙的修業が如何に仏道に周く採用されてるかは、人の知るところである。",
              "citation": {
                "source": "「沈黙」の話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "面壁九年能く道徳の蘊奥を究むべしといえども、たとえ面壁九万年に及ぶも蒸気の発明はとても期すべからざるなり。",
              "citation": {
                "source": "文明教育論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は法王庁カペラ　シスチナの天井に旧訳聖書を画き、正面壁画に最後の審判を画きながら、ただひたすら人間造型の美を究めようとした。",
              "citation": {
                "source": "（私はさきごろ）",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓は高くて外は見えず終日終夜面壁の修業です。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日三度三度の食事は供へてくれますし、社會のやうに、あくせく働かないでも、生活の心配はなし、いささかも心が散らず、勉學に專心し、終日終夜、面壁靜坐默想に耽ることもできるし、こんな贅澤な生活は、外界では到底できません。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち快楽主義を仇敵として、苦痛主義を本尊となし、世好に反し、人情に逆らい、滔々たる世界｜名奔利走の人に向かってストイックの哲学家たるを求め、これに望むに雪山苦行の釈尊をもってし、これに責むるに面壁九年の達磨をもってする、迂濶にして苛酷なる空論のみ。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "三方損の運命に、甘んじるべきや、否や、これ実に、小生一生の大問題、面壁九年の一大事であったです。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、面壁、一週間足らずで、解決したね。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
