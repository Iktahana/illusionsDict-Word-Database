    "definitions": [
      {
        "index": 1,
        "gloss": "anniversary of a person's death",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "毎月御命日に欠かさず拝みにお出でなさるのは、あの経師職の息子さんばかりで……」「経師職の息子さんは毎月来るかね」「はい、お若いのに御奇特なお方で……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも爾迦夷｜上人と申しあげて、毎月十三日がご命日ぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも爾迦夷｜上人と申しあげて、毎月十三日がご命日じゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日葬式や命日というような儀式は見慣れてきてはいたけれども、自分の家から死者の出たのは、園が生まれてから始めてのことなので、よけいそうした感じが起らないのかもしれなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五日前に赤坊の命日をすました姉は、その日縫物の事か何かで鶴床に来て、店で兄と何か話をして居た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに力三の命日と云ふのに、朝つぱらから何んと思へば一人だけ気楽な真似が出来るんだらう。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、命日は十｜月三十｜日、……その十四五｜日前であつたと思ふ。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "親兄弟もある人物、出来る限り、手を尽くして捜したが、皆目｜跡形が分らんから、われわれ友だちの間にも、最早や世にない、死んだものと断念めて、都を出た日を命日にする始末。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）けふは二日、そちが亡父の命日ぢやぞ。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "高綱　　今日はこゝろざす佛の命日。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎月二日はほとけの命日でござれば、誰にかぎらず、門前をすぐる出家をよび止めて、囘向を頼みまゐらするが家例でござる。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめては亡人の菩提を弔ふために、月の二日を命日とさだめ、供養をおこたらず營んで居ります。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "子之介　けふは月こそ違へ、父樣の御命日で、今まで奧で御囘向をして來ました。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "子之介　むかしの罪を後悔して、毎月二日を命日に、佛事供養をかゝさず營んでくださる殿樣を、いまさら執念く恨むのは……。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の祥月命日、涙なしには母の事は考へられない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペテロの命日は、十月四日でした。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、同じ月、同じ夜の其の命日は、月が晴れても、附近の町は、宵から戸を閉ぢるさうです、眞白な十七｜人が縱横に町を通るからだと言ひます――後で此を聞きました。",
              "citation": {
                "source": "雪靈續記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいでね、命日に、ぼくがまた薬屋からうた時計を借りてきて、やぶの中で鳴らして、アキコにきかしてやったよ。",
              "citation": {
                "source": "うた時計",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何の、隠居さん、なあ、おっかあ、今日は父親の命日よ。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の月の命日に参詣をしました時、山門を出て……あら、このいい日和にむら雨かと思いました。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、同じ月、同じ夜のその命日は、月が晴れても、附近の町は、宵から戸を閉じるそうです、真白な十七人が縦横に町を通るからだと言います――後でこれを聞きました。",
              "citation": {
                "source": "雪霊続記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人ともその命日は長く忘れませんと申すのでありまする。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見えなくなった日を命日にしている位でございましたそうですが、七年ばかり経ちましてから、ふいと内の者に姿を見せたと申しますよ。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "以後、娘の村では、娘の入水の日を娘の命日にして赤飯を蒸し山へ持ち行きて小沼に投げ込む。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼に身を投げた竜女を弔うため、麓の村では毎年、命日に赤飯を蒸してこの沼に投げ込んでやるのですが、赤飯は失せて、容器の殻だけが渚に漂い寄る、それがこれですという案内人の説明でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪作が怪しい死方をしたのでもうほど落ちへ往ってお種を探さなかったが、他に手がかりがないうえにほど落ちにはたしかに櫛があったところから、お種も猪作のような怪しい死方をしているものとして、お種の家ではお種のいなくなった日を命日にしてその冥福を祈ることになった。",
              "citation": {
                "source": "蟹の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしは飯田在の、某村の何某の娘であるが、今から十三年前、ちょうど十六の七月に、近くの川へ洗濯に往っておって、遁れられない因縁から、そのまま山に入って仙人になったが、両親はそれと知らないで、其の日を命日にして、供養してくれるのはありがたいが、仙界ではそれが障碍になって、修行の邪魔になる。",
              "citation": {
                "source": "女仙",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "部落の人は共同風呂を作ったばかりでなく、千代の命日には、風呂供養とも云うべき一種の行事を営んで千代の霊を慰めたが、その日は部落の人たちは、一日じゅう行水もしないで、風呂桶を浄め、そして、それに供えものをし、燈明をあげるのであった。",
              "citation": {
                "source": "風呂供養の話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、八十年目の長者の死んだ命日になると、其の杉は火になって焚けてしまった。",
              "citation": {
                "source": "長者",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓は正方形に近く、やや横の広い面の石に、上下二段に許多の戒名が彫り附けてあって、下には各命日が註してある。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
