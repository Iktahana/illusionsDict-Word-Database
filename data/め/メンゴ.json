    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sorry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕は空気銃をほうり出し、裏から廻って店の奥にはいり、「ごめんごめん、ごめん。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私を愛していてくれたのに、顔を見ると、「お前は子供のうちはめんごかったのになあ」と云った。",
              "citation": {
                "source": "祖母のために",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前のおっかさんはあの舎弟息子を呉れてやって、ちっともめんごがらなかったでねえか」と云ったが、それは違った。",
              "citation": {
                "source": "突堤",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆さんはこの前の日まで中学の教師の家へ手伝に行って居たとか云って、「めんごい赤坊さまでござりますぞい。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮山　ハハ、ごめんごめん。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんにしてやられましたねと女房が言ふと、ふふと嬉しさうに笑つて、枯れた手つきで札をあわててめくつて、二枚下の分までめくつてごめんごめんと言つたりした。",
              "citation": {
                "source": "故郷を辞す",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、「孫は大勢あるが、これが子供のうちから馴染んでいるせいか、一番めんごいことよ」と、伸子を見た。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪雄っていう六つの孫が御秘蔵でね、なーして（どうして）、こんげな（こんな）鬼みてよなばあさまにとっつくだ、というと、雪雄は、そいでもいいんだア、めんごくねえことねえ（かわいくないことない）って云ったと云って、トロトロになって云って居りました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "たむしにアルコールの話や、一つ蚊帳の中に寢てゐて、二人とも布團をころがりだしたから、額と額をぶつつけて目がさめて、同時にごめんごめんといつてゐた話は、芥川がなにかに紹介をしてゐるが、今日からみればあの頃の時代はよかつたと思ふ。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいているところあるかしら」とひどく突慳貪に言い、言ってから、ごめんごめんと弱気に謝る気持で、「――ちょっと財布をアパートへ取りに行ってきますがね」とやさしく言った。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "失敬、ごめんごめん」　とことわる。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
