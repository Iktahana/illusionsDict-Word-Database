        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "将軍、独裁官田中ハ、諸君ヲ山東ニマデヨコサシメタル田中ハ諸君ノ階級ノ最悪ノ敵デアルコトヲ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一等賞から九等賞まではぼくが大きなメタルを書いて、明日枝にぶらさげてやる。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一とうしょう、白金メタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第二とうしょう、きんいろメタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第三とうしょう、水銀メタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第｜四とうしょう、ニッケルメタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第五とうしょう、とたんのメタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第六とうしょう、にせがねメタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「よせ、よせ、にせものだからにせがねのメタルをやるんだ。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第｜七とうしょう、なまりのメタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第八等、ぶりきのメタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なく画かきは、「こんどはメタルのうんといいやつを出すぞ。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一とうしやう、白金メタル。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第二とうしやう、きんいろメタル。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第三とうしやう、水銀メタル。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第｜四とうしやう、ニツケルメタル。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第五とうしやう、とたんのメタル。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第六とうしやう、にせがねメタル。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第｜七とうしやう、なまりのメタル。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なく画かきは、「こんどはメタルのうんといゝやつを出すぞ。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土耳古人たちは、みんなまっ赤なターバンと帯とをかけ、殊に地学博士はあちこちからの勲章やメタルを、その漆黒の上着にかけましたので全くまばゆい位でした。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "７　かしわばやしの夜桃色の大きな月はだんだん小さく青じろくなり、かしわはみんなざわざわ言い、画描きは自分の靴の中に鉛筆を削って変なメタルの歌をうたう、たのしい「夏の踊りの第三夜」です。",
              "citation": {
                "source": "『注文の多い料理店』新刊案内",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それへプラチナ鎖に七宝が菊を刻んだメタルのかかった首飾りをして紫水晶の小粒の耳飾りを京子はして居た。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、儲けた人も随分多く、谷町九丁目のメタル細工屋の丁稚は、純白の十姉妹を捕えて、一財産つくり、大島の対を着て、丹波へ帰って行ったと、大変な評判であった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、結局咄嗟に脱いだ毛糸のシャツと、帽子と万年筆と銀のメタルとで二円五十銭貸してくれた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつどこで相手を抜いたか気付かなかつたが、Ｏ町の決勝点に入つた七郎の胸には、輝やかしい一等賞のメタルが、月の光のやうに光つてゐた。",
              "citation": {
                "source": "月下のマラソン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "天ノ命、二十世紀ノ第一年ヲ以テ此ノ法案ヲ起草セシメタルヲ拜謝ス。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
