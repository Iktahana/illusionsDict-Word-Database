[
  {
    "uuid": "e19adc4e-3ac2-56d5-8c49-73dc9f049e90",
    "entry": "目に映る",
    "reading": {
      "primary": "めにうつる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
