        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おまけに牧野さんが酔ふと発しはじめるのなぞは、当人に自制力がないよりも、周囲が彼にとつてはあまりに不真面目に見える所から起るのであつたと考ふべき点もあるのであるから、さういふ定説が呑気に繰返されることは辛かつたのである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのようなこと、決してないのです』と夫人が言うに対しても、『心からの話、真面目のことです』と言い、『仕方ない！",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "へんに、しらじらしく真面目になるだけである。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」先生は、真面目である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちの面目丸つぶしです」と言って来た。",
              "citation": {
                "source": "無題",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでは僕が、大井広介の面目を踏みつぶした事になる。",
              "citation": {
                "source": "無題",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、人々によつて真面目な手記と見做されてゐるものはすべて、これら寛容な人達、殊には老人の手によつて遺された。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディレッタント達が一番壮大とみえ、真面目に何かをやつてゐる者は驢馬なのである。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "不真面目になつてるからだ。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女には、その真面目臭つた顔の小僧と、先刻「お嫁さん」と云つた時の小僧とが、どうしておんなしなんだらう？",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "達沢は嬉しげにたゞニタニタしてゐたが、ヒヨイと顔を外向けると真面目くさつて、一人の若い運動員に必要もなさゝうなことを云付けてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「偉い者になつて貰はうなんてチヤンともう願はないから、学校だけを平凡で好いから真面目に出て呉れ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "半年くらい通って真面目に働いていたが、自分の骨折って書いたものが一度も紙上へ載らないので此方も出てしまった。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は中学校を出るとすぐに生真面目な紙屋の旦那になっている主人と、自分のような人間との境遇の著しい違いを思い較べていた。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気象輪講会は何となく上品にのんびりしていたし、地球物理輪講会は生真面目でしかも家族的な気分であったが、地理の輪講会には何となく物々しい人間臭い気分があった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ学生の中にはずいぶん不真面目らしい茶目や怠け者も居て一体に何となく浮世臭い匂がこの教室全体に漂っているのを感じた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰れに恐れる事も諛う事も入らぬ、唯我独尊の生涯で愉快だろうと夢のような呑気な事を真面目に考えていた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はぎゆつと眞面目になつた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　眞面目な口調でさういふので、浦島も、或ひはさうかも知れぬと思つたが、しかし、何だかへんだとも思つた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは言ふのもつらいが、飮んだくれのならず者でね、おれはもう恥づかしくて、面目なくて、生れて三十何年間、いや、兄がだよ、兄が生れて三十何年間といふもの、このおれに、迷惑のかけどほしさ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と眞面目な顏で言つて、部屋を出て行く。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく經つと、やはり眞面目な顏をして部屋へやつて來て、「あの、少し値が張りますけれど、よろしうございますか。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その癖、みんな眞面目で、みんな嚴肅な顏をして、みんな高尚な事ばかり言つて、哲學者氣取りでゐますが、それでゐて我々の大多數は百人のうち九十九人まで、まるで野蠻人のやうな生活をして、ちよつとどうかすると、すぐ啀み合つたり、惡口をつき合つたりします。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるものはただ垢と、凡俗と、アジア風の生活ばかりです……僕はあまり糞眞面目な顏が、おそろしくもあれば嫌ひでもあります。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は糞眞面目な話を恐れます。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は讃岐の産れで、国には崇徳上皇の御陵のある白峰という阜陵がある、上田秋成の『雨月物語』や、露伴氏の作として、かなり評判のあった『二日物語』は、この白峰に取材がしてあるが、まさか、あの白峰じゃあなかろうと、真面目になって考えこんだものである。",
              "citation": {
                "source": "日本山岳景の特色",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこの甚だ杜撰な比較が万一この方面の専門家の真面目な研究のヒントにでもならばと思って、思い付いたままを誌してみた次第である。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生赤い涙があるもんですかと、真面目で聞いたのは僕の友達じゃ。",
              "citation": {
                "source": "赤",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは何でもないような事だが、どうして猫が廻転するかという事は昔から物好きな学者の間で真面目な問題となっている。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "市会議員の舌の鳴物入りの忠言なんかはこの道で苦労している彼等には真面目に対手になってはいられなかった。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
