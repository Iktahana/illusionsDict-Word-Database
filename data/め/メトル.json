[
  {
    "uuid": "4d68a3ba-5950-56ac-8a46-8edb759adc53",
    "entry": "娶る",
    "reading": {
      "primary": "めとる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
