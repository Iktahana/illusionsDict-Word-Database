    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to marry (a woman)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "諸葛孔明は実に立派な人ですが、其の妻を娶るに当つては特と醜婦を択びましたので、当時小歌を作つて其事を囃したものがあります。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "学位のある、立派な男が、大切な嫁を娶るのだ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……最早や、忰の嫁を娶るのに、他の大切な娘の、身分系図などを検べるような、不埒な事はいたしますまい。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊右衛門は女房は子孫のために娶るもので、妾として遊ぶものでないから、それほど吟味をするにも及ばないと思った。",
              "citation": {
                "source": "四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にいたしましても、来るものも娶るものも亡くなりましたのは、こりゃ葬式が出ましたから事実なんで。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の立場として、楚国で夏姫を娶るのが無理なことは、明らかであったから。",
              "citation": {
                "source": "妖氛録",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "禁軍の將校たるものゝ爭でか歌妓を娶るべき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　牡丹奇縁は小説乍ら、其第十回、魏玉卿が學生中、隣家の美人卞非雲にほれ、合格授職の後、その依然處子たるを娶る敍事に、明朝時代の新婚祕俗を精寫しある故、手當り次第、相似た諸國の事例と駢べて寫し出そう。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妻を娶るならば、洛神のような女が欲しいものだ」「あなたは水神を好んで、わたしをお嫌いなさるが、わたしとても神になれないことはありません」　妻は河に投身して死んだ。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺婦長者既に多くの妻を先立てし罪業を懼れ、新妻を娶ると直ぐさま所有鎖鑰を彼女に附し、わが家の旧法仏僧に帰依すれば、汝も随時僧に給事して、惰るなかれというた。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある若者、その師より戒められたは、妻を娶るは若い娘か後家に限り、年取った娘や、嫁入り戻りの女を娶るなかれと。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に極めて貧しい者あって、妻を娶るに大将を招待すべき資力なし。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、曠野城の大将の恒例として、城内の人が新婦を娶るごとに処女権を振り廻す。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "教師が媒酌人となるは勿論、教師自から生徒を娶る事すら不思議がられず、理想の細君の選択に女学校の教師となるものもあった。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は既に大官を得て出世しているとはいえ、万事が粗野放胆で婚儀のことなど礼節にかかわらず、妻を娶るは品物のやり取り位に思っていたであろうから、お品の好い御殿風な三枝未亡人を驚かしたも無理ならぬことと思われます。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大隈綾子刀自の思い出",
                "note": "青空文庫"
              }
            },
            {
              "text": "この僅かな秘密の記憶一つを、彼自身がキレイに忘れて終いさえすれば、彼は今まで通りの完全無欠の童貞……絶対無垢の青年として評判の美人……初枝を娶る事が出来るのだ。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "清の雍正年間、内城の某家で息子のために※を娶ることになった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、前申す通り境遇上、まだ妻を娶るに好都合という時機へも来ていないのであるから、私は生返辞をしていた。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "家内を貰った頃のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れ妻を娶るは子孫存続のためなれば也。",
              "citation": {
                "source": "三つの「女大学」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は娶りしより前七年間の近附にて、小生を愛し、小生の娶るを待つとて結婚を申込みし者を二人まで却けしこと有之候。",
              "citation": {
                "source": "アンドレアス・タアマイエルが遺書",
                "author": "ANDREAS THAMEYERS LETZTER BRIEF",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時はそれで善かつたが、だんだんその子が年を取つて、女房を娶る、子が出来る、それも子一人位の時はまだ善かつたが、だんだん殖えて来て三人も四人もとなつた。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "抽斎が三人目の妻徳を娶るに至ったのは、徳の兄岡西｜玄亭が抽斎と同じく蘭軒の門下におって、共に文字の交を訂していたからである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "長子玄亭が蘭軒門下の俊才であったので、抽斎はこれと交を訂し、遂にその妹徳を娶るに至ったのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘化元年には五百の兄栄次郎が吉原の娼妓浜照の許に通って、遂にこれを娶るに至った。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして榛軒は遂に志保を娶るに至つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に伊沢氏の初の女婿全安と柏との間に生れた女梅を娶るのは此養玄である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は同じようにだれも娘と思って世話をしているものの、この方と縁を結ぶ人には命までも譲りたい気でいるのだのに、父親がないと聞いて、軽蔑をして、まだ年のゆかない、でき上がっていない子などを、この方をさしおいて娶るというようなことができるものなんだねえ。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れ妻を娶るは子孫相続の為なれば也。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "男子に二女を娶るの権あらば、婦人にも二夫を私するの理なかるべからず。",
              "citation": {
                "source": "中津留別の書",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて襲われたという家を私も二軒知っているが、そのいずれもが剛慾で人の持っているものを叩き落してでも自分が肥っていこうという家であったのを見ると、海賊というものにも、たゞ者を掠めとる一点ばりでなく、復讐的な気持や、剛慾者をこらしめる気持があったらしい。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
