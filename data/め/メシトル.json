        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "上意により、隠居していた名軍師を再び城へと「召し捕った」。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "帝が歌の優れた公卿を「召し捕り」、御前で披露させることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "師匠が一番弟子を「召し捕り」、秘伝の技を伝授する決意を告げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
