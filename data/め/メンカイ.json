    "definitions": [
      {
        "index": 1,
        "gloss": "meeting (face-to-face)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
