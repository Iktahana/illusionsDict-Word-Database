    },
    "definitions": [
      {
        "index": 1,
        "gloss": "discernment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところであの母親の方はドウヤラ継母と私は睨みましたが……」　和尚は良助の明察にギョッとしたらしくよろめいた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程のう」　さすがの松倉十内も非人の明察振りに舌を巻いたらしい。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご明察恐れ入ります。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると警察長はびっくりしたらしく、「全くご明察の通りです。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に御明察の通りです。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家に於いても、それを御明察なさらぬわけはなく、何かと優しくおいたはりになつた事と存ぜられます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子の明察があの老人に劣る訳はない。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ子路の邸に入るに及んで、「善い哉、由や、明察にして断なり」と言った。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "治者の言、明察にして断なるが故に、その政が紊れないからである。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察に報告して、驚くべき明察を以て自分の犯行の経路を発く。",
              "citation": {
                "source": "書けない探偵小説",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "梵語アース（迅速）、ギリシア語のアコケー（尖頂）、ラテンのアクス（鍼）、アケル（迅速また鋭利また明察）、英語アキュート（鋭利）等から煎じ詰めて、これら諸語種の根源だったアリヤ語に鋭利また迅速を意味するアスてふ詞あったと知る。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "クララはフランシスの明察を何んと感謝していいのか、どう詫びねばならぬかを知らなかった。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女魔と申すものはとかく美しきもの、御寵愛はさることながら、それゆえにお上ほどの御明君が、正邪のお目違い遊ばされたとあっては由々しき大事、只々御明察のほど願わしゅうござります……」　一にも明君、二にも明君、只明君々々と明君ずくめで押し通しました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "上は二なき御明君、御明察願わしゅうござります」「いずれにしても不埓者じゃ、不、不埓者めがッ」「恐れ入ってござります。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――なにものか胸中に明察のついたもののごとく、ぴくりとまゆを動かして考え込んでいましたが、そのまま右門はおし黙って、ぷいと立ち去りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらを綜合して、わたしはそれを地上の偽雷と認めたのである」　人は県令の明察に服した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "閲微草堂筆記（清）",
                "note": "青空文庫"
              }
            },
            {
              "text": "趙尚書は明察の人物であったが、遂に我来也の奸計を覚らなかったのである。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "時の人は姚の明察に服して、包孝粛の再来と称した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "輟耕録",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に御明察ですわい」　船長は、甲板に立って、改めて辺りを見廻すのだった。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "溝口氏が益々奥ゆきとリズムとをもって心理描写を行うようになり、ロマンティシズムを語る素材が拡大され、男らしい生きてとして重さ、明察を加えて行ったらば、まことに見ものであると思う。",
              "citation": {
                "source": "「愛怨峡」における映画的表現の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、この刻々に変ってゆく一般の情勢のなかで、その変化にひきずられずに変らぬ愛が満たされているためには、全く現実的な周囲の出来事への判断とその理由への明察と、人間生活の真の成長への評価を見失わない堅忍や行動が、求められていると思う。",
              "citation": {
                "source": "これから結婚する人の心持",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の読者は、一人の筆者においてあらわれるこのような或る種の矛盾に対して、文化的明察の敏感性をもたなければならないと思う。",
              "citation": {
                "source": "世代の価値",
                "author": "――世界と日本の文化史の知識――",
                "note": "青空文庫"
              }
            },
            {
              "text": "公然と条理をもって、しかも人間的機智と明察をもって、どこまでもユーモラスに、だが誰憚らぬ正気な状態において諷刺文学がありうる処と時代に、スカートの中を下からのぞくようなゲラゲラ笑いが、笑う人間の心を晴やかにするとは思われない。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界文化の水平線の上に露わされている旧日本文化の後進性とその深い由来とをきわめつくし、その努力を足場として前進して行く明察と勇気との中にこそ新日本文学の端緒が期待されるのである。",
              "citation": {
                "source": "新日本文学の端緒",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間を超越された宮様のこの御生活の中においでになりますあなた様がたのお心の境地は澄みきったものでしょうから、こうした男の志の深さ浅さも御明察くだすったらうれしいことだろうと私は思います。",
              "citation": {
                "source": "源氏物語",
                "author": "橋姫",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときも久左衛門は、後のもつれを明察して、誰より真先きに、一人勝手に百円を納めた。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその恐るべき明察の重囲に陥った苦しさに堪え得ないままに、極めて卑怯な、且つ徹底的に皮肉巧妙な手段を以て逆襲を試みようとした。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "警視庁よりは第一捜索課志免主任警部、飯村刑事部長、金丸、轟二刑事、鑑識課員の数名と共に時を移さず現場に出張し、又、検事局よりは新進明察の聞え高き熱海検事と古木書記とが臨場して詳細なる調査を遂げたるが、その結果は更に幾多の怪事実の発見となり、疑問に疑問を重ぬるのみ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
