        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ポール・ヴァレリーの『ユーパリノスあるいは建築家』のうちで、メガラ生れの建築家ユーパリノスは次のようにいっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひところはやった玄米パン売りの、メガフォーンを通して妙にぼやけた、聞くだけで咽喉の詰まるような、食欲を吹き飛ばすようなあのバナールな呼び声も、これは幸いにさっぱり聞かなくなってしまった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しじみ売りは「スズメガイホー」と呼び歩いた。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧衣にたすき掛けの僧｜覚猷が映画監督となってメガフォンを持って懸命に彼の傑作の動物喜劇撮影をやっているであろうところの光景を想像してひとりで微笑したりした。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きなボール紙のメガフォーンを脇の下にぶら下げているものもある。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に、私たちが持っていたものは、一本のエンピツと、ナイフと、一冊のノートブックと、一個のムシメガネと、水を入れた三本のビール瓶と、小さな新約聖書が一冊と……それだけでした。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、そんなものを集めて来ると、ムシメガネで、天日を枯れ草に取って、流れ木に燃やしつけて、焼いて喰べました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして二人とも、聖書を、神様とも、お父様とも、お母様とも、先生とも思って、ムシメガネや、ビール瓶よりもズット大切にして、岩の穴の一番高い棚の上に上げておきました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸法師が尨大なメガフォーンをさしあげてどなっているような感じがある。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし階級争闘というものが現代生活の核心をなすものであって、それがそのアルファでありオメガであるならば、私の以上の言説は正当になされた言説であると信じている。",
              "citation": {
                "source": "宣言一つ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの青空高くひびきわたるかたつむりのメガホーンの声でした。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたつむりの吹くメガホーンの声はいともほがらかにひびきわたりました。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが丁度その時、又もや青ぞら高く、かたつむりのメガホーンの声がひびきわたりました。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大臣はメガネを動かして、何もないはた織り機をじっくり見ました。",
              "citation": {
                "source": "はだかの王さま",
                "author": "THE EMPEROR'S NEW SUIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤワラカナ　ケムリノヤウナ　ハルノ　アメガ　二三｜日　フリツヅキマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメガ　ヤムト　マヘヨリモ　イツソウ　アタタカナ　ヒノ　ヒカリガ　ソソギマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノライヌメガ　ウルサク　ツイテ　キタノデ、タニガワヘ　ホリコマウト　イツテタンデスヨ。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソシテ、アメガ　フツタ　アトナドニ　ポコポコト　ツチカラ　アタマヲ　ダスノデ　アリマス。",
              "citation": {
                "source": "タケノコ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤガテ　マイタ　タネカラ　メガ　デテ　ノハラ　イチメンニ　ムギノ　ミノル　トキガ　ヤツテ　キタノデ　アリマス。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポストノ　ウエニ　トマツテ　ヰタ　スズメガ、「アレハ　ワタシノ　カゲダワ」ト　イヒマシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつそ、学校の先生にたのんで、メガホンで「越野たけさん、御面会。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青龍展のこの悪趣味をわたくしは私かにメガロマニアと呼んでゐるが、あれを尺大に縮めてくれたら、好い本の表紙になると思つて看て過ぎた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水上署の巡警船が交叉点に立ってメガホンや提灯で、来る船々を整理しています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動会の係の先生がメガホンで、叫び廻る。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "標準的に使われているフロッピーディスクの容量は、一・四メガバイトです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "メガは百万を意味しますから、一枚で百四十万バイト。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "広く使われるようになってきたＣＤ―ＲＯＭならさらに、フロッピーディスクの五百倍近い六百五十メガバイトまで入ります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩野さんが教育映画部でメガフォンをとっていた一九七〇年代は、ヴィデオという新しい技術が、制作現場を革新していった時期です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
