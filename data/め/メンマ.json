          "literary": [
            {
              "text": "いちめんまっ白な雪、（それは大へんくらく沈んで見えました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光はまっすぐに四方に発射し、下の方に落ちて来ては、ひっそりした台地の雪を、いちめんまばゆい雪花石膏の板にしました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのいちめんの山谷の刻みにいちめんまっ白にマグノリアの木の花が咲いているのでした。",
              "citation": {
                "source": "マグノリアの木",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うと小十郎はがあんと頭が鳴ってまわりがいちめんまっ青になった。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雪の降る日はひるまでもそらはいちめんまつくらでわづかに雁の行くみちがぼんやり白く見えるのだ。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光はまつすぐに四方に発射し、下の方に落ちて来ては、ひつそりした台地の雪を、いちめんまばゆい雪花石膏の板にしました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてゆきがふり、あたりいちめんまっ白になって、おはかも銀いろにおけしょうをしました。",
              "citation": {
                "source": "アッシェンプッテル",
                "author": "ASCHENPUTTEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝生がいちめんまるで砂浜みたいに白く浮いて、遠くの松原が黒ぐろと影を描いてゐました。",
              "citation": {
                "source": "死児変相",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮内庁では、門を入るといちめんまっ平らなコンクリート敷きになっていて、宮内庁記者クラブの建物の手前、警備の警官が詰めている建物まで、Ｓ字カーブを半分にしたようなラインが引いてある。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大陸的な夕空いちめんまさに灼奕と真っ赤に燃え映えている頃だった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
