[
  {
    "uuid": "8495ce96-3c5c-5b87-82aa-dc8a479cfacd",
    "entry": "名実ともに",
    "reading": {
      "primary": "めいじつともに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
