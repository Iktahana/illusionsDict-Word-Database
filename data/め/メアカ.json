        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "神秘――昔から今に懸けて地上のあらゆる人々の求めあかした者はそれでは無いか。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小閑ながめあかるきをりをりをほそりと影は通るなり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌おのづからうらさびぬらし萩の戸のへだての垣も枯れて匂ひぬ日あたりつれづれと眺めあかぬを、枯れしとて萩は刈られぬ。",
              "citation": {
                "source": "風隠集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "老畸人も亦たむかしの豪遊の夢をや繰り返しけむ、くさめ一つして起き上たれば、冷水に喉を湿るほし、眺めあかぬ玄境にいとま乞して山を降れり。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "たくじやうぎんぎよのめよりをんなのへそをめがけてふきいづるふんすゐひとこそしらねてんにしてひかるはなさきぎんぎよのめあかきこつぷををどらしめ。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "われも後生の雲はれて、真如の月を眺めあかさん」　とありますが、「初夜の鐘は諸行無常、入相の鐘は寂滅為楽」などというと、いかにも厭世的な滅入ってゆくような気がします。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや暫く眺めあかした後、彼はそっと片足下駄のまま花壇に踏み込んだ。",
              "citation": {
                "source": "牡丹",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざ今宵｜一夜はわれととり出でたこの心の臓を窓ぎはの白き皿に載せ、心静かに眺めあかさう。",
              "citation": {
                "source": "無題",
                "author": "富永太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々はみな外にすみあかれて、故郷にひとり、いみじう心ぼそくかなしくて、ながめあかし侘びて、久しうおとづれぬ人に、　　茂りゆく蓬が露にそぼちつつ人に問はれぬねをのみぞなく　尼なる人なり。",
              "citation": {
                "source": "かげろふ談義",
                "author": "――菱山修三へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お雪ちゃんが庖丁を使っている手を休めて、まぶしそうに眼を上げて、またうっとりと、なだらかな胆吹尾根から近江の湖面を眺めやった時――壺中の白骨の天地から時あって頭を出して、日本の脊梁であるところの北アルプスの本場をお雪ちゃんは眺めあかしておりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "種彦は眺めあかすこの景色と、久ぶりに取上げる杯の味と、埒もない門弟たちの雑談とに、そぞろ今日の外出の無益でなかった事を喜んだ。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "そはバルコンの夕やみにふたり手をとり寄添ひて眺めあかしゝ町はいづこぞ。",
              "citation": {
                "source": "偏奇館吟草",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、その前に坐って眺めて眺めて、眺めあかざるものがあったら、迚も台所をテカリとさせるために、立ち上るというような芸当は出来ないのよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
