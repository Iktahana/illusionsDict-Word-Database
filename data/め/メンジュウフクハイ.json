    "definitions": [
      {
        "index": 1,
        "gloss": "pretending to obey but secretly betraying (someone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
