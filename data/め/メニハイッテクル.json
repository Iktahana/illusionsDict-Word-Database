          "literary": [
            {
              "text": "向けた目に入ってくるのは、大通りのあちらこちらに立つ旗、祝い事のしるしだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そんなに歩くわけでもなくすぐにヤヨイウサギのおうちが目に入ってくる。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえ山の影すら詩人の目に入ってくることなく、ときには月光が船客の寝台を照らす。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "見慣れた自分の書斎がまず目に入ってくる。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
