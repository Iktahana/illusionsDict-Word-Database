        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "想像し難い自然の深淵から、何者かが時を超えて盲撃ちでもしているのだろうか？",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸を目掛けて盲撃ちだ。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            },
            {
              "text": "星空を衝くように、双つの手を挙げて、「待てッ」　盲撃ちに撃つ小銃に対して、まず云ったのである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "めくらうちの弾が飛ぶ。",
              "citation": {
                "source": "伝四郎兄妹",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
