          "literary": [
            {
              "text": "「めんこいとっつあんだ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺が野幌で教師をしてゐた時……　教師といへば……子供つてたまらなくめんこいねえ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "めんこいども、俺その中で出来る子と出来ない子とがめんこかつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来る子は顔がめんこいけども、出来ない子は心がめんこいんだ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい凸勃、今夜こそお前のめんこい額さ舐めてやつから。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この女子こ、めんこい顏してるど。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
