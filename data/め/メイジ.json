[
  {
    "uuid": "3c416097-38aa-58c2-bbb0-747a97ad39a0",
    "entry": "明示",
    "reading": {
      "primary": "めいじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞",
