        "examples": {
          "standard": [
            {
              "text": "歴史の授業で、名誉革命がイギリスの立憲君主制の礎となったことを学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "名誉革命は、血を流さずに王位が交代した稀有な例として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、名誉革命における議会の役割の重要性について熱弁を振るった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかるに彼は今やフランス革命を見、それが名誉革命の精神と相通ずることはなはだ多きを感じた。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼によれば、名誉革命は大事業ではあったが決して完全な事業ではなかった。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は、フランス革命に倣い、名誉革命の精神に復帰して、英国の社会的並びに政治的の改革を行わんことを、主張したのである。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
