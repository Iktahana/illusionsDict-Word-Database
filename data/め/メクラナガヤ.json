          "literary": [
            {
              "text": "ＴＭの家の前が加賀様の盲長屋である。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲団を積んだ手荷車が盲長屋の裏を向うへ、ゆるやかな坂を向うへ上って行く。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同座の「盲長屋梅加賀鳶」で、お民という子守女。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊「湯鳥天神境内」をつかったものに『天衣紛上野初花』の序幕の外『盲長屋梅加賀鳶』の序幕がある。",
              "citation": {
                "source": "上野界隈",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
