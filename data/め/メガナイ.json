    },
    "definitions": [
      {
        "index": 1,
        "gloss": "being extremely fond of",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と、こちらも拔け目がない。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い手術着を着た助手らしい男がしきりにあちこち歩き廻ってそれを助けてくれようとするのだが、一向｜利目がないので困り果てたところで眼がさめたのだという。",
              "citation": {
                "source": "夢判断",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは男ですから平気でお出でだけど、私は年は多いし女ですもの、あァ云われては実に面目がないじゃありませんか。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことがあっては日本軍人として面目がないぞ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……けれども、虹には目がないから、私の姿が見つからないので、頭を水に浸して、うなだれ悄れている。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで遡江部隊の遡という字からシンニユウを除いた朔だとか、国民に愬ふといふ愬から心を除いた上の字だとか言つてみるが、これもまた一向に利き目がない。",
              "citation": {
                "source": "名前の話",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "教える為め、又は修養の為め書物も読まなければ世間へ対して面目がない。",
              "citation": {
                "source": "入社の辞",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "……かわいいのに目がないから、春も秋も一所だが、晴の遊戯だ。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "申訳より、面目がないくらいだ。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どや、お祖父やんは抜目がないやろ？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そこはＦ君抜け目がない。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "吝な癖に、女には目がないとか、不思議に食奢だけはするとか云うのがそれである。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々と諫めては見るものの一向に験目がない。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに籠城が北条の十八番でも、のびのびと屈托のない秀吉に対しては一向利き目がない。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹が聟養子をとるとあれば、こちらは廃嫡と相場は決っているが、それで泣寝入りしろとは余りの仕打やと、梅田の家へ駆け込むなり、毎日膝詰の談判をやったところ、一向に効目がない。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も鶏肉には目がないのですが、あんなに育ちのよい鳥はそうお目にかかれません。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと変わった発想をするやつでね――科学の方に目がないんだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ありたけの目が、その一ところへ寄って、爛々として燃えて大蛇の如し……とハッとするまに、目がない、鼻もない、何にもない、艶々として乱れたままの黒髪の黒い中に、ぺろりと白いのっぺらぼう。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……けれども、虹には目がないから、私の姿が見つからないので、頭を水に浸して、うなだれ悄れて居る。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とさっきから噴霧器で頭に殺虫剤をかけているが、これがさっぱり効き目がない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ないしょ事の淫奔がとおって、立派な親の考えがとおせんから面目がない。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがしは故殿様にも御当主にも亡き父にも一族の者どもにも傍輩にも面目がない。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾日も雲の切れ目がないような空ばかりをながめて暮らしていると京のことも気がかりになって、自分という者はこうした心細い中で死んで行くのかと源氏は思われるのであるが、首だけでも外へ出すことのできない天気であったから京へ使いの出しようもない。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし今日の馬と驢が、既に出来るだけの諸役に立っており、新たに他の種を仕付けて使わねばならぬような、格段の役目がない故、新種を飼い擾すに十分力が出ぬのじゃろう。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも利き目がないらしく、女湯は男湯よりも三倍以上の水量を要すると云われていた。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "禄高十二万石の御門番ですから、屈強な御番士が門を預かっているのに不審はないが、余程退屈しているためにか、それとも目がない程に好きであったためにか、ひとりでしきりに将棋を差しているのです。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも万事に抜け目がない。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何というても二人の関係は卵時代で極めて取りとめがない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、ぬけめがないところもあるんだ。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなときは、いくら理合をつくして云つても何のききめがないものであると云ふことは明らかであるけれど、やつぱり黙つて居ることが出来なかつた。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
