[
  {
    "uuid": "249fac45-9dae-5169-a855-f08ef7917c0e",
    "entry": "名筆",
    "reading": {
      "primary": "めいひつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
