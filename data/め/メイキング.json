        "examples": {
          "standard": [
            {
              "text": "映画のDVDには、撮影の裏側が見られるメイキング映像が特典として付いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このドキュメンタリー番組は、有名な彫刻作品がどのように生まれたかを追ったメイキングだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イベントのメイキング映像を見て、準備の大変さを改めて知った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "即座に洗面、着替え、ベッドメイキング。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "カメラ位置を変えてのクロースアップ、ベッドメイキングの絵などが撮られた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "本を作る（ブック・メイキング）意欲は、私には非常に古くからあった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
