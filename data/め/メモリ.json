[
  {
    "uuid": "99010c7b-eb47-5fbe-8d64-58620084c4d7",
    "entry": "目盛り",
    "reading": {
      "primary": "めもり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
