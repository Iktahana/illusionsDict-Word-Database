[
  {
    "uuid": "db341c83-62f5-5f02-91c8-9c477a3fa45f",
    "entry": "綿布",
    "reading": {
      "primary": "めんぷ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cotton cloth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "突然、電鈴が私の耳に亀甲町にある、綿花綿布倉庫会社の事業停止による賃金不払のため、従業員のストライキを報らせた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜食が発達したとほぼ同様な理由から植物性の麻布綿布が主要な資料になり、毛皮や毛織りが輸入品になった。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿布麻布が日本の気候に適していることもやはり事実であろうと思われる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの場合になぜ金属棒は松やにを着けた皮でしごき、ガラス棒だとアルコールを着けた綿布でこするか、この幼稚な疑問に対してふに落ちる説明をしてくれる教師はまれであろう。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌着　最も膚に親しき衣なり、数百金の盛装をなす者も多くは肌着に綿布を用ふ、別に袖もなし、裏はもとよりなり、要するにこれ一片の汗取に過ぎず。",
              "citation": {
                "source": "当世女装一斑",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今は聞かぬが吾輩幼時迄、サントメといふ綿布が有た。",
              "citation": {
                "source": "女順禮",
                "author": "並にサンヤレの事",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨元祿初年又其前に、專らサンヤレ織の綿布を衣た賣女をサンヤレと名づけ、此稱呼が熊野の勝浦港邊に近日迄殘り有るのだらう。",
              "citation": {
                "source": "女順禮",
                "author": "並にサンヤレの事",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも或る時、ドウいう咄の連続であったか忘れたが、例の通り清貧咄をして「黒くとも米の飯を食し、綿布でも綿の入った着物を着ていれば僕はそれで満足している」と得々としていった。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "――服の綿布がだんだん湿りを含んで緊って来た。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿布の仕事に従事して世界をごろごろ廻って来た客は、「ああ、もう世界は、ユダヤ人と印度人と支那人とで、廻っていますよ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗をぬぐふために絶えず堅い綿布でごしごし肌をこするので強靱さを失つた太田の皮膚はすぐに赤くただれ、膿を持ち、惡性の皮膚病のやうな外觀をさへ示しはじめたのである。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗をぬぐうために絶えず堅い綿布でごしごし肌をこするので強靱さを失った太田の皮膚はすぐに赤くただれ、膿を持ち、悪性の皮膚病のような外観をさえ示しはじめたのである。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主たる名跡でよそへ出掛けるにも、常の式日には綿布ばかりとするがいゝ。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "化粧品でも、毛糸でも、綿布でもふんだんに店頭に積んである。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "絹子は村の高等小学を出ると、すぐ名古屋へ出て、親類の吉尾の世話で綿布問屋の二宮家へ女中奉公に住みこんでゐたのであつた。",
              "citation": {
                "source": "幸福の彼方",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "-------------------------------------------------------　紺唐草の木綿布団をかけた炬燵のなかへ、裾の方三分の一ばかりをさし入れて敷いた床の上に中気の庄平が眠っていた。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうの御儀に日本綿布の外衣をそろえた、儀仗兵も休ませなくてはならない。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭被、綿布、Maharajah の国だ。",
              "citation": {
                "source": "一週一夜物語",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムクングといふ部落に行きますと、土人は贈物として綿布を要求しましたが、その贈物の分量が決定したのは日没後のことでした。",
              "citation": {
                "source": "アフリカのスタンレー",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、合名会社で、綿布類をあつかう商売だと聞いてみれば、驚くに当りませんよ。",
              "citation": {
                "source": "女と帽子",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿布商人の妾なんか、蹴飛しちゃいなさいよ。",
              "citation": {
                "source": "女と帽子",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は甲板に出るごとに、予備大佐と自称するルウマニヤの綿布商人につかまつた。",
              "citation": {
                "source": "世界覗眼鏡",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が買い込むつもりだったのは、鑵詰類と綿布類だった。",
              "citation": {
                "source": "立札",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "匪賊どもは、鑵詰は便利だから掠奪しますが、穀物は調理に手数がかかりますから、あまり沢山は持ち去りませんし、また、毛織物は本能的にきらって、綿布に執着するものだと、そういうお考えのように存じておりましたから、お考え通りに取計らいましたのです。",
              "citation": {
                "source": "立札",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が註文したのは、鑵詰類と綿布類で、外の品物ではないんだ。",
              "citation": {
                "source": "立札",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一隻の船には、酒甕や綿布類や鑵詰類や若干の金銭が積まれていました。",
              "citation": {
                "source": "立札",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "絹布、綿布、洋服地、毛布、などの切れ端で、かき廻すと、絵具箱をひっくり返したような色彩の花が開く。",
              "citation": {
                "source": "蔵の二階",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（そして日本の繊維業は「女工哀史」と民主主義時代の冒頭における宝塚会談と一九四八年において中国香港からプロテストの提出されている日本綿布ダンピングに代表されている。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "香港における日本綿布　香港商工会人員の二百十五人の反対署名　香港における日本の綿布、紙、印刷用インク、磁器、□甃、ガラス、味の素、化学製品、オモチャ水産物は米英品及国産のの価格。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
