        "examples": {
          "standard": [
            {
              "text": "カードゲームでは、山札からめくり札を引く順番が回ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "めくり札をめくるたびに、会場からは歓声とため息が漏れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「さあ、次のめくり札は誰だ？」とディーラーが尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ゲームとなれば、トランプにしてもハナにしても、八重子は慎重に一手一手を考え、千重子はめくり札の天運を楽しみにし、順一は無理やりに大きなヤクを狙うのが、いつもの癖だ。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
