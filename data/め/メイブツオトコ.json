        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "名物男の狂歌師、赤猪口兵衛の独住居はすべて二、三日前の通りに閑寂である。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて富岡先生は十一月の末｜終にこの世を辞して何国は名物男一人を失なった。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでいよいよ私は、この浦塩の名物男となってしまいました。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "フェアチャイルドをしっちゃかめっちゃかの大騒ぎのあげくに飛び出したシリコン・バレーの名物男、ジェリー・サンダースが一九六九年に創設した、アメリカで五番目の規模の半導体メーカーだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫でも全寮で可也名物男に近かつた久米や自分がやつて居るので、喝采するものも可なりあつたが、狂言その物はマルで出鱈目であつた。",
              "citation": {
                "source": "学生時代の久米正雄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はもう、どのように言いなんしても、かえしはしませぬぞ」　――声の主は笑止なことに身分柄もわきまえず、大身旗本のこの名物男早乙女主水之介に、もう久しい前から及ばぬ恋慕をよせている、そこの淡路楼と言う家の散茶女郎水浪でした。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいらがむっつりのなんとかいう名物男さ、覚えておきな」　いうかいわないかのせつなです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜造寺長門守骨ある名物男ならば、早乙女主水之介の骨も一枚アバラのつもりじゃ。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "主水之介いかに江戸一の名物男であったにしても、時でもない時に釣れる筈はない。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "名物男をうたふ・でたらめをうたひつつあさぶをもらひつつ・若葉に月が、をんなはまことにうつくしい・いつ咲いた草の実の赤く　　　江畔老に・その蕎麦をかけば浅間のけむりが　四月二十九日　曇。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたまが禿げて、鼻さきの赤いこの老人は、もと、内地の或縣に於いて、縣會議長までしたことがあるが、今は札幌中知らない人がないくらゐなか／＼喰へない點に於いて名物男だ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正五年三月實業之日本社刊『十人十色名物男』所收）",
              "citation": {
                "source": "酒に死せる押川春浪",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "名物男のガイドでシイ・※イ・ホテルの客引を兼ねた馬来人メラメデインが鈴木｜鼓村に酷似した風采をして見物を勧めに来る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "名物男の老主人フレデリツクは断えず酒臭い気息をして客｜毎に話して居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "田中正造と云へば足尾鉱毒問題の絶叫者として、議会の名物男と歌はれて居た。",
              "citation": {
                "source": "大野人",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "与力とは云っても貝十郎は、この時代の江戸の名物男であり、伊達男であり、風流児であり、町奉行の依田和泉守などとは、そういう点で憚りのない、友人｜交際をしていたので、そういうわがままは大目に見られていた。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十四年一月二十四日の朝、社會主義仲間の名物男齋藤兼次郎君があたふたとやつて來ました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにはともあれ、私は私なりに、このヨオロッパの名物男にすつかり興味を惹かれてしまつたのだが、この回想録から得た感銘をさう簡単に説明できるものではない。",
              "citation": {
                "source": "人間カザノヴァの輪郭",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとなく、気にかかるな」　波川巡査は当年四十五というウダツのあがらぬ名物男。",
              "citation": {
                "source": "南京虫殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛸のように赤く酔っ払っている重吉といえば、十年さきからの名物男だものな。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "圓朝門下には俊才も少なくなかったが、同時にぽん太とかコマルとかへん朝とか愚かを以て鳴る名物男も存在していた。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに二、三年前今年の二月に雪崩で死んだ名物男の小林｜喜作が東鎌尾根の路を拓いて、大天井岳から殺生小屋へ通ずるようにした。",
              "citation": {
                "source": "秩父宮殿下に侍して槍ヶ岳へ",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れは彼が古くから病院にゐる爲か、町で子供等や、犬に圍まれてゐても、决して他に何等の害をも加へぬと云ふ事を町の人に知られてゐる爲か、左に右、彼は町の名物男として、一人此の特權を得てゐたのである。",
              "citation": {
                "source": "六號室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼が古くから病院にいる為か、町で子供等や、犬に囲まれていても、决して他に何等の害をも加えぬと云うことを町の人に知られている為か、とにかく、彼は町の名物男として、一人この特権を得ていたのである。",
              "citation": {
                "source": "六号室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "名物｜皿鉢料理の卓を圍んで土佐料理に舌鼓をうつて居る折、其時の母校々長、校友會長の甲藤義治氏の好意であつたらう、高知の名物男の政吉といふ老藝人を呼んでくれた。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　京都の御影堂本家の主人は、店に、本尊｜法然の像をまつって、時宗だったから、僧形で妻帯していたが、円頂で扇をつくって京の名物男だった。",
              "citation": {
                "source": "元禄十三年",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
