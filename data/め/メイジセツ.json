    "definitions": [
      {
        "index": 1,
        "gloss": "Emperor Meiji's birthday (November 3; national holiday held from 1927 to 1948)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
