        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十一月三日の明治節の国民運動会の日である。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして、一日楽しく明治節を祝つた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治節の朝、朝香宮妃殿下の薨去が報ぜられた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の日記を翻して見ると、それはやはり十一月の三日、明治節の日であった。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治節ですから……」「ふうん。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の庚戌会は、ちょうど明治節だから久し振りの大会にするから東京市外の病院の方々も参加を申し込んで頂きたいって書いてありましたわ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月三日しぐれ、明治節、農学校運動会の騷音。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治節、菊花節、むしろ日本節とよぶべきだらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月三日はこちらの明治節のいい日であったので、結婚式が幾組もあった。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治節で何處の家にも國旗が出てゐてきれいな町である。",
              "citation": {
                "source": "婚期",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　十一月三日、明治節の朝だ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マアあれが、今の最大限だからね」「それはそうだわね」「どんな本が出版されようと……」「そうよ、そうよ、わたしもそれはよく分っているわ、題や表紙だけでは決して判断しませんから」十一月三日（金曜）　明治節が大雨というのは珍しい。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年のことながら、明治節の空は高く澄み上って、沢山の参詣者たちは、誰もこの絶好の秋日和を愉んでいるように見えた。",
              "citation": {
                "source": "壁画摸写",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒うすしせめては燗を熱うせよ慟哭せしは昔となりむ明治節昭和六年十一月十三日　東大俳句会。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治節大帝｜日和かしこしや十一月十日　草樹会。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治節のお式に出なくてはいけないから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつ出発するの」「明治節の日」「どこから、――東京駅？",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
