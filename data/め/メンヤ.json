        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と、夜中の一時頃に起きて仕事にかゝる、製麺屋の玉田は、幼時のことを考えていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧民窟といわれた通新町を過ぎ、吉原堤にかかりますと、土手際に索麺屋があって、一面に掛け連ねた索麺が布晒しのように風に靡いているのを珍しく思いました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "刈り株ばかりの冬田の中を紅もめんやうこんもめんで頬かぶりをした若い衆が酒の勢いで縦横に駆け回るのはなかなか威勢がいい、近辺のスパルタ人種の子供らはめいめいに小さな凧を揚げてそれを大凧の尾にからみつかせ、その断片を掠奪しようと争うのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "身は高皇帝の子にして、南面して王となる、豈能く僕隷の手に辱しめられて生活を求めんやと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自ら得るあらば　苟に伝ふるに堪へむ、何ぞ必ずしも　知音を求めんや。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡弓弾きはいきなり胡弓を鳴らしながら賑やかに閾をまたいではいってゆかねばならないのだが、木之助は知らずに、「ごめんやす」と言ってはいっていった。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごめんやす」とほっぽこ頭巾をぬいで木之助は土間にはいった。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "山名宗全、但馬に在って是を聞き、「我軍功の封国何ぞ賊徒の族をして獲せしめんや」　と嚇怒して播磨を衝き、次いで義政の許しを得ないで入洛した。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "英雄自ら是れ風雲の客児女の蛾眉敢て仙を認めんや若し武陵｜何処と問わば桃花流水門前に到れ　老婆はその詩を見て世高を秀英の許へやってもいいと思った。",
              "citation": {
                "source": "断橋奇聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "豈に敢て生を求めんや。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（紙製石盤は公判所より許されて被告人一同に差し入れられこれに意志を認めて公判廷に持参しかくて弁論の材料となせるなり）さりながら妾は長崎にて決心せし以来再び同志の言を信ぜず、御身は愛を二、三にも四、五にもする偽君子なり、ここに如何ぞ純潔の愛を玩ばしめんやと、いつも冷淡に回答しやりたりき。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "死苦に臨むもなお一旦吐いた毒を収れず、いわんや今更に棄つるところの薬を収めんやと。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉服屋をのぞくにしても、さらしもめんや、欝金もめんみてえな安い品をのぞくなよ、どこで知恵の小づちを拾うかわからねえんだからな」「へえい……」「いやに景気のわるい返事をするな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "豈汝らをして容易にこれを動揺せしめんや。",
              "citation": {
                "source": "日本男子論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが飮めんやうな事やつたら、えらさうな事いふのはやめて貰ひまつさ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大將だらうが兵隊だらうが御酒のよう飮めんやうな男は一人前とはいはれへん。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "豈小兒をして之に觸れしめんや、之を動搖せしめんや。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうめんや孫にあたりて舅不興　　　久女貧しき群におちし心や百合に恥づ　　　同貧しき家をめぐる野茨の月尊と　　　同　田舎の旧家の複雑した家庭。",
              "citation": {
                "source": "大正女流俳句の近代的特色",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきに我この事をもほかの事をも彼に告げたり、またレーテの水いかでかこれを忘れしめんや。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな事を思い合わせながら私達はまだ見たこともない人種が来でもするように、「御めんやす」と云う声をまって居た。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナア、そうやろ、ほんまに大きに御邪魔、御めんやす」　御まきさんは御仙さんに御辞ぎをさせてそそくさと玄関に行ってしまった、「西の人はゆっくりだってのにあなたは随分せっかちだ事」　母はこんな事を云いながら送った、私も御仙さんのふんだ足あとをボカすようにしてあるいた。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御めんやす」　御まきさんが斯う云うと車は段々くらい方に入ってしまった。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと退いてやれ」　百折れ千折れ、五間とは直に続かぬ坂道を、呑気な顔の女が、ごめんやすと下りて来る。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らず長松の下に箕踞して白眼世人を見る底の人物を養成する張本人は誰ぞや、吾人｜豈独り女学雑誌社中を攻めんや、彼れが代表する一派の傾向に針※する所あらんと欲するのみ。",
              "citation": {
                "source": "唯心的、凡神的傾向に就て（承前）",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は、「へえ」と腰をこごめながら、それでやっと、「ほんならここからどうぞごめんやす」と沈み沈み言って、上り框に躙り上がって、茶の間の板の間のところに小さくなって坐った。",
              "citation": {
                "source": "霜凍る宵",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "変化に先立ちてこれが備をなさざれば遣繰身上いかでか質の流を止めんや。",
              "citation": {
                "source": "桑中喜語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "』フルコム答ふ―『わが南蛮四十二国、みなデウス如来を拝むによつて、苦患なく乞食なく病者なし、なんぞ貧者を駆つて施物を集めんや。",
              "citation": {
                "source": "ハビアン説法",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに格別話もないとみえて、名前のとおりに、「ごめんやす」　とお尻を上げて、安兵衛は帰って行った。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と威勢よく駈け出して使いよりも早く、「ごめんやす」　とばかりに、伊呂波寿司の暖簾へとび込んで行くと――驚いた。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごめんやす」　で、親分と乾分は土手の柳の樹の下で、左右に別れたのだった。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
