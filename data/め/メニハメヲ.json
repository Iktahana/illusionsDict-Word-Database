        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "目には目を――魔術には魔術を――いかほどの教訓を深淵で学んだか、いまこそ示して進ぜようぞ！",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "「目には目を、齒には齒を。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            },
            {
              "text": "目には目を、歯には歯をだ。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「目には目を、歯には歯を」という、あの蛇の様な復讐心だ。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「目には目を、歯には歯を」この外に真理はないのだ。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「目には目を、歯には歯を」これがわしの動かし難き信念であった。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "目には目を、歯には歯を。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "古めかしい言葉ではあるが、目には目を、歯には歯を、そして、彼奴の犯した罪業と同じ分量の苦痛を嘗めさせないでは、此の私の腹が癒えぬのだ。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
