    "definitions": [
      {
        "index": 1,
        "gloss": "to shut one's eyes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大人の狐にあったら急いで目をつぶるんだよ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ゲルダは、目をつぶるどころではありません。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、ゲルダは、目をつぶることもできませんでした。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために、デメリットに目をつぶる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その表現として支配階級のファッショ化が導き出されているほど激化している階級対立の現実からは何とも手を下しようなく目をつぶる。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云って、自分が沼津に居た時の歌だと云って、熱にうかされる様になって昼間火鉢によりかかって目をつぶるといつでも好きな夢を見られる嬉しさをうたった歌を誦して聞かせた。",
              "citation": {
                "source": "ひととき",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ不足なものが滿たされないからであらう――かう考へて、電燈の光に目をつぶると、暗い身をしぼる必然の力ばかりが勃興して來る。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "二等待合室のふツくりしたどす赤の天鵞絨ベンチに腦天からふらつくからだの腰をおろし、外套の袖に引ツくるまつて目をつぶる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひげ武者のアイノに道を聽いて後、義雄がこの紅葉した濶葉樹密接林の間を驅ける時、目をつぶると、その葉毎／＼に當る風の音が急雨のやつて來るかと驚かれた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのままにしておけばトラブルの原因になりかねないものにも、平気で目をつぶる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は、目をつぶる様にしてぴったりと其処を押えつけて、本を重しにかって置いた。",
              "citation": {
                "source": "盗難",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも亡くなったこの子のおかあさんが、この子の運がいいように何かいい名前をつけようと、三日三晩考えぬいて、病気になって、いよいよ目をつぶるというときに、かすかな声で、「ああ、やっと考えつきました。",
              "citation": {
                "source": "長い名",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と独り言のようにいって、目をつぶると、そのままうとうと眠ったようでしたが、やがて息を引き取ってしまいました。",
              "citation": {
                "source": "鉢かつぎ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は目をあいて天井を見上げ、勿論何も天井にはそんなもののないことを確めた上、もう一度目をつぶることにした。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし目をつぶることは必しも僕の自由にはならない。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうそう、昨日の籖は一番違いだったっけがと……じっと目をつぶるとゆうべの記憶が、瞼の裏へ走馬燈のように走りはじめる。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは如何にあがいて見ても、到底目をつぶるまでは楽は出来ないと云ふ事実だつた。",
              "citation": {
                "source": "一塊の土",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "（看護婦なら、知ってる筈がない……）　目をつぶると、もう考えること、それ自身が懶うくなって来た。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達はしばらくそこで目を潰っていた、目をつぶると、まるでここが深海の底でもあるかのように、何んの音もしなかった。",
              "citation": {
                "source": "※の囁き",
                "author": "――肺病の唄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "目をつぶると腕を斬る疼みが伝わって来るようであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "目をつぶると、まぶたの奥に、恋しい顔――恋しいが憎らしい顔、恨みの顔、どうあっても、赦してはやれぬ顔――さまざまに二人の顔が、ちらちら映って来る。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジット目をつぶると、静けさ、嬉しさは、ソット忍足に私の心の中にしみ込んで行く。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいでも私達は目をつぶる様にして入りました。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてふと目をつぶると、頭の中がしいんとして、いつも同じように、自分がいままで遊んでいた、村のはずれにある、あの大きな沼が目の前に浮かんできました。",
              "citation": {
                "source": "清造と沼",
                "author": "宮島資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "清造は、「あっ」といって驚いて目をつぶると、いきなりまた、例の沼が目の前に浮かんで来たのです。",
              "citation": {
                "source": "清造と沼",
                "author": "宮島資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうとき、だまってじっと目をつぶると、いつもあの沼と、沼に浮かぶあわがかならず目に浮かんできました。",
              "citation": {
                "source": "清造と沼",
                "author": "宮島資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでかれはじっと目をつぶると、沼にはあわが浮かんで来ます。",
              "citation": {
                "source": "清造と沼",
                "author": "宮島資夫",
                "note": "青空文庫"
              }
            }
          ]
        }
