    "definitions": [
      {
        "index": 1,
        "gloss": "clear or definite judgement (judgment)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
