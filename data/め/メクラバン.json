    "definitions": [
      {
        "index": 1,
        "gloss": "approving a document without adequately reading it",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
