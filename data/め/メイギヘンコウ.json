        "examples": {
          "standard": [
            {
              "text": "中古車を購入したので、すぐに陸運局で名義変更の手続きを行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "結婚を機に、銀行口座の名義変更をする予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "名義変更が完了するまで、この物件はまだ私のものとは言えない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私の実印は御送り致しませんが、もし私の名義となっているものがありましたらその名義変更のためには何時でも捺印致します。",
              "citation": {
                "source": "柳原※子（白蓮）",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつでも名義変更は致しましょう。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
