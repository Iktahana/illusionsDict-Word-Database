        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "綿ネルの下着が袖口から二寸もはみ出しているのが、いつも先生から笑われる種であった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勃凸は着物を腰までまくり上げて、粗い鰹縞のやうな綿ネルの下着一つで胡坐をかいてゐた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よれよれに垢じみた綿ネルらしい寝衣を、剥ぎ取られた姿は、前よりももっとみじめな浅ましいものでした。",
              "citation": {
                "source": "島原心中",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は菱なりのような顔の口の大きい男で、これも綿ネルのシャツなど着て、土くさい様子をしていた。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "参詣人の大群は、日和下駄をはき、真新しい白綿ネルの腰巻きをはためかせ、従順にかたまって動いているが、あの夥しい顔、顔が一つも目に入らず、黄色や牡丹色の徽章ばっかりが灰色の上に浮立ち動いているのは、どうしたものだろう。",
              "citation": {
                "source": "上林からの手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "出がけに脱いで行った志野の綿ネルの寝間着が、衣紋竹に吊下っている。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その婦人の負ぶつてゐる赤ン坊は、この暑中に、赤い綿ネルのボタボタを着て、小さい手を私の方へ差し伸べ、パラソルの柄を堅く握つて放さなかつた。",
              "citation": {
                "source": "烈日",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根裏の窓に引っかかっている春の夜の黄色い片割月を見上げながら、洗い晒しの綿ネルの単衣一枚に細帯を一つ締めて、三階の物置の片隅に敷いてある薄ッペラな寝床から脱け出した。",
              "citation": {
                "source": "継子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤスが和服と暖い下着をさし入れてくれたのを着て、綿ネルの襤褸になった寝間着を畳んだものの上に坐っている。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁沓を履いて、綿ネルの布切で首から頭から包んだり、綿の厚くはいった紺の雪袴を穿いたり――女も――していた。",
              "citation": {
                "source": "贋物",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な蜜柑畑も、紀ノ川も、高野山も、粉河寺も、熊野の浦も、綿ネル工場も、なにもかも観たこともないのである。",
              "citation": {
                "source": "紀州人",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "垢だらけの綿ネルシャツの袖口は金ボタンのカフスと相接した。",
              "citation": {
                "source": "深川の唄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿ネルの洗いざらしを申し訳に背中だけへ乗せているのがある。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "古風な綿ネルのシャツを著て大きな鞄を重さうに提げて人込みの中をうろ／＼としてゐた。",
              "citation": {
                "source": "續俳諧師",
                "author": "――文太郎の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿ネルのシャツに薄いパイルのヴェスト。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "捺染物や綿ネルやまた家具の如きも、産額は大きなものでありますが商品に止るというだけであります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼｜丈けは、綿ネルの背広を着て、赤いネクタイを結んでいた。",
              "citation": {
                "source": "踊る一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
