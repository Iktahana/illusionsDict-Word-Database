    "definitions": [
      {
        "index": 1,
        "gloss": "email",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは主として、チャム、モン、クメール、マラヨポリネシア系の言語によって解釈を試みておられる。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方朝鮮語やウラルアルタイ、チャムモンクメール、オセアニック等の語系との関係についての論文は往々われわれの目にも入ったが、正面からマライとの関係を論じて、そうしてそれが一般学界ひいては世人の注意をひくほどに至ったもののあった事は寡聞にしてまだ知らなかったのである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たわいもない幻影を追う目がガラス棚のチョコレートに移ると、そこに昔の夢のビスケット箱の中のメールコーチが出現し、五十年前の父母の面影がちらつき、左団次の知盛が髪を乱して舞台に踊るのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これこそ」と、私はやっと老人に言った、――「これこそ、あのメールストロム（４）の大渦巻なんですね」「ときには、そうも言いますが」と彼は言った。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "キルヘル（８）やその他の人々は、メールストロムの海峡の中心には、地球を貫いてどこか非常に遠いところ――以前はボスニア湾（９）がかなり断定的に挙げられた――へ出ている深淵がある、と想像している。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "原語読みならばメールシトルムとでも書くべきであるが、ここでは英語読みにした。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "以降、社内のメールシステムを使って、足抜けの段取りが練られました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「正確に書いて欲しい」との指摘を受けて、原稿の一部を何度も何度も繰り返し電子メールでやり取りしたことを、昨日のように思い出します。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も作ってるんですよ」とさっそくメールをくれたのが、後に『ポン！",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "』のことを話しておくと、後日彼からメールが届きます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりに京都インターネットに接続してみると、事務局からメールが届いていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Dairiqui のホームページを作ろう」　メールを読んだ途端、原さんの心は決まりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界中から送られたメールを即座に受け取って、すぐに反応を返すといった本格的な使い方も、繋ぎっぱなしにしなければ不可能だ。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまで名刺には、ニフティーサーブのユーザーＩＤを書いてきましたが、電子メールの住所も、藤井さんの会社に間借りした新しいものに変更です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにも解説めいた記述はなかったのですが、夜中に図々しくメールしておくと、翌朝にはもう、返事が届いています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本の未来へと通ずるヒロシマへの道　一九九五（平成七）年十二月十五日、エキスパンドブックの仕組みを作っている祝田久さんから、メールが届きます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "誤解に基づく訳の分からないものも含め、祝田さんにメールを書き続けます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "祝田さんからのメールが届いた夜以来、私は途切れることのない時間の糸を手繰るように、そんなことを考え続けていきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｅメールアドレスなど持たない人のことをデジタルホームレスなどと呼ぶらしいが、インターネットの上にだってホームレスの予備群は立派に育っている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "通信によって、メールも届きます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "煮詰まったところで、「病気の話は大切だと思う」と書いてくれた八巻美恵さんのメールには、勇気づけられた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "青空文庫を訪れる人が少しずつ増え始めた、一九九七年の秋、視覚障碍者読書支援協会（ＢＢＡ）のメンバーであるという堀之内修さんから、「自分のページにリンクさせてもらった」とのメールがとどいた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、できればこれまでのものも含めて、明確化させた新しいルールに従って使ってもらえないかと考え、すべての作業者にメールで連絡を取り、「みずたまり」＊で論議して、合意の形成を目指した。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらの犯人は、電子メールとＦＡＸの二人組だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし電子メールを送るためにネットワークにアクセスするたびに、我が家のゴリラは軽度の錯乱をきたす。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディスプレイを使ってマシンと対話するように作業する基本姿勢、ＣＲＴ上にテキストとグラフィックスを混在させて表示した仮想的な文書を作業対象とする概念、画面を複数の窓に分割するアイデア、マウス、そして電子メール、みんなそうだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話に関してはこんな具合に屋上屋を重ねてその上にドームまで被せたような日々を送っているオレは、一年ほど前にオンスペック社というところがモデムとＦＡＸ、ボイスメールの機能をＰＣ用ボードにまとめたＦＡＸ―Ｏ―ＦＯＮＥという製品を出したと聞いて、指パッチンをかました。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "△田中行一氏――グロンメール先生から離れたやうに見えるしかし事実は色彩の上でか、線の上でか、結果離れてはゐない『結髪』で自己のものを築きあげたらいゝと思ふ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨナーの鯨、ソロモンの蟻、イシュメールの羊、アブラムの犢、シェバ女王の驢、サレクの駱駝、モセスの牛、ベルキの郭公、マホメットの驢だ。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "小波がお伽噺に筆を染めたのは随分古い事で、二十一年十二月発行の『我楽多文庫』第十三号から「鬼車」というメールヘンの飜訳を連載したのがそもそもの初めであった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
