    "definitions": [
      {
        "index": 1,
        "gloss": "closing one's eyes and joining one's hands together in prayer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
