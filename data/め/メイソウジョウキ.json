          "literary": [
            {
              "text": "閑日月の中に明窓浄机で本を読む世界と遠く離れた世界である。",
              "citation": {
                "source": "国会図書館のこのごろ",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてひどく毛色は変っているが、一種の明窓浄机の面影が実験室の中に出て来るのである。",
              "citation": {
                "source": "実験室の記憶",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の毛色の変った明窓浄机とこの雑草の園との差は、結局研究の性質の差なのであろう。",
              "citation": {
                "source": "実験室の記憶",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明窓浄机とはいわないまでも、心身を清め、無念無想になって筆をとらなければならない。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
