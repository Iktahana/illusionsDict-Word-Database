[
  {
    "uuid": "fa47877f-cf57-5689-91df-e835d7d4a499",
    "entry": "目茶",
    "reading": {
      "primary": "めちゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
