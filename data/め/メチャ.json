              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また第二の山では牛若丸が六人の賊をめちゃくちゃにたたき斬る、そうして二つ三つに切った死骸を蓆で包んで川へ流しに行くまでを精細な数コマに描き分けたものらしい。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらでも、めちゃくちゃに金の儲かるボロイ商売のように云われている薬屋でも、やって見れば、やはり、苦労と、骨折がかゝるものだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、どこでもかまわず、めちゃくちゃだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "体裁よく飾りつけられた屋内のさまざまなものが、片ッぱしからめちゃめちゃに放り出された。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭をめちゃ／＼に斬られた人が這入ってきた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "照準が間違っているのにめちゃくちゃにうって居るからだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかもめちゃくちゃだ。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "りんごをひろってきてあげましょうか云ったら眼がさめちゃった。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち事象は決してめちゃくちゃには起こっていない。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　映画批評について　このごろはそれほどでもないがひところはソビエト映画だとなんでもかでもほめちぎり、そうでない映画は全部めちゃくちゃにけなしつけるというふうの批評家があった。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "めちゃなことをしたい。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い切って、めちゃなことを、やってみたい。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、いま、おのれの芋虫に、うんじ果て、爆発して旅に出て、なかなか、めちゃな決意をしていた。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、人の三倍も四倍も復讐心の強い男なのであるから、また、そうなると人の五倍も六倍も残忍性を発揮してしまう男なのであるから、たちどころにその犬の頭蓋骨を、めちゃめちゃに粉砕し、眼玉をくり抜き、ぐしゃぐしゃに噛んで、べっと吐き捨て、それでも足りずに近所近辺の飼い犬ことごとく毒殺してしまうであろう。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "りんごをひろってきてあげましょうか、と言ったら眼がさめちゃった。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このなかでいちばんばかで、めちゃくちゃで、まるでなっていないようなのが、いちばんえらいとね。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このなかで、いちばんえらくなくて、ばかで、めちゃくちゃで、てんでなっていなくて、あたまのつぶれたようなやつが、いちばんえらいのだ。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長靴のタールもなにももうめちゃくちゃになってるんだ。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」恭一がぼんやりたずねますと、じいさんは顔をまるでめちゃくちゃにしてよろこびました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い火山灰層のひとところが、平らに水で剥がされて、浅い幅の広い谷のやうになってゐましたが、その底に二つづつ蹄の痕のある大さ五寸ばかりの足あとが、幾つか続いたりぐるっとまはったり、大きいのや小さいのや、実にめちゃくちゃについてゐるではありませんか。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとあいつのゴム靴がめちゃめちゃになるだらう。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからおなか中をめっちゃめちゃにこはしちまふんだよ。",
              "citation": {
                "source": "いてふの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
