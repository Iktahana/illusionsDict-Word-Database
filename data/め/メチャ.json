    "definitions": [
      {
        "index": 1,
        "gloss": "very",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然るに来てみると、彼の眼に映つた此の中学は目茶苦茶なものであつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつの為に千満子の縁談は目茶苦茶になるやろ」　と政江は叫んだ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "初乃が居なければ伝三郎の家は目茶苦茶だと権右衛門は常にいってるのだが、之は大体当っている。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "糊刷毛かなにかでもって書いたものらしく、仰山に肉の太い文字で、そのうえ目茶苦茶ににじんでいた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "目茶目茶なんですのよ、それが。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しこうなれば目茶よ。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかも目茶苦茶だ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会制裁の目茶目茶は医師のはんらんと、小市民の医師の良心に対する盲目的信仰より起った。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、目茶苦茶なんだ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「言ってみたって、どうにもならんけど、このごろ僕は、目茶苦茶なんだよ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つには私たちの同人雑誌『春服』が、目茶苦茶になりかかった、わびしさから、二つには、ぼく自身のステールネスから、最後に、あなたがぼく如きものに好意をお持ち下され居る由、昨晩の松村と云う『春服』同人の手紙が伝えてくれたので、加うるに性来の図々しさを以て、御迷惑を省みず、狎書を差し上げる次第です。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、『春服』が目茶苦茶なので悲観しているのです。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "起上ろうとする所を、二人がのしかかって来て、目茶苦茶に殴った。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五右衛門は、腹が立つやら、情けないやら、熱いやら、痛いやら、まるで精神状態が目茶苦茶にみだれてしまったが、しかし、この男は元来が虚栄心で固めて日本一の大泥棒になったくらいの男であったから、さすがに燃え残りの自尊心を取り戻して、「やいやい、野郎共、何を笑うておる。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人しく服罪している者を爆破しようというのは勿論言語道断だが、勝手に禁錮を流罪に変更するのも随分目茶な話だ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それで、あんまり目茶やから、僕、校長の所へ言ひに行つたんですよ。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（寒いといえば目茶苦茶に炭をつぎやがるし、暑ければ暑いで、目茶苦茶に行水しやがるし、どだいこのおなごの贅沢にも困ったもんや）　行水をするとき、お君は相変らず何度も水を浴びた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "エロスのカクテル、抱擁、馬鹿噺、接吻、目茶苦茶踊り――で、パッパッと目の先を刺激して瞬時瞬時を過して行けば、理窟はいらない、それならそれで誠にそれは面白い、何たる朗らかさぞや！",
              "citation": {
                "source": "新興芸術派に就いての雑談",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論狂人になるなどゝいふ馬鹿／＼しい考へは持たうとしても持てなかつたし、その儘にして置けば当然再び道子のために折角の勝利を目茶／＼にされてしまはなければならないのだ――彼は膝に眼を伏せて、何と云つたらよいものかと考へ込んだ。",
              "citation": {
                "source": "爪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の心は目茶苦茶になつた。",
              "citation": {
                "source": "ランプの明滅",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃写真などを初め目茶苦茶にカチリカチリとやつて居りますが、それも少しもはかどらず幽霊ばかりで、この手際で山へでも行つて写したらそれこそ魂を寒からしむる凄い画が出来るかも知れないが下手な手際を当にすることは心細いこと、困つたこと。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "句読の切り方などは目茶だった。",
              "citation": {
                "source": "温情の裕かな夏目さん",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで先ず当分は目茶苦茶だ。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその瞬間、金二千両の天目茶碗を失った代りに、自分の心の落着きをしかと取り返すことが出来たように思って、昂然と胸を反らした。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはこの愉快な創造の数時間をめちゃめちゃに壊した窓のたくさんの顔をできるだけ強い表情でにらみまはした。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "りんごをひろってきてあげませうか云ったら眼がさめちゃった。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い火山灰層のひとところが、平らに水で剥がされて、浅い幅の広い谷のようになっていましたが、その底に二つずつ蹄の痕のある大さ五｜寸ばかりの足あとが、幾つか続いたりぐるっとまわったり、大きいのや小さいのや、実にめちゃくちゃについているではありませんか。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからおなかじゅうをめっちゃめちゃにこわしちまうんだよ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また第二の山では牛若丸が六人の賊をめちゃくちゃにたたき斬る、そうして二つ三つに切った死骸を蓆で包んで川へ流しに行くまでを精細な数コマに描き分けたものらしい。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらでも、めちゃくちゃに金の儲かるボロイ商売のように云われている薬屋でも、やって見れば、やはり、苦労と、骨折がかゝるものだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
