          "standard": [
            {
              "text": "恵まれた人々は、自分たちの富を社会のために還元すべきだと考えられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "世界には、恵まれた人々がいる一方で、貧困に苦しむ人々も多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は恵まれた人々の一員として、慈善活動に積極的に参加している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「勿論世間には、」と彼は云う、「或る題目について思索しようと考えてその通りにする、ごく賢い恵まれた人々がいます。",
              "citation": {
                "source": "意欲の窒息",
