    "definitions": [
      {
        "index": 1,
        "gloss": "taking care of someone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「今後はこの子をあなたがいつまでも面倒見てやって下さい。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「事によったら僕が面倒見てあげてもいいんだがね、この土地としては君の着附けは大変いいようじゃないか、何かいいパトロンがついているんだろう。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけどあまり東京風を吹かさずに、三四カ月もおとなしく働いていれば、きっと誰か面倒見てくれる人が見つかるのよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう折々、いつも私は思うのであるが、これは氏の天資か、幼時からの都会の良家的「お仕込み」で、習性となって居る氏の動作が、このほか松葉杖つく画家Ｋ氏を、まめまめしく面倒見る氏の様子を、何事の美挙ぞと、私は眺めたことも度々あった。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「能くなあ、おつうはよきこと面倒見んな、女の子は斯うだからいゝのさな、直ぐ役に立つかんな」女房の一人がいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何でだつぺなまあ、おめえそんなに仕ねえで面倒見てやらつせえよ、此れがおめえ女つ子でもなくつて見さつせえ、こんな小えの抱えて仕やうあるもんぢやねえな」「さうだともよ、こらおつうでも無くつちや育たなかつたかも知んねえぞ、それこそ因果見なくつちやなんねえや、なあおつう」女房等はいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "親方が勘次へ噺をした時「わしや、なあに、家のもんだから面倒見ねえた云はねえね」勘次は油の乘らぬ態度でいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「※等、大層なこと云つたつて、老人の面倒見たゝ云へめえ」勘次はぶつ／＼と獨語した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お内儀さん、わしどんな形にか家も建てなくつちやなんねえから、そん時や家族の極りもつけべと思つてんですが、お内儀さん又わしこと面倒見ておくんなせえ、わし等野郎も其内はあ大く成つて來つから學校もあとちつとにして百姓みつしら仕込むべと思つてんでがすがね」「さうかえ」内儀さんは慰めるやうにいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "初のうちは皆可哀想だつて餘計な賃錢をやつたり衣物なんぞ呉れたりして面倒見たんですがね。",
              "citation": {
                "source": "おふさ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴様が家をあけて、誰が家のことをすると思ふ、清親叔父さんだからこそ斯うして親切に面倒見て呉れるんだ。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私には迚もこの子は面倒見切れませんよ。",
              "citation": {
                "source": "チビの魂",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいうおせんのような女をよく面倒見て、気長に注意を怠らないようにしてやれば、年をとるに随って、存外好い主婦と成ったかも知れない。",
              "citation": {
                "source": "刺繍",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らが関心を持ったのは、価格であり、アプリケーションの品揃えであり、メインテナンスの面倒見であり、せいぜいが使い勝手と外側から見た限りでの機能だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（自分を毎日面倒見て下さる学校の先生の事なのです。",
              "citation": {
                "source": "小さい子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前なぞ、そんないい往生が出来るなんて――よく若い者が面倒見てくれるな。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "蕎麦屋の利久",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな風になる少し前から越後者の伊佐といふ若い男が入り込んでゐたが、正直者でおとなしい性質だったから、お絹の世話は親切に面倒見てゐた。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもこれも尾島氏に余り面倒見て貰い過ぎ、聖書会社へ迷惑を掛けました神より自分に降した相当の責罰には、自分は今度冤罪の下に斃れなければならぬ道行となりましたものと思います。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角の日曜もこれだからと、小泉は不平をこぼすのだったが、中江から見れば、研究旁々病院に勤めていて、知人の患者だけを面倒見てやる彼の落付いた生活が、余りに散漫で中心点のない自分の生活に比べて、羨ましくなるのだった。",
              "citation": {
                "source": "立枯れ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「哀れなお君を面倒見てやって下さい、　私の一生の願いやさかいな。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お関さんに一から十まで面倒見てもらってるんだから決して我を張る様な事が有っちゃあならないのさ。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「我々の組合から出た犠牲者は我々の手で救援してゆくのが当然じゃないか、家族だって吾々が面倒見られるだけ面倒みてるじゃないか、こういう奴等が策動し出すから我々に対して警察の弾圧がひどくなって来るんだ！",
              "citation": {
                "source": "鋳物工場",
                "author": "戸田豊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "、永い事ァ厄介かけたねえ、なんの一年ばかし面倒見といてくんねえ。",
              "citation": {
                "source": "もつれ糸",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺だとて、お妙さんのこと、優しい綺麗ないじらしい嬢さまだとは思うている、思うていればこそ、お前のことづけた金を持ってってやって以来、ズーッと植木にいて面倒見て来たがそんでも、俺あ惚れているのとは違うぞ！",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "してたぶん吾々は彼の面倒を見ねばならないのです、しかしそうたいして面倒見る事はありませんでしたが」「あんたは何んにもなさる事が出来なかったのです」と夫人が言った。",
              "citation": {
                "source": "金の十字架の呪い",
                "author": "チェスタートン",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺だとて、お妙さんのこと、優しい綺麗ないじらしい嬢様だとは思うている、思うていればこそ、お前の言伝けた金を持ってってやって以来、ズーッと植木に居て面倒見て来たがそんでも、俺ぁ惚れているのとは違うぞ！",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫は光子さんの家の方い、「もう御安心です」いうてやりましたのんで、お父さんわざわざ事務所にお礼に来なさるやら、お母さんも私のとこい来なさって、「どうぞどうぞ、あの通りの我が儘もんですさかい、ほんまの妹や思て面倒見てやっとくなはれ。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ちゅうけんどな、そんな奴は、おれでも面倒見てやらにゃ、誰も、うてあわん。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう長いこと労咳でわしがめんどうみていた無宿者の老人が、急にゆうべ変が来たというて呼び迎いに参ったのでな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "やけ酒を飲んでゐるやうに見かけられるのも気がひけるし、子供を直接めんどうみてゐる間は十分つゝしまなければならないと思つたわけだつた。",
              "citation": {
                "source": "跡",
                "author": "尾形亀之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
