        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのペンキはボロボロに剥げて、建物も鎧扉も、指で押せば立ちどころにメリメリツといきさうであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、大きいりっぱな木が、メリメリポキッと、恐ろしい音をたてて、地べたにたおれるんですからね。",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "カシワの木は、メリメリッとさけて、根こそぎにされてしまいました。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "メリメリッという音がしました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "制して制さるる男共であればこそ、右と左へ伊達の家来を押退け押飛ばして、楯に取る門の扉をもメリメリと押破った。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の動揺ははなはだしかったが、満船している関係上、動揺以上に浪の打ち込みがはなはだしく、そのため、水夫室の頭上では、錨が浪と衝突して少しでもゆるみが来ると、今にもサイドを押し割りそうに、メリメリッと鳴った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "露国の監視船に追われて、スピードをかけると、（そんな時は何度もあった）船のどの部分もメリメリ鳴って、今にもその一つ、一つがバラバラに解ぐれそうだった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとメリメリと音がする。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱はみるみる抉られてしまって、メリメリと、大きな音をたててゴトンと下に落ちた。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五人の男女がその上にのぼって、メリメリと屋根をこわしている。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は猶も力を込めて戸を推したが、メリメリと蝶番が毀れて戸は下の屋根へ落ち、室の中が一時に明るく成った、とは云え夕明りで有るから昼間ほどには行かぬが幽霊の正体を見届けるには充分で有る。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "メリメリと壊れそうなガラス窓に映っている緑色の光……あの光はお前なのか、それとも僕なのだろうか。",
              "citation": {
                "source": "夢と人生",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして自信のある柔道の手を施す術もないうちに私の両肩は、巨大な噛締機にかかったように痺れ上って、抵抗する力もなくなってしまったばかりでなく、肋骨がメリメリと音を立てて千切れて行くような……今にも肺臓が引き裂かれて、呼吸が止まりそうな大苦痛を感じ初めたのであった。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "メリメリと鎧戸は壊れました。",
              "citation": {
                "source": "計略二重戦",
                "author": "少年密偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "メリメリという音がした。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小指の尖で、中身をポンと落しメリメリと外箱を壊して裏をひっくりかえすと、弦吾はポケットから薬壜を出し、真黄な液体をポトリポトリとその上にたらした。",
              "citation": {
                "source": "間諜座事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいてガチャンガチャンと大きなレンズが壊れて、頑丈なケースが、薪でも割るようにメリメリと引裂かれる。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに肩のところがメリメリいって来た。",
              "citation": {
                "source": "蠅",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "コツツン、メリメリ、コツツン　メリ、コツツン、メリメリ、コツツン、メリ　コツツン、メリメリ、コツツン、メリ、八つのたまごは　つぎつぎに　メリメリメリメリメリメリメリと　われて、なかから、八つの　かわいらしい　ひよこがうまれました。",
              "citation": {
                "source": "にはとり　は　みんな　しあわせ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、なるほど、その時、メリメリツといふ音をたてながら、直径一尺ほどの三ツ又になつたコブシの木が、まさに地上に倒れようとし、丁度その真下に子供が二人、余念なく草をむしつてゐるのである。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリャ、リャ、リャ、リャ……」　ゆさぶるうちに大地がメリメリとさけてきた。",
              "citation": {
                "source": "曾我の暴れん坊",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
