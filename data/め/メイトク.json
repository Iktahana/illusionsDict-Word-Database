        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "道必ず正直なるは、明徳を神にする也。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "道は碁盤上の線道なり、明徳は即ち正直也。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "四象は地則、明徳、陰陽、天文なり。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "協会の勉強会に出席した野口さんが、ＢＢＡ代表の浦口明徳さんから、おみやげをもらってきた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大学』の道はただこれ三綱領（明明徳、親民、止於至善）八条目（格物、致知、誠意、正心、修身、斉家、治国、平天下）に止まる。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "と書了りて又搜ると明徳記既に之を記し、藥師寺の邊りに其名を今に殘しける池籠めの御座敷是なるべしとあり。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後にも南北朝の争いは一日も絶えなかったが、北朝の明徳三年に南北朝の和議がはじめて整った。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも前にいった明徳年中、南北両朝の和議が取り結ばれた頃から、どこでも彼の姿を見たというものはなかった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずくんぞ彼らをしておのおのその明徳を明らかにし、相親しみて至善に止まらしむることを得ん。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちこれを儒教的に言わば、われわれがその本具の明徳を明らかにして民を親しみ至善にとどまるということ、これを禅宗的に言わば見性成仏ということ、これを真宗的に言わば、おのれを仏に任せ切るということ、これをキリスト教的に言わば、神とともに生くということ、これをおいて他に人生の目的はあるまい。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学にいう、「古の明徳を天下に明らかにせんと欲する者は、先ず其の国を治む。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "この宮城の正南門の承天門から、皇城の正南門の朱雀門を經て、京城の正南門の明徳門に至るまで、南北を一貫せる大通りがある。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この李處耘は實に宋の太宗の皇后、即ち明徳皇后の實父に當るから驚く。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "南北朝は元中九年（北朝の明徳三年）南朝の後亀山天皇が北朝の後小松天皇に神器を伝えて、南朝の不和は和解したことになっているが、実はさにあらず、後南朝というべきものがあって、その後も吉野にたてこもり、六十五年がほど抗争していた。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎は明徳四年、即ち、百三十一年前、二十六歳の年の九月三日、海上で行衛不明、妻サヾエは、それから半年後に、旅の商人某に嫁づき、離村、となつてゐる。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「慈忍を日月の明徳に型取り、天地を照らして諸臣を総べ、民を安きに置くものと、かように道人解釈しましてござる」「それが政治の要諦と思う」「決して間違いはござりませぬ」　ここでまたもや沈黙した。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明徳……（遠くの山中で人の叫び声らしきもの別々に二ヵ所で起り消える。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これのみならず明孝以下明光明徳教育上につきしかも一方ならず御配慮下されたることと、これまた低頭御厚礼申上候。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○同庄花園部落の斎堂（明徳堂）にて屋根裏の構造を見て　浜田（庄司）も竹屋根をやっているんだけど、これには負けるな。",
              "citation": {
                "source": "台湾の民藝について",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝる人は胸に明なる鏡ありて、善悪を照し視てよきあしきを知りて其｜独を慎む、之を明徳の鏡といふ。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "その意は、古聖人の道を祖述する以上に敢て自己の創見によって新しい道徳律を作るのではない、というのであるが、古聖人とは、孔子においては、「大学」にいうところの「明徳を明らかにした」地上の人であり、「修身・斉家・治国・平天下」を実現した理想的為政家であって、決して現世を超越した神秘的存在ではなかった。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "明徳……（遠くの山中で人の叫び声らしきもの別々に二ヶ所で起り消える。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明徳三年の銘あるこの鐘、たしか方広寺の鐘銘より以前に「国家安康」の文字が刻んであったはずの鐘、それが物静かに鳴り出しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "平家琵琶から分れて咄し家が立ち、『太平記』や『明徳記』や『大内義弘退治記』（応永記）のような講釈軍記の台本が書かれている。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尭孝は明徳二年、両統合体の前年に生れた。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明徳二年（一三九一年）の紀年で「ゆう通ねんぶつ縁起」の版木本だ。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
