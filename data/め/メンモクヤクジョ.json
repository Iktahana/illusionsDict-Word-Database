    "definitions": [
      {
        "index": 1,
        "gloss": "demonstrative of one's worth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
