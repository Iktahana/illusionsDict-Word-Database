        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "よもすがら音なき雨や種俵うぐひすや家内｜揃ふて飯時分　春の日の遅い朝飯。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所で家中夕飯時であったが、ただそこに母が見えない許り、何の変った様子もない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼飯時に午後のプランをきめた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯時に近所の家から「子供の時間」の唱歌などが聞こえて来ても、宅の機械は固く沈黙を守って冷やかにわれわれの食卓を見下ろしているだけであった。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は暮れかかり夕飯時になったけれど何を食うとも思わない。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど昼飯時だったが、先生、台所の棚の上に膳を載せて、壁の方に向いて立ったなりで飯を喰っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のうちへ來て坐り込んで飯時が來て飯を食ふに、恰も正當の事であるかの如き顏をして食ふ。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいにく昼飯時で、いけなかつたね。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざっと半日居たけれども、飯時を避けるなぞは、さすがに馴れたものである。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに夕飯時じゃありませんか」　母親の声は鋭かった。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "住職は六人の者を離屋に隠して、何人にも知らせないようにと、飯時には握飯を拵えて己でそれを持って往った。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一二　もう、ゆう飯時だからと思って、僕は家を出で、井筒屋のかど口からちょっと吉弥の両親に声をかけておいて、一足さきへうなぎ屋へ行った。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう会が朝の十時ごろから始まって昼飯時一時間の休憩があるだけで午後六時ごろまでもぶっ通しに続くことも珍しくない。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼飯時が近くなるので、勝手のほうでは皿鉢の音がしたり、物を焼くにおいがしたりする。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いゝや、酒にやられて半年ばかり静養してゐるんですが、晩飯時が難関でな……」　とわたしは唸つた。",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦い顔してるＳ、Ｓ―ぢや窮窟だけど、Ｉ―子さんだつたら、御飯時には御馳走してちやうだいつて、遠慮なく言へるし、何んなに楽しいか知れないのよ。",
              "citation": {
                "source": "草いきれ",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それならば杉浦が突然御飯時に押しかけて行って、御馳走を強制したのだろうか。",
              "citation": {
                "source": "Ｍ侯爵と写真師",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして間もなく翌年の春になりますと、或るお夕飯時のことで御座いました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼飯時の食堂は何時ものように、女工たちがガヤ／＼と自分の場所を仲間たちできめていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の健は、畠からすぐ市街地の「青年訓練所」に廻ったらしく、夕飯時に家に帰らなかった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理場の天井裏から飯時ちかくなると眼を光らせて見守つてゐる歩兵の一隊があります。",
              "citation": {
                "source": "船の中の鼠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼飯時に船のものが焼いて出した小魚に箸をつけてみると、不思議にうまい。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによると、船に乗つて海に漁猟に出たものが、午飯時にこの小魚を焼いて食べると、そのうまさに自分の飯櫃を空つぽにした上、その近くにゐる僚船を呼びとめて、飯の残りを無心したので、いつのまにか「ままかり」といふ名で呼ばれるやうになつたといふのだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処かへ出ていても、飯時になれあ直ぐ家のことを考える。",
              "citation": {
                "source": "一利己主義者と友人との対話",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝子が初めて此学校に来た秋の頃は、毎朝｜昧爽から朝飯時まで、自宅に近所の小供等を集めて「朝読」といふのを遣つてゐた。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝子が初めて此學校に來た秋の頃は、毎朝｜昧爽から朝飯時まで、自宅に近所の子供等を集めて「朝讀」といふのを遣つてゐた。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯時でなければ年寄と顔も合せずにゐるのに！",
              "citation": {
                "source": "籔のほとり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊夫君は小田さんと二人きりで、しばらくのあいだ何やらぼそぼそ話をしておりましたが、それがすむと、ちょうど昼飯時だったので、私たちは小田さんといっしょにうどんのご馳走になりました。",
              "citation": {
                "source": "暗夜の格闘",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてじっさいオツベルは、そいつで上手に腹をへらし、ひるめしどきには、六寸ぐらいのビフテキだの、雑巾ほどあるオムレツの、ほくほくしたのをたべるのだ。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち三人はひるめしどきを樂しみにしてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
