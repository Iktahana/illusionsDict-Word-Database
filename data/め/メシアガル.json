    "definitions": [
      {
        "index": 1,
        "gloss": "to eat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今朝戴いたお端書ですと、召し上がるものも追々おいしくなつて来たとの由ですから、もう油断さへ為さらなければほどなく御快癒になれますわね。",
              "citation": {
                "source": "〔婦人手紙範例文〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけでも召し上がるようにと思って、女房たちが持って来たお菓子の台がある、そのほかにも箱の蓋などに感じよく調理された物が積まれてあるが、宮はそれらにお気がないようなふうで、物思いの多い様子をして静かに一所をながめておいでになるのがお美しかった。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "召し上がるか上がらないかに、「お立ちイ――」　の声がかかって、すぐにもう還御です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬をつり出すためのえさですかい」「おいらが召し上がるんだよ、いただきいただき武鑑を繰って、ここと眼がついたら風に乗ってお出ましあそばすんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "お将軍さまが召し上がる目刺しだっても、これほど行儀よく頭をそろえちゃおりませんぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "また夢中になって、がつがつといくつ召し上がるんですか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつをみんな召し上がるんですかい」「あたりめえだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「王様は臓物を葡萄酒のソオスで召し上がるさうだが、ネルラが水で煮るとそれよりも旨い。",
              "citation": {
                "source": "聖ニコラウスの夜",
                "author": "SANKT NIKOLAUS BEI DEN SCHIFFERN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「若し先生が召し上がるのであつたのではございませんか。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "粥などを召し上がる院のほうを小侍従はもう見ることもできなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝は八時に、おひるは十二時、おやつは三時、夜は六時とちやんと召し上がるときがきまつてをりませう。",
              "citation": {
                "source": "鳩の鳴く時計",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天子様が鹿や猪の肉を召し上がることは平安朝までもありました。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィールス　（コーヒー沸かしのところへ行き、心配そうに）奥さまは、こちらで召し上がるとおっしゃる。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この御隠居がこのくらい召し上がるのだもの、ちっとやそっと飲んだからって、よもうちの娘にあんな飲み助はとはおっしゃるまい。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "道頓堀あたりでよく海老団治とへべれけた馴染の酒屋の小父さんはいいお酒の講釈をして聞かせて、高貴のお方の召し上がるお酒には金粉酒というものがある、お酒の中に黄金の粉がいっぱい浮いていて、それはそれは綺麗なものだと言ったけれど――。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あついお酒を召し上がると、あったかくなりますでございますよ」そして、部屋を出て行こうとしていた久助に、命じた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもあなたは大変ご愉快そうね、少しご酒を召し上がると」「時によると大変愉快になる。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいつでもというわけにはいかない」「今夜はいかがです」「今夜は好い心持だね」「これから毎晩少しずつ召し上がると宜ござんすよ」「そうはいかない」「召し上がって下さいよ。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨夜どんな事があつたか、話してくれ」「お客樣がお歸りになりましたので、私が參つてお掃除をいたしますと、一杯召し上がると仰有つて、ほんの一合ばかりつけて差上げましたが、毎朝｜据ゑる灸を忘れて居たが、肩が凝つていけないから、今からでもやつてくれと仰有つて、肩と、三里に据ゑて上げました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "佛像の膝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どんな様子なんだ、ともかく、詳しく話してくれ」「旦那はこの間から、すっかり萎気切っておりました、仲の良い内儀さんに死なれて、何事も手につかない様子で、毎晩召し上がるお酒だけが次第に多くなるばかり」「で？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "和蘭の銀貨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どんな樣子なんだ、兎も角、詳しく話してくれ」「旦那は此間から、すつかり萎氣切つて居りました、仲の良い内儀さんに死なれて、何事も手につかない樣子で、毎晩召し上がるお酒だけが次第に多くなるばかり」「で？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "和蘭の銀貨",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「人様の前で召し上がるのを恥ずかしいとはお思いなさらないのですか、動物園の獣のように。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐにお茶だのお菓子だのお強飯に口取りを添えた溜塗の高台だのが運ばれて、「坊ちゃん、お母様がお友達と仲よくこれを召し上がるようにって。",
              "citation": {
                "source": "少年",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……何かそこらの物を持って行って、市で叩き売ってしまうなり、借りるなりして、酒を持ってこい」「そんな算段をしないでも、もッと召し上がるなら、お酒はまだたんと買ってございますから、安心しておあがりなさいませ」「ふうむ……このごろはいやにいつでも断れたことがねえな。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速おかゆに玉子を入れて召し上がる。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度あったので、買って参りましたわ」　お目ざめになってから一つ皮をむいて召し上がる。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            },
            {
              "text": "「餅がくいてえなあ」「買ってまいりましょう」「あるかね」「ええ、ありますわ」　お餅も三切れほど、お海苔を巻いて召し上がる。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かき」「とうふ」「しらたき」の鍋物をお作りして召し上がる。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            },
            {
              "text": "正樹ちゃんがお目覚めで、おむつがすっかり濡れていたので、それを取り替えてあげてから御飯を召し上がる。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あなた方が、女中さんに御祝儀を出してめしあがる場所などには、決してあるものではない。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
