        "examples": {
          "standard": [
            {
              "text": "メキシコ湾流は、熱帯の暖かい海水を北上させ、ヨーロッパの気候を穏やかにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "メキシコ湾流のような強力な暖流のおかげで、高緯度にあるイギリスでも冬の寒さは比較的和らぐ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "海洋調査船がメキシコ湾流の流れを観測し、地球温暖化による海流の変化を調べている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "大西洋を、メキシコ湾流がめぐるちょうどまっ唯中、北緯二十度から三十度辺にかけておそろしい藻の海がある。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな船でメキシコ湾流に漕ぎ出し、独りで漁をしていた。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少ししたら、メキシコ湾流の縁から出られるだろう。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
