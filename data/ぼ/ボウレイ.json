[
  {
    "uuid": "f1b654cf-e314-5135-b3f6-6c3d38bb17af",
    "entry": "亡霊",
    "reading": {
      "primary": "ぼうれい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "departed spirit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "厚化粧の亡霊等は苟安の中に百鬼夜行する。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "地平線はみつめようにもみつめられない陽炎の亡霊達が起つたり坐つたりしてゐるので、――僕は蹲んでしまふ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中の宿で盗賊の群に襲われ、着物を剥がれた上に刺殺される、そのあとへ母をたずねて上京の途上にある牛若が偶然泊り合わせ、亡霊の告げによってその死を知る。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それですから近所でまあ、いろいろのことを云うんですが……」と、家主の胸にも歌女代の亡霊を描いているらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "書籍、学生、勘定台、これらはみな借金取りの亡霊のように私には見えるのだった。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんの罪もない日本民族の魂が警察の目を避けて過去の亡霊のように踊っていたのである。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "深夜の十字街頭に音もなく立ち迷うて、何かの亡霊に取り憑かれたかのように、くるくるくると闇黒の中に渦巻き込む塵の幾群れが見える。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを雨月物語式に綴れば、範頼の亡霊がここへ現れて、「汝、見よ。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その飴をかひに行つた女は母の亡霊である。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までに幾人となく引き裂かれ、切り千切られ、タタき付けられた女工や、幼年工の亡霊を嘲る響き……。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "所詮、作者の、愚かな感傷ではありますが、殺された女学生の亡霊、絶食して次第に体を萎びさせて死んだ女房の死顔、ひとり生き残った悪徳の夫の懊悩の姿などが、この二、三日、私の背後に影法師のように無言で執拗に、つき従っていたことも事実であります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は住居に対する執著の亡霊がまだ顔をさらしてゐるやうで軽蔑したくなつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおまた、作中第七節、朗読劇の台本は、クリスチナ・ロセチの「時と亡霊」を、作者が少しあくどく潤色してつくり上げた。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は、亡霊の役だそうです。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に栄えてゐる藤原氏の反対側の公の亡霊の威を藉りたなどは一寸をかしい。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その亡霊が書いた文章の真似をしようたって、それもかなわぬ。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、ここには近代青年の『失われたる青春に関する一片の抒情、吾々の実在環境の亡霊に関する、自己証明』があります。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其状たとへば、廃寺の残壁の下、怨みを負へる亡霊の其処此処とさまよふなる黄昏の断末魔の如し。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し沙翁の『ハムレツト』を読んで、其第一幕のうち、ハムレツトが父王の亡霊と語るあたりの、戦慄を禁ぜざる光景を真に味はむと欲する者あらば、来つて我が四畳半に入れ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらは、よしや真の亡霊に似ずとするも、誰かその少なくとも衣服の亡霊たるの事実を否定し得んや。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝる時の亡霊共の迷惑思ひやらる。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔色の蒼ざめた墨の法衣の、がんばり入道、影の薄さも不気味な和尚、鯰でも化けたか、と思ふたが、――恁く／＼の次第ぢや、御出家、……大方は亡霊が廻向を頼むであらうと思ふで、功徳の為め、丑満まで此処にござつて引導を頼むでがす。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは柴田勝家の亡霊で、同地方では、それを見た者は死ぬと云われているものであった。",
              "citation": {
                "source": "首のない騎馬武者",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊右衛門はお岩の亡霊に悩まされるので、蛇山の庵室に籠って、浄念と云う坊主に祈祷してもらっているところであった。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お岩の亡霊も跟いて入って来た。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或はいふ、北国筋の武家｜何某、夢中にお七の亡霊告げて云ふ、わが墳墓は江戸小石川なる円乗寺といふ寺にあれども、後世を弔ふもの絶えて、安養世界に常住し難し、されば彼の地に尊形の石塔を建て給はゞ、必ず得脱成仏すべしと。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもお七の亡霊が武家に仕える者の夢に入って、石碑建立の仏事を頼んだということは一致しているのである。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この島の人間どもが死絶えた（それはもうほとんど確定的な事実なのだ）後は、この影のような・砂の亡霊のような小蟹どもが、この島を領するのであろうか。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
