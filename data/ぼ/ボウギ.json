[
  {
    "uuid": "d2135247-158c-5c5b-8481-a2d311457b3b",
    "entry": "謀議",
    "reading": {
      "primary": "ぼうぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
