    "definitions": [
      {
        "index": 1,
        "gloss": "Buddhist priest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "むずかしいでしょうか』『あなた、坊さんでない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、むずかしいですね』『私、坊さん。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊さんになるさえもよきです』『あなた、坊さんになる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白い坊さんでしょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の大きい、鼻の高い、よき坊さんです』『その同じ時、あなた比丘尼となりましょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日経よむと墓を弔いするで、よろこぶの生きるです』『あなた、ほかの世、坊さんと生れて下さい』『ああ、私願うです』　人間よりも、虫や鳥の方が幸福だと言ったヘルンは、人生について、悲哀の外の何物をも知らなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えてみると、僕たちだって、小さい時からお婆さんに連れられてお寺参りをしたり、またお葬式や法要の度毎に坊さんのお経を聞き、また国宝の仏像を見て歩いたりしているが、さて、仏教とはどんな宗教かと外国の人に改って聞かれたら、百人の中の九十九人は、へどもどするに違いないのだ。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "考へてみると、僕たちだつて、小さい時からお婆さんに連れられてお寺參りをしたり、またお葬式や法要の度毎に坊さんのお經を聞き、また國寶の佛像を見て歩いたりしてゐるが、さて、佛教とはどんな宗教かと外國の人に改つて聞かれたら、百人の中の九十九人は、へどもどするに違ひないのだ。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨染の衣を着た坊さんが、網代笠を片手に杖ついて、富士に向って休息しているとすれば、問わずして富士見｜西行なることを知る。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊さんでさへ、昔のやうには「死」を売りものに出来ない時代なのだ。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭半分程這入って行くと、お松は母と二人で糸をかえしていて、自分達を認めると直ぐ「あれまア坊さんが」と云って駈け降りて来た。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「良くまア坊さんきてくれたねえ」と云って母子して自分達を迎えた。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お松は襷をはずして母に改った挨拶をしてから、なつかしい目でにっこり笑いながら「坊さんきまりがわるいの」と云って自分を抱いてくれた。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お松は「今夜坊さんはねえやの処へ泊ってください」と頻りに云ってる。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お松は「仕様がないねえ坊さん」と云って涙ぐんだ。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうどうしてもここでとおもう処で、自分をおろしたお松は、もうこらえかねて「坊さんわたしがきっと逢いにゆくからね」と自分の肩へ顔をあてて泣いた。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "志一や高天は言うに足らない、山伏や坊さんは職分的であるから興味もない。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "杜生はお坊さんで、廷珸の謀った通りになり、鼎は廷珸の手に落ちてしまった。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで彼はこの条下で地の球形説に対して、コロンバス時代の坊さんの唱えそうな反対説を唱えている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前で坊さんが二人立ち話をしている。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "梟の、きっと大僧正か僧正でせう、坊さんの講義が又はじまりました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふの低い松の木から、さっきの年老りの坊さんの梟が、斜に飛んでさっきの通り、説教の枝にとまりました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊さんの梟はゴホンゴホンと二つ三つせきばらひをして又はじめました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声は幸に少しつんぼの梟の坊さんには聞えませんでしたが、ほかの梟たちはみんなこっちを振り向きました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度ゆふべと同じ時刻でしたのに、説教はまだ始まらず、あの説教の坊さんは、眼を瞑ってだまって説教の木の高い枝にとまり、まはりにゆふべと同じにとまった沢山の梟どもはなぜか大へんみな興奮してゐる模様でした。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "梟の坊さんは、じっと星ぞらを見あげて、それからしづかにたづねました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "梟の坊さんがそれをじっと見送ってゐましたが、俄かにからだをりんとして言ひました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぢゃ、今朝も今朝とて穂吉どの処を替へてこの身の上ぢゃ、」　説教の坊さんの声が、俄におろおろして変りました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "梟の坊さんはしばらくゴホゴホ咳嗽をしてゐましたが、やっと心を取り直して、又講義をつゞけました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままで　そこには　おかあさんが　いたのに、目をあいて　みると、みも　しらぬ　ぼうさんが　いたからです。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
