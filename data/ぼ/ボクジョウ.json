    "definitions": [
      {
        "index": 1,
        "gloss": "meeting place for calligraphers and painters",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「往昔十四五、出デテ遊ブ翰墨場、斯文崔魏ノ徒、我ヲ以テ班揚ニ比ス、七齡思ヒ即チ壮、九齡大字ヲ書シ、作有ツテ一｜襄ニ満ツ」　すなわちこれが証拠である。",
              "citation": {
                "source": "岷山の隠士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二峰、五峰の父子、半嶺、石※、春洞の諸老、そのほか詩人学者の面々、それぞれ盛名を馳せて、両国の井生村、中村楼などに書画会が絶えず、文墨場裏大繁昌、その頃を思うと今は誠にさびしい。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "二郎さんは　じぶんも、にいさんの　しゃせいに　いって　いる、ぼくじょうへ　いって　みようかと　おもって　いると、おばさんが、きみ子さんを　つれて、おいでに　なりました。",
              "citation": {
                "source": "つめたい　メロン",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
