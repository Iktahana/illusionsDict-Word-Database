        "examples": {
          "standard": [
            {
              "text": "数学の公式を棒暗記するだけでは、応用問題には太刀打ちできない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "テスト直前に英単語を棒暗記したが、試験が終わるとすぐに忘れてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "意味も分からずお経を棒暗記した子供の頃の記憶が、今も微かに残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "学課は虎の巻をうつして行つて、お時間中黙つてきいて、試験の前には棒暗記さへすればいゝ。",
              "citation": {
                "source": "転校",
                "author": "平山千代子",
                "note": "青空文庫"
              }
            },
            {
              "text": "盲滅法に棒暗記をしなければならないような課目が、相当ある。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々が与えられている物理法則がどの程度に確かなものか、どういう異論に出会いつつあるか、つまりどの程度の疑問の余地のあるものか、そういうことを抜きにされたただの教材では、棒暗記の他はなくて、それから何等の想像を産むことも出来ぬ（この想像力は探検の精神に近いだろう。",
              "citation": {
                "source": "現代科学教育論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
