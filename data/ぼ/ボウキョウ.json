        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "むかし「望郷」という仏蘭西映画にペペ・ル・モコという異色ある主人公が出て来たが、そのペペをもじったのか、それとも、ペッペッと唾を吐く癖からつけたのか。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に望郷の念禁じ難く、徒に雲に島影を羨むのみ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし懸軍数百里望郷の情は、武将の心を傷ましむるものがあったであろう。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "『望郷の歌』は、誰も知つてゐる通り、ゲエテのウヰルヘルム・マイステルにあるミニヨンの歌を想ひ浮べながら、京都の四季のうつり變りを歌つてみました。",
              "citation": {
                "source": "詩集の後に",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしているかなあ、ヘルナー山の上の記者たちは……」　望郷の念に駆られたらしい、ドレゴがこんなことをいった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれが常住の土地を離れた者の望郷病だと解し、自分の心の弱さを軽蔑した。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "若いもの稚いものが、一日の働きの後で何か求める体と心との渇えを、体と心との望郷を暖くみたしてやり、休めてやり生気を与えてやる方法は、真剣に誠意をもって新しい国民生活のなかに具体化するように努力されなければなるまいと思う。",
              "citation": {
                "source": "若きいのちを",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、現実にその作家の描くもの、即ち描けたものはどんな作品かと云えば、池谷信三郎氏の「望郷」から横光利一氏の「郷愁」に至るまで、いずれも例外なくその作家の身辺的な素材に立った作品なのである。",
              "citation": {
                "source": "遠い願い",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラジルでコーヒー畑の間を歩いて居る裸足の日本海外移民の魂には消えぬ望郷がある。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本にしかないソーユが構成した生理的望郷がある。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "諏訪公園（図書館でたま／＼九州新聞を読んで望郷の念に駆られたり、鳩を見て羨ましがつたり、悲しんだり、水筒――正確にいへば酒筒だ――に舌鼓をうつたり……）。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし薄田氏の抒情詩は「ああ大和にしあらましかば」「望郷の歌」に至る前に夙に詩壇を動かしてゐる。",
              "citation": {
                "source": "人及び芸術家としての薄田泣菫氏",
                "author": "薄田泣菫氏及び同令夫人に献ず",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋が深まるといつしよに、このあたりも蟲の音がしげくなり、兵隊の望郷は一日一日つのつていつた。",
              "citation": {
                "source": "雨",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　モルガンは、お雪が望郷の念に沈んでいるのだと思って慰めた。",
              "citation": {
                "source": "モルガンお雪",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはバーバラという非常に日本人に近い顔立ちの娘で、昨日から私の目について、望郷病らしいものを感じさせられたのであった。",
              "citation": {
                "source": "暗号音盤事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうです憐れ深い「望郷の歌」が聞こえて来るではありませんか！",
              "citation": {
                "source": "沙漠の歌",
                "author": "スタンレー探検日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅泊の鎮魂歌のあたりの矚目と、遠地の郷家の斎戸の様とを兼ねて表してゐるもので、叙景と瞑想風な夜陰の心境望郷の抒情詩とが、此から分れ出ようとする複雑な、古式の発想法である。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまでも見ていると、本当にアルプスへ登って、この小屋の中を覗きこんでいるような気がしてきて、淡い望郷病が起ってきたり、それから小屋の家族たちの眼がこっちをジロリと睨んでいるのが、急になんともいえなく恐ろしくなったりして、堪らなくなって眼鏡から眼を離して周囲を見廻す。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "田端の高台にある下宿屋に移り、駒込の学校へ通う路すがらの田の畦に蟋蟀が唄う秋の詩をきくともなしに耳にする候になると、少年のわが胸に、淡い望郷の念が動いてきた。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の激しい望郷の念は、おそらく、欧洲の旅を通じ、母国日本に向つて示されたに違ひない。",
              "citation": {
                "source": "横光君の印象",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "山男××くん、最後の望郷に愛しき妻子に幸あれかしと祈ったか祈らぬかはしらねど、何でも昨夜新山でかいた通信にはたしか、こんなことがかいてあったらしい。",
              "citation": {
                "source": "平泉紀行",
                "author": "──専攻科第一類歴史部──",
                "note": "青空文庫"
              }
            },
            {
              "text": "望郷の錯覚とそれをいってみようか。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここ五稜廓に凝集される徳川の過去も、旭川に集約された明治の既往も、このうるわしい光景のなかにいつかけしとんで、着岸の日のあの望郷の想念を、このうるわしい光景のなかに、私はほしいままにする。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "望郷落日々々…………、独りたゝづむ名知れぬ浜辺、――悲し海原生れの故郷。",
              "citation": {
                "source": "小曲二十篇",
                "author": "漢那浪笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ私はお祖母さん子の内弁慶で、浅草にゐるじぶんにはおもてで近所の子供たちと遊ぶなどおもひも寄らない意気地なしなのであつたが、蓋しそのときの私は余りにも烈しい望郷の念にと駆られ過ぎてはゐたためであらう。",
              "citation": {
                "source": "異版　浅草燈籠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "シゴイさんのパパは、フランスのために働くより日本の陸軍にいてあの方に忠誠をつくしたいと思って運動したが、軍部の将校たちが嫉妬して、いろんな妨害をして帰れないようにしてしまったので、シゴイさんのパパは、〈望郷〉のペペ・ル・モコのように、首を長くして日本のほうを眺めながら淋しくフランスで死んでしまった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本へ帰って来たのは、勿論望郷の念などによるのではなく、変った土地へ行って見ようと思ったのにすぎない。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっさりした棉紗のカーテン越しにおずおずと内部を覗き込んで見ると、ジメジメした土間にじかに食卓を置いた横長の部屋で、「望郷」に出てくる悪党そのままの、ゾッとするようなじだらくな恰好をしたのが二十人ばかり、何か大きな声で叫び交しながら、乱雑極まる食事をしている。",
              "citation": {
                "source": "犂氏の友情",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は辛い現実に再び立帰ると共に身の不遇を泣き、あらためて望郷の念にかられたのであった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
