[
  {
    "uuid": "1463fab1-e18a-5b9d-b0f0-62d421ba2e91",
    "entry": "釦",
    "reading": {
      "primary": "ボタン",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
