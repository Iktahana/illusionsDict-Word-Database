    "definitions": [
      {
        "index": 1,
        "gloss": "button (clothing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "天鵞絨と紐釦がむやみに多く、色は見事な銀鼠であって、話にならんほどにだぶだぶしていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "室内の浮気な釦穴が、多数の男性によってつくられた鋳型のように、慇懃に籐椅子にもたれていた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして釦をはずした軍衣を、傷が痛くてぬげないから看護卒にぬがして呉れるように云った。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうするのかと彼が見ていると、母は胸の皮を引張って来て（それはいつの間にか、萎んだ乳房のようにたるんでいた）一方の腫物を一方の腫物のなかへ、ちょうど釦を嵌めるようにして嵌め込んでいった。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "釦の多いフロックコートを着たようである。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、そうした妖気に包まれながら、わななく指で左右の手袋の釦をシッカリとかけ直していたように思う。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "園の手は自分でも気づかないうちに、外套と制服の釦をはずして、内｜衣嚢の中の星野から託された手紙に触れていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "釦をきちんとかけた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を当てると冷かった、光が隠れて、掌に包まれたのは襟飾の小さな宝石、時に別に手首を伝い、雪のカウスに、ちらちらと樹の間から射す月の影、露の溢れたかと輝いたのは、蓋し手釦の玉である。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "立花は怯めず、臆せず、驚破といわば、手釦、襟飾を隠して、あらゆるものを見ないでおこうと、胸を据えて、静に女童に従うと、空はらはらと星になったは、雲の切れたのではない。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、卓子に肱をつくと、青く鮮麗に燦然として、異彩を放つ手釦の宝石を便に、ともかくも駒を並べて見た。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "古靴屋の手に靴は穿かぬが、外套を売る女の、釦きらきらと羅紗の筒袖。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かみわざで助けられるように、金釦の制服と漕ぎつけた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "インキの壺を、ふらここの如くに振つて、金釦にひしやげた角帽、かまひつけぬ風で、薄髯も剃らず遣放しな、威勢の可い、大學生がづか／＼と入つて來た。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "目は手釦の上にとまつた。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "留めの方がとれかかつて釦がぶらりと下つて居た。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわててそれを篏め直しながら、「見ろこの釦は。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋板がまた、がッたりがッたりいって、次第に近づいて来る、鼠色の洋服で、釦をはずして、胸を開けて、けばけばしゅう襟飾を出した、でっぷり紳士で、胸が小さくッて、下腹の方が図ぬけにはずんでふくれた、脚の短い、靴の大きな、帽子の高い、顔の長い、鼻の赤い、それは寒いからだ。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……渠は金釦の制服だし、此方は袴なしの鳥打だから、女中も一向に構はなかつたが、いや、何しても、靴は羊皮の上等品でも自分で脱ぐ方が可ささうである。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "到頭金釦をつけた空色の制服を着ている税関の役人が私の肩を敲いた。",
              "citation": {
                "source": "父を失う話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、やはりお金を持っておいで――」　井深君は、ほっとした気持で、直ぐ外套と上衣の釦を外してふところに手を差し入れた。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "うとうととしたと思うと、路次に跫音が聞こえ、呼び鈴の釦を押すらしかったが、戸を叩く音もしたと思うと、おいおいとそっと呼ぶ声もしていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　銀子は洋服の釦が花に見え、微かに言ったが、医師には通ぜず、「晴子は可愛い子だよね。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "給料を一文も費わないばかりか、営庭の掃除の時に見付けた尾錠や釦を拾い溜めては、そんなものをなくして困っている同僚に一個一銭｜宛で売りつけて貯金をする。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "加藤清正が金釦のシャツを着ていましたが、おかしかったですよ。",
              "citation": {
                "source": "虚子君へ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の少佐の胸のボタンが一つはとれて一つはとれかゝつて居るのが始終私の氣にかゝつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫の智慧　ある人の飼猫は主人の居室で椅子の上に登って呼鈴のボタンを押しボーイを呼出す癖があった。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッチの貼紙や切手を集めあるいはボタンを集め、達磨を集め、甚だしきは蜜柑の皮を蒐集するがごとき、これらは必ずしも時代の新旧とは関係はないが、珍しいものを集めて自ら楽しみ人に誇るという点はやはり骨董趣味と共通である。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説でも歴史の本でも皆そういう巻物になっていて、それを机上の器械にはめてボタンを押すとその内容が器械のスクリーンの上に映写されて出て来るというのである。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　部屋にかえると私は壁の黄色いボタンを執拗に押えつけて印度女の乱暴さをのろうように苛酷に一瞬間を指の先に約束する。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
