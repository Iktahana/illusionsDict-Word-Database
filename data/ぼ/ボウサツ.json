    },
    "definitions": [
      {
        "index": 1,
        "gloss": "premeditated murder",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "うっかりすると謀殺か強盗の廉で首を絞められるかも知れない虞れが十分にある。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故世の中には情死や殺人や強盗や姦通や自殺や放火や詐欺や喧嘩や脅迫や謀殺の騒が斷えぬのであらうか、何故また狂人や行倒や乞食や貧乏人が出來るのであらうか。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は予審調書を読んで、この事件は何者かあるいは、数人の謀殺であると知った時は、シャーロック・ホームズの死は、社会にとってはどんなに大きな損失であるかと云うことを、以前にもましてしみじみと痛感させられたのであった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはもちろん、シャーロック・ホームズ氏謀殺未遂事件でしょう、――」「いやいや、レストレード君、僕はこの事件の中には、一切関わりを持ちたくないんだがね。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年死んだヘッケルがエナ大学の蔵中になき猴種一疋を打ち取った時、英人ミラー大佐、たとい科学のためなりともその罪人を謀殺せるに当ると言うた（一九〇六年板コンウェイの『東方諸賢巡礼記』三一七頁）。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "陶淵明の『捜神後記』上にいわく、会稽句章の民、張然、滞役して都にあり、年を経て帰り得ず、家に少婦ありついに奴と私通す、然都にありて一狗を養うに甚だ快し、烏竜と名づく、のち仮に帰る、奴、婦と然を謀殺せんと欲す、飯食を作り共に下に坐し食う。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それさえわかっておれば、この事件はもう明瞭で、御子息の犯罪は『過失罪』ということにきまるのですが、たった一箇所｜曖昧なところがあるために、謀殺ではないかという疑いの余地が生じて来るのです。",
              "citation": {
                "source": "予審調書",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "過失罪として情状を酌量されるかどうかも、今となっては疑問で、ことによると謀殺と認定されるかもしれないのです。",
              "citation": {
                "source": "予審調書",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうですなあ、過失罪になればたいしたこともありますまいが、謀殺となると――まあその方が可能性が大きいと見なければなりませんからねエ――謀殺となると、まず、九分通り死刑ですかね。",
              "citation": {
                "source": "予審調書",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かような御布告が出た以上、親の敵を討っても、謀殺であることに変りはない。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "謀殺未遂というやつですねえ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "謀殺犯人と做すは可なり。",
              "citation": {
                "source": "続野人生計事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私欲のために謀殺される。",
              "citation": {
                "source": "死刑の前",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山本さん、わたしはあなたを奥田未亡人謀殺未遂として起訴します」",
              "citation": {
                "source": "愚人の毒",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その名例律の十惡の惡逆の注に、謀殺祖父母・父母といふ一句はあるが、かかる行爲に科する實刑を掲ぐべき賊盜律（一）には、諸謀殺期親尊長・外祖父母・夫・夫之祖父母・父母者皆斬。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに『唐律』を母法とせる我が『養老律』の賊盜律（『律疏殘篇』【賊盜律第七】所載）には、凡謀殺祖父母・父母・外祖父母・夫・夫之祖父母・父母者皆斬。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "『唐律』に謀殺祖父母・父母の文句を缺くことも、我が『養老律』がこの點で『唐律』と相違せることも、すべて私は今囘始めて心附いたのである（16）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は當初『唐律』賊盜律の脱落かと疑つたが、『通典』（卷百六十五、刑典三）や『宋刑統』（卷十七）に載せてある唐の律文にも、『唐律』と同樣に謀殺祖父母・父母の文句が見えぬ所から推すと、『唐律』の本文に、最初から親殺しの條項を缺いたものと斷定せなければならぬ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに期親の尊長、即ち伯叔父や兄※を殺害せんとする計畫の者を、已に斬に處するのであるから、又單に毆祖父母・父母者をも已に斬に處するのであるから、それ以上謀殺祖父母・父母者に適用すべき刑罰が、律にないといふ實際上の困難。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐律……無謀殺祖父母・父母罪名。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "その『明律』の親殺しの處分に關する條文には、凡謀殺祖父母・父母……已行者皆斬。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "（16）我が王朝時代の立法者が、『唐律』に存在せぬ謀殺祖父母・父母といふ一句を、『養老律』に増補した主意は、次の如く忖度することが出來る。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "（第一）　『唐律』の名例律に開列した十惡中の惡逆の註に、謀殺祖父母・父母の文句が見えて居る。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを母法とせる我が名例律の八虐中の惡逆の註に、同一の文句を使用する以上、賊盜律の條項に、謀殺祖父母・父母の文句を掲げても、不都合とは考へられぬ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "賊盜律を見ても、謀殺期親尊長（伯叔父母・兄※）の罰は遠流で、『唐律』の斬に比すると二等輕い。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に謀殺祖父母・父母の罰を斬と定めても、その間に毫も輕重の權衡を失せぬ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "賊盜律の謀殺祖父母・父母の一句も亦、かかる改正の一例である。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
