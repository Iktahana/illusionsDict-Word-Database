[
  {
    "uuid": "3a56159b-4e4e-5415-a135-9859c67d933a",
    "entry": "謀殺",
    "reading": {
      "primary": "ぼうさつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
