        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "◯世田谷名物ボロ市、昨日と今日と開く。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつてのボロ市では、飲食店が大繁昌したものだったが。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日が世田ヶ｜谷のボロ市。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世田ヶ谷のボロ市は見ものである。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世田ヶ谷のボロ市を観て悟らねばならぬ、世に無用のものは無い、而して悲観は単に高慢であることを。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボロ市過ぎて、冬至もやがてあとになり、行く／＼年も暮になる。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼろ市の散歩者　※　東京の世田谷にボロ市というのがある。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの手のボロ市を好いている。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の日本の文芸界の景色は、ボロ市の景色に非常に似て来た。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボロ市を歩くには、歩きかたがある。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、当時のデューク団長は今と大いに異なり、マルボロ市ハイ通り新聞店の二階に間借りし、みすぼらしい小部屋で愛妻に事件を打ち明けていた。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "市長やら、多くの著名人が訪れ、月曜日の正午ごろにはマルボロ市民がこの話を聞きつけた。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
