    },
    "definitions": [
      {
        "index": 1,
        "gloss": "disaster preparedness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうしてそれらの世襲知識を整理し帰納し演繹してこの国土に最も適した防災方法を案出し更にまたそれに改良を加えて最も完全なる耐風建築、耐風村落、耐風市街を建設していたのである。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩波書店から出ている「防災科学」全五巻は、近代社会としてはまことに素朴に自然力の下にさらされている日本にとって独特の意味を有すると思う。",
              "citation": {
                "source": "科学の常識のため",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
