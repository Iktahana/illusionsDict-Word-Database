    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ball",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕としてたゞまだ塵芥箱もないことだし、隅ッコに暫時捨てたわけで、おまけにそこらに前ゐた人が捨てて行つたのだらう、ボール箱や新聞紙のキレが相当散らかつてゐたので、そのお説教が始まつた時は全く意外であつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは折々フットボールが飛んで来て窓硝子が割れるので、校長の考案したことであつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄が湯から上つて来ると、耕二がボールをグラムに投げ込んではまたボールを手に取つて投げ込む――それを殆んど無意識に繰り返してゐるらしい音が、三畳の間でしてゐた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に耕二は足を投げ出して先に言つたボールをポツタポツタ言はせてゐるのである。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそんなことに一向無頓着で俯いてボールで時を潰してゐる耕二が何だか癪に障つた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "千の天使が　　バスケットボールする。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "可憐な都会の小学児童まで動員してこの木枯しの街頭にボール箱を頸にかけての義捐金募集も悪くはないであろうが、文化的国民の同胞愛の表現はもう少し質実にもう少しこくのあるものであってもよいと思われる。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナウエンの無線電信塔の鉄骨構造の下端がガラスのボール・ソケット・ジョイントになっているのを見たときにも胆を冷やしたことであった。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は医科大学生Ｆ兄弟の宅へ招ばれ、素晴らしく大きなクリスマス・ツリーの下で御馳走になり乍ら、医科大学の教室でつくるツリーへかける飾付けは、人間の心臓や肺、そのあらゆる人体諸臓器の形をボール紙で造らえて色彩をつけたものだという話など聞き夜を更かしました。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供のキャッチボールのそれ球をわんわんのように這って椽の下にさがしに行ったりどろだらけな靴下をつくろってやることもあります。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "なし〕「ボール投げなら僕決してはづさない。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ベースボール」は「野球」に完全に駆逐されてしまった。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体の地面よりは一段高い芝生の上に小さな猪口の底を抜いて俯伏せにしたような円錐形の台を置いて、その上にあの白い綺麗なボールを載せておいて、それをあのクラブの頭でひっぱたくと一種独特の愉快な音がする。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか、このキャディのうちの一人がリンクの池で鮒を一匹つかまえて、ボールを洗う四角な水桶の中に入れておいて、一廻りした後に取りに来たらもう見えなかったそうである。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間ばかりかと思うと、猫などが喜んで紙を丸めたボールをころがすのが、なんら直接功利的な目的があってするとは思われないから、やはりスポーツの一種らしく思われる。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家畜の糞を丸めてボールを作り転がし歩く黄金虫がある。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　八十三で亡くなった母の葬儀も済んで後に母の居間の押入を片付けていたら、古いボールの菓子箱がいくつか積み重ねてあるのに気がついた。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外の娯楽は乗馬、クリケット、フートボール、クロケー、射的などであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い包紙やボール函や封筒なども棄てずに取っておいて使った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "テニスの上手な来客でもこの羽根の生えたボールでは少し見当が違うらしい。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫が見たら人間のテニスやベースボールは定めて間だるっこくて滑稽なものだろうという気がするのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛾をはたき落す猫を羨み讃歎する心がベースボールのホームランヒットに喝采を送る。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボールの机にブリキの時計、時計はいつでも三十度くらい傾いて、そして二十五時のところで止っている。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　大掃除の午後の路地の交互点、こわれたおもちゃに葱大根の尻尾、空瓶空ボールの交響楽、マルクス、ムッソリニの赤ん坊の夢を買わないか。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも楢原さんのダンスは玉置さん仕込みだけあってボールが板の間についていてわるかぁないけど。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人はボール箱の荷物をおろすと、脂ぎった手で無神経にその毛布をめくり上げた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、橇に積んだボール紙の箱を乾草で蔽いかくし、馬に鞭打って河のかなたへ出かけて行った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろさまざまな恰好の壜がはいったボール箱が橇いっぱいに積みこまれた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
