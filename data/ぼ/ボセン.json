[
  {
    "uuid": "483ee114-e8b4-5d03-bf83-85dbf8d24904",
    "entry": "母船",
    "reading": {
      "primary": "ぼせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "depot ship",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は、はぢめ羅馬のつもりで、母船を脱け出したのであつたが、案外にも斯んな不思議な市だつたので全く途方に暮れてしまつたのである。",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにわれわれは母船を失った。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二京丸は三百四十｜噸、昨年の十月から今年の四月まで捕鯨母船極洋丸と共に南極の洋へ遠征し、キャッチャーボートとして百七十頭の巨鯨をとった手柄の船だ。",
              "citation": {
                "source": "鯨を釣る",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャッチャーボートは、この月末に南極の海へ母船と共に、巨鯨を狙って出発するという。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう鰹船を改造したあやしげな機船ではなく、どれもみなスクゥナー型のスマートなダイバー・ボートで、根拠地と現地を連絡する母船までつき、昭和九年の出漁船は百七十隻もあった。",
              "citation": {
                "source": "三界万霊塔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう潜水夫が入っているらしく、後帆をあげた三十六隻の採取船が一列になって青い海の上を活溌に移動し、二百屯ばかりのスクゥナー型の母船が、雛をまもる白鳥のようにそのあとから行き、水や食料を供給するランチがラガーからラガーへ火の出るように忙しく走りまわっている。",
              "citation": {
                "source": "三界万霊塔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日の午後になると、船団の活動が不活溌になり、五隻ばかりのラガーが母船のそばへ錨をおろしてしまった。",
              "citation": {
                "source": "三界万霊塔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "母船の医者は腐敗蛋白中毒だといって貯蔵の缶詰を海へ捨てさせているということだった。",
              "citation": {
                "source": "三界万霊塔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにラガーが弔旗を掲げて母船のまわりに集り、母船の前甲板で告別式のようなことがはじまった。",
              "citation": {
                "source": "三界万霊塔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝の七時ごろ、船長達がそちらにいるのかと母船から信号で訊いてきた。",
              "citation": {
                "source": "三界万霊塔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜、十時ごろ帰ったと返事をしてやると、母船の事務長がランチでやってきて、じつは船長達が一人も船団へ帰って来ないのだと心配そうな顔でいった。",
              "citation": {
                "source": "三界万霊塔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務長は礼をいって、沈痛な顔で母船へひきあげて行った。",
              "citation": {
                "source": "三界万霊塔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "威容を誇っていた二十六隻の船団は、母船とも十一隻になってしまったが、それから間もなく、船団の代表者の対島利吉が息子だという十二、三の子供を連れて遊びにきた。",
              "citation": {
                "source": "三界万霊塔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日の朝、船団の母船のそばへ船を持って行くと、調節弁付きの新式の潜水服をランチで届けてよこした。",
              "citation": {
                "source": "三界万霊塔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "梭魚のせいばかりでもないだろうが、せっかくの貝床を放棄し、船団を連れて外水道のほうへ行ってしまったが、後で聞くと、領海へ入って監視船に銃撃され、母船とラガーは没収。",
              "citation": {
                "source": "三界万霊塔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "母船上での操作は非常に巧くいっているらしく、数秒のうちに鋼索がぴんと張られ、機はほぼ正常の位置にもどる。",
              "citation": {
                "source": "海底の散歩",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母船を離れた大小のボートは、陸を目がけて夜光虫のように這い寄った。",
              "citation": {
                "source": "あめんちあ",
                "author": "富ノ沢麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい網打船に分乗、しばらくは網打ち、母船へ戻って、とり立てを天ぷらにして食ふ、去年と同じだから感興は薄いが、東京では味はへぬのんびりした遊び。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、あっしが兄貴分の役得で、乗られるんですね」「のぼせんな！",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
