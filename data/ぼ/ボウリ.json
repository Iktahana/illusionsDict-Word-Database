    "definitions": [
      {
        "index": 1,
        "gloss": "excessive profits",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "密輸入につきものの暴利をむさぼるだけではなかった。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸した物を買っても、すぐに暴利を貪ろうとする。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "始のほどは高利の金を貸し付けて暴利を貪り、作事を構へて他を陥れ、出ては訴訟沙汰、入ツては俗事談判の絶ゆる間も無き中に立ツて、頑として、たゞ其の懐中を肥すことのみ汲々としてゐた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そのぉ、乗合いとするとぉ、すでにその規定人員を超過して、しかもなおかつ暴利をぉ………。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の非義非道を働いて暴利を貪る所以の者は、やはり旨いものを食ひ、好い女を自由にして、好きな栄耀がして見たいと云ふ、唯それだけの目的より外に無いのだと謂ふが、さうなのかね。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一端男と生れながら、高が一婦の愛を失つたが為に、志を挫いて一生を誤り、餓鬼の如き振舞を為て恥とも思はず、非道を働いて暴利を貪るの外は何も知らん。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇薬　徽州｜懐金郷の程彬という農民は、一種の毒薬を作って暴利をむさぼっていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "団十郎はその傲慢が増長して法外の暴利をむさぼると言うものもあった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも拘らず、主としてこの商人達を相手とする商工大臣農林大臣の連署になる省令暴利取締令の範囲拡大の公布は、如何にも物価騰貴対策という国民生活安定策の一つでもあるかのように、提出されている。",
              "citation": {
                "source": "挙国一致体制と国民生活",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣家は、支那人の経営する東洋美術骨董店で、大体余り上等な区域ではないが、ホテルは昔からやっているのと、静かで暴利ないのとで、一部の商用を帯びた旅行者などには、よく知られていたのだった。",
              "citation": {
                "source": "ロウモン街の自殺ホテル",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう在来の暴利的習慣は容易に改められるものでない。",
              "citation": {
                "source": "私娼の撲滅について",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして最近に及んで遅れ馳せに暴利取締令を出したり、全国にわたって十｜石以上の貯蔵米を申告させたり、御用商人に托して外米の輸入を計ったりしたような事が、かえって一層米価の暴騰を激成する結果となりました。",
              "citation": {
                "source": "食糧騒動について",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "指導者側のそれらの婦人たちの中の或人たちが、経済的労働を私たち婦人に奨励されるのを見ると、その目的が利殖の外に出でず、その方法が振売商人の暴利を狙う不正手段と大差のないものであるのに呆れます。",
              "citation": {
                "source": "婦人指導者への抗議",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "通三丁目の、米屋というのは、長崎屋三郎兵衛が、仲間と組んで、出している米穀問屋、つまり、この二、三年の、関東、東北の不作状態を見込んで、上方西国から高い米を廻し、暴利をむさぼって、恒、日ごろから、市民の恨みを買っていたのだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気の為に信心して幸に痊ゆれば平気で暴利を貪って居る者もある。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして公平な商人は、意志をまげてまで、不当の暴利を貪りはしない。",
              "citation": {
                "source": "操守",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、「金さへ払へば」といふ客種の感覚喪失をいゝことに、趣味低き旅館経営者は、まことに驚くべき手段をもつて、その歓心を買ひ、自尊心をあふり、暴利をむさぼる口実とする。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかがわしい地蔵の像を刻んでは盛んに売り出して暴利を貪り、怪しげな呪文や護符を撒布して愚民を惑わす、との風聞も頻りなるにより、我々同志が事情を篤と見届けに参ったのだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座の山崎なぞは暴利を貪るのみにて、縫目あるいはボタンのつけ方｜健固ならず。",
              "citation": {
                "source": "洋服論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢張りぶつ／＼云ひながらそれを飲むのと一緒で、競馬ファンも其通りで、クラブが不親切な残酷な暴利過ぎると云ひつゝ止めることが出来ぬ。",
              "citation": {
                "source": "競馬興行と競馬狂の話",
                "author": "初代　桂小南",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月十二日（水）　今日から暴利取締令がいよいよ励行されて、宅の近所で商店や露店の売品の値が高いと言って巡査に殴られたり、蹴られたりしたものがあった。",
              "citation": {
                "source": "震災後記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はそのほかにも巣鴨、市ヶ谷の刑務所や、そんじょそこらの暴利屋などにも焼けなかったのが多いのだ。",
              "citation": {
                "source": "震災後記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でなら暴利取締令によって、刑務所へ送られたのであったかも知れぬ。",
              "citation": {
                "source": "震災後記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "★暴利征伐　他人の災害をよいことにして不当に商品を値上げし、この機会に暴利を貪ろうとする奸商の少からぬのは憎んでもなお余りあることだ。",
              "citation": {
                "source": "震災後記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府もこれに鑑みてさっそく暴利取締令を発布し、警視庁から特に各警察署に訓示するところがあったと見えて、秩序もやや立って来た十一月に、自分の近所では巡査が一々売値段を調べて廻ったものだ。",
              "citation": {
                "source": "震災後記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その工場は軍用毛布を一手に受けて暴利を貪って居たのだが、その血が残って一枚も納まらない。",
              "citation": {
                "source": "落ちぬ血痕",
                "author": "根岸正吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、いつものあの黒い服の擦れる音、暴利の白粉で白くなったように、そこかしこ光っている黒い服。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "物理学者たちの消極的反対にもかかわらず、千里眼の方は益々流行を極め、「天下その真偽に惑い奸催眠術者の徒｜忽ちに跋扈を極め迷信を助長し暴利を貪り思想界を擾る」という状態にまでなったのである。",
              "citation": {
                "source": "千里眼その他",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "備中地方ではこの草で編んだ蓑を「ぼうりょう」と呼んでいる。",
              "citation": {
                "source": "蓑のこと",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
