[
  {
    "uuid": "a74892af-a3c9-5d60-a3b6-489d8253150b",
    "entry": "棒術",
    "reading": {
      "primary": "ぼうじゅつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
