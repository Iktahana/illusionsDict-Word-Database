[
  {
    "uuid": "8c349396-a20d-5ed0-81ee-3ebbae347623",
    "entry": "牧人",
    "reading": {
      "primary": "ぼくじん",
      "alternatives": [
        "まきびと"
      ],
      "is_heteronym": false
    },
    "grammar": {
