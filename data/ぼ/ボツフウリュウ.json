          "literary": [
            {
              "text": "故宅と言えば風流なれど、今は郵便局の横町にある上、入口に君子自重の小便壺あるは没風流も亦甚し。",
              "citation": {
                "source": "北京日記抄",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "其にしても、没風流の上に、ものゝあはれを度外視して、うき世に沈湎する人・悟り得ぬ不信者など云ふ義はあつた。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "その没風流に比興した聾の夷神で名高くもなつた。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "画工であればこそ趣味専門の男として、たとい人情世界に堕在するも、東西両隣りの没風流漢よりも高尚である。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "風流を以て今宵をはじめた二人の風流人は、極めて没風流な用向を兼ねて、関ヶ原の真中の夜に没入してしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
