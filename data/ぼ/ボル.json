    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to ask a high price",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "男、コーヒーを啜つて天井の隅を凝視したまゝ――右手の指に挟まれた葉巻から、冷い空気の中を薄紫の煙が細く細く立ちのぼる。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで、私が思い浮べたのは、北米ポートランド市の、シチイ・パークから遠望した、フッド火山の、においこぼるる白無垢小袖の、ろうたけた姿であった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、未だ見ぬ遠い彼方の別世界へこれから分けのぼる途中の嶮しさを想はせるのであつた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、まだ見ぬ遠い彼方の別世界へこれから分けのぼる途中の嶮しさを想わせるのであった。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが何のため、向ふは壇をのぼるのだ。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "常盤の松を名に呼べれば、千歳ならずとも枯野の末まではあるべきを、萩の花ちりこぼるゝやがて声せずなり行く。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、一夜中、親爺のその煙草の臭いをむさぼるように嗅いだ。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "密輸入につきものの暴利をむさぼるだけではなかった。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四丁のぼると、すきを伺って、相手の頸もとへひらりと飛びこんでくるシャモのように、舳の向きをかえ、矢のように流れ下りながら、こちらへ泳ぎついてきた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は気がついてすぐ頭の上を仰ぐと、昼間は真っ白に立ちのぼる噴煙が月の光を受けて灰色に染まって碧瑠璃の大空を衝いているさまが、いかにもすさまじくまた美しかった。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろはあるかなきかに思われし源叔父またもや人の噂にのぼるようになりつ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "西の山｜懐より真直に立ちのぼる煙の末の夕日に輝きて真青なるをみつめしようなり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句の季題と称するものは俳諧の父なる連歌を通して歴史的にその来歴を追究して行くと枕草子や源氏物語から万葉の昔にまでもさかのぼることができるものが多数にあるようである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな魚のやうに川上へのぼるらしいのでした。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、自分の恍惚状態を夢のようにむさぼるばかりだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「太陽は、　丘の髪毛の向うのほうへ、　かくれて行ってまたのぼる。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてかくれてまたのぼる。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ちのぼる蒸気は毎日弱ってゆく。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう一度」　少女は確かめたいばかりに、また汗を流して傾斜をのぼる。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "織次は偶と幻に見た、夜店の頃の銀河の上の婦を思って、先刻とぼとぼと地獄へ追遣られた大勢の姉様は、まさに救われてその通り天にのぼる、と心が勇む。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の門、植木屋の庭、花屋の店など、坂下を挟みて町の入口にはあたれど、のぼるに従いて、ただ畑ばかりとなれり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり倦みたれば、一ツおりてのぼる坂の窪に踞いし、手のあきたるまま何ならむ指もて土にかきはじめぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴のごとく、その底よりは風の吹き出づると思う黒闇々たる坂下より、ものののぼるようなれば、ここにあらば捕えられむと恐しく、とこうの思慮もなさで社の裏の狭きなかににげ入りつ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだやうな夜気のなかに、凝つて、ひとり活きて、卯の花をかけた友染は、被衣をもるゝ袖に似て、ひら／＼と青く、其の紫に、芍薬か、牡丹か、包まれた銀の鍋も、チチと沸くのが氷の裂けるやうに響いて、ふきこぼるゝ泡は卯の花を乱した。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ新しくて青き光失せぬ建仁寺籬折りまはしたる小さき坪の中に咲き出でたる、あるはまたよろづ黒みわたりたる古き大寺の書院の椽近く※ひこぼるゝなど、云ひがたき佳きおもむきあり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "我邦にては、はやくより咲くもあれど、春に至りて美しく咲きこぼるゝを多しとす。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かげろう」が立つのは、壁や屋根が熱せられると、それに接した空気が熱くなって膨脹してのぼる、そのときにできる気流のむらが光を折り曲げるためなのです。",
              "citation": {
                "source": "茶わんの湯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの祖先を千年前にさかのぼると、今の自分というのはその昔の二千万人の血を受け継いでいる勘定だそうである。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓からのぼる煙が渦巻いて来たら床の面へ顔をつければよいかと思われる。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてかくしのキャラメルを取り出して三つ四つ一度に頬張りながら南方のすそ野から遠い前面の山々へかけての眺望をむさぼることにした。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
