[
  {
    "uuid": "5ce1974c-4049-5b9f-8349-b3adfc5bb0a5",
    "entry": "盆地",
    "reading": {
      "primary": "ぼんち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
