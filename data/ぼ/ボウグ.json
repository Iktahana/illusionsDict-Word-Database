        "examples": {
          "standard": [
            {
              "text": "剣道では、面や小手、胴などの防具を身につける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ラグビー選手は、頭部を守るためにヘッドキャップという防具を着用する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重厚な防具を身につけた騎士たちが、城門を守っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "実に彼は死よりもつらき不面目を担いつつ、折角新調したりし寒防具その他の手荷物を売り払いて旅費を調え、漸く帰京の途にはつき得たるなりき。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（b）学問が自然の不幸に対する我々の新たな防具たらんと努めながら、かえって我々の心の中にそうした不幸の大きいこと重いことを深く刻むだけに終り、何一つそれらに対して我々をかばう理由も理屈も教えなかったとは何たることであろう。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "先客の三人も今来た一人も、みな土方か立ちんぼうぐらいのごく下等な労働者である。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
