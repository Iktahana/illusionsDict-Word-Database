    "definitions": [
      {
        "index": 1,
        "gloss": "plotting to damage the imperial palace or an imperial tomb",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
