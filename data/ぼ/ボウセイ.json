[
  {
    "uuid": "a5675bfd-d183-508c-9468-9dc784febfe7",
    "entry": "暴政",
    "reading": {
      "primary": "ぼうせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
