    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mediocre ability",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それをこのくらいにまでまとめ上げるのはやはり凡手ではできないであろう。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜しむらくはその職人の名が伝わっていないが、彼は決して凡手ではなかったと見えて、その細工は甚だ巧妙に出来あがって、寺の西の軒に高く置かれたのを遠方から瞰あげると、さながらまことの龍のわだかまっているようにも眺められた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "泳いでゐる小魚が一尾づゝ己れの影をここでは魚自身の観念体としての影を、ひつぱりながら遊泳してゐる詩味は凡手の到底着想し得ないところであらう、水草をもまた生きたものとして生活させてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京朝日に出た『波の上』なども、新聞で毎日読んでは冗長なやうな気がするけれども、男女のもつれを二条はつきり出して見せたところは、凡手の及ぶ所ではない。",
              "citation": {
                "source": "自他の融合",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際一面からいえば、痒いところへ手の届くように書きこなされてあるのであって、これは到底凡手の企て及ばざるところである。",
              "citation": {
                "source": "「マリー・ロオジェ事件」の研究",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮花の茎が入り乱れて抽でている下に鷺を配したところも凡手でなく、一種重厚な、美を貫く生の凄さに似たものさえ、その時代のついた画面から漂って来るのだ。",
              "citation": {
                "source": "蓮花図",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらも凡手段の及ぶ所でない。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "落花を画いて置きながら桜の樹を画かずかへつて柳をあひしらふた処は凡手段でない。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "舊作家の固有派に屬するは、其凡手なるためなり。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな一つの造句でも凡手のよく造り得る所ではない。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前からある替手というものとは違った意味で――」　箏の調子を低くしろということは、これは凡手には言えないことだ。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　　「悪霊」――　わたしは今この町――別にこれという特色もないこの町で、つい近頃もちあがった、奇怪な出来事の叙述に取りかかるに当って、凡手の悲しさで、少し遠廻しに話を始めなければならぬ。",
              "citation": {
                "source": "作家的思想",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌は前篇の作者にくらべて劣るが凡手でない、その時代に歌人として頭角を現わしていた人の筆になった傑作小説として、私は大弐の三位の家の集をずいぶん捜し求めたが現存していない。",
              "citation": {
                "source": "『新新訳源氏物語』あとがき",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新小説」「文藝倶樂部」「新著月刊」「小天地」といふやうな一流の文藝雜誌に掲載されたものは大凡手に入つたつもりでゐた。",
              "citation": {
                "source": "貝殼追放",
                "author": "購書美談",
                "note": "青空文庫"
              }
            },
            {
              "text": "その描写、ただ、水の波紋の次第に減らしてゆく丈、それで静かに大らかにたたえられた水のひろさと日の暖かさまで感じさせるのだから凡手でない。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "野上君の処女戯曲岸田國士「夢を喰ふ女」は野上彰君の最初の戯曲だといふことだが、私は作者自身に朗読してもらひ、第一幕ですでにその凡手でないことを感じ、ところどころ散漫な部分はあるにはあるが、ともかく、最後まで楽しんで聴くことができた。",
              "citation": {
                "source": "野上君の処女戯曲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩のおとく孝助の新枕を「玉椿八千代までと思い思った夫婦中、初めての語らい、誠にお目出たいお話でございます」云々とまことにいやらしくなく、簡潔の中に一味清純な艶かしさをたたえていて凡手でない。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこ迄もこの旦那、よい人であることが、こうした動作ひとつで如実に分ってくるところ、繰り返すようだが凡手でない（どうして旦那に長兵衛の住所が分ったか、それはもう少しあとまで読者よ聞かないでいて貰いたい）。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、そこに土橋がある……』　に、江戸末年の高田、落合風景｜泛びて、まことにこの描写、凡手ならずと今に嘆称するのところなり。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはとうてい凡手の好くするところではない。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "霙橋辻斬夜話",
                "note": "青空文庫"
              }
            },
            {
              "text": "狹い庭にごちやごちや石をならべ、ともかくもこれだけのものを作り上げるといふことは、凡手では仕上げられない仕事であらう。",
              "citation": {
                "source": "京洛日記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも交互におく黒白の一石は自分の恥しい俗手凡手ではなくて本因坊の、井上｜因碩のそれである。",
              "citation": {
                "source": "独り碁",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは普通第一石とは遠く離れた碁盤の他の隅に置かれようとも遥に第一石を睨まえ、我われ凡手には考察しきれぬ複雑な戦略的理由によって盤石のごとく動かしがたく据えられるのである。",
              "citation": {
                "source": "独り碁",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "数かずの局を続けることにより古人の名局が凡手の脳裡に錯綜して風趣をそこなうことのないように。",
              "citation": {
                "source": "独り碁",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この有名な難曲を、これほど楽々と弾くことは凡手の企て及ぶところでなく、その上バックハウスの演奏風格は、申し分なく高朗である。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの刀さばきは凡手では不可能だ。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前のミロクは皮肉の作だが、彫りの気魄、凡手の作ではない。",
              "citation": {
                "source": "夜長姫と耳男",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "探し疲れて権現堂の迂回路へ戻って来ると、孫次郎はもういちど二人の死体を検めて、「おかしい、この突き傷にはなんだか覚えがある……みんな一刀ずつ、しかも的確に急所を覘った突は、凡手ではない」「とにかくこうしていてもしようがない」　伊兵衛が云った。",
              "citation": {
                "source": "夜明けの辻",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣＬの阪田英一が来て待ってゐる、「ハリキリボーイ」の脚色についていろ／＼意見を出す、いゝシナリオ屋がゐない、阪田も凡手であるが熱心らしいからまあいゝ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "九州に同名の凡手の画家があったのだ。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
