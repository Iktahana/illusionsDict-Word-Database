    "definitions": [
      {
        "index": 1,
        "gloss": "behaving outrageously as though there were no one around",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "味方と思つた彌次連は、先刻から傍若無人の暴言を小面憎く思つて居た、敵であつたのだ。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜に村の煮売屋などの二階から、大勢兵隊が赤い顔を出して、近辺の娘でも下を通りかかると、好的好的などと冷かしたり、グズグズに酔って二、三人も手を引き合うて狭い田舎道を傍若無人に歩いたりするのが、非常に不愉快な感じを起させた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、瀬戸内海を傍若無人に通り抜けた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば大勢の中にきっと一人くらいは「豪傑」がいて、わざと傍若無人に振舞って仲間や傍観者を笑わせたりはらはらさせるものである。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "群集からこぼれ出て路端に傍若無人に立小便をしている男も見逃してやりたい。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座二丁目辺の東側に店があって、赤塗壁の軒の上に大きな天狗の面がその傍若無人の鼻を往来の上に突出していたように思う。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　日本人の威張り方は傍若無人だ。",
              "citation": {
                "source": "防備隊",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが食堂で夜ふけまで長時間続いていた傍若無人の高話がようやく少し静まりかけるころに始まるのが通例であった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍若無人に何か柿江と笑い合う声がしたと思うと、野心家西山と空想家柿江とはもつれあってもう往来に出ているらしかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺が札幌にいりゃ、この幕は貴様なんぞに出しゃばらしてはおかなかったんだが」　そういって西山は取ってつけたように傍若無人に高笑いするよりのがれ道がなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけれど兄であるのを嵩に着て傍若無人の振舞をし続けたり、弟だからとて甘えて放蕩の仕ほうだいをする。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といいさま追い縋って、多磨太は警部長の令息であるから傍若無人。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋水を佩ける将校もあり、勲章を帯べる官吏もあり、天下有数の貴婦人、紳士、前後左右を擁せる中に、半身の裸美自若として突立ちたるは、傍若無人の形状かな。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……暢気さも傍若無人で、いずれ野宿の、ここに寝てしまうつもりでいよう。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたがいの遠慮――この美徳はたしかに昔の人に多かったが、殊に前にいったような事情から、むかしの浴客同士のあいだには遠慮が多く、今日のような傍若無人の客は少かった。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　市郎も驚いて顧ると、怪しの婆は傍若無人に呵々と笑った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "赫子は、云うだけは云ったが、折角の計劃が無になったいまいましさを紛らす為めか傍若無人にたてつづけの鼻唄。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ茶会の当日には、まず会主のお宅の玄関に於いて客たちが勢揃いして席順などを定めるのであるが、つねに静粛を旨とし、大声で雑談をはじめたり、または傍若無人の馬鹿笑いなどするのは、もっての他の事なのである。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十四歳で死したるかれには、大作家五十歳六十歳のあの傍若無人のマンネリズムの堆積が、無かったので、人は、かれの、ユーゴー、バルザックにも劣らぬ巨匠たる貫禄を見失い、或る勇猛果敢の日本の男は、かれをカナリヤとさえ呼んでいた。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と次第に傍若無人の高声になって、「のう、玄斎、よしその人魚とやらの怪しい魚類が北海に住んでいたとしてもさ、そんな古来ためしの無い妖怪を射とめるには、こちらにも神通力が無くてはかなわぬ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……鳥のような、獣のような異体な黄色い脚を、ぬい、と端折った、傍若無人で。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あ、あ、あ、と傍若無人、細長き両の腕を天井やぶれよ、とばかりに突き出して、しかもその口の大きさ、歯の白さ、さながら、馬の顔であった。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間も構わず傍若無人、と思わねばならないのに、俊吉は別に怪まなかった。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "濶歩埋葬地の間をよぎりて、ふと立停ると見えけるが、つかつかと歩をうつして、謙三郎の墓に達り、足をあげてハタと蹴り、カッパと唾をはきかけたる、傍若無人の振舞の手に取るごとく見ゆるにぞ、意気｜激昂して煙りも立たんず、お通はいかで堪うべき。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずかずかとその主家にはいり込み、納屋をのぞき、牛舎へ廻り、ほとんど傍若無人の限りを尽していた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "義雄はかう云ふ時には非常にはしやぎ出す方で、皆を傍若無人に揶揄しながら賑やかに誰れでもの相ひ手をした。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "痛快にも傍若無人にもお話にならない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍若無人はこうした応待の席ばかりでない。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつものとおり、傍若無人で良人の意志など問題でないようであった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と傍若無人の駄々を、こねているらしかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
