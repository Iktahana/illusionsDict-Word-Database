          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "漁師は、腰まで水に浸かる作業のため、丈夫な防水長靴を着用していました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この防水長靴は膝上まであり、川や沼での作業に非常に役立ちます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長時間の水作業でも足が冷えないように、厚手の防水長靴を選びました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
