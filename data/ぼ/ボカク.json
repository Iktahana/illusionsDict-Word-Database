        "examples": {
          "standard": [
            {
              "text": "放射性崩壊によって、ある元素の母核が別の元素の娘核に変化する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その反応では、不安定な母核が安定した状態へと変化していく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "核物理学の研究では、母核の構造が重要なテーマとなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それはともあれ、フランスに於ける演劇の取り扱はれ方は、ほぼかくの如きものであつた。",
              "citation": {
                "source": "演劇と政治",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "同盟の結ばれ解かれる順序はほぼかくのごとくで、決して永久不変のものではない。",
              "citation": {
                "source": "戦争と平和",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
