    "definitions": [
      {
        "index": 1,
        "gloss": "writing in India ink",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鏡板の松は墨絵で、シテ座後方の鴨居に「安和堂」と達筆に墨書した木額が上げて在った。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "売薬の名を大きく墨書した白｜洋傘をさして、学童の鞄を下げた朝鮮服の男が、安重根と反対側に立って大声に言いはじめる。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十八頁以下の欄外には往々「伊沢信重書」、「渋江全善書」、「森立夫書」等補写者の名が墨書してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨書は榛軒、朱書は柏軒である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "鑑札は白木の札に墨書して、烙印を押したものである。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その横の壁のうんと高いところに銀三四九〇とアラビア数字で白墨書きがあり、気がついて見ると、その電話のまわりには、謂わばところきらわず、がさつな事務所にでもありそうに番号変更の紙を貼りつけたり、番号をかきちらしたりしてある。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、其も墨書きや彩み画の絵巻若しくは、屏風の構図であつた。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "此句だつて、唯の墨書きではない。",
              "citation": {
                "source": "河童の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次に曰く、三、丈が二尺グライノ花瓶、口ニ拇指ヲ置キテ指ヲ中ニサシ入レテ花瓶ノ内側ヲサグリ、中指ガアタルトコロニ、小サク５０９８ト墨書シアリ。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、十五年前に墨書し、その後十五年間｜瓶の中に水を張ったのでは、大伴の黒主の手を借らずとも、今日５０９８の文字は消え失せているに違いなかろう。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "天幕の裏はすべて墨書きの雲であつた様に思ふ。",
              "citation": {
                "source": "だいがくの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊池幽芳氏の『琉球と爲朝』には、其の木棺の一に「ゑさしのあし」と墨書したものがあつたとある。",
              "citation": {
                "source": "沖繩の旅",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "表紙には随筆と墨書してあるが、中味はペンで書いたものだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな粗末な裝幀で、一册は「本木昌造、平野富二詳傳」他の二册は「活字高低の研究」「植字能率増進法」であつたが、「本木昌造、平野富二詳傳」の方は、表紙に「再版原稿」と墨書してあつて、いろんな書込みや、貼込みがしてある。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は蟲の喰つた寫本の肩をいからせた墨書き文字をながめながら、百年前の鬱勃とした知識慾といふか、進歩慾といふか、そんなものを、身體いつぱいに感じながら、當時の世界を想像してゐるうちに、Ｋ・Ｈ氏にきいた木村嘉平のことがつよく泛んできた。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "血気盛んなる小児の腹中に寄生する小虫を見る法なりとて、俗間に伝うるものを述ぶるに、小児の掌面に呪文三回墨書し、さらにその上を墨にて塗抹して文字をして不明ならしめ、これを握ること暫時にしてその手をひらき見れば、その爪甲より毛ようのごとき白繊維のもの続々出ずるなり。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が筆墨書籍に事欠かせまじとては、夜もろくろく内職のお手休めたまはぬほどの御難儀、ああこれもかれも我が身の為か勿体なやと、心づくやうになりては。",
              "citation": {
                "source": "葛のうら葉",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この絵には署名こそ「劉生」とあれ、落款の印章はまだ作られてゐなかつたと見えて、墨書した劉生の下に朱書きで劉の字の左書きが文様風に添へてあるのである。",
              "citation": {
                "source": "岸田劉生の日本画",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "真面目な墨書きの巻紙で五尺に及んでいるものさえあった。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "道人の漢字・仮名まじり文の調和したうつくしさは、墨書の書翰などにもつともよく現はれてゐるとおもふ。",
              "citation": {
                "source": "秋艸道人の書について",
                "author": "吉野秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛乗りを承る者は、顔へ白粉を塗り額へ大の字を墨書し、裃を着し赤青紙張りの笠を破り、手に長い竹弓と蕪矢を持つ。",
              "citation": {
                "source": "穀神としての牛に関する民俗",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "台の両側に赤く縁どった張り紙がしてあって、墨書で「今日明日限り」とある。",
              "citation": {
                "source": "宝くじ・その後",
                "author": "始めてから十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　当時の中学には、「罰札」というのがあって小さな木の札に墨書してあったが、普通語（ヤマトグチ）を励行させるために、沖縄語（ウチナーグチ）を罰したのである。",
              "citation": {
                "source": "初恋のやり直し",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "）を墨書した紙があったり、古い相撲の番付や、映画のスチール写真などが、その八畳の日本間の壁という壁に貼られていた。",
              "citation": {
                "source": "軍国歌謡集",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし多数の生徒たちが墨書で署名するようだったら、自分も人並に墨書する方がいいと思ったからである。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙は宛名を墨書して座敷の机の上にのせてあったが、それは俊亮の手紙にしてはめずらしく分厚なものだった。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ見返しに誌された、このぬしの墨書が、なかなかに見事で、しかも女の手、そうして、どうやら床の間の「花の色は」の筆蹟と似通っていることだけです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "※852　「ふきの匂ひ」（明治16年）裏表紙見返しの墨書。",
              "citation": {
                "source": "藤野古白句集",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田親分さんのお志、ありがたく頂戴いたして置きます」「こら、金さん、そんな汚れた銭、受け取んな」「まあ、おれに委せとけ」　金五郎は、そういって、君香から、「御見舞」と、表に、太く墨書された、部厚な慰斗袋を受けとった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
