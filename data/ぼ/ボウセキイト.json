        "examples": {
          "standard": [
            {
              "text": "このシャツは、細番手の紡績糸で織られているため、とてもなめらかです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "丈夫な紡績糸は、ジーンズなどの厚手の衣料品によく使われます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は、紡績糸を使って手編みのマフラーを作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "余程｜鍛練して上手になった人が、まずむらのない細い糸を拵える位のもので、その細い糸といったところで紡績糸のようなものは夢にも見ることが出来ん。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "栓抜きは、紡績糸で、天井から吊るしてある。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
