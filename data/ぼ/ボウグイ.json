        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "月あかりのために、石ころや、笹の葉や、棒杙や、掃き溜めまで白く光っていた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "路傍に粗らに棒杙を打ち並べた垣根の裾に、汚れた雪が吹き寄せられて溜まっている。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十七圖　現代水上住居　新石器時代の人間は、またあるところでは湖水の中に棒杙を打つてその上に小屋を設けて棲んでゐました。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その底に棒杙が一萬本もにょき／＼と立つてゐるのをケラーといふ學者が發見しまして、だん／″＼研究した結果、これが昔の人の湖上住居の跡であることがわかりました。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "棒杙相手に物を言うようなものです。",
              "citation": {
                "source": "女房ども",
                "author": "БАБЫ",
                "note": "青空文庫"
              }
            },
            {
              "text": "棒杙と、横板、俵などで、あぶなっかしく一時の足がかりが出来ている。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙と焼棒杙の間からお顔を見るような感じでしたから、田舎でゆっくりと出来たらさぞうれしいことでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
