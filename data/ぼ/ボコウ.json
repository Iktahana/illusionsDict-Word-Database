[
  {
    "uuid": "ac1505b3-dfb9-54a3-a914-4775ea1efe41",
    "entry": "母校",
    "reading": {
      "primary": "ぼこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "alma mater",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "卒業後長崎三菱造船所に入って実地の修業をした後、三十四年に帰京して大学院に入り、同時に母校の講師となった。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、母校の悪口はおっしゃらないで下さい。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけは、母校の名誉のために申し上げて置きたいと思います。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は之れ、なつかしき杜陵の母校の旧恩に酬ゆる一端かとも被存候。",
              "citation": {
                "source": "渋民村より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "五山は秀でて水清く秀麗の氣をあつめたるこのみちのくの澁民の母校の友よいざさらば文の林の奧深く理想の旗を推し立てむ。",
              "citation": {
                "source": "唱歌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方の国立高校で進学希望者の多かった『我が母校』も、その嵐から無縁ではなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "で大音寺が徐ろに云ひ出すところを聞いて見ると、彼は「正義団」といふものの一員で、且又応援団の理事であつて、対一高戦が迫つた折から応援団員を物色中であるのだが、君は余程のフアンと見た、打ち見たところ稍はにかみ屋であるらしいが母校の為に団員に加はらないかと進めるのであつた。",
              "citation": {
                "source": "大音寺君！",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、自分の母校――と云う程の親しみは持っていなかったが――の学生であるのを欣んだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、おまえは、母校が消えてかまわないっていうのか！",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、たとえ半分だとしても、母校だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねてから母校の先輩として尊敬していた白鷹先生の名前を久し振りに聞いた私は、喜びの余り眼を丸くして彼女に問いかけたのであった。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "母校の出来事の全部は、わたくしの到らなかった責任で御座います。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまだ睡眠剤から醒め切れないような夢心地で、死ぬにしても生きるにしても、どちらにしても考えようのないような考えを、頭の中一パイに渦巻かせながら、今一度、母校の正門を潜りました。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからズット以前に、学校の化学教室から盗んで置きました××××と脱脂綿と、昨日買って置きました△△△△と△△△とを持って、あの母校の思い出の廃屋に忍び込みます。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、母校とは云いながら、私たちに取っては縁の薄い方である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、自分の母校――と云ふ程の親しみは持つてゐなかつたが――の学生であるのを欣んだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　これは此市で一番人の目に立つ雄大な二階立の白堊館、我が懷かしき母校である。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　これは此市で一番人の目に立つ雄大な二階立の白堊館、我が懐かしき母校である。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（学習院の女子部といふのは、自動車の運転手と情死した芳川夫人の母校である。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "母校の建物が私の目に浮んで来た。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう母校の歌をささやいてるような気がする」　なつかしさがこみ上げて私は岸伝いの道路を急いだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は篠竹のステッキで路ばたの藪をたたきつつ、口笛まじりに、朝霧のこめた馬洗川伝いに一時間も歩くと母校の柵や、いらかがもう見え出した。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女等は母校と校長にもゆるやうな反感を持つてゐた。",
              "citation": {
                "source": "編輯室より（一九一五年五月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙ中学の卒業生で、このほど陸軍大学を首席で卒業し、恩賜の軍刀を拝領した少佐が、帰省のついでに一日母校の漢文の旧師を訪ねて来た。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイスクール時代の後半を、コンピューターの回路設計に夢中になって過ごしたウォズニアックは、父の母校であるカリフォルニア工科大学の受験に失敗し、地元のデアンザ・コミュニティー・カレッジにしばらく籍を置いたあと、一九六八年、コロラド大学に入りなおした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（都の西北、早稲田の森に……）　今はそこらの幼稚園の生徒でも、何かというとすぐ口癖のように歌い出す程あまねくひろまったこのなつかしい「われ等が母校」の歌が、はじめて「早稲田の森」から歌い出されたのは、明治四十年の秋、大学創立二十五年記念祭の折のことだった。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「遣唐使と日本に於ける近代精神の交渉」という評論の一部も、前に矢代は母校の教授に出してあり、幾らか好評を受けている話も聞かされていたから、なお励みも増して来ていたときの突然の父の死だった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊勝気に白い服を着込んで、母校の研究室に居据ってしまった。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして彼の学術研究……断頭刃磨ぎを断然打切るべく、彼が母校に提出した学位論文の根本主張は、何であったか……曰く……『脳髄は物を考える処に非ず……』」「……………」「……かくしてＭの個人としての煩悶は遂に、学術の研究慾に負けた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、その右の膝小僧の上に大きな肉腫が出来たからで、私が母校のＷ大学のトラックで、ハイハードルの練習中にこしらえた小さな疵が、現在の医学では説明不可能な……しかも癌以上に恐ろしい生命取りだと云われている、肉腫の病原を誘い入れたものらしいという院長の説明であった。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
