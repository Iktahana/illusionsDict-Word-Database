        "examples": {
          "standard": [
            {
              "text": "周囲の苦しみを顧みない彼の振る舞いは、まさに非情な木石漢と言わざるを得ない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "どんなに美しい音楽を聴かせても反応しない彼を、友人は木石漢だと笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "木石漢と噂される彼だが、実は陰でこっそり動物愛護の活動をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "僕コウ見エテモ必ズシモ木石漢ニ非ズ、芳子ノコトナド思イ出シテ感慨無量ナルモノアリ、唯何処マデモソウ云ウ感情ヲ後ニ残シテ斯波ノ家ヲ去ラナケレバナラナクナッタアナタノ不仕合ワセヲ歎クノミデス。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
