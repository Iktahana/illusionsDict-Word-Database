[
  {
    "uuid": "a1fb447b-6aaa-5af8-a096-35fd5ca8db12",
    "entry": "ぼつぼつ",
    "reading": {
      "primary": "ぼつぼつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gradually",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "著実な詩の書が、ぼつぼつと出ることともなれば、文壇はもつと住心地のよい所ともなるであらう。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いことがぼつぼつ復活する当代であるから、もしかすると、どこかでまたこの「鴫突き」の古いスポーツが新しい時代の色彩を帯びて甦生するようなことがないとも云われないであろう。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをぼつぼつ切にして、麩と一緒に、味噌汁にして、朝飯を済す。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "また近頃タンタラムという金属の線を代用したのがぼつぼつ用いられる、この針金を糸枠のようなものに巻きつけてある。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃は日本にも外来語の字引がぼつぼつ出来てきたが、ドイツには早くから十数種の外来語辞典があるほど外来語が多い。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "六ヶ月分の郵便物がぼつぼつ到着しますが慰問の小包なぞこの腹では到底コナセマセン。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘の上のそこかしこの灯が、カーテンにさえぎられ、ぼつぼつ消えて行った。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　兵士は恐ろしいものに近づくように、ぼつぼつ、ぼつぼつと、軸木を拡げた蓆の間を縫って、現場へ近づいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「ほんとうにいったい何をしていたんです」　というようなことから、Ｋ君はぼつぼつそのことを説き明かしてくれました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが梟はよろこんでぼつぼつ話をつゞけました。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれを再実験すると同時にぼつぼつ老の手で紙に書き留めた。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はしばらく物も言えませんでしたが、やっとブドリが、その後のことをたずねますと、ネリもぼつぼつとイーハトーヴの百姓のことばで、今までのことを話しました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "げんのしようこのおのれひそかな花と咲く　萩がぼつぼつ咲き初めた。",
              "citation": {
                "source": "草と虫とそして",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ぼつぼつ話しながら、二人は青嵐荘近くまで来ていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころになると父の店もやや調い、棚の前通りにズックの学生靴や捲ゲートル、水筒にランドセルなど学生向きのものも並べてぼつぼつ商いもあり、滝に打たれたせいか父の頭も軽くなり、仕事に坐ることもできた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊香保はぼつぼつ避暑客の来はじめる時節で、ここは実業界の名士に、歌舞伎俳優や花柳界など、意気筋の客で、夏は旅館も別荘も一杯になり、夜は石の段々を登り降りする狭い街が、肩の擦れ合うほどの賑わいなのだが、銀子の行った時分には、まだそれほどでもなく部屋は空いていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の向く時ぼつぼつお座敷へ出てもらえば、結構なんですがね。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、カラーは年ごろになりましたので、ぼつぼつ、結婚したいと思いました。",
              "citation": {
                "source": "カラー",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうぼつぼつ、お姫さまは、御殿へ帰らなければなりません。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、あなた、ぼつぼつ、あの子に嫁をさがしてやりませんか？",
              "citation": {
                "source": "幸福な一家",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん、まあ、ぼつぼつさね。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうぼつぼつ一人前です。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜は別に低気圧の予告もなかったのだが、夜中から始めてぼつぼつ降り出した。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺から、まあ、ぼつぼつ始めてみたらいいだろうという事なんだよ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼつぼつと受験生が集って来る。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
