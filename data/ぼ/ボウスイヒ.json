        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "有るのは防水扉だけであった。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって、防水扉は、決して開いたわけではなかった。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし防水扉が開けば、海水が、どっと下におちてくるだろう。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから防水扉は絶対に開かなかったのだ。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も大使の体は防水扉を透過して、クロクロ島の外に出た――と、そうとしか考えられないのであった。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "掩蓋兼防水扉は、直ちに、閉った。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、防水扉ががらがらとおろされた。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、せっかくおろした防水扉の表面から、どうしたわけか、ぶつぶつと、さかんに泡がたちはじめた。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、だいてやるから、安心しろ」　太刀川とダン艇長とが、両方から石少年をかかえて、ついに防水扉を開いて外へ出た。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「急ぎ防水扉閉鎖せよ！",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィングに水を入れてキングストンを開け入れようと苛っているのであったが、すでにキングストン・ヴァルヴは水中に没したとみえて圧力で防水扉は飴のごとくに曲り、扉の間隙より海水は士官室へと烈しく噴き出してきた。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
