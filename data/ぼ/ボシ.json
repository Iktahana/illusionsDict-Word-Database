    "definitions": [
      {
        "index": 1,
        "gloss": "epitaph",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "舞踊場で未来の墓誌銘に現代の道徳を刻んだ同志と、レムブルグ美容院の舞踊場の楽隊の奏でる哀悼歌に合唱して、米良は柩車のように螺旋をえがいて踊りながら、彼は絶えず東支那海の電信夫がもたらす秘密結社の女シイ・ファン・ユウの恋の便りを受取った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の運命の墓誌銘をつくるために妾は女だてらに気が狂うほど急がしいのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の運命の墓誌銘をつくるためには妾は女だてらに気が狂うほど急がしいのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "金貨遊戯室の、立縞の短いスカートの女が毛皮の襟に顔をうずめて、夜会バッグにしまった三角形の××を彼女の墓誌銘にして、梅田方面に立ち去った。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓誌銘は友人｜海保漁村が撰んだ。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも『喫茗雑話』から抄したものは、漁村の撰んだ抽斎の墓誌の略で、わたくしはその中に「道純｜諱全善、号抽斎、道純｜其字也」という文のあるのを見出した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ往けば漁村の撰んだ墓誌銘の全文が見られるわけである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「抽斎渋江君｜墓碣銘」という篆額も墓誌銘も、皆｜小島成斎の書である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓誌に三子ありとして、恒善、優善、成善の名が挙げてあり、また「一女｜平野氏出」としてある。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "初にはわたくしは墓誌を読まんがために、墓の所在を問うたが、後にはせめて京水の歿した年齢だけなりとも知ろうとした。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学史の記載中脚註に墓誌と書してあるのは、当時墓について親しく抄記したものだというのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜むらくは富士川さんは墓誌銘の全文を写して置かなかった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして游さんは湮滅の期に薄っていた墓誌銘の幾句を、図らずも救抜してくれたのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに富士川さんの抄した墓誌には、京水は独美の子で廃せられたと書してあったらしい。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつわたくしは京水の墓誌が何人の撰文に係るかを知らない。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士川さんの如きも、『日本医学史』に、墓誌に拠って瑞仙の子なりと書しているのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "また放縦だとか廃嗣だとかいうことも、此の如くに書したのが、墓誌として体を得たものであろうか。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして墓誌の全文を見ることを得ず、その撰者を審にすることを得ざるのを憾とする。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは独撰者不詳の京水墓誌を疑うのみではない。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "京水の墓誌に多病を以て嗣を廃せらるというように書してあったというのと、符節は合するようだからである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてわたくしは撰者不詳の墓誌の残欠に、京水が刺ってあるのを見ては、忌憚なきの甚だしきだと感じ、晋が養父の賞美の語を記して、一の抑損の句をも著けぬのを見ては、簡傲もまた甚だしいと感ずることを禁じ得ない。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "海保漁村撰の墓誌に、抽斎が『説文』を引いて『素問』の陰陽結斜は結糾の訛なりと説いたことが載せてある。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "海保漁村の墓誌はその文が頗る長かったのを、豊碑を築き起して世に傲るが如き状をなすは、主家に対して憚があるといって、文字を識る四、五人の故旧が来て、胥議して斧鉞を加えた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "只彼人名辞書の記載は海保漁村の墓誌の外に出でず、羯南の文も亦経籍訪古志の序跋を参酌したに過ぎぬに、わたくしは嗣子保さんの手から新に材料を得た。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓誌に徴するに、与力を勤むることゝなつてから本郷に住んだ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは墓誌の記する所を以て家督相続をなし、三右衛門と称した日だとするのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒は平洲の墓誌銘を目睹して、士幹と書してゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "手帳は富士川游さんが嶺松寺の墓誌銘に就いて抄録したものである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓誌の全文を見むがためである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "――此の場合、その百姓は、農学士を心理的に判断し、その判断を、序でに耕作法その物にまで及ぼしたのである。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
