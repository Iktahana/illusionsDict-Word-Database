    "definitions": [
      {
        "index": 1,
        "gloss": "god of shepherds, herdsmen, flocks and herds",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
