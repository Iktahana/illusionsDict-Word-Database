    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(another's) son",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "誰だって、いつまでも上品な坊ちゃんではおられない。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野へ入れば往来の人ようやくしげく、ステッキ引きずる書生の群あれば盛装せる御嬢様坊ちゃん方をはじめ、自転車はしらして得意気なる人、動物園の前に大口あいて立つ田舎漢、乗車をすゝむる人力、イラッシャイを叫ぶ茶店の女など並ぶるは管なり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は、「それゃ表面のこった、そんなもんじゃないや、坊ちゃん奴」と云おうとしている。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は見違えるほど体など肥って来たようだがね」　事実、柚木はもとよりいい体格の青年が、ふーっと膨れるように脂肪がついて、坊ちゃんらしくなり、茶色の瞳の眼の上瞼の腫れ具合や、顎が二重に括れて来たところに艶めいたいろさえつけていた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、向ふの坊ちゃんがた。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジョバンニは坊ちゃんといはれたのですこししゃくにさわってだまってゐましたがカムパネルラは「ありがたう、」と云ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「坊ちゃん」のモデルの多いのは当然としても、自ら「赤シャツ」と称するのが出て来たりするから面白い。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来作者は自分自身の中に居る「坊ちゃん」「赤シャツ」「のだ」「狸」「山あらし」を気任せに取出して紙面の舞台で踊らせ歌わせる。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物人の読者はそれを見て各自の中に居る「坊ちゃん」「赤シャツ」エトセトラを共鳴させる。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地主の坊ちゃんは、部落の子供達を集めて、それぞれ四五尺の棒を手にして、猫を追っかけてぶん殴りに来た。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、向うの坊ちゃんがた。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ジョバンニは坊ちゃんといわれたのですこししゃくにさわってだまっていましたがカムパネルラは「ありがとう、」と云いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたは、それじゃ、」温泉芸者は、更に興を覚えぬ様子で、「Ｔさんのお坊ちゃんなの？",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのような問題が出ても、フロオベエルはお坊ちゃんである、と書くつもりでいた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――フロオベエルはお坊ちゃんである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボオドレエルこそは、お坊ちゃん。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、向こうの坊ちゃんがた。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとりください」　ジョバンニは坊ちゃんといわれたので、すこししゃくにさわってだまっていましたが、カムパネルラは、「ありがとう」と言いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも坊ちゃんもう下りますか。",
              "citation": {
                "source": "車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「坊ちゃん、もうおりて下さい。",
              "citation": {
                "source": "車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「坊ちゃん、では少し待ってゐて下さいね。",
              "citation": {
                "source": "車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」給仕「さうですか、坊ちゃんも。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "タッタお一人のお坊ちゃんが、牛乳ばっかりで育てておいでになったのが、四、五日前に急にお亡くなりになった。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "茸狩りに来たのは、どこかのお父さんとお母さんと姉さんと坊ちゃんでしたが、ここへ来ると皆大喜びで、「もはやこんなに茸はあるまいと思っていたが、いろいろの茸がずいぶん沢山ある」「あれ、お前のようにむやみに取っては駄目よ。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が、あらかた茸を取ってしまってお父さんが、「さあ行こう」　と言われますと、姉さんと坊ちゃんが立ち止まって、「まあ、毒茸はみんな憎らしい恰好をしている事ねえ」「ウン、僕が征伐してやろう」　といううちに、片っ端から毒茸共は大きいのも小さいのも根本まで木っ葉微塵に踏み潰されてしまいました。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には平常向い合って話していると、あの風采がソックリそのまま、実にタヨリない、涙ぐましい位のお坊ちゃんに見えて来る。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ坊ちゃんが来てお菓子箱の蓋を取ってみるとビックリして、「お母さん。",
              "citation": {
                "source": "キャラメルと飴玉",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の窓から坊ちゃんがこれを見つけて、あの憎らしい犬が又猫をいじめてやろうとしている。",
              "citation": {
                "source": "ドン",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の隅で縫い物をしていらっしたお母様はお父様の様子に気がついて、どうしたのかと思って窓の外を見ると、猫は金魚をねらい、犬は猫のすぐ後に近寄り、坊ちゃんは犬のお尻を狙って引き金を引こうとし、お父様は坊ちゃんの襟を捕まえようとしておられます。",
              "citation": {
                "source": "ドン",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただあまりに世間見ずのわがままなおぼっちゃんの象であった。",
              "citation": {
                "source": "解かれた象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
