[
  {
    "uuid": "066b8e04-1122-5219-90c0-17fdc52adef5",
    "entry": "凡々",
    "reading": {
      "primary": "ぼんぼん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
