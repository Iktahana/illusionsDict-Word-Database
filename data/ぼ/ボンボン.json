    "definitions": [
      {
        "index": 1,
        "gloss": "ordinary",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女の一生は実に平々凡々なものであつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "平々凡々の喜多実となって、二度と能が舞えなくなりはしまいか……といったような気がしたので……。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車の旅行は平々凡々、未醒子ははや居眠りを始める。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうてい私たちのような平々凡々の徒の堪え得るところでない。",
              "citation": {
                "source": "寝床〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、あんまりやっつけ過ぎたために、相手は平々凡々のお人好しを通り越して、何もかも覚りつくした、諦め切った人間になってしまっている。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい弱い平々凡々の者も中々の仕事をする。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "鑛山の如きは特殊の鑛物を包有せるもので、おのづから平々凡々の尋常一樣の山とは異なるのであるから、氣もまたおのづからにして各氣あれば銅ありなどといふことを記して居るといふ望氣經もあれば、採鑛｜取璞の事をも記した天工開物の如き書にも些少ながら望氣の事が載つて居たと記憶して居る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その自然の觀照に於ては、必ずしも名山大澤に之を索めず、居に從ひて選ぶ平々凡々の四圍に過ぎず。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一奇男児なる道也、其粉飾を脱し去れば、凡々たる遊冶郎。",
              "citation": {
                "source": "「伽羅枕」及び「新葉末集」",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "その自然の観照に於ては、必ずしも名山大沢に之を索めず、居に従ひて選ぶ平々凡々の四囲に過ぎず。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、それがわかった時はビタミンの発見と同様、遠からず平々凡々な趣味によってしまうべき運命を持っているので、現在のように大衆を酔わせる力はなくなってしまうであろう――ナアンダ。",
              "citation": {
                "source": "ナンセンス",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "老幼賢愚の隔意なく胸襟を開いて平々凡々に茶を啜り、談笑して御座る。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間の所謂快人傑士が、その足下にも寄り付けない奇行快動ぶりに、測り知られぬ平々凡々な先生の、人間性の偉大さを感じて、この八十幾歳の好々爺が心から好きになってしまったのだから致し方がない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまるところは聖人以外の誰にでも出来る平々凡々振りであるが、その平々凡々振りが又なかなか容易に真似られないのだから不思議である。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭山翁の恐ろしさと偉大さは、その平々凡々なノンセンス振りの中に在ると云ってもいい位である。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "持って生れた平々凡々式で、万事ありのまんまの手掴みで片付けて来ている。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこが頭山翁の古来ありふれた人傑と違っている点で、その平々凡々式の行き方が又、筆者をして頭山翁を好きにならしめた第一の条件になっているらしいのだ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁の名はその姻戚故旧の死亡と共に遠からずこの地上から平々凡々と消え失せて行きはしまいか。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここ人の作りし大都会ロンドンのただなかにありながらも、そのときだけは我々の心も平々凡々の現実から目覚めた気分で、大自然の力をまざまざと見せつけられた。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "平々凡々とした生活から逃れようと、四六時中もがいている。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉱山は特殊な鉱物を埋蔵しているので自然と平々凡々な普通の山とは異なるから、気も自然に各々相異なる理屈である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論マクベスの発端のように行数は短かくても、興味の上において全篇を貫く重みのあるものは論外であるが、平々凡々たるしかも十行内外の一段を設けるのは、話しの続きをあらわすためやむをえず挿入したのだと見え透くように思われる。",
              "citation": {
                "source": "作物の批評",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一見、平々凡々な、何んでもない出来事の連続のように見える彼女の虚構の裡面に脈動している摩訶不思議な少女の心理作用の恐しさ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔からせっかくわしが注意をあたえているのに、その注意を用いないからして、いまだに平々凡々たる学者でいる」　轟博士は、いいたいことをずばりといって平気な顔をしている。",
              "citation": {
                "source": "地球を狙う者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、日が経つて、再びそんな稿を翻して見ると、無意識なる、凡々たる日録のうちにも、何か、再び廻り合せぬかの如き心の媚惑と、「物質の鉄則から釈放されたる宇宙」に向つての止め度もなき霊の推進器の飽くなき回転の響きを耳にする思ひがする、たゞ、それが春であつたがために――あゝ、わたしは、今日！",
              "citation": {
                "source": "波の戯れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題の取り上げ方と打ち込み方とは凡々たるものであつた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、二人でではなく、自分だけが何とか変化しなければならない――さよは、保夫が彼自身の平々凡々にはまるで気がつかないのを知っていた。",
              "citation": {
                "source": "心の河",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝの主人公は苦労人といふよりも磨かれた人間だ、角力取、遊人、世話役、親方、等々の境地をくゞつてきて本来の自己を造りあげた人だ、強くて親切だ、大胆であつて、しかも細心を失はない、木賃宿は妻君の内職で、彼は興行に関係してゐる、話す事も行ふ事も平々凡々の要領を得てゐる。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "碧梧桐調は専売特許の如き者いち早くこれを摸して世に誇らんとするは不徳義といはんか不見識といはんか況してその句が平々凡々「も」の一字によりて毫も価を増さざるをや。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "島で銅鑼がだるそうにぼんぼんと鳴り椰子の木もパンの木も一ぱいにからだをひろげてだらしなくねむっているよう、赤い魚も水の中でもうふらふら泳いだりじっととまったりして夢を見ているんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
