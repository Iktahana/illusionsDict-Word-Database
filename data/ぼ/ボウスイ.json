[
  {
    "uuid": "444b57e0-d51c-5dcd-b3ca-3758ef5cbd79",
    "entry": "紡錘",
    "reading": {
      "primary": "ぼうすい",
      "alternatives": [
        "つむ",
        "つみ"
      ],
      "is_heteronym": true
    },
