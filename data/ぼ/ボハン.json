        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（翼ある蛇）　わたしたちは、ここにＤ・Ｈ・ローレンスという作家の秘密の母斑を見る。",
              "citation": {
                "source": "傷だらけの足",
                "author": "――ふたたび純潔について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしという一人の作家にふれる場合、見のがすことのできない母斑のようにあつかわれても来ている。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第十巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右臀部にあった大きなオリーブ色の母斑すら消え、一方で胸に、これまで全く存在しなかった奇妙な黒子ないし黒斑が現れた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "多賀ちゃんのを念のために診て貰ったら先天性母斑というのですって。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの母斑は、やっぱりもっともっと大きくなる性質ですって。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
