[
  {
    "uuid": "25681937-93a9-58ed-b505-a9106e9ee211",
    "entry": "亡婦",
    "reading": {
      "primary": "ぼうふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
