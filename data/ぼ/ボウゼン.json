[
  {
    "uuid": "1856ab8d-4992-5626-ad75-de23aba783d1",
    "entry": "呆然",
    "reading": {
      "primary": "ぼうぜん",
      "alternatives": [
        "もうぜん",
        "ボーゼン"
      ],
      "is_heteronym": true
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dumbfounded",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "フォルムのない競技で以て、徒らに勝たうとばかりしてゐるやうなもので、仮令勝てたにしても、競技そのものを楽しむ気持はなく、勝つた時に熱病的に嬉しいだけで、十年の後に回想したらば、なんといふこともなかつたと、呆然としなければならない始末だらう。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾崎君は吃驚し、呆然とし、それから異常な感激にうたれて立ちあがつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に、生活を、殊には虚栄を、顧慮する限りに於て衰褪する底の、呆然見とれてゐる世界のことである。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」浦島は呆然とつつ立つたまま、なほもその不思議な聖諦の曲に耳を傾けた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁が呆然眺め上げる福慈岳の山影は天地の闇を自分に一ぱいに吸込んで、天地大に山影は成り切った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この火事を呆然として見ていれば全市は数時間で火の海になる事は請合いである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを讀んだ時、僕は世にも意外な讀者があるものだと思つて、自ら事の意外に呆然とした。",
              "citation": {
                "source": "常識家の非常識",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "之れにもまた僕は呆然としてしまつた。",
              "citation": {
                "source": "常識家の非常識",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もさすがに呆然として、何事が起つたのかと怪んだ。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私が呆然として突つたつてるまに、人々が早くも室生君を抱き止めてしまつて居た。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹は呆然と立ちすくむ。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "見送る呆然たるお絹。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝長屋　三次はお絹の家の表戸に凭れて呆然として居る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「旦那に金がないと　知ると、急に　手の掌かえして　水臭くなりやがって、　果は情夫と手に手を　とってドロン……」（次の画面へダブル）　＝大吉の浪宅　（前の字幕からダブって）　遺されたおきよの書置き手に呆然自失、ドッカと座敷に坐った儘の大吉、　やる瀬なくその手紙胸に抱いて、Ｔ「おきよ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "見て居た五郎蔵、呆然たり。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "訳の分らぬお光、傘持って呆然と立つ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次と児分お光を抱えて呆然。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "呆然たるおしま、団九郎。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "呆然と殿様を見守る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寝巻姿のバルザック像がサロンに出品されると世論は沸騰して、ロダン後援会の人々でさえ呆然としてしまったのだそうです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日は書きつかへて机のまはりに空しくたまつた原稿紙の屑を見詰めながら、深い疲れに呆然となつてゐた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでなくても乏しかった衣類の、大半を、戦火で焼いてしまったので、こんど生れる子供の産衣やら蒲団やら、おしめやら、全くやりくりの方法がつかず、母は呆然として溜息ばかりついている様子であるが、父はそれに気附かぬ振りしてそそくさと外出する。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人は、呆然自失したという。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "その印刷所から逃げ出してからの私の生活たるや、お話にも何にもならぬていたらくのものでございまして、いま思い出しても、まるで地獄の走馬燈を呆然と眺めているような気持が致しまして、よくまあ発狂もせず餓え死もせず、こうして生き伸びて来たものだと我ながら驚歎の念を禁じ得ないものがございます。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒田藩の大目付様に先手を打たれて、今頃はボンヤリしておる事と存じまするが……この後始末はいずれ貴方様へかかって来る事と存じまするが……」　半三郎はもう腰が抜けたように呆然となっていた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、呆然と自失して暫く男に向い立っていた。",
              "citation": {
                "source": "窓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はすっかり懐疑家になり、しばらく呆然として暮していましたが、反撥心を起して、こう言いました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし内心では夫を死ぬほど愛していたのですから、脳も疲れ果てて嫉妬することや、疑ぐることが出来なくなると、呆然として、ただただ馬鹿のように夫に寄りすがるのでした。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議とある人に限ってこの齟齬が度々繰り返されることがありまして、悲運の余りいじけたり、呆然自失してしまう人があります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の次の室も、他は推して知るべしで、珍什奇器殆ど人界のものにあらず、一同呆然として、口を利くものある事なし。",
              "citation": {
                "source": "畫の裡",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
