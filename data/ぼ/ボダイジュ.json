        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "伯林にちらほら街路樹の菩提樹の葉が散り初めたのは十日程前だった。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こまかい菩提樹の葉が粉のように顔や肩や足元に散りかかった。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "街路樹の菩提樹の葉が、黄色の吹雪を絶えずサラサラサラ撒きちらして居た。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを出て、夢中で、これまで見たことのない菩提樹の並木の間を、町の方へ走った。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上の菩提樹の古木の枝が、静かに朝風に戦いでいる。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから毎日日のさす所へとこころざして、市の公園へ跛を引きながら往つて、菩提樹の下のベンチに腰を掛ける。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａは私の知識の中で名と物とが別であった菩提樹をその窓から教えてくれました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "万朶の花、菩提樹の落葉、いななく馬あれば、眠る猫あり。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈尊が菩提樹下で正覚後四十五年の説法、それに次いで代々の宗祖、高僧がたの利生方便はみなこれであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "菩提樹、椰子、棕櫚、雑草など、これを大方｜覆う。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小十郎は夏なら菩提樹の皮でこさえたけらを着てはむばきをはき生蕃の使うような山刀とポルトガル伝来というような大きな重い鉄砲をもってたくましい黄いろな犬をつれてなめとこ山からしどけ沢から三つ又からサッカイの山からマミ穴森から白沢からまるで縦横にあるいた。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "涅槃花ざかりなる菩提樹の下密林の影のふかいところでかのひとの思惟にうかぶ理性の、幻想の、情感の、いとも美しい神祕をおもふ。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花ざかりなる菩提樹の下密林の影のふかいところでかのひとの思惟にうかぶ理性の、幻想の、情感の、いとも美しい神祕をおもふ。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河堤の古本屋の箱屋台はすっかり黒い蓋をしめて、その背後に梢を見せている河岸の菩提樹の夕闇を細かく刻んだ葉は河上から風が来ると、飛び立つ遠い群鳥のように白い葉裏を見せて、ずっと河下まで風の筋通りにざわめきを見せて行く。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "対岸の石垣の道の菩提樹の間に行列の色がゆらめく。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "菩提樹神のむかしは知らねど、腕を組み言葉を交へずとも、松心あらば汝も我を友と見よ。",
              "citation": {
                "source": "二日物語",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、にれぜん河のほとり、菩提樹の蔭に、釈尊にはじめて捧げたものは何であろう。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "菩提樹よ、闇の葉よ、覆輪の金の椎、花よ、木よ、朴よ、漆よ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤煤がふります、菩提樹に、朝のタオルに、籐椅子に。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "中門から古風な奧庭へ入ると、椎垣に添つて冬青やゆづり葉が繁り、菩提樹や楓、茶室の隔ての袖垣、幾つかの大きい石、厠近くには一本の櫨が秋は深い夕日に照り輝き、裏には柿の枯枝が冬は黒い蔕をこびりつかしてゐた。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "中門から古風な奥庭へ入ると、椎垣に添つて冬青やゆづり葉が繁り、菩提樹や楓、茶室の隔ての袖垣、幾つかの大きい石、厠近くには一本の櫨が秋は深い夕日に照り輝き、裏には柿の枯枝が冬は黒い蔕をこびりつかしてゐた。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "菩提樹下と訳するときは、幽静なる境なるべく思わるれど、この大道｜髪のごときウンテル・デン・リンデンに来て両辺なる石だたみの人道を行く隊々の士女を見よ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "棕梠、芭蕉、椰子樹、檳榔樹、菩提樹が重なり合った中に白い卓子と籐椅子が散在している。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの案内をした老年の土人は病気で熱があるとかいってヨロヨロしていたが菩提樹の葉を採ってみんなに一枚ずつ分けてくれた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車はゆつくり花壇の周囲に輪をかいて、それから速度を早めて、跳るやうに中庭を走つて出て、街道に続く道の、菩提樹の並木の間に這入つて行く。",
              "citation": {
                "source": "薔薇",
                "author": "ROSEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "）車にて行かば坐席極めて妥なるべく、菩提樹の街※は鬱蒼として日を遮り、人に暑さを忘れしむ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗込んでから、またどうか云う工合で、女たちが二人並ぶか、それを此方から見る、と云った風になると、髪の形ばかりでも、菩提樹か、石榴の花に、女の顔した鳥が、腰掛けた如くに見えて、再び夢心に引入れられもしたのでありましょうけれど、なかなか、そんな事を云っていられる混雑方ではなかったのです。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "菩提樹下と譯するときは、幽靜なる境なるべく思はるれど、この大道髮の如きウンテル、デン、リンデンに來て兩邊なる石だゝみの人道を行く隊々の士女を見よ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんのりいいにおいのするばらが、ひくいかきねにからんでいましたし、ぼだいじゅも、ちょうど花ざかりでした。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、この王さまのお城のちかくに、こんもりふかくしげった森があって、その森のなかに一本あるふるいぼだいじゅの木の下に、きれいな泉が、こんこんとふきだしていました。",
              "citation": {
                "source": "かえるの王さま",
                "author": "DER FROSCHKONIG ODER DER EISERNE HEINRICH",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
