        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "運動会の目玉競技である棒倒しは、毎年大いに盛り上がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "棒倒しは、チームワークと戦略が勝敗を分ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は棒倒しの練習で、相手の棒にしがみつく作戦を練っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "兄は眼を見開いたまゝ棒倒しにセメントの床の上にどうと倒れたのである。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドタリドタリと棒倒しに引っくり返った。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
