        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "朝から降り出して、大阪から船の著く頃にはしとしと牡丹雪だった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の暮れかたからちらちらしはじめ間もなくおおきい牡丹雪にかわり三寸くらい積ったころ、宿場の六個の半鐘が一時に鳴った。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "降りしきる牡丹雪は焔にいろどられ、いっそう重たげにもったいなげに見えた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "火事のあかりにてらされながら陣州屋をたしなめていたときの次郎兵衛のまっかな両頬には十｜片あまりの牡丹雪が消えもせずにへばりついていてその有様は神様のように恐ろしかったというのは、その後ながいあいだの火消したちの語り草であった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車が大正橋を過ぎる頃、しとしと牡丹雪になった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しとしとと落ちて来る牡丹雪を、眩い光が冷たく照らしていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪が降っているのよ」　花びらのような大きい牡丹雪が、ふわりふわり降りはじめていたのだ。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞いだしたとなると、鉄火というか、伝法というか、雪までがたいそうもなく江戸前に気短なところがあって、豪儀といえば豪儀ですが、ちらりほらりと夜の引きあけごろから降りだしたと思ったあいだに、たちまち八百八町は二寸厚みの牡丹雪にぬりこめられて、見渡すかぎりただひと色の銀世界でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "時とすると、思ひもかけず、ちらちらと牡丹雪がふつてくる。",
              "citation": {
                "source": "孟宗と七面鳥",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシア更紗の毛布団をそつとぬけでてつむ雪を銀のかざしでさしてみるお染の髪の牡丹雪。",
              "citation": {
                "source": "どんたく",
                "author": "絵入り小唄集",
                "note": "青空文庫"
              }
            },
            {
              "text": "南風の爽やかなその海辺の町にも、古老も知らぬといふ牡丹雪が夜を徹して降り止まなかつた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月廿六日　廿七日　牡丹雪が降つた、星城子居。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "積もるとみせかけて、牡丹雪は案外なところで消えてゆく。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラス戸越しに、大きな牡丹雪が忙しそうに降っている。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "空からドンドン降るのを見るとまるで灰みたいなものが、地面から或る距離のところまで落ちて来ると、急に真白な牡丹雪となる。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか空が曇り、一旦止んでいた牡丹雪が風に連れて降って来た。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "門松しめ飾り、松の内の八百屋町をぱったり人通りが杜絶えて、牡丹雪が音も立てずに降っている。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時の雪片は直径一寸もあろうという今迄に見たこともない大きな牡丹雪であったから、此家を立ち出る頃は既に八寸以上も積っていたし、峠の頂上近くの崖のある所では、路を横切って極めて小規模ながらアワの現象さえ起って、少なからず歩行に悩んだ。",
              "citation": {
                "source": "初旅の大菩薩連嶺",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外は嵐が吹き巻いて、桜の花の盛りだというに、さっきから降っている牡丹雪は、嵐に雑り吹雪となり、窓の外部から横撲りに凄じい音を立てて襲っている。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人物風景の大半はほとんどこの兄弟子二人が片づけてしまい、まだ表立って名も貰っていない次郎吉はベトベト胡粉で牡丹雪を降らすばかりだったが、それだけのことでもこの程度の修業年月で引き受けさせられるのは前例のない速さだとされた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "時折西北の風が爽に吹き下ろして来ると、枝や葉が一斉に靡いて、其間から無数の柳絮が真白な綿をちぎって飛ばすように、ふわりふわりと飛んで行く、まるで牡丹雪が降っているようだ。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "凍てついてはいなかったが、空からは水気の多い牡丹雪が降りしきって、気持の悪い湿っぽい風が吹いていた。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝がたからちらつきだした粉雪は、いつの間にか水気の多い牡丹雪に変って、午をまわる頃には奈良の町を、ふかぶかとうずめつくした。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝がたからちらつきだした粉雪は、いつの間にか水気の多い牡丹雪に変つて、午をまはる頃には奈良の町を、ふかぶかとうづめつくした。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年も暖冬で、地上に雪はなかったが、時時、大きな牡丹雪が、一頻り降り続く。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "また牡丹雪が降って来る。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡丹雪とか、綿雪とかいうのは、この雪片の名前である。",
              "citation": {
                "source": "自然の恵み",
                "author": "――少国民のための新しい雪の話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡丹雪の雪片をよく見ると、六花の結晶がたくさん集まったものであることがわかる。",
              "citation": {
                "source": "自然の恵み",
                "author": "――少国民のための新しい雪の話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが即ちわれわれによって牡丹雪あるいは綿雪と呼ばれているものである。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡丹雪あるいは綿雪と呼ばれているものは、割合に温暖の地に降ることは人の知るところであって、その大きさは、時には直径十五｜糎にも及ぶものがあることが記録されている。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
