    "definitions": [
      {
        "index": 1,
        "gloss": "end (of a stick, rod, pole, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
