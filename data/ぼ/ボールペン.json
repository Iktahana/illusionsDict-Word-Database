        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何かを知りたいというはっきりした目的があって本を読むとき、私はたいてい赤のボールペンを持って、線を引いたり書き込みを入れたりしながら頁をめくります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "後には、ボールペンで少し強めに書いていくだけで版の作れる、特殊な原紙も開発されました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このボールペン原紙を使うと文字の切れは鈍りましたが、経験のない人でも気軽にとりかかれることから、広く使われるようになります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから口をきかないほうの子が、慶一の名を見つけたらしく、ボールペンを動かす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ページを開いたときにはすでに、彼女は右手にボールペンを持っていた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノートを縦に持ち、ボールペンを持った右手を大きく左へまわし、ページの上から下に向けて、横書きしていった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "成立するわね」「成立します」「大福帳に財産がたまったなら、それをみんなと分かち合わなくては」　芯を引っ込めたボールペンの先端でノートを軽く叩きながら、エレン・ステュードベイカーはそう言った。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の壁に掛けて、客との話題にするのだと言ってました」「店宛てに送っておくわ」　ピストル・ケースを開いた彼女は、手帳を開いてボールペンで走り書きをした。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "何年もまえに仕入れをやめ、そのまま売れ残ったノートパッドやボールペンが、時間の流れの外にとり残されている。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっ赤とは、赤いボールペンで訂正や修正を書き込んだことによる、校正刷りの紙面ぜんたいの印象のことを言う。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "サインをもらっておくのも、悪くないかなと思います」　小さなバッグを膝に置いて開き、裕子はなかから赤いボールペンを取り出した。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、いまから、次の私よ」「それは、なにですか」「なにかしら」　指先に持ったボールペンを見つめて、裕子は言った。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話機を置いてある小さなテーブルには、卓上のカレンダーやメモ用紙、そしてボールペンなどがあった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カレンダーのその日の下に、五郎はボールペンで線を引いた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに文具店に寄り、ボールペンを慎重に選んで買った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その予感に忠実に、彼は愛子への手紙専用にするためのボールペンを買った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "机にレター・ペーパーと封筒、そしてボールペンを置き、椅子にすわった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから福山は、どの名刺にも定規を使いボールペンで周囲を書き込んでいた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだかよくわからないけれど、不思議な奥行き」　日比谷に渡した自分の名刺を取り出させ、その裏に富美子は世田谷の住所と電話番号を日比谷のボールペンで書いた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "担当美容師、と肩書のように小さく印刷した下に、高木節子、とボールペンで名前が書いてあった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カウンターに、ボールペンが一本、ころがっていた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　こんな文章が、きれいなボールペンの字で、横書きしてある。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
