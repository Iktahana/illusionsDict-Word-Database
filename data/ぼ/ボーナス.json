        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鼻糞ほどのボーナスを貰ってカフェーへ駈込んだり、高等官になったとて嚊殿に誇るような極楽蜻蛉、菜畠蝶々に比べては、罪が深い、無邪気で無いには違い無いが、氏郷の感慨の涙も流石に氏郷の涙だと云いたい。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "社の方もボーナスを貰ってやめたのだしねえ。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから遂々ボーナスを貰って社を辞めようとした最後の日まで来てしまったのです。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほ、前年度のボーナスの推定額迄、書入れてある。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボーナスが大きいぞ」と又野が巨大な肩をゆすぶって見せた。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "儲けとボーナスは重役のオテモリにきまってらあ。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしボイジャーのスタッフは、こうしたコンピューターらしさやマルチメディアは、本を電子化することのボーナスに過ぎないのではないかと受けとめていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんどんボーナスを出して、基本給の少なさを補いたいと言った心境です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "興味深いコメントをもっと良い画質で残しておきたかったと悔いは残りましたが、マルチメディアは電子本のボーナスとして活用できるなとは実感させられました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の会社を見給へ、重役様がボーナスを少とでも余計｜握まうといふ外には何の考も無い。",
              "citation": {
                "source": "青年実業家",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "俸給は百円でボーナスは三月分だそうだが、御承知ならば私が大阪へ電話をかけるから、直ぐにも出発出来るだろうって言う事だがね……」　と言うお話でした。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなくともボーナスの減少と来るから、照り降りはなくとも心臓には応える。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さて仕事もだいたい終ったので、本日はこれより諸君全部に対し、週給の二十倍に相当するボーナスを給与する。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボーナスをうけとるときに、諸君はどの港で下りるか、それを申し出てもらいたい。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、どうもながながありがとう」　リット少将が、いつもに似合わぬ和やかな態度で挨拶をおわると、週給の二十倍のボーナスに興奮した大衆は、口笛をふき、足をふみならし、帽子をふってウラーを唱えた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今日は、たんまりボーナスをもらって、なつかしい自分の国へ帰れるのだ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボーナスは、ほんとうに手渡された。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が好む学生気分の少しもない連中で、「俺はボーナスを幾ら貰ふ」とか「扇風機を買はうと思つてゐる」とか、また「日本の文壇なんて相手にしまいぜ」とか、主に彼等はその場限りの話に打ち興じてゐた。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸官庁や諸会社のボーナスが行き渡って、盗賊たちが市中や郊外を横行しようとする時分のある夜、ふと私は電話のベルに眼をさましました。",
              "citation": {
                "source": "深夜の電話",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し現代風俗として見るとき、これらの現象はこれだけで切り離せぬもので、百円迄のボーナスも一割は公債で。",
              "citation": {
                "source": "風俗の感受性",
                "author": "――現代風俗の解剖――",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの頭のなかにはいろいろの問題があって、くれにさしかかっている今は今年の正月は餅が何枚つけるか、蜜柑が買えるか、ボーナスがいくら貰えるだろうか、貰ったらどう使うか、また靴の新しいのを買わなければならない、いまはいている靴は底がぬけたとかいろいろな考えが頭にあります。",
              "citation": {
                "source": "平和運動と文学者",
                "author": "――一九四八年十二月二十五日、新日本文学会主催「文芸講演会」における講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏のボーナスをあてて、パーソナルコンピューターを買うことを決めていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七九（昭和五十四）年八月、タケシは夏のボーナスをはたいて、コンポＢＳを買った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "最終的にポータブル機のソフトウエアが自分のイメージに非常に近い形で実現したことを喜んだゲイツ氏は、アスキーの三人に個人的にボーナスを支払った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボーナスもうんと出す。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第一金を調べて下されば判ります」　彼が自分の潔白を証明しようとして、内ポケットから月給の袋とボーナスの袋を出したが、彼は顔色を変えた。",
              "citation": {
                "source": "琥珀のパイプ",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝口の辺で岩見が始めてカフス釦を見て茫然としている隙にボーナスの袋を抜いたのです。",
              "citation": {
                "source": "琥珀のパイプ",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
