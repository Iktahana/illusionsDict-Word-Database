    "definitions": [
      {
        "index": 1,
        "gloss": "assault",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「暴行でもする氣かな？",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふにこの事件は、室生君が卓の遠く離れた地位に居た爲に、私と岡本君との問答してゐる光景を見て、何か私が不當の暴行でも受けてゐるやうに見誤り、友人の一大事として決死的に突進して來たのである。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シナの庭園も本来は自然にかたどったものではあろうが、むやみに奇岩怪石を積み並べた貝細工の化け物のようなシナふうの庭は、多くの純日本趣味の日本人の目には自然に対する変態心理者の暴行としか見えないであろう。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ではまた、突然の暴行の後に釈放された白い母鳥も、ほんのちょっとばかり取り乱した羽毛をくちばしでかいつくろって、心ばかりの身じまいをしただけで、もう何事もなかったように、これも瞬間の驚きから回復したらしい十羽のひなを引率してしずしずと池の反対の側へ泳いで行くのであった。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、ある少女が思春期以前に暴行を受けてその時の心の激動の結果が、熱烈な宗教心となって発現する。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "惟うに博学多才なる深川夫人が慈善会を代表して、渠が暴行を戒めしに、屈服したりしものならんか。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時｜最寄の交番より巡査｜真黒になりて駈附けつ、暴行を制せんとすれば、お丹先んじて声を懸け、「おい、皆静まった。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "○一月二日の夜、春木座の出方が赤馬車数台に乗込みて、銀座尾張町のやまと新聞社を襲い、社員を殴打して暴行を働く。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "席上東京朝日新聞記者村山某、小池は愚直なりしに汝は軽薄なりと叫び、予に暴行を加う。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "検屍の結果、死後四日を経ており、暴行の形跡があると判明した。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "レヴュ小屋通いをしているところを、不良少年に目をつけられ、ひきずり廻されたあげく、暴行され、発覚をおそれて殺されたのであろう。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "強姦奪掠憚らねば、市街の商人は武裝して、我が暴行を防がむとす。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "南海の騎士を以て任ずるサモア人の間に在って、之は許すべからざる暴行である。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は故人になった前の福岡市の名市長、佐藤平太郎氏は神戸署の一巡査の身で、外人の治外法権制度に憤慨し、神戸居留地域を離るる一間ばかりの処で、人力車夫に暴行して逃げて行く外人を斬って棄て、天下を騒がした豪傑であるが、氏は語る。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝刊に昨夜「オリンピア」の表で暴行事件があったと、出ていたのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "検屍の結果、他殺暴行の形跡があり、犯行後四日を経ていると判明した。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のしたことは初めから訴えられる要素がないけれど、あなたがその扉を閉めている限り、常にあなたは暴行の脅迫と不法拘束で訴えられるおそれがある。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィリアムソンとウッドリは、どちらも誘拐と暴行のかどで裁判にかけられ、前者は七年、後者は一〇年とのことだ。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "カラザズのその後については何も記されていないが、ウッドリは危険な悪党との評判であったから、確か裁判では彼の暴行は重く見られず、数ヶ月という求刑でうまく落ち着いたのだと思う。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は獣的暴行を受けたのだというのであった。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "（原注一七）「一昨日、当市の付近で、もっとも凶悪なる暴行が行われた。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はそれを取りにひき返して、その一団の者に捕えられ、河のなかへ連れて行かれて、猿ぐつわをはめられ、ひどい暴行を受け、遂に彼女が初め両親とともにボートに乗った地点に近い河岸に上げられたのである。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "この死体は、暴行を加えられた痕があって、河に浮んでいるのが見つかったのだ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その娘が殺されたと想像されているちょうどそのときに、あるいはちょうどそのころに、その死者の受けたのほど程度はひどくないが、似たような性質の暴行を、若いごろつきどもの一団が、別の若い婦人に加えた、ということがわかるようになった。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間がどう判断したらいいかという見当を待っているところへ、このはっきりわかった暴行事件が実におりよくそれを与えてくれたように思われたのさ！",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリーも河のなかで見つかったんだし、その同じ河ではっきりわかった暴行が行われたのだ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし我々がただ一人の暴行者を想像するなら、眼に見えるほどの『跡』を遺すくらい猛烈で執拗な性質の格闘を考えうるし、またその場合にのみ考えられるのだ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんにちの言葉でいえば監禁暴行、昔はこんな悪い奴が往々ありました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごろすけほう、ごろすけほうこう、むだぼうこう。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあさんの孫の、かわいそうな女中ぼうこうをしているうつくしい女の子が、おばあさんにあうために、わずかなおひまをもらって、うちへかえってきました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
