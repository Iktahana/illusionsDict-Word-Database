    "definitions": [
      {
        "index": 1,
        "gloss": "Bombay (old name for Mumbai)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私達｜孟買在住の日本人にとっては珍らしい変り種にちがいないのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄私達が土人街｜印度家屋の油の濃い日本女（ここに住む日本髪の女が世界中で一等醜い女だということは貴方にも直きお分りになるでしょう）以外に恋の体力をあらわさなかったのに、たとえ英国種にしろアダは水際だった、いわば我々日本人にとって彼女は孟買のエンゼルなのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（孟買には若い夫婦者は皆無と云っていいのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車が土耳古に這入ると車中の美しい女はみんなばたばた下車してしまって孟買までの通しの切符を持った英国人の布教師の博物館のような顔と、目に見えて黒いものが車室にふえてくるのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は亜丁湾を横切って孟買に一路船が進行をつづけるころになると急にアラビア海に顔をうつしてお化粧を始めてしまったのです――。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は少し興奮して孟買の私達の邂逅に懐古的な黒い騎士の心をもって、　――アダ、できることなら貴女のために私は何かすることはないかと思うのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　孟買埠頭の藍色の海に室蘭丸が碇泊していた。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから孟買の港に船遊びする富限者船の燈が明滅するのを眺めながらサルーンから響いてくる音楽と歓談の声を聞いた。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　孟買の花嫁である万国女のいる孟買市場の裏街では天幕の舞台で、緬甸の女がバゴダ踊をおどっている。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は宴のなかばを抜けて夜の孟買の街を英国の煙管から吐き出される煙で曇らすのだが、印度人の象使いが象の背に古代神の敷物を敷いて外人の子供を乗せて円のなかを大声で叫びながら引張りまわしているのを見ているうちに、アダのことを忘れてしまった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜遊びした孟買女学校の生徒が茶色の肩掛で顔を包んで皮膚には香気ある花を飾って帰途を急いでいる。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "イサックもまた一先ず上海の東洋での黄色い手を棄てて孟買に帰る途中であった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、数日にして私は孟買のマイダンにあります。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二四年版、エントホヴェンの『孟買俚俗』六章）。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "近く孟買に栄転する筈の、神戸｜駐紮仏国領事などもその一｜人で、この人は今だに領事館に電話を引かうとしない。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "酢屋は横浜の貿易商で孟買とカルカツタとに十年｜前から店を持つて居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "孟買と聞くと僕等の門外漢には大分に日本商人の勢力が及んで相に想はれるが、三井物産と郵船会社との支店を除いて個人の経営する商店と云へば酢屋丈だ相である。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨今は英帝が印度皇帝としての戴冠式を挙げる為に孟買に行幸して居られるが、革命党が何か仕出かしはしまいかと半｜年前から非常な警戒だ相である。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "孟買市のは英国系で、ジェネラル・ホスピタルと呼んだ。",
              "citation": {
                "source": "ブイヨン・ドンゾール",
                "author": "――十一時の肉の煮出し――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャズ・バンド、マルセル・シュオブに似たセロ弾き、グロテスクな洋服師思い出すボンベイの過去、いまではロシアで苦心｜惨憺アンナ・ニコロを祝福して、私は最期迄知ってしまう。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時連隊はインドに駐屯していたが、私の赴任に先立ち第二次アフガン戦争が勃発、ボンベイに到着するやいなや、連隊は峠の向こう敵陣深くにあり、と聞かされることになった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなもの今もあるにや、一九一四年ボンベイ版エントホヴェンの『グジャラット民俗記』一四二頁に或る術士は符※を以て人咬みし蛇を招致し、命じて創口から毒を吸い出さしめて癒す。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一四年ボンベイ板エントホヴェンの『グジャラット民俗記』五四頁にいわく、一説に帝釈瞿曇の妻に通じた時アンジャニ女帝釈を助けた故、瞿曇これを詛いて父なし子を生むべしという。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大佐は一八三四年ボンベイで死んだとあるから余り古い事でない。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その像象首一牙で、四手に瓢と餅と斧と数珠をもち、大腹黄衣で鼠にのる（ジャクソンの『グジャラット民俗記』一九一四年ボンベイ板、七一頁）。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボンベイの俗伝にガネサその乗る所の鼠の背より落ち、月これを笑うて罰せられたという事あり（クルック、一巻一三頁）。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "大黒像もガネサより因襲して鼠に乗りもしくは踏みおったが、梵徒は鼠を忌む故（一九一五年ボンベイ板、ジャクソンの『コンカン民俗記』八四頁）、追い追い鼠を廃し女神を代用したと見える。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日ボンベイ辺の下等民は鼠を鼠叔父と呼び、鼠と呼ぶを不吉とす。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年前に長い賜暇期日が終わったので、グレーヴセントからボンベイへ帰る船中で、ボンベイ地方の士官の妻のアグネス・ケイス・ウェッシントンという女と一緒になったのが、そもそも私の運命――わたしの大きな不運であった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年の春にボンベイに着くと、私たちは別れわかれになった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
