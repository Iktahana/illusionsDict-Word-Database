        "examples": {
          "standard": [
            {
              "text": "離婚後の生活を立て直すため、自治体が運営する母子寮への入居を決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "母子寮では同じような境遇の母親たちと励まし合いながら、自立を目指している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "施設の建て替えにより、母子寮の各個室はプライバシーに配慮した設計になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "体位向上徒歩奨励、幼児保健の問題、戦没者の母子寮の設立などと全く背までくっついていて離れられない双生児の歩む姿である。",
              "citation": {
                "source": "風俗の感受性",
                "author": "――現代風俗の解剖――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間、母子寮に暮している洋子ちゃんという十歳の女の子が、よその男につれまわされて、幸い無事に発見されたという事件があった。",
              "citation": {
                "source": "若い母親",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
