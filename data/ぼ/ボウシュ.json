        "examples": {
          "standard": [
            {
              "text": "日本では、芒種の時期になると田植えが本格的に始まり、農家は忙しくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "芒種の候、野には緑が深まり、生命の息吹を感じさせる季節となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今年の芒種は晴天に恵まれ、農作物の生育には良い兆しが見えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」「芒種五月の節に相成りますると、野にも川にも螢が夥しく居りまして子守や子供衆は日の暮を待ち兼ねて螢狩りに行きましたものでござりますが、鉱毒の為め少しも見えませぬ。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "この花の頃は、時鳥があちこち啼いて飛びちがいましたものでござりますが、只今では、虫や蜘蛛が鉱毒のため居りませぬ故か、一と声も聞きません」　芒種五月の螢狩、大麦小麦の穫り入れ。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
