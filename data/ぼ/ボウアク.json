        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は彼の命を必しも暴悪神として居らぬ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠れた暴悪と残忍性とが、薄い皮一重のやさしさと美しさとで蔽われているのであるから物凄い。",
              "citation": {
                "source": "惨事のあと",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『根本説一切有部毘奈耶』に、仏の弟子｜陀夷曰く姑の過ちでない、彼の両乳の間および隠密処に黒黶と赤黶と旋毛、この三の暴悪相があるからだと教え食を受けて去った。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺しても飽足りないような、暴悪な憎悪の念が、家を飛出して行く彼女の頭に湧返っていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺々の鐘突如としておびえ立ち、住家なく彷徨ひ歩く亡魂の、片意地に嘆き叫ぶごと、大空に向ひて傷しき声を上ぐれば、送る太鼓も楽もなき柩の車吾が心の中をねり行きて、欺かれし「希望」は泣き暴悪の「苦悩」黒き旗を立つ、垂頭れしわが首の上に。",
              "citation": {
                "source": "珊瑚集",
                "author": "仏蘭西近代抒情詩選",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　道鏡の暴悪と清麻呂の正義　勿論皇胤だとて必ずしも皇族ではない。",
              "citation": {
                "source": "道鏡皇胤論について",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "限りなく騰貴する物価は住民に向つて常に粗悪なる物品と食物とを供給せしめ、足らぬ勝ちなる生活は次第に野卑となつて礼儀交際の美観を許さず、目的を第一とした暴悪な行動は手段の如何を問はしめない。",
              "citation": {
                "source": "海洋の旅",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "維新後零落した旗本の家庭、親の為めに身を売る娘、新しい法律を楯にして悪事を働く代言人、暴悪な高利貸、傲慢な官吏、淫鄙な権妻、狡獪な髪結等いづれも生々とした新しい興味を以て写し出されてゐる。",
              "citation": {
                "source": "虫干",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち一城の主人であったが、主人の暴悪に愛想をつかし、自分から無断で国を立ち退き、宮仕えこそ煩わしと、そのまま賤民の群に入り、部下を作ること四千余人。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つらつら近時の世相を案ずるに、仏法の衰微、政道の弱化がいまに過ぐるものはない、もし清盛入道の暴悪をこらしめなければ、いつの日を期せようか。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この古今に例のない暴悪に、われらは賊徒として彼をその罪に問うべきであったが、あるいは神慮ととなえ、あるいは勅旨と称して偽りの名分を立てるなどで、われわれも隠忍せざるを得なかった次第。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな清らかな娘が、楽しそうにいそいそと働いているところに、不正も暴悪もあろうはずはないと思わせたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "不死の霊薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "後の鳥羽伏見の戦いも、一は、この四国町の薩摩屋敷の焼討ちが、退引させぬことにしたので、志士浪人の計画は、思うように的中し、明治の改革には、これがまた有力な動因とはなっているが、表面上、その形勢を見れば、暴悪の徒を蓄えて、江戸の上下を脅威愚弄した傍若無人ぶりに、腹の立つのも無理のない次第でした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来の大臣、従来の政府の役人は、賢明なる者ばかりであったかも知れないが、あとにはただ暴悪の跡ばかりが残っている。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――まことは、北面の侍ども、また、ただいま読み申した連判の輩が、血をすすりあって、院の法皇を仰ぎ奉り、新大納言の君を盟主として、暴悪な平氏を一挙に、覆えさんと思うのでござる。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦国の悲しさには、この暴悪なともがらの暴行に、駈けつけてくる代官所もなく、取りしまる政府もない。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一族の渡辺天蔵とその手下どもを誅罰に参ったのだ」　と、諭すと、ようやく鎮まって、口々に、天蔵の暴悪を怨んで訴えた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "欣んでわれわれは、暴悪な狂兵と戦いつくして、最後の旗を焼きましょう。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「かくまでの師直の暴悪を、兄者は真底では憎んではおられぬように見える。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
