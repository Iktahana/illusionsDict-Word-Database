          "literary": [
            {
              "text": "「寮の出入りって、大問題がありますよ」　ワラがぼそっという。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……津田もあの黒子が曲者じゃ」　繩をよっている掌に唾をして岩太郎がぼそっとつづけた。",
              "citation": {
                "source": "だるまや百貨店",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、私をじっとみつめながら、ラジオと縁をきれ、とぼそっと云った。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれも求められると何か言うには言ったが、いつも結論だけをぼそっと言って、あとはとぼけているといった風であった。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "神のご加護でございます」　デュマレスク伯爵ことグライドが微笑んで、ぼそっと言った。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼそっとささやいた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガイ牧師がぼそっと言った。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」だがノアノブを回す者はなく、私はじれて、ぼそっと「そうかい、だったらそこで待ってろ！",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、なんにも云わんところに、やっぱり、なにか、思いがこもってたね」「…………」「それで、しばらくしてからぼそっとつぶやくんだ。",
              "citation": {
                "source": "日めくり",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "お分かりですな、奥さま、掘り返しますよ」　声をひそめ、ぼそっと囁いた。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビートリスさん、もう手遅れですか」　ベリントン大佐が、だしぬけに、ぼそっと尋ねた。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かがぼそっと聞いた。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつはえらい災難にひッかかったな」　と、孫新は女房から聞く一ぶ一什にただ唸って、深く腕ぐみを結んだままだったが、やがてこうぼそっといった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――弟直義への、お咎めだに晴るるならば」　高氏は、ぼそっと言って、頭をさげた。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            }
          ]
        }
