    "definitions": [
      {
        "index": 1,
        "gloss": "violent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "野蛮な暴力的なことをやらなくたって、正式に娘を貰えばいいじゃないか、それなら俺れだって賛成だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実人生の、暴力的な真剣さを、興覚めする程に明確に見せつけられたのであります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとでいいから、とにかく、ちょっとでいいから、奥さんも、どうぞ、と、ほとんど暴力的に座敷へあがってもらって、なにかと、わがままの理窟を言い、とうとうＹ君をも、酒の仲間に入れることに成功した。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その欺きかたが、浅墓な、ほとんど暴力的なものだったので、私は、そのとき実に、言いよう無く不愉快であった。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とでも叫んでもらはうかしら、とも思つたが、そんな暴力的な手段は何としてもイヤだつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふよりも、私は、他人との間に暴力的な關係に陷つたといふ・その事だけで、既に、心中の大變な擾亂・動搖を免れない。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今は暴力的であり得た。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "荘田の家へ、単身乗り込んで行く以上、召使や運転手や下男などの多数から、どんな暴力的な侮辱を受けるかも知れない。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴力的権威もあれば、高尚なる精神的権威もある。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近｜遽に勃興したかの感ある新感覚派なるものの感覚に関しても、時にはまた多くの場合、此の狭小なる認識者がその狭小の故を以って、芸術上に於ける一つの有力な感覚なる賓辞に向って暴力的に突撃し敵対した。",
              "citation": {
                "source": "新感覚論",
                "author": "感覚活動と感覚的作物に対する非難への逆説",
                "note": "青空文庫"
              }
            },
            {
              "text": "共産黨はかかる趨勢に對處し、プロレタリアと利害一致せざる階級或は利害相反する階級までも、術策を弄して自己の陣營に抱込み、他方暴力的獨裁的方式をもつて、少數者の獨斷により一擧に事をなさんとしている。",
              "citation": {
                "source": "新日本の進路",
                "author": "石原莞爾將軍の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに恐るるものなき指導者群の專制は、個人の專制以上に暴力的となつたことを我等は認める。",
              "citation": {
                "source": "新日本の進路",
                "author": "石原莞爾將軍の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体主義につき從來いろいろの見解があつたが、我等はこれにつき統制主義の時代性を理解せず、指導者群の專制に後退したもの、繰返していうが、その弊害は個人の專制以上に暴力的となつたものと見るのである。",
              "citation": {
                "source": "新日本の進路",
                "author": "石原莞爾將軍の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か暴力的に画一的に命令する事が統制と心得ている人も少なくないようである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本帝国主義は、国内においては、農村の半封建的搾取、労働者の殖民地的搾取、国外においては、暴力的・軍事的に隣接民族を併呑、侵略、殖民地化して、成長してきたのである。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく個人的にまもられ、まったく個人の努力で営まれているわれわれの一つ一つの家庭、しかも戦争の間暴力的な権利でそれをちりぢりばらばらに壊されてしまっていた家庭、それを今日インフレーションの中で再建してゆく努力は、男も女も互にくらべてみれば、決してまさり劣りはないと思う。",
              "citation": {
                "source": "明日をつくる力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "平和に対する世界の努力を、暴力的に破壊させる切掛を合図し合うための同盟を結んだ三国は、西に東に兇暴な力を揮い始めた。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それは、その人なりの世界のうちに暴力的な支配や、戦争や、一般人間性をころす力への抗議がふくまれているという時に、民主的な方向へのつながりができるのである。",
              "citation": {
                "source": "その柵は必要か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただの暴力的な運動家が幅を効かせたりするのは学問の府として排斥すべきであるというのであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日ごろ進歩的な意見をもっている作家である豊島与志雄、新居格氏などからさえ、この新聞はまるで共産党系統のだれかが暴力的行為を仕組みでもしたような話をひき出している。",
              "citation": {
                "source": "「推理小説」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども彼はそこに漸次的な、連続的な、自然的な発展を見るのであつて、革命は暴力的なもの、破壊的なもの、不自然なものを含むとしてそれを却け、また彼はかやうな飛躍的な発展が可能であるとは信じない。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一切の暴力的革命を嫌ふ、といふのはそれによつて多くの善事が獲得されると同様にまた破壊もされるからだ。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し既に云つたやうに、一切の暴力的なこと、飛躍的なことは私の性質に合はない、それは不自然だからである。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」更にゲーテは、国民的生活は本来自然的な発展を遂げるものであり、これに対して不自然なこと、暴力的なことを為し、もしくは為す動機を与へるのは政治家であり、政府であると考へた。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは川合という文学の友達から肺病で、「さようなら」され、池田という同じ非合法運動の友人には、ぼくたちの恥かしい転向の際、剃刀で彼自ら右手首の動脈を切り温湯につけるという、暴力的方法で、「さようなら」された。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして其間に推測を逞くしたには相違ないが、余り暴力的な切盛や、人を馬鹿にした捏造はしなかつた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
