    "definitions": [
      {
        "index": 1,
        "gloss": "Boshin War (Japanese civil war between Imperial and shogunate forces; 1868-1869)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大坂に退いて謹慎してゐる慶喜をめぐつて、幕臣の激昂は渦をまき、伏見鳥羽の一戦となつて爆発、こゝに一箇年余に亙る戊辰戦争の幕は切つて落されたわけである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "また戊辰戦争の後には、世の中が惨忍な事を好んだから、仕掛物と称した怪談見世物が大流行で、小屋の内へ入ると薄暗くしてあって、人が俯向いてる。",
              "citation": {
                "source": "江戸か東京か",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "戊辰戦争の経験は胆玉のことには役立っても、指揮者としては何にもならない。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜田門事変から戊辰戦争にいたる大小幾多の政争や内乱をそのあいだにさしはさんで、混乱しきっている日本幣制を、金銀両本位の円制度に切替るというはなれわざが、どうしてあの貧乏政府にできたかという問題である。",
              "citation": {
                "source": "明治の五十銭銀貨",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "贋貨問題というのは戊辰戦争で、官賊両軍ともに軍費の捻出にくるしんでさかんに贋貨を鋳造した。",
              "citation": {
                "source": "明治の五十銭銀貨",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため戊辰戦争のさいに、その養子や家来らとともに、領土において理由もなく惨殺された。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八六八年（慶応四年）一月二日、これが、戊辰戦争の発端であった。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
