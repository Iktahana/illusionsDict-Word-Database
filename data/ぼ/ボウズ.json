[
  {
    "uuid": "e3be2bab-8ff0-578b-a75b-2c472a1e56db",
    "entry": "坊主",
    "reading": {
      "primary": "ぼうず",
      "alternatives": [
        "ぼんず"
      ],
      "is_heteronym": false
    },
    "grammar": {
