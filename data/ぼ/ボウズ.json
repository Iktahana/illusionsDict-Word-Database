    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Buddhist priest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一雄（註、長男）小さい坊主です。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者と坊主だって、路で逢えば互いに敬礼するではないか。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも君、意味深げな丸坊主だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宰は坊主頭のうしろへ両手を組んで、「言葉はどうでもよいのです。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが面白かつたので、すぐ次の外題が掛かると祖母にせがんで連れてつて貰つたが、その時は本願寺の高僧の葬儀の実写か何かで、後から後からゾロゾロゾロゾロ坊主ばかりの行列であつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "若くて禿頭の大坊主で、いつも大きな葉巻を銜えて呑気そうに反りかえって黙っていたのはプリングスハイムであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、何であったか、坊主の耳の動くことを書いてあったのを面白いと思ったことがあるくらいである。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩石の大崩れがあって、左の方に石を囲んだ坊主小舎がある、小舎の中は未だ雪が多くて、泊まることは出来そうもない、鍋が一枚蔵してあった、冠君は既に槍ヶ岳登りを終られて、雪を辷り落ちるようにして、下りて来られた、二言三言話を交えて、さっさと下りて行かれる。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主の除れたフランスのセーラーの被る毛糸帽子。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主刈りでチョッキを着ないドイツ人。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主頭め、山山は集ひて青き原をなすさてその上の丘のさびしさ。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいゝがさ沼森めなぜ一体坊主なんぞになったのだ。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この著者がどうかすると腥さ坊主と云われる所以かもしれない。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時から僧になった人とちがって、北面武士から出発し、数奇の実生活を経て後に頭を丸めた坊主らしいところが到る処に現われている。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また船乗の恐れる海坊主というのは霧の濃いかたまりだという説がある。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の父が出て來てみると、見知らぬ薄汚ない風采をした、一見乞食坊主のやうに見える男が――と父は後に僕に話した――横柄にかまへて「朔太郎君は居ますか」と言つたので、てつきり何かの不良記者かゆすりの類と考へ、散歩中の不在を幸にして、すげなく追ひ歸してしまつたさうだ。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に父からそれを聞いて、僕は風采から想像し、或はその乞食坊主が牧水氏でないかと思つた。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主の二十の入墨してる。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "――土人街の日本の坊主頭から苦情は出ないのですか。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき食卓の日本料理の美味のうちに急に鳴物の入った三味線を土人街の坊主頭の幇間が弾き出すと、香港あたりでよく歌われる鴨緑江節を女達が噛むようにうたいだした。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主頭のロシア人のジャズ・バンドが演奏を始めたのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦死者があると、いつも、もと坊主だった一人の兵卒が誦経をした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "急ごしらえの坊主の誦経が、いかに声高く樹々の間にひびき渡ろうとも、それによって自ら望まない死者が安らかに成仏しようとは信じられるか！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その医官は、頭をくり／＼坊主にして、眼鏡をかけていた。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが寒い時候にはいつでも袖無しの道服を着て庭の日向の椅子に腰をかけていながら片手に長い杖を布切れで巻いたのを持って、そうしていつまでもじっとしたままで小半日ぐらいのあいだ坊主頭を日に照らしていた。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく去年などは幾株かのばらとつつじを綺麗に坊主にしてしまわれた。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつは元は上野の山内の坊主で、歌女寿よりも年下なんですけれども、女に巧くまるめ込まれて、とうとう寺を開いてしまって、十年ほど前から甲州の方へ行って還俗していたんですが、故郷忘じ難しで江戸が恋しくなって、今度久し振りで出て来て、早速歌女寿のところへ訪ねて行くと、女は薄情だから見向きもしない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで蛇を見なかったら、そんな知恵も出なかったかも知れませんが、師匠も坊主も、つまりおたがいの不運ですね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "え、その坊主ですか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経質のくせに表面は大ように見せている父親はときどき「ぼうずはどうして生きているのかい」　と子供の食事を覗きに来た。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
