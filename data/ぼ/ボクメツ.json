        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蚊の撲滅　北米バルチモアーでは蚊のためにいろんな病気の流行るのを防ぐために一昨年市会で二万円ほど支出して撲滅にかかったが、結果がよかったので今年また一万円ほど支出したそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ持つて來て政府が干渉して、この機會に彼等を全く撲滅しようといふやうな方針でやつたとすれば、もう君、裁判とは言はれんぢやないか』『まあさうだね。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる間に、彼等の檢擧以來、政府の所謂危險思想撲滅手段があらゆる方面に向つてその黒い手を延ばした。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "記憶力しか有つてゐない人間は、足し算しか出來ない人間と同じだと云ひ、自分のこの力を撲滅しようとした。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神職が無慙不義にして、私慾のために諸神社を検挙し撲滅するより、愛国心など説くも誰も傾聴せぬは、上にすでに述べたり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "（１）十二世紀ごろから始まりその後数世紀にわたって、ローマ教会の教権擁護のために、異端その他宗教に関する罪悪を摘発撲滅するために行われた、歴史上有名な裁判。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "行為は勿論、思想まで、そう云う危険な事は十分撲滅しようとするが好い。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてさういふものは飽迄撲滅しなければならないと思つてゐるらしい。",
              "citation": {
                "source": "月明夜々",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "救世軍や婦人矯風会、又はその筋の言明に依ると、震災後特に馬力をかけて撲滅に努力しているという。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、実際、撲滅されかけているように見える。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち震災を機会として試みられた当局の「私娼撲滅」である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "醜業窟撲滅の結果　私娼は撲滅すべきものである。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "新生会の方は千束町の撲滅に対して正面から反対して、飽く迄も昔の千束町を復活させてもらうべく運動をした。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は人間最大の不幸は死の恐怖であり、人類の続く限りこれは消滅しないから、一刻も早く全人類を撲滅さすに限ると云ふ、ややシヨウペンハウエル流の考へを抱いてゐた。",
              "citation": {
                "source": "霧",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "革命前に於けるロシアの一般勤労婦人の状態は、目下の日本同然ひどいものでしたが、ソヴェト政府が樹立されてから、先ず生産において地位が向上し、徹底的に文盲撲滅運動がやられたので、間もなく、プロレタリア婦人の中からも続々と通信員が出、文学活動に進出する者が出て居ります。",
              "citation": {
                "source": "婦人作家の「不振」とその社会的原因",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェト市民は一九一七年以来文盲撲滅を努力的に行って、もとはインド、中国と並んでいた文盲のロシア人民を、啓発してきた。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシア、中国、朝鮮の人民が文盲撲滅の第一頁においてソヴェト権力、抗戦救国、民族独立の文字を知らされてゆくのとはひじょうにちがいます。",
              "citation": {
                "source": "文学について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この官僚主義者、新生活の擾乱者の標本が、世界無産婦人デーの夜、トラムによってどう撲滅されるか、息をつめて観ている。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからいろいろなクラブの研究会や、文盲撲滅研究会、実際に工場に於ける熟練工に自分をすること、そういうことは非常に熱心にやっている。",
              "citation": {
                "source": "ソヴェト・ロシアの素顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五幕九場のこの喜劇は、ソヴェトが、五ヵ年計画のはじまり、実際大仕掛に官僚主義撲滅と、労働の規律のためにアルコーリズム反対をやった時代に「左翼戦線」の詩人マヤコフスキーによって書かれたものだ。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五ヵ年計画は、勤労階級の文化向上のため、文盲撲滅費、住居増築費、学校・病院・托児所増設、食堂の増設、ラジオ・キネマ配布網の拡大費等に莫大な基金を予定している。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミーチャのよんでいる労働者新聞には官僚主義撲滅の一般集会で、やり玉にあげられた官僚主義の工場委員が、顰めっ面してさすがバツわるそうに写真にとられている。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "官僚主義撲滅は、どこまでも、どこででも行われた。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェトの作家たちでも、富農撲滅の必然性を把握することのできないものが少くなかった。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをどうして今急に撲滅しなければならないのか？",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学研究会気質を撲滅せよ！",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十月」は、翻る赤旗とともに、すべてこういうプロレタリア、農民への重石をはねのけ、猛然と文盲撲滅をはじめた。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
