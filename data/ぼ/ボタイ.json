[
  {
    "uuid": "103ecf62-31e9-571b-8264-c8abddccbd6f",
    "entry": "母体",
    "reading": {
      "primary": "ぼたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
