        "examples": {
          "standard": [
            {
              "text": "高い関税は、貿易障壁の一種として国際的に批判されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "非関税貿易障壁の撤廃が、自由貿易の推進には重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "技術的な基準も、国によっては貿易障壁となることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ところが米国通商代表部が教育用パソコンへのＢＴＲＯＮ採用は、アメリカ企業の市場参入を阻む排他的な貿易障壁となると言いだし、通産省の腰が呆れるほどあっけなく崩れて採用は取り消しとなった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
