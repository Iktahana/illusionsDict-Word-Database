    },
    "definitions": [
      {
        "index": 1,
        "gloss": "my personal (e.g. opinion)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼はその瞬間、青木に対する自分の従僕的な位置が転換して、青木に対して、彼が強者として立っているのを見出した。",
              "citation": {
                "source": "青木の出京",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは従僕的な魂の者であるとはいえ、それは彼らの罪ではなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "きびしい眼をした小さなブルドッグみたいな男で、偽善的な意地悪な奴僕的な顔をしていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩書や金モールや勲章の前に平伏してる奴僕的な魂。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その恬淡にして公僕的たること、戦後税務吏員の中では異例に属し、表彰したいくらいの人物でした。",
              "citation": {
                "source": "ボロ家の春秋",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕的にはカットリス技師が追放してくれて嬉しいですけど……。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
