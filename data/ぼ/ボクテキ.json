  {
    "uuid": "48b0ff06-4142-5eec-a35f-4e4e747acdb6",
    "entry": "僕的",
    "reading": {
      "primary": "ぼくてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
      "ctype": null,
