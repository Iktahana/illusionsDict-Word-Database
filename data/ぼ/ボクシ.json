        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――これがプロレタリア牧師さんの言葉。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには「青空」の中谷孝雄が田舍の老牧師になつて出てゐる。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中谷の老牧師は袋かなにかをかぶせられてぶん撲られたりするのであるがこれがまた可笑しかつた。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公ヂックが牧師の内に往って、牧師夫婦と話をしているうちに、牧師が余所へ出てしまう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ敵兵が来て牧師を縛ろうとする。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵兵はヂックを牧師だと思って縛りに掛かる。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヂックは牧師の積で、平気で縛られて行きます。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧師がヂックのために恩義でもある人ですか。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしヂックは「己は牧師ではない」というのが嫌なのです。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだからヂックを勤めたカアソンという役者が、批評家に智恵を附けられて、ジックは牧師の妻を愛しているので、それで牧師の身がわりに立ったということにした。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして敵兵に捕えられる時に、そっと牧師の妻の髪に接吻したのです。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして皆の考へたり祈つたりしてゐることを、牧師は教壇の上から大聲にしやべるのだつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧師もまた夜眠ることが出來ず、そしてもう神の御意が分らなくなつでしまつてゐるからだつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧師が賛美歌の番号を知らすと、堂のすみから、ものものしい重い、低い調子でオルガンの一くさり、それを合図に一同が立つ。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから牧師の祈りと、熱心な説教、そしてすべてが終わって、堂の内の人々｜一斉の黙祷、この時のしばしの間のシンとした光景――私はまるで別の世界を見せられた気がしたのであります。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎりり、時計のねぢをばまいて　　牧師が階段、ことことおりた。",
              "citation": {
                "source": "月の角笛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると牧師は腰掛の一端に倚りかゝつて後向に一人の青年と話をして居たが、相島の這入るのを見ると、其のつや／＼しい長い髮を電燈の光に輝かして一寸挨拶をした。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは少し讚美歌の練習をしませう」と軈て牧師が男らしい聲で快活に云ふと、女で居ながら人の前で決して面をかぶらない、其の細君は飾氣のない身ぶりで腰掛を立上つてオルガンに近づいた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧師はやをら身を起して講壇に登つたが、例の黒い運動着が又眼に付く。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "松崎には似合つた代物だが、松崎牧師としては不似合極まると心の顏をしかめながら思つた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して殆んど涙にあふれんとする眼を擧げて牧師を見た。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "説教は進んで牧師の意氣も昂つて居た。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は白髯でやはり牧師らしい黒い服装をしていましたが壇に昇って重い調子で答えたのでした。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはあすアフリカへ行く牧師の娘でございます。",
              "citation": {
                "source": "マリヴロンと少女",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、田舎の、古い牧師の家の庭で遊んでいたのでした。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわたしには、牧師の小さな娘のほうが、ずっと美しいバラの花のように思われました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしのバラの花も、牧師の家の庭のバラの花とおなじように、ずんずん若枝をのばしていきました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたあすこへぼくしるしをつけておくから。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかなは素人くさい風をして、山焦のした顔に白粉も塗らず、ぼくぼくした下駄をはいて遣って来たが、お島には土地の名物だといって固い羊羹などを持って来た。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに乗客はぼくしかいなくなっている。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
