          "standard": [
            {
              "text": "亡命文学には、故郷への深い思いと、失われた自由への渇望が込められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は亡命文学を研究し、抑圧された人々の声に耳を傾けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "亡命文学は、特定の政治体制下で書かれたものが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "もとの大公だの貴族だのと云われるグループとこれらの亡命文学者たちのして来たことは、ソヴェトの新しい社会建設への誹謗と、しつこい反革命運動しかなかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
