        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "船は防波堤を掠めて、油を流したやうな穩かな海にうねりを殘しながら進んでゐた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "独り荷物をかついで魚臭い漁師町を通り抜け、教わった通り防波堤に沿うて二町ばかりの宿の裏門を、やっとくぐった時、朧の門脇に捨てた貝殻に、この山吹が乱れていた。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒く濡れた防波堤が現われる。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "河口の防波堤も半分つくりかけて投げ出したやうな形に見える。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘だ、煙突だ、レールだ、そして防波堤だ、浮標だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、それに余り興味を覚へませんでしたので仲間に加はりませんでしたが満里子やＲは非常に、これに熱心となつて暇さへあれば、私の窓から真正面に当る防波堤に出て、海へ向つて（私の方を背にして）体操の練習に余念がありません。",
              "citation": {
                "source": "満里子のこと",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "左岸には一簇の葦の穗の茂りがあつて其先からは防波堤が屈曲して居る。",
              "citation": {
                "source": "佐渡が島",
                "author": "波の上",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽船は防波堤に隨つて屈曲して進む。",
              "citation": {
                "source": "佐渡が島",
                "author": "波の上",
                "note": "青空文庫"
              }
            },
            {
              "text": "防波堤の上には十人ばかり四つ手｜網を引いて居る。",
              "citation": {
                "source": "佐渡が島",
                "author": "波の上",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷電峠と反対の湾の一角から長く突き出た造りぞこねの防波堤は大蛇の亡骸のようなまっ黒い姿を遠く海の面に横たえて、夜目にも白く見える波濤の牙が、小休みもなくその胴腹に噛いかかっている。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのそばに、さまざまの漁具と弁当のお櫃とを持って集まって来た漁夫たちは、言葉少なに物を言いかわしながら、防波堤の上に建てられた組合の天気予報の信号灯を見やっている。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも牛乳のような色の寒い夕靄に包まれた雷電峠の突角がいかつく大きく見えだすと、防波堤の突先にある灯台の灯が明滅して船路を照らし始める。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "命とかけがえの漁場が、間違った防波堤の設計のために、全然役に立たなくなったのは前にも言ったとおりだ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "津浪の如くに押寄せる外来思想は如何なる高い防波堤をも越して日一日も休みなく古い日本の因襲の寸を削り尺を崩して新らしい文明を作りつつある。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人は私を伴れて、すぐ近くの防波堤の上にあった魚市場へ往った。",
              "citation": {
                "source": "妖影",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪はやんでいたが、まだ身を切る様な烈風が吹｜捲り、底深く荒れ果てた一面の闇を透して遠く海も時化ているらしく、此処から三｜哩程南方にある廃港の防波堤に間断なく打揚る跳波の響が、風の悲鳴にコキ混って、粉雪の積った線路の上を飛ぶ様に歩いて行く私達の跫音などは、針程も聴えなかった。",
              "citation": {
                "source": "気狂い機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "珊瑚礁は防波堤のやうに島のはるか沖合を取卷いてをるが、さういふところに緑青を溶いたやうな青い海の色が熱帶の太陽を浴びて、その上に白い波頭が幅廣く縁取つてをるのは實に美觀である。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "長さ二百五十間、幅二十間の埋立地をつくり、二百間あまりの岸壁を立て、總延長千六百間の餘にも及ぶ防波堤を築くために、五年間も一つの根氣仕事を續けて來たといふやうな、そんな辛抱強い人達が、その小山の上の土木出張所に働いてゐた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上防波堤へ上がって、砂ぶかい汽車や電車の軌道ぞいの往来へあがってみると、高台の方には、単調な松原のなかに、別荘や病院のあるのが目につくだけで、鉄拐ヶ峰や一の谷もつまらなかった。",
              "citation": {
                "source": "蒼白い月",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐和子は、妹と並んで防波堤兼網乾し場の高いコンクリートのかげで、日向ぼっこをしていた。",
              "citation": {
                "source": "海浜一日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "防波堤の下に並んで日向ぼっこをしながら、篤介がその犬に向って口笛を吹いた。",
              "citation": {
                "source": "明るい海浜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故ならイギリスは彼らに対抗する最後の防波堤だからだ」と。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第八巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "足元を洗う小波か、防波堤を越える大波か、いずれにせよ波頭はここに及ぶ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の家は老人たちの丹精の小松が成長して、しっかり根をかためていたせいか防波堤は崩れなかった。",
              "citation": {
                "source": "木魚の配偶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し入江は自然の防波堤の為めに浪は左程に立たなかつた。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岬の丘に登ると、太平洋炭鑛埋立地が南の防波堤に續き、まるで海を二ツに切つたやうに見える。",
              "citation": {
                "source": "摩周湖紀行",
                "author": "――北海道の旅より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈の並んだ防波堤を三方｜海原の行き止まりまで来てビックリして引き返した……。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋風や船、防波堤、安房の山皆痛ましく離れてぞ立つ　昭和八年の秋、横浜短歌会席上の作。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "その舟と防波堤と安房の山との間に生じた距離が三者の間のなごやかな関係を断ち切つて、離れ離れに引き離してしまつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、右舷のはるかに、黒々と防波堤が見え、星のように燦めくタラント軍港の燈火――いまや、戦艦「レオナルド・ダ・ヴィンチ」は目睫の間に迫ったのである。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
