[
  {
    "uuid": "720470be-c429-50ab-8f33-90e202f98fb1",
    "entry": "凡小",
    "reading": {
      "primary": "ぼんしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "small and of mediocre talent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "恋ぢやの人情ぢやのと腐つた女郎の言草は止めて了つて、平凡小説を捻くる間に少と政治運動をやつて見い。",
              "citation": {
                "source": "貧書生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "君達も平凡小説や平凡議論を書く暇があるなら日本人冥加に「猟之友」にでも日本犬主義を少と皷吹し給へ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡小井蛙の眼孔をもって、軽々な取沙汰は慎むべきであると――苦々しくたしなめる老武者もあった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間通有の凡小な感情は、抑えてのないまま、かえって普通人以上、露骨に出てくる。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
