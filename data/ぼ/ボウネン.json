[
  {
    "uuid": "5ea710f4-4d44-5157-a69e-e3da308cef0e",
    "entry": "忘年",
    "reading": {
      "primary": "ぼうねん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "forgetting the hardships of the old year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四、五日前役所で忘年会の廻状がまわった。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは会社に出勤、忘年会とか、いちいち社員から会費を集めている。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ忘年会ということにして……」　天辰の主人の思いがけない陽気な声に弾まされて、ガヤガヤと二階へ上る階段の途中で、いきなりマダムに腕を抓られた。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮に押し詰まって、毎晩のように忘年会の大一座があって、女中達は目の廻るように忙しい頃の事であった。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "近いうちに忘年会をやりませうか。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりこの妻を連れたサラリーマンは四五日前忘年会の二次会で、一友と語り合って、僕達は到頭男になったね、と頻りに男らしい感慨に耽ったものだが、今夜も彼は自分が男であることを自覚してそれはとてもいい気持になってゐた。",
              "citation": {
                "source": "飯田橋駅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘の向ひ側にある村長の家で忘年の仮装飲酒会を催さうといふ約束の宵だつたのである。",
              "citation": {
                "source": "ラガド大学参観記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今夜は愉快な忘年会なのだから、たゞ滅茶苦茶に騒いで、明さうよ。",
              "citation": {
                "source": "ラガド大学参観記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「のらくら手記」素材□忘年会とは面白い、忘の字が意味深長だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前、Ｋさん来庵、昨夜の会合の愉快だつたことなど話して、今日もまた飲まうといふ、それもよからう、何度でも忘年会をやつたつてかまはない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も酒なしか、――などと考へてゐるところへ、Ｋさん来訪、まだ酒があるから、樹明君を誘うて、もう一度（二度でも三度でも）忘年会を開かうといふ、大賛成で待ち受けてゐると、暮れないうちに、樹明君は魚の包を、Ｋさんは罎詰を持つて来庵、それからおもしろおかしく飲んで解散した、めでたやめでたや、善哉々々！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "（先日貰つた残り）午後は曇つて憂欝になつてゐるところへ、樹明君来庵、すぐ酒屋へ魚屋へ、Ｊさんも加はつて、第三回忘年会を開催した、酒は二升ある、下物はおばやけ、くぢら、ユカイだつた、おとなしく解散して、ほんにぐつすり寝た。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "テアトルという町での忘年会に二人して過って火傷をした時。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の忘年會大會の幹事を義雄も引き受けた龍土會の歸りには、おも立つた人々よりも一時代あとの若手連が二三名、麹町の詩人と共に付いて來た、が、中の町の隱れ家へは連れ込むことをしたくなかつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍土會の忘年會が、義雄と長谷天香といふ批評家との幹事で、午後五時から烏森の湖月であると云ふ日の晝過ぎであつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」かう千代子が聽いたのを振り向きもせず、渠は自分が幹事の忘年會が湖月で多くの藝者などをまじへて賑やかに飮んでゐるありさまを想像しながら、「どうか分らない」と、乃ち、お鳥にも告げて來たのと同じ言葉を繰り返して、電車の乘り場へ急いだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」其子｜懐之、其忘年の友渋江抽斎も亦古泉を翫んだ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵腹を立てるような事はあるまいと、純一の推測していた瀬戸が、一昨日谷中の借家へにこにこして来て、今夜｜亀清楼である同県人の忘年会に出ろと勧めたのである。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "曽根というのは、書肆博聞社の記者兼番頭さんをしている男で、忘年会の幹事だと、瀬戸が教えてくれた。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "こん度の忘年会の計画をしているうちに、或る日教育会の職員になっている塩田に逢った。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "年の暮のえびす講などに忘年芝居を催したりする派手な店で北新道のあたしの家の並びの荷蔵に、荷車で芝居の道具を出しに来たりしていた。",
              "citation": {
                "source": "大丸呉服店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段の上り口には赤い紙に白く、「世直し忘年会、有楽座において」とした広告ビラが張ってあった。",
              "citation": {
                "source": "一世お鯉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄宿舎には従来年末に忘年会をする例になっていて、常には昼する詩会を夜にして、これを開いた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで常の詩文会では出席生徒が順番にその宅から持寄りにする豆煎りを食うのみであるが、忘年会の詩会では、いり豆の外に獣肉の汁をこしらえて飯を食うことになっていた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は父の役目もあるから一層この束縛に就いていたのだが、或る年忘年会の幹事に当ったので、他の幹事に率いられて肉を買いに行った。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
