        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "翁はときどき、ひょんなところで、ひょんな憩い方をしていると、苦笑して悩みつつある一人ぼっちの自分を見出すのであったが、なかなか腰は上げ悪かった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜂雀もあんな遠くにいるんですし、僕ひとりぼっちになってしまうじゃありませんか。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八、九歳頃の彼はむしろ控え目で、あまり人好きのしない、独りぼっちの仲間外れの観があった。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕白な遊戯などから遠ざかった独りぼっちの子供の内省的な傾向がここにも認められる。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "双親とも亡くなって、一人ぼっちなのだそうだ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお嬢さんが一人ぼっちでいらっしゃったからだと仰ゃるのね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度己のように一人ぼっちでいたのだから。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "己のように一人ぼっちなんだ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前だって一体一人ぼっちなのだろう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "その話をききながらひとりぼっちの気持で黙り込んでいました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ご免なさいまし、）といったがものもいわない、首筋をぐったりと、耳を肩で塞ぐほど顔を横にしたまま小児らしい、意味のない、しかもぼっちりした目で、じろじろと門に立ったものを瞻める、その瞳を動かすさえ、おっくうらしい、気の抜けた身の持方。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい太郎は、兄弟がなくてひとりぼっちだったからです。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりぼっちということは、こんなとき、たいへんつまらないと思います。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありやとっつぁんぼっちやんだなあ」　ともいつたさうだ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して私がとっつぁんぼっちやんなら、あの男はぼっちやんとっちやんだといつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供達は、お涌も時に交って、その土蔵の外の溝板に忍び寄り、俄かに足音を踏み立てて「ひとりぼっち――土蔵の皆三」と声を揃えて喚く。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、お前さん一人ぼっちでこんな所にいて……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから私は全くたった一人ぼっちで、この堪え難い人生を渡って行かなければならないのだ……。",
              "citation": {
                "source": "父を失う話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あしたになって、おてんとさまがのぼっちまえば、あと一年たたないことにゃ、おまえさんを助けてやるわけにはいかなかったんだよ。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、かわいらしい、伯爵のぼっちゃまは、それはそれは愛らしくて、神さまの天使のようでした。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼっちゃまは、アンネ・リスベットに、とてもなついていました。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンネ・リスベットも、ぼっちゃまが大好きでした。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼっちゃまは、アンネ・リスベットにとっては、大きなよろこびでした。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのぼっちゃまも、今は大きくなって、十四｜歳になっています。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンネ・リスベットは、赤ちゃんのときに、だいてあげてから、ぼっちゃまには、一度も、会ったことがありませんでした。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
