    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fifth division of the night (approx. 3am to 5am)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雲が延びると、裾野のぼやけた緑は、水底に揺らめく青草の波になった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "十間許り下流で釣つてゐる男の子の姿も、夕暗に輪廓がぼやけて来た。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで日の入りがぼやけた朱色に見え、日の出が褪めた桃色に見えるが、兎に角その交代して繰り返されて行くことが分かる。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『十七‥‥‥』と、それに習つたお前の聲は、もうその時『ふうち‥‥‥』と呟いたやうに細く、ぼやけてゐた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ふらふらしながら歩き續けてゐる内に現實的な意識は殆ど消えて、變にぼやけた頭の中に祖母や友達の顏が浮び上つたり、三四｜日前にＫ館で見た活動寫眞の場面が走つたりした。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小豆島で汽船に乗って、甲板から、港を見かえすと、私には、港がぼやけていてよく分らなかった。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひところはやった玄米パン売りの、メガフォーンを通して妙にぼやけた、聞くだけで咽喉の詰まるような、食欲を吹き飛ばすようなあのバナールな呼び声も、これは幸いにさっぱり聞かなくなってしまった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七味唐辛子を売り歩く男で、頭には高くとがった円錐形の帽子をかぶり、身にはまっかな唐人服をまとい、そうしてほとんど等身大の唐辛子の形をした張り抜きをひもで肩につるして小わきにかかえ、そうして「トーン、トーオン、トンガシノコ」と四拍子の簡単な旋律を少しぼやけた中空なバリトンで歌い歩くのがいた。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青と赤のインキで塗った下手な鳥の絵のぼやけた映像を今でも思い出すことができる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでながら、切り立ての鋏穴の縁辺は截然として角立っているが、揉んで拡がった穴の周囲は毛端立ってぼやけあるいは捲くれて、多少の手垢や脂汗に汚れている。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは黄色にぼやけて夜だか昼だか夕方かもわからずよもぎのやうなものがいっぱいに生えあちこちには黒いやぶらしいものがまるでいきもののやうにいきをしてゐるやうに思はれました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "裾のぼやけた、そして全体もあまりかっきりしない入道雲が水平線の上に静かに蟠っている。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲の色にぼやけてしまって、姿は見えなかったが、光の反射だけ、鳥にすれば三羽ほど、鳩一流のどこにあてがあるともない飛び方で舞っていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "開くでもなしに、弁当を熟々視ると、彼処の、あの上包に描いた、ばら／＼蘆に澪標、小舟の舳にかんてらを灯して、頬被したお爺の漁る状を、ぼやりと一｜絵具淡く刷いて描いたのが、其のまゝ窓の外の景色に見える。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "改札口には、雨に灰色した薄ぼやけた旅客の形が、もや／＼と押重つたかと思ふと、宿引の手手の提灯に黒く成つて、停車場前の広場に乱れて、筋を流す灯の中へ、しよぼ／＼と皆消えて行く。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の順礼のお盥髪さへ、此方に背き、早やうしろを見せて、びしや／＼と行く処を――（見なくとも可いのに）気にすると、恰も油さしがうつ伏せに鉄の底を覗く、かんてらの火の上へ、ぼやりと影を沈めて、大な鼠のやうに乗つて消えた。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼山について休んだ処で、渋茶を汲むのはさだめし皺くたの……然ういへば、来る道の阪一つ、流を近く、崖ぶちの捨石に、竹杖を、ひよろ／＼と、猫背へ抽いて、齢、八十にも余んなむ、卒塔婆小町を正で見る婆さんが、ぼやり、うつむいて休んでゐた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、どんな式服を着ていたかと聞かれると、たった今見て来たばかりの花嫁の心像は忽然として灰色の幽霊のようにぼやけたものになってしまう。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もやもやした霧の中から突然日輪でも出現したようにあまりにくっきりとそれだけが聞こえて、あとはまた元どおりぼやけてしまった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえ、でも、その青蚊帳に写した幻燈のような、ぼやけた思い出が奇妙にも私には年一年と愈々はっきりして参るような気がするのでございます。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫のような耳をもち、ぼやぼやした灰いろの髪をした雪婆んごは、西の山脈の、ちぢれたぎらぎらの雲を越えて、遠くへでかけていたのです。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつらは人の眼には見えないのですが、一ぺん風に狂い出すと、台地のはずれの雪の上から、すぐぼやぼやの雪雲をふんで、空をかけまわりもするのです。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　雪婆んごの、ぼやぼやつめたい白髪は、雪と風とのなかで渦になりました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なんだがお日さんぼやっとして来たな。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで案内記ばかりにたよっていてはいつまでも自分の目はあかないが、そうかと言ってまるで案内記を無視していると、時々道に迷ったり、事によると滝つぼや火口に落ちる恐れがある。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、ひとコマの照射時間にその物自身の線長に対して比較さるべきほどの距離を動くすべてのものはもはや夢のようにぼやけてしか現われない。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、これが写真の場合だとカメラのシャッターの開いている間の各瞬間における影像はことごとく重合し、その重合したぼやけくずれただらしのないものがフィルムに固定される。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
