        "examples": {
          "standard": [
            {
              "text": "細胞分裂の際には、染色体が紡錘体によって正確に両極に分配されます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "顕微鏡で観察すると、細胞内に美しい紡錘体が形成されているのが見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "紡錘体は、生命の連続性を支える重要な細胞内構造の一つです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それがこの奇妙な紡錘体の把柄とでも云いたいような恰好をしているのであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが波を打って動くにつれて紡錘体は一刻みずつ枝の下側に沿うて下りて行った。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十九個の紡錘体の始末に困ったが、結局花畑のすみの土を深く掘ってその奥に埋めてしまった。",
              "citation": {
                "source": "簔虫と蜘蛛",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
