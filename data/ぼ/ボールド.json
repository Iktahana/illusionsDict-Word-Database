    "definitions": [
      {
        "index": 1,
        "gloss": "bold",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "当時には珍しいボールドなタッチでかいた絵で、子供をおぶった婦人が田んぼ道を歩いている図であった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その右手の壁に株の相場を書いたボールド。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを私は、電話の横にかかったボールドにチョークで書き直すのであったが、それを見ながら叔父は腹の中でいろんな奸策を立て直しつつ、お客の株を売ったり買ったりして、悪銭をカスッている事が私によくわかった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "数学の先生がボールドに向って一生懸命説明して居ると、後から白墨を以って其背中へ怪しげな字や絵を描いたり、又授業の始まる前に悉く教室の窓を閉めて真暗な処に静まり返って居て、入って来る先生を驚かしたり、そんなこと許り嬉しがって居た。",
              "citation": {
                "source": "落第",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は又数学に就ても非常に苦しめられたもので、数学の時間にはボールドの前に引き出されて、その儘一時間位立往生したようなことがよくあった。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はボールドウィン、キャバンディッシュ、バカテルと云う骨牌倶楽部の会員であったが、彼は惨殺される当日は、昼食後バカテル倶楽部で、ホイストの勝負をやっていたと云うことがわかっている。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かに余白に書き込みを入れる、ページの端を折ったりクリップをはさむなどして目印とする、覚えに線を引く、書体をボールドにしたり下線を付したりするなど、従来の本でできることは（多少のおまけもついて）カバーされている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大森君は職員中第一の肥大漢で、教授の時間でもボールドの前に立つて居るのを太儀だといつて止むを得ぬ外は椅子へかゝつて居る。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三世紀にコンスタンチノプル帝、ボールドウィン二世、四方より敵に囲まれて究迫至極の時、他国へ売却した諸宝の内に大勝十字架あり、これを押し立て、軍に趨けば必ず大勝利を獲というたものだが、肝心緊要の場合に間に合わさず、売ってしまったはさっぱり分らぬとジュロールの『巴里記奇』に出づ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイボールドの『米国書目』は米国書目中の貴重書として珍重されて時価著るしく騰貴しているが、此の貴い書目も丸善の誇りの一つであった。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボールドには、授業の最後の時間に数学を教えた数字がそのままになっている。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽快な小枝模様でもさっぱりと出した壁の前には、単純で、細工は確かなカップボールド、サービング・チェスト。",
              "citation": {
                "source": "書斎を中心にした家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、この生の執着に打勝って自殺するには、そこにスプリングボールドとなるものがあればよいということに気がついたのだ。",
              "citation": {
                "source": "ある自殺者の手記",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "スプリングボールドはいうまでもなく死の道づれだ。",
              "citation": {
                "source": "ある自殺者の手記",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって、スプリングボールドがなくては、とても死ねなくなって来たのだ。",
              "citation": {
                "source": "ある自殺者の手記",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果、スプリングボールドとするには、あながち先方の同意を得なくっても、換言すれば、先方の意志にさからってでも、なし得るものだということがわかったのだ。",
              "citation": {
                "source": "ある自殺者の手記",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この長沢先生の時間と覚えておりますが、その先生がカッパードシヤカッパードシヤとボールドへ書くので、そのカッパードシヤを書こうとしてチョークを捜すために抽斗を明けると、その抽斗の中から豆ががらがらと出て来たというような話がある。",
              "citation": {
                "source": "模倣と独立",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手に首をねじって、ボールドと先生とを見るわけであったが、化学の一時間は何と余力の欠けた、溌溂としたところのない時間であったろう。",
              "citation": {
                "source": "私の科学知識",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日堀野が私にちょっと来いと言うので、博物教室に行って見ると、彼は誰れも居ない教室のボールドに、チョークをとって、Let me open your flour-gate with my keet　と書いて、ニコニコしながら、「どうだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカの人権擁護協会理事ボールドウィン氏が来朝したことも、日本の民主化の現実を世界に知らす上に役立った。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　自分は、座って　サイドボールドの中を覗き　美しい柳の描いてある　水なし飴を一つつまみ　ひとりで、部屋を見廻し　味わう。",
              "citation": {
                "source": "五月の空",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此處は何學年の教室であつたか、正面の剥げちよろのボールドには、白墨で海石流に書かれた「忠君愛國品行方正」の八文字が淡く消えかゝつて、ラムプの火に映つてゐた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "能率を上げなくてはと、汚れた壁のボールドには、二十人の女工の色塗りの仕上げ高が、毎日毎日数字になって、まるで天気予報みたいに、私達をおびやかすようになった。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "背景は九州帝国大学、精神病科本館、講堂のボールドで、白い診察服を着ておりますのは、平生の講義姿をそのままに画面にあらわしたもので御座います。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、石勝の隣の家具屋によいサイドボールドが七十円であると云う。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "数学の先生はボールドへ式をかいて、答えをかいて、それっきりである。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校ではいつも臨時試験を行って、私はかつて師範科の伝習を朧気ながら受けていたから、自ら教鞭を執り、ボールドに向って、白墨を使い、生徒の試験をしたのは、今から思えば可笑しい。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "改札のところ寒い故、ボールドに、МОЯナカニ居ルとかいて置いたがＹ来ず。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボールドに面と向いつつ却って上にお芳さんと他の者の書いた字があったためよまず。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
