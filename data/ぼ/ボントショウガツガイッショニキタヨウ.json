    "definitions": [
      {
        "index": 1,
        "gloss": "as if Christmas and one's birthday had come at the same time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
