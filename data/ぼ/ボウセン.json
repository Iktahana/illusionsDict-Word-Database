[
  {
    "uuid": "87412305-b285-5db7-94ef-24e961053856",
    "entry": "傍線",
    "reading": {
      "primary": "ぼうせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
