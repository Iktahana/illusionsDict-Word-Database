        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このけものかね、これはボスといってね、おいおい、そこつるはしはよしたまへ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボス〔と〕いってね、いまの牛の先祖で、昔はたくさん居たさ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人のアインシュタインに対する関係は、一見ボスウェルのジョンソン、ないしエッカーマンのゲーテに対するようなものかもしれない。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「琥珀の中の蝿」などと自分で云っているが、単なるボスウェリズムでない事は明らかに認められる。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボストンで、とあるチョプスイ屋へはいって夕飯を喰ったら、そこに日本人のボーイが居て馴れ馴れしく話しかけた。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にはボストンの医師某。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は着ていた猫の舌で一杯の衣服を脱いで、しかつめらしく恋の密輸入物をトランクにしまうと一寝入りするつもりで車窓からボスニヤ平原に咲く砂糖黍の花の香いを嗅いでいるうちに、すっかり追想的になってしまったのだ。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボスボロス海峡で過去の汚いものを洗い清めて東西の国境に足をまたげ、土耳古の空を見上げたときは現代の世界が実業家によって支配されるってことが非常に僕を得意にしてケマル・パシャが尻に錨をつけて黒海を泳ぐさまさえ可笑しかったのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が部屋に這入ると絹のハンカチに涙の地図をかいた女が私の姿を見ると罵るように、妾は日本が憎い、妾の恋しい人を連れ出すのはこのインボスタ奴！",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "このけものかね、これはボスといってね、おいおい、そこつるはしはよしたまえ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボスといってね、いまの牛の先祖で、昔はたくさん居たさ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このけものかね、これはボスといってね、おいおい、そこ、つるはしはよしたまえ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボスといってね、いまの牛の先祖で、昔はたくさんいたのさ」「標本にするんですか」「いや、証明するに要るんだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このけものかね、これはボスといつてね、おいおい、そこ、つるはしはよしたまへ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボスといつてね、いまの牛の先祖で、昔はたくさん居たのさ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーレー万国史、クヮッケンボス文典などという書名を連ねた紙片に過ぎなかったが、それが恐ろしく幼い野心を燃え立たせた。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがために、いわゆるストロボスコープ的効果によって、進行せる自動車の車輪だけが逆回りをしたりするような怪異が出現し、舞踊する美人が千手観音に化けたりするのである。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にはタチツボスミレの天ぷらである。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "政党方面にも関係して若い癖に地方政界のボスのような形になっていた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、銀ちゃんの仲間の多くは、闇市のボスになり、キャバレーと特殊関係を作り、またたく間に産をなして、もはや宵を越さずに使おうと思えば四十万円、百万円の別荘を買うよりほかに方法がない。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボスとなった仲間への、ささやかな抗議であった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺たち七人はシカゴで徒党を組んでて、エルシィの父親は一味のボスでした。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシアのレスボス島では熟兎を道で見れば凶、蛇を見れば吉とすと見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る学者はその穴がボスニア湾だとはつきり云つてゐる。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "キルヘル（８）やその他の人々は、メールストロムの海峡の中心には、地球を貫いてどこか非常に遠いところ――以前はボスニア湾（９）がかなり断定的に挙げられた――へ出ている深淵がある、と想像している。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "一六九九年にアメリカの海岸へ帰り、やがてボストンで逮捕されて部下と共にイングランドへ送られ、海賊を働いたことを否認したが、船員の一人を殺害した廉で、九人の部下と共に絞刑に処せられた。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八七年八月、ボストンで開かれたマックワールドエキスポで発表されたハイパーカードは、日米二つのその他班を、パーソナルコンピューターに一段と近づけました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "宛名――Ｒ・区六八番、ボストン、Ｕ・Ｓ・Ａ。",
              "citation": {
                "source": "初夏通信",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八九八年六月、在米ボストン市　　　　　　　　　　＊六月六日（月）　晴、午後に至りて風強し。",
              "citation": {
                "source": "サフランの花",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "また有名なる慈善家ピーボディーはいかにして彼の大業を成したかと申しまするに、彼が初めてベルモントの山から出るときには、ボストンに出て大金持ちになろうという希望を持っておったのでございます。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            }
          ]
        }
