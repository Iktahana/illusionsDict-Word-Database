[
  {
    "uuid": "dc4e9f18-54f3-5b6f-a636-26632af5543a",
    "entry": "母性愛",
    "reading": {
      "primary": "ぼせいあい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
