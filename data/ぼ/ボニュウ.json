[
  {
    "uuid": "12cbd569-7b86-50bd-bbcc-e2e96af55d2f",
    "entry": "母乳",
    "reading": {
      "primary": "ぼにゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
