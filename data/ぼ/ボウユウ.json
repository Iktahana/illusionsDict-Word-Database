    "definitions": [
      {
        "index": 1,
        "gloss": "deceased friend",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その中で、小御岳の小舎で、亡友、曾我部一紅追悼登山の納め手拭を見出した時、私の眼にうるみを覚えた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "水瀦に映る雲の色は心｜失せし人の顔の色のごとく、これに映るわが顔は亡友の棺を枯れ野に送る人のごとし。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "われとわが亡友との間、半透明の膜一重なるを感じた。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し子規は又例の如く尻持たぬわが身につまされて、遠くから余の事を心配するといけないから、亡友に安心をさせる為め一言断って置く。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "身は学舎にあり、中宵枕を排して、燈を剪りて亡友の為に哀詞を綴る。",
              "citation": {
                "source": "哀詞序",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡友Ｋ君が眼病で手術をして一時失明したことがあった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎といふ男は何か悟ったとこのあるやうなやつで、妙に人の悪口を云はないね――と、僕は柏村といふ亡友と学生時分からはなしてゐたので、聞くにつけ意外の感に打たれた。",
              "citation": {
                "source": "喧嘩咄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――細君の亡友の妹なんだが、家庭の不和でもあるらしく何時からともなしに百合子は彼等の行く先々へ伴いてまはつて、時々映画女優になり度いなどと云つて姿をくらますこともあつたが、やはり文学が一番のものだと云つては舞ひ戻つてゐた。",
              "citation": {
                "source": "好色夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく紅葉の訃は伝わって、世を挙ってこの比い少ない天才の逝くを痛惜したが、訃を聞くと直ぐ、私は弔問して亡友の遺骸に訣別を告げた。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡友の記念だと思って長い間それを袋の中に入れてしまっておいた。",
              "citation": {
                "source": "子規の画",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "高松半之丞というのは、帯刀から云えば、亡友高松半左衛門の遺児で、同じ旗の本に集っていた若侍、また岡引虎松から云えば、世話になった故主半左衛門の遺した只一人の若様だった。",
              "citation": {
                "source": "くろがね天狗",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし亡友の遺児であってみれば捨てて置くことは世間が蒼蠅かった。",
              "citation": {
                "source": "くろがね天狗",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、亡友に尽すつもりで、出来るだけその人達の世話を焼いた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日からこの亡友とその事業とについて少し書いてみたい。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この書の翻訳としては先に亡友一戸直蔵君の『宇宙開闢論史』がある。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず亡友｜浩さんと兄弟と見違えるまでよく似ている。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど亡友の日記は面白かろう。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡友の記念だと思つて長い間それを袋の中に入れて仕舞つて置いた。",
              "citation": {
                "source": "子規の畫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それというのも、実は此の一篇の本筋は作者が空想の上から捏ねあげたものではなく、作者の親しい亡友Ｍが、其の死後に語ってきかせて呉れたものなのである。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡友Ｍについては、いずれ此の物語を読んでゆかれるうちに諸君は、それがどのような人物で、どのような死に方をしたのであるか、おいおいとお判りになってくれることであろう。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても「死後に語ってきかせたもの」などと言うのは大変｜可笑しいことに聞えるかも知れないが、これも事情を申して置かねばならないことであるが、諸君もかねてお聞きおよびかと思う例の心霊研究会で、有名なるＮ女史という霊媒を通じて、作者がその亡友から聞いた告白なのである。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのも実はこの物語の主人公であり、又同時に尊い実験者であるところの私の亡友Ｙ――が亡くなる少し前に、是非私に判断して呉れという前提のもとに秘密に語った彼自身の驚くべき実験談なのでして、内容が内容だから、他へは決して洩らさぬことを誓わされたものなのです。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸なる亡友Ｙ――は、永らくおのれが胸だけに秘めていた解き得ぬ謎の解決を求めんがために折角私という話相手を選んだのでしたが、流石の私にも彼が満足するような明答を与えることが出来ませんでした。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　＊　　　＊　　　＊　亡友Ｙ――は斯う語って、この壊れた加減蓄電器を私に手渡したのです。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
