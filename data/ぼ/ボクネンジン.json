    "definitions": [
      {
        "index": 1,
        "gloss": "quiet unsociable person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
