    "definitions": [
      {
        "index": 1,
        "gloss": "death",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "演奏方面は勿論として、作曲家も没々出て来る。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろこちらから云へば、都の人が没個性的であるのでもあるのです。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "会話が、少しもわからず、さりとて、あの画面の隅にちょいちょい出没する文章を一々読みとる事も至難である。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし本質的に観察して、音楽精神の時代的没落を語るものであり、併せて現代日本文化の、救ひがたき卑俗的低落化を実証するものである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日最近にいたって、僕は漸く芭蕉や一茶の句を理解し、その特殊な妙味や詩境に会得を持つようになったけれども、従来の僕にとって、芭蕉らの句は全く没交渉の存在であり、如何にしてもその詩趣を理解することが出来なかった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水茎の岡の館に妹と我と寝ての朝の霜の降りはも」という古今集の歌と、どこか共通の情趣があり、没落した情緒への侘しい追懐を感じさせる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐれた英雄の戦没した後に、こういううわさの生まれたのはいつの世でも同じだと思われる。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴場へ行って清澄な温泉に全身を浸し、連日の疲れを休めていると、どやどやと一度に五、六人の若い女がはいって来て、そこに居たわれわれ男性の存在には没交渉に、その華やかな衣裳を脱いで、イヴ以来の装いのままで順次に同じ浴槽の中に入り込んで来た。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　暦の上の春と、気候の春とはある意味では没交渉である。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "性格が分裂して徹底した没分暁漢になれなくなるから。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから一見閑静な田舎に住まっていては、とても一生懸命な自分の仕事に没頭しているわけにはいかない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窪んだ眼にまさに没せんとする日が落ちて、頬冠りした手拭の破れから出た一束の白髪が凩に逆立って見える。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "顧れば峡間から東方の霞沢岳連峰の木山には、どす玄い雨雲が、甘藍の大葉を巻いたように冠ぶさって、その尖端が常念一帯の脈まで、包んで来ている、雪の峡流は碧い石や黄な石をひたして、水嵩も多くなって、樺青く雪白い間を走って行くのが、遙かに瞰下されて、先は森林の底に没している。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の下からは蒼黯い偃松が、杉菜ほどに小さく見えて、黄花石楠花は、白花石楠花に交って、その間にちらほらしている、一団の霧が槍へ吹っ懸けて、白い烟をパッと立てるので、一時は姿を没したが、又穂先だけ鋭く突き出す。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉附近の路が酷くくずれている、宿の前で嗽いをした筧の水などは、埋没してしまっている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "月見草の花が白い、カケス畑を知らぬ間に過ぎて、自動車はスケッチ帳入りの小嚢を手に下げた茨木君と私と長男隼太郎外、強力一人を大野原に吐き出して、見送りのため同乗せられた大山さんと、梅月の主人をさらって、影を没してしまう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは一歩さかのぼって、裾野がいまだ生成しないうち、富士と、愛鷹と、箱根が、陥没地帯の大海原に、火山島のように煙を吐いて、浮かんでいたところを想像すれば、今日の豆南諸島の大島、利島、三宅島などが、鋪石のように大洋に置かれているのと似て、更に大規模なる山海の布置を構成するであろう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに石楠花にとろけている生物が二個ある、一個は私である、一個は石楠花の花の中に没頭して、毛もくじゃらの黄色い毛だらけの尻を、倒しまに持ちあげ、蜜を吸い取っているアブである。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの儘に、埋没させるには、あまりに華やかに、あまりに麗はしく、若々しい川の姿である、Rev. LO, Roke といふ日本へ来たことのある英国人は、五六年前、倫敦の王立地学協会で、講演して、「およそ全世界に見られ得るほどの川の純美は、凡て天竜川にあつまつてゐる。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四は、山の不幸は、住人の不幸になって、シャスタ山と、切っても切れぬ歴史中の人を、埋没しようとしている。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕は日が背後に没して、紫水晶のように匂やかに見える。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでなかった日には、雪ばかりの山が、大崩雪となって、日本のように山岳が多くて平原の狭い国は、平原中が雪で埋没されるわけになってしまうのである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう、どんな者にも搾られはしない」　これ以上搾取されることが厭になった、と云う訳でもあるまいが、安田の死体が、未だ海の中へ辷り込まない、その夜、一人のセイラーと、一人の火夫とが、「又酔っ払った」　第三金時丸は、沈没する時のように、恐怖に包まれた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう云ふ風な考へ事に没頭してゐれば、具体的な、現実的な生活からも、生活手段からも離れて行くことは自明の理であつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸壁が海の方へせり出して、その内側が陥没したので、そこに建て連ねた大倉庫の片側の柱が脚元を払われて傾いてしまっている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘安四年に日本に襲来した蒙古の軍船が折からの颱風のために覆没してそのために国難を免れたのはあまりに有名な話である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベンチの脚は落葉に殆ど没している。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の祖神が没くなるとまもなく子が無いことを託っていた筑波の岳神夫妻の間にこれをきっかけに男女五人ほどのこどもができた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仏子、仏域を穢すときいかに」「鯉魚」「そもさんか、出頭、没溺火坑深裏」「鯉魚」「這の田舎奴、人を瞞ずること少なからず」　「鯉魚」「ほとんど腐肉蠅を来す」「鯉魚」　これでは全く問答になっていません。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に人に使われて働いていた時分は、生活の心配を離れて、専心に工夫に没頭したら、さぞ快いだろうという、その憧憬から日々の雑役も忍べていたのだがその通りに朝夕を送れることになってみると、単調で苦渋なものだった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
