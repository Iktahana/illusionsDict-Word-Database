        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "李張はこうして締め切ってある房の内へどうして入って来たろうと思って不審して見ていた。",
              "citation": {
                "source": "悪僧",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後二、三日の間は、監房の内と外とで囚人と看守との間の戦争が続いた。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "李茂は、小ざっぱりとした廂房の内部と、春桃の生活につよい好奇心がある。",
              "citation": {
                "source": "春桃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙ったまま腰に吊っている剣をバンドごとはずすと改めて監房の内へ泥靴のまま突進していった。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "錠をはずしてある鉄扉を押しあけ、房の内に入った。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が間もなく女は監房の内部へ消えて、厚い扉が、図太く入口を覆つてしまつた。",
              "citation": {
                "source": "間木老人",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは止そう、きょうこそ通うことは止そうと、いまのいままで考えていながら身はすでに房の内に、花桐の衣裳の筐のかげに坐っていた。",
              "citation": {
                "source": "花桐",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、明慧上人のこの獅子吼があらわれてから、吉水禅房の内部にも、かすかな信仰の揺るぎが萌してきた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して貴人に危害を加えるためではありません」　房の内外を司る管家婆という役目の老女が、こういって、玄徳の小心を笑った。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　遠くの房の内で、尊氏の返辞が、大きく聞えた。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえは、どろぼうのうちにまよいこんだんだよ。",
              "citation": {
                "source": "三本の金の髪の毛をもっている鬼",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
