        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかも、この狸たるや、アルテミス型の少女に惚れる男のごたぶんにもれず、狸仲間でも風采あがらず、ただ團々として、愚鈍大食の野暮天であつたといふに於いては、その悲慘のなり行きは推するに餘りがある。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「草葉の蔭で父上が……」とそれからさわりで行くところだが、あの時はどうしてあの時分はあんなに野暮天だったろう。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は東京に出てから十年の間、いろいろな苦労をしたに似ず、やはり持って生まれた性質と見えまして、烈しいこともできず、烈しい言葉すらあまり使わず、見たところ女などには近よることもできない野暮天に見えますので、大工の藤吉が唐偏木で女の味も知らぬというのは決して無理ではなかったのです。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "）あんたが野暮天か道楽者か、その見分けが付かないようで、憚りながら芸妓の鑑札を持っていられるかって云うんだ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、この狸たるや、アルテミス型の少女に惚れる男のごたぶんにもれず、狸仲間でも風采あがらず、ただ団々として、愚鈍大食の野暮天であつたといふに於いては、その悲惨のなり行きは推するに余りがある。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は死期が近づくにつれて、どんなに俗な野暮天でも、奇妙に、詩というものに心をひかれて来るものらしい。",
              "citation": {
                "source": "犯人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃ち茲に暫らく閑天地を求めて、心頭に雲を放ち、胸底に清風を蔵し、高眠安臥、興を暮天の鐘にさぐり、思を緑蔭の流光に托し、風鈴に和して吟じ、雨声を友として語り、この夏中百日を暢心静居の界に遊ばんとす。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "み空の花なる星、この世の星なる花、黙々として千古語らざれども、夜々｜綢繆の思ひ絶えざる彷彿一味の調は、やがて絶海の孤島に謫死したる大英雄を歌ふの壮調となり五丈原頭凄惨の秋を奏でゝは人をして啾々の鬼哭に泣かしめ、時に鏗爾たる暮天の鐘に和して、劫風ともにたえざる深沈の声を作し。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "都ホテルや京都ホテルで嗅いだ男のポマードの匂いよりも、野暮天で糞真面目ゆえ「お寺さん」で通っている醜男の寺田に作ってやる味噌汁の匂いの方が、貧しかった実家の破れ障子をふと想い出させるような沁々した幼心のなつかしさだと、一代も一皮｜剥げば古い女だった。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "都ホテルや京都ホテルで嗅いだ男のポマードの匂いよりも、野暮天で糞真面目ゆえ「お寺さん」で通っている醜男の寺田に作ってやる味噌汁の匂いの方が、貧しかった実家の破れ障子をふと想い出させるような沁々した幼心のなつかしさだと、一代も一皮剥げば古い女だった。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ隅田川のほとりじゃ、てめえがこさえた寄席に客が来なくて左前になったのを、弟子の不勉強のせいにして血相変えて怒ってみせる情ねえ野暮天がのさばってるもの。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、抜けッ、抜かぬかッ」　可哀そうに若衆は、垣間見ただけでも身の内が、ぼッと熱くなる程な容色を持っているというのに、こういう野暮天な人斬り亡者共にかかっては、折角稀れな美貌も一向役に立たぬとみえて、口汚なく罵しられるのをじっと忍びながら、ひたすらに詫びるのでした。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、抜けッ、抜かぬかッ」　可哀そうに若衆は、垣間見ただけでも身の内が、ぼッと熱くなる程な容色を持っているというのに、こういう野暮天な人斬り亡者共にかかっては、折角稀れな美貌も一向役に立たぬとみえて、口汚なく罵しられるのをじっと忍びながら、ひたすらに詑びるのでした。",
              "citation": {
                "source": "旗本退屈男",
                "author": "第一話　旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その銀座が夜になると、来るわ来るわ、東京市に居る人で銀座散歩を知らぬ人は余程の野暮天と笑われる位である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての点に於て、田舎者や無教育なもの、又は無趣味なものと思われまい、そこいらの野暮天と一所に見られまいという注意が、極めてこまかく払ってある。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほどわれらも野暮天ではござらぬ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴嬢の情夫にしちゃア些と野暮天すぎるネ」「本田」　昇は飲かけた「コップ」を下に置いて、「何でゲス」「人を侮辱して置きながら、咎められたと云ッて遁辞を設けて逃るような破廉耻的の人間と舌戦は無益と認める。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "心配するだけ野暮天、素人。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親爺相伝の、野暮天野郎だ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九一八、三、使命所載）夕暮夕暮天上は騷ぎだ。",
              "citation": {
                "source": "自分は見た",
                "author": "千家元麿",
                "note": "青空文庫"
              }
            },
            {
              "text": "有難い事には野暮天ではなかった。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕陽消えて暮天暗し。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがなあ、安、てめえの情婦のお蔦も、おれみてえな野暮天にかかっちゃあ災難よなあ。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "）熱帯圏中路、火輪蹴浪趨、暮天雲断処、夕日赤於朱。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間は山影を見ざりしも、暮天陸端を認む。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮天ことに穏やかにして、波滑らかなること油のごとし。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い実のついている梅　かさだけ時代もので、胴がよせもののとうろう、　つつじ　杉、しゃぼてんの鉢　　　　　　　　　　――○――　かた木の庭木　大名竹　槇　周防の花　下ぬりのまま五六年たった壁。",
              "citation": {
                "source": "Sketches for details Shima",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫂の形のしやぼてんの真赤な花に目をやれば、来る日で無いと知りながら来る日のやうに待つ心。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この画は、御承知の通り、「しゃぼてん」を書いたものです、「しゃぼてん」は、あの青黒い、とげのある醜い形をして居りますが、その頂上に開く小さな花は、血のような、真赤な色をしています。",
              "citation": {
                "source": "仙人掌の花",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らがそれほど飢餓に悩まないのは、オプンチアすなわちさぼてんの実が熟する季節だけである。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
