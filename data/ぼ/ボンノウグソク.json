    "definitions": [
      {
        "index": 1,
        "gloss": "possessing worldly desires and passions",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
