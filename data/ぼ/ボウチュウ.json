  {
    "uuid": "85abe5f1-1d3c-5d41-b818-6366a36b0d3f",
    "entry": "傍注",
    "reading": {
      "primary": "ぼうちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "marginal notes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "反歌春の夜と滴りあまる豊造酒は朱塗の樽に添ひて流れつ習字太竹の青き筒、つやつやし筒に、たぷたぷと素水入れ、硯の水｜清けし、墨磨れと、傍注ぎ、注ぎてまはりぬ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "――またその本のグルントウンドグッツェルの下注と共に、ストゥッフンドプッフの自筆の傍注をも参考にせられよ。",
              "citation": {
                "source": "鐘塔の悪魔",
                "author": "THE DIVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳田氏かつて越前のある神官の家の系図に、十数代の間婦女より婦女に相続の朱線引き夫の名は各女の右に傍注しあったという（『郷土研究』一の十）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍注の助けによって、あるいはパリスの林檎が、あるいはオランダの旅宿が、あるいは白馬の臀が、認められるのだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
