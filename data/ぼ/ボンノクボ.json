[
  {
    "uuid": "feaaa7f7-abbe-5012-9b69-473c252ac121",
    "entry": "盆の窪",
    "reading": {
      "primary": "ぼんのくぼ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
