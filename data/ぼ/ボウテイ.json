    "definitions": [
      {
        "index": 1,
        "gloss": "one's deceased younger brother",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "愛宕山林をながめて亡弟追憶の涙をしぼつた。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖母様と、モウ七歳になっていた私を連れて二日市に移住し、漢学の塾を開かれた一方に、母は亡弟｜峻を抱いて市内柳原に住み、相変らず足袋の底と、軍隊の襯衣に親しんだ。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "市長の一家は歡びて我を迎へ、主人の妹なるロオザ夫人は、亡弟の記念と拿破里の繁華とを語りて、我に再遊の願の甚だ切なるを告げ、主人の姪なるマリアは我をして復たララの姿を見、フラミニアの才を見る心地せしめき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡弟二郎の祥月命日（私の推定日）、読経焼香して彼の冥福を祈つた、彼はまことに不幸な正直な人間であつたが。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡弟二郎を想ふ、彼は正直すぎて、そしてあまりに多感だつた、彼の最後は彼の宿命だつた、あゝ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡弟二郎の祥月命日（推定）、甘い物を供へて回向する、あゝ彼は愚直すぎた！",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "明け方になつて、やつと、とろ／＼したら妙な夢を見た、亡弟新婚を訪ねたことなど。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "我欲刻亡弟信卿遺稿。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」十九日には亡弟｜彦の法要を営んだ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの亡弟篤次郎の外舅に長谷文さんと云ふ人がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし最後には亡弟の無二の親友バルベイ・ドオルヴィリに宛てて書くやうになつたが、一八四〇年の冬メエトル夫人の病氣を見舞ふために再度ヌヴェルの旅に出、その旅のなかば、十二月の最後の日に遂に日記の筆は投ぜられた。",
              "citation": {
                "source": "モオリス・ド・ゲランと姉ユウジェニイ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、其の性質上記の如きところより、之を発表せんとするに当りては、亡弟も可なり慎重な態度を採り。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは兎に角として、また内容価値の如何も之を別として、亡弟が心を籠めて遣せる一産物たるには相違ないのである。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨秋弟が死んだ後、僕は久しぶりでハムレットの行衛を、亡弟の妻に訊ねて見た。",
              "citation": {
                "source": "汝自身を知れ",
                "author": "ベルンにて",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、亡弟が残して行った一つのなぞとして、そっとそのままにしておくべき事柄だったかも知れません。",
              "citation": {
                "source": "日記帳",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、第三金時丸は、その島々を眺めながらよろぼうていた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
