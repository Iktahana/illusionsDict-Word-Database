          "literary": [
            {
              "text": "子供等の亡祖父の若かった頃の昔話もしばしば出る。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今になつて、亡母や亡祖父の心をはつきりと自分の心に蘇らせて来る。",
              "citation": {
                "source": "心の絵",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして初めて亡母や亡祖父のその時分の心の苦しみを知ることが出来たやうな気がした。",
              "citation": {
                "source": "心の絵",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は少し長逗留なので、私はこれ迄一向注意を払わなかった亡祖父の蔵書を見る気になった。",
              "citation": {
                "source": "蠹魚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "太々餅　芝神明の太々餅のラヂウム温泉が設けられて、はる／″＼下町から私は亡祖父と大叔母とに連れられて半日の湯治に来たことがある。",
              "citation": {
                "source": "山の手歳事記",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
