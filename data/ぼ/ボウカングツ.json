        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "氷に滑べらないように、靴の裏にラシャをはりつけた防寒靴をはき、毛皮の帽子と外套をつけて、彼等は野外へ出て行った。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "防寒靴は雪の中へずりこみ、歩くたびに畚のようにがく／＼動いた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "演説を傍聴さしてもらうぞ」　支那人、朝鮮人たち、労働者が、サヴエート同盟の土を踏むことをなつかしがりながら、大きな露西亜式の防寒靴をはいて街の倶楽部へ押しかけて行った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "松木は、防寒靴をはき、ズボンのポケットに両手を突きこんで、炊事場の入口に立っていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪に落ちこむ大きな防寒靴が、如何にも重く、邪魔物のように感じられた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　イワンは、口の中で、何かぶつぶつ呟きながら、防寒靴をはき、破れ汚れた毛皮の外套をつけた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟は疲れて、防寒靴を雪に喰い取られないばかりに足を引きずっていた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば外套、防寒靴、布地等をそういう組織で配給している。",
              "citation": {
                "source": "露西亜の実生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬だと、誰でも靴の上にもう一つ重ねてフェルトの厚ぼったい防寒靴をはいて外を歩くのだが、ところによると映画館でもそれを脱がなければならないところがある。",
              "citation": {
                "source": "映画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所のその映画館は小さくて、きたないかわり、防寒靴をはいたままでよかった。",
              "citation": {
                "source": "映画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は仔熊のような防寒靴をはいたまま、外套も着たまま腰かけてそれを聴いていて、好意を感じた。",
              "citation": {
                "source": "映画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当は新しい防寒靴をもうとっくに買わなければならない筈なんだ。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "“905”日本女の受けとった外套防寒靴預番号の真鍮札。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "防寒靴の足の先だけが此処から見える。",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "防寒靴はだいぶ古で、歩くとパクつくが、何！",
              "citation": {
                "source": "ワーニカとターニャ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　ワーニカは、わいわい云いながら入口で防寒靴をぬいでる一かたまりの男女学生の中に、見なれた円い緑色の毛糸帽を見つけた。",
              "citation": {
                "source": "ワーニカとターニャ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニーナは、寝室の下から長い防寒靴を出してはき、頭を暖かい毛のショールできっちりくるむと、雪の凍っている往来へでた。",
              "citation": {
                "source": "ソヴェト同盟の三月八日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊り達者で名うてのオリガが、重い防寒靴をはいているとは信じられない身軽さで、つと輪の真中にでた。",
              "citation": {
                "source": "ソヴェト同盟の三月八日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外套の下に上靴と防寒靴が三足かためてあった。",
              "citation": {
                "source": "無題（七）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年も妾の妹があちらから子供の防寒靴を持って来ましたがね、品が丈夫なもんで、いまだに履いていますだよ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "真新の防寒靴八足も見つけられた噂があった。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論陸軍からの払下げの兎の毛皮の防寒服に防寒帽、フェルトの防寒靴など、身拵えはしているのであるが、一時間以上もはいっていると、膝のあたりから少し痛くなって来る。",
              "citation": {
                "source": "映画を作る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもこの室へ入る者は、毛皮の防寒服、防寒頭巾、防寒靴及び手袋を着用しなくてはならないことは勿論である。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "防寒靴を下足にあずける間も伸子は深い興味をもってこの二十世紀初頭の新様式（ヌーボー）で建てられている建物を見まわした。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人群れにまじって伸子たちも防寒靴をあずけた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだね」　肉を入れて来た樺製のカバンを足許において、その売手は、膝まである防寒靴を雪の上でふみかえながらせきたてた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は、防寒靴の底にキシキシと軋んで雪の鳴る道を、足早に追いこしてゆくどっさりの通行人の間にまじりながら、小さい黒外套の姿で歩いて行った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗客たちの防寒靴の底についた雪が次々とその上に踏みかためられて、滑りやすい氷のステップのようになっているバスの降口から、伸子は気をつけて雪の深い停留場に降り立った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "通行人の男の短い髭もパリッと白くなっているし、厚外套の襟を高くして防寒靴を運んでいる女の頬にかかる髪の毛も、金髪や栗毛の房をほそい氷の糸で真白くつつまれている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでは防寒靴のままはいれた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
