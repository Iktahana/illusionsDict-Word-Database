          "literary": [
            {
              "text": "亡妹に似ていると云うのがますますこの感じを深くしたのであろう。",
              "citation": {
                "source": "雪ちゃん",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹の机には青い机掛けが掛つて、その上には木彫の奈良人形と、亡妹の寫眞を插んだ寫眞立があつた。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹の机には青い机掛けが掛って、その上には木彫の奈良人形と、亡妹の写真を挿んだ写真立があった。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡父、亡妹、孤独になって生きている自分。",
              "citation": {
                "source": "八寒道中",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは、心霊研究にうき身をやつしていると聞く長田幹彦の家ではその亡妹が家族の一員としてその家に住んでいていつも廊下などで人々とすれ違ったりするのを何人も怪しまなくなっていると彼の書いているのを読んだことを思い出した。",
              "citation": {
                "source": "幽香嬰女伝",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
