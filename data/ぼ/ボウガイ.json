[
  {
    "uuid": "92154410-7ed9-5dd5-83d8-9ff0e1c15aa1",
    "entry": "妨害",
    "reading": {
      "primary": "ぼうがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
