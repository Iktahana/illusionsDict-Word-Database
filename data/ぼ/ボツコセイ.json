          "literary": [
            {
              "text": "寧ろこちらから云へば、都の人が没個性的であるのでもあるのです。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年の没個性、自己喪失は、いまの世紀の特徴と見受けられます。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "処がこの個々の事象は、たといリッケルトの云うような文化価値への直接な関係づけが一応無意味であったにしても、そうだからと云って決して全く没個性的なものではない。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
