    "definitions": [
      {
        "index": 1,
        "gloss": "the Bon Festival and New Year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
