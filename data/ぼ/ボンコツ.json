        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "木版の刻は伊上凡骨氏を煩はした。",
              "citation": {
                "source": "『心』自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "多少、凡骨に化する必要が在る。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊上凡骨の処で木板を習つてゐるルンプといふ独逸人を神田の安田旅館に尋ね、それを一緒につれて行つた。",
              "citation": {
                "source": "パンの会の回想",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木版は孰れも伊上凡骨が其弟子を督して彫刻する所であつた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲエテの門番の孫で、伊上凡骨の弟子の猿づらの彫刻家｜独逸人のフリッツ・ル※プも若かった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たい頭腦で遠慮無く散々貶して貰ひませう、とても癒らぬ官僚主義で、つるつる禿げた凡骨を。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡骨空菴の守りとなりて、これより幾千年の春のあはれを見んといはゞ、一代の宗匠かくこそあるべけれと誰しも思ふべきに、けしからぬは路雪なり。",
              "citation": {
                "source": "山家ものがたり",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彫刻師凡骨などのお伴をした時は、その度によくからかはれたもので蜀山流の狂歌が口を突いて出た、それを皆で笑つたものだ。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "彫刻師凡骨をかし湯の宿に人をまねびて転寝ぞする　日本木版の技術を洋画に応用することは寛先生の考案であり、凡骨がそれを実行したのである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "恩義に感じた凡骨は死ぬまで與謝野家に出入して変らなかつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "その凡骨は元来職人ではあるし少し変つた所もあり可哀らしい所もあつたので、夫人はこれを愛してよく冗談を云つたりからかつたりしたものである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡骨に一寸人並みでない所があるので、人並みに昼寝をするのがをかしいのである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "平たく言へば凡骨だ。",
              "citation": {
                "source": "愛人と厭人",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "×凡骨さんの大事がる薄い細身の鉄の鑿。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "から騒ぎ騒ぐ野次馬、安価なる信仰家、単純なる心の尊敬すべき凡骨、神経の鋭敏と官能のデリカシイとに鼻｜蠢かす歯の浮くような文芸家はいるが、人生に対する透徹なる批判と、纏綿たる執着と、真摯なる態度とを持して真剣に人生の愛着者たらんと欲する人は無い。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の會合もその勢に押された擧句こゝに持出されたが、依然として無名の會であつたことが不滿足に思はれて、皆で相談の結果「凡骨會」として一會を催したことがある。",
              "citation": {
                "source": "龍土會の記",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたまそんな事柄があつたために大略分ることではあるが、凡骨會がいよいよ龍土會と改まつて一段と生長したのは翌三十八年の新春であつたらう。",
              "citation": {
                "source": "龍土會の記",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "展覧会の写真を拝見して、とうてい私のような凡骨の見るべきものではないと切に自戒していたからである。",
              "citation": {
                "source": "安吾巷談",
                "author": "教祖展覧会",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡骨はツマランことを考えるよ。",
              "citation": {
                "source": "安吾巷談",
                "author": "教祖展覧会",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡骨の思慮のとどかぬ奇ッ怪事が、まま起るものでござります。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二　密室大犯罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "生田葵山氏の若い時の話、永井先生の「矢筈草」の発端、フリツルンプや凡骨や都川という木下杢太郎氏の詩へ出てくる鳥屋の話など、ことに心を惹かれました。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見ると詩人は常の人よりも苦労性で、凡骨の倍以上に神経が鋭敏なのかも知れん。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔つ払ひの筆頭は伊上凡骨君であつた。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝霞の兄弟も泰文の弟の権僧正光覚も、いずれも融通のきかない凡骨ぞろいで、事件のおさまりをあきたらなく思っていた。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "井上剣花坊、近藤京魚、伊上凡骨、川上三太郎氏らと相知る。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに故人となつたが、伊上凡骨といふ木版彫刻家である。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寫樂がよく描くあの特異な鼻、顎の線、頬の幅、顏總體の大まかさなど、およそ寫樂によつて誇張されたものが、この凡骨の顏にはあつた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、伊上凡骨、と東洲齋寫樂とは、同郷人であり、仕事も、版と繪といふ唇齒の關係をもつてゐる。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寫樂と共に、郷土の藝術家として、伊上凡骨の事蹟を殘しておきたいが、といふ問合せが、徳島縣からあつたが、その後、どうなつたか、結果を聞いてゐない。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
