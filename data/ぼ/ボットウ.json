    },
    "definitions": [
      {
        "index": 1,
        "gloss": "immersing oneself in",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それだから一見閑静な田舎に住まっていては、とても一生懸命な自分の仕事に没頭しているわけにはいかない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに石楠花にとろけている生物が二個ある、一個は私である、一個は石楠花の花の中に没頭して、毛もくじゃらの黄色い毛だらけの尻を、倒しまに持ちあげ、蜜を吸い取っているアブである。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう云ふ風な考へ事に没頭してゐれば、具体的な、現実的な生活からも、生活手段からも離れて行くことは自明の理であつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に人に使われて働いていた時分は、生活の心配を離れて、専心に工夫に没頭したら、さぞ快いだろうという、その憧憬から日々の雑役も忍べていたのだがその通りに朝夕を送れることになってみると、単調で苦渋なものだった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら何度やっても同じことなのだ」　仕事であれ、男女の間柄であれ、混り気のない没頭した一途な姿を見たいと思う。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてそんなことで、主人も私も東海道のことはすっかり忘れ果て、二人ともめいめいの用向きに没頭して、名古屋での仕事もほぼ片付いた晩に私たちはホテルの部屋で番茶を取り寄せながら雑談していた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は将棋を試みた事もあり、また筆者などと一緒に昔の本郷座で川上、高田一座の芝居を見たこともありはしたが、中年以後から、あらゆる娯楽道楽を放棄して専心ただ学問にのみ没頭した。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前中は大抵キャビンに籠ってこの仕事に没頭していた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は蝋燭の光の下で落着いて仕事に没頭する気にはなれないように思う。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学者自身が、もしもかなりな資産家であって、そうして自分で思うままの設備を具えた個人研究所を建てて、その中で純粋な自然科学的研究に没頭するという場合は、おそらく比較的に一番広い自由を享有し得るであろう。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "好きな研究に没頭する時間を拾い出すのはなかなか容易でないのである。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそのおかげで学者は心静かに落着いて各自の研究に没頭していられるのかもしれない。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し心とからだの安息を与えて、思いのままに彼の欲する仕事に没頭させた方が、かえって本当にこの稀有な偉人を尊重する所以でもあり、同時に世界人類の真の利益を図る所以にもなりはしまいか。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何か興味のある仕事に没頭することが出来れば暑さを忘れてしまうことは容易である。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方面の研究に没頭せる気象学者にとっては、この一節は尽きざる示唆の泉を与えるであろう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし世界の広い学界の中にはまれに変わり種の人間もいて、流行の問題などには目もくれず、自分の思うままに裸の自然に対面して真なるものの探究に没頭する人もあるから、いつの日にかこれらの物理学圏外の物理現象が一躍して中央壇上に幅をきかすことがないとも限らないであろう。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分なども時々だいじな会議の日を忘れて遊びに出たり、受け持ちの講義の時間を忘れてすきな仕事に没頭していたり、だいじな知人の婚礼の宴会を忘れていて電話で呼び出されたりして、大いに恥じ入ることがあるが、しかたがないからなるべく平気なような顔をしている。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその先生の平生の勉強ぶりから推して考えてみると、映画の享楽の影響から自然学問以外の人間的なことに興味を引かれるようになり、肝心の学問の研究に没頭するに必要な緊張状態が弛緩すると困るということを、こういう独特な言葉で言い現わしたのではないかと思われる。",
              "citation": {
                "source": "映画と生理",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも半日研究室で仕事に没頭したあとで鏡の中に現われる自分の顔に比べるとまるで別人かと思われるように顔の色もつやもよく、顔全体の表情が明るく若やいで見えるのである。",
              "citation": {
                "source": "映画と生理",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨万の財産を死蔵して、珍書画の蒐集に没頭していた故伯爵が四五年前に肺病で死ぬと間もなく未亡人は、旧邸宅の大部分を取毀して貸家を建てて、元銀行員の差配を置いた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙の出ないのが当然の事のように思い込んでしまって煙突とは全然無関係としか思えない、ほかのネタを探ることばかりに没頭していた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私の知れる範囲内では、蓄音機レコードの製造工場へ聘せられて専心その改良に没頭している理学士は一人もないようである。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう刺激の目にふれないという事は、仕事に没頭している多くの人のためにはむしろ有利なくらいである。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一事に没頭しきらなければすまない。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んのこだわりもなく研究に没頭しきっているような後姿を見送りながら、園は何んとなく恥を覚えた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "知っていながら哲学や芸術に没頭しているとすれば、彼らは現代から取り残された、過去に属する無能者である。",
              "citation": {
                "source": "宣言一つ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう慾を起すものは莫迦か気狂いだ、こう思う骨折りさえ頭脳に課さないで塀に書かれた変った楽書を見過すような気持で、さっさと自分々々の眼の前の仕事に没頭してしまう。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に人に使われて働いていた時分は、生活の心配を離れて、専心に工夫に没頭したら、さぞ快いだろうという、その憧憬から日々の雑役も忍べていたのだが、その通りに朝夕を送れることになってみると、単調で苦渋なものだった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら何度やっても同じことなのだ」　仕事であれ、男女の間柄であれ、湿り気のない没頭した一途な姿を見たいと思う。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一義の問題をそのままにして置いて第二義第三義の問題に没頭するとき、俳壇は堕落するばかりである。",
              "citation": {
                "source": "最近の感想",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
