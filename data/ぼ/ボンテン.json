[
  {
    "uuid": "eaa4df4d-8fec-504a-9433-80a683f9586b",
    "entry": "梵天",
    "reading": {
      "primary": "ぼんてん",
      "alternatives": [
        "ぼんでん"
      ],
      "is_heteronym": false
    },
    "grammar": {
