      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Brahma (Hindu creator god)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども娘は、梵天王と自分の花婿のことしか考えていませんでした。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "梵天丸の幼立からして、聞怯じ、見崩れをするようなケチな男では無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "片倉小十郎景綱というのは不幸にして奥州に生れたからこそ陪臣で終ったれ、京畿に生れたらば五十万石七十万石の大名には屹度成って居たに疑無い立派な人物だが、其｜烱眼は早くも梵天丸の其様子を衆人の批難するのを排して、イヤイヤ、末頼もしい和子様である、と云ったという。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから政宗は満海の生れ代りであろうと想われ、そして梵天丸という幼名はこれに因りて与えられた。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "梵天は此世の統治者で、二生の人たる嬰児の将来は、其の前生の唱名不退の大功徳によって梵天の如くにあるべしという意からの事だ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "満海の生れ代りということを保証するのは御免｜蒙りたいが、梵天丸という幼名だったことは虚誕では無く、又其名が梵天｜帝釈に擬した祝福の意であったろう事も想察される。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はあれ梵天丸で育ち、梵天丸で育てられ、片倉小十郎の如き傑物に属望されて人となった政宗は立派な一大怪物だ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば、梵土には表面梵天を祀る堂なし。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "また梯子を上りて五色の滝、大梵天、千手観音などいうを見る。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは仏経に多頭竜王と訳したもので、梵天の孫｜迦葉波の子という。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "古伝にアハリアは梵天創世最初に造った女で瞿曇仙人の妻たり。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "人民老ゆれば自然に樹下に往き、念仏して静かに往生し、大梵天や諸仏の前に生まる。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼、宮に入れば、仏、また還り、入る事三度して四度目に仏出でず、鬼神怒って出でずんば汝の脚を捉え、恒河裏に擲げ込むべしというに、仏いわく、梵天様でも天魔でも我を擲つ力はないと。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "クベラすなわち毘沙門で、ヒンズー教の説に梵天王の子プラスチアの子たり、父を見棄て梵天王に帰した。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "梵天王これを賞して不死を与え福神とした。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿を出でゝ再たび三月堂に上れば、梵天帝釋の温雅整肅にまします、裏手なる執金剛神の怒氣すさまじき、共に寧樂美術の粹とこそ聞け、乾漆の四天王、本尊は不空羂索の觀世音、共に天平のものなりとぞ、建築も當時のまゝなるは、東大寺境内にて正倉院を舍きては、この堂に留めたり。",
              "citation": {
                "source": "寧樂",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは梵天、帝釈、弁天、吉祥天等。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫刻修行のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "突如、梵天の大光明が、七彩嚇灼の耀を以て、世界開發の曙の如く、人天三界を照破した。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "突如、梵天の大光明が、七彩｜赫灼の耀を以て、世界｜開発の曙の如く、人天三界を照破した。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は五条｜西洞院辺にゐる仏ぢやが、つね／″＼評判のお前様の読経を聴きたい／＼と思つてゐたが、平素は梵天帝釈などのお入来があるので遠慮してゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは外でもない、あの堂に安置してある等身大の梵天の立像に手を入れる時、台座を外してみると、その箝め合せの所に、男子の局部が二つ描いてあつたといふ事だ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四　水晶のお土産ある日、父さんは人に連れられて梵天山といふ方へ行きました。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い躑躅の花なぞの咲いて居る山路を通りまして、その梵天山へ行つて見ますと、そこは水晶の出る山でした。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "之に懲りて爾後曾國藩一族の子弟は、皆拘謹身を持したといふ（民國の柴萼『梵天廬叢録』卷四、曾文正公二十六則の條）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "民國の柴蕚の『梵天盧叢録』（卷十七）の剥皮十二則の項に、左の如き記事がある。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "即、一つはそほどと、他の一つはぼんてんと関係があるのでは無いか、といふことである。",
              "citation": {
                "source": "稲むらの蔭にて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々上方育ちの者には、梵天と謂へば直ちに芝居の櫓などに立てた、床屋の耳掃除に似た頭の円く切り揃へられた物を聯想するが、関東・北国等の羽黒信仰の盛んな地方では必しも然らず、ぼんてん即幣束の意に解して居り、其形状も愈削り掛け又はいなうの進化したものゝ様に見えて参る。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐渡平、ではやがて近いうちに、貴様の弟忠三郎の仇もとってやるぞ」　たちまち、前垂れをはずし、縞の着物をかなぐり捨てると、そこにあった、ぼんてん帯に、仲間法被、真鍮こじりをうしろに差し込んで、「一走り、行って来る」　と、小箱をふところに、裏口から飛び出した。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
