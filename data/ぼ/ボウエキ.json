    "definitions": [
      {
        "index": 1,
        "gloss": "(foreign) trade",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一八七三年にレーリーが家督を相続した頃は農業も相当有利であったが、一八七四年に外国貿易の頓挫した影響から、引いて農民の窮迫を来し、従って地主の財政も極めて不利になった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の貿易商人みたいな洋服姿で、佐藤惣之助が先頭にやつてきた。",
              "citation": {
                "source": "大船驛で",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「十年前に父が密貿易をやって居りました。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "左衛門が「其処でじゃ」Ｔ「十年前に身共もその密貿易の一味に加って居た」　なる程と七兵衛。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は父の経営している、北浜にある貿易商会を出て、心斎橋から戎橋筋を道頓堀に向ってあるいていた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "保護貿易主義は、労働の発達の中へ暴力を導引き入れるものであり致命的な軍国主義の狂態を齎らすものなのだ。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西は入江の口、水狹くして深く、陸迫りて高く、此處を港に錨を下ろす船は數こそ少いが形は大きく大概は西洋形の帆前船で、出積荷は此濱で出來る食鹽、其外土地の者で朝鮮貿易に從事する者の持船も少なからず、内海を往來する和船もあり。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "西は入り江の口、水狭くして深く、陸迫りて高く、ここを港にいかりをおろす船は数こそ少ないが形は大きく大概は西洋形の帆前船で、その積み荷はこの浜でできる食塩、そのほか土地の者で朝鮮貿易に従事する者の持ち船も少なからず、内海を行き来する和船もあり。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この土地の船乗りの中には二、三百トンくらいの帆船に雑貨を積んで南洋へ貿易に出掛けるのが沢山いるという話であった。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室子の父はこれに代る道を海外貿易に求めた。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『私が此港へ貿易商會を設立た翌々年の夏、鳥渡日本へ皈りました。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふに此潮流はラツカデヴ群島の方面から、印度大陸の西岸を船に見出されるとか、何國かの貿易港へ漂着するとか、兎角して救助を得られぬ事もあるまいと考へたのである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この祖父は、壮年の頃は横浜で、かなりの貿易商を営んでいたのである。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "商業商業は旗のやうなものである貿易の海をこえて遠く外國からくる船舶よあるいは綿や瑪瑙をのせ南洋　亞細亞の島島をめぐりあるく異國のまどろすよ。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、良寛さんが、乗せていつてくれと頼んだ、清の貿易船であつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三階は後で判ったことだがこの雑貨貿易商である娘の店の若い店員たちの寝泊りにあててあり、二階の二室と地階の奥の一つ、これも貸部屋では無かった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその鉢や竜眼肉を見てふと気付いて、「お店は南洋の方の貿易関係でもなすっていらっしゃるのですか」と訊いた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、店のものの一人に、強情に貿易のことを主張する男がいる。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その船貿易を主張する店のもののことに就いて、なおこう云って私の意見を訊いた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "シンガポール邦字雑誌社の社長で、南洋貿易の調査所を主宰している中老人が、白の詰襟服にヘルメットを冠って迎えに来て呉れた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、「飛魚」とか「貿易風」とかいう題の種類のもので、いくらか詩風は時代向きになったかと感じられる程度のことが、却って詩形をきごちなくしていた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処は当時｜明や朝鮮や南海との公然または秘密の交通貿易の要衝で大富有の地であった泉州堺の、町外れというのでは無いが物静かなところである。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の外国貿易に従事する者は、もとより市中の富有者でもあり、智識も手腕も有り、従って勢力も有り、又多少の武力――と云ってはおかしいが、子分子方、下人｜僮僕の手兵ようの者も有って、勢力を実現し得るのであった。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "夙に外国貿易に従事した堺の小島太郎左衛門、湯川｜宣阿、小島三郎左衛門等は納屋衆の祖先となったのか知れぬ。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その商事会社は元来、地所持ちの旧舗が店の形を改めたもので、貿易は片手間に過ぎないけれども当主は道楽半分なか／＼熱心でありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに関係する運漕店や貿易会社の事務所が町家の中に混っています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "海外貿易もその一つである。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "事業はみな切捨てさして、海外貿易だけは残した。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "海外貿易の商法の顧問としてわたくしの父が頼まれました訳です。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女たちには高麗丸が大貿易港神戸の一部であり、神戸はまた高麗丸の延長であるかのごとく思えたに相違なかった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
