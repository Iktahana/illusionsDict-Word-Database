    "definitions": [
      {
        "index": 1,
        "gloss": "name of the writer of a gravestone epitaph, engraved after the epitaph",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "舞踊場で未来の墓誌銘に現代の道徳を刻んだ同志と、レムブルグ美容院の舞踊場の楽隊の奏でる哀悼歌に合唱して、米良は柩車のように螺旋をえがいて踊りながら、彼は絶えず東支那海の電信夫がもたらす秘密結社の女シイ・ファン・ユウの恋の便りを受取った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の運命の墓誌銘をつくるために妾は女だてらに気が狂うほど急がしいのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の運命の墓誌銘をつくるためには妾は女だてらに気が狂うほど急がしいのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "金貨遊戯室の、立縞の短いスカートの女が毛皮の襟に顔をうずめて、夜会バッグにしまった三角形の××を彼女の墓誌銘にして、梅田方面に立ち去った。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓誌銘は友人｜海保漁村が撰んだ。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ往けば漁村の撰んだ墓誌銘の全文が見られるわけである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「抽斎渋江君｜墓碣銘」という篆額も墓誌銘も、皆｜小島成斎の書である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜むらくは富士川さんは墓誌銘の全文を写して置かなかった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして游さんは湮滅の期に薄っていた墓誌銘の幾句を、図らずも救抜してくれたのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒は平洲の墓誌銘を目睹して、士幹と書してゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "手帳は富士川游さんが嶺松寺の墓誌銘に就いて抄録したものである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは池田宗家の諸墓が全く痕跡なきに至らなかつたのを喜ぶと同時に、其墓誌銘の佚亡を惜んで已まぬのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「嶺松寺及池田氏墓誌銘は江戸黄蘗禅刹記巻第五に記載有之候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "朗廬の墓誌銘には「称淵蔵、中称和介、後称文兵衛」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは永田嘉一さんの手に藉つて秋山の墓誌銘を獲た。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "己はゆうべ寝られぬから墓誌銘を自撰した。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は京都へ往つてそれを受け取つて、彦根にゐる兄｜下総の邸へ往つて大林｜権之進と云ふものに逢つて、詩文稿に墓誌銘を添へてわたしてくれ給へ。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂叢の墓誌銘は齋藤拙堂が撰んだ。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが徐氏の墓誌銘です。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は心中ひそかに、おじさんのために、こんな墓誌銘をさえ考案しているのだが。",
              "citation": {
                "source": "おじさんの話",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がおじさんのために墓誌銘を考案したのは、この散策の最中に於いてである。",
              "citation": {
                "source": "おじさんの話",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が頭の中でどうやら墓誌銘を仕上げたとき、風に送られてまた琴の音がきこえてきた。",
              "citation": {
                "source": "おじさんの話",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
