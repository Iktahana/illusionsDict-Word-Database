        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "上のボートデッキでボーイと女船員が舞踊をやっていた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜ひとりボートデッキへ上がって見たら上弦の月が赤く天心にかかって砂漠のながめは夢のようであった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボートデッキは、船中で一番高い部分であって、それは士官室の屋根と天井とを兼ねていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "この少し前から、ボートデッキで、サンパンの下にもぐり込んで仕事していた、水夫の波田芳夫というのも、今小倉が見つけたのを見つけて、一人でサンパンの下からながめていたのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、全員はボートデッキへスタンバイした。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボートデッキに二人、各のロープについた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボートデッキで綱の操作をしている二人の水夫も、伝馬の中にあって、しっかり、鉤のはずれないように握った、波田も字義どおりに「一生懸命」であった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
