    "definitions": [
      {
        "index": 1,
        "gloss": "(bound) book",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さて官事の暇あるごとに、かねておおやけの許しをば得たりければ、ところの大学に入りて政治学を修めんと、名を簿冊に記させつ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて官事の暇あるごとに、かねておほやけの許をば得たりければ、ところの大学に入りて政治学を修めむと、名を簿冊に記させつ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "榛軒が簿冊を河に沈めさせたのは、恐くは諫草を焚く意に外ならなかつたであらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三万五千五百八十四号ヲ以テ勲等簿冊ニ記入ス」　書院の袋戸棚　四枚の芭蕉布にぼんやり雪舟まがいの山水を書いたもの、ふたところ三ところ小菊模様の更紗でついであって、いずれも三水がくすぶっている。",
              "citation": {
                "source": "Sketches for details Shima",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、劉表にすすめて、戸簿を整理し、遊民を簿冊に入れて、非常の際は、すぐ兵籍に加え得るようにしなければいけません」といった。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……爺の左近は正成が見終った沢山な簿冊を両手にかかえてひとまずそこをさがってきた。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兵全員の軍簿が調べあがりましたが」　と、安間了現が、簿冊を手に、入って来た。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここのうちの美術室には国宝のぼさつ像がある。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "国宝のぼさつ像です。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
