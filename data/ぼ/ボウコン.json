    "definitions": [
      {
        "index": 1,
        "gloss": "departed soul",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "精霊棚を設けて亡魂を迎える人はやはり今でもあるのである。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは『過去』の亡魂である、それでもいい足りない。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、嘘か眞か、本所の、あの被服廠では、つむじ風の火の裡に、荷車を曳いた馬が、車ながら炎となつて、空をきり／＼と※つたと聞けば、あゝ、その馬の幽靈が、車の亡魂とともに、フト迷つて顯はれたかと、見るにもの凄いまで、この騷ぎに持ち出した、軒々の提灯の影に映つたのであつた。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四谷左門町に住んでいた田宮伊右衛門という侍がその妻のお岩を虐待して死に至らしめ、その亡魂が祟りをなして田宮の家は遂にほろびたというのが、先ず普通一般に信じられている伝説である。",
              "citation": {
                "source": "四谷怪談異説",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "暦の亡魂薄暮のさびしい部屋の中でわたしのあうむ時計はこはれてしまつた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして芥燒場の泥土にぬりこめられたこのひとのやうなものは忘れた暦の亡魂だらうよ。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処に説く「象徴」という観念も、この怨めしき亡魂の一つであって、かつてずっと早くから我が国に輸入され、一時詩壇で流行したるにかかわらず、早く既に廃ってしまい、しかも今日｜尚、言語は不可解のままに残されている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあくる日の夕方、私は運動にとりかかる前に、先づきのふの墓標へお參りしたら、朝の驟雨で亡魂の文字はその近親の誰をも泣かせぬうちに跡かたもなく洗ひさらはれて、蓮華の白い葉もところどころ破れてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "当家の妾たまと申す者、家来と不義のこと露顕いたし候｜間、後の月見の夜、両人ともに成敗を加え候ところ、女の亡魂さまざまの祟りをなすに付、その黒髪をここにまつりおき候事。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の旗本屋敷などには往々こんな事があったそうだが、その亡魂が祟りをなして、ともかくも一社の神として祭られているのは少ないようだ。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡魂が祟りをなすなどは、もちろん信じられなかった。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "物怪といっても、育てた姫君に愛を残した乳母というような人、もしくはこの家を代々敵視して来た亡魂とかが弱り目につけこんでくるような、そんなのは決して今度の物怪の主たるものではないらしい。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前四月二十四日の夜、福井市内に柴田勢の亡魂の行列あり、その大将騎馬にて首がなかった（『郷土研究』二巻九号、寺門氏報）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "古エトルリアの地獄神チャルンは巨槌で亡魂どもを打ち苦しむ（デンニス著『エトルリアの都市および墓場』二巻二〇六頁）、『※余叢考』三五に鍾馗は終葵の訛りで、斉人｜椎を終葵と呼ぶ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その城址を誰も修理する者もないのみか、焼け残った本丸の百畳敷には、赤松一族の亡魂があらわれるというので、めったに近寄る者もなかった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの広書院には赤松殿の亡魂がまことに棲んでいるであろうか。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ源三｜位頼政の亡魂だといふんだからな。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『猫間川の岸に柳櫻を植ゑたくらゐでは、大鹽の亡魂は浮ばれますまい。",
              "citation": {
                "source": "死刑",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "義経なんかも、ごらう（ごりやう）に何の縁もない名だが、やつぱり死後の亡魂の恐がられる理由はあつたのである。",
              "citation": {
                "source": "芸能民習",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ああ、みんな、父御のお引き合せ、御亡魂の御念力じゃ――このわしの前で、二人が二人べらべらと、昔の悪事をしゃべり出そうとは――　彼は、ガクガクと、身ぶるいがして来るのを、一生懸命に押えながら、耳をすます。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一一　相手が兇悪な盗賊とかまたは殺人の罪人とか、そういうものを退治るなら一も二もなくお受けしようが、亡魂とあっては有難くない――これが葉之助の心持ちであった。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子としての道を歩もうとすれば、母親の臨終の妄執を未来｜永劫解くことが出来ず、浮かばれぬ母親の亡魂をいつまでも地獄へ落として置かねばならぬ」　すると葉之助は笑い出したが、「これは何をおっしゃることやらとんと私には解りませぬ。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の実の父も母も飯田の城下に健かに現在も生活しておりますものを、臨終の妄執だの亡魂だのと、埒もないことを仰せられる。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――で、亡魂が残っておられ、日置流の頽廃を嘆かせられ夜な夜な怪異を示されて勇士をお求めになられたのだ。",
              "citation": {
                "source": "日置流系図",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶人芝居といふものは、土台が本地物と言つて、神変不思議を説くところから、怪物・怨霊・悪鬼・亡魂など、人外の恐しいものが常に登場した。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "笠をかぶつたのが、山三の亡魂、歌舞妓男の姿が、おくにの扮する所である。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "九泉に堕つる涙まことこもりて、再び亡魂をや還しぬべき。",
              "citation": {
                "source": "『聊斎志異』より",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "春寒の夜を深み、加茂川の水さへ死ぬ頃を見計らつて桓武天皇の亡魂でも食ひに來る氣かも知れぬ。",
              "citation": {
                "source": "京に着ける夕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "車はかんからゝんに桓武天皇の亡魂を驚かし奉つて、しきりに馳ける。",
              "citation": {
                "source": "京に着ける夕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうすると亡魂が返るのを、迎へてまつるといふのではなく、亡者に孝養を示す為に、生前同様、目上としての待遇を、改めなかつたのであると思ふ。",
              "citation": {
                "source": "たなばたと盆祭りと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
