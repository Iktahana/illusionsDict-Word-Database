[
  {
    "uuid": "adb1ea73-7638-5da3-9771-bd1a934b597f",
    "entry": "亡魂",
    "reading": {
      "primary": "ぼうこん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
