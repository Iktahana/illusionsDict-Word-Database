    "definitions": [
      {
        "index": 1,
        "gloss": "fire prevention",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "餘程特別な防火設備が必要であらうと思はれる。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう暮れ近く草がそよぎ防火線もさびしいのだ。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも早くまはって行って沼森のやつの脚にかゝりそれからぐるっと防火線沿ひ、帰って行って麓の引湯にぐったり今夜は寝てやるぞ。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "防火線もずうっとうしろになった。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言つても、新橋の上でうす緑色の馬車がどうだとか、或はあの赤いやうな色の滲じみ出し具合がどうだとか、或はまた眞珠に近い灰色をした家々の防火壁の上に貼られてある廣告がどうだとか、と一々取り上げて言ふことは出來ない。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一つには東京市民が明治以来のいわゆる文明開化中毒のために徳川時代に多大の犠牲を払って修得した火事教育をきれいに忘れてしまって、消防の事は警察の手にさえ任せておけばそれで永久に安心であると思い込み、警察のほうでもまたそうとばかり信じ切っていたために市民の手からその防火の能力を没収してしまった。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん従来でも一部の人士の間では消防に関する研究がいろいろ行なわれており、また一方では防火に関する宣伝につとめている向きも決して少なくはないようであるが、それらの研究はまだ決して徹底的とは言い難く、宣伝の効果もはなはだ薄弱であると思われる。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その地図にある防火線とさあとからできた防火線とがどうしてわかる？",
              "citation": {
                "source": "春と修羅　第二集",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月にはいってから防火演習や防空演習などがにぎにぎしく行なわれる。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその中に集積される材料にはことごとく防火剤が施されていたもののようである。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分が憚らねばならぬような人たちから遠ざかったような心安さで、一町にあまる広々とした防火道路を見渡した。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで幾度か出征兵士の壮行会が催され、英魂が迎えられ、焼夷弾の処置が練習され、防火の訓練が行なわれた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体、この辺の横町は、大小｜旧舗の問屋筋が、表附を現代のオフィス風に建て改めたのが多く、退勤時間以後は防火扉を卸して町並は黝み渡っています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊覧客相手の贅沢品屋は防火扉をおろしてまだ深々と眠って居た。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "片盤坑に抜け出たお品がそこの複雑なレールのポイントにつまずいて思わず投げ出されながら後ろを振返った時に、早くも爆音を聞いて駈けつけた監督が、いまお品の転げ出たばかりの採炭坑の入口で、そこにしつらえられた頑丈な鉄の防火扉をみるみる締めはじめた。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お品は矢のように起上ると防火扉の閂にかかった監督の腕に獅噛みついた。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて工手が駈けつけると、監督は防火扉の隙間に塗りこめる粘土をとりに駈けだして行った。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　技師の屍体は、防火扉から少し離れた片盤坑の隅に転っていた。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその締縄に清められた筈の防火扉の前で、皮肉にも新らしい血が、一度ならず二度までも流されてしまった。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "片盤の坑夫や坑女たちは、網をかぶった薄暗い電気の光に照らされながら、閉された採炭場の防火扉の前に、意味ありげに二つも並んだ屍体を遠巻きにして、前とは違って妙にシーンとしていた。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "危急を要する場合ですよ」「どうも君は、算盤よりも狩猟のほうが好きらしいね」　係長が仕方なく苦笑すると、技師は直ぐに片盤坑の入口の大きな防火扉を引寄せて、水平坑道でうろたえ始めた坑夫や小頭に事情を含め、係長と一緒に片盤坑へ飛び込むと、外側から防火扉を閉めて、小頭に閂をかけさした。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では、もう一度大事なことを訊くが、お前が発火坑から逃げ出して、監督や技師や工手たちが駈けつけて防火扉を締め切ったその時には、確かにその場に峯吉は出ていなかったのだな？",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、いちいち探すまでもなく、防火扉を締めたら間もなく鎮火したと云うのですから、これは消甕みたいなもので、防火扉のところよりほかにあの坑内には絶対抜け穴はない。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは峯吉は防火扉のところから出たに違いない。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、防火扉の閂は外側にあるし、隙間に塗込めた粘土は塗られたままに乾燥していて開けられた跡はなかった。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝附近――　三次此処まで来て立ち止って、勝坊に、Ｔ「隠れんぼうをして遊ぼうか」　と言い出した。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "またたとえば忠犬美談で甲新聞が人気を呼ぶと、あとからあとからいろいろな忠犬物語がほうぼうから出て来て、日本じゅうが犬だらけになり昭和八犬伝ぐらいはまたたくひまに完成するのである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、声あげて叫ぼうか。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「呼ぼうか、呼ぼう。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見て大森は煙草を取って煙草盆をつつきながら静かに、「それとも呼ぼうか？",
              "citation": {
                "source": "疲労",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
