[
  {
    "uuid": "58a003e4-f790-596a-b09a-9f670b491585",
    "entry": "呆ける",
    "reading": {
      "primary": "ボケる",
      "alternatives": [
        "ぼける"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to grow senile",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「よし、そのくらい空呆けることがうまくなれたんなら、男と共住みも大丈夫だろ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あてもなく、たゞぶらりと……」三「呆けるのも好い加減にしたまへよ。",
              "citation": {
                "source": "好日の記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だつて写真でいつも見てゐるではないか、と母がわらつても、どうも写真とは違ふようだとわたしは空呆けるばかりで、一向なぢまうともしなかつたとか、ついこの間も母は何かわたしをからかふような調子で憶ひ出したりした。",
              "citation": {
                "source": "気狂ひ師匠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐野郎……空呆けるない、あたいだつて皆な知つてゐるんだぞ。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "スツポンといふのは養魚場の宇佐見金蔵の仇名で、彼は自ら空呆けることの巧みさと喰ひついたら容易に離さないといふ執拗振りを誇つてゐた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ツアイス製などには相当のものがあるさうだが、色を合せるのが厄介でね……」　俺は空呆けるより他はなかつた。",
              "citation": {
                "source": "木枯の吹くころ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、幾分後暗い見たいな思ひを秘しながら空呆けると、いきなり百合子は、「嘘つき！",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "スッポンというのは養魚場の宇佐見金蔵の渾名で、彼は自ら空呆けることの巧みさと喰いついたら容易に離さないという執拗ぶりを誇っていた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、些くとも私は、小さい時からよく寝呆ける癖があったので、今でも妹によく笑われる位だから、私の何代か前の先祖の誰かにソンナ病癖があって、それが私の神経組織の中に遺伝していないとは、誰が保証出来よう。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日待ち、二日待ち呆けるうちだんだん氣力が衰へてくる。",
              "citation": {
                "source": "おばあさん",
                "author": "ささきふさ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二六時中、頭のなかが冴えかえり、およそ寝くたれるの寝呆けるのということのない眼の慧いひとだから、気づかれずにぬけだすなどは、出来ない相談である。",
              "citation": {
                "source": "うすゆき抄",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして」「遊び呆けるのも一快でしょうが、そのうえまた、彼女らの世界に楮銭の価値を教えてやって流行らせます。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "」太郎丸いよいよ空トボケる。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちでボケる上に、ロケで、無知な奴等に、見せものを見るやうな目で見られる、いら／＼してたまらない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「次郎長」が又みんなが舌をかむやら、ボケるやらで一ばん出来が悪い。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことをいって、ただひとり間者牢へのぼって行った影が、うすい夜霧にボケるまで、一同見送ってはいたが、誰も、「あの老人が、血刀を下げた白衣の影にパッタリ行き会ったらどうする気だろう？",
              "citation": {
                "source": "鳴門秘帖",
                "author": "剣山の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
