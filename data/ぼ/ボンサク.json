[
  {
    "uuid": "0cc15de4-f7a8-5c62-a897-a6b14baeb12f",
    "entry": "凡作",
    "reading": {
      "primary": "ぼんさく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mediocre work",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『文藝戰線』　　　　　返される包　（細田源吉氏）　凡作。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに比べてこれはあまりに凡作だ。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄作だの傑作だの凡作だのというのは、後の人が各々の好みできめる事です。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "△横山大観――『雲翔る』大観のものといふ先入観を入れなければ批評の出来ないやうな絵である、画庫から何時でも引出して出品できさうな凡作である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の仏師が多分を占めてはおりますが、いずれも腕揃いであって、凡作は稀で、なかなか結構でありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "本所五ツ目の羅漢寺のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体、かの仮面は、名作か凡作か、素人の我々にはちっとも判りませんが、何でも名人の彫った名作でなければならぬ。",
              "citation": {
                "source": "修禅寺物語",
                "author": "――明治座五月興行――",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、御覧に入れましたところで、お笑ひを蒙りますのは必定で……」「達つて所望いたす、すぐに持参いたすやうに」忠興は前にある小壺の列に、ちらと眼をくれながら、「この上凡作をいまひとつ加へたところで、おれが所領の大きさを知る上には、少しも差支へないのぢや」　小壺は佐渡の屋敷からすぐに取り寄せられました。",
              "citation": {
                "source": "小壺狩",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体仏画といふものはざらにあるが、名高い二十五菩薩｜来迎や山越の阿弥陀などを除けると、何れも凡作揃ひでお談話にもならぬが、美術の好きな者には盲目が多く、盲目には富豪が多いから、下らぬ仏画に万金を投じても悔いないのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "このうち、例年のとおりベスト・テンを選ぶとすれば、なお三十八本の平凡作が残る。",
              "citation": {
                "source": "思い",
                "author": "――情報局の映画新体制案について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄作、悪作、愚作、――せめて凡作を――傑作は出来ないから――もちろん、人生の、生活の、私の身すぎ世すぎである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、私は右の不動を出して見ると、なかなか凡作でない。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "不動の像が縁になったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "実をいうと、あれは広小路の夜店で八銭で買ったのです、値は八銭であっても、作は凡作でない。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "不動の像が縁になったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "素人眼には誠につまらぬ画にて、雪舟崇拝と称せし当時の美術学校派さへこれを凡作と評したるほどなりしが、不折君はやや暫し見て後｜頻りに讃歎して已まず、これほどの大作雪舟ならばこそ為し得たれ到底凡人の及ぶ所に非ずといへり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "因襲の圏内にうろついている作は凡作である。",
              "citation": {
                "source": "沈黙の塔",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の常に云ふ美術に於ける唯心的領域とはこれであつて、どんな美術にでも何等かの現はれ方でこの形以上の世界の描かれてゐないものは凡作であると云つてさしつかえない。",
              "citation": {
                "source": "美術上の婦人",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者の歌としては寧ろ凡作に属するものであらうが、それにも拘らず、普遍的実相に触れた小さなクラシツクとして存在の価値はありさうである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると私の友人は「それは乞食の中の凡作ぢやないか」といつて私を揶揄した。",
              "citation": {
                "source": "噴水のほとりで――",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "神の国人其でも、此歌などは、凡作つた場合が想像せられるのである。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして段々新作に手を染めるやうになり、古人の名作は名作として、其精神を為活す様になるし、今人の凡作にも、人物の性根を優人の敏感を以て、思ふまゝに解釈を加へ、又勝手ながら表現によつて深めて行く。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、何れも、その作品は戯曲的生命に乏しく、凡作の域に止り得るものすら稀であつた。",
              "citation": {
                "source": "近代劇論",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるところには五体十体、やや離れて五十体、駒井甚三郎は、その目をひくものの一つ一つをかぞえて行くうち、愚拙なるもの、剽軽なるもの、なかには往々にして凡作ならざるものがある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　凡作事、須要有事天之心。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　傑作と凡作との間は紙一重の相違である。",
              "citation": {
                "source": "愛陶語録",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいずれも凡作見るに堪えざる事を知って、稿半にして筆を投じた反古に過ぎない。",
              "citation": {
                "source": "十日の菊",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の木で作られてある独楽なのか、作られてから幾年を経ているものか、それが上作なのか凡作なのか、何型に属する独楽なのか、そういう方面に関しては、彼は全く無知であった。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そういう無知の彼にも、何となくこの独楽が凡作でなく、そうして制作されて以来、かなりの年月を経ていることが感じられてならなかった。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "他に多くの凡作もあったであろうし、また専門の俳優を必要としない程度のものが伝えられたとも考えられる。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「地獄極樂の人形は凡作だが、招きの普賢菩薩が大した名作だつてね」「作人は本所緑町の佛師又六、大した腕のある男ぢやねえが、あの普賢菩薩だけは、後光が射すやうな出來だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "歎きの菩薩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「成程、これは凡作だ」　平次も驚きました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "歎きの菩薩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
