    "definitions": [
      {
        "index": 1,
        "gloss": "in a daze",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あんな時分は訳もわからず、ぼーっとしているから、他哩のないものなのよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "糺の森がぼーっと霞んで見えなくなる。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、ぼーっとしてきて、私はねむってしまいました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、たちまち眼の前の、ぼーっとした仄暗い空を切り裂いて、青光りのする稲妻が、二条ほどのジグザグを、竪にえがいた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "車置き場でぼーっとしていると、ぼろを着た少年がジェファースン・ホープという運ちゃんはいるかと訪ねてきて、ベイカー街二二一Ｂの紳士が馬車をご指名だと言うのです。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経が急にざわざわと騒ぎ立って、ぼーっと煙った霧雨のかなたさえ見とおせそうに目がはっきりして、先ほどのおっかぶさるような暗愁は、いつのまにかはかない出来心のしわざとしか考えられなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半身が痲痺したり、頭が急にぼーっと遠くなる事も珍しくなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとすると、そのドン助というのは、そのときこの○○獣に喰われてしまったかもしれないよ」「ええっ、ドン助が○○獣に喰べられてしまいましたか」　それを聞くと、敬二は頭がぼーっとしてきた。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それには及ばぬ」こういって再び持ち上げましたが、その瞬間、ふと、これが昨日まで一しょに語った箕島の『はらわた』であるかと思って、気がぼーっとしました。",
              "citation": {
                "source": "稀有の犯罪",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか気がぼーっとして、心臓の音だけが、いやに強く私の耳に響きました。",
              "citation": {
                "source": "体格検査",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして傍らにあった椅子に腰をかけ、気を静めようとしましたが、何だか頭がぼーっとしてきました。",
              "citation": {
                "source": "玉振時計の秘密",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "体じゅう熱くなるばかりで、人の顔や声がぼーっと遠のいたようになるのであった。",
              "citation": {
                "source": "打あけ話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼーっとしているねえ、みんな」　そのうち、その電車は駛り去った。",
              "citation": {
                "source": "一刻",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "姓がかわっていたばかりでなく、この下の弟は、全く母に似て、ぼーっと肥った大柄だった。",
              "citation": {
                "source": "道灌山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手の方、一間半ばかり離れて、雑草の中に、何か、時々ぼーっと浮き出る白いものが眼についた。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それが、生い繁った雑草の中に寝かされてあり、その夏草の葉蔭にとまった蛍が、無心に息づく度に、ぼーっと蒼白い仄な光りと共に、それが隠し絵のように、浮び出るのであった。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それと対照的に、ついさっき塗られたばかりらしいルージュの深紅と血潮とが、ぼーっと明るむたびに、火のように眼に沁るのだ。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽のもとでは、さぞ酷らしいであろうその屍体が、このぼーっ、ぼーっと照しだされる蛍火の下では、どうしたことか却って、夢に描かれたように、ひどく現実離れのした倒錯した美しさを見せるのであった。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、受付でミサ子が自分の名を紙に書いてた間、ぼーっと往来を眺めていた男の顔付でわかる。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くも少くもないその毛は、しなやかに波うって、ぼーっと薄暮の色を呈していました。",
              "citation": {
                "source": "幻の園",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼーっとした明るみがさしていました。",
              "citation": {
                "source": "幻の園",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、或る夜、淡い上弦の月が西空に傾いてる頃、その焼跡に、青白い火がどろどろと燃えて、狸石のほとりにぼーっと明るみを投げ、人の姿を浮き出さした。",
              "citation": {
                "source": "狸石",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリーのあのタランテラ踊のこと、言葉――ナポリ語のこと、下位春吉君のこと、オピアム・イーターのこと、あんなに喋ったら、あとでぼーっとなりはしないかと思う位、晶子夫人が笑うとき、鼻柱眉の間に強く横しわをつけ、眉をつらせ、一種独特の表情やや肉感的――をされる。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "四ノ二　義公は、不意に、一同の視線を浴びて、その可愛いい顔をぼーっと上気させながら、それでもすぐ続けた。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒吉は、その背後姿が、ぼーっと霞むと、膨らんだ瞼から熱いものが、頬を伝った。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから、たった一つの窓が、カーテン越しに、ぼーっと明るんでいるきりだった。",
              "citation": {
                "source": "腐った蜉蝣",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行って呼んで来て下され、あの、そら、案内の男を――おお、ついでに鍋なぞ、米なぞを持たせて――」　うしろの木立ちにぼーっと明らんだところが見えて、火も燃えて来た。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、どきんと心悸がたかまり、目先がぼーっとなってはッきり確かめることは出来なかった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "風はやみ、うららかな春の日で、遠くはぼーっとかすんでいました。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
