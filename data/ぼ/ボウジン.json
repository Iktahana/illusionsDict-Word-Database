[
  {
    "uuid": "a20afa90-8854-5759-9f1a-d0d0d2f34bff",
    "entry": "傍人",
    "reading": {
      "primary": "ぼうじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bystander",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして此の場合に若しその患者自身が……何等かの必要に迫られて……この苦しい実感を傍人に向つて説明しようと試みるならば（それはずゐぶん有りさうに思はれることだ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし傍人がこの病気について特種の智識をもたなかつた場合には彼に対してどんな惨酷な悪戯が行はれないとも限らない。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼兒と聖人は神に聽かれんために祈祷し、衒學者及び説教者は傍人に聽かれんために祈祷す。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍人慌てゝ彼をとゞめて曰く、君よ口を慎しめ、かの破れたる帽子の下に宇宙は包まれてありと。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　父竜池の後を継いで二世藤次郎となった子之助は、継母三村氏すみその他の親族、最故参の金兵衛以下大勢の手代の手前があるので、暫くは謹慎を守っていたが、四十九日の配物が済んだ頃から遊所に通いはじめ、漸く馴れては傍人の思わくをも顧みぬようになった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍人の眼に苦々しく映ったに違いない・彼の無用の気取（或いはダンディズム）の正体は、正しく此処にあった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し其の場合にも猶、負惜しみ的な弱者の強がりが、（傍人に見えるのは差支へないとして）自分に意識されて立派とは思へない。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはヱネチアの既に甚だ近きを覺えしに、今｜傍人に問へば猶一里ありと答ふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀しいとか、佗しいなどゝいふことはわたしは文字を誌すにも控たいやうな言葉なのであるが、その時はそんな大きな声でまぢまぢと云ひ放つても、余外な神経も現れず、おそらく傍人の眼には滑稽に見えたであらうほど、大胆に哀しく、わたしはまつたくのしらふの眼で凝つと空を見あげてゐた。",
              "citation": {
                "source": "痩身記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍人蛇を殺して鳥を救いしも、全く怖れたばかりで死にいた証拠には、その身を検べしに少しも疵なかった。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンドリウ・スミス男喜望峰で見たは、一士官しばしばある狗頭猴を悩ます、ある日曜日その士盛装して来るを見、土穴に水を注ぎ泥となし、俄に投げ掛けてその服を汚し傍人を大笑せしめ、爾後その士を見るごとに大得色を現じた由。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその後、予備門（今の高等学校）の生徒控室でゆくりなくもこの五分刈の巨頭君に邂逅って、喫驚して窃に傍人に訊いて、初めてこれが石橋助三郎という人であると教えられた。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "御母さんがいっしょになってワーと泣かぬ以上は、傍人が泣かんでも出来損いの御母さんとは云われぬ。",
              "citation": {
                "source": "写生文",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は子供の折から父親の厄介になつたことがないといふのが、得意であるのは結構だつたが、苟くもその親たる者を虫ケラ同然に鼻であしらふ態度に到つては、傍人の正視成し難い冷酷さであつた。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二人まったく掴み合いになろうとして、傍人から止められる）村年寄甲　誰ぞ村の難儀を救う人ないか。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "川もないのに鉄橋とは可笑いと思つて、窓をあけると、傍人は「石狩川です」と教へて呉れた。",
              "citation": {
                "source": "雪中行",
                "author": "小樽より釧路まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "此辺は、北海道第一の豊産地たる石狩平野の中でも、一番地味の饒かな所だと、傍人はまた教へて呉れた。",
              "citation": {
                "source": "雪中行",
                "author": "小樽より釧路まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "村長から洩れたのであらう、松川は駿介の事を聞き、不滿のこころを傍人にもらしたと云ふのである。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おちかが順吉の學費のためにいくばくかの補助を願ひ出、ひさがそれをにべもなく蹴つた、昔のことを恩に着せようつてのがわたしやいやなのさ、とひさは傍人に語つてあるいたが、その時以來、おちかの順吉への期待にはあらたな情が加はつたのである。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "空論ばかりにては傍人に解しがたく、実例につきて評せよとの御言葉ごもっともと存候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍人より見なば定めて狂人の言とさげすまるることと存候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ傍人より見れば新聞取次店または地方歓迎者の名前を一々列記したるだけはややうるさい感があるが、それはこの紀行の目的の一部であるから固より記者を責むべきものではない。",
              "citation": {
                "source": "徒歩旅行を読む",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "小生今日の容態は非常に複雑にして小生自身すら往々誤解｜致居次第故とても傍人には説明｜難致候へども、先づ病気の種類が三種か四種か有之、発熱は毎日、立つ事も坐る事も出来ぬは勿論、この頃では頭を少し擡ぐる事も困難に相成、また疼痛のため寐返り自由ならず蒲団の上に釘付にせられたる有様に有之候。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "空論ばかりにては傍人に解しがたく、実例につきて評せよとの御言葉｜御尤と存候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍人より見なば定めて狂人の言とさげすまるる事と存候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "空論ばかりにては傍人に解し難く實例に就きて評せよとの御言葉御尤と存候。",
              "citation": {
                "source": "歌よみに與ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍人より見なば定めて狂人の言とさげすまるゝ事と存候。",
              "citation": {
                "source": "歌よみに與ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜燈下交膝客　　昨夜灯下交膝の客、今朝忽作路傍人　　今朝忽ち路傍の人と作る。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
