    "definitions": [
      {
        "index": 1,
        "gloss": "banks of the Sumida river",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
