    "definitions": [
      {
        "index": 1,
        "gloss": "forgery of documents",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "遊惰にして財を糜し、屡謀書謀判の科を犯し、兄有信をして賠償せしめた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十に、もし、御当家へ咎めのかかることがあれば、証拠書類は、某の謀書として、この腹一つ切れば、よろしきようにも企んで置きましてござりまする。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
