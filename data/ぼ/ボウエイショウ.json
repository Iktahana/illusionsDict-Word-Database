        "examples": {
          "standard": [
            {
              "text": "防衛省の庁舎からは、夜遅くまで明かりが漏れており、職員たちの多忙さが窺える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "防衛省は、周辺海域での警戒監視活動をさらに強化する方針を固めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自衛隊の最高機関である防衛省は、国民の生命と財産を守る重責を担っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
