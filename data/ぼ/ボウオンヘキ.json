        "examples": {
          "standard": [
            {
              "text": "高速道路沿いには、騒音対策として防音壁が設置されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "住宅街の近くに工場を建てる際には、防音壁が必須となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "防音壁のデザインは、景観にも配慮されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "防音壁をとおして、隣室の機械室に廻っている廻転機のスピード・アップ音が、かすかに聞える。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄いろい防音壁にかこまれた四角い部屋はボール箱の中のようで、壁にはめこまれた時計が午前か午後かわからない六時ちかくを指し、部屋はつけっぱなしの蛍光照明がまぶしかった。",
              "citation": {
                "source": "演技の果て",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
