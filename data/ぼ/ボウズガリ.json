          "literary": [
            {
              "text": "坊主刈りでチョッキを着ないドイツ人。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭を坊主刈りにして歯のかけてる老人が出て来ました。",
              "citation": {
                "source": "白蛾",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "赧ら顔に鼻眼鏡をかけ、頭を青い坊主刈りにして、いくらかしまりのない大きな口元に愛嬌を浮べながら社交的に話す技師が現れると、パンシオン・ソモロフの食堂の空気は微妙に変化した。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の毛も以前とちがう坊主刈りになってしまい、口髭も失くなっている。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから私が切るわ」「坊主刈りです」「なんですって？",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は坊主刈りにしてください」　彼の頭を、美代子は見た。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸びて来たら、別のスタイルにしなさい」「とにかく、坊主刈りにしてください」「バリカンで切るのだわ」　そう言った彼女は、バリカンの使える人はいるかと、店の女性たちに聞いた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主刈りにしたなら島村冬彦に写真を撮ってもらおう。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主刈りにした僕を節子さんは初めて見る。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
