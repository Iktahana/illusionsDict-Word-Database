    "definitions": [
      {
        "index": 1,
        "gloss": "both mother and child",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "母子ともに頭を屈めて進むと、更に第二の石門が行手を塞いでいた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもだんだん平板に落着いて来たが、あの規矩男にこういう母親の平凡な待望がかけられているとは、あまり見当違いも甚しく、母子ともに気の毒な感じがする。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母子ともに即刻引取られ、少年は豎（小姓）の一人に加えられた。",
              "citation": {
                "source": "牛人",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母子とも社交を避けゐたり。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "注に騾もし姙めば、母子ともに死すとある（『大明三蔵法数』一九）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に芸者や娘に私生児を生ませ母子ともピンピン跳ねているに父は神と祠られいるなど欧米人は桜よりも都踊りよりも奇観とするところだ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の病児と過した半年間は、母子とも枕があがらなかった。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに久しく東京で母子ともまごついている母親は、村の表通りを晴れて通ることすら出来なかった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "母子ともに無事だという話だったが、その後はいかが。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の嫁入前に母子ともに忙しきは、仕度の品を買てこれを製するがために非ず、その品を造るがためなり。",
              "citation": {
                "source": "旧藩情",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、次第にその二人の間は、師弟とも母子ともつかぬ、異様な愛着で結ばれて行ったのであるが、然しその時だけは、杉江の口の端に焦り焦りしたものが現われ待ち兼ねたように腰を浮していた。",
              "citation": {
                "source": "絶景万国博覧会",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにお若は安産いたし、母子とも肥立よく、甚兵衞夫婦は相変らず親切に世話してくれます。",
              "citation": {
                "source": "根岸お行の松　因果塚の由来",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "うう好い箪笥を置いて」私はそういいながらなお立っていると、「まあ、どうぞここへお坐りやして」と、母子ともどもして言う。",
              "citation": {
                "source": "黒髪",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "電報が……」　襖開き、武男が電報をとりて見、小間使いが女主人の一｜睨に会いて半ば消え入りつつそこそこに去りしまで、わずか二分ばかりの間――ながら、この瞬間に二人が間の熱やや下りて、しばらくは母子ともに黙然と相対しつ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれを無憂樹と称するのは、釈迦が毘藍尼園の該樹下で誕生したとき、母子ともに何んの憂いもなかったので、そこで無憂樹といったとのことである。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人工呼吸でそれでも母子ともにもう安全だそうです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それであなたは万事を会得なさるのよ、母子とも健在なり、と。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……諄くは候えども、幼児松二郎は其許にとっても血筋なり、母子とも不憫の者に候えば返す返す身上の事頼入り候。",
              "citation": {
                "source": "柿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらもまた、近頃の寺侍に劣らない自堕落な裏面を内部にもっているので、御隠殿下の一群の寺侍町では、お袖｜母子とも、ほかの仲間とも、よく遊び場所で顔をあわせていた。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
