          "literary": [
            {
              "text": "「暴行を働いた上に暴言を吐くのか。",
              "citation": {
                "source": "電車停留場",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、今このしおらしい美男の若殿原に向って、さいぜんからあらんかぎりの暴言を吐くのみならず、人間の力ではできない相談の無理を吹きかけています。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしが娘の下手人だなんて、途方もない暴言を吐くのだ。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "象戯をさしているうちに、いつか主従の見さかいも忘れ、余りに暴言を吐くので、懲らしめてくれようとしたところ、さらに悪罵を放って、逃げて行ったというのである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴言を吐くにも程があるぞ」「程があると思うから、千両欲しいところを、こっちから五百両と負けて出ているんじゃございませんか。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "木曾の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
