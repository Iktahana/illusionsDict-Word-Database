        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その時、ああだれが山頂の墓碑を見るか。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある杉垣の内を覗けば立ち並ぶ墓碑｜苔黒き中にまだ生々しき土饅頭一つ、その前にぬかずきて合掌せるは二十前後の女三人と稚き女の子一人、いずれも身なり賤しからぬに白粉気なき耳の根色白し。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓碑に寛延の年号が刻んであるのを見るとよほど長命であったらしい。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か僕の墓碑に、次のような一句をきざんでくれる人はないか。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその日、鴎外の端然たる黒い墓碑をちらと横目で見ただけで、あわてて帰宅したのである。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廖氏氏」］二子及び門人｜王※等拾骸の功また空しからず、万暦に至って墓碑｜祠堂成り、祭田及び嘯風亭等備わり、松江に求忠書院成るに及べり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてはや終の墓碑。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓碑銘われは常にかれを尊敬せりき、しかして今も猶尊敬す――かの郊外の墓地の栗の木の下にかれを葬りて、すでにふた月を経たれど。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "われら同志の撰びたる墓碑銘は左の如し、「われは何時にても起つことを得る準備あり。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生、彼は自分の墓碑銘とすべき詩句をポケットにしのばせていた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い十字架や墓碑の群がつた傾斜の向ふに、増徳院の二本銀杏が見える。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓碑、碑銘、花束、祈祷、哀歌など、死の形式的な半面だけが、美しく哀しい舞臺の上のことのやうに、浮かび上つてくるのである。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "セトナ皇子は今迄の勉強に輪をかけて、古文書や墓碑銘を熱心に漁り出した。",
              "citation": {
                "source": "セトナ皇子（仮題）",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョン・フェリア元ソルト・レイク・シティ住民一八六〇年八月四日没　わずか前に別れたばかりのあの不屈の老人は、そのときすでに逝っており、これが彼の墓碑銘なのだった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧州で、死人の墓碑に犬の像を具する例甚だ多いが、必ずしも皆その人に忠誠を尽したものとは限らぬ。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその人の家紋そのまま禽獣を墓碑に添えたのも多い（同誌十一輯三巻三一〇頁参照）。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "中世武士が軍陣に犬とともに臥して寇敵を予防する風盛んに、その後婦女が犬を寵愛する事普通になりしより、犬が殊に墓碑に刻まるるに至ったので、スペインブールホスの大寺にあるメンシア・デ・メンドザ女の葬所なる臥像はその裙に狆を巻き付かせある。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘安の年號の文字纔に見ゆる古き墓碑もあり。",
              "citation": {
                "source": "白河の關",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "日露戦役後、度々部下の戦死者のため墓碑の篆額を書かせられたので篆書は堂に入った。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな事をいわずに墓碑の篆額を書くツモリで書いてくれ」と重ねていうと、「墓碑なら書くよ、生きてる中は険呑だから書かんが、死んだら君の墓石へ書いてやろう、」といった。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓碑に寛延の年号を刻んであるのを見ると、よほど長命であったらしい。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その右手の草原を通つて小高いがけの上に青竹をめぐらし半坪程の土地をくぎつてそのなかにさゝやかな墓碑が建てられてあつた。",
              "citation": {
                "source": "伊那紀行",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はこの月の七日、春雨さむき朝、逝水落花のあわれを示し給いて、おなじく九日の曇れる朝、季叔の墓碑と相隣れる処を長えに住むべき家と定め給いつ。",
              "citation": {
                "source": "父の墓",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "清光童女と記した藤野さんの小さい墓碑は、字が見えぬ程風雨に侵蝕されて、萱草の中に隱れてゐた。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "清光童女と記した藤野さんの小さい墓碑は、字が見えぬ程雨風に侵蝕されて、萱草の中に隠れてゐた。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓碑銘一九一一・六・一六・ＴＯＫＹＯわれは常にかれを尊敬せりき、しかして今も猶尊敬す――かの郊外の墓地の栗の木の下にかれを葬りて、すでにふた月を経たれど。",
              "citation": {
                "source": "呼子と口笛",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "われら同志の撰びたる墓碑銘は左の如し、‘われには何時にても起つことを得る準備あり。",
              "citation": {
                "source": "呼子と口笛",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村不折氏に墓碑の文字を頼んだのはどういふものか、この頃アメリカの新聞で見ると、紐育に住んでゐるある男は、自分が大病にかかつて、もうとても助からないと気が付くと、寝床に横たはりながら大きな声でお葬式の讃美歌をうたつたものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "葬式は遺言通りに自分のうたふ讃美歌で自分の屍骸を葬ることになつたさうだが、鴎外氏もいつそのこと、自分で自分の墓碑を書き残しておけばよかつたのに。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻の瑚※尼が死んで、全く孤独のやもめの老人となつた秋成は、一時、弟子の羽倉信美の家へ寄食してみたが窮屈で堪へられず、またよろぼひ出て不自由な独居生活に返つた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
