[
  {
    "uuid": "a3070441-5b8a-51da-9d06-5ab4e24a9f40",
    "entry": "膨大",
    "reading": {
      "primary": "ぼうだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
