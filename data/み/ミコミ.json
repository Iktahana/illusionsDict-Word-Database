[
  {
    "uuid": "10ab9757-294f-5f41-a3b9-855c73fb5b79",
    "entry": "見込み",
    "reading": {
      "primary": "みこみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
