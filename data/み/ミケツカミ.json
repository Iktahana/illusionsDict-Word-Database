        "examples": {
          "standard": [
            {
              "text": "日本の神話には、五穀豊穣を司る三狐神が登場する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地域によっては、三狐神を祀るお祭りが行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "三狐神への感謝を込めて、初物の作物を供えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "然るに後の書に素盞嗚尊の子、宇賀之御魂神、亦の名は専名｜三狐神とあり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
