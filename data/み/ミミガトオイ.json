        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「わ、わたしは耳が遠いんですが。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自らの語るが如く耳が遠いのであつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝三郎は少し耳が遠いので、納得させるには大声を出さねばならぬ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は耳が遠いから……」　といったような囁きが浴場の周囲の物蔭から聞こえた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし親爺は耳が遠いので気がつかないらしく、黙って曲った右足を湯の中に突込んだ。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚はまじりと見ていたが、果しがないから、大な耳を引傾げざまに、ト掌を当てて、燈明の前へ、その黒子を明らさまに出した体は、耳が遠いからという仕方に似たが、この際、判然分るように物を言え、と催促をしたのである。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……祖母さんは耳が遠いから可かったものの、（活きてるよ。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「すぐ開き扉一つの内に、祖母が居ますが、耳が遠い。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし翁も媼も耳が遠いので、わたくしは次第に声を大くして二三度繰り返さなくてはならなかった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの女の車」豹一は、こいつは耳が遠いんだと思うことによって腹立って来る気持を押えることにした。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は耳が遠いのである。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店の爺さんも笑ひながら、旦那、この爺さんはまことに耳が遠いのでそんな聲ではなか／＼通じないといふ。",
              "citation": {
                "source": "比叡山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "五尺七八寸もあらうかと思はれる大男で、眼の大きい、口もとのよく締らない樣な、見るからに好人物で、遠いといふより全くの金聾であるほど耳が遠い。",
              "citation": {
                "source": "山寺",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳も男は左が弱いので、耳が遠いとか何とかいう場合は、男なら大抵左に決っている。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "身共はな――」「なにッ、耳が遠いとは何を言うかい。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どやつが指し図致したのじゃ」「わははは、誰の指し図とは御老体、耳が遠いばかりか脳の方も少々およろしくござらぬな。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これよ、平七平七」「…………」「耳が遠いな。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分少々――」「耳が遠いか」「遠い段じゃねえ、このとおり耳のねえ人も同然なんです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "北川爺は耳が遠いので、彼を見ながら、頭をかしげて、あやふやな笑い顔を向けた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見てゐるわよ、顔つきと口つきさへ変へなければ、何んなに爺の悪口を云つたつて大丈夫よ、とても耳が遠いんですもの、眼の前だつて聞えやしないのよ。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　組頭は老人で、すこしく耳が遠いところへ、こっちが小声で云っているので能く聴き取れない。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度も三度も訊きかえし、云い返して、両方がじれ込んで来たので、組頭は自分の耳を扇で指して、おれは耳が遠いから傍へ来て大きい声で云えと指図したので、若い与力はすゝみ出てまた云いました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "留守居の老婆が耳が遠いのであつた。",
              "citation": {
                "source": "痴日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし耳、ためためあるよ」　なんだ、この料理人は耳が遠いのか。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は、少し耳が遠いんでね。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄斎老人は耳が遠いからといふので、息子さんの謙蔵氏が代りに会ふ事になつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳も男は左が弱いので、耳が遠いとかいふ場合は、男なら大抵左にきまつてゐる。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そういう対手も耳が遠いが曾祖母もやっぱり同様なので、おとなしく「ハイ、そうであります」と答えている。",
              "citation": {
                "source": "明治のランプ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
