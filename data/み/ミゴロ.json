[
  {
    "uuid": "a2cba010-dc39-5201-8151-de5079f4ee22",
    "entry": "見頃",
    "reading": {
      "primary": "みごろ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
