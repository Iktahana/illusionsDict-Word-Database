      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "best time to see",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "七、八分という見頃から満開にかけてはとうとう見損ってしまった。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度の見頃だとおもふ距離をおいて仰がるゝのはこの天城山からであつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "四邊の山より富士を仰ぐ記",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は此春先――殊に花見頃の時候になると、左右脳を悪くするのが毎年のお定例だ。",
              "citation": {
                "source": "背負揚",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、まだ行きません」「ちょうど今が見頃だそうですわ」「そうですか、じゃ見てくるかなあ」　龍之介は自然に対しては、あまり興味をもっていなかったので、梅園などちっとも見たいと思わなかった。",
              "citation": {
                "source": "謎の女",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘　こゝ四五日のところが見頃でござります。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間のところ／″＼には残雪がある、蕗のとうのよいのを見つけて袂に二つ三つ、今晩のお汁にいれようといふのである、白樺のよろしさ、落葉松のよろしさ、中腹の落葉松は今が見頃だ、辛夷が咲いてゐた、木賊が生えてゐるのも珍らしかつた。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど若葉の見頃な楓もあったが、樹ぶりが皆、すんなり、どちらかというと細めで素直だ。",
              "citation": {
                "source": "九州の東海岸",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水仙は莟がだいぶ大きくなつた、裏の梅二株は見頃だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の竹藪から、谷を隔てて続いて居る梅林（興正寺別院下から清水寺へ行く近道に当つて居る）の梅も見頃に近く、奥の間の縁側に出ると、赤い毛布を掛けた掛床几や、ビール、サイダーなどと染め抜いた赤や青の小旗が樹間に隠見して居る中を、瓢箪を携へた梅見客が三々五々と逍遥して居るのが手に取るやうに見られた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花ももう二三日で見頃と云う四月の初旬であった。",
              "citation": {
                "source": "琥珀のパイプ",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうなると、あとは提灯持ちみたいになるからやめるが、高崎から十幾里の山奥の、温川の谿谷は奇ならずと雖も閑寂、樹々は五分の芽立ちで、桜は散りそめ、山吹は盛り、つゝじも、早咲きが見頃である。",
              "citation": {
                "source": "旅の苦労",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、そのお祭の頃が、恰度花の方も見頃だとされてゐます。",
              "citation": {
                "source": "果物の木の在所",
                "author": "津村信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の花見頃｜午前の晴天は午後の二時三時頃からきまって風にならねば夕方から雨になる。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "山椿の花が見頃に咲いている崖を五、六歩上りかけた処に在った。",
              "citation": {
                "source": "墓畔の梅",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "市川驛前の闇市にて一老婆のふかしたる里芋賣りゐたるを見、花見頃のむかしを思出でゝこれを購ふ。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ好いこと」と云いながら二人は切株に腰を下ろし、咲きも終わらず散りも始めぬ、見頃の桜に見取れていた。",
              "citation": {
                "source": "善悪両面鼠小僧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例年十月一日から五日あたりにかけて最も見頃であるという。",
              "citation": {
                "source": "尾瀬雑談",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅の花も熱海や湯河原より少しおくれるだけで、二月にはいるともう見頃はとうに過ぎて、城跡の公園は朝から霜どけの道に悩まされるくらゐである。",
              "citation": {
                "source": "暖地の冬から山国の春へ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "白、紅、所々の畦や堤に、見頃の梅花が眺められる千住道を、蛾の行列みたいに、ぞろぞろと人が出る。",
              "citation": {
                "source": "雲霧閻魔帳",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、いよいよその季節が来て、何日頃が見頃であると云う便りがあっても、貞之助と悦子のために土曜日曜を選ばなければならないので、花の盛りに巧く行き合わせるかどうかと、雨風につけて彼女たちは昔の人がしたような「月並な」心配をした。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「南禅寺ッテ云エバ永観堂ノ紅葉ガ綺麗デショウネ、アタシガアレヲ見テカラモウ何年ニナルカ知ラ」「永観堂ハマダ早イヨ、高尾ヤ槙ノ尾ガチョウド見頃ダガ、己モコノ脚ジャ行ケソウモナイ」……………………………………………………………………………………………………十二日。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも晴れ着の裾や袂からすうッと風が薄荷のように体へ沁みたのを未だに記憶しているが、その肌寒さはあたかも梅見頃の陽気の爽やかさに似てぞくぞくしながらもここちよく、「もう幕が開いているんですよ」と母に促がされて小さな胸をときめかせつつ走って行ったものであった。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人は矢張り五尺六寸ぐらいが一番見頃さ」　とお父さんは好いことなら大抵自分を標準にする。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふうむ」「二十日といえば、月の見頃はすこし過ぎますが、せっかく、東宮もその覚一を御所へ呼んで、お愉しみにしておられますこと。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、どうしてこのまま父親をみごろしにできましょう。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "喪の人と、この時すでに、新妻の美喜子の君はなりたまひ、つるばみごろも、深く染め、籠りたまふと、云ふことを、誰れか思はん。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「知れたことよ、貴様ぐらいの小坊主がちょうど投込みごろの小坊主だ、スポーンと投げ込んでみたい、古井戸や坊主飛び込む水の音、スポーン」　神尾主膳は悪謔を弄しながら盲法師を抱き上げたものらしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんざらみごろしにもできない気持がしたのであった。",
              "citation": {
                "source": "ニュー・ヨーク　『青春の自画像』より",
                "author": "前田河広一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひる休みごろには、全校の気分が何となくざわめき立っていた。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの子は火事の晩に拾ったのよ、庄さん、親が死んじゃって、ひとりでねんねこにくるまれて泣いていたの、もうまわりは火でいっぱいだったわ、あたしみごろしに出来なかったの、――これが本当のことよ、庄さん、あたし約束どおり、待ってたのよ」　おせんは両手で面を掩い、堰を切ったように泣きだした。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
