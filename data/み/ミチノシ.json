    "definitions": [
      {
        "index": 1,
        "gloss": "Michinoshi (fifth highest of the eight hereditary titles)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "曾祖父は剣道の師範のような事をやっていて、そのころはかなり家運が隆盛であったらしい。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "安知は思ひあまつて、自分の茶道の師範役である小堀遠州に相談を持ちかけました。",
              "citation": {
                "source": "利休と遠州",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "四本ばかりでいゝんだが……」　仕合と道具屋は名人を拵へる事にかけては、その道の師匠よりもずつと傑れた腕を持つてゐるので、幸田氏は十日も経たぬうちに名人の吹いた尺八を三本まで手に入れた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校の先生たちは大人の世界でどんな暗闘があったか知らないが、少なくとも子供たちに対しては正しく、公平であり、道の師範であった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "本道の師は清水荘介と云つて、新町通丸太町下る西側に住んでゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「や、拙者も同じく剣道の師匠の身の上を案じてだ。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆｜是剣道の師の命令に叛き、女侠客の為に抑留されて、心ならずも堕落していた身から出た錆。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　その頃の雪之丞の師匠だったのが、つい今し方、八幡さまの境内でめぐり会った、奇人孤軒先生――そして、剣道の師範がこれから訪ねて行こうとする、今はこれも、江戸へ出て御蔵屋敷の近くに、道場を構えている、脇田一松斎なのであった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は剣道の師範役なのである。",
              "citation": {
                "source": "国事犯の行方",
                "author": "―破獄の志士赤井景韶―",
                "note": "青空文庫"
              }
            },
            {
              "text": "……高萩の猪之松の剣道の師匠、逸見多四郎殿と試合をするのだ」３（なるほどな）と浪之助は思った。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "処士とはいっても所の領主、松平｜大和守には客分として、丁寧にあつかわれる立派な身分、ことには自分が贔屓にしている、高萩の猪之松の剣道の師匠――そういう逸見多四郎であった。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げたというのでは決してなく、自分の剣道の師匠であり、日頃から無用の腕立てや、殺生を厳しく戒められている、その逸見多四郎にこんな姿を――抜身をひっさげているこんな姿を、こんなところで見られるということが、面伏せに思われたからであった。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはそのころの教道の師の言葉も責めを負わねばならぬ。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "是は我々の歌道の師松浦萩坪先生の歌の集で、還暦の記念として門下一同に買わせたものである。",
              "citation": {
                "source": "予が出版事業",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に、正しい修行には正しい師匠を取らねばならぬ……わしがその正しい剣道の師匠を其許に推薦する、その人について修行なさるがよい」　弾正が推薦する正しき剣道の師とは何者か。",
              "citation": {
                "source": "大菩薩峠",
                "author": "甲源一刀流の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはすなわち剣道の師範役小林文吾であります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "如法闇夜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらかじめ罪人の屍骸を貰って来てあって、斬り手の役は小林という剣道の師範役、それに勤番のうちの志願者も手を下して、利鈍を試みるということであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "伯耆の安綱の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉服屋の番頭も、花道の師匠様も、出入りの八百屋までが、義士たちのためになら、どんなことでも尽したい。",
              "citation": {
                "source": "べんがら炬燵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一二歳の頃にはその道の師範ですら相手にならなくなったが、格別に珍奇な手法を弄するわけではなく、ごく簡単に、まさかと思うほどあっけなく勝負がついてしまう。",
              "citation": {
                "source": "雨あがる",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……二百石で召抱えられてから既に三年、自分のつもりでは岡山へ行けば剣道の師範にでもなれる気でいたのが、別にそんな沙汰もなく、馬廻りの普通の勤めで、三年間なんの変哲もない月日がたってしまった。",
              "citation": {
                "source": "備前名弓伝",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老職の妻として教養を身につけたいという気持であろう、家政をとるいとまに茶の湯、華、琴、鼓などという芸事をずいぶん熱心にならった、また生得さかしい彼女はその一つ一つにすぐれた才分をあらわして、その道の師たちをおどろかしたものであるが、どれも末を遂げたものがなかった。",
              "citation": {
                "source": "日本婦道記",
                "author": "梅咲きぬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親は柔道と剣道の師範として知られた人で、その町および近隣に、三つの道場を持っていた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大殿さまは、よほど茶道もお花もお習いになったのでしょう」「うそを申せ、わしは公卿じゃなし、挿花や香道の師についたことはない」「でも、そう見えますもの」「なんの、挿花を生けるのも、わしは剣道で生けるのじゃ」「ま」　彼女は、驚いた目をして、「剣道で挿花が生けられましょうか」「生かるとも。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その母に伴われて、初めて武道の師というものにまみえたのは、六ツか七歳ぐらいなときだった。",
              "citation": {
                "source": "剣の四君子",
                "author": "小野忠明",
                "note": "青空文庫"
              }
            },
            {
              "text": "不動如山　それはまた信玄がふかく心契していた道の師、恵林寺の快川和尚が筆になるものとは、どんな者でも知っていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "その特性は、出入の茶道の師でも、植木屋でも、魚屋までが、より知っている所だ。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎作の茶道の師匠に、四方庵と申して、山田宗※という宗匠がある、御老中小笠原佐渡守のお抱えで。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして忠利に至って、祖父が宗門の麒麟児として愛し、父が心友として相許す沢庵に、道の師として畢生の敬慕を捧げたのは当然というべきである。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やまぶきやまぶきのたちしげみたるやましみづくみにゆかめどみちのしらなく萬葉集さくらEdward Thomasさくら木は覆ひかぶさりて花ちりそそげり。",
              "citation": {
                "source": "佐藤春夫詩集",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
