        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "松本附近である神社の周囲を取りかこんでいるはずの樹木の南側だけが欠けている。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南側の樹木が今度の風で倒れたのではなくて以前に何かの理由で取払われたものらしく見受けられた。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京辺と四国の南側の海岸とでは満潮の時刻は一時間くらいしか違わないし、満干の高さもそんなに違いませんが、四国の南側とその北側とでは満潮の時刻は大変に違って、ところによっては六時間も違い一方の満潮の時に他の方は干潮になる事もあります。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」　見ると、スパイは、日あたりのいゝ、積重ねられた薪の南側に腰をおろしてうつら／＼櫓をこいでいた。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのようなことの可能性を暗示する一つの根拠は、最大頻度方向より三十度以上の偏異を示す七匹のどれもがみんなその尾端を電線の南側に向けており、反対に北側に向けたのはただの一匹もなかったという事実である。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車が上諏訪に近づいたころには、すっかり暗くなっていて、やがて南側に、湖が、――むかしの鏡のように白々と冷くひろがり、たったいま結氷から解けたみたいで、鈍く光って肌寒く、岸のすすきの叢も枯れたままに黒く立って動かず、荒涼悲惨の風景であった。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "南側の壁には、紙の風船玉がひとつ、くつついてゐた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "南側の壁には、紙の風船玉がひとつ、くっついていた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは萱の間の小さなみちを山のほうへ少しのぼりますと、その南側に向いたくぼみに栗の木があちこち立って、下には葡萄がもくもくした大きな藪になっていました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の南側は、太古の大地変の痕跡を示して、山骨を露出し、急峻な姿をしているのであるが、大垣から見れば、それほど突兀たる姿をしていないだろうという事は、たとえば陸地測量部の五万分一の地形図を見ても、判断する事ができる。",
              "citation": {
                "source": "伊吹山の句について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関の左に六畳ぐらいの座敷があり、その西隣が八畳ぐらいで、この二｜室が共通の縁側を越えて南側の庭に面していた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか彼は遊廓の南側まで歩いてきていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "原駅は富士の南側だから風下の東側ほどひどい被害地には数えられなかったが、それでも大迷惑には違いなかった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "修彌山の南側の瑠璃もまるですきとおるように見えます。",
              "citation": {
                "source": "四又の百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の南側は段々に高くなつてゐて、終には村の南端の、運動山の頂にいたるのである。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひろい扉が東側と北側に二つもついてゐたし、南側にも洋ふうの開窓があつて、それを皆いつぱいに明け放すと、風がどんどんはひつて來て書物のペエジがいつもぱらぱらとそよいでゐるのだ。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "省線の阿佐ヶ谷駅で降りて、南側の改札口を出た時、私は私の名を呼ばれた。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠綱さまと義村さまは、お庭の簀子の円座におすわりになつて、まづ義村さまが、このたび和田左衛門尉義盛の政所襲来と同時に、義村、政所の前の南側に馳せ向ひ、まつさきに敵勢に矢を射込みましたが、塵ひとつ義村の眼前を駈け行くものは見受けられませんでした、といかにも実直さうに申し述べました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は首を低めて開け放しの南側の闇を透して川下を窺いました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンよりもずっと清新なニューヨーク街の雑沓や速力の早い汽車の南側から眺める米大陸の深林の緑が夫人の空想のなかに浸み込む。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹田を過ぎ、東淀川の駅を過ぎると、やがて南側の車窓に、北野劇場のネオンサインが見え、大阪はもう夜であった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "家を出て、表門の鳥居をくぐると、もう高津表門筋の坂道、その坂道を登りつめた南側に「かにどん」というぜんざい屋があったことはもう知っている人はほとんどいないでしょう。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達はその台場の南側の草原で旗奪をやった。",
              "citation": {
                "source": "鷲",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弐　そのころから無縁坂の南側は岩崎の邸であったが、まだ今のような巍々たる土塀で囲ってはなかった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "店は仲町の南側の「たしがらや」であった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "南側の小屋敷の板塀や生垣はすべて白いなかに沈んで、北側の大溝も流れをせかれたように白く埋められていた。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはむろん土間で、南側と北側とには日本の床よりも少し高い寝床が設けられて、その上には古びた筵が敷いてあった。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その藤沢の宿の南側、ここから街道を切れて、石亀川の渡しを越えて片瀬へ出るのが、その当時の江の島参詣の路順であるので、その途中には開帳を当て込みの休み茶屋が幾軒も店をならべていた。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "南側に坐っている男が言った。",
              "citation": {
                "source": "北斗と南斗星",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
