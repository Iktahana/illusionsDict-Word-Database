        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "民家の垣根に槙を植えたのが多く、東京辺なら椎を植える処に楠かと思われる樹が見られたりした。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑の中に點々と碁布した民家は、きまつたやうに森を背負つて西北の風を防いで居る。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑中にある民家でぼろぼろに腐朽しているらしく見えていながら存外無事なのがある。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "慰めのない「民家の沙漠」である。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈はその村に来ているが、私の家は民家とかなりかけ離れた処に孤立しているから、架線工事が少し面倒であるのみならず、月に一度か二度くらいしか用のないのに、わざわざそれだけの手数と費用をかけるほどの事もない。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして民家の上方に、一郭の城が嚴めしく聳えてゐた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその延焼区域の住民家屋の種類、密集の程度にもよることもちろんである。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこの際そういう家屋の存在を認容していた総督府当事者の責任を問うて、とがめ立てることもできないことはないかもしれないが、当事者の側から言わせるとまたいろいろ無理のない事情があって、この危険な土角造りの民家を全廃することはそう容易ではないらしい。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い民家の集落の分布は一見偶然のようであっても、多くの場合にそうした進化論的の意義があるからである。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑の中に点々と碁布した民家は、きまったように森を背負って西北の風を防いでいる。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも虞美人草はこのへんの民家の庭にあまり見受けなかった。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに中央線の汽車で甲州から信州へ分け入る際、沿道の民家の建築様式あるいは単にその屋根の形だけに注意してみても、私の言うことが何を意味するかがおぼろげにわかるであろうと思う。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽は霧に光り、草葉の霜は解け、遠くの民家に鶏は鳴いたが、霧も光も霜も鶏もみんな人々の心には沁まず、人々は家に帰つて食卓についた。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "環境と無関心のその有様は自分がただ一ところに足を踏み交わしているだけで、街道筋の民家が却って並木と共に西へ西へと歩いて行くと思われたほどだった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車はやがて廃れた様な暗い民家の低い軒毎を明るくして新鮮な蜜柑の山積する海添いの村落に入った。",
              "citation": {
                "source": "動かぬ女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "民家の妻が妊娠中に死亡したので、その亡骸を村内の古廟のうしろに葬った。",
              "citation": {
                "source": "餅を買う女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、廟に近い民家の者が草むらの間に灯のかげを見る夜があった。",
              "citation": {
                "source": "餅を買う女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャメラは始終草の茂った塹壕の中や、人の逃げてしまった民家の戸口の蔭なぞにかくれて、我々の行動を撮影していたらしい。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王｜弁疏する能わざるところありけん、佯りて狂となり、号呼疾走して、市中の民家に酒食を奪い、乱語妄言、人を驚かして省みず、或は土壌に臥して、時を経れど覚めず、全く常を失えるものゝ如し。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時其の土地の者が敵方へ同情を寄せていると、通過させなければ明白な敵対行為になるので武力を用いられるけれども、通過させることは通過させておいて、民家に宿舎することを同盟謝絶して其一軍に便宜を供給しない。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然候わば今日道通りの民家を焼払わしめ、明日は高清水を踏潰し候わん、と氏郷は云ったが、目論見の齟齬した政宗は無念さの余りに第二の一手を出して、毒を仕込み置いたる茶を立てて氏郷に飲ませた、と云われている。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏郷軍は民家を焼払って進んだところ、本街道筋にも一揆の籠った敵城があった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊田郡の栗栖院、常羽御厩や将門領地の民家などを焼払つて、其翌日さつと引揚げた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "怠り無く偵察してゐると、丁度将門の雑人に支部子春丸といふものがあつて、常陸の石田の民家に恋中の女をもつて居るので、時になつて、命を落す者四十余人、可なり手痛き戦はしたが、敵地に踏込むほどの強い武者共が随分巧みに、うま／＼近づいたにもかゝはらず、此の突騎襲撃も成功しなかつた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "霊亀元年五月には、遠江国に大地震があって、山が崩れて※玉河を壅いだが、続いてそれが決潰したので、敷智、長下、石田の三郡の民家百七十余区を没した。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞観六年七月には富士山の噴火に伴うて大地震があって、噴出した鑠石は本栖、※の両湖をはじめ、民家を埋没した。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "許宣は気が注いて船頭に一言二言別れの詞をかけ、楊柳の陰から走り出て湧金門を入って、ぎっしり簷を並べた民家の一方の簷下を歩いた。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑の中や森陰に当って、民家の屋根がぼつぼつ見えていたが、入って往こうと思うような家はなかった。",
              "citation": {
                "source": "黄金の枕",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは普通の民家でこしらえる衣ではなかった。",
              "citation": {
                "source": "賈后と小吏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その邑に入れば民家の牆屋は完備し樹木は繁茂している。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
