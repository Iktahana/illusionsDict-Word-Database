        "examples": {
          "standard": [
            {
              "text": "耳の不自由な方々のための手話通訳者が常駐している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の兄は生まれつき耳が不自由で、筆談でコミュニケーションをとる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "耳の不自由な子供たちが、音楽に合わせて楽しそうに体を動かしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "両者は、地位ある、耳の不自由な婦人に紹介されることをしきりに望んでいたが、いよいよ引き合わされて、彼女の聴音器の一端が自分の手にわたされると、何にもいうことがなかったという男のような境遇にある。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「恰幅のいい、強い外国なまりの、耳の不自由な方でした」　ハーマンはホッとしたようだったが、怪訝な顔だ。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
