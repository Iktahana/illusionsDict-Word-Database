[
  {
    "uuid": "fd3d352c-dad5-54ff-9ae8-f68d1fceb678",
    "entry": "見るに忍びない",
    "reading": {
      "primary": "みるにしのびない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
