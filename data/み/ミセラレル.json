    "definitions": [
      {
        "index": 1,
        "gloss": "to be enchanted",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "魅せられるような感じはそこから生れるのである。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "概念で以て俺を軽蔑する奴も、実際に俺の作品を読んで見れば、文句なしに魅せられるに決ってるんだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はいつもこの強いひとみに魅せられるのであった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは何時も長閑な汝の頭上から、瀟洒な外輪船の出てゆく油繪の夕日に魅せられる。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にまた、文化の面では、アンナ・アフマートヴァのフランス香水の残り香のする老いた桃色と紫色との詩にちょっと魅せられるような気分をも伴った。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした山中の体験の楽しさに二度三度と案内しった同じ山へ幾度も私は魅せられるように登って見た。",
              "citation": {
                "source": "英彦山に登る",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒューッとはいる下座の笛、ドンドンと打ち込む太鼓つづみ、嫋々と咽ぶ三弦の音、まず音楽で魅せられる。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス文学の理解は、彼の「毒舌」に負ふところが多いことを、誰でも認めるだらうが、たゞ批評に魅せられることを望むものも亦、彼の業績を一瞥すべきである。",
              "citation": {
                "source": "「サント・ブウヴ選集」推薦の言葉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの奴隷も鞭の下に、いつの日か、この芸の鬼に魅せられる日があり、この凄惨な芸の奥底にたぐりよせられた人々が、ずいぶんあったであろう。",
              "citation": {
                "source": "脱出と回帰",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一姿のよさに魅せられる。",
              "citation": {
                "source": "若鮎の気品を食う",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど招き猫に魅せられるように、舟三はその死人の招きを避けること出来ない。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "佃の身持の堅さは、人間の面白さ、愛らしさなどに魅せられることの少いところから来ているように思われたのであった。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒はナダ色は年増に釣りは青　　　金馬香りに魅せられるアユ〈六月〉石船に今年のアユのデキを聞き　毎年五月中旬、世の釣り師はいっせいにアユ竿を出し、仕かけと蚊針ケースを取り出して手入れをし、解禁の日を夢見る。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身の思ひは私と私がいつも魅せられるページとの間をさまよつてゐた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はよしやこの女が狐であっても、その正体がこんな妖艶なものであるなら、寧ろ喜んで魅せられることを望んだでしょう。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この形式の単純化が企てられるとき、観賞者にとつては、彼に益々判り易い絵をみせられるといふことになる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠を見せて下さいますか」「みせられる者なら見せますけれど」「見せて下さいますか」「見せられる者なら。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵としてはもちろん月並の画題でもあろうが、さて実際にそういう風情をみせられると、決して悪くは感じない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今までは、どんな娘だろうなどと一種の興味をもって待ち受けていたのであるが、さてその本人の悼ましい姿をみせられると、僕たちももう笑ってはいられなくなった。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとして、僕は絵里子の死骸でもみせられるのではないかと考えていたのだ。",
              "citation": {
                "source": "宇宙女囚第一号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "母のそつのなさをみせられるたびにお初は自分を恥じて顔を赧める。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような優しさ劬わり深さをみせられるよりは、寿女は、罵られながら扱使われたほうがましだと思った。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へ帰って、夫婦喧嘩をみせられるのはたまらない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば、今の自分ならてきぱきと超人的な捜査をやってみせられるのだがなあ――と、大寺警部は人柄にもなくはかない夢を抱いている。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうだ、ああ言ってもらえば、俺にも死ねる、立派に死んでみせられる！",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらだつてみせられる……。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦災者のなかには、日本人ならではと思はれる恬淡な気分の持主もゐるし、込み合つた汽車の中でも、同胞なるかなと心の和むやうな風景をみせられることもある。",
              "citation": {
                "source": "其日、其日の気持",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画による文化の序列をみせられるようで、変な悲しい気がしないでもなかった。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳の上にしゃんと坐って、両袖を張って、その身振りをしてみせられる峯子夫人の姿には、昭憲皇太后の面影がしのばれるような気がした。",
              "citation": {
                "source": "牧野伸顕伯の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……失礼ながらそう思った位でしたが、そのなかであの若宮さんの芸妓だけは、脚本を離れて、いかにもそうありそうな、無理のない……ことに、あの、しまいに気の違って来るところなんぞ、よくまァあれだけ、細かなしんみな芸がみせられる。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
