    "definitions": [
      {
        "index": 1,
        "gloss": "purificatory font at shrines and temples",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから水屋の窓先に実っている柚子を※ぎ取り、これを二つに割り、柚子の酢を混ぜた味噌を片方ずつの柚子の殻に盛りました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこが水屋のように出来ていて、それから大廊下へ出入口に立てたのが件の金屏風。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……段の上り口の傍に、水屋のような三畳があって、瓶掛、茶道具の類が置いてある。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "道子は湯呑みを出そうとして、水屋の戸をあけようとした。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "タンス、本箱、机、椅子、座蒲団、水屋、雨傘、洗面器の類まで買い与えたので、へそ繰りを全部投げ出した上に、借金が出来る始末だった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手には机に近く茶器を並べた水屋と水棚があって、壁から出ている水道の口の下に菜種と蓮華草の束が白糸で結わえて置いてある。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "多く夏の釣でありますから、泡盛だとか、柳蔭などというものが喜ばれたもので、置水屋ほど大きいものではありませんが上下箱というのに茶器酒器、食器も具えられ、ちょっとした下物、そんなものも仕込まれてあるような訳です。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "水屋口に山椒の木が在りましたがあまりの老木なので葉は僅か許りしか出ませんでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜中におなかがすいたら、水屋の中に餅がはいってますから……」勝手に焼いて食べろ、あたしは寝ますからと降りて行こうとするのを呼び停めて、「あの原稿どこにあるか知らんか。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからわざと起さず、紅茶を淹れ、今日搗いて来たばかしの正月の餅を、水屋から出して焜炉の上に乗せ乍ら、「どうしてた。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "菓汁の飲料を売る水屋の小僧もあき罐をたたいて踊りながら客を呼ぶ。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は梯子段をあがりながら、飯を喫ったなら清水屋へ往って、引きとるか引きとらないかをしかと定めようとおもった。",
              "citation": {
                "source": "女の首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園の附近に網を張って壮い女を覘っているこの悪漢は、今晩誘拐して来た女を、清水屋という怪しい家へ渡すことにしてそこで酒の饗応になって帰って来たところであった。",
              "citation": {
                "source": "女の首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「米びつがけさでからだから、清水屋の小僧が来たらおいいなせえよっていっといたはずですが、まさかお忘れじゃねえでしょうね」　すると、右門という男は、どうもどこまで変わり者だか、すましていったものです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "きさま清水屋にお糸っていう小娘のあること知っているな」「え？",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "知ってますが、清水屋っていや米屋じゃござんせんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "水屋があって、風炉には松風の音がたぎっているし、これはまたどうでがす。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さなテレビと、それに、ちゃぶ台と水屋がある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷水屋を出て少し行くと、鉄道の踏切だった。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "（燈籠屋は盆燈籠の荷をおろして、駒寄の石に腰をかけ、水屋は障子屋根の屋臺を卸して立つ。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）燈籠屋　どうですね、水屋さん。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "水屋　　いや、なか／＼さうは行きませんよ。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに此邊は掘井戸が多いから、水屋は一向御用なしさ。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "水屋　　おたがひに樂は出來ませんよ。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き損じの原稿をやきすて、新しい方にみずやなどを持ち込む。",
              "citation": {
                "source": "日記",
                "author": "一九二〇年（大正九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間や馬や鳥や魚や、それから甲むしや蝶々やみみずや……みんな動物です」　これはヒトミが答えた。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "神前には紅白の落雁が四つ供えてある、三十銭を奉納してこの供物をいただき、弁当の残りだというみずやき（うどん粉を溶いた中に菜漬を入れて焼いたもの）を一つ老人から貰い受け、少し気力を恢復して、一里の暑い野原路を台ヶ原までまっしぐらに急いだ。",
              "citation": {
                "source": "木曾駒と甲斐駒",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早く、車体検査のため、沢田がトラックを運転して出た後、彦太郎は油で汚れた手を洗濯石鹸で洗って、柱に腰を下すと、昨夜残しておいた焼酎のあったのを思い出し、細目の金網の張ったみずやの中から一升徳利を取り出した。",
              "citation": {
                "source": "糞尿譚",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
