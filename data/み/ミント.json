        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "からいおひやをよばれる、ペハアミントをよばれる、いやはや。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして重い緑色のペパミントと濃い珈琲とを併せ飲んだ。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから自分がベッドカバーとして使っているペパーミントの葉を取って来て、ツバメの頭にかぶせました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミルテやペパーミントのかぐわしい香りもただよってきます。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから押入れを開けてみると、自慢のレミントンの二連銃と一緒に、狩猟の道具が消え失せている。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もお金の多寡はハッキリわかりませんがね……それから、もう一つ重要なのは、屍体の左手にシッカリと握っていたレミントンの二連銃の中に、発射したままの散弾の薬莢が二発とも残っていた事だそうです」「ハハア……詰め換えないままにですな」「そうです。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実松氏はその幻影と闘うべくレミントンの火蓋を切られたのです。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "露西亞ノ外蒙古進出ニ押サレテ日本亦内蒙古ニ進出シテ防備ヲ試ミントスル軍閥ノ支那保全策ハ、或ル程度ニ於テ支那ヲ保全シツツ或ル程度ニ於テ支那ヲ分割スル者。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "君もまた色青きペパミントの酒に、かなしみの酒に、いひしらぬ慰藉のしらべを、今日の日のわがごとも、あはれ、友よ、思ひ知り泣きしことのありや。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一層悲しげに見える料理店の桃色の窓枠の間々には、もう新鮮さを失った飾花や、焼きざましのパイの大皿や青いペパミントのくくれた罐などがある。",
              "citation": {
                "source": "小景",
                "author": "――ふるき市街の回想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の大晦日は林町で二三時頃まで過し、雪の凍ってつるつるする街路を、Ａと小林さんと三人で、頼まれたペパアミントを探し乍ら、肴町を歩いたのを思い出す。",
              "citation": {
                "source": "二つの家を繋ぐ回想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この特許を逃れるために菊の花弁をバドミントンの羽根の形に変えて開発した新シリーズの中位機は、特に好評を博した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七八（昭和五十三）年四月、印字機構の形からバドミントンプリンターと名付けられていたこの製品の新機種が発表された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "作表機市場でＩＢＭにはるかに差をつけられながらも二番手につけていたレミントンランドは、一九五一年、コンピューターの開発事業に乗り出していたエッカートとモークリーによるマシンをＵＮＩＶＡＣと名付け、初めて商品として売り出した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＵＮＩＶＡＣから遅れることおよそ二年、科学技術計算用の７０１の発表にこぎ着け、続いて事務処理用の７０２を発表したＩＢＭは、徹底した低価格攻勢によってレミントンランドを追いかけた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれに反して私が辿って行く岨道は、冷たいペパミント色の薄暗に蔽われて、木の下の道なぞは月夜のように暗かった。",
              "citation": {
                "source": "眼を開く",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "只レミントンのタイプライターと電話器とこのガソリンランプが一台残っているばかりです」　私は地下室へ這入って見る気も出なかった。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『｜鷹の城』を快走艇に外装した――それが、古臭いバドミントン叢書になんの関係があるんだい。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさしくそれが、貴女の心の暗い秘密――不倫の恋が打ち出した怖るべき犯罪だったのです」　と、先刻検事が嘲ったバドミントン叢書の「操艇術」を取り出してきたとき、その驚くべきほど劇的な一致が、今や動かしがたい事実となって現われた。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「メリケン仕入れの最新式、レミントン」「なアるほど」「もと込めです、手にとって調べてみて下さい」「おッと――これは軽い、なるほど、なるほど」と阿賀妻は遊底を動かしてみて床尾を肩に構えてみた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちらりと彼の脳裡に映ったのは石狩役所で見たレミントン銃であった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の直ぐ下の潮はペパミントの酒になる。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の注いだペパミント男の手から飲まうもの。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この昼の若葉を透す日の色はほんに酒ならペパミント、黄金と緑を振り注ぎ、広く障子を開けたれば、子供のやうな微風が衣桁に掛けた友染の長い襦袢に戯れる。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "志村の大将、その時分は大真面目で、青木堂へ行っちゃペパミントの小さな罎を買って来て、「甘いから飲んでごらん。",
              "citation": {
                "source": "片恋",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、僕は志村のペパミントの話をして、「これは私の親友に臂を食わせた女です。",
              "citation": {
                "source": "片恋",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ五百元でも、こっちのペパミントがいい。",
              "citation": {
                "source": "毒瓦斯発明官",
                "author": "――金博士シリーズ・５――",
                "note": "青空文庫"
              }
            },
            {
              "text": "生返事をしただけで、彼はなおも飾窓の青いペパミントの値段札に全身の注意力を集めている。",
              "citation": {
                "source": "毒瓦斯発明官",
                "author": "――金博士シリーズ・５――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
