        "examples": {
          "standard": [
            {
              "text": "体育の時間、先生の「右へならえ！」という掛け声で生徒たちが素早く整列した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "軍隊の訓練で、一糸乱れぬ動きで右へならえをする兵士たちの姿は圧巻だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "運動会の開会式で、緊張した面持ちの子供たちが一生懸命に右へならえをしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "平家に非ずんば人に非ずといった言葉も、むしろ当然のように迎えられたし、六波羅風と言えば、猫も杓子も、右へならえで、烏帽子の折り方やら、着つけの仕方まで、皆が平家一族を真似するのである。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばあまりの緊張のあまり、「かしら右」と言うところを「右へならえ！",
              "citation": {
                "source": "赤い駱駝",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
