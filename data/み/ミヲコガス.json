        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "初めて会った瞬間から、彼は彼女に身を焦がすほどの恋をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遠く離れた恋人を思い、毎晩身を焦がすような切なさに襲われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "嫉妬に身を焦がし、彼は友人の成功を素直に喜べなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "身を焦がすほど激しい恋じゃ。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳴かぬ螢　「恋にこがれて鳴く蝉よりも、鳴かぬ螢が身を焦がす」といいます。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "茂吉はただもう身を焦がすだけ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "欄干の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "人口の中の少ないパーセンテージながら常にある種の人々がおり、未知の外宇宙への身を焦がすような好奇心を持ち、既知の現実という牢獄から逃げ出して信じ難い冒険と限りない可能性をもつ魅惑の国へ行きたいという燃えるような願いを持っているのです。",
              "citation": {
                "source": "怪奇小説の執筆についての覚書",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからゴリオ氏が彼女のところに身を落ち着けたその日、ヴォーケ夫人は夜寝る時、まるで薄皮に包まれてあぶり焼きにされるヤマウズラのように身を焦がす思いがした。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
