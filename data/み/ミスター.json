        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ロンドンの宿に同宿していた何とかいう爺さんが、夕飯後ストーヴの前で旨そうにパイプをふかしながら自分等の一行の田所氏を捉まえて、ミスター・ターケドーロと呼びかけてはしきりにアイルランド問題を論じていた。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ミスター・ロウが描いて呉れたんですよ。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――市長ですか、市長は今朝五時半まであの娘さんとスコットランドの金持ちミスター・ジョージと三人でルイジで小夜食を喰べ乍ら一緒に居ました。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お気の毒ですが市長マシップ氏も、ミスター・ジョージも西班牙へ御同行出来ません。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この花は市長マシップ氏と、ミスター・ジョージとの贈物です。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "在席者――小説家ミスター・ドライ。",
              "citation": {
                "source": "新興芸術派に就いての雑談",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "同ミスター・ウエット。",
              "citation": {
                "source": "新興芸術派に就いての雑談",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "同ミスター・Ｓ・マキノ。",
              "citation": {
                "source": "新興芸術派に就いての雑談",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミセス、そしてミスターＲは、相変らず私を先輩として尊敬してゐます。",
              "citation": {
                "source": "満里子のこと",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が短い足で歩く工合はあぶなさうな容子だといふのでミスター薄氷と綽名された位だからどうしても上目使ひになる。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便屋だと思ったんだろ」　といって、〈ミスター・ポウストマン〉のファーストラインを口ずさみながら、高志は、受けとった紙袋から薄い本をひっぱりだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高飛び、素早い逃走、共犯者なし、貴族趣味――こういったやり口が、ミスター・ヴァレンタインを罪からうまく逃れる男として、有名にさせたのだ。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ミスター Happy Pendulum!」　と私の仇名を呼んで立ちあがつたのは、村役場の執達吏であつた。",
              "citation": {
                "source": "酒盗人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ところがね、それを、橇引きのミスター伝に発見されたことを、さつき知つたのさ。",
              "citation": {
                "source": "山男と男装の美女",
                "author": "ミツキイのジヨンニイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、英語を喋る国の女が、自分の良人を第三者に対して話す時には、ミスター・誰々と姓を呼ぶ、それと共通な心理なのだと抗議を申し込むでしょう。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼に対して公訴を提起した王冠法曹（The Counsel bor the Crown）はボドキン氏、そうしてスミスの為に弁論を行つたのは有名なエドワード・マーシャル・ホール卿（当時ミスター）で、裁判長はスクラトン氏であつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、ミスター・エモット（当時全院委員長の椅子を占めていた人）、これはこれ一の戦争予算である。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六六（昭和四十一）年、当時の社長、小林宏治の抜擢によって新設された集積回路設計本部長となってから、日電の半導体事業を育て上げてきた、ミスター半導体である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "定価を二〇万円台とする常識的な案と、一〇万円台とする渡辺の案は平行線をたどっていたが、最終的には日電のミスター半導体、大内淳義の裁定によって渡辺案に決した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『マイコン入門』（廣済堂出版）の著者であり、〈ミスター半導体〉の大内淳義副社長や、わが国コンピュータ研究開発の草分けで、ソフトウエア技術の第一人者、水野幸男取締役らも、このマイコン勉強会で若い女性講師の『マイコンの動かし方』『プログラムの作り方』といった実技指導、講義の聞き役に回る。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの人びとは、きまって「ミスターＫ・ニシを知っているか？",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらは「ミスター・ニシは、わがはいの良き教師である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "記事によれば、取材をかねて年に数度はアメリカに行くという西は、米国の関係者には「ジャパンのミスター・ニシ」として知られており、六月には全米コンピューター会議（ＮＣＣ）で「極東におけるマイクロコンピューティング部会」の座長を務め、日本の現状を報告してきたという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダム・レースやミスター・ワイシャツや、マドモアゼル・ハンカチの衆愚に、こんな姿をさらすのが厭なのです。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダム・レースや、ミスター・ワイシャツや、マドモアゼル・ハンカチの衆愚に、こんな姿をさらすのが厭なのです。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故痣蟹に知らせて、利用させたのだ」「わたくし痣蟹と称ぶミスター北見仙斎を信用していました。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、ミスター・ホムラ。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "編　それと共にその他のアメリカ作家のもの、例へば先だつて日本でやつたソーントン・ワイルダーの「ミスター・人類」などをみても、なにかいままでの形式で書いてゐてはもどかしくてしかたがない。",
              "citation": {
                "source": "対話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼に随いて、この門まで足を運んだ背の高い看守が、釈放囚の肩をぽんと叩き、「じゃあミスター・Ｆ。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃあ、気をつけていくがいい」「……」　ミスター・Ｆと呼ばれたその釈放囚は、新聞紙にくるんだ小さい包を小脇にかかえて、無言のままで、門を出ていった。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
