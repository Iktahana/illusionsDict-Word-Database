    "definitions": [
      {
        "index": 1,
        "gloss": "visitor to a sick or distressed person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "家の中は、見舞い客で混雑していた。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "裕福かと思えば、見舞い客が少ないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だのに、あれほどの騒ぎがあって見舞い客がひとりもいねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "押し寄せて来た多数の見舞い客の挨拶はまだことごとくは取り次ぎきれずに、家従たちの忙しがっている所へ左大将が涙をふきながら出て来た。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お見舞い客が皆去ったあとの静かな夕方であった。",
              "citation": {
                "source": "源氏物語",
                "author": "蜻蛉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで例の見舞い客に振れ舞う土瓶らの茶碗酒を我々にも飲ませたが、我々はそこへ腰をかけたままで、もう火事の句数句を作る、また主人も作るという風で周囲の他の人々は呆れ顔をしていた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　　　　　＊　本を読んでいるときに来る見舞い客は決まったように、「お退屈でしょう」と言う。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "重病人の部屋であるから、静粛、清潔ということを医師や看護婦にくどく言い渡されていたし、時々見舞い客もあることだから、万年床をしきッ放してヒルネもしていられない。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "明くる日は朝から見舞い客が来た。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "事情が事情なので見舞い客はみんな玄関で帰って貰った。",
              "citation": {
                "source": "日本婦道記",
                "author": "藪の蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "アパートへの見舞い客はこの玉塚だけではなく、慷堂先生もわざわざ来てくれたが、今は丸万留吉の来訪を語ろう。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
