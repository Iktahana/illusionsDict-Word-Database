[
  {
    "uuid": "b2ab043c-7821-5a04-a886-07f3eec3b664",
    "entry": "店構え",
    "reading": {
      "primary": "みせがまえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
