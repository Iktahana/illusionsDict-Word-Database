    "definitions": [
      {
        "index": 1,
        "gloss": "Eurasian wren (Troglodytes troglodytes)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
