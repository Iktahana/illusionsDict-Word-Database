    "definitions": [
      {
        "index": 1,
        "gloss": "to the right (in location)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "寄宿舎の右寄りの上にも二軒の二階家が涼しそうな顔を見せていた。",
              "citation": {
                "source": "変災序記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡い翡翠いろの大沼の水面の右寄りにチョコレート菓子をちょんと一つ置いたような形のものがあります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "松原の幅は百間から二百間、その間にほゞ中央にではあるが、時には右寄り左寄りに我等の歩く徑が通じてゐる。",
              "citation": {
                "source": "樹木とその葉",
                "author": "春の二三日",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その半島の尖端の松輪崎といふのは私たちの浜からやゝ右寄りの正面に細く鋭く浮んで見ゆる。",
              "citation": {
                "source": "岬の端",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "男體山の右寄りにやゝ開けて見ゆるあたりは戰場ヶ原から中禪寺湖であるべきである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "男体山の右寄りにやや開けて見ゆるあたりは戦場ヶ原から中禅寺湖であるべきである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうちよつと右寄りだ。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑の様子はよくわからないが、右寄りの方には、お寺の屋根の頂が見えています。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "この坂は道より少し右寄りに登った方が楽だ。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この谷にはよく雪庇ができているので、なるたけ右寄りに巻いて谷を渡る方が安全である。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そのうち右辺からかけて室を一周し終ろうとする際に、思いがけなくも、法水のすぐ横手――扉から右寄りの壁に闇が破れた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人は、それを把手とその右寄りの板壁の隙間に挾んだ鍵との間に、六、七寸の余裕を残して張ったのだよ。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、この日和下駄は被害者が履いていたのだそうだ」　堂の右端にある敷石から、そこと大石との間を往復している雪駄の跡があって、もう一つその右寄りに、二の字が大石の側迄続いているのだが、日和下駄はそこへ脱ぎ捨てられてある。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹がへって目が廻りそうなので、赤岳へ最短コースによって登るべく、バットレス正面やや右寄りのチムニーに入ったところが、不精の天罰てき面、とたんに雨をくい、チムニー上部で苦心した。",
              "citation": {
                "source": "八ガ岳大門沢",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "その山形の右寄りの肩のあたりで、セーヌは幅広くなって、二つの島を浮かべている。",
              "citation": {
                "source": "パリの地下牢",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右寄りのものが地図に記入された千七百二十米の圏である。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "諦めてどうでもなれという気になって、其処らを足掻き廻っている中に、雑木が次第に殖えて、恐ろしく背の高い偃松が姿を顕わしたと思ったら、うまく切明けに出た、長次郎が休んでいる、南日君と実君はずっと右寄りの藪の中から、笹葉を背負った蝟のような姿をして出て来た。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは画面で言ふとこの右寄りのあたりに群がつてゐるさまざまの象が混り合つて生れ出た、説明のできない調子なのだから。",
              "citation": {
                "source": "恢復期",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "遥かに姨捨駅の赤い屋根が見え、やや右寄りの方には、千曲川向うの塩崎の長谷寺の大きな茅屋根が見えた。",
              "citation": {
                "source": "野の墓",
                "author": "岩本素白",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一傷が物凄くて、あんなヒョロヒョロの短刀なんかじゃありませんよ」「どこを切ったんだ」「喉笛、少し右寄り、前から後ろへ突き抜けるほどの傷で――部屋の中には血の気もない短刀が一つ」「フーム、だいぶ変っているな、行ってみよう」「そいつは有難い」　平次はさっそく仕度に取かかり、本郷二丁目に向いました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "密室",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一傷が物凄くて、あんなヒヨロヒヨロの短刀なんかぢやありませんよ」「何處を切つたんだ」「喉笛、少し右寄り、前から後ろへ突き拔けるほどの傷で――部屋の中には血の氣もない短刀が一つ」「フーム、大分變つて居るな、行つて見よう」「そいつは有難い」　平次は早速仕度に取かゝり、本郷二丁目に向ひました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "密室",
                "note": "青空文庫"
              }
            },
            {
              "text": "傷は右寄りに喉へ一ヶ所、凄まじい血潮を見ると、下手人の手際の恐ろしさは舌を卷かせるばかり。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お登世の戀人",
                "note": "青空文庫"
              }
            },
            {
              "text": "右寄りの、まだ一カ所だけ修繕のゆきとどかないで破れたままになっているガラス窓の穴から見える黒い戸外の闇の中に音もなく雪の降っているのが、内部からの電燈の光に照らされてチラチラと白い。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳敷きの上がり框は、その凸字形の土間から両側へ区分されていて、店主は這入って右寄りの方の畳の間に紫檀の小机をすえ、好みの文房具やら印譜などを並べて、ちょっとした煎茶家か文人の書斎めかしたそこへ坐って、時々、頬杖ついているにすぎなかった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その右寄りの斜面に、頭を稜線に触れそうにして、このはにかみやのお爺さんはひそやかに立っていた。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――飴色になった仕事台の上の、ちょっと右寄りに、厚さ三インチばかりの板が立ててあり、豚の毛を入れた筒とか、ブラッシの台木、ごくぼその針金、にかわの鍋などの材料が、良さんの左右に並んでいた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右寄りの山脚は急に反つて、此の山あひの盆地を覗きこみ、其の膚には六月の新緑を想像するに餘りある美しい闊葉樹林がおほふてゐる。",
              "citation": {
                "source": "黒岩山を探る",
                "author": "沼井鐵太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も右寄りだった時期には、共産主義者は自分達よりも左寄りの党派全てを同様のやり方で非難した。",
              "citation": {
                "source": "ファシズムとは何か",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪だたみがつきて、道が二｜股にわかれる所へ来ると、男はツウと、また右寄りへ進もうとした。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
