    "definitions": [
      {
        "index": 1,
        "gloss": "completely unknown (usu. of people)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
