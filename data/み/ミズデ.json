    "definitions": [
      {
        "index": 1,
        "gloss": "declaring one will participate in the game without first looking at one's dealt hand (when being the dealer)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それはとにかく、あの運動遅鈍なみみずでさえ、同じ種族と考えられるものが、「現時の大洋」を越えてまでも広がっているという事実を一方に置いて考えてみる。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、豹吉は向うみずではあったが、莫迦ではなかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、四ばんめのおねえさまは、それほどむこうみずではありませんでしたから、そこで、ひろい大海のまんなかに居ずくまったままでしたが、でもそこがどこよりもいちばんうつくしかったと話しました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、目の見えないみみずで、目が不自由なものですから、こんなに来るのに手間をとってしまったのです。",
              "citation": {
                "source": "物のいわれ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――姉さんは、案外世間みずで、つまらない生活をしてゐると思ひますよ。",
              "citation": {
                "source": "秋果",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、毎日毎日、筏を組んで漂流する練習ばかりしたンですから、そんな事をしてゐるうちに段々自分は怖くなつてきて逃げ出したくなりました……」「さうさ、どうも、此の戰爭はたゞでは濟まんと考へてゐたが、えらい不始末をしでかしたものさねえ、何しろ向うみずで、勘のやうなもので戰爭を始めたンだから。",
              "citation": {
                "source": "雨",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は、やはり川虫とみみずで釣った。",
              "citation": {
                "source": "莢豌豆の虫",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「切取、強盗は武士の習い」とか、「分捕功名、鎗先の功名」とか、体裁のよい遁辞の前に、いわゆる大功は細瑾を顧みずで、多くの罪悪が社会に是認され、為にその犠牲となったものが、到る処に発生した。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "くらも、　うらぐちへ　つづく　ろうかも、　みずで　びちゃびちゃ　つるつる。",
              "citation": {
                "source": "つりびとジェレミーさんのはなし",
                "author": "THE TALE OF MR. JEREMY FISHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって　めのまえで　おおつぶの　あめが　いけに　ぱしゃぱしゃ　ふっているんですから　――「みみずでも　つかまえて、　つりにでも　でかけて、　ばんごはんに　もろこでも　１さらぶん　とるか。",
              "citation": {
                "source": "つりびとジェレミーさんのはなし",
                "author": "THE TALE OF MR. JEREMY FISHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は意識的に子供らしくて、非道徳的で、むこうみずで、快活で、うぬぼれていて、しかも病気になってさえ得意になれるほど、健康なのだから、彼等の虚栄心は、まだ一度も傷つけられたことがない間は、実際気持のいいものである。",
              "citation": {
                "source": "ルイスヒェン",
                "author": "LUISCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "千菊丸は　うばに　つれられて　きよみずでらに　おまいりに　いきました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
