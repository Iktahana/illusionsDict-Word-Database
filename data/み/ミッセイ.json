    "definitions": [
      {
        "index": 1,
        "gloss": "growing thickly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "隙間なく密生しても活力を失わないという特徴があるために垣根の適当な素材として選ばれたのであろう。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しはなれて見ると密生した梢の色が紫色にぼうと煙つたやうに見える。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらは樹がまた密生して居た。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に自然に生える烏瓜も搦んで、ほとんど隙間のないくらいに色々の葉が密生する。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉松の林中には蝉時雨が降り、道端には草藤、ほたるぶくろ、ぎぼし、がんぴなどが咲き乱れ、草苺やぐみに似た赤いものが実っている、沢へ下りると細流にウォータークレスのようなものが密生し、柵囲いの中には山葵が作ってある。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が顔を洗う前足の横側には、毛脚の短い絨氈のような毛が密生していて、なるほど人間の化粧道具にもなりそうなのである。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉の秀が細胞のように密生している遙かな谿！",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "柔毛の密生している、節を持った、その部分は、まるでエンジンのある部分のような正確さで動いていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから少しきたない話ではあるが、昔｜田舎の家には普通に見られた三和土製円筒形の小便壺の内側の壁に尿の塩分が晶出して針状に密生しているのが見られたが、あれを見るときもやはり同様に軽い悪寒と耳の周囲の皮膚のしびれを感ずるのであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しはなれて見ると密生したこずえの色が紫色にぼうとけむったように見える。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると細かく密生した苗床を草履か何かですりつぶしたりする。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になると曇るので気づかずにいたが、もう九日ぐらいだろうかと思われる上弦というより左弦ともいうべきかなり肥った櫛形の月が、川向うの密生した木立の上二段ほどの所に昇っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠い水は瑠璃色にのして、表面はにこ毛が密生しているように白っぽくさえ見える。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "叩いてみると軽いすか／＼の音がして七五三縄を張るほどの神秘性もなく、寺の本堂の屋根の辺よりも高い空中から急に枝葉を密生さした、さゝくれた古｜箒のような形でやゝ南方に傾いています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分は傍の蓬の若葉の密生した上へ蹲った。",
              "citation": {
                "source": "明暗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのツンドラ地帯にはフレップという紅い果の生る灌木が密生していましてね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャック（馬）を連れて来たのだが、河床の上に樹々が低く密生して馬は通れないので、叢林の中の木に繋いで置く。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭上の枝葉はぎつしりと密生んでゐて、葉洩日も殆ど落ちて來ない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の跡らしいもの、井戸の形をしたものなどが、密生した羊齒類の間に見え隱れする。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "島内を一巡して見たが、島中、椰子と蛸樹と麺麭樹とがギツシリ密生してゐる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが年收五萬乃至七萬に上るといふ（椰子の密生した島を有つてゐるといふだけで、コプラ採取による收入が年にその位あるのだ）大酋長とは一寸思はれなかつた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭上の枝葉はぎっしりと密生んでいて、葉洩日もほとんど落ちて来ない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の跡らしいもの、井戸の形をしたものなどが、密生した羊歯類の間に見え隠れする。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "島内を一巡して見たが、島中、椰子と蛸樹と麺麭樹とがギッシリ密生している。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが年収五万ないし七万に上るという（椰子の密生した島を有っているというだけで、コプラ採取による収入が年にその位あるのだ）大酋長とはちょっと思われなかった。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に或る深山の谷間を通ったら福岡地方で珍重する忍草が、左右の崖に夥しく密生しているのを発見したので、奈良原到が先ず足を止めた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝の若芽が延びそめると同時に、この密生した葉の林の中から数限りもない小さな生き動くものの世界が産まれる。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白い刃が垂直に平行して密生した芝の針葉の影に動くたびにザックザックと気持ちのいい音と手ごたえがした。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉は根もとを切られてもやはり隣どうしもたれ合って密生したままに直立している。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むごたらしい人間の私は、三毛がこの防腐剤にまみれた足と子猫で家じゅうの畳をよごしあるく事に何よりも当惑したので、すぐに三毛をかかえて風呂場にはいって石鹸で洗滌を始めたが、このねばねばした油が密生した毛の中に滲透したのはなかなか容易にはとれそうもなかった。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
