    "definitions": [
      {
        "index": 1,
        "gloss": "volume of water (in a river, pond, flood, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "川はちょうど雨のあとで水かさが増していた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「川も春になると、雪解で水かさが増えるでええのう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "水かさのました稲田から流れ込んだ浮き草が、ゆるやかに回りながら、水の面へ雨のしずくがかいては消し、かいては消す小さい紋といっしょに流れて行く。",
              "citation": {
                "source": "竜舌蘭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりろ」　ふたりが馬を捨てて、土手を下りながら長つゆのあとの水かさのました水面に近づいてよくよくみると、二つとも女の持ちものなのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　川は長雨に水かさを増して、岸を洗う大波小波、青葉に茂る並み木の土手を洗いながら、雨はまた雨で墨田のふぜいなかなかに侮りがたい趣でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "船頭、急げ、急げ」　水かさを増した大川をひと下り。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはかなり水かさのある河だったが、二人は堤防の石垣に手をかけて無事に地上へはい上がった。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し行ったら水かさのました川で柳があたまだけ水から出して揺れていた。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つれづれと身を知る雨のをやまねば袖さへいとど水かさまさりて　という歌を長く手から放たずながめ入っていたのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾分、ふだんより亢奮して居るので、まるで、水かさのました急流の様に、せくにせかれない勢で、想像がドウドウと流れて行く。",
              "citation": {
                "source": "熱",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし舟が小さいので、少し風が強く吹いたり、雨が降って水かさが増したりすると、舟はたびたびひっくり返りそうになりました。",
              "citation": {
                "source": "一寸法師",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "水かさを増した川で鮒釣りする蓑姿。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "月が大きくなるにつれて、海の水かさはますし、潮の色も複雑になって来る。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき水かさはまして、八木君の乳のあたりから下をひたしていた。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう五十センチも水かさが増せば、いやでも土左衛門だ。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく一段を掘り、次にその上の第二段目を掘っていると、水かさがましてきて、はじめの第一段をひたしてしまう。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "河の水かさが増して濁ってくるのが。",
              "citation": {
                "source": "旅だち",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "迫る硝子天井　水槽の中の水かさはいよいよ増した。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭が硝子天井につかえるまでに水かさは増した。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、水かさは更にずんずん増して来るではないか。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川の水かさが少しました。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ氷山も雪原も一度に融けだしたんだから、町という町、防空壕という防空壕は水浸しになり、水かさはどんどん殖えていく。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "川上には、どこかで大雨が降ったとみえて、水かさが増していました。",
              "citation": {
                "source": "海ぼたる",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "水かさは、空っぽになった放水溝の土台をさえ下※る始末で、その水かさを手っとり早く上げようと色々苦心はしてみたが、いつかな成功しなかった。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "水かさだってずっと多いわ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは通常冬は水かさがのぼり夏は落ちるが、一般的降雨の多少とは合致はしない。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅雨時の谷川は、水かさを増して、山の上からエライ勢いで逆落しに、用水堀の中へ落ちて居ります。",
              "citation": {
                "source": "古城の真昼",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳之助　文太の奴め、ゆうべの雨で水かさました益田川の流れに落ちた。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "水かさが一歩ごとにますようでこの先へ行くのは不安になったとき、つれの男は、一つの狭い入口の前で止った。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
