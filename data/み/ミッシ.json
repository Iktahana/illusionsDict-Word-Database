    "definitions": [
      {
        "index": 1,
        "gloss": "secret messenger",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然るに後年、京城の諸士にして、かの北狄の囘文を受けたるもの少からず、事顯はるゝに及びて、官司、其の密使を案討するに、無足の婦人即ち然り、然も奸黨の張本たりき。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内に未だ紛争が絶えぬ故、今暫く猶予され度い、と、取敢えず使を以て言わせたが、其の使者と入れ違いに衛の太子からの密使が晋に届いた。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "國内に未だ紛爭が絶えぬ故、今暫く猶豫され度い、と、取敢へず使を以て言はせたが、其の使者と入れ違ひに衞の太子からの密使が晉に屆いた。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏姫が鄭に着くと、それを追いかけるようにして巫臣の密使が鄭に行き、夏姫を聘し度い旨を伝えた。",
              "citation": {
                "source": "妖氛録",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち宿老松田憲秀であって、密使を早雲寺の秀吉に発し、小田原城の西南、笠懸山に本営を進むべきことを説いて居る。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ郡主馬宗保の密使が來て、今軍兵が寄せると云つた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもあと十日とたたぬ間もなく江戸から御分銅改めの密使が到着することをちゃんと知っていながら、そのうちの何本かを融通したため、騒ぎは愈々大きくなって、長門守は当然の結果のごとく厳罰に問われることになったのでした。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これぞ赤きコミンテルンの国、ソビエト連邦の密使であって、元海軍人民委員長という海軍大臣と軍令部長とを一しょにしたような要職にいた軍人であった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当にそれをやるつもりなら、なぜもっと極東に兵力をあつめないのです」　とソ連の密使ハバノフ氏は叫ぶ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍを密使として送った上海の同志等は、最初、（二十六字削除）。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして明晩城に火をかけるからお前達は逃げてこいという密使がきたわけですが、その時に女の人は何と申しましたかといえば、私はもう女として生きることはこりこりだ、自分は今までに二度結婚させられている。",
              "citation": {
                "source": "幸福の建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スーラーブは、アフラシャブの所へ送るべき密使のこと、至急調るべき糧食、武器などのことに就て、相談した。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフラシャブの許に至急送られた密使も、二十日後、スーラーブの、満足する返答を得て来た。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四郎左衛門が京都に上つてからも、浮田村の家からは市郎左衛門が終始密使を遣つて金を送つてゐた。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "御上の御配慮はそこにあるので、この出羽に何とか分別無いかと、それ故の御密使であろう。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴は密使に相違ないと僕も思う。",
              "citation": {
                "source": "人間レコード",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと以前からネバ河口の信号所の地下室で作り出して欧羅巴方面の密使に使用しておったものじゃが、この頃日本の機密探知手段が極度に巧妙になって来たのでヤリ切れなくなって使い始めたものに違いない。",
              "citation": {
                "source": "人間レコード",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それに、国許より度々の密使が、斉彬公の許へ参っております」「そうあろう」「国許では、久光公がござるゆえ、かようのことも起る。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "醤買石閣下の密使だそうです。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "醤の密使｜油蹈天氏が、その部屋に現れたのは、それから五分ばかりたって後のことであった。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が来るようじゃ、大した土産もないのであろう」　博士は、密使の顔を見て、率直に落胆の色を現した。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なら、用談より先に、これをごらんに入れましょう」　密使は、背中に負っていた大きな包を、機械台のうえに下した。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら燻製にしても、羊特有の、あの動物園みたいな悪臭は消えるものか」「まあ、黙って、これをごらん下さい」　密使油が、包を派手にひろげると、中から鼠色の大きな動物が現れた。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "重慶か、成都か、それとも昆明か」　博士の質問は、密使油にとって、甚だ痛かった。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、主席はぜひ博士の御好意によって、最近御発明になったあの……」　といいながら、密使は一応四方八方へ気を配った上で、「……あのう、それ、人造人間戦車の設計図をお譲り願ってこいと申されました。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそのときは、うんと代償物を用意して置けよ」　そういって、金博士は、大きな青写真にとった設計図を、惜し気もなく密使に渡してしまったのであった。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからこっちへ十年、遂にこの砂漠の一劃に、十年計画の重工業地帯が完成したのを機に、密使油蹈天をはるばる上海に遣して、金博士の最新発明になる“人造人間戦車”の設計図を胡魔化しに行かせたのであった。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで年下の信長を臆面もなく「父信長」などゝ尊敬して大いに徳としながら、さつそく裏では父信長を殺すことを考へて、本願寺に密使を送り、信玄と結び、朝倉、浅井、上杉、毛利、信長と兄弟分の徳川家康、手当り次第に密使を差向けて信長退治のふれを廻す。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つのものを一つに減らしてもその中の一番根本的な一つをみっしりよく理解し呑込んでしまえば、残りの二つはひとりでに分かるというのが基礎的科学の本来の面目である。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草の一番うまいのはやはり仕事に手をとられてみっしり働いて草臥れたあとの一服であろう。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
