        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "科学がキャピタリズムやミリタリズムやないしボルシェヴィズムの居候になっているうちは、まあ当分見込がなさそうに思われる。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、主として、力点をアンチ・ミリタリズム文学に置くと云ったまでのことである。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミリタリズムの気風が、最もさかんな中学であつた。",
              "citation": {
                "source": "塚越の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は、かういふ種類のミリタリスティックな気風は余り好かない、……ミリタリズムは嫌ひぢやないんだが。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には父の態度が、祖父母や母の古風なミリタリズムの教育風とは全くその趣きを異にして、突ぴよう子もなく自由気なのが余程の驚きであつた。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪鬼のごときミリタリズムがこの街にのしかかって来たのは、ずっと後のことのやうだ。",
              "citation": {
                "source": "広島の牧歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この分だと君らのミリタリズムは、当然ロシアと衝突せずにはおられまい。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ミリタリズムがロシアと衝突すれば、君、印度はどうする？",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "再びナチかミリタリズムの世になつて晶子歌が全部亡ぼされる日が来たら、私はこの一首だけを石に彫して地に埋めるであらう。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "演説と号令、政治家と軍人以外に少い声であるが、どちらも、一概に、デマゴジイ又はミリタリズムの声として貶し去るべき性質のものではない。",
              "citation": {
                "source": "「語られる言葉」の美",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（アンチミリタリズムの）　かえって仕事しようとして居たらオリガさんが居て実は悄気た。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月二十五日　火　海外ニュース（と云っても或見地をもった）にチャストーシカ〔四行詩の俗謡〕をつけてポーランドのミリタリズムを見せるところなど凄いぞ。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に、海外ニュースにミリタリズムやキャピタリズムの映画にストーシュカ〔たたく音〕を入れたのなど、どうしてエイゼンシュテインのおかめとまけぬ皮肉さだ。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを四十四年後に於ける今日の時勢に比較すると、吾々は殊にミリタリズムの暴圧の下に萎縮しつゝある思想界の現状に鑑みて、転た夢の如き感があると云つてもいゝ。",
              "citation": {
                "source": "虫干",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行船物干竿で届きさう紅太郎昔でたよこねの辺へ金ぐさり同船成の宗旨ミリタリズムと云ひ愛耳　第二句について、嘗て私はあるところへかうしたためたことがある。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "満寿子さんもシゴイさんも、馬鹿なミリタリズムの犠牲者にちがいないけど、そういう意味でなら、この戦争で死んだ男のひとも女のひとも、ことごとくとはいわざるも、ほとんどすべてはおなじ犠牲者でしょう。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがにレエヌさんもいにくくなったと見え、椅子から立ちあがると、扉のところで、憎悪をこめた眼つきでキャラコさんのほうをふりかえって、「ミリタリズム！",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）ということの根拠もあったわけだが、同時に之が学生に夫々のユニフォームを着せるという教育上のミリタリズムをも産んだわけだ。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ミリタリズム」より更に一層強き言葉を以ていえば武断主義、露骨にいえば侵略主義なるものが、今度の大戦乱を起したのである。",
              "citation": {
                "source": "大戦乱後の国際平和",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、国際法学者も、歴史家も、芸術家も、宗教家も、哲学家も皆「ミリタリズム」の渦中に投じて社会と一緒になってかかった。",
              "citation": {
                "source": "大戦乱後の国際平和",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "この先生は「ミリタリズム」の渦中に投じて働いた先生だ。",
              "citation": {
                "source": "大戦乱後の国際平和",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、彼はミリタリズムの型に熱中している。",
              "citation": {
                "source": "あめんちあ",
                "author": "富ノ沢麟太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
