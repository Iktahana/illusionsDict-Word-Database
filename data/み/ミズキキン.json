        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ニューヨークといえば、われわれのクラブの委員長であった松岡洋子さんはこのごろ水飢饉のニューヨークでどんな毎日を送っているだろう。",
              "citation": {
                "source": "この三つのことば",
                "author": "――わたしたちは・平和を・欲している――",
                "note": "青空文庫"
              }
            },
            {
              "text": "水飢饉のため、風呂沸かず、据風呂で沸かして運ぶ始末、心地悪し。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "入浴、水飢饉のため、階上迄水が揚がらず、据風呂を持ち込み、狭苦しいの何のって。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "待望の雨が少しだが降り出した、水飢饉が救はれる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月十七日（月曜）　雨は朝に至ってもひどく降ってゐる、水飢饉の折柄、いゝおしめりである。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座へ出て、小松理髪店へ、水飢饉で洗ふ水が無いさわぎ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々はおぼろげながら水飢饉がどんなものか分かり始めた。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
