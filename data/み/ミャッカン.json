    "definitions": [
      {
        "index": 1,
        "gloss": "(vascular) vessel",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
