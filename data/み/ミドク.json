    "definitions": [
      {
        "index": 1,
        "gloss": "unread",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "未読の書を瞥見する毎に異様な圧迫を覚えてならない。",
              "citation": {
                "source": "五月のはじめ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "未読の方に、すゝめたい。",
              "citation": {
                "source": "推賞寸言",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "附記――九月号の「文藝春秋」に発表される作は、これを書く迄に間に合はなかつたので未読であつたことを附け加へて置く。",
              "citation": {
                "source": "真夏の夜の夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かと賞めちぎることのかはりに、二三個所を抜萃して、未読の方へおすゝめ申すよすがとも為したい、且つは作者への敬意として。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは買ってもっているだけで未読ですが。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「緑色の目の白いネコ」という題名で足沢良子さんが児童書として翻訳されているようですが未読です。",
              "citation": {
                "source": "ドラムガニョールの白い猫",
                "author": "Ｊ. Ｓ. レ・ファニュ　J.S.Le Fanu",
                "note": "青空文庫"
              }
            },
            {
              "text": "未読の方はご注意ください。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷崎先生の全集第一巻の中、未読の「飆風」を読み出す。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "手際よく電文を見て再び封をして、未読のようにした。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
