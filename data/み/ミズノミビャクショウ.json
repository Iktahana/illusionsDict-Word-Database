    "definitions": [
      {
        "index": 1,
        "gloss": "poor peasant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小作料やら、納税やら、肥料代やら、さういつた生活費に追はれてゐて、何時まで経つても水呑百姓から脱することが出来ないのです。",
              "citation": {
                "source": "私有農場から共産農団へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十代まえからの水呑百姓、だけである。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と噛んで吐き出し、『水呑百姓。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩淵の渡場手前に、姉の忰が、女房持で水呑百姓をいたしておりまして、しがない身上ではありまするけれど、気立の可い深切ものでございますから、私も当にはしないで心頼りと思うております。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は子供心にも此樣子を見て不審に思つたといふは、其男の衣服から風采から擧動までが、一見百姓です、純然たる水呑百姓といふ體裁です、けれども校長の之に對する樣子は郡長樣に對する程の丁寧なことなので、既に浮世の虚榮心に心の幾分を染められて居た僕の目には全く怪しく映つたのです。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十男の水呑百姓と思つたのは、學校より十町ばかり隔だつて居る松林の奧に一構の宅地を擁し、米倉の三棟を並べて居る百姓、池上權藏といふ男で、大島小學校の創立者、恩人、保護者であつたのです。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこえらの水呑百姓と縁組が出来ると思うのか！",
              "citation": {
                "source": "栗の花の咲くころ",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は元來貨財なき水呑百姓なり。",
              "citation": {
                "source": "鹿島詣",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "小作料を徴収したり、成墾費が安く上がったりしたことには成功したかもしれませんが、農場としてはいったいどこが成功しているんでしょう」「そんなことを言ったってお前、水呑百姓といえばいつの世にでも似たり寄ったりの生活をしているものだ。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば左にも右くにも文部省が功労者と認めて選奨した坪内博士、如何なる偏見を抱いて見るも穏健老実なる紳士と認めらるべき思想界の長老たる坪内氏が、経営する文芸協会の興行たる『故郷』の上場を何等の内論も質問もなく一令を下して直ちに禁止する如き、恰も封建時代の地頭が水呑百姓に対する待遇である。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、祖父の道楽で、長年苦しめられた祖母が、死ぬ間際になって、手を合せながら、『お前さんの代で、長い間続いていた勝島の家が、一文なしの水呑百姓になってしまったのも、わしゃ運だと諦めて、厭いはせんが、せめて死際に、お前さんから、賭博は一切打たんという誓言をきいて死にたい。",
              "citation": {
                "source": "勝負事",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の母親は水呑百姓で、小学校にさえ行っていない。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれを二十何年間も水呑百姓をして苦しみ抜いてきた父や母の生活からもジカに知ることが出来る。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちとらのような、水呑百姓が大根一本だって、人にくれられるけ。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "節用集を食ふ８・24（夕）　先日七十三の老齢まで女遊びをしたといふ西依成斎の事を書いたが、成斎の生れた家は、熊本在の水呑百姓で、両親は朝｜夙くから肥桶を担いで野良へ仕事に出たものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、土に塗れた水呑百姓が、大きな黒牛を追ひながら、のつそりと通りかかるのが目についた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿様、地頭様、庄屋様、斬りすて御免の水呑百姓という順序で息もつけなかった昔から、今日地主、小作となってまで東北農民の実生活は、果してどの程度の経済的向上が許されたであろう。",
              "citation": {
                "source": "村からの娘",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の傳記にもずゐぶんとさういふ例はあるもので、士族ならまだしもつまらない素町人とか、いやそれどころか、たかが水呑百姓といつた賤しい人間が、何かの彈みで素性がわかると、思ひもよらぬやんごとない貴人だとか、男爵だとか、さういつた素敵もない身分の人間だつたりすることがある……。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "水呑百姓でさへさうなんだもの、士族のおれからはどんな偉いものが飛び出すか分つたものぢやない。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもその筈で、集まつて来る人々はといへば、どうしてどうして、そんじよそこいらの十把ひとからげの水呑百姓などではなく、この蜜蜂飼などよりぐんと身分の高い人々にさへ、訪問を受けるのが肩身の広いやうなお歴々ばかりなのぢや。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲雀がチユークラ／＼と囀つて、二人の水呑百姓の上を舞うた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "水呑百姓ちうけど、水も碌に飮めん。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に津軽百姓がさうで、所謂水呑百姓の果てまでも日本の他の地方の百姓のやうにはコセつかず、余裕綽々たるものが在り、ユウモアに富み、舌鋒鋭く、警句の多々交はる談話をかはす。",
              "citation": {
                "source": "津軽地方特有の俚諺",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の生れたのは東北の田舎で、うちは水呑百姓だつたな。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩年の芥川龍之介の話ですが、時々芥川の家へやつてくる農民作家――この人は自身が本当の水呑百姓の生活をしてゐる人なのですが、あるとき原稿を持つてきました。",
              "citation": {
                "source": "文学のふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩年の芥川龍之介の話ですが、時々芥川の家へやってくる農民作家――この人は自身が本当の水呑百姓の生活をしている人なのですが、あるとき原稿を持ってきました。",
              "citation": {
                "source": "文学のふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "法神大先生の高弟は三吉と称し、深山村の房吉、箱田村の与吉、南室村の寿吉、この三吉に樫山村の歌之助を加えて四天王というが、いずれもタダの水呑百姓だ。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "座長と見える老爺など終生水呑百姓の見るからに武骨そのものの骨柄であるが、巧みに女形をしこなして優美哀切を極め、涙の袖をしぼらせること、いつの年も変りがないといふことである。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の生家は水呑百姓であったが、鶏やケダモノを食うので、村中から嫌われていた。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
