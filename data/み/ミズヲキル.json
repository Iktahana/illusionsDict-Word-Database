        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "水を切るごとに眼くるめくや、背後に居たまえりとおもう人の大なる環にまわりて前途なる汀に居たまいき。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水を切るごとに眼くるめくや、背後にゐたまへりとおもふ人の大なる環にまはりて前途なる汀にゐたまひき。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　鮎の大きいのは越中の自慢でありますが、もはや落鮎になっておりますけれども、放生津の鱈や、氷見の鯖より優でありまするから、魚田に致させまして、吸物は湯山の初茸、後は玉子焼か何かで、一｜銚子つけさせまして、杯洗の水を切るのが最初。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "庖丁の腹で塊の頭を押えて大事そうに水を切る。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱に凭せて洗った米が箕に一ぱい水を切る為に置いてあった。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫓の聲、舟の水を切る音、天地の寂寞を破りて、美人の顏のみぞ光る。",
              "citation": {
                "source": "月の隅田川",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟の水を切る音、高く江天にひゞく。",
              "citation": {
                "source": "南洲留魂祠",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもわたる渡良瀬川の渡しを渡って土手の上に来ると、ちょうど眼の前を、白いペンキ塗りの汚れた通運丸が、煙筒からは煤煙をみなぎらし、推進器からは水を切る白い波を立てて川をくだって行くのが手にとるように見えた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "湿気を帯びた、新鮮な風がさつと吹いて来ると、ぐしよ濡れになつて突つ伏してゐたそこらの木々は、狗が身ぶるひして水を切るやうに、身体ぢうの水気を跳ね飛ばして、勢ひよく起き上りました。",
              "citation": {
                "source": "雨の日に香を燻く",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺も大分うまく泳げるように成ったに」　三吉は子供らしい手付で水を切る真似をして見せた。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "音色は緩やかな平和な調べをようやくに強め、撥の音が水を切るように聞えたとき、極めて柔しい小鼓の音が、三絃の調べにからみ合った。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "平素は、菜っ葉とか芋とかその他の洗い物などが、水を切るために並べられるぐらいなものであろう。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちやって来た汽船には、御客はもう少なくって、両側の小村に、神妙に寄り路して行っても、甲板には相かわらずたった二人で、その一人のイタリヤ人がデルヴィヨの村で降りてしまうと、あとは気の毒なほどひっそりして、外輪車の水を切るのが、寂とした湖上に遠く響きわたる。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "波にあたる波の音、しぶきにぶつかるしぶきの音、船ぞこを叩く水音、舵に添うて流れゆく死体の水を切る低い静かな音、それよりほかに音もなかった。",
              "citation": {
                "source": "浅瀬に洗う女",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "水を切る散弾の音が築山のかげで本を読んでゐる私に聞えてきた。",
              "citation": {
                "source": "測量船",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かな庭の寂寞を破る鯉の水を切る音に佇ずんだ。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、佃島の下をまわって、小舟に助け櫓をかけたのが、舳先で水を切るように、すばやくこっちへやって来る。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い背びれが水を切る。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、水を切るオールの音。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ櫓が水を切るごとに、うす白い波がたつばかりです。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "過分な礼を見たせいか、船頭の櫓は気持ちよく水を切る。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもわたしは雨が多く湿気が強いから、こうして水を切るひつようが一層大きいのかと思っている。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
