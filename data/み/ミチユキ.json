[
  {
    "uuid": "df61cbab-8159-597a-ba84-452d3bf669b4",
    "entry": "道行き",
    "reading": {
      "primary": "みちゆき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
