        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私も水撒きの手伝ひをする。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の定吉は花屋を商売にしている他に、この寺内が広いので、寺男の手伝いをして草取りや水撒きなどもしている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "八つの年初めてお目見得に上って、お茶との御所望があったとき、過ってお膝の上にこぼしたら、ほほう水撒きが上手よ喃、と仰せられた程の殿である。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の長い日もようやく暮れて、家々の水撒きもひと通り済んで、町の灯がまばらに燦めいてくると、子供たちは細い筒の花火を持ち出して往来に出る。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の乳くびの先きには水撒きの如露のやうな沢山の穴が通つてゐる。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "年若い友達はみな私の庭掃きや、水撒きを根気好く眺め、仕事の済むまで残酷に手伝ってはくれなかった。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は、ある日、片手で着物の裾をつまみながら、如露で部屋の前に水撒きをしていた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで思いついた水撒きだあね。",
              "citation": {
                "source": "日本名婦伝",
                "author": "谷干城夫人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
