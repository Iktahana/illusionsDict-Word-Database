[
  {
    "uuid": "b412980b-e0d2-5de3-a74c-007e719bd9e4",
    "entry": "見劣りがする",
    "reading": {
      "primary": "みおとりがする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-サ変-する"
      ],
      "ctype": null,
