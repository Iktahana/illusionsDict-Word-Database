[
  {
    "uuid": "c2d61c9b-b6db-5e62-859f-467c0e9e3298",
    "entry": "都人",
    "reading": {
      "primary": "みやこびと",
      "alternatives": [
        "とじん"
      ],
      "is_heteronym": false
    },
    "grammar": {
