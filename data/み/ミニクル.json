    "definitions": [
      {
        "index": 1,
        "gloss": "to come to see",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "中には遠くから自動車で見に来る人もあるらしかった。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの大勢の人声は、皆、貴下の名誉を慕うて、この四阿へ見に来るのです。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮に米斎君のやった舞台装置を他の画家が見に来るとします。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "均平の亡くなった妻の姉が、誰よりも銀子に苦手であり、それが様子見に来ると、女中の態度まてががらり変わるのもやりきれないことであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを珍らしがって見に来るなんて失敬な奴だ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "評判に釣られて見に来る人が多いので、文作の女房の葬式は近頃にない大勢の見送りであった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人はきっと決闘を見に来る。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お君ちゃんはいつもこれ見に来るの？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "名古屋の甥たちや隆太郎にも見に来るように通知はしたが、それもどうやら怪しくなって来る。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "感心な犬の話は、そこからかしこへとつたわって、町中で大評判になり、わざわざ肉を買いがてら見に来る人もあったりして、肉屋ははんじょうしました。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "準之助氏は、もし都合がつけば開店の景気を見に来るといっていたが、とうとう来ず、九時近くになって、電話がかかって来た。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人の踊りをわざわざ見に来るなんて！",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり頻繁に見に来ると猫の神経を刺激して病気にさわると言って医師から警告を受けて帰ったものもあった。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それも今日、買手が見に来るっていうんだぞ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外人より見れば、かの国公園内の雪隠か動物園内の水茶屋ほどの※爾たる軽き建築ゆえ、わざわざこんな物を見に来るより、自国におりて広重や北斎のむかしの神社の浮世絵を集むるがましと長大息して、去りて再び来たらず。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど少しもその意中を語らず、かつその日よりして、児を見に来る事もやや疎くなり行きて、何事か不満の事情あるように見受けられければ、妾も事の破れんことを恐れ、一日｜説くに女学校設立の意を以てし、彼をして五百金を支出せしめたる後、郷里の父母兄弟に柬して挙家上京の事に決せしめぬ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日が暮れても小僧が帰らなけりゃあ、新次郎という奴は不安心に思って、ここへ様子を見に来るかも知れません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし予も今に余暇ごとに研究を続けおり、これより外に一言も洩らさぬ故、例の三銭の切手一枚封じ越したり、カステラ一箱持って遥々錦城館のお富（この艶婦の事は、昨年四月一日の『日本及日本人』に出でおり艦長などがわざわざ面を見に来るとて当人鼻高し）を介して尋ね来りしたってだめだと述べ切って置く。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "試験の準備ツたら少しもしないし、その上夜ときたら十二時前に帰つたことはなく……静だから勉強なのか、と思つて、妾は一日に何辺そつと見に来るか知れないのよ――いつでもお昼寝ばかりなんじやないの、でもね、妾達は責めませんでしたが、妾は阿母さんと、純ちやんの事が心配で何れ程泣いたか知れませんよ。",
              "citation": {
                "source": "凸面鏡",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはたまらぬ、いくら娘の祝いだというても、こんなに京大阪の旅人まで聞き伝えて見に来るようでは、今に身代限りになりそうだ。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聞き伝え云い伝えして見に来る人が又沢山にありましたが、その中にはあのお金持ちの柴忠さんも見えまして一生懸命に力んで感心をしながら、こんな事を云われました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実を申しますとこの前の阿古屋のお人形を家に置いておきますと、そのためのお客がうるさくてたまりませんので、娘の名前で櫛田神社に奉納したのですが、その当時はあれを見に来る人のために、お宮の賽銭が違ったと申す位で……イヤイヤ決してお世辞を云うのでは御座いませぬ。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私の今までの罪を赦すから、直ぐに女王の病気を見に来るようにとの、有り難い御言葉を承りまして、取るものも取り敢えず参いった次第で御座います。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "名古屋の甥たちや隆太郎にも見に来るやうに通知はしたが、それもどうやら怪しくなつて来る。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "――本当に、どんな気で他人の働いてるのを見に来るんだか。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この格構を見に来るが好いわ。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが哀しみにくるめけるももいろうすき日のしたに白く光りて涙ぐむ洋銀の皿をたづねゆく草むら深く忘れつる洋銀の皿はいづこにありや。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを包みにくるみ、へとへとながらも必死で来た山を歩いて戻る。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が君のような貧乏書生に頭を低げて頼みにくる奴があるか、君の方で、つてを頼って、せっせと足まめに運動しなくちゃ、今時職を求める人間は掃く程あるのだ。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらにでも金にすればよいので、時価なぞにかまっていないよいお得意なのだから、彼らの番頭はうやうやしく町人｜袴をはき、手代を供につれて香奠をもって悔みにくる。",
              "citation": {
                "source": "お墓のすげかえ",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
