        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分はミューズの神のインスピレーションによって、以下さらに深く真理の解説をしようとする。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミューズの女神も一片のチョコレットの前には、醜い老いぼれ婆にすぎないんだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（こんどは自分が食いかく）ミューズを老いぼれ婆にしくさったチョコレットめ、芸術家が今｜復讐するから覚悟しろ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬古　　僕は汚されたミューズの女神のために今命がけの復讐をしているところだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは美の女神ミューズの胸に、そっとキスをしました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤードバーズ〈フォー・ユア・ラヴ〉、アウトサイダーズ〈タイム・ウォント・レット・ミー〉、ナシュヴィル・ティーンズ〈タバコ・ロード〉、ビーチボーイズ〈アミューズメント・パークス・ＵＳＡ〉、それに、ナンシー・シナトラやレズリー・ゴーアなんてものまである。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故男より女の作家が少ないかと云えば、文学を司る神はミューズで、ミューズは女性だ。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争中詩人たちの多くは、ミューズと一緒に活動するよりもマースと一しょに活動した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局のところ、アミューズメントロボットの開発計画は、中途で頓挫することになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自他ともに認める硬派のハッカー仲間の橋本と、ＣＧに入れ込んでいた木原範昭とは、アミューズメントロボットの話でも組んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが造作がえして、硝子窓だの硝子張りの扉をとりつけて、「高級喫茶ミューズ」などと出ている。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "数寄屋は、「グレイスの神よりは多く、ミューズの神よりは少ない。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりブラギはギリシヤ、ローマのミューズの神、日本で言へば和歌三神に當るわけであります。",
              "citation": {
                "source": "スカンヂナヴィア文學概觀",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も原始民族が一つの群衆となって神を祭った如く、今日の観衆は舞台という祭壇を通じて芸術の神、ミューズの声をきこうと願っている。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのミューズの声を昔の聖職者の如く民衆に伝えるのが即ち俳優なのであります。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、私のミューズが造型の暗示を与えるまで、しずかにその円を視守ろうと努めるのであった。",
              "citation": {
                "source": "ふるさとに寄する讃歌",
                "author": "夢の総量は空気であった",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、私のミューズが造型の暗示を与へるまで、しづかにその円を視守らうと努めるのであつた。",
              "citation": {
                "source": "ふるさとに寄する讃歌",
                "author": "――夢の総量は空気であつた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "職業意識が燃え立つせいで、宣伝文の要領が、ミューズとなって発現するのである。",
              "citation": {
                "source": "深夜は睡るに限ること",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お雪は倦みつかれたわたくしの心に、偶然過去の世のなつかしい幻影を彷彿たらしめたミューズである。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらにしてもし誠の心の底から、ミューズやヴェヌスの神に身を捧げる覚悟ならば、われらは立琴を抱くに先立って掟きびしいわれらが祖国を去るに如くはない。",
              "citation": {
                "source": "監獄署の裏",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は歩いた、夜天の下を、ミューズよ、私は忠僕でした。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ミューズもアポロも大喝采。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私には、私の耳には、今宵もあそこに、ミューズの竪琴の聲が聞える　……。",
              "citation": {
                "source": "駱駝の瘤にまたがつて",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、私の耳には、今宵もあの、ミューズの竪琴の聲は、聞えないから……。",
              "citation": {
                "source": "駱駝の瘤にまたがつて",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざ軍船の將帥を、又軍船の一切を――484　歌の神女、（英語のミューズ、）單數ムーサ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで野心家のアメリカ人のレデイは、詩人と駆け落ちすればミューズの神々と一緒にオリムポスの空高く舞いあがれるとでも思つていたのに、一日かそこらの道中でウンザリしてしまいました。",
              "citation": {
                "source": "ブラウン神父の醜聞",
                "author": "THE SCANDAL OF FATHER BROWN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべも、これでミューズが揃ったと大笑いしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああこれはミューズお揃い物語のあとにかかれたものだったのね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨中のミューズというほどでもないし。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
