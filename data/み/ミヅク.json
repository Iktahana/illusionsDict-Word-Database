    "definitions": [
      {
        "index": 1,
        "gloss": "to be soaked (in water)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "海行かば水漬く屍、山行かば草むす屍、また顧みぬ防人の昔ながらの雄たけびや。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "水漬く葉の眞菰のみだれ、伏葦の臂のひかがみ、末枯や、――さてしも齋場、おもむろに鳰は滑りぬ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと日は、うるむ月の夜に、水漬く磯根の葦の葉を、卯波たゆたにくちづけし深日の浦をおもひいでぬ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "水漬く葉の眞菰のみだれ、伏葦の臂のひかがみ、末枯や、――さてしも齋塲、おもむろに鳰は滑りぬ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "三ひと日は、うるむ月の夜に、水漬く磯根の葦の葉を、卯波たゆたにくちづけし深日の浦をおもひいでぬ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しだらなの眞菰のなかに、水漬く火や、――今宵も星は、秉燭の火影に、天の戸こそまもれ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "水漬く屍に、君や　まじると※初午詣稲荷坂　見あぐる朱の大鳥居。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "また長歌には、「大伴の遠つ神祖の、其の名をば大来目主と、負ひ持ちて仕へし官、海行かば水漬く屍、山ゆかば草むす屍、おほきみの辺にこそ死なめ、顧みはせじと言立て」（巻十八・四〇九四）云々とあるもので、家持は生涯の感激を以て此の長短歌を作っているのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "水底に水漬く白玉なる郎女の身は、やがて又、一幹の白い珊瑚の樹である。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "水底に水漬く白玉となつた郎女の身は、やがて又｜一幹の白い珊瑚の樹である。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大伴佐伯の祖先以来の家訓に、海行かば水漬く屍、山行かば草生す屍、大君の辺にこそ死なめ、のどには死なじ。",
              "citation": {
                "source": "本州における蝦夷の末路",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをぢかに拝したからには、何びとといへども、「海行かば水漬く屍、山行かば草生す屍、大君の辺にこそ死なめ、かへりみはせじ」といふ気持になつたであらう。",
              "citation": {
                "source": "君臣相念",
                "author": "龜井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海行かば水漬く屍、てなことにはなるなよ」「大丈夫ですよ」　福は五郎に白い歯を見せて笑った。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に入っていよいよ風波が加われば、空しくここに水漬く屍となり終ろうも知れぬ」「日の暮れぬうちに、どこか出口を」　人々の眼は、しだいに血走ってきた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日なら、もうほんたうに立派な雲の峰が、東でむくむく盛りあがり、みみづくの頭の形をした鳥ヶ森も、ぎらぎら青く光って見えた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも來る時は、縞もののそろひで、おとなしづくりの若い男で、女の方が年下の癖に、薄手の圓髷でじみづくりの下町好みでをさまつてゐるから、姉女房に見えるほどなのだが、「嬰兒が乳を呑みますから、私は何うでも、彼女には實に成るものの一口も食はせたうござんすから。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "潮みづく国つ神、海豚の眼見よな、遠眼、鋭眼、慧しな、羽ぶり羽ぶりおもしろ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "潮みづく國つ神、海豚の眼見よな、遠眼、鋭眼、慧しな、羽ぶり羽ぶりおもしろ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨降れば五六里の山道を伝ひて博多に出で、世上の風評を聞き整へ、種々の買物のほかに奈美女の好む甘き菓子、珍らしき干物、又は何処より手に入れ来るやらむ和蘭の古酒なんどを汗みづくとなりて背負ひ帰るなんど、その忠実々々しさ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと吾に返ると沢田が汗みづくになつて自分を背負つてゆく。",
              "citation": {
                "source": "月下のマラソン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬからずに洗っておいでよ」　命じておくと、ひと足先に伝六を駕籠で送り出しておきながら、右門は結城袷の渋好みづくりに、細身の蝋色鞘をおとし差しにして、ゆうぜんと本石町へやって参りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年に唯つた一度の井戸がへで、家主のおれまでが汗みづくになつて世話を燒いてゐる。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿介は汗みづくになり、激しい鼓動を薄い胸壁に堪へながら、總身の力を搾つた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗みづくになつて働いてゐる若ものは、十八にしては大きく、二十にも二十一にも見える出來上つた立派な體だつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しぼるやうに汗みづくになつた（原文四字缺）が粗い肌ざはりでべとべとと身體にからみつくのであつた。",
              "citation": {
                "source": "盲目",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どうぞお尋でに一寸……」　米華は山のやうな画絹を前に、汗みづくになつて滝を描き、山を描き、鶴を描き、亀を描き、洋妾のやうな観音様を描き、神戸市長のやうな馬を描きしてゐるうちに、到頭｜眩がして自分にも判らぬやうな変な物を描き出した。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "整理掛りが汗みづくになつて、それを取り調べてゐると、なかに一通大判な用紙に、剣先で書いたかと思はれるやうな太い文字で、「ペンは剣よりも偉大なり。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "凝り性の露伴氏の事だから、新式の機械など買ひ込んで、弟子と二人で汗みづくになつて麺麭を焼いたものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして機械を取寄せて、汗みづくになつて拵へにかゝつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――風谷は白耳義通ひの船の中で、汗みづくになつて豆腐を拵へた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
