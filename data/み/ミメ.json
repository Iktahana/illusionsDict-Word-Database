        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "王子も燕も気がついて見ますとそこには一人のわかい武士と見目美しいおとめとが腰をかけていました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてお見目得もすんでしまったのです。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐつたり成つたお品はそれでなくても不見目な姿が更に檢束なく亂れた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも不見目な貧相な勘次は依然として彼には蟲が好かなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだお品はおつぎが生れたばかりに直に竈を別にして、不見目な生計をしたので當時は晴の衣物であつた其の單衣に身を包んで見る機會もなく空しく藏つた儘になつて居たのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は絶えず或物を探すやうな然も隱蔽した心裏の或物を知られまいといふやうな、不見目な容貌を村落の内に曝す必要が漸く減じて來た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしや、老人が此儘死んでしまうようなことがあれば、自分はどんなに淋しい身の上になることであろうか、それは帰るべき塒を失った仔鳥よりも、いく段か不見目であろうと思われる。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩手県上閉伊郡釜石町、板沢某という家の娘に見目よきものがあった。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして太郎は世の中の誰よりも見目麗しくて感じがとても良いと確信するに至ると、お芳にそんな気持ちをもう今すぐにでも告げたいという思いが募っている。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、板敷きの歩道を歩いて行く見目うるわしい一人の婦人を、しげしげと見送った。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "是則小倉候ヨリ長州の讒申立しニよりし、則小倉より申立し書付ハ外国奉行より見セくれしより、手帳ニ記シアリし故、御見目かけ申べし。",
              "citation": {
                "source": "手紙",
                "author": "慶応元年九月七日　坂本権平、乙女、おやべあて",
                "note": "青空文庫"
              }
            },
            {
              "text": "重臣はああいう見目よい男がお好きなのかも知れないと考えた。",
              "citation": {
                "source": "議会見物",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとこの海豹の側に見目うつくしい女が泳いでいた。",
              "citation": {
                "source": "海豹",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ヘヽヽヽ、スベタとは、見目かたちよからぬ女房のことで……」「わかつた、わかつた……。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しでも美しく、さう思つて大事にする見目かたちは、ただあなたへのささやかな心尽しなのです。",
              "citation": {
                "source": "命を弄ぶ男ふたり（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "宜なるかな、諸官省、諸会社殊に軍隊さへ一令なくして解散し、通信交通機関は忽ち途絶し、囚人は脱獄し、僕婢は遁走し、飲食店は掠奪に遭ひ、恨みを受くるものは殺され、見目よきものは犯され、（群集の声次第に高まりて後の句を聴き取り難し）文六　　みんな、こちらへ来い。",
              "citation": {
                "source": "麺麭屋文六の思案（二場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓町人の隔てなく、木曽一円に令を出し、見目よい男女を猟り集めるよう」「かしこまりましてござります」　でその日から八方へ踊り子集めの令が飛んだ。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "義明が煩悩を昂ぶらせ、彼女へ犠牲を強いるごとに、彼女は見目よい侍女をもって自分の代わりにあてがった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　血のにじむほど口びるを噛み締めながら、大次郎は、しんみりとつづけて、「これは、千浪様のまえでははばかりますが、すこしでも見目のよい若い女で、出羽守に犯されずにすんだものはありませぬ。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「約束どおりこの山へ来り候えども、思う仔細ありて、両人を待たず、一足先に下山仕り候と申すは、昨夕登山のみぎり、この下の猿の湯にて、江戸｜女と覚しき見目うるわしき女子を見初め、この七年間、何ものにも眼をくれず、黄金のみ追い来りし文珠屋佐吉。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉殿のお目に留まって以来、此の二、三年お館に仕えておりますが、見目形は申すに及ばず、心も気質も優しい女性でございます、名は千手の前と申します」　警固の侍の言葉に、重衡は深くうなずくのであった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "云うまでもなくパンフレットは、普通のジャーナリズム様式とは違って極めてセンセーショナルな様式なのだが、他方に於て、夫は云わば白昼に於ける堂々たる出版物だと云うよりも一見目立たずに而も絶大な的確な効果を持つ処のやり方なのである。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "力めて栄養も取るように心掛け始めたので、見目形も少しは好くなって、それだけ益々有利に事情は展開するようになって来たのである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "封建時代の領主の中には、城の物見に立って、望遠鏡で城下を通る見目よき婦人を物色し、有無を言わせずに引入れて枕席に侍らせた例もあり、ひどいのになると、櫓の上に立って、自分の鉄砲の腕前を試すために、城下を通る町人を、鳥を撃つように撃ち殺した大名さえあります。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "暴君の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "そは豊かで見目好き若人であり、名はバッティスタ・デルコールである。",
              "citation": {
                "source": "犬酸漿",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "総じてかかる事態は、いかなる意識的な行動によっても治癒不能だと看做されている一方、社会が見目麗しく変貌するや否や外力なしに自分自身を糺すものと期待される。",
              "citation": {
                "source": "詩とマイクロホン",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "見目のよいのが縁づきばかりか見目の悪いがやもめでいるよ親の代から髪のないわれに野老食たとて髪が生よか聟殿やれ、髪が生よか　米磨ぎ笊を被った酔いどれは、歌にあわせて道化た踊りを舞っていた。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くそこらの皿小鉢を片づけよう、おいお十夜、掃除だ、掃除だ、その酒の徳利を隠しておけ」「なんだ、たいそうあわてるじゃねえか」「殿様の見目嗅鼻がやってきた」「お目付か」「なに、居候だ」「居候？",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "西根よりみめよき女きたりしと、　　角の宿屋に眼がひかるなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「笹や、笹々笹や笹、笹を買わんせ煤竹を――」　大高うまい、と今呼ばれた、件の（鼬みめよし）が、笹をわざと、島田の上で、ばさばさと振りながら、足踏をして唱出した。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
