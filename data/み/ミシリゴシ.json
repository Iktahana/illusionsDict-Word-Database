        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は煮えくりかえる程腹がたって、どうしてくれようかと思い思いその時計屋に行ったら、見知り越しの番頭が出て来て、「いらっしゃいまし。",
              "citation": {
                "source": "ざんげの塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "客同志見知り越しのものもある。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ昼前なので遠くの街から集まって来た人達より踊り手には近所の見知り越しの人が多かった。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして特に見知り越しの私たちの眼と眼とぶつかると、莞爾として片手をあげた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "見知り越しの老酋長の所へ寄ったが、此の前会った時とは打って変って、若々しく活気づいて見えた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして君は疑わしそうな目を時々上げて、見知り越しの顔にでもあいはしないかと気づかった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "数多い見知り越しの男たちの中で如何いう訳か三人だけがつぎつぎにクララの夢に現れた。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高慢というのでもなく謙遜というのでもなく、きわめて自然に落ち着いてまっすぐに腰かけたまま、柄の長い白の琥珀のパラソルの握りに手を乗せていながら、葉子にはその貴婦人たちの中の一人がどうも見知り越しの人らしく感ぜられた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見知り越しの巡査は「助ける側のお前が自分でやったら困るなあ」というた。",
              "citation": {
                "source": "身投げ救助業",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "木枯が江戸の名物とすれば、それにも劣らぬ江戸名物の退屈男が久方ぶりに帰って来たのであるから、眉間の三日月傷でその顔を見知り越しの駕籠人足共が、わが駕籠に乗せているのを自慢顔に、しきりと景気よく怒鳴りながら走ったからとて不思議のないことでした。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいこもちとは同じ連れか、でなくば見知り越しらしい話工合でした。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "板囲いの待合所に入ろうとして、男はまたその前に兼ねて見知り越しの女学生の立っているのをめざとくも見た。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、見知り越しの女のように挨拶して通った。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度は村の見知り越しの若者の横顔を張り見世の前でちらと見た。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "立て札もなければ、あたりに見知り越しの近所の人も見えない。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は又、近所の誰彼、見知り越しの少年共を、自分が生村の會堂で育てられた如く、育てて、教へて……と考へて來て、周圍に人無きを幸ひ、其等に對する時の嚴かな態度をして見た。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "機会を窺ている二日目の朝、見知り越しの金貸が来てお政を連出して行く。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹部でもなんでもなかつた、しかし日頃から見知り越しの一人だつた。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに突つ立つてゐたのは、旅商人らしい一人の男で、三日にあげず、彦山から槻の木へ通つてゐるので、茶店の爺さんとは見知り越しの仲でした。",
              "citation": {
                "source": "小壺狩",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには五六人の客が居合はせたが、誰一人｜見知り越しの男は居なかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日｜予て見知り越しの男が訪ねて来たので、舞台監督はきさくに会つてみた。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "極く極く漠然とした眼移りのするような心地でもって、町へ行って娘達に逢うのを楽みにしたり、見知り越しなお嬢さんの家の門なぞに佇立んだり、時には繁子の居る寄宿舎の方へ、あるいは彼女が教えに通う学校の窓の見える方まで行ったりして、訳もなしに彷徨い歩かずにはいられなかった。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "何方もみのるの見知り越しの人であつた。",
              "citation": {
                "source": "木乃伊の口紅",
                "author": "田村俊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いるのはこれも見知り越しの、海軍将校の夫妻だけだった。",
              "citation": {
                "source": "妙な話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "お粒は男の中の一人と見知り越しなのか、急にハスッパになつて、その男の肩に凭れ、何か耳打ちをしてゐる。",
              "citation": {
                "source": "「リラ」の女達",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその中でも見知り越しの二人の刑事の顔を、わざと不思議そうに見まわした。",
              "citation": {
                "source": "冗談に殺す",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼく達のクルウでも、豪傑風な五番の松山さん迄が、見知り越しのシャ・ノアルの女給とテエプを交しています。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
