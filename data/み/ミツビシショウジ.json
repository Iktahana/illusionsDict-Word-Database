        "examples": {
          "standard": [
            {
              "text": "三菱商事は、世界中で様々なビジネスを展開する総合商社だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は三菱商事に勤めており、海外出張が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "三菱商事の支援を受けて、新しいプロジェクトが立ち上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "次で三井物産支店長松本季三志夫妻、三菱商事支店長山口勝、宮地秀雄等来船。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三菱商事藤室益三夫妻に迎へられ大和旅館に入る。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、三菱商事支店長渡辺寿郎邸にて晩餐会。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上陸、南市の半淞園に行きそれより三菱商事の招宴にて月廼家にて田中三菱商事支店長等と会食。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
