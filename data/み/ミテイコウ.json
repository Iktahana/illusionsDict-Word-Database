    "definitions": [
      {
        "index": 1,
        "gloss": "unfinished manuscript",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
