[
  {
    "uuid": "4a7ed039-ef6c-5e91-b183-bc03c8f5001c",
    "entry": "見逃す",
    "reading": {
      "primary": "みのがす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
