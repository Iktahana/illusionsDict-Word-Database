    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to open a business",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "○九月九日より三日間、歌舞伎座において東京養育院慈善演劇を催し、貴婦人令嬢らが売店を開く。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜美子が教えていた戦死者の未亡人達が、やがて卒業して共同経営の勲洋裁店を開くのだと言って、そのお礼かたがた見舞いに来た。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、店を開くは、さてめでたいぞ。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は水戸の或通りへ近く洋物店を開く計畫を成就した。",
              "citation": {
                "source": "商機",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "店を開くと云うような場合には……」　斯う河上は更に付け加えた。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "店を開くための、土地の所有価値を暴騰させるための投資であった。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鄰地の農夫、重藏の所有地に蕎麥店を開く。",
              "citation": {
                "source": "近藤重藏の富士山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕎麥店を打毀して矢來を設けたるに、矢來を破壞して又蕎麥店を開く。",
              "citation": {
                "source": "近藤重藏の富士山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんの宵の中丈露店を開くのではあるが、疵物なぞを安く割引して売るために、客の足は思ったよりも繁かった。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰しも思いつく兵営のぐるりの餅菓子屋だの、一寸一杯だのの店を開くのも今はたやすいことではない。",
              "citation": {
                "source": "村の三代",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣村から時々出張して来て吉野屋で店を開く呉服屋の佐々木は折々云った。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩に店を開くものは小商人としてむしろ軽蔑されがちだった。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはね、これからここに店を開くんだけれど、何の店を始めたらいいだろうね」「なんだって」　相手は本通りから源一の立っているところまで歩いてきた。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして各階に、いろいろ楽しい店を開くのです。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋裁とか美容術といふこともあるが、これは店を開くまでに相当修業の時間がかかるだらうしね。",
              "citation": {
                "source": "雨宮紅庵",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてお久はその男と夫婦になり、麹町六丁目へ暖簾を分けて貰い、文七元結の店を開く。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、資本が極めて薄いのであるから、東京の中央で店を開くなどは思いもよらない。",
              "citation": {
                "source": "烏惠壽毛",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、ここで店を開くのはよしてもらおう。",
              "citation": {
                "source": "町はずれの空き地",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラビヤなどとは使節を交していないから、彼女の責任を負うている外国公館も存在しないぜ」「店を開く手続きは？",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十四　ロッテナム美人術",
                "note": "青空文庫"
              }
            },
            {
              "text": "大平といふのは、両国広小路に店を開く絵草紙店の版元であつたが、途中その職場の窓をすれすれに覗きすぎることが出来て、暗いその家の中では、数人の男達がいつもせつせと紙を折つてゐたり、あるひは――今思ふと――せはしなくバレンを使つて木版画を刷つてゐたりした。",
              "citation": {
                "source": "両国界隈",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一七六三年にはトロンゲート街に自分だけの店を開くことさえできるようになりました。",
              "citation": {
                "source": "ジェームズ・ワット",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がまあここで書画｜骨董店を開くとする。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から一ヶ月ばかり前、暫くぶりで彼が訪ねて来て、「いよいよ今度年期もあけ、御礼奉公も済ましましたので、本郷の湯島新花町百〇一番地――天神様の横を半町ほど入つた所です――に自分で店を開くことになりました。",
              "citation": {
                "source": "質屋の主人",
                "author": "宇野浩二",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞くところによれば、南アフリカの日本人排拒は豪州よりもはなはだしく、労働者は絶対的に入港を許さざるのみならず、近年は商店を開くことを許さず。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来のすみずみ、家いえの石段、そのほかちょっとした店を開くことのできる場所にはきっと花を売っていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし少ない資本のものならば、将来有望と思われる場末の地で、その隣家に立ち勝った店を開くが上策である。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "新たに商店を開く注意　地方人の失敗する理由は、概略前章において述べた通りであるが、いよいよ新たに店を選択せんとするには、さて如何なる場所を如何にして得べきかを詳細に説く必要が起る。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔦屋の店を開く金は大方近藤さんが出してくれたつてえからねえ。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……彼は清吉の消息をしるために狂奔した、そしてなにがわかったろう、清吉はおたまと夫婦になって、新しく出店を開くために上方へ去ったという、おたまは十五六のじぶんからおとこ出入が多く、店の者だけでも五人より少なくなかった。",
              "citation": {
                "source": "金五十両",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたらこの臨床でコーヒー店を開くことができる！",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
