        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "水機関の性質上、やはり舞台で水を奇術風にとり扱ふことになるのは当然である。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと賢いお祖父さんが、僕の音楽を素敵だと言ってるんだ」といくらみずからくり返しても甲斐がなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は叔父の言葉をみずからくり返した。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（不幸にも彼は、その話の一部を手紙の中でみずからくり返して述べた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしみずからくり返した。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼は、フランス人にたいするグルックの不当な言葉を、いつもみずからくり返した。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして彼はみずからくり返した。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも彼はなお、彼奴らの家へ足を踏み入れるものかとみずからくり返した。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
