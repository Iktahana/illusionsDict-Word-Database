        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然しこれを歌つてゐるのがボオドレエルだと思ふと、船の沢山ゐる港、それも余り大きくない港が見えて来たりする。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "校庭宮沢賢治さ霧する白き木柵幹彫れる桐のいくもと剥げそめし白きペンキの木柵に人人は倚りそのペンキあるいは剥げあるものは庭をのぞめり一鐘のラッパが鳴りて急ぎ行く港先生白堊城秋のガラスはひらごとにうつろなりけり",
              "citation": {
                "source": "校庭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "湾も、港市――その家々も、たゞ一様にドス黒く見えてゐる。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しだいに暮れゆく海波の上既に分列の任務を終へて艦等みな歸港の情に渇けるなり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等みな軍務を終りて、歸港の情に渇ける如し。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れ既に生活して、長く既に疲れたれども、軍務の歸すべき港を知らず。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の長崎にはロシアの東洋艦隊の勢力が港町の隅々まで浸潤していた。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は東寺に先祖の一海和尚の墓に参って、室戸岬の荒涼で雄大な風景を眺めたり、昔この港の人柱になって切腹した義人の碑を読んだりしたが、残念ながら鯨は滞在中遂に一匹もとれなくて、ただ珍しい恰好をして五色に彩色された鯨漁船を手帳にスケッチしたりしただけであった。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船は早や港を出るよと思えど窓外を覗く元気もなし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "港口浅せたるためキールの砂利に触るゝなるべし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "再びとろ／＼として覚むれば船は既に港内に入って窓外にきらめく舷燈の赤き青き。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽笛の吼ゆるごとき叫ぶがごとき深夜の寂寞と云う事知らぬ港ながら帆柱にゆらぐ星の光はさすがに静かなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "港市の秋石崖に、朝陽が射して秋空は美しいかぎり。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかふに見える港は、蝸牛の角でもあるのか町では人々｜煙管の掃除。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "港の市の秋の日は、　　大人しい発狂。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが喫煙おまへのその、白い二本の脛が、　　夕暮、港の町の寒い夕暮、によきによきと、ペエヴの上を歩むのだ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も、桑港で発行される日本字新聞『日米』で、君とスタア博士と富士山との交渉を書いて、心ばかりの供養に代えたが、富士山の納め手拭から、この事を知ったのは、山中でひょっくり君に出逢ったようであった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その氷河で思い出したが、私が桑港にいるとき、一九二四年九月十八日の夕、新聞の号外売りが、声高く「ラッセン火山大爆裂、シャスタ氷河大融解」と、大の字｜尽くしで呼んでいるので、耳寄りに思って買って見ると、いかにもシャスタ山の、氷河融解、大洪水来と、拳大の活字で見出しがついている。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャスタへ行くには、私たちの居住地、桑港から、オレゴンへと北向する南太平洋鉄道の便を借りるのである。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　彼女は三池港で、船艙一杯に石炭を積んだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その島も、船が寄港しない島に限るのであった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと前の話であるが、『藪柑子集』中の「嵐」という小品の中に、港内に碇泊している船の帆柱に青い火が灯っているという意味のことを書いてあるのに対して、船舶の燈火に関する取締規則を詳しく調べた結果、本文のごとき場合は有り得ないという結論に達したから訂正したらいいだろうと云ってよこした人があった。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ティアガルテンの冬木立や、オペラの春の夜の人の群や、あるいは地球の北の果の淋しい港の埠頭や、そうした背景の前に立つ佗しげな旅客の絵姿に自分のある日の片影を見出す。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを畢竟するに太陽系がこの星座に向って進んでいるため、丁度船が港に近づく時眼前の景色が目指す埠頭を中心として展開すると同じだと説き、爾来誰も異議を挿むものがなかった。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海から近づいて行く函館の山腹の街の灯は、神戸よりもむしろ香港の夜を想わせる。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝港内をこめていた霧が上がると秋晴れの日がじりじりと照りつけた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "港内の眺めが美しい。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、惜しい事には、この能力は人間に都合のよいほうにはあまり使われないで、かえって海岸を破壊したり、またせっかく築いた港を砂で埋めたりするほうに使われています。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが、ついちょっと前に港頭に聳ゆる有名な「自由の神像」を拝して来た直後のことなのである。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで蟹は、じぶんの子どもたちをみなとこやにしました。",
              "citation": {
                "source": "蟹のしょうばい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
