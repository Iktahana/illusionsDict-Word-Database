    "definitions": [
      {
        "index": 1,
        "gloss": "one's personal belongings",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
