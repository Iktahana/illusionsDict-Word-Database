        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "汽車が東京を出発してから、二言三言言ひかはしたばかりである此の男は、節野と云つて、外国語学校の夜学で知合ひになつた男である。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が一日、予告もなく府庁の学務課から参観に来て、校長には二言三言だけ普通の話をして立去つた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩石の大崩れがあって、左の方に石を囲んだ坊主小舎がある、小舎の中は未だ雪が多くて、泊まることは出来そうもない、鍋が一枚蔵してあった、冠君は既に槍ヶ岳登りを終られて、雪を辷り落ちるようにして、下りて来られた、二言三言話を交えて、さっさと下りて行かれる。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "知ってる顔と見えて、案内者は薄明りに、二言三言挨拶をして行き過ぎる。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお三言四言話をするうちに、民子は鮮かな曇りのない元の元気になった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田の上に乗りかぶさっていた若者は、二三言老人に返事をした。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "当直士官は、作業場への出入に対して、二三言を費した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お里は何か他のことを二言三言云った。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "店には頭の禿げた肥った主人が居て、Ｂ君と二言三言話すと、私の方を見て、何か云ったがそれはオランダ語で私には分らなかった。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっぱら談話をリードしているその中の一人が何か二言三言言ったと思うと他の二人が声をそろえて爆笑する、それに誘われて話し手自身も愉快そうに大きく笑っている。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また二言三言何か言ったと思うと再び同じような爆笑が起こってそれが三声つづく。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "教授はそれから譯のわからぬフランス語を二言三言つぶやき、教壇の机のうへでなにやら書きものを始めたのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "教授はそれから訳のわからぬフランス語を二言三言つぶやき、教壇の机のうえでなにやら書きものを始めたのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻の一｜言いう中に母は三言五言いう。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は三言目には喧嘩腰、妻は罵倒されて蒼くなって小さくなる。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻の一言いう中に母は三言五言いう。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ艦長松島大佐に向つて、何事をか二言、三言、公務の報告を終つて後、私の方に向直つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が反省も思索もなく、きつとお使僧を見つめたとき、彼女は溢るゝ計りの熱心と真実との籠つた彼の説話の二言三言を聞くとはなしに聞き入つた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮子は弓子を案内して、二言三言挨拶が済むと、座を外して応接室の方へ戻って行った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち話、という程でもないが、二言三言口もきいたであろうか。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客様のお買物について何か二言三言お尋ねになりましたきりで、その椅子に腰を卸して煙草を召あがりながら、表の通りをボンヤリと眺めてお出でになる様でしたが、そのままユックリユックリ出てお出でになったんですが……」　と云う雄弁な中小僧の言葉を片耳に残しながら……。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "睫毛の長い、大きな眼を愛想よくクルクルさせながら、何か二言三言早口に言って、昂作の垢だらけの手に五十銭銀貨を一つ握らせると、チョットあどけなくお辞儀をした。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし母親がまじめな顔をして、何か二言三言云いわけをすると、間もなく納得したらしく、組んでいた腕をほどいて元気よくうなずきながら、靴をスポンスポンと脱いだ。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "テツさんと妻は天候について二言三言話し合った。",
              "citation": {
                "source": "列車",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "テツさんと妻は天候について二言三言話し合つた。",
              "citation": {
                "source": "列車",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを今ここで、二言か三言で説明し去るのも、あんまりいい気なもののように思われる。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご亭主は土間のお客を一わたりざっと見廻し、それから真っ直ぐに夫のいるテーブルに歩み寄って、その綺麗な奥さんと何か二言、三言話を交して、それから三人そろって店から出て行きました。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "路の半ばに時雨しめやかに降り来たりて間もなく過ぎ去りし後は左右の林の静けさをひとしおに覚え、かれが踏みゆく落ち葉の音のみことごとしく鳴れり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの西の国の詩人がながれのきしのひともとはみそらのいろのみづあさぎなみことごとくくちづけしはたことごとくわすれゆく。",
              "citation": {
                "source": "「わすれなぐさ」はしがき",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ついだれでも知っているはずのことをふたことみこと、お話しただけですよ。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
