  {
    "uuid": "192d58eb-f096-53aa-ad3d-1d821776b929",
    "entry": "ミノ",
    "reading": {
      "primary": "ミノ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "plain tripe",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ヨミノクニ」は黄泉でもあるがまた「海」だとの説もあったように思う。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……大方眠りつこうとしていると、不意に土間の隅に設けてある鶏舎のミノルカがコツコツコと騒ぎだした。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "骰子だのルーレットだのトランプだの将棋だのドミノだのいうものは、そんな目的のために猶太人が考え出して世界中に教え拡めたものである。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼飯に食った「サシミノ残リ」を晩飯に食ったという記事がしばしば繰り返されている。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "フジサンヤウミノミエルアイビキ！",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "オヒルノ　ヤスミノ　トキ、ヨシダセンセイニ　イヒツカツテ　タキクンハ、トウサンノ　トコロヘ　ホンヲ　モツテ　イキマシタ。",
              "citation": {
                "source": "センセイノ　コ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤガテ　マイタ　タネカラ　メガ　デテ　ノハラ　イチメンニ　ムギノ　ミノル　トキガ　ヤツテ　キタノデ　アリマス。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴランナサイ　コノ　ミミノ　ナガイ　コトヲ。",
              "citation": {
                "source": "ウサギ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "キミノ仕事ノコルヤ、ワレノ仕事ノコルヤ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫女人ノ身ハ、五障三從トテ、オトコニマサリテカカルフカキツミノアルナリ、コノユヘニ一切ノ女人ヲバ、――馬鹿らしい。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "６　去られたミノベ先生が、こんな事を云はれた事があつた。",
              "citation": {
                "source": "海から歸る日",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は京橋の本八丁堀に事務所を構え、ヨシ、ミノという二人の俥夫が引く二人引の俥で東京市中を馳けまわっていた。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "戀のしるしの素馨〔ジエルソミノ〕の花よ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの事実を発見した瞬間に、オレの心の中で六〇年代のドツボに向けて、魂のドミノ倒しが雪崩を打ちはじめた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本当に何がやりたいのか、魂の声に耳を傾けろ」　倒れ続けるくそったれドミノどもは、繰り返しオレにそうささやくのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊「――俺家の鶏ども、白色レグホンだって、ミノルカだって、アンダラシャだって、どいつもこいつも、みんなはあ、黒鶏みてえになってるから。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○男子一、（叫ぶ）百姓にとつて大地は隠れミノだ。",
              "citation": {
                "source": "きのふは嵐けふは晴天",
                "author": "小熊秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "國語問題ハ文字又ハ單語ノミノ問題ニ非ズシテ言語ノ組織根底ヨリノ革命ナラザルベカラズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二ノ理由ハ國家ガ國家ノ兒童ニ對シテ大父母タル立場ニ於テ其ノ生ミノ父母ハ單ナル保姆ノ任ヲ負フモノナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "『本草啓蒙』に猴の和名を挙げてコノミドリ、ヨブコトリ、イソノタチハキ、イソノタモトマイ、コガノミコ、タカノミコ、タカ、マシラ、マシコ、マシ、スズミノコ、サルと十二まで列ねた。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "因ってスペイン人は今も銀河をエル・カミノ・デ・サンチアゴ（サンチアゴ道）と呼ぶ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてやその他の月卿雲客、上臈貴嬪らは肥満の松風村雨や、痩身の夷大黒や、渋紙面のベニスの商人や、顔を赤く彩ったドミノの道化役者や、七福神や六歌仙や、神主や坊主や赤ゲットや、思い思いの異装に趣向を凝らして開闢以来の大有頂天を極めた。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "オ母ッチャモヤセテ、目ガヒッコンデ、カミノケガヌケタノ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ンダオ父ッチャヨリモヤセテ、カミノケガヌケテ、ネテシマッタノ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラヤミノナカデ、オ母ッチャノコエガスルト、ヤットアンシンスルノ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネコヤネズミノシワザデハナイ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてタイプで打ったミノ判二枚の「昭和二十三年の勤労者の家計について」という見出しで和田長官の名によって出されたメモのようなものを見せた。",
              "citation": {
                "source": "ほうき一本",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "万葉集以前の古事記や日本書紀の中で、最初に描かれた女性であるイザナミノミコトは、古事記を編纂させた人は女帝であったにもかかわらず、それを書いた博士たちの儒教風な観念によって、男尊女卑の立場においてかかれている。",
              "citation": {
                "source": "女性の歴史",
                "author": "――文学にそって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自分の名をミノルさんということにしたので、子供たちは私が通りさえすれば、ミノルさんミノルさんと言ってたかって来た。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
