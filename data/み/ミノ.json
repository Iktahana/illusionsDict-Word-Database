    },
    "definitions": [
      {
        "index": 1,
        "gloss": "straw raincoat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ダルゲは灰色で腰には硝子の蓑を厚くまとってゐた。",
              "citation": {
                "source": "圖書館幻想",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んに致せ、あの大勢のいる宴会の中で、隠れ蓑、隠れ笠をでも持っているように致す事の出来た二人でございますから。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん貝がらだけでなく生きた貝で、箱の中へ草といっしょに入れてやるとその草の葉末を蓑虫かなんぞのようにのろのろはい歩いた。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時になって初めてその服装を見ると、依然として先刻の鼠の衣だったが、例の土間のところへ来ると、そこには蓑笠が揃えてあった。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "若僧は先ず自ら尻を高く端折って蓑を甲斐しく手早く着けて、そして大噐氏にも手伝って一ツの蓑を着けさせ、竹の皮笠を被せ、その紐を緊しく結んでくれた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か知らん痛いものに脚の指を突掛けて、危く大噐氏は顛倒しそうになって若僧に捉まると、その途端に提灯はガクリと揺めき動いて、蓑の毛に流れている雨の滴の光りをキラリと照らし出したかと思うと、雨が入ったか滴がかかったかであろう、チュッといって消えてしまった。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大噐氏にちょっと会釈するや否や、若僧は落付いた、しかしテキパキした態度で、かの提灯を持って土間へ下り、蓑笠するや否や忽ち戸外へ出て、物静かに戸を引寄せ、そして飛ぶが如くに行ってしまった。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猿蓑」や「炭俵」がナンセンスであり、セザンヌやルノアルの絵がナンセンスであり、ドビュシーやラベールの音楽がナンセンスであると同じような意味において立派なナンセンス芸術であるように思われる。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろんぼのからだには、青い藺の腰蓑がひとつ、つけられてゐた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろんぼのからだには、青い藺の腰蓑がひとつ、つけられていた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの「春」と「炭俵」「猿蓑」等の中の歌仙とを対比して見ると、私はいかに前者がまだ幼稚で、いかに後者が洗練されているかに驚嘆するものである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後にもう一つ「猿蓑」で芭蕉｜去来凡兆の三重奏を取ってみる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関の方に自動車の止る音がして、やがて階段の下で、義弟に当る七つの蓑吉の声がする。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもちゃ持って来てやったぞ」「いま、階下へ降りて行きます、上って来ないでよ――」　室子は、急いで降りて、蓑吉が階段へ一足かけているのを追い戻して、一緒に階下の座敷へ伴れて行った。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯殿で身体と顔を洗って来て見ると、蓑吉は座敷のまん中へ、女中にほぐして貰った包みから、沢山のおもちゃを取出して並べている。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "郊外にいる室子の父の妾の子であり乍ら、しじゅう、通油町の本宅の家の子として引取られている蓑吉は、折を見つけては姉のいるこの橋場の寮へ遊びに来｜度がっている。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "室子が此間じゅう、一寸風邪をひいたと昨日｜言伝けたのを口実に、蓑吉は早速母親にせがんで、見舞いに来さして貰ったのだった。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "室子は縁側の籐椅子で、女中を相手に、朝飯を喰べながら「蓑ちゃんは可笑しい。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉ちゃんはもう、とっくに風邪なおって起きちまってるのに見舞いに来るなんて」「でも、来てやったんだい」　蓑吉は、こまごましたおもちゃを並べるのに余念が無い。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「済まないわね、そんなに沢山蓑ちゃんから頂いちゃ」　室子は、とぼけた声で、云って見せた。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると蓑吉は、欲望を割引しなければならない切ない苦痛で顔が真赤になり、物事を決断し兼ねるときのこの子の癖のしきりにもどかしそうに両手で脇腹を掻く仕草をしたあと、意気地の無い声を出した。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉ちゃんにみんな遣んの嫌だあ」　それから蓑吉は人を賺すときの声を作って「姉ちゃん、これ、いっち好いの、ひとつあげる」　セルロイドのちっぽけなお酌人形だった。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓑吉はもう大胆に取り澄して、分取ったおもちゃを並べるのに余念ない風をしている。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "室子の父の妾の子である蓑吉は、乳離れするころ、郊外の妾の家から通油町の本宅へ引取られた。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓑吉は、実母である妾のお咲が時折実家へ来て「坊ちゃん」と云って自分に侍いても、実母とはうすうす知っていながら別に何とも無い顔をしている。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓑吉は本宅の茶の間の炬燵へちょこなんと這入って、しきりに戦争の絵本かなにかに見｜耽っている。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みやげの菓子袋を前に置いていつもの通り蓑吉の小さい耳のほとりで挨拶した。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本に気を取られている蓑吉はお咲に見向きもしないでそのまま本に気をとられている様子だった。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙袋がごそごそといって、蓑吉の傍へ余計近よると、蓑吉は手だけ延ばした。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはもう、疲れしぼみ、悔とさびしい微笑としか持つてはをらぬけれど、それは此の世の親しみのかずかずが、縺れ合ひ、香となつて籠る壺なんだ。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
