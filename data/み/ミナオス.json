[
  {
    "uuid": "6166d778-8287-5f1d-88ff-4745f2546e9a",
    "entry": "見直す",
    "reading": {
      "primary": "みなおす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to look at again",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "併し、紅葉の季節に見直すといゝかも知れない。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、紅葉の季節に見直すといいかもしれない。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう考えて来ると少なくも彼の税関吏の場合はやや従前とはちがった光の下に見直すことが出来る。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体津田君の主張するように常に新たな眼で自然を見直すという事は科学者にとっても甚だ重要な事である。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次「違ったかな」と、も一度見直す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何となくひやりとして、もう一度見直すやうに振り返つたが、もうその時は何の影も見えなかつた。",
              "citation": {
                "source": "自分の變態心理的經驗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように恐ろしい地殻活動の現象はしかし過去において日本の複雑な景観の美を造り上げる原動力となった大規模の地変のかすかな余韻であることを考えると、われわれは現在の大地のおりおりの動揺を特別な目で見直すこともできはしないかと思われる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いボンヤリした月のかげに、始め、二三十頭に見えた犬が、改めて、周囲を見直すと、それどころか、五六十頭にもなっていた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくもそうしてみることによってわれわれは連句というものの本質をなんらかの新しい光のもとに見直す事ができるかもしれない。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも一度こういうふうに創作心理を分析した上で連句の鑑賞に心を転じてみると、おのずからそうする以前とはいくらかちがった心持ちをもって同じ作品を見直すことができはしないか。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神社の日向を、ゆるゆる歩み、知人に遇へば、につこり致し、飴売爺々と、仲よしになり、鳩に豆なぞ、パラパラ撒いて、まぶしくなつたら、日蔭に這入り、そこで地面や草木を見直す。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お孝は軽く傾いていたのが屹と見直す。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "慌てて懐に捻込む時、間近にお沢を見て、ハッと身を退りながら凝と再び見直す）何じゃ、人か、参詣のものか。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらかその人を見直す気になり、ぼそんと笑ったときのその人の、びっくりするほど白い歯を想いだし、なんと上品な笑顔だったかと無理に自分に言いきかせて、これあるがために私も救われると、そんな生意気な表現を心に描いたのだった。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは当り前のファンで、週末の休み日毎に、たとい二度三度見直す同じ狂言であろうとも、きまって彼女の出る映画ばかりを漁っている中に、だんだん彼女の何時も深い愁しみに隈どられた面輪が、頭の中のスクリインに大写しのようにいっぱいに映ったまま消えなくなったのである。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯貝は見番の役員で、北海道では株屋であったが、ここでは同業者へ金の融通もするらしかったが、酒とあの一つのことにこだわりさえしなければ、好意のもてなくもない普通の人間で、銀子も虚心に見直す瞬間もあるのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう思つてこの句を見直すと、わるくない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "許宣ものこり惜しいような気がするので、そのまま立っていて今度見直すと、二人の姿はもう見えなかった。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "あッ」初枝、驚いてメモを見直す。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は新しい驚きをもって彼の顔を見直すようにした。",
              "citation": {
                "source": "街底の熔鉱炉",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツイ、僅かばかり前に一生懸命して自分で作つておきながら、いま改めて見直すとなつて殆んど正體なく驚いたのである。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども「善良の面」と信じたものを、一朝にして「悪の面」と見直すためには相当な時間が私には必要であつた。",
              "citation": {
                "source": "疑惑の城",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "外見的に絵の幼稚さを見て、素人画家と断定し、たまたまその画家のすばらしい画人的なデッサンをみて、その画家を見直すといふ場合が、画家の世界には少くない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私が、再び照子を見直すと、照子は右の手で鼻と眼を覆つた儘、フラフラとする身体を辛うじて支へてゐるらしく、ジツと彳んでゐた。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱暴に鉛筆で書き捨ててある歌を一首一首とノートから拾って原稿紙に写しとってゆくのだが、作る時にはみな相当に思い昂って詠んだものでも、暫くの時日を経ていま改めて見直すとなると、なかなかに意に満つものがない。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして部屋をもう一度よく見直すとストーブのふたが取りのぞかれてい、石炭の新しい灰が溢れるように残っている。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目見て美しく、二目見て美しく、見直せば見直す毎に蘇って来る美しさを持っていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は主人に言いつけて、器を綺麗に洗い濯がせた後、あらためて手にとって見直すことにした。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎょっと致しましたが、そこはやはり旅馴れた出家で厶りますゆえ、雪あかりにすかしてよくよく女を見直すと、これがどうで厶りましょう。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やかましい、どう盲人と、足のちぎれたばった野郎、よくもよくも、一処へ集まったものだ」銚子で食卓の上を叩いて、「こんな不具者ばかりの処で、酒なんか飲めるものでない」とついと起って、「どこかへ往って、飲みなおす」　お杉はどんどん歩いて往ったが、やがて障子を啓けて外へ出て往く気配がした。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
