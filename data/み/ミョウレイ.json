[
  {
    "uuid": "5ea190d2-3a2d-5939-b0d1-881df661dc8a",
    "entry": "妙齢",
    "reading": {
      "primary": "みょうれい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
