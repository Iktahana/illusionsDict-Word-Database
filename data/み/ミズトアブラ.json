    "definitions": [
      {
        "index": 1,
        "gloss": "two incompatible things (or people)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
