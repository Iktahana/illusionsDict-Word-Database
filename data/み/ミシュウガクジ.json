        "examples": {
          "standard": [
            {
              "text": "映画館で、未就学児向けの「泣いても大丈夫」な上映会が企画された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "迷子センターに保護されたのは、まだ言葉もおぼつかない未就学児だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地域の交通安全教室で、未就学児を対象に横断歩道の渡り方を教えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "たとえば、日本では百三十万の未就学児童があります。",
              "citation": {
                "source": "質問へのお答え",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "道ゆく人々がみんな行きずりに、お早うといふ、学校生徒は只今々々といふ（今日は日曜だが、午後は只今帰りましたといふ）、これも山国らしい嬉しい情景の一つである（その癖、行乞の時は御免が割合に多い、未就学児童が、御免々々といふのは何としても嬉しくない）。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
