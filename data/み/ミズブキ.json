          "literary": [
            {
              "text": "何となく倦怠、顔を剃り、身体を水拭きする。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちどの湯浴みも水拭きもしたことなく、皮膚は垢とこの冬中の寒気で松かさみたいになっている。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと門人の聞き書に、体はいつも水拭きにして風呂には生涯入らなかったとあるが、それは晩年の熊本時代のことだろうと思われる。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいこ・どほな・みずぶき・ごうわらび・ほときまだ色々試して見たが、多くは忘れた。",
              "citation": {
                "source": "山の湯雑記",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
