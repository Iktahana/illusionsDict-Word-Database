[
  {
    "uuid": "f30e60ca-9ffb-5f8f-8cf0-c0cdafb8c401",
    "entry": "見るに堪えない",
    "reading": {
      "primary": "みるにたえない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
