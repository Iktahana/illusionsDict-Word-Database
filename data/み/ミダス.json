[
  {
    "uuid": "f153a67f-c3e8-57b0-86e1-9ac45026e237",
    "entry": "乱す",
    "reading": {
      "primary": "みだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
