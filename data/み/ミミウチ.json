    "definitions": [
      {
        "index": 1,
        "gloss": "whispering into a person's ear",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
