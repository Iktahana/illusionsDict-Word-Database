    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to guide",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "見知らぬ令夫人を卓に導く役を云い付かって当惑した。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "意味体験を概念的自覚に導くところに知的存在者の全意義が懸っている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に文筆の上で国民指導の位置にある学者と文士と新聞雑誌記者とが民族意識に深く目覚めて、国語の純化に努力し、外来語の排撃に奮闘し、社会の趣味を高きへ導くことを心掛けなければならない。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座を追われた靴磨き両人に腹を減らさせて浜町公園のベンチへ導く。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしておいて後にそろそろ被告の運命を明るい方へ導くために、今度は有利な側の証人を招集する段取りになる。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して誤った傾向に生徒を導くような事があっては生徒の科学的の研究心は蕾のままで無惨にもぎ取られるような事になりはしないかと恐れるのである。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者は読者の心理学的機関に衝動を与え、その運転を導くような資料を提供するのであって、その作の価値はその資料の選択や、それを提供する順序や仕方によって規定される。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、すべての人の長所を認識して適材を適処に導く事を誤まらなかった。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば世の家庭談とか云うものは、実は其の人々の思々を云うたものに過ぎない訳で、それを以て、他を律することも出来ず他を導くことも出来ない筈のものである。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、科学はマテリアリズムに導く、という一般的｜謬見を排し、計算や実験では解けない“higher mysteries of being”のあることを暗示した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画の頂点はヒロインが舞台で衣裳をかなぐり捨てブロンドのかつらを叩きつけて煩わしい虚偽の世界から自由な真実の天地に躍り出す場面であって、その前のすべてのストーリーはこの頂点へ導くための設計であるように見える。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して今時の大多数の絵は、最初には自分の本当の感じから出発するとしても、甚だしいソフィスチケーションの迂路を経由して偶然の導くままに思わぬ効果に巡り会うことを目的にして盲捜りに不毛の曠野を彷徨しているような気がする。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれはいずれにしても、今の苛立たしい世の中を今少し落着けて、人の心を今少し純な集中に導くためには、このような音楽も存外有効ではないだろうか。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その道楽が遂に二人を禁断の釣り場所へ導くようにもなったので、お徳は自分の亭主の罪を棚にあげて、その相棒の為さんを悪い友達としてひそかに怨んでいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、プロレタリアートは、現在の戦争に対しても、それが、吾々を解放へ導くものであるか、或は、吾々をなお圧迫するものであるか、その歴史的特殊性を分析することが必要である。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木魅、山魅の影が添つて、こゝのみならず、森の廊下の暗い処としいへば、人を導くが如く、あとに、さきに、朦朧として、顕はれて、蕚の角切籠、紫陽花の円燈籠を幽に青く聯ねるのであつた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの所説は畢竟するに人間霊魂非不滅論に導くべき前提としてルクレチウスのかなり力こぶを入れているところであるらしく見える。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「セバストポールの鐘をごらんなさい」と先に立って、反対の側の鐘楼へ導く。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりに抽象的で特殊な少数の観客だけにしか評価されないようなものは結局映画館と撮影所とを閉鎖の運命に導く役目しか勤めない。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただわれわれ科学の畑のものが見ると、二マイルもの遠方から水路を導くのに一応の測量設計もしないでよくも匆急の素人仕事で一ぺんにうまく成効したものだという気がした。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただそれに対して一つの心配することは、最高水準を下げると同時に最低水準も下がるというのは自然の変異の方則であるから、このユートピアンの努力の結果はつまり人間を次第に類人猿の方向に導くということになるかもしれないということである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人類を幸福に世界を平和に導く道は遼遠である、そこに到達する前にまずわれわれは手近なとんぼの習性の研究から完了してかからなければならないではないか。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と笑いながら言って、記者たちは、もうそろそろ太宰も酔って来た、この勢いの消えないうちに、浮浪者と対面させなければならぬと、いわばチャンスを逃さず、私を自動車に乗せ、上野駅に連れて行き、浮浪者の巣と言われる地下道へ導くのでした。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはその路が君を小さな林に導く。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはその路が君を妙な処に導く。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "たれかこの少女らの行く末を守り導くものぞ、彼ら自ら唄いて自ら泣く時も遠くはあるまじ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時は山羊のごとく然り山野泉流ただ自然の導くままに逍遙したり。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらの生涯を通じて歓喜より歓喜へと導くは彼の特権なるを知ればなり。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはおのずから、神と偕にある世界、仏に融け入る境地へみちびく。",
              "citation": {
                "source": "物を大切にする心",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、さっきから、政府だの、国家だの、さも一大事らしくもったい振って言っていますが、私たちを自殺にみちびくような政府や国家は、さっさと消えたほうがいいんです。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
