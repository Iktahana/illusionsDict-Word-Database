        "examples": {
          "standard": [
            {
              "text": "支援のお礼として、見返り物資が被災地に届けられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "貿易摩擦を解消するため、見返り物資の提供が議論された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その国は資源の輸出と引き換えに、見返り物資を受け取っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "賠償物資、見返り物資の輸出入を司り、国内生産の要を握るこの役所に、頭として据えられたのは三井である。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもお札では駄目で、見返り物資がそれだけいる。",
              "citation": {
                "source": "雪を消す話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれを大量生産して見返り物資としようということになる。",
              "citation": {
                "source": "硯と墨",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
