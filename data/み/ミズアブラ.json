        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また、鬢附と梳油と水油とこの三種の油必要なり。",
              "citation": {
                "source": "当世女装一斑",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奥様のように、髪に手入れをなさらないではいけません」と、私の頭の雲脂を落したり、梳いたりしてくれた上に、「少しお頭を拝借させて下さい」と、水油を少し附けて、丸髷に結ってくれました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅紗、唐桟、金巾、玻璃、薬種、酒類なぞがそこからはいって来れば、生糸、漆器、製茶、水油、銅および銅器の類なぞがそこから出て行って、好かれ悪しかれ東と西の交換がすでにすでに始まったように見えて来た。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときに風全く収まり、海水油のごとく滑らかに、鏡のごとく明らかなり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気清朗、風波穏静、海水油のごとく、夕照朱のごとし。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときの扶持が御切米金十五両、御合力七両二分の他に、月々薪六貫四分、炭二俵八分、水油八合、糠二升八合、菜銀三十匁で、子供を三人使うことが出来た。",
              "citation": {
                "source": "柘榴",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
