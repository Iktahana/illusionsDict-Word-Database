      {
        "index": 1,
        "gloss": "carpenter specializing in temple, shrine, etc. construction",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
