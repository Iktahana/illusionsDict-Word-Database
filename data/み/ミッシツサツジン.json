    "definitions": [
      {
        "index": 1,
        "gloss": "locked-room murder (e.g. in murder mystery fiction)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もしくは密室殺人の手口を発案するのと似たようなタンテイ眼の所産だね。",
              "citation": {
                "source": "フシギな女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「黄色い部屋」は密室殺人の元祖でもある。",
              "citation": {
                "source": "推理小説論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさに密室殺人とはこのことで、下の物置は四囲をぬりかためて、出ることも、はいることもできない。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十三　幻の塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼も耳も、人並み以上に働く八五郎ですが、その材料をかき集めて、動きの取れない證據に組み立てる段になると、どうも、八五郎の智惠では、密室殺人の謎は解けさうもありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美少年國",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の横に伏せてある本の表紙には“ハイライト著　密室殺人事件”と印刷されてる。",
              "citation": {
                "source": "浴槽",
                "author": "大坪砂男",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　ここで相手はにやにやと顔を崩して、「残念ながら、密室殺人事件にはなりませんでしたよ。",
              "citation": {
                "source": "浴槽",
                "author": "大坪砂男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは残虐な殺人事件で、しかも「密室殺人」なのだが、警察の方では人間の兇悪犯人ばかり探していると、素人探偵デュパンが、ある面白い手掛りから、動物に着眼し、巧みにその犯人を捕える。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「密室殺人」というのはその部屋の窓にもドアにも内部から鍵がかけられ、金庫のように密閉されていて、その内に被害者が倒れている。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの作では密室殺人の場所として憑かれた家（ホーンテッド・ハウス）が用いられている。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
