        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "霙は雨と雪の混じたもので、これも有りふれた現象である。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（英国で俗にスリートと言うのは我邦の霙である。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "春先とはいえ、寒い寒い霙まじりの風が広い武蔵野を荒れに荒れて終夜、真っ闇な溝口の町の上をほえ狂った。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど教師は知らざりき、かく想いやりし幾年の後の冬の夜は翁の墓に霙降りつつありしを。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪は霙と変わり霙は雪となり降りつ止みつす。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸助を中にして三つの墓並び、冬の夜は霙降ることもあれど、都なる年若き教師は源叔父今もなお一人｜淋しく磯辺に暮し妻子の事思いて泣きつつありとひとえに哀れがりぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を切るような風吹きて霙降る夜の、まだ宵ながら餅屋ではいつもよりも早く閉めて、幸衛門は酒一口飲めぬ身の慰藉なく堅い男ゆえ炬燵へ潜って寝そべるほどの楽もせず火鉢を控えて厳然と座り、煙草を吹かしながらしきりに首をひねるは句を案ずるなりけり。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "霙で、電燈の灯もうるむかと思われるような暗鬱な冬の夕暮であった。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月　それ、おほみそかは大薩摩の、もの凄くも又可恐しき、荒海の暗闇のあやかしより、山寺の額の魍魎に至るまで、霙を錬つて氷を鑄つゝ、年の瀬に楯を支くと雖も、巖間の水は囁きて、川端の辻占に、春衣の梅を告ぐるぞかし。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした日は、これから霙にも、雪にも、いつもいゝものは湯豆府だ。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "霙が降っているのだ。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "熙々として照つてゐた春の陽は何時か烈しい夏の光に變り、澄んだ秋空を高く雁が渡つて行つたかと思ふと、はや、寒々とした灰色の空から霙が落ちかかる。",
              "citation": {
                "source": "名人傳",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "煕々として照っていた春の陽はいつか烈しい夏の光に変り、澄んだ秋空を高く雁が渡って行ったかと思うと、はや、寒々とした灰色の空から霙が落ちかかる。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時雨も霙も知っている。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "軒に干したる日は、時雨颯と暗くかゝりしが、曳く頃は霙、霰とこそなれ。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫婦乞食は霙の降る中を寒さに赤さつま芋色になった手をつなぎ合って、町の表通りから溝の橋を渡って遊郭へ入って行きます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご両人」　と揶揄い声をかけますけれども、二人の姿は、つゆ乱れるところもなく同じリズムを霙の中に、しくりかえし、とくりかえしして行きます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は手をつないだまゝ霙の中を進んで行きます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "霙は雪になりかけて、凝る雲も暗く北の空から地へ頭を競って巻き下ろうとしております。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨まじり霙ふる日も、風まじり雪の飛ぶ夜も、こごしくも凍え立ちたり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨、雪、霰、雹に霙、それさへたちまち消えうせぬ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふりそそぐものみなあはれなり、雨、雪、霰、雹に霙、それさへたちまち消え失せぬ。",
              "citation": {
                "source": "第二真珠抄",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴か、曇りか、霙か、雪か、雲はあかるし、夕日は寒し、七歳お店の長松さへも黒い前掛ちよいとしめて、空を見上げちや真面目顔、真面目顔。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴か、曇か、霙か、雪か、雲はあかるし、夕日は寒し、七歳お店の長松さへも、黒い前掛ちよいとしめて、空を見上げちや真面目顔、真面目顔。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして日の光だ、雨の音だ、清しい草花のかをり、木の葉のそよぎ、しめやかな霙、雪の羽ばたきだ。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨まじり霙ふる日も風まじり雪の飛ぶ夜も、こごしくも凍え立ちたり。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸いたみ、春の霙の降る日なり。",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛に就て瞳は金貨足あと銀貨そして霙ふり涕垂らして物質の精神の冬はきたつけがもういつてしまつた。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひかりうづまく黒の雲、　　ほそぼそめぐる風のみち、苔蒸す塔のかなたにて、　　大野青々みぞれしぬ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けむり停まるみぞれ雲、　　峡を覆ひてひくければ、大工業の光景なりと、　　　技師も出でたち仰ぎけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
