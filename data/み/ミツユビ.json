    "definitions": [
      {
        "index": 1,
        "gloss": "bowing while pressing three fingers of each hand on floor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そういう時、妻はわざわざ私の所へやって来て、『遅くなりますから、お先へ休ませて戴きます』と言う、丁寧に三つ指をついてお辞儀をし、それから自分の寝床へ入る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関の格子戸をあけると間もなく障子がスーッと開いて、私より一つか二つ上位に見える痩せこけた紺飛白の書生さんが顔を出して三つ指をついた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車が鶴原家に着くと若先生……ではない妻木君が、この間の通りの紺飛白の姿のまま色眼鏡をかけないで出て来て三つ指を突いた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり……」と妻木君は女のように、しとやかに三つ指を支いた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "家霊は言ってるのだ――わたくしを若しわたくしの望む程度まで表現して下さったなら、わたくしは三つ指突いてあなた方にお叩頭します。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして南紺屋町の社へ駈けつけると、のやうに車を飛び出し、二つ三つ指図をして、やがてまたゆつたりと自動車の人となる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、籐椅子に尻を据えて、勝手な気焔をあげていると、奥さんが三つ指で挨拶に出て来られたのには、少からず恐縮した。",
              "citation": {
                "source": "田端日記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎の足あとらしい三つ指ついたのが、かなたの谷へ、長く長く引いている。",
              "citation": {
                "source": "雪の武石峠",
                "author": "別所梅之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の出入りには、家人の誰かが必ず玄関に三つ指をついて送迎しなければならないそうですね。",
              "citation": {
                "source": "道標",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お待ち申し上げておりました」　三つ指をついて若いお小間遣いがうやうやしく迎えた。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙なやつがやってきたと思って眺めていると、その男は数寄屋の濡縁に近い庭先へ三つ指をつき、右手を口にあてて、えへん、えへんと二度ばかり軽く咳払いをした。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "捨公方",
                "note": "青空文庫"
              }
            },
            {
              "text": "村垣は庭土に三つ指をついて首を垂れたまま、いつまでもじっとしている。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "捨公方",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げるようにお露の去ったのを萩乃は眼ざとく、眼のすみで意識しながら、たえてひさしい源三郎の前に、お屋敷育ちの三つ指の挨拶。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "敷居に、三つ指をついていた。",
              "citation": {
                "source": "元禄十三年",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "向き直って、三つ指を突いた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁葺の洒落た門を入って、右左に咲き過ぎた古木の梅を眺めながら、風雅な入口の槃を叩くと、「…………」　美しい女中が現れて、行儀正しく式台に三つ指を突きます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幻の民五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しばらく御待ち下さいまし」　芝居の御腰元の外には見たこともないような、淑かな女中が姿を隠すと、「へッ、三つ指で、――御待ち下さいまし――と来やがった、親分、悪い心地はしないネ」「馬鹿」　平次は睨む真似をして見せます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幻の民五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お照さんを怨んでゐるのは御内儀が一番だが、先生が塔へ通つた晩は、必ず後をつけて來て、先生より一足先に母屋に歸つて、お床の前に三つ指を突いて迎へる御内儀が、塔の頂上に引返して、お照さんを殺せるわけが無いぢやありませんか」「成程、うまい言ひわけがあるもんだな。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "軍學者の妾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は小堀和泉守樣御上屋敷に仕へて居ります、早瀬と申します、御見識り置きを――」　三つ指が縁無し疊の上を滑つて、小笠原流にピタリと極るのを、錢形平次さすがに持てあまし氣味でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁葺の洒落れた門を入つて、右左に咲き過ぎた古木の梅を眺め乍ら、風雅な入口の槃を叩くと、「――」　美しい女中が現はれて、行儀正しく式臺に三つ指を突きます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "幻の民五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　三つ指を突いて迎へたのは妹のお京、町内の若いのが、顏を一と目見るだけのことに、三晩湯屋の前を張つてゐたといふピカピカする娘です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "捕物仁義",
                "note": "青空文庫"
              }
            },
            {
              "text": "「金、顔を挙げえ」「…………」　狭い船の中ですから、聞えるも聞えないもありません、お金はすぐ側に三つ指を突いて、頑固に黙り込んで居りますが、その俯向いた美しい顔には、きかん気が虹の如く輝やくのはよくわかります。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第八夜　蛇使いの娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　三つ指を突いて迎えたのは妹のお京、町内の若いのが、顔を一と目見るだけのことに、三晩湯屋の前を張っていたというピカピカする娘です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "捕物仁義",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は小堀和泉守様御上屋敷に仕えております、早瀬と申します、御見識りおきを――」　三つ指が縁無し畳の上を滑って、小笠原流にピタリと極るのを、銭形平次さすがに持てあまし気味でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "「唯今戻りました」　小買物にでも行つたらしい内儀のお延は、杉之助の前に三つ指を突いて、それから平次と八五郎に丁寧に挨拶しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "遺書の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ただ今戻りました」　小買物にでも行ったらしい内儀のお延は、杉之助の前に三つ指を突いて、それから平次と八五郎にていねいに挨拶しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "遺書の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私に御用と仰しやるのは」　縱やの字に三つ指、爪はづれの尋常さ、これが神樂坂でさゝやかに暮した、背負小間物屋の娘でせうか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美しき人質",
                "note": "青空文庫"
              }
            },
            {
              "text": "大野　以前は、いつも着物を着て、マゲなどにゆって――いや、あれもよく似合っていられたからねえ――三つ指をついてさ、全くの日本趣味の――忘れもしません、三芳君が二度目に、この、引っぱられた時に、あんたが真青な顔をして私んところに駆けこんで来られた時さ――三芳　おい、津村君の方は、いいのか？",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つ指式であったら、私は自分が熊の仔にでもなったように工合わるくて迚ももちませんでしたろうから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
