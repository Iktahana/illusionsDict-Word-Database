    "definitions": [
      {
        "index": 1,
        "gloss": "approach (to a castle gate)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さうあるべきがよかつたかも知れない多くの元気な顔たちの中に、私は容易におまへを見付ける。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の後に出た詩人達は彼女の中に様々な美点を見付けた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンは日本の煙管を好んだので、夫人が外出するごとに変った物を見付けて帰った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が屋根と屋根との間から落ちる、やつと自分の背幅程の日向に、自分のおかつぱの影を見付けた時に、小僧とお祖母さんの話声が聞え出してゐた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、それが朝の空に聳り立つてゐるのを見付けた瞬間、愕然と思ひ出した。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも餓鬼大将の悪戯小僧は、必ず僕を見付け出して、皆と一緒に苛めるのだった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は少年時代に黒岩涙香やコナン・ドイルの探偵小説を愛読し、やや長じて後は、主としてポオとドストイェフスキイを愛読したが、つまり僕の遺伝的な天性気質が、こうした作家たちの変質性に類似を見付けた為なのだろう。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後この文房具店で同じような色々の皿を見付けて一つ欲しいと思い立ったが、今日まで機会がなかったのである。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三囲の稲荷堤上より拝し、腹まだ治まらねば団子かじる気もなく、ようやく百花園への道札見付けて堤を右へ下り、小溝に沿うてまがりくねりの道を行く半町ばかり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした茫漠たる冬田の中に一羽くらい鴫が居るのを見付け出すということは到底｜素人には出来ない芸当であったが、さすが専門家の要太の眼には、不思議なフィルター・スクリーンでもあるかのように、実に敏感に迅速にそれを発見するのである。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りにはやっぱり御院殿の坂が見付かった。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い湿っぽい朽葉の匂のする茂みの奥に大きな虎杖を見付けて折取るときの喜びは都会の児等の夢にも知らない、田園の自然児にのみ許された幸福であろう。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローマの大学を訪ねたとき、物理学教室の入口に竹の一叢を見付けてなつかしい想いをした。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡兎が森の方からやつてくるのを見付けると牝狐は、急いで子供達に云つた、「何時もの彼が来たらば、私は家にゐないとお云ひ。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで牡兎を見付けるや彼女は彼を修道僧だと思ひ込んだ。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の照る砂地に落ちてゐた硝子を、歩み来た旅人は周章てて見付けた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ファンネルの烟を追っていた火夫が、烟の先に私を見付けて、デッキから呶鳴った。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れから行先にまだいくらも同じやうな煙突の一對があるだらうからもう少し詳しく觀察してやらうと思つて注意してゐたが、たうとう見付からずに澁川へ着いてしまつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黍を主題にしたのが一枚描き度かつたがどうも工合のいゝ背景が見付からなかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は気象観測というものがなかったから遺憾ながら数量的の比較は出来ないが、しかし古来の記録に残った暴風で今度のに匹敵するものを求めれば、おそらくいくつでも見付かりそうな気がするのである。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "出口へ出るとそこでは下足番の婆さんがただ一人落ち散らばった履物の整理をしているのを見付けて、預けた蝙蝠傘を出してもらって館の裏手の集団の中からＴ画伯を捜しあてた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子の岳神は暇な暇な、父の祖神を山中に案内して見せて廻るうち、ある日、山ふところの日当りの小竹原を通りかかり、そこに二坪近くの丸さに、小竹之葉が剥げ、赤土が露き出ているのを見付けると、息子の岳神は指して笑いながらいった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手の山や岳神を詮議して、とかくそれ等に不足を見付け出した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に見付からぬように」　昭青年だとて、先にあてがあるわけではありませんが、差当って今の取り做し方としては、これ以外に無かったのでした。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、昭青年は早く機会を見付けて何とか始末をしなくては、悟道の妨げにもなるし、姫のためにもよくない。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見付かったら最後、二人はどんな運命になるか判らない。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れてこんなこと始めてだ」「麦とろの食べ過ぎかね」老妓は柚木がよく近所の麦飯ととろろを看板にしている店から、それを取寄せて食べるのを知っているものだから、こうまぜっかえしたが、すぐ真面目になり「そんなときは、何でもいいから苦労の種を見付けるんだね。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この間、島田で、大井川の川越しに使った蓮台を持ってる家を見付けた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの巴里人のならわし通りこの男も老後を七、八十｜里巴里から離れた田舎へ恰好な家を見付けて買取り、コックに一人の女中ぐらい置いて夫婦の後年を閑居しようという人達だ。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「家は腰高の塗骨障子を境にして居間と台所との二間のみなれど竹の濡縁の外には聊かなる小庭ありと覚しく、手水鉢のほとりより竹の板目には蔦をからませ、高く釣りたる棚の上には植木鉢を置きたるに、猶表側の見付を見れば入口の庇、戸袋、板目なぞも狭き処を皆それぞれに意匠して網代、船板、洒竹などを用ゐ云々」。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
