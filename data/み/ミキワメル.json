    "definitions": [
      {
        "index": 1,
        "gloss": "to watch to the end",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "細い手で受け取った鏡を、京子は朝日にかざしてきらりと光らせ、傍の者を眩しがらせてから、も一度、朝陽の在所を見極める。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがシャーロック・ホームズは、心のなかにわだかまる問題があると、何日も、いや何週間も休みなく、そいつをひっくり返しては事実を再び並び替え、隅から隅までじっくり眺め回して、そいつを見極めるか、検討材料が不十分だとわかるかするまで起き続ける、そんな人間だった。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵術に最重要なのは、数ある事実から周辺のものと本質とを見極める能力です。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "六郎は曲物と思ったので、己の体を見せないようにと、ちょと己を見返って、それが木立の陰になっているのを見極めると、急いで雨戸の方へ眼をやった。",
              "citation": {
                "source": "頼朝の最後",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ如何なる時でも、レースに対してはそのレースの本命が確実かそうでないかを先ず第一に見極める精神を忘れてはならない。",
              "citation": {
                "source": "競馬の一日に就いて",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは如何にも彫刻家が物のかたちを見極める無言の観察であるかの如く、余念のない、清澄な沾みを持つてゐた。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その異同を見極めるだけにでも女性の中から天才の出現するのは最も望まるべきことだ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて闖入者に他意がないらしいのを見極めると、海老は安心したように、しずかにお洒落の鼻眼鏡の柄を畳んでしまう。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はわが久しく飼ひつゝ馴れたその赤い色が、どちらへどう飛んだかを見極めるいとまもなく、そのまゝ走せて馬車に乘る。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つには、わたくしも確かに彼奴と見極めるほどの立派な証拠を握ってはいないんですから、まあ手探りながら無暗にあんなことを云って見たんで……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "勘平の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見極めると同時に突然野島は「ワン、ツー、スリーツ。",
              "citation": {
                "source": "渚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから私は、彼女の私に対する忠実な方面を一層見極めることで、云はゞあんな寂しさから救はれようと努めた。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「果して出發點であるか、求めつつある過程であるかといふことも、こりや、見極めるのになかなか面倒なことでね。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "除去さるべき惡の根源に立ち向ふ勇氣は勿論、見極める勇氣さへ持たぬ小ブルジヨアが、窖のなかに駈け込むためにつけた一つの假面さ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は語氣をも強めず、平然とそれを云つてのけたが、心では樣子如何にと相手を見極めるやうな氣持であつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どつちの方向へであるか、勿論見極める餘裕などはなかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス全国の同業者等は、この唐突に現れた資本も少ない若年の一出版業者が、疑なく時流に投じるであろう出版計画をもっていることを見極めると、共通な悪計によって結束した。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、自分のいつた言葉の効果を見極めるのみならず、自分の言葉を更に強調したんだ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユーザーからの使用感に関する報告や不満の声を直接聞けないでいることも、製品改良の方向を見極めるうえでは問題だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして伯母の寢る時、一度一緒に寐たふりをして、伯母の寐ついたのを見極めると、そつと自分だけ起きて、まだ女中部屋に起きてゐるお時の所へ出かけるのです。",
              "citation": {
                "source": "反古",
                "author": "小山内薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「不自然に歪めるもの」さへはつきり見極めることが出來れば先づ危險信號の標識がわかるわけである。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼には被告の悲しみは自分に悲しめられた名残りの悲しみであるのか、それとも被告自身の秘めた行為を意識しての悲しみであるのか明瞭に見極めることが出来なかつた。",
              "citation": {
                "source": "マルクスの審判",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "因縁と云うものゝ恐ろしい事は、貞子が普通ありふれた服装をしていたのなら、又見極める事もむずかしかったであろうが、彼女は田辺校長の鑑定で分る通り、誠に特異な帯を締めていたので、僅に残った帯地が彼女を確認する手段となった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら――」　葉子は、上り口の手すりを握んだ儘、一目でこの狭い部屋の中の様子を見極めると、「黒ちゃん、おたのしみね、……ほほほ、一人だよ、なんて可笑しくって……。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは物の本体を見極める眼である。",
              "citation": {
                "source": "大人の眼と子供の眼",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の家から豊かに煙の立ちのぼるのを見極めると、仁兵衛はいつも著換してその家に行く。",
              "citation": {
                "source": "念珠集",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の蒼い光りの底を、闇が黝々と流れて、どんな男かはつきり見極めることは出来なかつたが、宇津はすぐさう感じた。",
              "citation": {
                "source": "間木老人",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君は、遅くも六ヶ月の後に、自分の進むべき道を見極めるか、然らずんば、進むべからざる道を知り得るだらう。",
              "citation": {
                "source": "俳優養成と人材発見",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（雲の切れる天の果ては一望するもみきわめることはできず、北洋の風景を船のれんじ窓を通してみる。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の心がどのような状態にあるか、まずそれをみきわめる必要がある。",
              "citation": {
                "source": "日本婦道記",
                "author": "笄堀",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
