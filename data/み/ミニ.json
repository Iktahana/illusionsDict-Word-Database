        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "途中の淋しい小驛の何處にでも、同じやうな乘合自動車のアルミニウム・ペイントが輝いて居た。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽い双眼鏡　今度ロンドンのネグレッチ・アンド・ザンブラで売り出した新形の双眼鏡「ミニム」というのは従来の双眼鏡中で最も軽いものである、その倍率は八倍で重量七十五匁くらい、柔らかい皮袋に入れて隠袋に収めるように出来ている。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "フェミニストにもいろいろある。",
              "citation": {
                "source": "女性崇拝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「英雄が女性の胸に額をつけるとき、遠き星の囁きを聴く」事業上の霊感の交媒者として女性に神秘を感じ、フェミニストたるものもある。",
              "citation": {
                "source": "女性崇拝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角真のフェミニストは質的のものだ。",
              "citation": {
                "source": "女性崇拝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性から言えば、弱々しくフェミニストたらざるを得ない男性より昂然としていても、女性に理解力ある男性の方が見込みがある。",
              "citation": {
                "source": "女性崇拝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "レモンの花咲く国に憧れるのは単にミニョンの思郷の情のみではない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "由来物理学者はデターミニストであった。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚水中にアルミニウムの電極を入れて電流を通ずれば、過酸化アルミニウムを生じ、これが種々の汚物に結合して固まってしまう。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミニオンの伊太利人は、路傍楽人にならねばならぬのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "天界ホテルのサルーンへ這入ると、有名な五十に近い小柄な舞踏の師匠を取巻いて、コムミニストだというマルクス派の作家らしい男達がひどく酔って女達に愛想をつかされていた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ラグビー争闘の場合の靴の跡を刺繍され、……野球における華美な盗塁と、……水球のときの潜水と、……ミニチュア、ゴルフの墜死と、……ボクシングにおける残酷な、……マットの中の死を。",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "而もそのマキシマムになる錯覺とミニマムになる錯覺とが入れ代り立ち代り交錯する。",
              "citation": {
                "source": "自分の變態心理的經驗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、日本の地殻構造が細かいモザイックから成っており、他の世界の種々の部分を狭い面積内に圧縮したミニアチュアとでもいったような形態になっているためであろうと思われるのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱庭は言葉どおりに庭園のミニアチュアである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "筒の外側はアルミニウムペイントで御化粧をしてあるが、金属製だかどうだか見ただけでは分らない。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンミニストは日を逐うて、戦いの用意を整えている……」この悲痛な手紙を突きつけられた、裏切者、蒋介石の軍司令部の一行だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "モロビト山ニ入ラントテ、　　　朝明ヲココニ待チツドヒ、或イハ鋸ノ目ヲツクリ、　　　　アルハタバコヲノミニケリ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど従来の再起的という言葉はいわゆるデテルミニスティックな意味での再起性を意味するものであるから、そういわれるのは一応はもっともらしいようであるが、しかし以上のいわゆる非再起的の場合でも、統計的の意味ではちゃんと決定的再起的である。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおぜいの押し合う力の合力の自然変異のために神輿が不規則な運動をなしている状態は、顕微鏡下でたとえばアルコホルに浮かぶアルミニウムの微細な薄片のブラウン運動と非常によく似た状態を示している。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯槽にはいったまま腕をのばし、水道のカランをひねって、備付けのアルミニウムのコップで水を幾杯も幾杯も飲んだ。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女は、私にアルミニウムのコップを、だまって渡した。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはでこぼこではありましたが、アルミニユームでできてゐましたから、大丈夫こはれませんでした。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどアルミニウムだかマグネシウムだかの閃光は光度において大きく、ストロンチウムだかリチウムだかの炎の色は美しいかもしれないが、始めからおしまいまでただぼうぼうと無作法に燃えるばかりで、タクトもなければリズムもない。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの漫画の長所は、音楽との対位法的モンタージュを行なう場合における視像のエキスプレッションが自由自在であって、画像の運動は pp から ff まで任意に大なる変化をすることができ、クレッセンドー、ディミニゥエンドー勝手次第なことである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上のことが、この話の主人公に分らなかったのは、恐らく彼が事件の渦中にあり、しかも明日子を愛していたというその時の彼のフェミニズムの為ではなかったろうか。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の智識人や武士たちは、自分より身分階級の高い所の、所謂「やんごとなき」貴族の姫君等に対して、心ひそかに思慕の恋情を寄せ、騎士道的崇拝に似たフエミニズムを満足させてゐた。",
              "citation": {
                "source": "月の詩情",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
