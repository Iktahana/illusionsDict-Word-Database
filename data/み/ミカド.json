    },
    "definitions": [
      {
        "index": 1,
        "gloss": "emperor (of Japan)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "東京｜帝国大学の招聘に応じて、松江や熊本の地を去ったことも、同じくヘルンの身にとっては、愛する妻への献身的な犠牲だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、この帝大生が佐野次郎左衛門さ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、旅行者にとってはのんきそうに見えながらも、帝都の人たちはすべて懸命の努力で生きているのだという事を、この北京の客に説明してやろうかしらと、ふと思った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユーモアを虐待することと、人格者であるといふことと、平和と苟安とは同義で通用する日本の、そして帝都は彼の育つた雰囲気であつた。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "入学証書と云ったような幅一尺五寸｜長二尺ほどの紙に大きな活字で皇帝や総長の名を黒々と印刷したものを貰ったが文句はラテン語で何の事か分らない、見ていると気の遠くなるようなものであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京帝国大学の卒業証書も検閲のために差出したが、この日本文は事務の役人にとって自分の場合のラテン語以上に六かしそうであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物々しい番兵の交代はベルリン名物の一つであったが、実際いかにも帝政下のドイツのシンボルのように花やかでしかもしゃちこばった感じのする日々行事であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためにその頃郷里でただ一人の東京帝国大学卒業医学士であったところの楠先生の御厄介になることになった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピョートル大帝の目玉が、雲の中で光つてゐる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "遥に北へ行くと、白馬岳が聳えている、雪の室は花の色の鮮やかな高山植物を秘めて、千島｜桔梗、千島｜甘菜、得撫草、色丹草など、帝国極北の地に生える美しいのが、錦の如く咲くのもこの山で、雪が白馬の奔る形をあらわすからその名を得たということである。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてどこから見ても、神河内を統御する大帝は穂高岳で、海抜五千七百尺の神河内から聳ゆること更に五千尺に近く、梓の濶流も、支線の小峡流も、その間の幾十反の点々たる平地も、何もかも一切包まれた谷は、神つ代の穂高見の命の知ろし召す世界である。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "木曾川を下って、白帝城に擬せられた犬山城があるために、日本ラインの名を、（好むにせよ、好まざるにせよ）いかに適切にひびかせるであろう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「のろい振動の長い週期」を略して「帝展」「震研」流に云ったものと思えば不思議はないのである。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞西あたりの山のホテルを想はせるやうな帝国ホテルは外側から観賞しただけで梓川の小橋を渡り対岸の温泉ホテルといふ宿屋に泊つた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ道を引返して帝国ホテルで昼飯を食つてから、今度は田代池といふのを見に行つた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように、颱風は大陸と日本との間隔を引きはなし、この帝国をわだつみの彼方の安全地帯に保存するような役目をつとめていたように見える。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スイスあたりの山のホテルを想わせるような帝国ホテルは外側から観賞しただけで梓川の小橋を渡り対岸の温泉ホテルという宿屋に泊った。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ道を引返して帝国ホテルで昼飯を食ってから、今度は田代池というのを見に行った。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国の名優の梅蘭芳が帝国劇場に出演しに来たとき、その肝煎りをした某富豪に向って、老妓は「費用はいくらかかっても関いませんから、一度のおりをつくって欲しい」と頼み込んで、その富豪に宥め返されたという話が、嘘か本当か、彼女の逸話の一つになっている。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "梁の武帝因みに僧〔に〕問ふ、あゝいかん、梁の武帝達磨に問ふ　磨の曰く無功徳　帝の曰く朕に対する者は誰ぞ　磨の曰く無功徳　いかん朕に対する者は誰ぞ　磨の曰く不識！",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「帝釈の湯で、熊また捕れたってな。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーベントという言葉を用いたのは明治の終りか大正の初めころ、帝大の山上御殿ではじめて開かれた哲学会のカント・アーベントあたりが最初であったろうと思う。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことを考えながら帝劇の玄関を下りて、雨のない六月晴の堀端の薫風に吹かれたのであった。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭湯の湯船の中で見る顔には帝国主義もなければ社会主義もない。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは上野の科学博物館とその裏側にある帝国学士院とが意外に遠く離れて見えるということである。",
              "citation": {
                "source": "観点と距離",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一高等学校を経て東京帝国工科大学造船学科へ入学し、明治三十三年卒業した。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十二年関東大震災以前から既に地震学に興味をもっていたが、大震災の惨害を体験した動機から、地震に対する特殊の研究機関の必要を痛感し、時の総長｜古在由直氏に進言し、その後援の下に懸命の努力をもって奔走した結果、遂に東京帝国大学附属地震研究所の設立を見るに到った。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二年には帝国学士院会員となった。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眺めるのは開け放してある奥座敷を通して眼に入る裏の谷合の木がくれの沢地か、水を撒いてある表通りに、向うの塀から垂れ下がっている椎の葉の茂みかどちらかである。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず伝説の方から云うと、人皇第九十二代のみかど伏見天皇のおんときに、小刑部という美しい女房が何かの科によって京都から播磨国に流され、姫山――むかしは姫路を姫山と云った。",
              "citation": {
                "source": "小坂部伝説",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
