[
  {
    "uuid": "d6e92ca3-e2a1-58e4-909a-e8aed528a1be",
    "entry": "見ぬふり",
    "reading": {
      "primary": "みぬふり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
