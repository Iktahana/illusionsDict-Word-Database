    "definitions": [
      {
        "index": 1,
        "gloss": "Maitreya (Bodhisattva)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
