    "definitions": [
      {
        "index": 1,
        "gloss": "ripening (of a crop)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
