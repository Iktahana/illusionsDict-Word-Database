    "definitions": [
      {
        "index": 1,
        "gloss": "before one's own eyes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
