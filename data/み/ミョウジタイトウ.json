[
  {
    "uuid": "df27ea87-afe4-55a8-982e-9fc138f9d84f",
    "entry": "苗字帯刀",
    "reading": {
      "primary": "みょうじたいとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
