    "definitions": [
      {
        "index": 1,
        "gloss": "Mino paper (var. of Japanese paper)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
