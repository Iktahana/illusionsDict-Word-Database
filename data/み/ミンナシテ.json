        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それでは皆して参ってくるがよかろう……いや着物など着替えんでよいじゃないか」　女達は、もう鼻啜りをしながら、それじゃアとて立ちあがる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦々しい奴だと思っている筆者を皆して引っぱって、重役室に挨拶に行った。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "若奥様が、島田のお髪、お振袖と承りましたから、私どもは、余計そのお姿のお目立ち遊ばすように、皆して、かように申合せましたのでございます。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……かつと、かつと、　　かつと、……　それ、揃つて、皆して……」「むゝ、聞こえる、――かつと、かつと――か、然ういへば。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼けたら、焼けたで、皆して力を合せ、焼跡に小屋でも建てて頑張って見ようじゃないか。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死骸の片付けも皆して上げます。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……かっと、かっと、　かっと、……　それ、揃って、皆して……」「むむ、聞こえる、――かっと、かっと――か、そういえば。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったん右近の五条の家に姫君を移して、そこで女房を選りととのえもし衣服の仕度も皆して、十月に六条院へはいった。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならこれから皆していつそ輕井澤まで出掛け、其處の蕎麥屋で改めて別杯を酌んで綺麗に三方に別れ去らうではないか、と。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならこれから皆していっそ軽井沢まで出掛け、其処の蕎麦屋で改めて別盃を酌んで綺麗に三方に別れ去ろうではないか、と。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがマンマと首尾よく図に当ったので、あんなに皆して笑ったのかも知れない。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "“SORI-BATTEN!”麹室の長い冬のむしあつさ、そのなかに黒い小猫を抱いて忍び込み、皆して骨牌をひく、黄色い女王の感じ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "身をもって爆弾庫にとびこんだあの水兵を、皆して褒めてやってくれ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして出来ない奴があったら、皆して分るとこまで教えっこするんだ。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おきん　さあ、皆して、放り込んでしまえ！",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆してお茶飲んで……。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆してお茶飮んで……。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあね、今日倒したぐらゐの奴ア皆して擔いででも持つて來れつけど……。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなにさはぎまはつてゐた紅吉さん今は御良人と静かな大和に、子供を抱いてしとやかな日を送るやうになつたのですもの、あの文祥堂の二階で皆してふざけたり歌つたり、平塚さんのマントの中に入れて貰つて甘へたりした私が二人の母親に、他の皆も母になつたりした事を考へますと僅かの間にと、本当におどろいて仕舞ます。",
              "citation": {
                "source": "編輯室より（一九一六年一月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ皆して木沢さんに来て頂いたりなにかしたのですもの」「そうですか。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "面倒な夫人たちの訪問の供を皆してまわって、時のたったことで中将は気が気でなく思いながら妹の姫君の所へ行った。",
              "citation": {
                "source": "源氏物語",
                "author": "野分",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和守が葬儀の跡の始末を皆してから、「こんなふうになさいまして、まだながく寂しい山荘においでになることは御無理です。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧一",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると右の手の親指がキュッと内の方へ屈っている、やがて皆して、漸くに蘇生をさしたそうだが、こんな恐ろしい目には始めて出会ったと物語って、後でいうには、これは決して怨霊とか、何とかいう様な所謂口惜しみの念ではなく、ただ私に娘がその死を知らしたいが為めだったろうと、附加えていたのであった。",
              "citation": {
                "source": "因果",
                "author": "小山内薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は不思議でならない働らいても働らいても御飯の食へない私と美しい秋の服装と――たつぷり栄養をふくんだ貴女の頬つぺたのはり具合貴女と私の間は何百里もあるんでせうかね――つまらなくつて男を盗んだのですそしてお酒に溺れたんですが世間様は皆して地べたへ叩きつけてこの私をふみたくつてしまふのです。",
              "citation": {
                "source": "蒼馬を見たり",
                "author": "蒼馬を見たり",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は巡査さんも来ると云っていたが、こんな吹雪の烈しい道は、素人には危いので、皆して留めて来たという話であった。",
              "citation": {
                "source": "眼を開く",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "仇を取って来るから』と云って駈け出しそうになりますので皆して押え付けようとしましたが、どうしても静まりません。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで必定後悔するもんだから……てな事を皆して色々云うもんですからね……ハハハ……」　船長の表情は依然として動かない。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで又その足跡が頗る珍妙なんで、皆して色々研究してみたがね。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに皆して妾をジロジロ見ているでしょう。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "晃平が、先刻、未だ日の暮れないうち、朝飯の菜にとて、山款冬数十茎を折って来たのを、みんなして、退屈｜凌ぎに、繊維を抜いては、鍋へ投げ入れる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
