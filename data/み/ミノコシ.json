    "definitions": [
      {
        "index": 1,
        "gloss": "leaving something unseen",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで私は、橋や荷足を見残しながら、　　レストオランに這入るのだ――わんわんいふ喧騒、むつとするスチーム、　　さても此処は別世界。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでも求婚の競争者が相当ございましてね」　という意味のようなことを話しかけると、妻は「まあまあ、そんなお話、どうでもいいじゃございませんか」「それよりかまだ山の中でおとうさまがお見残しのとこもございましょう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "故郷のこういう姿をあとに見残して慧鶴は再び旅に立った。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでまた柳の根方に片足かけ、やおら二本目の煙草を喫ってから、見残した芝居の幕のあとを見届ける気持で、半町ほど距った人混の中のかの女を追った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜にふた晩泊って、三日目に江戸へ帰るというのが最初からの予定であるので、きょうは朝のうちに見残した所をひとめぐりして、神奈川の宿まで親類の者に送られて、お峰とお妻の親子は駕籠に乗った。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをすますと見残した京都の名所を廻って、最後に比叡山越しに大津に出てみようと定雄は思った。",
              "citation": {
                "source": "比叡",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときにはまた風来坊のように、名のある古い建物の門柱についている彫刻を見て廻ったり、見残した絵を見て廻ったりした。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「見残した庭も沢山あるんだが、――」　今の自分は寺の庭も見たくはないと思った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の記憶もない筈の赤ん坊が、眠っているうちに突然に魘えて泣き出したり、又は何か思い出したようにニッコリ笑ったりするのは、母胎内で見残した「胎児の夢」の名残を見ているのである。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の事件か知らないが豆を撒いたように街路を狂奔する号外売を、追い散らす間もなくすり抜けすり抜けして赤坂見附の真中に片手を揚げている交通巡査をちらりと見残したまま一気に東宮離宮横の坂を飛び上った。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "総ては、見残した悪夢であって、未だ頭の中で醒めきっていなかった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "あと二軒を見残して旅館へ帰つたのは午前二時であつた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は是れを幸ひとして、諸友と会談を重ねる機会を作り、また大連と旅順の見残したる所をも歴訪することに決めた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "祇園の夢を見残してひとり千鳥を聞く夜さはしんぞ恋路が悲しかろ。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居は刎が夜に入るから一幕は見残して帰らねばならなかった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は暗い夜を欺むいて眼先にちらちらする電灯の光を見廻して、自分をその中心に見出した時、この明るい輝きも必竟自分の見残した夢の影なんだろうと考えた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は見残して、留守番も火の気も無い家に帰った。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる平凡な場所、小さな隅を見残してもいけない。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "保釈になって、それをモトデに、見残した夢を見ようというわけです」　狸御殿の殿様などは、この手の名人だということである。",
              "citation": {
                "source": "安吾巷談",
                "author": "湯の町エレジー",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝記の資料の見残したのがあるからといつて土蔵の中へ這入つてしまへば、彼が何をしてゐやうと誰も見てゐる者はない。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この望外の見物をどうして見残して帰れるものか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜多院と云っても、はじめてではない、先年、花の盛りにも来て見たことはあるが、今度はその時見残した国宝の職人図だの、岩佐勝以の三十六歌仙だの、そんなものを見せてもらうことが出来れば幸だと思った。",
              "citation": {
                "source": "武州喜多院",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして五日目に、私はまだ見残していた島の方へ向いました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは田圃の近道をば田面の風と蓮の花の薫りとに見残した昨夜の夢を託しつつ曲輪からの帰途を急ぐ人たちであろう。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "白川は大切な夢を見残したような気持で、当座は、ぼんやりとしていた。",
              "citation": {
                "source": "雲の小径",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食後、いつものようにこの居間にこもって、見残した諸届け願書の類に眼を通し出してから、まださほど刻が移ったとも思われないのに、晩秋の夜は早く更ける。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの場所は残らず探したんだが、あそこだけ見残した。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、先刻は急いで見残したが、お萩の荷物を見せて貰おうか」「どうぞ、此方へ――」　お萩の死体を取込んで、ザッと飾った部屋へ、八五郎は通されました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "腰抜け彌八",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、みんなそろって広間へあがると、かわいいお小姓たちが、くだもののお砂糖漬だの、くるみのこしょう入りのお菓子だのをだしました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、王さまはかなしくて、なんにもお口に入れるどころではなく、それに、くるみのこしょう入お菓子はかたくて、お年よりには歯が立ちませんでした。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
