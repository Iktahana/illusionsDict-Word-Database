[
  {
    "uuid": "841e3443-d894-5d2a-855a-91da43ee4ca7",
    "entry": "水茶屋",
    "reading": {
      "primary": "みずぢゃや",
      "alternatives": [
        "みずちゃや"
      ],
      "is_heteronym": false
    },
    "grammar": {
