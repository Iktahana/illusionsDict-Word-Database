[
  {
    "uuid": "3ce780ec-ed9d-5d6e-9af6-5c90c9aaa467",
    "entry": "見返す",
    "reading": {
      "primary": "みかえす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
