    "definitions": [
      {
        "index": 1,
        "gloss": "Miyazaki Prefecture (Kyūshū)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "高森は今宮崎県の中学で英語の先生をしてゐる。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから半年ばかり上京して牛込あたりの下宿にゐたが、就職口があつたんだと云つて宮崎県に行つた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮崎県では、大事な名所の一つとしているのだろうが、島中に青島神社を祭ったぎり、その特徴ある島の成因について、科学的な説明を与えた印刷物などはどこにも売っていない。",
              "citation": {
                "source": "九州の東海岸",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……宮崎県では旅人の届出書に、旅行の目的を書かせる、なくもがなと思ふが、私は「行脚」と書いた、いつぞや、それについて巡査に質問されたことがあつたが。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮崎県の文化はたしかに後れてゐる、そして道を訊ねても教へ方の下手、或は不深切さが早敢ない旅人を寂しがらせる、たゞ町名標だけは間違ひなく深切だつたが。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の同僚は多くは鹿児島県人や佐賀県人や宮崎県人で、彼とは感情の上でも、これまでの生活環境でも大変な相違があった。",
              "citation": {
                "source": "奥間巡査",
                "author": "池宮城積宝",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、明治卅六年において長男の健行が前年を以て農科大学の乙科獣医科を卒業しこの年は宮崎県の農学校に採用されて赴任する事になったので、私もそれと同伴して松山に赴いた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "長男健行は前にいった、宮崎県より更に台湾の農事試験場に転任していたし、次男の惟行は北京で病み付いた頃であるから宅には居ない、それからいい落したが、次女の静はもう十年も前日清戦争の終った年に、凱旋した同郷人の騎兵大尉の小崎正満へ嫁した。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし日向の高千穂町を主張する宮崎県と霧島山の高千穂峯を主張する鹿児島県とが高天原の本家争いをしているのでも分るように、伝説を史実化しようとするのが無理だ。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮崎県内を自動車で走りながらも中食は駅弁を買って食うのを楽しみにしていたものだが、山中へはいると旅館が土地の食べ物を食べさせてくれないので残念だった。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "小村壽太郎は宮崎県の出身。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちなみに右田村氏は、かつて日向の国〔宮崎県〕において一の新蜜柑を発見し、これを小夏蜜柑と名づけて世に出した。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ切り忘れていたところが、二、三カ月経って、宮崎県庁の人が、大きい箱をもって、玄関へやって来られた。",
              "citation": {
                "source": "南画三題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二七項　屋内の怪音　宮崎県宮崎郡田野村にて、村長より直接に聞いた話に、その村のある民家に、二階の人のおらざる所に、毎夜キー、キー、キーと鳴る音がするので、妖怪の仕業に相違なかろうとて、たちまち大評判となり、わざわざ探検に出かけるものも、みなその音を聞いて、驚きかつ恐れて帰って来る。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔宮崎県の延岡に行ったとき、新聞取次店の亭主が、「今日はこれから町会に行きますんで」という。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "デハ　宮崎県などでは、デハというのがこの食用米のことである（日向の言葉巻三）。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケイモ　宮崎県の一部には、里芋をそう呼ぶ処がある。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "別府は宮崎県などでは国司の別荘ででもあったかのごとく思っている人もあるらしいが、そう想像するには少しばかり数が多くあり過ぎる。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "又宮崎県の郷土志資料には、あの地方の妖怪｜変化の目録が、先々月から連載せられている。",
              "citation": {
                "source": "おばけの声",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "栃木県河内郡｜豊郷村では会葬者は弓を持つと云うし、宮崎県の米良山の山村でも同じく弓を持つと物の本に載せてある。",
              "citation": {
                "source": "本朝変態葬礼史",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルコールの毒性は上澄みにあるというのが、宮崎県出身の興梠二曹の説で、いい加減燃えると吹き消し、水で割る。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず思い出したのは桜島の爆発当時宮崎県にいた人からきいた話である。",
              "citation": {
                "source": "地異印象記",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「宮崎県とか仰有っていましたよ」「宮崎あたりから来ると、こゝは物価が高いからね。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「宮崎県は論外として熊本県は万事立ち後れの観がありますよ」　と三輪さんの兄さんが言った。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り宮崎県はゆっくり案内するぜ」　と小林さんが帰りがけに団さんに諮った。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はこれを七県に分ち、福岡県、佐賀県、長崎県、熊本県、大分県、宮崎県、鹿児島県とします。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主な分布区域は宮崎県から熊本県にわたる県｜境いであります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊本県の南部でケサカケ、嶺を越て宮崎県の西隅でもケサバナというのは、やはり同じように折って首に掛ける風があったからと思う。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に九州の南の方、鹿児島県や宮崎県ではこれをコシギンと謂っている。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "是について私の心づいた一つの例を挙げると、『全国方言集』には宮崎県のどこかで、食用米をデハと謂うとある。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
