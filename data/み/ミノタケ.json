        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一瞬で、周圍の景色が、からつと晴れたやうな、自分が急に身の丈一尺のびて、ちがふ人種になつたやうな、やはり、晴れがましい氣持であつた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして七合五勺の室へ来て、海抜三千二百米と、棒杭に註されたのを見たとき、私は身の丈が急に高くなったような気がした。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポートサイドでレモンの皮のはいった塩水で嗽をしてスエズ運河の両岸の夜景に挟まれて身の丈を長くした妾は天晴れ一人前の女になったのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の附近の、身の丈ほどの灌木の繁っているところにも、なお人が、動いている気がした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "額の出た、頭の大きい、鼻のしゃくんだ、黄色い顔が、その長さ、大人の二倍、やがて一尺、飯櫃形の天窓にチョン髷を載せた、身の丈というほどのものはない。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "海野は年配三十八九、骨太なる手足飽くまで肥えて、身の丈もまた群を抜けり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　顔に苔むしたる髯を撫でつつ、立ちはだかりたる身の丈豊かに神崎を瞰下ろしたり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（尖へ玉のついた長杖を突き、草色、石持の衣類、小倉の帯を胸高で、身の丈六｜尺あまりもあらうかと云ふ、大な盲人）――と云ふのであるが、角帯を胸高で草色の布子と来ては、六｜尺あまりの大な盲人とは何うも見えぬ。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の鳥打をずぼりと深く、身の丈を上から押込んだ體に被つたのでさへ、見上げるばかり脊が高い。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊笹は人の身の丈を没すという深さ、暗い林の遠くには気味の悪い鳥の声がして、谿川の音は物凄いように樹立の間に唱っている。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "法師が入った口とは対向い、大崩壊の方の床几のはずれに、竹柱に留まって前刻から――胸をはだけた、手織｜縞の汚れた単衣に、弛んだ帯、煮染めたような手拭をわがねた首から、頸へかけて、耳を蔽うまで髪の伸びた、色の黒い、巌乗造りの、身の丈抜群なる和郎一人。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "檐下の黒いものは、身の丈三之助の約三倍、朦朧として頭の円い、袖の平たい、入道であった。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜しいことには、諸氏ひとしく自らの身の丈よりも五寸ほどずつ恐縮していた。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二の童子　それで身の丈が一丈をも超えて、手の甲に鱗が生えておぢやるさうぢや。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "△古河力作　府下瀧ノ川康樂園に雇はれて花造りを職とせり、王子に愛人社なるものを組織し社會主義の普及を圖れり、身の丈三尺五六寸胸廓手足之に準じ一見小兒の如し。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お道さんが、さんばら髪に肩を振って、身悶えすると、消えかかった松明が赫と燃えて、あれあれ、女の身の丈に、めらめらと空へ立った。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "海野は年配三十八、九、骨太なる手足あくまで肥へて、身の丈もまた群を抜けり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い鳥一　第十二代｜景行天皇は、お身の丈が一｜丈二｜寸、おひざから下が四｜尺一寸もおありになるほどの、偉大なお体格でいらっしゃいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからわしの身の丈ほどの大がめに酒を盛って、海山の珍しいごちそうをそろえて呼んでやろう、しかし、もしもらいそこねたら、あんな広言を吐いた罰に、今わしがしてやろうと言ったとおりをわしにしてくれるか」と言いました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは身の丈が一丈ばかりもある怪物の口から吐く焔であった。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "萌黄色の「キッテル」といふ衣短く、黒き臑をあらはしたる童、身の丈きはめて低きが、おどろなす赤髪ふり乱して、手に持たる鞭面白げに鳴らしぬ。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "萌黄色の「キッテル」という衣短く、黒き臑をあらわしたる童、身の丈きわめて低きが、おどろなす赤髪ふり乱して、手に持ちたる鞭おもしろげに鳴らしぬ。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほどいたら、身の丈にも餘らうと思はれる髮を束髮にしたのが半ば崩れて、ピンや櫛が、黒塗の臺に赤い小枕を附けた枕の元に落ちてゐる。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう三十にもなるといふ、身の丈三尺ばかりなる女の、赤き扇をかざして踊るを、見世物にて見たることあり。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "女王は身の丈甚だ高からず、面の輪廓鋭くして、黒き目は稍※｜陷りたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "振子の振動は私の身の丈と直角になっていた。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "身の丈は六フィート半もあるだろう。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも船で漂うのは、あわれに悲く、浅ましい……身の丈夫で売盛るものにはない、弱い女が流される。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "片あかりして、冷く薄暗い、其の襖際から、氷のやうな抜刀を提げて、ぬつと出た、身の丈抜群な男がある。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私に会おうともいいませんか」私は彼女に面と向って怨みのたけを言いたかった。",
              "citation": {
                "source": "霜凍る宵",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
