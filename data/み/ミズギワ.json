    "definitions": [
      {
        "index": 1,
        "gloss": "water's edge",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小坂家の玄関に於いて颯っと羽織を着換え、紺足袋をすらりと脱ぎ捨て白足袋をきちんと履いて水際立ったお使者振りを示そうという魂胆であったが、これは完全に失敗した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭青年がいま水際に降りる岩石の階段に片足を下ろしかけたとき、その石の蔭になっている岸と水際との間の渚に、薄紅の色の一かたまりが横たわっているのが眼に入りました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その河原の水際に沿ってたくさんのあかりがせわしくのぼったり下ったりしてゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄私達が土人街｜印度家屋の油の濃い日本女（ここに住む日本髪の女が世界中で一等醜い女だということは貴方にも直きお分りになるでしょう）以外に恋の体力をあらわさなかったのに、たとえ英国種にしろアダは水際だった、いわば我々日本人にとって彼女は孟買のエンゼルなのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しんとしてさびしい磯の退潮の痕が日に輝って、小さな波が水際をもてあそんでいるらしく長い線が白刃のように光っては消えている。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "不明瞭な点を残さず、悉くそれを赤ときめて、一掃してしまえば功績も一層｜水際立って司令部に認められる。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その河原の水際に沿ってたくさんのあかりがせわしくのぼったり下ったりしていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……たゞ桟橋から、水際から、すぐ手で掬へる小瑕の事。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足利以来の趣味はこの人によって水際立って進歩させられたのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、自分は其処の水際に蹲って釣ったり、其処の堤上に寝転がって、たまたま得た何かを雑記帳に一行二行記しつけたりして毎日｜楽んだ。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても、水際立ったものでした。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんにも作品残さなかったけれど、それでも水際立って一流の芸術家だったお兄さん。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　私はつぶやくようにまた考えるようにしながら水際に立ちました。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはみな霜を織ったような羅をつけすきとおる沓をはき私の前の水際に立ってしきりに東の空をのぞみ太陽の昇るのを待っているようでした。",
              "citation": {
                "source": "インドラの網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その河原の水際に沿つてたくさんのあかりがせはしくのぼつたり下つたりしてゐました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもお手際が生徒さん達よりも水際立っているようです。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その冷ややかな陰の水際に一人の丸く肥ッた少年が釣りを垂れて深い清い淵の水面を余念なく見ている、その少年を少し隔れて柳の株に腰かけて、一人の旅人、零落と疲労をその衣服と容貌に示し、夢みるごときまなざしをして少年をながめている。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づいて見ると、はたして一艘の小舟の水際より四五間も曳き上げてあるをその周囲を取り巻いて、ある者は舷に腰かけ、ある者は砂上にうずくまり、ある者は立ちなど、十人あまりの男女が集まっている、そのうちに一人の男が舷に倚って尺八を吹いているのである。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもあの透きとおるような海の藍色と、白い帆前船などの水際近くに塗ってある洋紅色とは、僕の持っている絵具ではどうしてもうまく出せませんでした。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れの解剖の手際は水際だつてゐた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆の中より、水際立って、美しく水浅葱に朝露置いた大輪の花一輪、白砂の清き浜に、台や開くと、裳を捌いて衝と下り立った、洋装したる一人の婦人。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お孝さん、……」　寂然としていたが、重ねて呼ぶのに気を兼ねる間も無く、雨戸が一枚、すっと開いて、下から映す蒼い瓦斯を、逆に細流を浴びたごとく濡萎れた姿で、水際を立てて、そこへお孝が、露の垂りそうに艶麗に顕れた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "髮は、ふさ／＼とあるのを櫛卷なんどに束ねたらしい……でないと、肱かけ窓の、然うした處は、高い髷なら鴨居にも支へよう、其が、やがて二三｜寸、灯のない暗がりに、水際立つまで、同じ黒さが、くツきりと間をおいて、柳は露に濡れつゝ濃かつた。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……其の下の水際の岩窟の湯に、立つたり、坐つたり、手拭を綾にした男女の裸身があらはれたかと思ふと、横の窓からは馬がのほりと顏を出す、厩であらう。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……宵に鯊を釣落した苦き経験のある男が、今度は鱸を水際で遁した。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙ君は水際のベンチに腰を下すと、長いサーベルの柄頭に両手を重ね、その上に頤を載せて深い溜息を吐いた。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "流の彼方此方で、何うかすると燦爛たる光を放つ……霧は淡い雲のやうになツて川面を這ふ……向ふの岸に若い婦が水際に下り立ツて洗濯をしてゐたが、正面に日光を受けて、着物を搾る雫は、恰で水晶のやうに煌く。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "長唄のお浚いにかかると、一時に五六番から十番も弾きつづけて倦むことを知らなかったが、宴会の席で浦島などを踊っても、水際だった鮮かさがあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいらもう尾っぽを巻いて小さくなっているから、ひとっ走りにやってくんな」　走らせて景気よく永住町のその大園寺へ乗りつけると、ものごし態度の鷹揚さ、あいさつ口上のあざやかさ、まことにみずぎわだった男ぶりです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいまおあけいたします……」　あわててお冬が奥のへやへ駆け込んだのといっしょに、黙々としてはいってきた名人を見ると、越後上布におとし差し、みずぎわだった姿に変わりはないが、その顔いろに曇りが見えるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
