    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Oriental paper bush (Edgeworthia chrysantha)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三椏の木が一本の幹から段々と無数の枝に分れる様なものです。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三椏の花が咲き、小屋の水車が大きく廻つてゐた。",
              "citation": {
                "source": "測量船",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ、象の胎内に何かからくりがあるのだと思うが……」　と、言いながら、懐中から三椏紙を横に綴じた捕物帖を取出し、「……象の右の前脚に入ったのは、美濃清で、左脚が植木屋の植亀。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "山王祭の大象",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐帳面の紙を引裂いたのらしく、丈夫な三椏紙で、たぶん血であろう、端の方にべッとりと赤黝い汚点がついている。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "長崎ものがたり",
                "note": "青空文庫"
              }
            },
            {
              "text": "三椏を主な材料とします。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体紙料には雁皮と楮と三椏とがありますが、雁皮を以て最上とします。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩坂ではこれと共に楮でも三椏でも新しい紙が色々と試みられ、これを愛好する人々が段々｜殖えて来ました。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "材料は純三椏である。",
              "citation": {
                "source": "和紙十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白石のものではないが近年出来た新しい品物のうち、私が最も感心したのは上質の純三椏糸で繻子風に織り出した一種である。",
              "citation": {
                "source": "和紙十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの王妃のやうに気高い「雁皮」も、武士のやうに強壮な「楮」も、官女のやうに典雅な「三椏」も、自然からの賜物でないものはない。",
              "citation": {
                "source": "和紙の教へ",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁皮と楮と三椏と、之が紙料の三位である。",
              "citation": {
                "source": "和紙の美",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁皮紙は上位を、楮紙は右位を、三椏紙は左位を占める。",
              "citation": {
                "source": "和紙の美",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "之に比べ三椏は紙境を柔らげる女性である。",
              "citation": {
                "source": "和紙の美",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三椏なくば紙は風情を減ずるであらう。",
              "citation": {
                "source": "和紙の美",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁皮と楮と三椏と、三者が相助けて和紙の生命を守り育てる。",
              "citation": {
                "source": "和紙の美",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬酔木居いつぽんかたすみのみつまたのはな川風さむみおちつかないてふてふ水車はまはる泣くやうな声だして　　日田水じゆうわうに柳は芽ぶく山ざくら人がのぼつて折つてゐる藪の椿の赤くもあるかみちがわかれるさくらさく猿田彦花ぐもりいういうとして一機また一機　三月廿五日　曇――晴、二日市。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "日のあたる明り障子たゞ白じろと　ひろがり見し夢の　かそかなる思ひに　つゞく　　　　　堀君　三みつまたの花咲く日山原を　行きしかな。",
              "citation": {
                "source": "『かげろふの日記』解説",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の戸をあけたる娘の家こそは　小かりしかもの言はぬ娘の黒｜瞳の　冴え／″＼と小かりしかみつまたの花咲く道をくだりうつ／＼と　若きはたちを歎きたりけむ　　　　　堀君　四村の子を　友として遊べとぞ　君を思ふ。",
              "citation": {
                "source": "『かげろふの日記』解説",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
