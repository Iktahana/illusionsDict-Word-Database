        "examples": {
          "standard": [
            {
              "text": "この地を都すると決めた将軍は、壮大な都市計画を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "天皇がこの地を都すると宣言し、新たな歴史が始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "かつての支配者たちは、戦略的な要地を都することが多かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その後にもここに都するの議がおこって、宋の太祖の開宝末年に一度行幸の事があったが、何分にも古御所に怪異が多く、又その上に霖雨に逢い、旱を祷ってむなしく帰った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると醤買石も、ついに人間の皮を被っては遷都する先がなくなって、遂に大蜘蛛に化けたのであるか。",
              "citation": {
                "source": "毒瓦斯発明官",
                "author": "――金博士シリーズ・５――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
