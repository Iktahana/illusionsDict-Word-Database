        "examples": {
          "standard": [
            {
              "text": "野原を歩いていると、珍しい高山植物がいくつか見当たった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "警察の捜索により、ようやく事件の証拠となる遺留品が見当たった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この古い地図には、現代の道路と一致する箇所がいくつか見当たる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そういうおもしろい研究に対してもその研究題目それ自身に対していろいろの故障を申し立てる学者があると見えて、そういう「異端学者」の論文の中に、そういう故障への弁明の辞を述べ立てたのがおりおり見当たる。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上の三種類のものがもっとも現在でも多く見当たるところのものである。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、われわれがいう寿司らしい寿司を作る店は、そうたやすく見当たるものではなかった。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼の音楽を見当たる限りことごとくやってみた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なに、書物の中で見当たる誤植のようなものさ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "足跡らしいものは多少みあたるが、草が倒れていないのはどうしたわけでしょう」　藤波は油断のない面つきで、切長なひと皮眼のすみからジロジロと顎十郎を眺めながら、「仙波さん、まア、そうとぼけないでものこってすよ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "御代参の乗物",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
