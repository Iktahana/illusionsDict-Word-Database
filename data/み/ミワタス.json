[
  {
    "uuid": "a98ef18e-e1fd-5bb0-84d1-2b6acb4c36e7",
    "entry": "見渡す",
    "reading": {
      "primary": "みわたす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
