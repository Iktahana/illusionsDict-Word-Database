[
  {
    "uuid": "d67c7a83-387c-5d3a-91ff-b29fffaa6086",
    "entry": "見かけ倒し",
    "reading": {
      "primary": "みかけだおし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
