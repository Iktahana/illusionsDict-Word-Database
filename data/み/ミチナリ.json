        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "スペクトルの色がそれぞれに美しいほんとうの色であるように、やはりそれぞれ正しい道なり原理なりが併立しうるように思われる。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "元禄の頃の陸奥千鳥には――木川村入口に鐙摺の岩あり、一騎立の細道なり、少し行きて右の方に寺あり、小高き所、堂一宇、次信、忠信の両妻、軍立の姿にて相双び立つ。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えゝ、申兼ねましたが、其が其の、些と道なりませぬ、目上のお方に、身も心もうちこんで迷ひました、と云ふのは、對手が庄屋どのの、其の、」と口早に云ひたした。",
              "citation": {
                "source": "片しぐれ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えゝ、申兼ねましたが、其が其が、些と道なりませぬ、目上のお方に、もう心もくらんで迷ひましたと云ふのは、對手が庄屋どのの、其の。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うらぶれし良家の女の、父の病氣なるに、夜半に醫を乞へる道なりけり。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡島は今の北海道なり。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道は碁盤上の線道なり、明徳は即ち正直也。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "奕は小道なりと雖も、君子の此を玩ぶや、おのづから応に君子の態度あるべき也、小人の心術に出づる無かるべき也。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "親に対する孝道なり。",
              "citation": {
                "source": "愛と婚姻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その玄関の燈を背に、芝草と、植込の小松の中の敷石を、三人が道なりに少し畝って伝って、石造の門にかかげた、石ぼやの門燈に、影を黒く、段を降りて砂道へ出た。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "又曰く、我は国詩の格調に於て七五調本位を以て正道なりと思惟すと。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "我こそは、信州上田の鬼小姓、笛も吹けば、法螺も吹く、吹けば飛ぶよな横紙を破った数は白妙の、衣を墨に染めかえて、入道姿はかくれもなき、三好清海入道なり」　と、名乗った。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一首は遂に一首にして亦生死の道なり。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳河の老儒渡辺村男先生の東道なり。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とは沙翁の悟道なり。",
              "citation": {
                "source": "山庵雑記",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の婦なることを知りて之を姦せんとす、元より非道なり、然れども彼は非道を世人の嫌悪する意味に於ての非道とせず。",
              "citation": {
                "source": "心機妙変を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども粋様と相照応して共に威光を輝かしたる者こそあれ、そを何と言ふに其頃盛なりし侠客道なり。",
              "citation": {
                "source": "粋を論じて「伽羅枕」に及ぶ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "欝樹參差として蔭闇し、碓氷の難險は盖し其の間に通ずるの道なり。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "この故に神国といふなり」と、冒頭第一に、国体の真髄を発揚してゐるし、「凡そ王土に孕まれて、忠を致し命を捨つるは人臣の道なり。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カタコンバ」は人も知りたる如く、羅馬城とこれに接したる村々とを通ずる隧道なりしが、半はおのづから壞れ、半は盜人、ぬけうりする人なんどの隱家となるを厭ひて、石もて塞がれたるなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが行くところの道は、二月の前にフエデリゴ、サンタの二人と與に行きし道なりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れ舟を行る道なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち言語で言い顕わし得ぬ冥々の裡に、わが国万古不変の国体を一時に頭の頂上より足趾の尖まで感激して忘るる能わざらしめ、皇室より下｜凡民に至るまで、いずれも日本国の天神地祇の御裔なりという有難さを言わず説かずに悟らしむるの道なり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "元禄の頃の陸奥千鳥には――木川村入口に鐙摺の岩あり、一騎｜立の細道なり、少し行きて右の方に寺あり、小高き所、堂｜一宇、継信、忠信の両妻、軍立の姿にて相双び立つ。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に死が最上の道なりと思わるる場合はたしかに在る。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "また行は道なりと『鄭箋』に数々見えるように、行と同じ意味で、行を「みち」と訓み、「みち」を道として通じるのである。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お帰来でしたか」　その人は待ちに待たれし直道なり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれ嬉しやと路を問へば、『棚倉街道なり、古關の蹟へは、後戻りせざるべからず』といふ。",
              "citation": {
                "source": "白河の關",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間をたっぷりかけてしらべると、もっとはっきりしたこの器械の性質なり使いみちなりがわかるかもしれません」「そうしてくれたまえ」　そこでふたりは、ヤナギの木かげから腰をあげた。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
