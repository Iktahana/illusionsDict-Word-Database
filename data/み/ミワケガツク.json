[
  {
    "uuid": "32124bbc-2e19-5365-8239-16ae255f00a3",
    "entry": "見分けがつく",
    "reading": {
      "primary": "みわけがつく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
