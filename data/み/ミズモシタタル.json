          "literary": [
            {
              "text": "その女はその美貌を水も滴るような丸髷と一緒に左右へ静かに振って居る。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三※の花咲き湿る、山の井よ、下井の水も滴るらしき。",
              "citation": {
                "source": "海阪",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三※の花咲き湿る、山の井の、下井の水も滴るらしき。",
              "citation": {
                "source": "篁",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "木下八百子は私が幼少のころすでに大蛇使用の連鎖劇にそこばくの称讃を博し得てゐたから前述の沢モリノ同様可成の年齢となつてゐたのだらうが、その扮する弁天小僧など訛の著しき以外には、水も滴るゝばかりの美しさだつた。",
              "citation": {
                "source": "浅草燈籠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
