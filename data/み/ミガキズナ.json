        "examples": {
          "standard": [
            {
              "text": "庭の石像についた苔を、磨き砂を使って丁寧に取り除いていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は海岸で拾ったシーグラスを磨き砂で加工し、手作りのアクセサリーを制作した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "工場の隅には、金属部品のバリを取るための大きな磨き砂の袋が積まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし楢雄は、磨き砂と石鹸で見た眼に綺麗に洗ふのは易しいが、培養試験に使用できるやうに洗ふのは、なかなかの根気と技術の要る仕事だと、帰つて雪江に聴かせた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は釜ヶ崎の木賃宿に住んで磨き砂売りをやつてゐるが、もちろん、稼ぎは思ふやうには行かず、それに女房が病気になつて寝て了ひ、日に日に重ることが眼に見えつつも、施す手がなく医者も相手にしてくれず、瀕死の彼女は苦悶するし――遂に思ひ余つて、女房を行路病者にしたてたと云ふわけであつた。",
              "citation": {
                "source": "釜ヶ崎",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、女中のオノリイヌが、その中へ、ランプの金具を磨く赤い磨き砂を容れてしまった。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "磨き砂みたいな土である。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
