    "definitions": [
      {
        "index": 1,
        "gloss": "direction of the capital (esp. Kyoto)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
