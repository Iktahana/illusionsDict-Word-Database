    "definitions": [
      {
        "index": 1,
        "gloss": "cry of earthworms (heard on autumn nights and rainy days)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
