          "standard": [],
          "literary": [
            {
              "text": "卒業式三宝または水差しなど、　　たとへいくたび紅白の、甘き澱みに運ぶとも、　　　鐘鳴るまではカラぬるませじと、うなじに副へし半巾は、　　慈鎮｜和尚のごとくなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をする気にもならない自分はよくぼんやり鏡や薔薇の描いてある陶器の水差しに見入っていた。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡や水差しに対している自分は自然そんな経験を思い出した。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷い白い肌に一点、電燈の像を宿している可愛い水差しは、なにをする気にもならない自分にとって実際変な魅力を持っていた。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡を見たり水差しを見たりするときに感じる、変に不思議なところへ運ばれて来たような気持は、却って淀んだ気持と悪く絡まったようであった。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょいと、その水差しを。",
              "citation": {
                "source": "女客",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ娘は前の日と同じ服装で、果もの鉢と水差しを持って入って来た。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームズは、屈んで水差しを手に取り、海綿に水を含ませ、そのあと独房の男の顔を力強く、ぬぐうように二回こすった。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ窓を開けて、水差しを私に。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台の足近く、台に載った一皿のオレンジとガラスの水差しがあった。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ママ、きっと天国の扉のところで、大きな水差しいっぱいの水と、そば粉のパンケーキをたくさん用意して迎えてくれるんだから。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "目が覚めて、片腕を伸ばすと、かたわらには一塊のパンと水の入った水差しとが置いてあった。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "目を覚ますと、前と同じように一塊のパンと水の入った水差しとが置いてあった。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼くような渇きを覚えたので、私はその水差しの水を一飲みに飲みほした。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしいことには、水差しがなくなっていた。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまな葡萄酒や甘露酒の罎がいろいろな形や質のジョッキや、水差しや、細口罎などと共に、その食卓の上一面に散らばっている。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョッキや、水差しや、籠入りガラス罎などが、ごちゃごちゃに押し合いへし合いしながらまざり、柳細工の細口罎が厚いガラス罎とやけにぶつかる。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜更けてから、寝床のなかで、どこかの草間や、石の下などで啼いている虫の音を聞いた時には、もう涼しい秋が来たようで、壁に映る有明けの灯影や、枕頭におかれたコップや水差し、畳の手触りまでが、冷やかであったが、睡りの足りない頭や体には、昼間の残暑は、一層じめじめと悪暑く感ぜられた。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭をいじって、話を書いて、芋がしらの水差しを玩んで――つまり前にも言ったように、日月星辰前にあり、室生犀星茲にありと魚眠洞の洞天に尻を据えている。",
              "citation": {
                "source": "出来上った人",
                "author": "――室生犀星氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上にある端渓の硯、蹲※の文鎮、蟇の形をした銅の水差し、獅子と牡丹とを浮かせた青磁の硯屏、それから蘭を刻んだ孟宗の根竹の筆立て――さう云ふ一切の文房具は、皆彼の創作の苦しみに、久しい以前から親んでゐる。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上にある端渓の硯、蹲※の文鎮、蟇の形をした銅の水差し、獅子と牡丹とを浮かせた青磁の硯屏、それから蘭を刻んだ孟宗の根竹の筆立て――そういう一切の文房具は、皆彼の創作の苦しみに、久しい以前から親んでいる。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕元の水差しの盆の上には、此一夜泊りの客の爲に、小さい列車時間表が置いてあつた。",
              "citation": {
                "source": "摩周湖紀行",
                "author": "――北海道の旅より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "長椅子の前には、卓子や椅子があり、壁には鏡や、水差しがはめこんであつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日宿の水差しのフタをオモチャに遊んでいてこわしたので女中にわびると、女中が言下に「ハア、先日水差しの下の方をこわしたお客さまがありましてね、ちょうどよろしゅうございます」　と言った。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋へ案内してくれたホテルの娘さんが、陶器の大きな水差しに水をいれて持ってきて、鏡の載っかってる台の上においてあった陶器の大きなカナダライのようなものの中へ、水差しの水をジャーボコボコと半分ぐらいつぎこんで立ち去った。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "長崎チャンポン――九州の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を殺した男かなんかが、血だらけのナイフをこの台の上へおいて、水差しの水をジャーボコボコとこの陶器のカナダライ的なものへ半分ぐらいついで、血だらけの手をさしこむ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "長崎チャンポン――九州の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理女のオリガが、水差しと銅の金盥とタオルと海綿を持って、後からついて行く。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはエールを汲んでくるよ」そうして明かりとクルーシュキーン（水差し）を持って酒蔵に下りていった。",
              "citation": {
                "source": "首なし",
                "author": "TRUNK-WITHOUT-HEAD",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
