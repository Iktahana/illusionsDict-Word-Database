        "examples": {
          "standard": [
            {
              "text": "船のメインマストの頂上にある見張り台から、「前方に陸地発見！」という力強い声が響いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "戦国時代の城には、敵軍の襲来をいち早く察知するために高い見張り台がいくつも築かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ライフセーバーたちが、白い砂浜の中央に設置された見張り台から海水浴客の安全を確認している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "屋根の上に、敵兵の接近に対する見張り台があった。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見張り台のように、真新しい第一橋脚の白い足が、海原に突き出ている。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
