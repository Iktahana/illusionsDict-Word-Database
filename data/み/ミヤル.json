        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "紀州は源叔父が顔見て驚きし様もなく、道ゆく人を門に立ちて心なく見やるごとき様にてうち守りぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の生徒たちはおおっぴらに女の方を見やる機会を得て、等しく物好きらしい眼を、渡井のしゃくり上げる肩のところから、手拭の下に真赤にしている横顔へと向けた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ひたすら楽屋の方打見やる。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つくづくと、うち見やる水、枯葦、まさしくもみ冬なり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "眺めやり、うち見やるのみ、海豹のうかぶ潮※。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡路嶋かよふ千鳥、明石の浦、このそよぐすずしき風に、親子づれ帰さ安しと、この日なか、波折光ると、甲板に鼠出でぬと、おもしろとその影見やる。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "眺めやり、うち見やるのみ、　海豹のうかぶ潮※。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおよそ人が欠伸でも始め、時計でも見やるような時刻のことだった。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が真っ先に見やるのは、常に女の袖だ。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と客は答え、その小さな目を光らせて、ホームズを鋭く見やる。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と友は窓の外を眺めながら時計も見やる。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "大佐はむろん、私までも驚いて友人の顔を見やる。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目後方を見やると、背の高い男が猛然と人混みをかき分けながら、列車を止めたいかのように手を振っている。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてすぐそのばから、夫人の前にも頓着なく、誘惑のひとみを凝らしてその良人の横顔をじっと見やるのだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死にかけた蛇ののたうち回るのを見やる蛇使いのように、葉子は冷ややかにあざ笑いながら、夫人の心の葛藤を見やっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし、　あんなおじいさんのお内儀さんになってみたい……だからね、いいものをやっちまった」　きょとりとしてまじまじ木村のむっつりとした顔を見やる様子は大きな子供とより思えなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見やると葉子は一時に力を回復したようになって、すぐ跳り出して来るいたずら心のままに、一本の桜の木を楯に倉地をやり過ごしておいて、後ろから静かに近づいて手と手とが触れ合わんばかりに押しならんだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜はあなた方にわかるようにねえさんが話して上げてみるから、よく聞いてちょうだいよ」　倉地の胸に抱かれながら、酔いしれたようにその頑丈な、日に焼けた、男性的な顔を見やる葉子の、乙女というよりももっと子供らしい様子は、二人の妹を前に置いてきちんと居ずまいを正した葉子のどこにも見いだされなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分でも知らぬ間に、葉子は、岡のそば近くすわって、右手をその肩に、左手を畳に突いて、しげしげと相手の顔を見やる自分を見いだした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪の音ゆるき朝なぎに、眞帆｜眞廣げにひき張りて、鳥羽路へわたる舟人は、山いただきの空みだれ、雲のちぎれを見やるにも、「上帆をあげよ、山颪吹きこそ來れ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "母はそこのカーテンを披つて、疊の上に日向を作つて冷吉を坐らせて、自分もそこから外を見やるやうであつた。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃが……」　玉藻はなにか言い出そうとして、ふと向こうを見やると、二つの笠を持った兼輔が河原づたいに横しぶきのなかを駈けて来た。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「して、入道にはなんとお見やる」「それがしの愚意を申そうならば、泰親の訴えを聞こしめされ、繰り返して今一度、七十日の秘密の祈祷を……」　泰親の不覚は重々であるが、さりとて今この都はおろか、日本国じゅうを見渡しても、この役目を勤めるものは彼のほかにない。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雄二がハツとして、家鴨の群を見やると六七羽の家鴨は岸の方の医院の石段へ集まつてしまつた。",
              "citation": {
                "source": "潮干狩",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八『さては、搖えた當時の魂のたゆたひ和ぎしづむ眞澄の今のしづけさに、見やるは何か、新に。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　人々はみんな聲をあげて笑ひ、同時に彼の最後の言葉に思ひ出したやうに壁の一方を見やるのであつた。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "壊れた竹の欄干に掴って、月の懸った雲の中の、あれが医王山と見ている内に、橋板をことこと踏んで、　向の山に、猿が三｜疋住みやる。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前にも一掴みやるぞ。",
              "citation": {
                "source": "三人兄弟",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "六『夫は巣立の子もつれて、深山つぐみの來ぬひまを、老の峠の切畑に、黄金覆盆子や摘みやる。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋にもエッチングのみやる人と、彩描のかたわら或る内容をエッチングで表す人との二種があるように。",
              "citation": {
                "source": "想像と装飾の美",
                "author": "それを持つ特殊の個性によって生かさるべし",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
