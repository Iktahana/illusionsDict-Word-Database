    "definitions": [
      {
        "index": 1,
        "gloss": "earring (non-pierced)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼らは、たがひに相手を澤山の新しい名でもつて呼びあひ、それからまた、耳環でもはづすやうに、そつとそれを引き込めるのだつた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "撒水孔のような耳環のあと。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は丸顏、一人は瓜實顏、其に口紅赤く、耳環の翡翠が青い。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなの顔の耳たぶの耳環もうつつてをりました。",
              "citation": {
                "source": "井戸",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はね紫水晶の耳環をして居るの。",
              "citation": {
                "source": "一平氏に",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けどやつぱり淋しいには淋しいの、ですから耳環の水晶のころころの可愛ゆいのまでに涙が出たりするのですわ。",
              "citation": {
                "source": "一平氏に",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ＫＲ女史に、耳環を贈る約束。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒に近い葡萄色の軽装で両手を高くまくり上げ、薄紅い厚ぼったい耳朶には金の耳環を繊細に、ちらちらと顫えさしていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこの肥って善良な七面鳥が奥の室から廉物の蓄音機を、耳環をちらちらで擁え出して来て、窓際の小さな卓子に据えると、煤色の大きな喇叭の口を私たちの方へ差向けたものだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女は顔をそむけて一方の耳環の碧い玉を見せた。",
              "citation": {
                "source": "竇氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "想ふに羅馬市には、黄金の耳環を典して、客人を贖ひ取ることを吝まざる人あるならん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の上にナポレオン銀貨四箇、黄玉を嵌めたる耳環一箇、銀の大匙三箇、アルジエリイ合金の小匙三箇の外、金貨四千フランを二袋に入れたるものあり。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつは右の耳から始まって、恐ろしい裂け目をなして左の方へずっとのび、――両方の耳朶につけてある短い耳環は、絶えずその口の中へぴょんぴょんと跳びこんでいる。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい首飾、耳環、腕輪――やはり娘を誘惑するには、これ以外のものはなからうといふメフイストのはからひで、二人は大急ぎでそれらのものを整へると、メフイストがそつと娘の部屋へ忍び込んで、娘の鏡台の傍らに宝石の箱を置いて来ます。",
              "citation": {
                "source": "フアウスト",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せめてこの耳環だけでも妾のものだつたら妾は何んなに幸せだらう。",
              "citation": {
                "source": "フアウスト",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「主人の家に婚礼がありまして、親類から珠の耳環を借りました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "輟耕録",
                "note": "青空文庫"
              }
            },
            {
              "text": "この耳環は銀三十錠の値いのある品だそうでございます。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "輟耕録",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はかの耳環を落した奉公人で、その失策から主人の機嫌を損じて、とうとう暇を出されて、ある髪結床へ嫁にやられた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "輟耕録",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳環の群れが、揺れつつ積った塵埃の中で伸縮した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "揺れる耳環が機械の隙間を貫いて光って来た。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "焔を受けて煌めく耳環の群団が、腹を返して沸き上る魚のように沸騰した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は彼の前で水に割られては盛り返す群衆の罅を見詰め、倒れる旗の傾斜を見、投げられる礫の間で輝く耳環に延び上った。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふとそのとき、彼は梅雨空に溶け込む夜の濃密な街角から、閃めく耳環の色を感じた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしその耳環が秋蘭であったなら、と思う彼の心が、突然、彼女と逢った後のことを考え出したのだ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルガは手品を使う前の小手｜調のように、しばらくの間淡紅色に輝いたパルパラチャンの指環を眺めたり、耳環を爪さきではじいてみたりしていてから、深い呼吸を面に幾回も繰り返して黙っていた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と甲谷はいうと、乾いた唇へ冷たく触れるオルガの水滴形の耳環の先を舌の先で押し出した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "門一ぱいに当っている、油のような夕日の光の中に、老人のかぶった紗の帽子や、土耳古の女の金の耳環や、白馬に飾った色糸の手綱が、絶えず流れて行く容子は、まるで画のような美しさです。",
              "citation": {
                "source": "杜子春",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬紅をさして、目ぶちを黒くぬつて、絹のキモノをひつかけて、細い金の耳環をぶら下げてゐる。",
              "citation": {
                "source": "窓",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、思つてもみて下され――蜜房を持つてくるてえと、部屋ぢゆうにぷんぷんと芳香がみなぎりわたるといふ始末でな、いや、とてもとても想像することも出来ませぬくらゐ、まるで涙か、それともよく耳環にはめる高価な水晶のやうに、混りつけのない蜂蜜ですぢやて。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでまたしても逢ふほどの哥薩克たちを残らず寄せ集めて、飲めや唄への乱痴気さわぎをおつぱじめて、銭をばら撒く、火酒は浴び放題……美しい娘つ子には、そつとすり寄るやうにして、リボンだの耳環だの頸飾だのを、もてあますほど呉れてやる！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
