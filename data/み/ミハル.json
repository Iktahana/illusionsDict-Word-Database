    "definitions": [
      {
        "index": 1,
        "gloss": "to stand watch",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それ聞いたか平土間の一人の客が「オホホ」Ｔ「此村大吉」　と眼見張る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "女客も「マァー」と鮮やかさに眼を見張る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（娘は呆れて目を見張る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（娘はいよいよ呆れ、何事とも弁えず、目をいよいよ大きく見張る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "掏摸に金をすられた肥った年増の顔、その密告によって疑いの目を見張る刑事の典型的な探偵づら、それからポーラを取られた意趣返しの機会をねらう悪漢フレッド、そういう顔が順々に現われるだけでそれをながめる観客は今までに起こって来た事件の行きさつを一つ一つありありと思い出させられる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのついでに小手をかざして、村の方を見張るのだから、大層｜工合はいい。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "はい、麻畑と謂ってやりゃ、即座に捕まえられて、吾も、はあ、夜の目も合わさねえで、お前様を見張るにも及ばずかい、御褒美も貰えるだ。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご想像通り、チャーリントンの丘にさしかかるあたりで目を見張ると、またしても男がいたのです、二週間前と同じように。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、先に触れた同居人のヴァイオリンの能力、非常に目を見張るものがあるが、それ以外の才と同様に奇抜でもあった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしはリヴァプールに電報を打って、人相を伝え、アメリカ行きの汽船を見張るよう通達しました。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ、ひどく心残りだった乳母は、そのとき以来、奥様の動きに気を付け、情もあって赤ん坊をより近くから見張ることにしました。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「その経歴は目を見張るものだ。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くはたゞ其處に置かれてあるとだけにぼんやりと生きてゐるので、オヤオヤこれが自分か、これが眞實の自分かと自分の姿に對して眼を見張る人すらも少ない樣に思はれてならない。",
              "citation": {
                "source": "樹木とその葉",
                "author": "歌と宗教",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一対の媼が、背後で見張るようにも思われたし、縄張の動く拍子に、矢がパッと飛んで出そうにも感じたのである。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生、――「座敷を別に、ここに忍んで、その浮気を見張るんだけれど、廊下などで不意に見附かっては不可いから、容子を変えるんだ。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、人間の方でいつの間にかその自然と離れて、やがてはそれを忘るゝ樣になり、たま／＼不時の異變などのあつた際に、周章へて眼を見張るといふところがありはせぬだらうか。",
              "citation": {
                "source": "樹木とその葉",
                "author": "自然の息自然の聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　事ごとに眼を見張る私を笑ひながら、初め不氣味な男だと思つた案内人は行く／＼種々の樹木の名を倦みもせずに教へて呉れた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これが橡、あれが桂、悪ダラ、沢胡桃、アサヒ、ハナ、ウリノ木、……」　事ごとに眼を見張る私を笑いながら、初め無気味な男だと思った案内人は行く行く種々の樹木名を倦みもせずに教えて呉れた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、心中はあの心中、川目付は墨田の大川の川見張り、やはり死によいためにか、十組みのうち八組みまでは大川へ入水して、はかなくも美しい思いを遂げるものがあるところから、これを見張るための川目付であるが、土左舟はまたいうまでもなくそれらの悲しい男仏女仏を拾いあげる功徳の舟です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のうちに取っておきましょうから、おいでなせえまし」　いざなっていった所は、広縁側の柱の蔭の、いかさま見張るには恰好な場所でした。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "手分け致して早う門を見張れッ」「何を見張るのでござります」「知れたこと、主計頭とて二万四千石は惜しい筈じゃ。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それで、あさってのことなんですけど……」　じぶんが、サロンの出入りを見張るのに好都合なイスを選んだため、令子のほうは光を背にするかっこうになり、表情が観察できず、慶一はイライラした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「休日の生徒を見張るのもヤボだから、退散することにしましょうか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いけない、と思って眼を見張ると、会場が海底ででもあるようにボヤけてしまう。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかはり、彼女のすることなすことは、一々その外貌にまつたく似つかはしく、舟を漕がせれば、どんな猟師もかなはないくらゐ巧みに櫂をあやつるし、野禽も射てば、草刈人夫も厳重に見張る。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "季参は益々私達の様子を憎悪に充ちた眼付をして鳥渡の油断も無く見張るのでした。",
              "citation": {
                "source": "温室の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにこの仲間たちは確に船醉を催してゐるので、私は船醉の原因がどこにあつたのかと、その意外さに目を見張るばかりであつた。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑ひの目を見張ると彼は、独りであかくなつた。",
              "citation": {
                "source": "Ｆ村での春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この旅館の部屋もまた、おや、と眼をみはるほど小綺麗で、さうして普請も決して薄つぺらでない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙をしいて払って、目をみはるようにして大臣はそれを取って読んでいた。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
