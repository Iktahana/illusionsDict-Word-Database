        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "密偵が見つけ出して来たんだ。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　密偵は、鮮人だった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "密偵は十円に釣られて、犬のように犯人を嗅ぎまわった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいつは昨日まで南軍の密偵をつとめたかと思うと、今日は、早や、こっちへ寝がえりを打つような奴なんだから。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳は、蒋介石の北上と共に、だん／＼はいりこんで来た南軍の密偵と、便衣隊について調べるため街に出かけたのだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつ南軍の密偵であるかもしれません。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」小山は、すぐ密偵の山崎だと悟った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ポーランド人の密偵の報告によるとそうだった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "密偵は、日本軍にこびるために、故意に事実を曲げて仰山に報告したことがあった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、パルチザンの正体と居所を突きとめることに苦しんでいる司令部員は、密偵の予想通り、この針小棒大な報告を喜んだ。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "忍術というのは明治になっては魔法妖術という意味に用いられたが、これは戦乱の世に敵状を知るべく潜入密偵するの術で、少しは印を結び咒を持する真言宗様の事をも用いたにもせよ、兵家の事であるのがその本来である。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "都御史暴昭、燕邸の事を密偵して奏するあり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　其の部屋の何処かに密偵が潜んでいたものらしい。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　其の部屋の何處かに密偵が潛んでゐたものらしい。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良原少年一流の急進的な激語が破鐘のように大きいのでその家を取巻く密偵の耳に筒抜けに聞えたに違いないという事になった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、島中の人民はほとんど総てが信徒なので、征討軍が放つ密偵は悉く偽りの報告を齎すから、まるで裏をかかれ通しである。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちは敵地に乗り込んだ密偵。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "士嘉曰く、この樹が祟ったのだ、これを治すべしとて駕してその樹下に往く、士民皆見物に出る、その間密偵せしむるに一人往かざる者あり、これを吟味するに果して盗なり。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "禄は少ないが、いわゆるお庭番と称された江戸幕府独特の密偵隊同様、役目がなかなかに重大な役目であるから、いずれも心きいた者ばかり。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "――恭順か、会津援兵か、その去就を内偵すべく官軍の密偵達が、平、棚倉、福島、仙台、米沢から遠く秋田南部のお城下までも入りこんでいるのは隠れない事実なのである。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "船底の酒倉の方から、「怪しい者をつかまへた、密偵を捕縛した。",
              "citation": {
                "source": "船の中の鼠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしや密偵が忍び込んで何んなたくらみごとを回らさうと、あしたはバナヽの島へ旅立つ船だ。",
              "citation": {
                "source": "船の中の鼠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺されたのは、「松」こと椎名咲松という男であって、これは団員となっているが、実は其の筋の密偵をつとめていた人物だった。",
              "citation": {
                "source": "キド効果",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば今、外国密偵団の監視をやっている有名な青年探偵｜帆村荘六が、数日前その筋から示唆をうけた話の内容について考えてみるのが早わかりがするであろう。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "密偵の巣窟に、この似つかわしからぬ図柄は一体どんな秘密を蔵しているのであろうか。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ああ矢張り密偵団の陰謀は、この大地図の上に印せられてあったのだ！",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "危機一髪　帆村が空気孔から見下ろしているとも知らず、突然下の部屋に現われたのは、例の密偵団の覆面をした二人の怪人物だった。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この話から考えると、首領は遂に警報を他の密偵区へ発したものらしい。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで召喚された密偵の一人が早速駈けつけたので、「右足のない梟」が迎えに出たものらしい。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "『折れた紫陽花』君、例のマッチ箱が日本人の手に渡ったため、わが第Ａ密偵区は遂に解散にまで来てしまった」「ほう、マッチ箱がねえ」　といったのは「折れた紫陽花」と名乗る他区の密偵だった。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
