          "literary": [
            {
              "text": "娘御をここへ呼び出して、わたくしと三つ鼎であらためて御相談いたしましょう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐるりと三人、三つ鼎に夫人を巻いた、金の目と、銀の目と、紅糸の目の六つを、凶き星のごとくキラキラと砂の上に輝かしたが、「地蔵菩薩祭れ、ふァふァ、」と嘲笑って、山の峡がハタと手拍子。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人が三つ鼎になると奴は不意に、髷の根から黒髪をふっつと断って、「おっかさんに面目なくって、合す顔がありませんから」と、ぷいと立って去ってしまった。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
