        "examples": {
          "standard": [
            {
              "text": "ベテランの看護師は、脈を診るだけで患者の体調の変化を察知する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "漢方医に脈を診てもらい、体のバランスが崩れていると指摘された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "毎朝、起床時に自分の脈を診ることを習慣にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私がぐずぐずしている間に、春日はその木島を抱え起し、脈を診ると、『まだ大丈夫だ、すぐ手当をすれば受合う……』『そう、それじゃすぐ病院へ……』　――手廻しよく呼ばれて来たタキシーで、木島をはじめ私達四人は、すぐこの町で一番大きい村田医院へかけつけた。",
              "citation": {
                "source": "腐った蜉蝣",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へエ――、親分が脈を診るんですか」　ヌツと顏を出したのはガラツ八でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "槍の折れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヘエ、――親分が脈を診るんですか」　ヌッと顔を出したのはガラッ八でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "槍の折れ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
