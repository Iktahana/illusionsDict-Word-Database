        "examples": {
          "standard": [
            {
              "text": "チケットのミシン目に沿って慎重に切り離し、半券を入場口のスタッフに渡した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このトイレットペーパーはミシン目が入っていないタイプなので、少し使いづらい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "振込用紙のミシン目をピリピリと破る時の感触が、なぜか少し気持ちいい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこへいって僕はひと組、ヴィニールのミシン目からちぎった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ページの下の隅には、ページの角を囲むように、弧を描いてミシン目が入っていた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
