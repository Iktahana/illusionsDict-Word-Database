[
  {
    "uuid": "29b82ba4-bc1e-54c7-b092-06a1a5083f01",
    "entry": "水を引く",
    "reading": {
      "primary": "みずをひく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-カ行"
      ],
