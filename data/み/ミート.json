    "definitions": [
      {
        "index": 1,
        "gloss": "meat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "英語の cold は冷肉（コールミート）のコールである。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木戸をチョップ・ミートのように叩き潰して抑さえつけ、チャンスを与えようとしなかったんだ」（「愚か者は真実に傷つく」李春成『ナンバー』一九九二年五月二十日号）　さらに職業政治家となった以降の猪木寛至も、相変らず鮮烈な布切れを、実に脈絡なく編み続けてくれる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "厨房一同入寮晩餐会メニューチキンコンソメ　　アスパラガスのサラダマッシュポテト　　ヒラメのソテコールドミート　　パンデザートはバニラアイスクリーム　慶一は、「厨房」という字を、とりあえず「とうぼう」と読み、コックかなんかの意味だろうと考えた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさはスパゲティ・ミートソースだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえ、タワーリシチ、ミートシカ！",
              "citation": {
                "source": "「インガ」",
                "author": "――ソヴェト文学に現れた婦人の生活――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは別に大した問題じゃありませんがね、ステパン・ドミートリエヴィッチ、それはともかくとして、どうも移住ってことは、あんまり感心できませんよ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドーミートーローフ。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スープから出した肉は薄く切ってコールミートになり、細かく砕いてコロッケになり、色々なものに変化します。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛の舌だの、ポテットミートなんぞを中へ入れる事もある。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くへ旅行する時にはサンドウィッチの外に食品屋からポテットミートと申して砕き肉の料理した極く小さい鑵詰を買って途中でそれをパンへ塗って即席のサンドウィッチを作ります。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "パテミーとはパテットミートの略語で食品屋へ行くと鶏肉ばかりでなく牛肉でも牛の舌でも野獣でも野鳥でも何のパテミーでも鑵詰めにして売っています。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四十八　パンのホースミート　は古いパン四半斤の中身を水で絞って玉子の黄身二つバター中匙半分メリケン粉中匙半分塩胡椒少しとよく混ぜて小さいお団子位に丸めてスープの実に入れます。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝飯はカフェーにロールとコールド・ミート、昼の弁当にはパンにタングとハム、それからイヴォルンの白葡萄酒を一本携帯に及んだ。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドミートリイ・ドミートリチ・グーロフは、＊ヤールタに来てからもう二週間になり、この土地にも慣れたので、やはりそろそろ新しい顔に興味を持ちだした。",
              "citation": {
                "source": "犬を連れた奥さん",
                "author": "DAMA S SOBACHKOI",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなかの読書家で、手紙も改良仮名遣いで押し通し、良人のこともドミートリイと呼ばずにヂミートリイと呼ぶといった塩梅式だった。",
              "citation": {
                "source": "犬を連れた奥さん",
                "author": "DAMA S SOBACHKOI",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「ヂミートリイ、あんたは二枚目なんぞの柄じゃまるでなくってよ」　ある夜ふけのこと、遊び仲間の役人と連れだって医師クラブを出ながら、彼はとうとう我慢がならなくなって口を切った。",
              "citation": {
                "source": "犬を連れた奥さん",
                "author": "DAMA S SOBACHKOI",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「ドミートリイ・ドミートリチ！",
              "citation": {
                "source": "犬を連れた奥さん",
                "author": "DAMA S SOBACHKOI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、いいこと、ドミートリイ・ドミートリチ？",
              "citation": {
                "source": "犬を連れた奥さん",
                "author": "DAMA S SOBACHKOI",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて医師のスタールツェフ、その名はドミートリイ・イオーヌィチが、郡会医になりたてのほやほやで、Ｓ市から二里あまりのヂャリージへ移って来ると、やはり御多分に漏れず、いやしくも有識の士たる以上はぜひともトゥールキン一家と交際を結ばなくてはいかん、と人から聞かされた。",
              "citation": {
                "source": "イオーヌィチ",
                "author": "JONYCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ドミートリイ・イオーヌィチ」とエカテリーナ・イヴァーノヴナはひどく真面目な顔をして、ちょっと考えてから言った。",
              "citation": {
                "source": "イオーヌィチ",
                "author": "JONYCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドミートリイ・イオーヌィチ、そう仰しゃって下さるのはあたし本当に有難いと思いますし、またあなたを御尊敬申し上げてもおりますわ。",
              "citation": {
                "source": "イオーヌィチ",
                "author": "JONYCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえドミートリイ・イオーヌィチ、あなたも御存じの通り、わたしは世の中で何よりも芸術を愛していますの。",
              "citation": {
                "source": "イオーヌィチ",
                "author": "JONYCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴェーラ・イオーシフォヴナからドミートリイ・イオーヌィチに宛てたもので、近頃はさっぱりお見えにならないので淋しくてならない、ぜひお越しくだすってわたくしの悩みを和らげて下さいまし、なおちょうど今日はわたくしの誕生日にも当たりますので、という文面だった。",
              "citation": {
                "source": "イオーヌィチ",
                "author": "JONYCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、出てるよ」とイワン・ドミートリッチは言った、「だけど、お前の富札は質流れになってるんじゃないのかい？",
              "citation": {
                "source": "富籤",
                "author": "ВЫИГРЫШНЫЙ　БИЛЕТ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　イワン・ドミートリッチは籤運などは信用しない男であったから、ほかの時なら何と言われたって当り籤の表など振り向きもしなかったにちがいない。",
              "citation": {
                "source": "富籤",
                "author": "ВЫИГРЫШНЫЙ　БИЛЕТ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　イワン・ドミートリッチは細君の顔を見ながら、まるで赤ん坊が何かきらきらする物を見せられた時のような、幅ったるいぽかんとした笑顔になった。",
              "citation": {
                "source": "富籤",
                "author": "ВЫИГРЫШНЫЙ　БИЛЕТ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
