    "definitions": [
      {
        "index": 1,
        "gloss": "to anticipate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ドカリ――洗面所の方なる、扉へ立つた、茶色な顔が、ひよいと立留つてぐいと見込むと、茶の外套で恁う、肩を斜に寄つたと思ふと、……件の牛乳の壜を引攫ふが早いか――声を掛ける間も何もなかつた――茶革の靴で、どか／＼と降りて行く。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "礼之進は、畏ったズボンの膝を、張肱の両手で二つ叩いて、スーと云ったばかりで、斜めに酒井の顔を見込むと、「たかだか風邪のこじれです。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あい、」と小芳が立構えで、縁へ振向いてそなたを見込むと、「私、そこへ行っても可いかい？",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "刀を振って階子の口に、一度｜屹と下を見込む。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍女一　二人が附添っております、（廻廊を見込む）ああ、もう御廊下まで。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、眉に翳すようにして、雪の頸を、やや打傾けて優しく見込む。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山伏の首が、高く、鎖した門を、上から俯向いて見込む時、小法師の姿は、ひよいと飛んで、棟木に蹲んだ。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目室内を見込むや否や、お松もお花も一しょに声を立てた。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "成金は建ち上つた家を、その儘番頭に呉れてやつて、自分はまた現在の財産から割出して四十万近くの建築費を見込むで、素晴しい邸を拵へにかかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、機械や小舎の修繕などを見込むと、鼠一頭の純益が一年に彼是三円はあるさうだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "節子がユウモアのある心持の時と言えば、極く近く顔を寄せて、まるでたましいの奥まで見込むように眸を合せることを好きでよくした。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに開墾費、少くとも三圓を見込むと、八圓――高い、高い。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "常磐木の間に、葉の黄ばんだ雑木の交っている茂みを見込む、二本柱の門に、大宮公園と大字で書いた木札の、稍古びたのが掛かっているのである。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "出荷開始は十二月からで、三年間に三万台の販売を見込むとされていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社元と製産費外に賄賂を見込むの計算なし。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "「様子を聞いたか」のちよぼにて暖簾の中にてどんどんどんどんと足音を響かせ、出の拵は弁慶の単衣に三尺を締め、手拭を浅く輪の様にして向鉢巻をなし、留をやや左に寄せＶ字状になし、右の偏袒になりて白木綿の腹巻を見せ、裾を高く尻端折し、袖をたくし上げ、両手にて暖簾をかかげ、股を開きて向を見込む。",
              "citation": {
                "source": "いがみの権太",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "梶原の実検を見込む様子「面あ上げろ」のせつなき工合、共に得心がゆきたり。",
              "citation": {
                "source": "いがみの権太",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の出にて面をとり、つかつかと舞台の端に出で、見附け柱を抱へて向ひを見込む所よし。",
              "citation": {
                "source": "両座の「山門」評",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の出は羽織を脱ぎしほしほとして出で「しつかりと」といふ白に力を入れ、刀を引寄せ、小刀をも抜出して揃へ置き、体を斜よりもむしろ後向になし、両手を膝につき松王の方をじつと見込む。",
              "citation": {
                "source": "両座の「山門」評",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かな湖面を、じっと彳んで見ているうちに――　ですから、近来の米友には、じっと風物を見込むと、知らず識らず考え込む癖がついてきました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋の中で臼のあたりを小箒で掃いていた若い男は、その手を休めてこちらを向いて、「狸に見込まれないようにしろや」と言って笑うと、「大丈夫だよ、わたしなんぞを見込む狸はいないから」　女もまた、小屋の中を見込んで笑いながら戸を締めました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "慢心和尚の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たしかにあの松原の中」　兵馬は松原の木の下闇を見込む。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴鹿山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの客人はどこへ行かんすやら」　大竹小竹の宿引が不審の眼を※ったのも気がつかず、一文字にここまで来て、「雨では山越しも困る」　鈴鹿明神の森の中を見込むと、鳥居の右へ向っては峠の山道、鈴鹿御前の社と内外宮とが棟を並べた中に、春日形の大燈籠の光も雨に濡れている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴鹿山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　片手で馬の轡を取りながら、そうして、石の飛んで来る前岸を見込むと、さても夥しい人出。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当に凝った作りのこの造作を見廻し、関東風の旅籠との調度の比較などを試みているうちに、部屋の一隅に張りめぐらした六枚屏風に屹と酔眼を留めて、鋭く中を見込むようなこなしをやりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "農奴の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち籠めている霧の中を見込むと、時々｜岡や村が近い所に見える。",
              "citation": {
                "source": "みれん",
                "author": "シュニッツレル　Arthur Schnitzler",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソロドフニコフは窓の前に立ち留まつて、中を見込むと、果して見習士官が見えた。",
              "citation": {
                "source": "死",
                "author": "アルチバシェッフ・ミハイル・ペトローヴィチ　Artsybashev Mikhail Petrovich",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「新聞配達を見込むなんて、そんなもの好きな人がいるのかね。",
              "citation": {
                "source": "おじさんの話",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そこが見込むということじゃないか。",
              "citation": {
                "source": "おじさんの話",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまちには、よく似た路地が蜘蛛の巣のように四通八達していて、路地の両側の家々の、一尺に二尺くらいの小窓小窓でわかい女の顔が花やかに笑っているのであって、このまちへ一歩踏みこむと肩の重みがすっと抜け、ひとはおのれの一切の姿勢を忘却し、逃げ了せた罪人のように美しく落ちつきはらって一夜をすごす。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
