    "definitions": [
      {
        "index": 1,
        "gloss": "Ming dynasty (of China; 1368-1644)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "車中の一行は、明朝の登山を控えて、「この雲では山は雨かな」と心配すれば、「なあに、雲は低いですよ、すっぽり抜けると、上はカラカラの上天気ですよ」などといい合った。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "明朝の登山準備を頼んで、宿の浴衣を引っかけたまま、細長い町を散歩する。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて寝に就いてからも、「何だ馬鹿馬鹿しい、十五かそこらの小僧の癖に、女のことなどばかりくよくよ考えて……そうだそうだ、明朝は早速学校へ行こう。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前はネ、明朝は夜が明けたら直ぐに往ってよオく民子の墓に参ってくれ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "無線電信――六〇六――石碑――W.C　――じゃ、間違いっこなし、明朝、練兵場よ。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた妾を明朝たずねてきていただきたいの。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓデパートに依頼された新衣裳と、Ｒ新聞に原稿を明朝までに書いて置かなくちゃならないの。",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハア、あの五週間の欠勤届の期限が最早きれたから何とか為さらないと善けないッて、平岡さんが、是非今日私に貴姉のことを聞いて呉れろッて、……明朝は私が午前出だもんだから……」「成程そうですねェ、真実に私は困まッちまッたねエ、五週間！",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「明朝のを今｜製造えるのでしょうねエ」とお秀も笑うて行こうとする、「ちょっと御待ちなさいよ」とお富は止めて、戸外から、「その麺包を少し下さいな。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあお気の毒さまねエ、明朝のお目覚にやりましょう。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや行き過ぎて若者の一人、いつもながら源叔父の今宵の様はいかに、若き女あの顔を見なばそのまま気絶やせんと囁けば相手は、明朝あの松が枝に翁の足のさがれるを見出さんもしれずという、二人は身の毛のよだつを覚えて振向けば翁が門にはもはや燈火見えざりき。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "明朝咲く朝顔の莟を数えて報告するのもある。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（おお、諏訪の湖の辺まで馬市へ出しやすのじゃ、これから明朝お坊様が歩行かっしゃる山路を越えて行きやす。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "明朝かれにさっそく、この事を告げて、彼をして狼狽させてやるのも一興である。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから手紙を持たしてやって、電話じゃアだめだよ、そして明朝午前八時までに御来車を仰ぐとでもしておこう。",
              "citation": {
                "source": "疲労",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の寝静まるのを待って、お政はひそかに箪笥からこの帯を引出し、明朝早くこれを質屋に持込んで母への金を作る積と思い当った時、自分は我知らず涙が頬を流れるのを拭き得なかった。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は家のこと母のこと心にかかれば、二郎とは明朝を期して別れぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "太子が摂政の任にお就きになった推古朝は、日本に公に仏教が入った欽明朝の時より四十年余りしか経っておりません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人と少年とを其船室に送つて、明朝を契つて自分の船室に歸つた時、八點鐘の號鐘はいと澄渡つて甲板に聽えた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は夕食後例のやうに食堂上部の美麗なる談話室に出でゝ、春枝夫人に面會し、日出雄少年には甲比丹クツクの冐瞼旅行譚や、加藤清正の武勇傳や、また私がこれ迄の漫遊中の失策談などを語つて聽かせて、相變らず夜を更かしたので、夫人と少年をば其船室に送り込み、明朝を約して其處を去つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "明朝まで待つのですか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と武村兵曹は口をむくつかせたが、忽ちポンと掌を叩いて『おゝ、それも左樣だ、私の考通りにも行かないな、之から糧食を積入れたり、飮料水の用意をしたりして居ると、矢張出發は明朝になるわい。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐵車が、いよ／＼永久紀念塔を深山の頂に建てんが爲めに、此處を出發するのは明朝午前六時と定つたが、櫻木海軍大佐は、海底戰鬪艇の運轉式も間近に迫つて居るので、一日も此塲を立去る事叶はねば、そこで私と、日出雄少年と、武村兵曹と、他に二名の水兵とが、鐵車に乘組む事になつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一五）巨大な天狗面　しかし小言をいったとて帰らぬ事、一同は些か咽の渇きも止ったので、「サァ明朝は早いぞ、もう寝ようか」と、狭い天幕内へゾロゾロと入り込んだが、下は薄い筵一枚で水がジメジメ透して来る。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう夜になっては探せないから、今日はどこかに野宿して、明朝早く探すことにしようじゃないか。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お媼さんにお土産は、明朝、こちらから。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、Ｓ署では明朝を期して、一斉に検挙の網を打とうと考えていた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　均平はそれを辞し、病院は明朝にすることにした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
