    "definitions": [
      {
        "index": 1,
        "gloss": "to command a view",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "見晴らす広漠とした河原に石と砂との無限の展望。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階に客のない時は大広間の真中へ椅子を持出して、三十畳を一人で占領しながら海を見晴らす。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑紫野を見晴らす大根畠と墓原の間の小径の行止まりに、万延寺の本堂と背中合わせにして一軒の非人｜小舎がある。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "博多の町の南の出外れ、万延寺の本堂と背中合わせの竹瓦に板庇、板敷土間に破れ畳二枚、ガタガタ雨戸の嵌め外しがやはり二枚という、乞食小舎の豪華版から、墓原越しに見晴らす筑紫野は、これも晩春の豪華版であろう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "登りつめるときれいな芝を植えた斜面から玉川沿いの平野一面を見晴らす事ができた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨はだんだん強くなって、二階の縁側から見晴らす海も潮けむりに暗かった。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の行きとまりに低い珊瑚樹の生垣、中ほどに形ばかりの枝折戸、枝折戸の外は三尺ばかりの流れに一枚板の小橋を渡して広い田圃を見晴らすのである。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時の東海道は品川から浜川、鮫洲で、鮫洲から八幡さまのあたりまでは、農家や漁師町が続いていますが、それから大森までは人家が途切れて、一方は海、いわゆる安房上総をひと目に見晴らすことになる訳で、仕置場までの間を鈴ヶ森の縄手と呼んでいました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "妖狐伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　径の在所も知れぬ熊笹の崖である、流れの岩を飛んで胸突きの崖をよぢ登ると、国境の山々を見晴らす明るい芝の野原に出るが、私は何時かの春の蕨狩りに出掛けた時、崖を這ひ登りながら胆を冷したのを思ひ出して、銃を担いだ娘がひとりであれを登るさまは想像が困難だつた。",
              "citation": {
                "source": "ダニューヴの花嫁",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "其所へ乗って四方を見晴らす。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "佐竹の原へ大仏を拵えたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから内部の階段を曲りながら登って行くと、頭の中になって広さが二坪位、此所にはその目の孔、耳の孔、口の孔、並びに後頭に窓があって、其所から人間が顔を出して四方を見晴らすと江戸中が一目に見える。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "佐竹の原へ大仏を拵えたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "青々とはれた空へ翔んでゆきでもするように高い崖から遠くを見晴らすときの面白さ。",
              "citation": {
                "source": "道灌山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう夜は黎明に向ったと見え、高地の中腹から見晴らす広い空の紺黒い色も星の輝きもほのかな軟かみを湛えて来た。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寺々が皆港を見晴らす山よりに建てられて居る。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この京都の町を一目に見晴らす高い山の上のお墓に埋められている人は、坂上田村麻呂という昔の名高い将軍です。",
              "citation": {
                "source": "田村将軍",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれを都の四方を見晴らす東山のてっぺんに持って行って、御所の方に顔のむくように立てて埋めました。",
              "citation": {
                "source": "田村将軍",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから博多湾の朝景色を見晴らす窓を見て、ヤット昨夜の事を思い出した。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陽ホテルの駅前街路を見晴らす豪華な一室に、立派な緞子の支那服を着た、鬚髯と眉毛の長い巨漢が坐っていた。",
              "citation": {
                "source": "人間レコード",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋は根津界隈を見晴らす二階、永井荷風氏の日和下駄に書かれたると同じ部屋にあらずやと思う。",
              "citation": {
                "source": "森先生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "西南を一目に見晴らす此処の座敷は、今雪の田園を額縁なしの画にして見せて居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓より見晴らす初夏の空あおあおと浅黄繻子なんどのように光りつ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、麗かな光に目を眩ませて顔を顰め乍ら、このやうに晴れ渡る日、広々と海を見晴らす横浜はどんなに壮快であらうかと駄夫を羨しがつた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "高山に登った人々の経験することであるが、山の頂きにたどりついて、脈々と連なる尾根を見晴らす時、何か叫びだしたくなる。",
              "citation": {
                "source": "うつす",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "先画面の下部に長き橋梁を斜に横はらしめよ、しかして淋しき夜駕籠と頬冠の人の往来を見せ、見晴らす水面の右の方には夜の佃島を雲の如く浮ばせ、左の方には新地の娼楼に時として燈火を点じて水上に散在する白魚船の漁火に対せしめよ。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は湖水を見晴らす野原のはじに家を建てる。",
              "citation": {
                "source": "過去となつたアイルランド文学",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝百合さんの肩にすがりながら初めてこの部屋へ上つて来たときの話では、窓の外は海や港を見晴らすヴェランダださうである。",
              "citation": {
                "source": "恢復期",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもアンドゥーズ山の頂から見晴らす地平線上に限られていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓は湖水を見晴らす露台に向かって開いていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて出て来ると、家じゅうの眼をみはらすような濃い化粧を見せ、着物も毎朝違ったのに着更えていた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
