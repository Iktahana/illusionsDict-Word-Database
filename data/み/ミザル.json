[
  {
    "uuid": "3fe7858f-e885-5b50-896f-24cec23ce4cf",
    "entry": "見猿",
    "reading": {
      "primary": "みざる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "see-no-evil monkey (one of the three wise monkeys)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第一色氣があつて世を憚らず、親不孝を顧みざる輩は、男女で相乘をしたものである。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その約に負かざらんことを虞るる者と、恩中に恩を顧みざる者とは、おのおのその務むべきところを務むるに専なりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "争はずして自から保つ者は多く勝ち、殺すを務めて顧みざる者は多く敗る。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "假に句讀訓詁を事とせざるは可なりとするも、書を讀んで句讀訓詁を顧みざるが如き習慣を身に帶ぶるに及んでは、何事を爲すにも、粗笨にして脱漏多く、違算失計、甚だ多きを致すを免れざるものである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何となれば、夢みつゝある時と、未だ夢みざる時との、其の人の事情が境遇や心理は殆ど同樣であるのに、一二時間前は夢みず、一二時間後は夢みる、其の所以如何といふことは、心理の上では解釋に及び難い理で有るから、是非も無いのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "賈人の物いひかはす聲の高きは、伊太利ことば知らぬ旅人聞かば、命をも顧みざる爭とやおもふらむ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は丈高き馬に乘れば、最早我を顧みざるならん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "この技は人と成りての後未だ試みざるものなるを。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどヱヌスの生けるをば、われあまたゝび顧みざること能はず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが諸君に対するの義務は、畢竟一身を抛擲して、内地に止まる人に好手段を与うるの犠牲たるのみなれば、決死の壮士少数にて足れり、何ぞ公私を顧みざる如きの人を要せんやと。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アア堂々たる男子にして黄金のためにその心身を売り恬として顧みざるの時に当り、女史の高徳義心一身を犠牲として兄に秘密を守らしめ、自らは道を変えつつもなお人のため国のために尽さんとは、何たる清き心地ぞや。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてその不斉一その粗悪なるは、その製出者と営業者とに徳義心を欠くが故なりというも可なり、鑑みざるべけんや。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お場所｜柄を顧みざるお咎めは甘んじて受ける。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "世は穢れ、人は穢れたれども、我は常に我恩人の独り汚に染みざるを信じて疑はざりき。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "子孫のために、己れの命を顧みざる也。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に況んや、幾多の無辜を罰して顧みざる非人道に想倒する時は、烈日の下寒毛樹立せずんばあるべからず。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃実際的道徳の要を知りはじめたる、我日本は、此際深く自ら省みざるべからず。",
              "citation": {
                "source": "実行的道徳",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "客観的人生にのみ心酔して主観的人生を顧みざるが如き趣きあり。",
              "citation": {
                "source": "実行的道徳",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく月みざる人はもはや戸さす比、何くより来にけん、白雲月の前に横り、をりしも雁なきわたる。",
              "citation": {
                "source": "月",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "高倉の宮の宣旨、木曾の北、關の東に普ねく渡りて、源氏｜興復の氣運漸く迫れる頃、入道は上下萬民の望みに背き、愈々都を攝津の福原に遷し、天下の亂れ、國土の騷ぎを露顧みざるは、抑々之れ滅亡を速むるの天意か。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何為ぞ行政区劃の異るを以て危急の災害を顧みざるを得んや。",
              "citation": {
                "source": "非常歎願書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "その沒却作家以外の面相、沒却理想以外の面相をば逍遙子不説として顧みざることを得べく、われはこれを不問にして棄ておくことを得べし。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどたとひ此區別明なることありと雖も、そのいろ／＼の資格にありて唱ふる論を、かれこれと併せ考へて、わが批評眼のそのすべての資格に通ずる論なることを認むるときは、批評の上にて復た論者の諸資格の區別を顧みざることあるべし。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに今日の経済組織の下においては天下の生産者はただ需要ある物のみを生産し、たといいかに痛切なる要求ある物といえども、その要求にして資力を伴わざる限り、捨ててこれを顧みざるを原則としつつある。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のいうところの必要及びぜいたくはかくのごとき意味のものであって、毫も個人の財産または所得のいかんを顧みざるものである。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてこの強者をおさえかの弱者をたすくるがためには、彼はほとんどおのれが身命の危うきを顧みざる人である。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下の書肆皆新作家の新作品を市に出さんとする時に当り、内田百間氏を顧みざるは何故ぞや。",
              "citation": {
                "source": "内田百間氏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに吾邦の学者は夙に李園（原）を鄙み、措て顧みざるを以て、之を記するの書、未嘗多しとせず。",
              "citation": {
                "source": "本の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば娼婦型の女人は啻に交合を恐れざるのみならず、又実に恬然として個人的威厳を顧みざる天才を具へざる可らざればなり。",
              "citation": {
                "source": "娼婦美と冒険",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
