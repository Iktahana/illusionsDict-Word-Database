    "definitions": [
      {
        "index": 1,
        "gloss": "to be undeserved",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まことに身に余る面目。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "身に余る晴れやかな男の親切の裡に、たよりなさ、わびしさがますます深く感ぜられて来る。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "朕のやうな無学無謀な輩が一日でも覇者の位を汚し得たことだけでも身に余る事だ。",
              "citation": {
                "source": "悲しき項羽",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "身に余る面目に昇は得々として満面に笑いを含ませ、紳士の笑い罷むを待ッてまた何か饒舌り出した。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今マアク・トヱン君が申し上げましたのが、紛れもない私の演説でございますが、それに対して皆様から過分な御拍手をいたゞいて、私身に余る光栄だと存じて居ります。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍従はこれを身に余る喜びとした。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆様からこれほどの身に余る御引立を受けまして、轟九蔵からあれほどまで可愛がられておりました私だったので御座いますよ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りまた、詩歌管絃の道に長じてさえ居りますれば、無位無官の侍でも、身に余るような御褒美を受けた事がございます。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "律儀といふ天然の砦がなければ支へることの不可能な身に余る野望の化け者だ。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "律義といふ天然の砦がなければ支へることの不可能な身に余る野望の化け者だ。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠方のどこかで未知の人々が私の新年を祝ってくれているなぞとは身に余ることで、それに対して私も来年は年賀状をだそう。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "高貴の方がなんと御得心遊ばされたかは私の関するところではないが、この奉答によって、ひたすら身に余る光栄を感じたことは真実に光栄であった。",
              "citation": {
                "source": "私の陶器製作について",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして殿下から御慰労のお言葉を賜わり、御奥からも御老女を以て「殿下は今度の登山を大層愉快だったとお喜びになって居られます、御苦労でありました」と有り難いお言葉を頂いて、二人は身に余る光栄にひたすら恐懼するのみであった。",
              "citation": {
                "source": "朝香宮殿下に侍して南アルプスの旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　身に余る上意にはだか武兵衛は畳へ面形を拵えたが、さも有難そうに顔を上げ、「いわば雲助のこの私を苗木の城で名も高い浪人組へお加えくだされ末長く仕えよとの有難い仰せ、何んの否やがございましょう。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "エンタツの天才や、時代感覚にくらべれば、歌笑などは、金魚とミミズぐらいの差があって、戦後にえた人気は、身に余るものであったろう。",
              "citation": {
                "source": "“歌笑”文化",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は寧ろ此の話を聴きながら身に余る重い負担を双肩に荷わされたような窮屈さを感じないわけには行かなかった。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあそうなりますと、身に余る大役をお請けした上に、大樹とも頼む太閤はおいでにならず、東の御方様はじめお若い方々のみ残られました桃花坊で、わたくしは茫然と致してしまいました。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあさうなりますと、身に余る大役をお請けした上に、大樹とも頼む太閤はおいでにならず、東の御方様はじめお若い方々のみ残られました桃花坊で、わたくしは茫然と致してしまひました。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「身に余る栄誉――。",
              "citation": {
                "source": "元禄十三年",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は紅葉門下の二巨星の間に挟まつて、真に光栄身に余る気がした。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次は老中阿部豊後守のお目通りを許され、身に余る言葉を頂きましたが、相変らず蔭の仕事で、表沙汰の手柄にも功名にもなりません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "南蛮秘法箋",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い時分は上方から九州までも放浪して、身に余る野心を抱いたこともありますが、今ではすっかり落着いて、兄の莫大な身上を切り廻して、何から何まで指図をしている四十男だったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "血潮と糠",
                "note": "青空文庫"
              }
            },
            {
              "text": "数々の下されもの、身に余る御賞めの言葉、その上祝い酒まで下されて、六郷左京上々の首尾で帰りましたが、「お帰り遊ばしませ」「――――」「上々の御首尾で、お目出度う御座います」　ワクワクした心持で迎えてくれた多与里に対して、左京はもう、大した関心も持っていなかったのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "左京の恋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし一生のあいだ姿を消して、事務局の暗い片隅にうずくまりつづけるというようなことにならなければ、それだけでもあの人の身に余る名誉なんですよ」「Ｋ、あなたは」と、オルガはいった。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "さような思いをかけて下さいますだけでもなよたけにとりましては、身に余る光栄でございます。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ主君の身に余る恩情については、辛い。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿体ない、身に余るお情けを何に包みましょうか。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリヴィエは、それを身に余る幸福だとして恥ずかしく思わなかったら、自分の力を濫用して勝手な真似をするのは容易だったろう。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "友の心のうちに多大の場所を占めてると感ずることは――それが身に余ることだと意識してもなお――非常にうれしいことだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
