        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "神の前にての、エゴイスチッシュならぬ、天使としてゲミュートを損ぜぬ、けれど性の要求を飽和させる恋というものを描かずにはいられません。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者はあなたの作物によって、運ばれて行く事件の進行ではなく、あなたのゲミュートに直接に感じて動かされます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は前の方の一面を道徳の習俗性（ジットリッヒカイト）と呼び、後の方の一面を道徳の心情性（ゲミュート）と呼ぶことが出来ると思う。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "三木のゲミュートは教育的本質のものだとさえ云えそうだ。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "バヴァリア――山岳――刺繍したシャツ――波をうつ羽根――太った、陽気な娘たち――ゲミュートリッヒカイト――。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
