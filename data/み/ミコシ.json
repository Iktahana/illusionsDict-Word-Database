    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mikoshi",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこに神輿が渡御になる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神輿の前で相撲がある。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "折からこの地の祇園祭で樽神輿を舁いだ子供や大供の群が目抜きの通りを練っていた。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これについて思い出すのは、東京の著名な神社の祭礼に、街上で神輿をかついで回っている光景である。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおぜいの押し合う力の合力の自然変異のために神輿が不規則な運動をなしている状態は、顕微鏡下でたとえばアルコホルに浮かぶアルミニウムの微細な薄片のブラウン運動と非常によく似た状態を示している。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神輿の運動の変異量と、その質量や舁夫の人数、各人の筋力、体量等との間に或る量的関係を見いだすことは充分可能でありそうに思われる。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "沈み切っていた、職人頭の富さんが、運八に推遣られて坐に返ると、一同も、お神輿の警護が解けたように、飲みがまえで、ずらりとお並びさ、貴方。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私たちの誂へを一二度通すと、すぐ出前に――ポンと袢纏を肩に投げて、恰も、八幡祭の御神輿。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（こゝのは擔ぐのではない、鳳凰の輝くばかり霄空から、舞降る處を、百人一齊に、飛び上つて受けるのだといふ）御神輿に駈け著ける勢ひで飛び出した。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御神輿かつぎは、人の氣競がもの凄い。",
              "citation": {
                "source": "祭のこと",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御神輿の柱の、飾の珊瑚が※と咲き、銀の鈴が鳴据つて、鳳凰の翼、鷄のとさかが、颯と汗ばむと、彼方此方に揉む状は團扇の風、手の波に、ゆら／＼と乘つて搖れ、すらりと大地を斜に流るゝかとすれば、千本の腕の帆柱に、衝と軒の上へまつすぐに舞上る。",
              "citation": {
                "source": "祭のこと",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう此時は、人が御神輿を擔ぐのでない。",
              "citation": {
                "source": "祭のこと",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍頭また鷁首にして、碧丹、藍紅を彩れる樓船なす御神輿の方が、います靈とともに、人の波を思ふまゝ釣るのである。",
              "citation": {
                "source": "祭のこと",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御神輿は行きたい方へ行き、めぐりたい方へめぐる。",
              "citation": {
                "source": "祭のこと",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三社樣の御神輿が、芳原を渡つた時であつた。",
              "citation": {
                "source": "祭のこと",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御神輿は、あらぬ向う側を練つて、振向きもしないで四五十間ずつと過ぎる。",
              "citation": {
                "source": "祭のこと",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お定りの魚軒と言ふと、だいぶ水氣立つたとよりは、汗を掻いて、角を落して、くた／＼と成つて、つまの新蓼、青紫蘇ばかり、濃い緑、紫に、凛然と立つた處は、何うやら晝間御神輿をかついだ時の、君たちの肉の形に似て居る。",
              "citation": {
                "source": "祭のこと",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて聞えて来る太鼓の音と神輿を担ぐ若い衆の挙げるかけ声。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十人許りの壯者に擔がれた神輿は拜殿前の石段を下つて鳥居の下の廣場に出る。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのやうに今も神輿がゆれながら響いたのである。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して幾度か止まり幾度か蹌踉いて、子供等の小さい胸を痛ましめた神輿は、突然何か思ひ付いたやうに細い道を東の方に驅つて行つた。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから予等は神輿の跡は追及しないで、後にその着く可き海岸で待つて居た。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或人は神輿にかかる。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年十月十九日、宝の市の最後の夜は、稚児、市女、順々に、後圧えの消防夫が、篝火赤き女紅場の庭を離れる時から、屋台の囃子、姫たちなど、傍目も触らぬ婦たちは、さもないが、真先に神輿を荷うた白丁はじめ、立傘、市女笠持ちの人足など、頻りに気にしては空を視めた。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑には馬鈴薯白う花咲きて、雲雀の歌も夕暮の空にいざよひ、南ふく風静やかに、神輿の列遠く青みき。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "國をあげての日章旗、神輿、群衆。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてお神輿を上げようと思つたが、コニヤツクに湯ざましを割つたコツプの、飲み干さずにあるのが目に着いた。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏神の祭礼に、東京で各町内、侠勇の御神輿を担ぐとおなじように、金沢は、廂を越すほどの幌に、笛太鼓｜三味線の囃子を入れて、獅子を大練りに練って出ます。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事と知ったら来るのじゃあなかったと、おかみさんも後悔していましたが、今さら帰るにも帰られず、まあ小さくなって辛抱して居りますと、やがて四ツ（午後十時）過ぎでもございましょうか、唯今お神輿のお通りでございます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗いなかでお神輿の金物がからりからりと鳴る音と、それを担いで行く白丁の足音がしとしとと聞こえるばかり。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
