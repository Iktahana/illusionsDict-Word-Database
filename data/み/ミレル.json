        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ことしは見れると思って来たのだが、この豪雨のためにお流れになってしまったらしいのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふんでも、立派な墓石など建てたって、毎日お墓さ行って見れるもんでもあるめえしね。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この兄弟なんぞもやっぱりその一例だと見れる。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "活動寫眞は毎日あるし、芝居も見れるし、音樂會はある。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴方にホテル経営の面倒が見れるか知ら。",
              "citation": {
                "source": "浪の音",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけんど、俺ア脳味噌が変ったぜ、世の中の事が表からよりも裏から見れるんだ。",
              "citation": {
                "source": "反逆",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "活動写真をタダで見れるようになるんだよ！",
              "citation": {
                "source": "ペーチャの話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも雪駄で稚子髷でゆらり袂で通つたらさくらの花道花のかげむかしの夢が見れるだろ。",
              "citation": {
                "source": "歌時計",
                "author": "童謠集",
                "note": "青空文庫"
              }
            },
            {
              "text": "「我等の劇場」と総括的に題した数篇の文章は、「演劇一般講話」の補遺と見れば見れる性質のものであるが、それと同時に、幾分、我が国に於ける現代劇の批評的考察を含んでゐる。",
              "citation": {
                "source": "「我等の劇場」緒言",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれで亭主の面倒が見れるかと思ふくらゐですよ。",
              "citation": {
                "source": "温室の前",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "真正面に見れるあの面影。",
              "citation": {
                "source": "四年のあいだのこと",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなくジュネーヴが見れるのだと考えると、熱っぽい喜びで脈搏が鼓動した。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この若木は、無事にそれをしのいで、いくたびも春を迎えて、麗しい花を開くであろう、が、こう年をとった私は、はたして、もう一｜度、その花が見れるだろうかと思ったのでした。",
              "citation": {
                "source": "手風琴",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ま、一度ごらんになってよ、とてもそんな――敦子　だって信州の山の中の人を私が見れる道理がないわ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらだとて見れるもんでねえ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八、お互いに顔が見れるのが不思議じゃないか」「灯りなんかつけて行ったはずはありませんよ」　金太はあわてて注を入れるのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「止しませうよ、親分、塀の外からだつてよく見れるぢやありませんか、屋敷は坂なりだから――まさか、匂ひも嗅いぢやいけないとも言はないでせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "白梅の精",
                "note": "青空文庫"
              }
            },
            {
              "text": "一元的に見れば見れるということが、彼等の身上だ。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな小さい窓から覗いたところで、家中見れるわけでもあるまいが」　平次は横槍を入れました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "江戸の夜光石",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらにだとて見れるもんでねえ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の雨は冷めたいけど雨が上った後の水たよりの清しさ静けさが見れると言う事はうれしいものです。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "両の手のひらに日ざしを受けて掌の汗が小さく光っている時、いのちって尊いなあー、見れる事はうれしいなあー、あたたかいなあーとつぶやきたくなるのです。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月五日さとるより　窪田章一郎先生　遠くに見える豊島区営グランドの樹々がすっかり黄いろくなりました窓から部屋にいて樹々を遠く見れるのは私の房ととなりの二部屋です。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れるものなら顔を挙げて俺の顔を見ろ！",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔が見れるものなら……おい、顔を挙げて真正面に俺の顔を見てみろ！",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすれば人は優しくなれるはずだ哀れみの目で物事を見れるはずだ、　わかってさえいれば。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪の意識がやつを打ちのめさなかったら、私の魂がやつの血にまみれるなんてことも確かにありえただろう。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざわざ深いぬかるみに入つたり、泥んこで團子やそのほか樣々な物の形を作つたり、手や足が土にまみれることが多ければ多いほど喜びを感じた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝剣は唾にまみれると同時に、たちまち神通力を失ったのか、ばたりと床の上へ落ちてしまった。",
              "citation": {
                "source": "金将軍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし罪にまみれることはうれしいことではない。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
