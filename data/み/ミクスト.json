          "standard": [
            {
              "text": "この地域では公共セクターと民間セクターが協力する、ミクストな経済体制が取られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今回の作品は、油彩とデジタルを組み合わせたミクストな表現を目指しました」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "社会問題の解決には、多角的な視点を持つミクストなチーム編成が不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ＪＢＤＭはフランスでは珈排のミクストの方式さ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャワとブレアンジュとデメラリとマルチニックのミクスト……どこの三文キャフェでもやっている方式なんだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "（＊真正なことを明記）チョウジとその混ぜ物処理（＊略）オールスパイスとその混ぜ物処理（＊略）ミクスト・スパイスとその混ぜ物処理（＊略）有毒なトウガラシとその混ぜ物処理（＊略）カレー粉とその混ぜ物処理（＊略）有毒な瓶詰め果物と野菜　結論は次の通りであった。",
              "citation": {
                "source": "食品とその混ぜ物処理",
                "author": "FOOD AND ITS ADULTERATIONS; ANALYTICAL SANITARY COMMISSION OF \"THE LANCET\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルドヴルと、ポタアジュ・エキセルソー、フリッタ・ミクスト、ピーチ・メルバ食って座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
