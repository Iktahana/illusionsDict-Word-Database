    "definitions": [
      {
        "index": 1,
        "gloss": "it seems that",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それがまた不思議に癒る（心は悪くないが、浅墓であることの象徴みたいだと予てブラ公はさう思つてみてゐるのである）。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだ唐人の寐言みたいだ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "をばさんも、娘さんも、はじめのうちは、私の音無しさに、かへつて奇怪を感じた樣子で、あのお客さんは女みたいだ、と蔭口きいて、私は、それをちらと聞いて、ああ、あんまり音無しくしてもいけないのか、とくやしく思つた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「展覧会の招待日みたいだ。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「展覽會の招待日みたいだ。",
              "citation": {
                "source": "春晝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは、何だかひどく下等な「面當て」みたいだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、私は新宿の或る店へはひつて、ひとりでビイルを飮んでゐたら、女の子が呼びもしないのに傍へ寄つて來て、「あんたは、屋根裏の哲人みたいだね。",
              "citation": {
                "source": "容貌",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くに町が、石灰みたいだ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そういえばタイガーの入口の電飾はにんしんした支那女の入墨のあるお腹みたいだぜ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日本人って奴は、まるで狂犬みたいだ。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋ君の批評に依ると、モーゼが紋服を着たみたいだそうですが、当っていますかね。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は、神さまみたいだ。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分で、ひそかに、「貫一さん」みたいだと思っていた。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お葬ひみたいだつたよ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作家にくらべたら、先生なんかは乞食みたいだ。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ学校教育を受けるという事が、ちょうど案内者に手を引かれて歩くとよく似ているという事をもう少し立ち入って考えてみたいだけである。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士「よろしい、私お二人とも乗せます」青年（笑いながら）「悪漢みたいだな、知らん人を自動車へ乗せるなんて、あんたは」紳士「冗談じゃない、そりゃ、アメリカのことですよ。",
              "citation": {
                "source": "オペラの帰途",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も何だか昨日にくらべると、一躍有名になったみたいだけどこうしてしょぼんと雨に吹きつけられて電車を待っていると、人間って奴は案外寂しいもんだなアという気がする」　信吉はふとそんなことを言った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁解みたいだけれど、『赤と黒』が九百一頁あるとすれば、その九百一頁に渡って書かれてあるような小説だとしか言えないよ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事言うと、非国民みたいだけど、あたし、みんなの様に夢中になれないの」「したいことって、どんな事……？",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も何だか昨日にくらべると、一躍有名になったみたいだけど、こうしてしょぼんと雨に吹きつけられて電車を待っていると、人間って奴は案外寂しいもんだなアという気がする――って。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれたちだけじゃ、まだ足りないっていうみたいだ。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで、植わっている箱みたいだ！",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ふうん、手だけ見てると、まるで、あたしのきたないおっかさんみたいだよ」　ゲルダは、うれしさのあまり、泣き出しました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい襟を指さして、よだれかけみたいだね、失敗だね、大黒様みたいだね、と言って大笑いした友人がひとりあったのでした。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは、何だかひどく下等な「面当て」みたいだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その言葉が、女みたいだとか、のろくさしてゐるとかいつて。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに女みたいだなあ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、みんなは新太郎ちやんのことを、まるで見落としてゐるみたいだつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
