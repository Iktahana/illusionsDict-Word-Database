    "definitions": [
      {
        "index": 1,
        "gloss": "to watch over",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "呆然と殿様を見守る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤牛は、じいっと鞍を背負って子供を見守るように立っていた。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ先端に点火されてただかすかにくすぶっている間の沈黙が、これを見守る人々の心をまさにきたるべき現象の期待によって緊張させるにちょうど適当な時間だけ継続する。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青衣の西洋少女が合掌して上目に聖母像を見守る半身像である。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の一擧一動を慈愛をこめてまじろぎもせず見守る眼を運命の眼の外に彼等は持たないからだ。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん判って来たでしょうが、あまり気にしないで呉れ給え」　私は良人が私をうち見守る眼差の中で、結婚して始めての嬌態を作って、こう云わないでは居られませんでした。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘驚きて飛び退き、呆れて母を見守る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "賀来子が伝三郎の妻に挨拶している間、兄弟は、ぽかんと突っ立ったまゝ、それ／″＼お互いの妙な顔を見守るばかりだった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "拳に据ゑた隼をひたと見守る。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つの足が一組になっていろいろ入り乱れるのを不思議に思って見守るのであった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　マーティン警部は物わかりもよく、我が友人を自由にやらせてくれ、ただその結果を見守るだけで満足のようだった。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、あたりにはこやつらもいますから、近くで見守る人間が必要だと。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "出席者のほとんどは、縦ノリには至らなかったもののカンビール片手のスタンディングで、イベントの進行を見守る形となった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてまた屡※起きては我が兒の顏を見守るのであつた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「樵夫のところから縄梯子を借りて来たら好からう、そしてあたしはお前の手がミスルトウの枝に触れるところを注意深く見守るであらう、お前が切りとつて来るミスルトウにあたしは、二人の永久の幸ひを祈る最初の接吻を寄せるであらう。",
              "citation": {
                "source": "寄生木と縄梯子",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "○合唱婦人、（優しく）私達は、静かに、（間）男達の仕事を見守る（急速に）人生の監視隊だ。",
              "citation": {
                "source": "きのふは嵐けふは晴天",
                "author": "小熊秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　Ｋはけげんそうにスケッチ帳から目を上げて君の顔をしげしげと見守る。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして立ちすくんだその姿の首から肩、肩から背中に流れる線は、もしそこに見守る人がいたならば、思わずぞっとして異常な憂愁と力とを感ずるに違いない不思議に強い表現を持っていた。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見守ることによって私は凡ての他の神秘を忘れようとさえする。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はそれでも真向にフランシスを見守る事をやめなかった。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は恐らくあすこの椅子にかけて微笑しながら自分を見守るだろう。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日毎日凍りつくような濃霧の間を、東へ東へと心細く走り続ける小さな汽船の中の社会は、あらわには知れないながら、何かさびしい過去を持つらしい、妖艶な、若い葉子の一挙一動を、絶えず興味深くじっと見守るように見えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し怪訝そうに葉子のいつになくそわそわした様子を見守る青年をそこに捨ておいたまま葉子は険しく細い階子段を降りた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは生命が見す見す自分から離れて行くのを見守るほどみじめでまっ暗だった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の妹たちはただはらはらして姉の狂暴な振る舞いを見守るほかはなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡の差し出す紙幣の束を怒りに任せて畳の上にたたきつける倉地の威丈高な様子、少女にはあり得ないほどの冷静さで他人事のように二人の間のいきさつを伏し目ながらに見守る愛子の一種の毒々しい妖艶さ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は心ひそかに自分を恐れながら、日々の自分を見守る事を余儀なくされた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣くにつけ、笑うにつけ、面白がるにつけ淋しがるにつけ、お前たちを見守る父の心は痛ましく傷つく。",
              "citation": {
                "source": "小さき者へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つはもともとからあった女を恋うる心、も一つは女をはなれてひややかに女をみまもる心でございます。",
              "citation": {
                "source": "おしどり",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてみまもる間もなく牝鶏が一匹の雛鶏を後に従えてトマトのそばに現はれた。",
              "citation": {
                "source": "雛鳥の夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
