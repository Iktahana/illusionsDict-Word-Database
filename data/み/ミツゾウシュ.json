    "definitions": [
      {
        "index": 1,
        "gloss": "illicitly brewed liquor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
