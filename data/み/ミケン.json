      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "brow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　母は元来蒼い顔にお負に眉間に皺を寄せて言つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉間には狐疑の深い皺がきざみ込まれ、小さい灰色の眼には淺間しい殺意が燃え、眞蒼な頬は威嚇の怒りに震へて、黒ずんだ薄い唇は嫌惡と侮蔑にひきつつたやうにゆがんでゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生々しい眉間の傷のような月が、薄雲の間にひっかかっていた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前には兩眉の間の眉間のへんが妙にむづむづしてくるのが極りだつたが、何しろ自分の體がいきなり涯知らずくうつと延び出すやうな感じがし出す。",
              "citation": {
                "source": "自分の變態心理的經驗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎は王の眼から、眉間を打たれた瞬間の屠殺される去勢牛のように、人のいい、無抵抗なものを感じた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えば、あのころ、十六歳の夏から、あなたの眉間に、きょうの不幸を予言する不吉の皺がございました。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなり度の強い近眼鏡をかけ、そうして眉間には深い縦皺がきざまれていた。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなかの柄であつて、われは彼の眉間の皺に不覺ながら威壓を感じた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなかの柄であって、われは彼の眉間の皺に不覚ながら威圧を感じた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "面の長さは三｜尺ばかり、頤の痩た眉間尺の大額、ぬつと出て、薄霧に包まれた不氣味なのは、よく見ると、軒に打つた秋祭の提灯で、一｜軒取込むのを忘れたのであらう、寂寞した侍町に唯一箇。",
              "citation": {
                "source": "月夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂上は外套の袖を捻ぢて、踵を横ざまに踏みながら、中折の庇から、對手の眉間を透かし視つつ、「私に用か。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度ヘッケルのような風をした眉間に大きな傷あとのある人が俄かに椅子を立ちました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもヒルガードには眉間にあんな傷痕がありません。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　梟眼赫と※けば、お丹も顔色｜蒼ずみて真白き面に凄味を帯び、眉間に透る癇癪筋、星眼鋭く屹と睨み、「ム、悔しいか。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まあ眉間から血が出て。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人ごとだけれども、眉間尺と較べると嘘のやうだ。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳の傍から眉間へ掛けて、小蛇のように筋が畝くる。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　声が眉間を射たように、旅客は苦しげに眉を顰めながら、「鍵はありません。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅顔可憐という形容が似合うのだが、しかし、じっと相手を見据える視線や、眉間の縦皺、きっと結んだ口元は、美少年型の鶴雄の顔に苦味走ったアクセントと、憂愁の陰影をつけていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔色が冴えず、何か思い悩んでいるらしく、眉間には深い縦皺が刻まれていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、西村はパイプを銜えたまま、俊鋭らしい眉間に十字に皺を刻んで、痛ましそうに相手のその様子を見やった。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は、まっこうから眉間を割られ、そうしてそれ以来その傷は、どんな人間にでも接近する毎に痛むのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉間には狐疑の深い皺がきざみ込まれ、小さい灰色の眼には浅間しい殺意が燃え、真蒼な頬は威嚇の怒りに震へて、黒ずんだ薄い唇は嫌悪と侮蔑にひきつつたやうにゆがんでゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は私にひとしきり、狂喜し感激して見せた揚句、眉間に皺を寄せて、どうしたらいいだろう？",
              "citation": {
                "source": "列車",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は私にひとしきり、狂喜し感激して見せた揚句、眉間に皺を寄せて、どうしたらいいだらう？",
              "citation": {
                "source": "列車",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎兵衛はおのれのからだをすみからすみまで殴ってみて、眉間と水落ちが一番いたいという事実を知らされた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むこうずねもまた相当に痛いことを知ったが、これは足で蹴るのに都合のよいところであって、次郎兵衛は喧嘩に足を使うことは卑怯でもありうしろめたくもあると思い、もっぱら眉間と水落ちを覘うことにきめたのである。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯れた根株の、眉間と水落ちに相当する高さの個処へ小刀で三角の印をつけ、毎日毎日、ぽかりぽかりと殴りつけた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたんにぽかりと眉間を殴る。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚してかれこれ二月目の晩に、次郎兵衛は花嫁の酌で酒を呑みながら、おれは喧嘩が強いのだよ、喧嘩をするにはの、こうして右手で眉間を殴りさ、こうして左手で水落ちを殴るのだよ。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
