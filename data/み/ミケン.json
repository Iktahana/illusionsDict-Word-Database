[
  {
    "uuid": "e7810079-f663-5ec7-83fe-4c0b65db2e76",
    "entry": "眉間",
    "reading": {
      "primary": "みけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
