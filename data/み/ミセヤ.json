        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "長さ二町ばかりの、その暗い湿つぽい通りに、今挙げたホンの三四軒の店屋が所々にあるのは、まるで蛍でもゐるやうな感じだつた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手に抱へられて、店屋の軒にやられた時、彼は「Ｓ子が来てやあしないか……？",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程兵隊の居さうなといふ事が町に並んで居る店屋の種類からも想像されるのであつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "表通りの店屋などでも荷物を纏めて立退用意をしている。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて私の住居を尋ねて来る人は、たとえ真昼間でも、交番やら店屋などを聞き聞き何度もまごついて後にやっと尋ねあてるくらいなものである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある店屋の主人は、銀座の十一屋にでも行ったらあるかも居〔知〕れないと云って注意してくれた。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってそういう淋しい村の雑貨店でも、神田本郷の店屋と全く同様な反応しか得られなかった。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "店屋の人自身がこれはほんのその時きりのものですから永持ちはしませんよと云って断っていたそうである。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら新宿をそばに控えているからといって、今どきの場末の稽古師匠が毎日｜店屋物を取ったり、刺身を食ったり、そんなに贅沢ができる筈がねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の店屋へ買い物に行くと、お前さんの故国でもワイナハトを祝うかなぞときくのがだいぶありました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人によると近所の店屋で得られると同じ罐詰などを、わざわざここまで買いに来るということである。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど兵隊のいそうなという事が町に並んでいる店屋の種類からも想像されるのであった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばおもちゃのモートルを店屋でちょっとやってみる時はよく回るが買って来て五分もやればブラシの所がやけてもういけなくなる。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車や人や店屋の上を、雲に這入つたり出たりして、涼しさうに、お月様は流れてゐた。",
              "citation": {
                "source": "散歩生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "店屋さへ最う戸が閉る。",
              "citation": {
                "source": "雪靈續記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また或る店屋では、木之助が中にはいって、ちょっと胡弓を弾いた瞬間、声の大きい旦那が、今日はごめんだ、と怒鳴りつけるような声で言ったので、木之助はびくっとして手をとめた。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "店屋さえもう戸が閉る。",
              "citation": {
                "source": "雪霊続記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに運送兼業の雑貨店や、やや小綺麗な店屋が飛び飛びに二、三軒はあった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "両側の店屋はどこも大戸をおろしているので、いざという場合にも駈け込むところがない。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあいだに、女房は右側の店屋の大戸を一生懸命に叩いた。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓家とも付かず、店屋とも付かない家で、表には腰高の障子をしめてあった。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "店屋なんかでだと嫌うらしいけど、宅なんかじゃ構わないから、なんなら、行くときにも、宅へ来て、宅の裏から出て行ったらよかない？",
              "citation": {
                "source": "街底の熔鉱炉",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災に焼けはしなかった土地と思うが、往来もあわただしく、落着きのない店屋が並んで、湿地か、大溝を埋めたかと見え、ぼくぼくと板を踏んで渡る処が多い。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつは大しくじりだ」「なに、そんなことはすぐに判りますよ」　店屋の灯がちらほら紅くなった往来で、親分と子分は別れた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "両側の店屋では皆あれあれと立ち騒いでいたが、一方の相手が朝日にひかる刃物を真向にかざしているので、迂闊に近寄ることも出来なかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしちっとのあいだ猶予して、わたくしに一杯飲ませてください」　あなた方にも飲ませるからと言って、無理に勧めてそこらの店屋へ案内したが、二人は鼻を掩うてはいらない。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "三丁目の角の店屋で、妻が履物を買って居る裡に、私は何時も買い馴れた夕刊新聞を買いました。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "店屋の前に、三人ばかり遊び居りたるが、三人の眼、忽ち風船玉に向つて凝る。",
              "citation": {
                "source": "風船玉",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらは小役人や御先手の組屋敷のあるところで、辻の片側には少しばかりの店屋があります。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼく、飛び下りて、あいつをとって、また飛び乗ってみせやうか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
