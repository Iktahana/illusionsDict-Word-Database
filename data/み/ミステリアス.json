        "examples": {
          "standard": [
            {
              "text": "彼女の過去はミステリアスで、誰も本当のことを知らなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "深夜の森には、ミステリアスな音が響き渡っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「彼のミステリアスな魅力に、みんな惹きつけられるんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "夢の起源は、彼等の學者が思惟するよりは、もつとミステリアスな詩人の表象と關聯してゐる。",
              "citation": {
                "source": "夢",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこのごろ好んで怪談の書物を読んでいるせいか、こういう場合には兎角その方へ引き付けて、ミステリアスに考える傾きがあるようです。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "賑かな世間から不意に韜晦して、行動を唯徒らに秘密にして見るだけでも、すでに一種のミステリアスな、ロマンチックな色彩を自分の生活に賦与することが出来ると思った。",
              "citation": {
                "source": "秘密",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
