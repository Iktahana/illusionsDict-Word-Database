        "examples": {
          "standard": [
            {
              "text": "アメリカのウィスコンシン州最大の都市はミルウォーキーだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はミルウォーキー出身のジャズミュージシャンで、地元では有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夏のミルウォーキーでは、毎年大規模な音楽フェスティバルが開催される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼が以前行ったこの市における宿泊は――それは彼同様に神秘的な禁断の知識に深く没頭した奇妙な老人を訪ねるためだったが――死と炎の中で終わったのであり、ミルウォーキーの自宅から彼をここに連れ戻したのは、何か病的な本能だったに違いない。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
