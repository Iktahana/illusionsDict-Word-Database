        "examples": {
          "standard": [
            {
              "text": "松茸やサンマなど、味覚の秋を象徴する食材が店頭に並び始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "温泉旅行に出かけて、味覚の秋を存分に満喫した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「味覚の秋ですね」と挨拶しながら、母は栗ご飯を炊いてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "味覚の秋、しかも香気の秋だ、紫蘇、柚子、橙、松茸。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "味覚の秋――春は視覚、夏は触覚、冬は聴覚のシーズンといへるやうに――早く松茸で一杯やりたいな。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあこんな所を味覚の秋とでもいうのであろう。",
              "citation": {
                "source": "室鰺",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
