[
  {
    "uuid": "d3beda18-c114-5f8d-a35a-4efca3d99945",
    "entry": "見える",
    "reading": {
      "primary": "みえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
