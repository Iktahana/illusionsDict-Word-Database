    "definitions": [
      {
        "index": 1,
        "gloss": "to look at each other",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お涌の眼と見合うと、男の子も少し赧くなった。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "他にも末尾がＥの四文字を考えたが、この状況に見合うものは他にない。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに見合うだけの豊かな鉱脈を見つけていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　グレグソンとレストレードは互いに見合う。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "兩の瓜は唯相隣して互に見合うて居るばかりでありました。",
              "citation": {
                "source": "白瓜と青瓜",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は五節句や年忌に、互いに顔を見合う親戚の中で、未婚の娘をあれかこれかと思い浮べてみた。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、そんな力仕事に見合うような代物は、今夜は払底してるけどな。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互いの顔を見合う日は最も気分のいい日で、私は病児の髪の伸びたのも苦にするほど何か楽しい母ごころに、不幸な濁流に抜手をきっているような、さなかの逼苦も柔らげられるのであった。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を見合うと、思わず笑い出した。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……」　中国人ボーイたちはきょとんとして、互の顔を見合うばかり。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて日本人はとわれわれは互に見合うのだが、このベルリンに匹敵する文化をどこから引き摺り出すのか、答えに詰った顔を撫で廻しているだけだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は黙って顔を見合う。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "山鹿には、以前気まずい思いをして、もう二度と口をきくまいと別れた鷺太郎ではあったけれど、この殺人事件という重大な衝動の前では、思わず口かずを重ねてしまってから、この前といい、今度といい、フト思い出したように、口を噤んでしまって、わざとらしく白い眼で見合う二人であった。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "額の生え際に細かい汗をにじませ、股のふくらみを折り曲げつつ、氷の面へせり登って来る千鶴子と見合う視線の閃めきも、冴え返っている白光の中ではただ一点の光りに見えるばかりである。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その目と私の目とふと見合うと、私は妙な不快な感じがした。",
              "citation": {
                "source": "遠野へ",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "車内はそれほど込みあっていなかったので、乗客は自由に互の顔を見合う余裕を充分持っていた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼と眼と、じっと見合うんだ。",
              "citation": {
                "source": "復讐",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まじまじと見合うお互の顔は、以前と少しの変りもありませんでした。",
              "citation": {
                "source": "旅だち",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々、友人といっしょに浮び上って、大急ぎで息を吸い込む変な顔を見合うことがあるが、それを笑っていられないほど忙しい。",
              "citation": {
                "source": "栄螺",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫婦の真の愛情というものは言葉で表現できないもので、目で見合う、心と心が一瞬に通じあい、とけあう。",
              "citation": {
                "source": "お奈良さま",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "云うまでもなく二人の仲が悪いから、酔っ払って事が起きては面倒だというので、木村が南正面なら升田は東正面に当る位置に、間に数名の人をはさんで遠く離れているばかりでなく、顔を見合うこともできないような位置に二人の席を定めておいた。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、気高い、さびしい姉は、やさしく妹をなぐさめて、「たとえ、遠く離れることがあっても、わたしたちは、毎晩顔を見合うことができれば、それで満足するであろう。",
              "citation": {
                "source": "王さまの感心された話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハバトフは肩を縮めて冷笑し、ニキタと見合う。",
              "citation": {
                "source": "六号室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "文次と安、思わず眼を見合う、二人のほか誰ひとりいないこの部屋である。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "六ヶ月お待ちくだされ、あなたの忍耐に見合うだけのものをご覧にいれてみせますよ。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちが今日見合うよろこびの裡には何と多くのものがこもっていることでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の知る下宿はいつもひっそりと薄暗くて、同宿人たちの交際もなく、彼らはすべて正面から顔をはっきりと見合うことすらないみたいだった。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互い同士にその面倒を見合う者もあろうし、中には自分の手で自分を罰する者もあるでしょう……その上、いろいろと公けに悔悟の意を表明するようなこともやるから――美しくって教訓的な効果がありますよ。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、報酬に見合う演技をしているだけなのに。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　互に見合うこと。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
