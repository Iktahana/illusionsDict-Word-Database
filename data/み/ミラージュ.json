          "literary": [
            {
              "text": "ミラージュも見えた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフリカのほうにははるかに兀とした岩山の懸崖が見え、そのはずれのほうはミラージュで浮き上がって見えた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂ミラージュとか蜃気楼とかって奴さ。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕闇は谷より湧いて、見るまに淡く、美しいミラージュは消えてゆく、私は眼を閉じて、静かにクーライエンを聞いた。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
