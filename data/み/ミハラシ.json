        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あなた一所に行きます』と言って、ヘルンが妻を連れ出す所はたいてい多くは寂しい静閑の所であり、寺院の墓地や、邸の空庭や、小高い見晴らしの丘などであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓄音機と云へば、宿へ着いた時につい隣りの見晴らしの縁側に旅行用蓄音機を据ゑて、色々な一粒選りの洋樂のレコードをかけてゐる家族連の客があつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "團體の爲に一時小さな室に追ひやられた埋合せに、今度はがらあきになつた三階の一番廣く見晴らしのいゝ上等の室に移され、地面迄數へると五階の窓下を、淙々として流れる溪流の水音と、窓外の高杉の梢にしみ入る山雨の音を聞きながら此處へ來てはじめての安らかな眠りに落ちて行つた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、見晴らしはどこへ行っても、大きな屋根の影絵があり、夕焼空に澄んだ梢があった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い方の見晴らしへ出た。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、昔の人は、見晴らしのいい丘の頂に建てられた小屋の中に雑居して、四方の窓から自由に外をながめていた。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな川に臨んだ見晴らしのいいきれいな部屋で、川向こうに見える山は郷里の記憶に親しいあの山である。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "転じて新井別邸の前、寄席のまえを過ぎて、見晴らし山というのに登った。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の頂上は俗に見晴らし富士と呼んで、富士を望むによろしいと聞いたので、細い山路をたどってゆくと、裳にまつわる萩や芒がおどろに乱れて、露の多いのに堪えられなかった。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに、千日前｜界隈の見晴らしの利く建物の上から、はるか東の方を、北より順に高津の高台、生玉の高台、夕陽丘の高台と見て行けば、何百年の昔からの静けさをしんと底にたたへた鬱蒼たる緑の色が、煙と埃に濁つた大気の中になほ失はれずにそこにあることがうなづかれよう。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭苦しい銀子の家も、二階の見晴らしがよくなり、雨のふる春の日などは緑の髪に似た柳が煙り、残りの浅黄桜が、行く春の哀愁を唆るのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋はたっぷりした八畳で、建具ががたがたで畳も汚かったが、見晴らしのいいので助かっていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お安婆さんの茶店は、鉄道の交叉点のガードの横から、海を見晴らしたところにあった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥太郎翁の全盛時代、芸妓など連れて来て桃林の見晴らしの莚を張った名残りだそうです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに気が置けなくて……それにまあいつも晴々した見晴らしで御座いますこと……オヤ坊ちゃんおとなしですこと……一寸｜入らっしゃい、抱っこしましょう」　と口では云いながら、内心実はつまらない。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "幟棹は墓地の最南端の、麦畑や村落を見晴らした処に樹てられていた。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "川を見晴らした中二階で、鯉こくと鯰のすっぽん煮か何かを喰わされて、根が悪党でもない長助は、何もかも正直に話してしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "今据わつてゐるのは、東の方一面に海を見晴らした、六畳の居間である。",
              "citation": {
                "source": "妄想",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたも立ち会つて話を聞いて下さい」　さう云つて、太田父子は、待合室を通り抜け、病室の廊下を通り抜けて、川を見晴らしてゐる医者の家の居間に入つて行つた。",
              "citation": {
                "source": "万福追想",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼も大に、胆も大にして、見晴らしの良い山上の岩頭から、国の隅々までを見渡す気概が無くてはならない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見晴らしから言つても、綺麗なことから言つても、あの海岸では、恐らく一番好い家だらう。",
              "citation": {
                "source": "青い風",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "見晴らしの利く木蔭などを見つけては幾度となく腰をおろした。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに見晴らしのいいのが、ふたりもおるじゃねえですかよ」「大きな声を出すな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京市の郊外、又は東京市内のちょっとした横町、又は坂道や高台の近くの見晴らしのいい処に、宿屋ともつかず下宿屋ともつかぬ家がよくある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の頂上は俗に見晴らし富士と呼んで、富士を望むのによろしいと聞いたので、細い山路をたどってゆくと、裳にまつわる萩や芒がおどろに乱れて、露の多いのに堪えられなかった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべろくろく寝ませんので、わたくしはなんだか頭が重いようでございましたが、座敷の窓から川を見晴らして、涼しい朝風にそよそよ吹かれていますと、次第に気分もはっきりとなって来ました。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "午に近い頃に目的地へゆき着きましたが、横田君の話で想像していたのとは余ほど違っていて、なるほど大木もありますが、昼でも薄暗いというような幽暗な場所ではなく、むしろ見晴らしのいい、明るい気分のところでした。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "多津吉の同伴はこの岨路を、みはらしの広場下りに駆出した。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙のあとの森も屋根も、市街はしっとりと露を打って、みはらしの樹の間の人影は、毛氈とともに仄暗い。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "なめくぢは垣根を這ひあがりみはらしの方から生あつたかい潮みづがにほつてくる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
