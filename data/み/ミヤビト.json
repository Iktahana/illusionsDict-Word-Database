    "definitions": [
      {
        "index": 1,
        "gloss": "(noble) courtier",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "宇都野さんの歌はどう見ても大宮人の歌ではない、何処かしら東夷とでも云いたいような処があると私は思う。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、宮人を今は「みやびと」と読むけれども昔は「みやひと」である。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『古事記』の中に宮人という語は清音の仮名で書いてあって、濁音の仮名で書いてあるものは一つもない。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "傳へ聞く、漢の武帝の宮人麗娟、年はじめて十四。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "魏の武帝の宮人は眉を調ふるに青黛を以つてす、いづれも粧ふに不可とせず。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王今は帝たり、宮人｜内侍を詰りて、建文帝の所在を問いたもうに、皆｜馬皇后の死したまえるところを指して応う。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "林間に酒こそ暖めませぬが、大宮人の風流。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "博学深識の従七位、花咲く霧に烏帽子は、大宮人の風情がある。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮人のはかまのすそのひもについた小さな鈴、たとえばその鈴が落ちたほどの小さなことに、宮人も村の人も、そんなに騒ぐにはおよびますまい」　こういう意味の歌を歌いながら穴穂王のご前に出て来て、「もしあなたさま、軽皇子さまならわざわざお攻めになりますには及びません。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉幕府と元寇　平家の衰亡は、武家にして、藤原氏を学んで、大宮人としての弊害を承け継ぐと共に、土地を根拠とする武士自身の生活を忘れたためである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "参列の諸員は皆小さい大宮人の美に感激の涙をこぼしていた。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山の風景に十分愛着を感じているのですが、陛下に御心配をおかけ申すのももったいないことですから、またもう一度、この花の咲いているうちに参りましょう、宮人に行きて語らん山ざくら風よりさきに来ても見るべく」　歌の発声も態度もみごとな源氏であった。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつとなく大宮人の恋しきに桜かざしし今日も来にけり　と源氏は歌った。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "太政大臣の猶子になっていて、その一族がすばらしい背景を作っているはなやかな後宮人であった。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いがけぬことで怪しがる顔を見て、「天にます豊岡姫の宮人もわが志すしめを忘るな『みづがきの』（久しき世より思ひ初めてき）」　と言ったが、藪から棒ということのようである。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "『南史』に、〈梁武帝元洲苑に幸し、大蛇道に盤屈し、群小蛇これを繞るを見る、みな黒色、宮人曰く恐らくこれ銭竜ならん、帝銭十万貫を以て蛇処を鎮め、以てこれを厭す〉、これ支那でも蛇を銭の神としたのだ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通ならば、もはや五月も終りに近く、雲の縫ひ目もところどころ綻びそめ、山の裾なども見えそめ、時に由つては明るい月影が野にも山にもさしわたつて、青空が人の顏にも衣にも、車にも、または騎馬の侍にも、調度掛を携へた大宮人にも、ところどころ崩れた築土にも快よく映るのであるのに、またしても雨、雨、雨。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためでもあるが、三人は大宮人の習慣を持ちつづけて、なすこともなく、毎日暮していた。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の女　　第二の女　　第三の女　　非番の老近侍　　帝の供人同宮人数多　　法王の供人数多及び弟子達　　イタリー、サレルノの農夫の老夫婦　　人民数多、及び不信心な遊び者　　　　第一幕　　　　　第一場　　　　場所　　ヘンリー王の城内の裏手景　近侍達の住んで居る長屋体の建物の中央にある広場。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚い髪を左右にピッタリとかきつけて心持下を向く法王の後からも、先に進む人と同じ様子に続いて沢山の宮人がついて行く。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「定めし、女の宮人が毒試をして差上げてゐたのでせうよ。",
              "citation": {
                "source": "滑川畔にて",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮人は豊の明りにいそぐ今日日かげも知らで暮らしつるかな　今年をこんなふうに隠忍してお通しになった院は、もう次の春になれば出家を実現させてよいわけであるとその用意を少しずつ始めようとされるのであったが、物哀れなお気持ちばかりがされた。",
              "citation": {
                "source": "源氏物語",
                "author": "まぼろし",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐の詩で陵園を守る後宮人を歌ったものである。",
              "citation": {
                "source": "源氏物語",
                "author": "手習",
                "note": "青空文庫"
              }
            },
            {
              "text": "春風珠簾を吹いて、銀鉤を蕩するの処、蛾眉の宮人の衣裙を洗ふを見る、月事も亦風流ならずや。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "作詩術　　　　　　　　――同上――　二人の宮人は彼の前に、石竹の花の色に似た、絹の屏風を開いてゐる。",
              "citation": {
                "source": "パステルの龍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "大宮人の感懐が、一番山の奥の田舎者にしみ込んで残っていたんだから、凄いですよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "集った宮人たちには、鹿の肉片と、松葉で造った麁酒や※の酒が配られ、大夫や使部には、和稲から作った諸白酒が与えられた。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　橘と榊の植った庭園の白洲を包んで、篝火が赤々と燃え上ると、不弥の宮人たちは各々手に数枚の柏の葉を持って白洲の中へ集って来た。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮人たちは歓呼の声を上げながら、二人を目がけて柏の葉を投げた。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは「みやびと」といっておったのを清音の仮名で書いたのではなく、「みやひと」と言っておったから清音の字で書いたのである。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
