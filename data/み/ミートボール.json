        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "直径四十五センチの大皿に、ミートボールとスパゲッティが土堤をつくって出てくる。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "罐詰のシチュウとミートボールで簡単な夕食をすませると、久美子は湖のそばへ一人で散歩に出た。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "罐詰のシチュウとミートボール……昨夜、ロッジで夕食に出たのと、おなじものだった。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタアジュとスパゲティ・ミートボール、冷チキン。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴木を誘ひ、ニューグランドへ、ポタージュと、卵かけあほり飯、スウェディシュのミートボール、アイスクリーム。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日明後日うまいもの食へまいからと、トマトスープ、白魚フライ、ミートボールに苺食って東京駅へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから堀井とニューグランドへ行き、トマトクリームスープに、ミートボール、スパゲティ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "新橋駅で別れ、ニューグランドへ、トマトクリーム、犢のスタッフ、ミートボールカレーライス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミートボール入りスープと、チキンのスパゲティ添、コーヒー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
