    "definitions": [
      {
        "index": 1,
        "gloss": "to see (someone) off",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "驛路に見送る人人よ悲しみの底に齒がみしつつ告別の傷みに破る勿れ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹屋の姐さんは吃驚した半身を店から出せば、筆屋の老翁は二三歩往來へ進み出て、共に引き行く人浪の趾を見送る事、少時焉たり。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "韋駄天を叱する勢いよく松が端に馳け付くれば旅立つ人見送る人｜人足船頭ののゝしる声々。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不審相に見送るお絹。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "見送る呆然たるお絹。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "見送る三次がお絹に、Ｔ「そーれ見なせえお絹さん」　と言って、Ｔ「俺と一緒に居るとお前迄があの通りやくざ者にされちまう」　と言うのを、　始終無言で聞いていたお絹が、　袂で隠して居た十手を三次に示す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の気なしに仲蔵がその男見送ると、　蛇の目傘の浪人者（大吉）が跣足で走り去る（所謂定九郎の恰好よろしく）。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "後見送る大吉の側へ雪枝が来て礼を述べる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "投げた烟草の一点の火が輪をかいて飛んで行くのを見送る目には、この外の景色が這入った。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてペピイとクリストフとはいつもおぢいさんと小さい娘との後影が木立の向うに隠れるのを見送る。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもおしかは十月の初めに清三が健康を恢復して上京するのを見送ると、自分が助かったような思いでほっとした。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして百舌鳥の飛び立ってゆくあとを茫然と見送るさまは、すこぶる妙で、この子供には空を自由に飛ぶ鳥がよほど不思議らしく思われました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "物陰から現れた右門と伝六舟を見送る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）７７＝（Ｆ・Ｉ）宿の表　朝、二階の手すりから浪之助とお類が見送る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）77＝（Ｆ・Ｉ）宿の表　朝、二階の手すりから浪之助とお類が見送る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜警はそれを見送ると、いつものようにつまらなそうに再び杖を鳴らしながら露路を立ち去ってしまった。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨て路を教へて後、件の親仁つく／″＼と二人を見送る。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "罷違うて旧道を皆｜歩行いても怪しゅうはあるまい、こういう時候じゃ、狼の旬でもなく、魑魅魍魎の汐さきでもない、ままよ、と思うて、見送ると早や深切な百姓の姿も見えぬ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見送ると小さくなって、一座の大山の背後へかくれたと思うと、油旱の焼けるような空に、その山の巓から、すくすくと雲が出た、滝の音も静まるばかり殷々として雷の響。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　高野聖はこのことについて、あえて別に註して教を与えはしなかったが、翌朝｜袂を分って、雪中山越にかかるのを、名残惜しく見送ると、ちらちらと雪の降るなかを次第に高く坂道を上る聖の姿、あたかも雲に駕して行くように見えたのである。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蔭に、遠い灯のちらりとするのを背後にして、お納戸色の薄い衣で、ひたと板戸に身を寄せて、今出て行った祖母の背後影を、凝と見送る状に彳んだ婦がある。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお正も吃驚して見送る。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めにヒロインとその保護者がこの行列を見送る場面ではヒロインと観客は静止していて行列はその向こう側を横に通過する。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "千歳は、今度も何か慶四郎の独り合点でこういう挙動をするのだろうと曳かれるままに連れられて表へ出たが、「さようなら、お気をつけ遊ばして」　と言って見送る女中達に千歳は慶四郎の露骨な振舞いが少しきまり悪かった。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘、いつまでも阿難の姿を見送る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一同退場　医師これを見送る。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と母君の纎手に依りすがると春枝夫人は凛々しとはいひ、女心のそゞろに哀を催して、愁然と見送る良人の行方、月は白晝のやうに明だが、小蒸※船の形は次第々々に朧になつて、殘る煙のみぞ長き名殘を留めた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "その影も、灯も、犬が三匹ばかり、まごまご殿しながらついて、川端の酸漿提灯の中へぞろぞろと黒くなって紛れたあとは、彳んで見送る井菊屋の人たちばかり。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏みおくるる者は斬るぞ」　鐙の革も断ち切れんばかり鞍腰上げて絶叫した。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
