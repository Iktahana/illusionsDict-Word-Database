[
  {
    "uuid": "c0c7c52b-88f1-5d67-bbb0-0af70880d83a",
    "entry": "御台",
    "reading": {
      "primary": "みだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
