    "definitions": [
      {
        "index": 1,
        "gloss": "in contrast to (one's, its) appearance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "見かけによらず、神經の強い女だと云ふことは、コツプに注いだ冷泉の臭ひがぷんと鼻へ來たので、それから決してそれを口にしようとしないのででも分つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "話から察するに、見かけによらず、たいへんゆゆしき問題となりそうです。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "とくと考えておけ」　兄は見かけによらず解った人であった。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "見かけによらず如才ない老爺は紅葉を娘の前へだし、これごろうじろ、この紅葉の美しさ、お客さまがぜひお嬢さんへのおみやげにって、大首おって折ったのぞなどいう。",
              "citation": {
                "source": "河口湖",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえが敷島の道に心得があるたア、見かけによらず風流人だよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "見かけによらずなかなか学者でござるぞ。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "見かけによらず、なかなかの軍師じゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は見かけによらず、よく物を見通しているよ」「水戸。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿介は今年はじめてだが、これは見かけによらず足にも手にも力のいる仕事であつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、さよは、一目で、彼の注意は見かけによらず、怠りなく自分に向って注がれているのを直覚した。",
              "citation": {
                "source": "心の河",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、この男は見かけによらず人が悪くて、小才を弄するのである。",
              "citation": {
                "source": "日本三文オペラ",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの交遊関係にも斯んな人物の一人二人はゐるものであるが、さて話してみれば見かけによらず物分りもよく、寛大で、寧ろ他人の好意に感動し易いと思はれるほど盲信的で、おまけに絶えず温い心を秘かに他人へ燃しつづけてゐたりする。",
              "citation": {
                "source": "姦淫に寄す",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "見かけによらず、とんだインチキものだ。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までの場面がすべて倫敦なのでも判るように、こういうことにかけては、見かけによらず、英吉利のほうがよほど突進的で、したがって事件に富んでいる。",
              "citation": {
                "source": "踊る地平線",
                "author": "白い謝肉祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "見かけによらず、日本は人材の国だ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見かけによらず腕がないね。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦和から大宮、武蔵の国の一の宮、氷川大明神へ参詣して、またまた米友をおどろかせたのは、道庵先生が見かけによらず敬神家で、いとねんごろに参拝祈願する体を見て驚嘆しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "（幾分、優しく）お前も、見かけによらず、大胆だね。",
              "citation": {
                "source": "秘密の代償",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、みんなが堅い皮を破って、肉を食べようとしますと、そのかには、まったく見かけによらず、中には肉もなんにも入っていずに、からっぽになっているやせたかにでありました。",
              "citation": {
                "source": "大きなかに",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "辰つアんは、二人をその中へ坐らせて、「どうです、見かけによらずしやんとした家でせう。",
              "citation": {
                "source": "天國の記録",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "が見かけによらず声は優しかった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怨霊首人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは見かけによらず凄い腕だなあ。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この認識も滑稽千万であるが、更に頻繁な手紙や訪問などの懇願が、自分を動かすのに有力だと考へる彼の神経も見かけによらず稀代の鈍感なものである。",
              "citation": {
                "source": "或る文学青年像",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "梯梧は大柄の木であるし、見るからに、筋肉のりゅうりゅうとした腕みたいな枝々を、四方八方に伸ばしていて、その木質は、見かけによらずもろいものなのだ。",
              "citation": {
                "source": "梯梧の花",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲助唄を歌わせれば、見かけによらず、行く雲を止めるの妙音を発する者さえある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤ待てよ、――羽を持った仲間にだって、それそれ、わが雷鳥さんという、これはやさしい見かけによらず、雪が降ろうが、氷が張ろうが、寒かろうが、冷たかろうが、何が何と言おうが……ガンとして、里へは下りない、無類の一国者もあるのだから、頼もしかろう。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、一方優しく華奢なクララは、見かけによらず剛毅であった。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "見かけによらず、その辺の海の底は浅かった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "みかけによらずの軽いキヤベツ一箇。",
              "citation": {
                "source": "愛する人達",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、あの造麻呂と云う爺はみかけによらず、大変な胴慾者ですから、娘の幸福などとても考えてやるような男ではないのです。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
