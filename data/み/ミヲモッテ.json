    "definitions": [
      {
        "index": 1,
        "gloss": "with one's own body",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ＫＳ倶楽部の土間は、命からがら、身をもって逃がれて来た人々で埋まっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "声に応じて少年はかッぱと刎ね起きて押被さり、身をもってお雪を庇う。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "拓が身をもってお雪と地位をかえたとすれば、直ちに我を棄てて渠に愛を移すのは、世に最も公平なことであると思って、満身の血が冷くなった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真砂町、と聞返すと斉しく、屹とその座に目を注いだが、驚破と謂わば身をもって、影をも守らん意気組であった。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと悟空に近づき、いかに彼の荒さが神経にこたえようとも、どんどん叱られ殴られ罵られ、こちらからも罵り返して、身をもってあの猿からすべてを学び取らねばならぬ。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "お通は止むなく死力を出して、瞬時伝内とすまいしが、風にも堪えざるかよわき婦人の、憂にやせたる身をもって、いかで健腕に敵し得べき。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあなるたけ主人の気のやすまるよう遠のいて、身辺の平和を守るか（この際｜扶養の責任あらば、それだけは物質だけでも果すべし）、さもなくば、妻は身をもって円満に尽し、親、親類に夫の折合い悪しき部分を補うべし。",
              "citation": {
                "source": "良人教育十四種",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」この一言の勢いは、抜き身をもってはいって来た強盗ででもあるかのようであった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "君正しからず一国正しからずと知らば、潔く身を退くべきに、身の程をも計らず、区々たる一身をもって一国の淫婚を正そうとした。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "苛刻な現実精神をかの獰猛な妖怪から、身をもって学んだわけだ、と、悟浄は顫えながら考えた。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　紀久子はその銃身をもって蔦代を押さえつけた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "列座の者の中から、「弱輩の身をもって推参じゃ、控えたらよかろう」と言ったものがある。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大切の御身をもって、みだりに剣戟を弄ばれ家臣の者を傷つけられては、公儀に聞えても容易ならぬ儀でござる。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "触は身をもっては覚れない。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにかは知らぬが、この珍事容易ならぬできごとだなということを早くも見てとりましたから、それには答えないで、さっと立ち上がると、とっさにまず身をもって家光公をかばったもので、同時にことばを強めながら、せきたてるように腰元たちへ下知を与えました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しゃがるんだ、なんで手荒なまねしゃがるんだ」　ついと横からしゃきり出て、景気のいい啖呵をきりながら、身をもって小娘をかばったのは、江戸っ子中の江戸っ子をもって任ずる伝あにいです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "）どういう風に、お互が繋がり合っているか、ということが身をもって知らされた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが虎穴に入らずんば虎児を得ずという一かばちかの気持ちで、降って湧いた奇妙なアバンチュールに身をもってあたってみることにした。",
              "citation": {
                "source": "謎の女",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "行親　おん謹みの身をもって、素性も得知れぬ賤しの女子どもを、おん側近う召されしは……。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪の中で「日本紀元二千三百二年、傾城塚爆発発掘、教主身をもってわずかに逃がれ、犠牲の処女大半焼死、イスラエル教覆滅し、珍器財宝没収されおわんぬ」　西教要覧の記事である。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで城之介はどうしたかというに、すなわち身をもって逃がれたのであるが、その間にちょっといきさつがあった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川上機関大尉に代り、身をもってこの大任務を遂行したのであった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "身をもって爆弾庫にとびこんだあの水兵を、皆して褒めてやってくれ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、その人情の波頭が一歩、或は数歩高まり、前進したところの形であり、また人情が一つの社会的桎梏の型に堕した時、それを身をもって破ろうとする人間の本来的感情であると思う。",
              "citation": {
                "source": "パァル・バックの作風その他",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日に於て、自分の最上の努力、最上の献身をもって従事すべき仕事としての自覚、誠実が不足している。",
              "citation": {
                "source": "ヒューマニズムへの道",
                "author": "――文芸時評――",
                "note": "青空文庫"
              }
            },
            {
              "text": "バックは中国の民衆生活の日常の現実に身をもってふれている。",
              "citation": {
                "source": "若い婦人のための書棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史的にも若々しかった彼らのある者は、性急にそのギャップを自分たちの身をもって埋めようとした。",
              "citation": {
                "source": "新しい一夫一婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同志小林は「組織活動と創作活動の統一」の課題に対し身をもって「文学を党のもの」とし、最も高度なボルシェヴィキ的解答を与えたのである。",
              "citation": {
                "source": "同志小林の業績の評価に寄せて",
                "author": "――誤れる評価との闘争を通じて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェルヌイシェフスキイの「何をなすべきか」のように、身をもって六〇年代を生きぬいて書いたのではなかった。",
              "citation": {
                "source": "ツルゲーネフの生きかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "七〇年代、八〇年代といえばロシアは「人民の中へ」の運動から「人民の意志」党などの活動へ移った時であり、有名なヴェラ・フィグネルなどを先頭に夥しい数で社会の各層の若い婦人が解放運動に身をもって投じた時代である。",
              "citation": {
                "source": "ツルゲーネフの生きかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
