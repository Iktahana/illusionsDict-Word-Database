        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その春、私が連れて行かれたその狂院に咲き満ちて居た桜の花のおびただしさ、海か密雲に対するように始め私は茫漠として美感にうたれて居るだけでした。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり浅間が爆発したのだろうと思ってすぐにホテルの西側の屋上露台へ出て浅間のほうをながめたがあいにく山頂には密雲のヴェールがひっかかっていて何も見えない。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度洋中の氣ぎて眞の闇――勿論先刻までは新月の微かな光は天の奈邊にか認められたのであらうが、今はそれさへ天涯の彼方に落ちて、見渡す限り黒暗々たる海の面、たゞ密雲の絶間を洩れたる星の光の一二｜點が覺束なくも浪に反射して居るのみである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　あくれば凱旋祭の当日、人々が案じに案じたる天候は意外にもおだやかに、東雲より密雲破れて日光を洩し候が、午前に到りて晴れ、昼少しすぐるより天晴なる快晴となり澄し候。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども連日の東風弥々吹き募り、六月土用に入りても密雲冪々として天候朦々晴天白日を見る事殆ど稀なり（中略）毎日朝夕の冷気強く六月土用中に綿入を着用せり、夜は殊に冷にして七月｜佞武多（作者註。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "両機は一千｜米の高度を保ちながら雁行していたが、箱根の上空にさしかかったところで、密雲のために視界を遮られたうえに、エアーポケットに入って機体が烈しい勢いで落下した。",
              "citation": {
                "source": "空中に消えた兵曹",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い雹を降らせる密雲が北の方からやって来ると言うのです。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に泰西文明の思想界に於ける密雲は一たび彼の上に簇まりて、而して後八方に散じたり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "このわずか一月ばかりの幸福な生活の地平線に、たちまち黒い密雲の立ち掩うて来るのを感じた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "密雲が北西の方から押し寄せて来て、その雲の投げたあらい触角が、月の面を横ぎって流れていた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜しいかなその夜も數日來打ち續いた雨催ひの空で、低く垂れた密雲を仰ぐのみであつた。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "明けても暮れても眞白な密雲のなかに、殆んど人の聲を聞かず顏を見ずに過してゐた。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "四隣には密雲が重く垂れ、稲妻に羅星の閃く戦国の夜は、いつになつて明けるやら、見定めもつかなかつたが、忽として頭をもたげた項羽の一睨によつて、西楚の曙は闇の帷を切り落されたのである。",
              "citation": {
                "source": "悲しき項羽",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "密雲脚下を封して眺望なし。",
              "citation": {
                "source": "春の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋の背後は直ぐ深い大きな溪で、いつの間にか此處らに薄らいだ霧は、その溪一杯に密雲となつて眞白に流れ込んでゐる。",
              "citation": {
                "source": "比叡山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋のうしろは直ぐ深い大きな渓で、いつの間にか此処らに薄らいだ霧がその渓いっぱいに密雲となって真白に流れ込んでいる。",
              "citation": {
                "source": "青年僧と叡山の老爺",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭へ降りて見ると、夕暮から雲の多かった空は、すっかり密雲に閉されて月の所在さえわからなかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "太平洋を圧している、密雲に閉ざされたまゝ、日は落ちてしまった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆心中に疾しくて、とかくに殺戮したれども、醜行｜已に為し了はり、密雲漸く散ずれば、積みかさなれる屍より階かけて、紅流れ、そのうしろ楼門｜聳ゆ、巍然として鬱たり。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆心中に疾しくて、とかくに殺戮したれども、醜行已に為し了はり、密雲漸く散ずれば、積みかさなれる屍より階かけて、紅流れ、そのうしろ楼門聳ゆ、巍然として鬱たり。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏訳詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆心中に疾しくて、とかくに殺戮したれども、醜行｜已に爲し了はり、密雲漸く散ずれば、積みかさなれる屍より階かけて、紅流れ、そのうしろ樓門聳ゆ、巍然として鬱たり。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ春は浅く、そしてその日は曇っていて、西空に密雲がたれこみ、日が早く暮れかけていた。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "太平洋を圧してゐる、密雲に閉ざされたまゝ、日は落ちてしまつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして三十分程ちらりちらりと月の顔を見ることが出来たと思うと、あとは又元のように密雲に蔽われてしまう筈である。",
              "citation": {
                "source": "空中墳墓",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は直ぐさま眼をレンズにつけたが、惜しむや数秒のちがいで、かねて計算通りに襲い来った密雲で、視野はすっかり閉じられてしまった。",
              "citation": {
                "source": "空中墳墓",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、過去からの影はどんなに深い密雲で若々しい精神の行手を遮り、その方向をかえ、或は中途で萎靡させたかという悲痛な歌の曲節も同じく近代日本文学のあらゆる段階の消長とともに響いているのである。",
              "citation": {
                "source": "若き精神の成長を描く文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "密雲の空は容易に明けようともせず、爆音はつぎつぎにききとれた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "空にはもはや密雲はなく、水野の上を濡れた湿っぽい風が漂うばかり。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗灰色の密雲は、みっしりと空を罩め、褪色した水彩画のようなあたりには「豊さ」というものは寸分も見出せなかった。",
              "citation": {
                "source": "自殺",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
