    "definitions": [
      {
        "index": 1,
        "gloss": "everyday articles which have come to be regarded as folk art",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "誰もが使う日常の器具であるからあるいはこれを民具と呼んでもよい。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　蓑は今も重要な民具の一つである。",
              "citation": {
                "source": "蓑のこと",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の時、雪の時、外に出る者、外で働く者に、なくてはならない民具である。",
              "citation": {
                "source": "蓑のこと",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の民具を語るよい例となるでありましょう。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じんべい」と呼ぶ鼻緒入の藁沓や、「にぞ」と呼ぶ蒲製の帽子や、また「たす」といっている葡萄皮で網代編にした背負袋や、いずれも民具として出来もよく形もよく、忘れ難いものであります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒物屋は北の国では民具の陳列場ともいえましょう。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "終りにもう一つこの辺の民具として、他にないものの一つに、古裂のみで作った背中当があります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓑だとか雪沓だとか、背中当とか背負袋とか、そういう民具に立派な手の技を示します。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もが使ふ日常の器具であるから或は之を民具と呼んでもよい。",
              "citation": {
                "source": "雑器の美",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
