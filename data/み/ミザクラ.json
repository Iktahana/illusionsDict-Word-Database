      {
        "index": 1,
        "gloss": "cherry tree with edible fruit (esp. sweet cherry or Nanking cherry)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭に植えた実桜が、今年はたくさんの実をつけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "実桜の甘酸っぱい実は、鳥たちのごちそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、よく実桜の木に登って実を食べたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "新らしく植付けられた林檎や葡萄や実桜の苗は何れも面白いやうにずん／＼生長びて行つた。",
              "citation": {
                "source": "新らしき祖先",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十人ばかりの日傭人がそこへ入りこんで、林檎や葡萄や実桜の樹を片つぱしから伐り倒してゐるのだ。",
              "citation": {
                "source": "新らしき祖先",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は斗満に帰ってから、実桜の苗二本送って呉れた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実桜や古茅はこぶ宮の修理　　　　邑姿「修理」は「シュリ」と詰めて読むのであろうか。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の桜の実は、花と違って多くの場合閑却された形であるが、この句は実桜にふさわしい趣を捉えている。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実桜林は私たちのチルドレンス・コウナアであった。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
