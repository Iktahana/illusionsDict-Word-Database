    },
    "definitions": [
      {
        "index": 1,
        "gloss": "visit (to someone affected by illness or misfortune)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "危篤な病人の枕もとへはおおぜいの見舞い人が詰めかける。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺結核でそこに転地しているある人を見舞いに行って一晩泊まった時がちょうど旧暦の盆の幾日かであった。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この会のエキスペジションで彼はインディアンの国土を見舞い、シカゴで始めて電車を見、またマイケルソンやローランドと親しく言葉を交わし、またエジソンの有名な昼寝を驚かした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなある日吉田は大阪でラジオ屋の店を開いている末の弟の見舞いをうけた。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五歳になる雪子が姉につれられて病院へ見舞いに来た。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠られぬままにいろいろな事を考えた中にも、Ｎ先生が病気重態という報知を受けて見舞いに行った時の事を思い出した。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府はただちに罹災者に対してお見舞いを差上げている筈だし、公債や保険やらをも簡単にお金にかえてあげているようだ。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆不精の私は、未だにお礼状も何も差し上げていない仕末ですが、こないだの三宅島爆発では、さぞ難儀をなさったろうと思いながら、これまたれいの筆不精でお見舞い状も差し上げず、東京の作家というものは、ずいぶん義理知らずだと王様も呆れていらっしゃるだろうと思います。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人に優しい見舞いの言葉をかけ、そうしてお金をそっと差し出す。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はともあれトックにも御見舞い伺わねばならぬ処へ、こげな御念の入りました御挨拶を受けましては、床の下へ這い込みたいくらいで……生憎、床の下が御座いませんが……」　半三郎は静かに顔を上げた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども僕は桂の生活の模様から察して、三百里外の故郷へ往復することのとうてい、いうべくして行なうべからざるを思い、べつに気にも留めず、帰れたら一度帰って父母を見舞いたまえくらいの軽い挨拶をしておいた。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分に不幸見舞いに行って笑い出した事や、本膳をふるまわれて食っている間にふき出したような話をする人も二人や三人はあった。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時、火事で焼け出されて、神社の森の中に持ち出した家財を番している中年の婦人が、見舞いの人々と話しながら、腹の底からさもおかしそうに笑いこけているのを、相手のほうでは驚き怪しむような表情をして見つめているのを見かけた事もある。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見舞いの手紙も一度も出した事はない。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへ見舞い状を出す先もないと思う事がさびしかった。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ生きていてももう再び会う事があるかどうかもわからず、通り一ぺんの年賀や暑中見舞い以外に交通もない人は、結局は思い出の国の人々であるにもかかわらず、その死のしらせはやはり桐の一葉のさびしさをもつものである。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸川畔の花屋でベコニアの鉢を求めてお見舞いに行ったときは、もう面会を許されなかった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉ちゃん、お見舞いに来たよ。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "室子が此間じゅう、一寸風邪をひいたと昨日｜言伝けたのを口実に、蓑吉は早速母親にせがんで、見舞いに来さして貰ったのだった。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉ちゃんはもう、とっくに風邪なおって起きちまってるのに見舞いに来るなんて」「でも、来てやったんだい」　蓑吉は、こまごましたおもちゃを並べるのに余念が無い。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ、姉ちゃんのお見舞いに呉れたのね、自分で買って来たの」「ああ」「それを買うおあし、お母さんにいくら貰ったの」「二円だい」　女中がきゅうきゅう笑った。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし釈尊の弟子ともあろうものが、ただ、形式の見舞いの使者では物足らなくあります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうわけで十大弟子は自らその資格なしと知って、見舞いの使者を辞退しました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お千世のためには、内の様子も見て置きたい、と菊家へ連れようとした気を替えて、清葉はお孝を見舞いに行くのに、鮨というのも狂乱の美人、附属ものの笹の気が悪い。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「祭り延ばすから早くよくなれ」本家のおばあさんが見舞いに行って、その子の頭をなでて言いました。",
              "citation": {
                "source": "ざしき童子のはなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがほかの子供らは、いままで祭りを延ばされたり、鉛の兎を見舞いにとられたりしたので、なんともおもしろくなくてたまりませんでした。",
              "citation": {
                "source": "ざしき童子のはなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕もとには見舞いの電報や、たくさんの手紙がありました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度病院へ取って返して、病人本間の様子を見舞い、身支度して出直さんと本郷に帰りけるに、早警官等は引取りつ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の内は宰八なり、誰か、時々お伺いはいたしますが、この頃は気怯れがして、それさえ不沙汰がちじゃに因って、私によくお見舞い申してくれ、と云う、くれぐれもその託でございました。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは恰かも青い色が青い色であり、赤い色が赤い色であるやうに、夢をみようともみまいともしないで私は夢みてゐるのである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
