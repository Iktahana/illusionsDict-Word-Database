[
  {
    "uuid": "f2df6d01-9cff-59ea-b76b-2882ea0879f3",
    "entry": "見舞い",
    "reading": {
      "primary": "みまい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
