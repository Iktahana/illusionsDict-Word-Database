        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今の話の様子じゃあ相手はいずれ大きい御旗本か御大名だろうが、なぜそんなことをするんだろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "某をば妙解院殿御弟君｜中務少輔殿立孝公の御旗本に加えられ御幟を御預けなされ候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝頼、今は戦うまでである、御旗、無楯に誓って戦法を変えじ、と云ったので、軍議は決定して仕舞った。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌四日にも、幕軍は敗勢を返さんとして戦ったが、此日仁和寺宮｜嘉彰親王が、金甲馬に跨り、前駆に錦旗を飜して、陣頭に進まれたので、絶えて久しき錦の御旗を仰いだわけで、官賊の別が判然としたので、薩長の軍は意気軒昂となり、幕軍は意気沮喪して、いよいよ敗勢の著しいものがあった。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「茜の吹貫二十本、金の切先の旗十本、千本｜鑓、瓢箪の御馬印、太閤様御旗本の行列の如く……」と、『大阪御陣覚書』に出ている。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀頼公が御旗御馬印を、玉造口まで押出させ、寄手の勢力を割いて明石が軍を目的地に進ましめることを計った。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "素町人の分際で、歴々の御旗本衆に楯突こうとは身のほど知らぬ蚊とんぼめ。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下の御旗本ともあるべき者が町人どもを相手にして達引とか達入とか、毎日々々の喧嘩沙汰はまこと見上げた心掛けじゃ。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一の時には公方様御旗の前で捨つる命を、埒もない喧嘩口論に果したら何とする。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾｜是なる剣は賢き王の御旗の許に是如く麗はしく喜びに踊りつゝあり。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "怕らしいお殿様じゃとばかり思い込んでおりましたお殿様が、どうやら御気性も頼もしそうな御旗本と、つい今あそこで承わりましたゆえ、恥ずかしさも忘れて駈け出したのでござります」「ほほう喃、左様か左様か。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "道場に、どんなカラクリがあるか知らねえが、本当に、竜造寺のお殿様が黒幕にいらっしゃるとするなら、こいつも只の騒動じゃあるめえと存じますゆえ、万ガ一の場合の御用意に、二人三人御朋輩の御旗本衆をでも御連れなすった方がいいと思うんでごぜえます。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにても一朝事ある時は、上将軍家の御旗本を固むる公儀御自慢の八万騎と申されるかッ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お高は二千三百石と申すのですから、御旗本のなかでも歴々の御大身でございました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつら素町人の分際で、歴々の御旗本衆に楯突かうとは、身のほど知らぬ蚊とんぼめ等。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下の御旗本ともあるべき者が、町人どもを相手にして、達引とか達入とか、毎日毎日の喧嘩沙汰、さりとは見あげた心掛ぢや。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして天下の御旗本が、くらべにもならぬ御身分違ひ、とても、とても。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）三左　　いかにも此頃の御旗本御家人が、武藝をすてゝ遊藝に耽り、次第に惰弱に流れまするは、なげかはしい儀でござりますが、他は他、われは我、さやうな徒にはおかまひなく、お前樣は飽までも御先祖以來の御家風によつて……。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一体ゆうべは何処へなにしに行きなすったんだ」「中の郷｜元町の御旗本大月権太夫様のお屋敷へ伜の名代として罷り出まして、先ごろ納めましたるお道具の代金五十両を頂戴いたしてまいりました」「元町へ行った帰りなら源森橋の方へかかりそうなもんだが、どこか路寄りでもしなすったか」「はい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "薩長の大軍が、錦の御旗を押し立てて今にも東海道を下って来るといったような風聞が、ひっきりなしに人心を動かした。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは、赤報隊と称して、錦の御旗を先頭に立て、二百人に近い同勢が、鎮撫使の万里小路侍従を取り囲んでいた。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "御旗｜向地へ御廻しに相成、江木軽部等近日渡海之事。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜四時御旗向地へ御渡海之事。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ御旗本でも御裕福な六浦琴之丞様。",
              "citation": {
                "source": "悪因縁の怨",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御旗本か」「はい」「何か手柄したか」「中々、鉄砲が――」「鉄砲が、恐ろしいか」「貴下方のように、胆が勝れていませんので、つい――」　土方が「鉄砲は、胆を選り好みしないよ」「あはははは」　と、大声で笑った。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉本米子夫人に日木は伸びたり、滿洲の荒野も今は大君の御旗のもと。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆白錦の御旗でございます。",
              "citation": {
                "source": "牛車",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "年寄の歩みはたどたどしいにしても翁は次いで三日も歩んだ麓の幅を計ることはできなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（われらみな主とならんぞ）　　みなかみはたがねうつ音。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンドをしていないので、胸のふくらみはたるんだ柔さだった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
