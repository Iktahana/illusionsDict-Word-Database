          "literary": [
            {
              "text": "サモアから濠洲へ、濠洲から独領西南アフリカヘ、アフリカから独逸本国へ、独逸から又ミクロネシアヘと、盥廻しに監禁護送されて来たのである。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミクロネシアを見てをるのでもない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミクロネシアを見ておるのでもない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、わが南洋諸島であるミクロネシアと、以前は食人種の島だったメラネシア諸島のあいだだ。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミクロネシア系の男だろう。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
