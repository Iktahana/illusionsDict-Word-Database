    "definitions": [
      {
        "index": 1,
        "gloss": "Sasamorpha borealis (species of bamboo grass unique to Japan)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いわゆる「水篶竹」で、それで作ったものを土地では「水篶細工」と呼びます。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "曽祖父欣次衛門（私の欣一はこの字を貰った）の父か祖父かが江戸に出たので、それ迄は信州でみすずを刈っていたか、戦争をしていたか、何にしても碌なことはしていなかったのであろう。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それから一年ほど経って金森のみすずと半三郎との、婚約をまとめたのだ。",
              "citation": {
                "source": "あだこ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金森主膳は八百石の書院番、すなわち父の上役であり、みすずはそのとき十三歳であった。",
              "citation": {
                "source": "あだこ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはみすずの部屋で、ただいちどだけあったことだ。",
              "citation": {
                "source": "あだこ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みすずは着ている物をすっかりぬぎ、素裸になって、自分のからだを彼にみせた。",
              "citation": {
                "source": "あだこ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みすずは頭部が小さく、手足もしなやかに細く、胴もほっそりとくびれていた。",
              "citation": {
                "source": "あだこ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あたしきれいじゃなくって、　みすずは彼の顔色をうかがいながらそう云った。",
              "citation": {
                "source": "あだこ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだ、彼はよく覚えている、みすずはそうしながら、絶えず彼の顔色をうかがっていた。",
              "citation": {
                "source": "あだこ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みすずは彼よりもはるかに能動的であった。",
              "citation": {
                "source": "あだこ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みすずは彼を放し、彼からはなれて、訝しそうな、さぐるような眼つきで彼を見まもった。",
              "citation": {
                "source": "あだこ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みすずは十五歳とちょっとで、自分のからだの美しさを、許婚である彼に誇りたかったのであろう。",
              "citation": {
                "source": "あだこ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本書は40年ほど前に橋本雅一博士が訳してみすず書房から刊行されている（1966）。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という身軽さであろう、親鸞は、生信房を案内として、西仏、光実、了智の五人づれで、もう角間の草庵を引き払い、みすずかる信濃を後に――浅間の煙のなびく碓氷の南へ――峠を越えているのだった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
