[
  {
    "uuid": "3aabb0a3-1298-53de-bdf0-60a66226febe",
    "entry": "見る度に",
    "reading": {
      "primary": "みるたびに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "whenever (each time) one sees (it)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "が、自分はこの絵を見る度に静かな田舎の空気が画面から流れ出て、森の香は薫り、鵯の叫びを聞くような気がする。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな繪を見る度に、屹度自分も門から外へ出て描いて見たくなるのである。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　けれども牛は、美しい草を見る度に、頭を下げて、舌をべらりと廻して喰べました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "如斯ことはきょう始めてと云うではないが見る度に胸がふさがるべくおぼえ何と云うて慰さめんようもなく身も世もあらぬ思である。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来ない相談とは知りつつも、毎年の展覧会を見る度にそう思わないことはないのである。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る度に六稜柱の壁はだんだんに延びて行くようであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は親類や知人の誰彼が避暑先からよこした絵葉書などを見る度に、なんだか子供等にまだなんらかの負債をしているような心持を打消す事が出来なかった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ若しこれが大金持ちか王様の娘であつたならば美事な着物を何枚も着せて大勢の人々に見せびらかさうものを、折角｜此様に天人の様な美しい娘を授かり乍ら着せるものは汚い黒い襤褸しか無い、嗚呼何と云ふ情ない事であらうと娘の顔を見る度に涙を流して居りました。",
              "citation": {
                "source": "金銀の衣裳",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は此手紙を見る度に何だか故人に対して済まぬ事をしたような気がする。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度洋上と云ひ、アラビヤ砂漠の中と云ひ、私は星を仰ぎ見る度に古代の人の心に立ち帰つて見るのであつた。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまじそれがあつた為に毛をさか※ぎにされるやうなくるしい目にあつたと思へば、感興に殉じた小伎倆立てが、自分ながらいまいましく、この冊子を見る度にをこな自分を版木に刷り、恥ぢづら掻いて居るやうで、踏まば踏め、蹴らば蹴れ、と手から抛つて置くとこまかせ、そこら畳の上に捨てても置いた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その様子を見る度に、以前の物語の聴手達は、この莫迦面の怠け者に、貴い自分達の冬籠りの食物を頒けてやったことを腹立たしく思出した。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の樣子を見る度に、以前の物語の聽手達は、この莫迦面の怠け者に、貴い自分達の冬籠りの食物を頒けてやつたことを腹立たしく思出した。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見ると私は、妙に母を愍む様な気持になつて、若し那※事を叔父の顔を見る度に言つて、万一叔父が怒る様な事があつたら、母は奈何する積りだらうと、何だか母の思慮の足らないのが歯痒くて、それよりは叔父が恁うして来た時には、口先許りでも礼を言つて喜ばせて置いたら可からう、などと早老た事を考へてゐた。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "末造は覗いて見る度に、早く無縁坂の家に持って往って、窓の所に弔るして遣りたいと思った。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は窓の外を見る度に、桜の葉の黄色くなって行くことばかりが考へられてならなかった。",
              "citation": {
                "source": "秋は淋しい",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "己は友達のさう云ふ様子を見る度に、古代の哲学にある一｜人二霊説を思ひ出さずにはゐられない。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "餘所を一寸見る度に大きな菅笠がぐるりと動く。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘次はお品のことをいはれる度に、おつぎの身體をさう思つては熟々と見る度に、お品の記憶が喚返されて一｜種の堪へ難い刺戟を感ぜざるを得ない。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅かに交つた小さな白い銀貨が見る度に彼の心に幾らかの光を與へた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいよさんは此を何と思つたか、私がおいよさんを見る度においよさんも私を見返すのであつた。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "義務が事実として証拠立てられるものでないと云うことだけ分かって、怪物扱い、幽霊扱いにするイブセンの芝居なんぞを見る度に、僕は憤懣に堪えない。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外、少年の顔を見る度に、それをするかと云い、小娘の顔を見る度に、或る体の部分に毛が生えたかと云うことを決して忘れない人は沢山ある。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は、見る度に、可笑しくてさ。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　訪ね先きに悪いと思つて、わざとあたり前の小娘風にお妙をつくつて来たのであるがお蝶は、気にして見る度に、そのために二人の気分までが窮屈になつてならなかつた。",
              "citation": {
                "source": "お蝶の訪れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女の蒼白い緊張した顔の表情を見る度に、Ｂはつらいつらい心になつた。",
              "citation": {
                "source": "山間の旅舎",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見る度に焦れつたくなる。",
              "citation": {
                "source": "地球儀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、彼は人々が振りかえってみるたびに、得意になっていた。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（臭いな、障子をあけてみたら）　彼は石油の匂いが鼻にしみるたびに外気を入れたらと思ったが、すぐその考えはノートの方へ往って、石油の匂いのことは忘れるのであった。",
              "citation": {
                "source": "雀が森の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "−−−−−−−−−−−−−−−−−−−−−−−−犬と女中　　――犬と謎々のうち――　心理学者吉植吉三郎博士の家庭では女中を解雇した、この女中といふのは、博士夫人が良い女中がゐなくて困ると、出入りの植木屋の顔をみるたびに愚智をこぼすので、植木屋が自分の郷里の新潟から呼びよせたものであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
