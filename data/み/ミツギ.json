  {
    "uuid": "fbe81b42-9d53-5169-8df2-cf0bef0016dd",
    "entry": "密議",
    "reading": {
      "primary": "みつぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
