      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "secret conference",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "兎角して二人の密議が着々進んで、四日目あたりになると、編輯局に多数を制するだけの味方も得た。",
              "citation": {
                "source": "悲しき思出",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "此を隠謀の参謀本部として、豚汁をつついては密議を凝らし、夜更けて雨でも降れば、よく二人で同じ蒲団に雑魚寝をしたもの。",
              "citation": {
                "source": "悲しき思出",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな連中と健児社の箱田｜六輔氏等が落合って大事を密議している席上に、奈良原到以下十四五を頭くらいの少年連が十六名ズラリと列席していたというのだから、その当時の密議なるものが如何に荒っぽいものであったかがわかる。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "密議の目的というのは薩摩の西郷さんに呼応する挙兵の時機の問題であったが、その謀議の最中に奈良原到少年が、突如として動議を提出した。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以来「奈良原の奴は密議に加えられない」という事になって同志の人は事ある毎に奈良原少年を敬遠したというのだから痛快である。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、船長室に密議を凝らしに行ったメーツらはサロンへ引っかえして来た。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どういうふうに体裁を繕えばいいか、この人を廃り物にしないためには」　大臣は二、三人と密議するのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "互いに相手の顔も知らなければ、名前も知らず、年齢の見当すらも知らない二人が、ただ、正義党の党員番号だけによって、恐るべき共同の大事業について密議を凝らそうとしているのだ。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "いましも署長室では、山川署長と恒藤司法主任とが、膝をつき合わして密議をこらしている。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからどのくらゐの間、二人してその城跡の山の上の枯草原で密議を凝らしましたか、二人とも非常な昂奮を抱いて山を降りる頃は、日はもうとつぷりと暮れてをりました。",
              "citation": {
                "source": "金比羅參り",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "密議の結果はかうです。",
              "citation": {
                "source": "金比羅參り",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は一大事の密議じゃで。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人四人打ち連れて訪い来る客は、一間に閉じ籠りてしばしば密議を凝らせり。",
              "citation": {
                "source": "書記官",
                "author": "川上眉山",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほどもなく入り来る洋服｜扮装の七分は髯黒の客人、座敷に入りてしばらくは打ち潜めきたる密議に移りしが、やがて開きて二側に居流れたるを合図として、運び出づる杯盤の料理は善四郎が念入りの庖丁、献酬いまだ半ばならず早くも笑いさざめく声々を、よそに聞きて光代は口惜しげに涙ぐみぬ。",
              "citation": {
                "source": "書記官",
                "author": "川上眉山",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして誰一人それに対して異存を唱える者が無かったが、控席へ退いては、右の御達はあまりの思召切りだ、何とか今少し御思案もありそうなものだといって、彼処に五、六人此処に七、八人各々密議をこらす者もあった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下室の密議　そこは窓のない部屋だった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな事より素晴らしいものを今夜は君に見せてやろう」「何んだい夫れは」と訊き返えすと、「即ち宗社党の留学生達が、ある建物へ集って、密議をしているその有様を、君に見せようと思うのさ」「いよいよこいつは面白くなった」「それでは一緒に出かけよう」　自分達は深夜の町へ出た。",
              "citation": {
                "source": "広東葱",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間を上がると幾個かの座敷で、その奥に大きさ三十畳敷きはあろうか、そういう広い部屋があったが、その部屋に一同は集まって、密議に耽っているのであった。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船中の密議　老貴公子は姉小路卿であった。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それよりわれわれは萩丸様自筆の、宥免状を手に入れましたれば、これをもって紀州に捕われおるところの、同志多数の人々の命を、至急救助いたさねばならぬ」　――こうしてこの日主立った者が、この船中に集まって、密議を凝らすことになったのである。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一瞬場内が蒼白になると、職員室で密議を凝らしてゐた村の顔役と教員がブロンズのデスマスクを顔にして黄昏をともなひながら入場した。",
              "citation": {
                "source": "村のひと騒ぎ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの野郎をくらすけても文句のでねような方法が、ここに一つあるがんだ」　そこで一同は額を集めて密議を重ねる。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "飛燕流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日ヴュルテンブルグ枢密議官ドイツ国会代議士フォン・ビューレルは全ドイツ国民は均しくこれ平和を好む者なれども今にしてその兵備を緩にすることあたわざるは、ひっきょう各国の国民の往々ドイツ国民に反するの挙動あるがためなり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀之助が戸を開けて入つた時は、二人差向ひに椅子に腰懸けて、何か密議を凝して居るところであつた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川の代もこれまでだと覚悟する将軍は、討幕の密議がそれほどまで熟しているとは知らなかったが、禍機はすでにその極度に達していることを悟り、敵としての自分の前に進んで来るものよりも、もっと大きなものの前に頭を下げようとした。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "白石の家が幾度か連絡の場所となり密議の室となって、結局そうきまった。",
              "citation": {
                "source": "志士と経済",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうすることも出来ません」　ここは麗人国の城主の居間で周章てきった城主大物主と、腹心の老臣山津主とが、人を避けて密議に耽っていた。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一に曰く、「梅田源二郎長門｜下向の節、面会したる由、何の密議をかせしや」。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の密議をかなさんや。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の国のみつぎとり、　　　　里長を追ひて出で来り、えりをひらきてはたはたと、　　紙の扇をひらめかす。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
