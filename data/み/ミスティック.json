        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "道路の方で白い犬が、ゆめのやうなミスティックな響をもつてぼうぼうと吠えてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともその他の点では、その考え方はペシミスティックである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "オプティミスティックな政治主義が考えるように、簡単にこの悲劇がなくなるとは想像され得ず、かえって悲劇は歴史の本質であるように思われる。",
              "citation": {
                "source": "政治の論理と人間の論理",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞑想は多かれ少かれミスティックなものである。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての魅力的な思索の魅力は瞑想に、このミスティックなもの、形而上學的なものにもとづいてゐる。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての魅力的な思索の魅力は瞑想に、このミスティックなもの、形而上学的なものにもとづいている。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョア社会は個人のアトミスティックであったから、最高の哲学的原則は何によらず個人の内に求められる他はない、そうしなければ全く外面的な機械的な尤もらしからぬ説明になるからだ。",
              "citation": {
                "source": "道徳の観念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "螽が嗤ふほどのペシミスティックな子供たち！",
              "citation": {
                "source": "希臘十字",
                "author": "高祖保",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろペシミスティックであり、ペシミスティックでありながら、体に作用してくる不思議な音だった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴隷労働者たちが教会でうたったスピリチュアルな歌は、このつらさの歌であり、世代がすすむにつれて、いつかは死によってこの求めざる土地から解放され天国にいけるのだという、宗教上の希望によって支えられたペシミスティックな生の肯定の歌にかわった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この穴のなかから、一九五〇年代のなかばに、ある種の人たちを這いあがらせてとりあえず解放したのが、すぐれてハッピーで同時にペシミスティックなあのロックンロールだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちらっと明るいところがあって、そのほかはペシミスティックでブルーな曲にしようと思ってるんだけど、セリカで走っているうちに、オートバイも曲のなかにとりこみたくなったんだ」「なるほど」「日曜日に馬鹿な四輪でトロトロ走ってるうちに、男は何度もオートバイを見る。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
