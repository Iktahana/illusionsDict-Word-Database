    "definitions": [
      {
        "index": 1,
        "gloss": "to accidentally be visible (in a play, TV show, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
