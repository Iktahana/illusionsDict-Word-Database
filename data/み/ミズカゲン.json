        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "前夜から洗っておいて、水加減を多くし、トロ火でやわらかくそしてふきこぼれないようにたいてみた。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『湯加減、湯加減、』『水加減。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣に適したる水加減、天気工合の、申し分無き日とては、一年に僅三日か五日なり、此の、僅の日に釣りたるだけにて、一年の釣楽は十分なりと。",
              "citation": {
                "source": "大利根の大物釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "水加減、火加減はするが、肝心かなめの時に、ほかの用事をしたりして、米を腑抜けにしてしまうからだ。",
              "citation": {
                "source": "料理一夕話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "煮加減、焼き加減、塩加減、水加減、火加減と、加減の大事が次々とかぎりなくあります。",
              "citation": {
                "source": "料理する心",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯の水加減が悪かったりすれば、結果は寿司になるべき第一義が失われる。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓　なにさ、俺あ、ついでに川っぷちのタンボの水加減見て来なきゃなんねから……お前はそこで休んでいな。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日ら、少し煮えてるずら、今丁度稲あホキてる最中だからな、下手あするとしくじらあ、……（立停って）それとも、シゲにタンボの水加減、わかるか？",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちびを使ひに出したので自分で水加減をして焚きつけた。",
              "citation": {
                "source": "續俳諧師",
                "author": "――文太郎の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の近郊滝めぐりお客様を見てから水加減　夏らしく、といってもあまり涼しくない滝の話。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
