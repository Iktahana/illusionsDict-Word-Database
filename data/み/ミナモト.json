    "definitions": [
      {
        "index": 1,
        "gloss": "source (of a river)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "芸術に始源がありとして、それは何だか知つてゐるか？",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手の籔が切れる所に来ると、右手の方に養漁場がみえ、その他は一面の田で遠く神田上水源の方の森並に縁取られてゐる。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "所で人間が物を創造するのはその源に於てはそれら神秘だの魂の愉悦だのといふものではないか？",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら善意といふものが在つて然る後神が在るのではなく、神といふ一切の根源が在る「在り様」こそ善意である筈だからである。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮りに神の御旨を人の子の側にも当篏めんか、最初に神の脳裡に構へられし静止せる理想郷に逆源するのみ。",
              "citation": {
                "source": "地上組織",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その余韻の源にさかのぼって行くと徳川時代などを突き抜けて遠い遠い古事記などの時代に到着する。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖書や源氏物語には音はない。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "首里の名主といはれて居る謝源は大広間の上座にうちくつろいで座つて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源のすぐ傍に丞相の郭光はもう大分酩酊したやうにして膝をくづして、ひかへて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源は派手な琉球絣の薄ものをたつた一枚身にまとひ、郭光の酌で泡盛の大杯をチビリ、チビリと飲んで居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源は今宵程自分といふものが大きく思はれた時はなかつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源は文字通りの悪戦苦闘を続けた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "首里に凱旋して来た謝源は今夜の宴を開いたのであつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源はそれを聞いて微笑みながら、だまつてその星のある方を指さした。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源も、これを聞いた家来の一部のものも、あまりのオカシさに笑ひこけてしまつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源と郭光はそれから一しきり、いくさの手柄話に花を咲かせて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源はフト郭光との話を止めて上機嫌で「アヽそうか、すぐこれへ」と口ばやに言つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源には二人の蘭人とは誰と誰であるかゞわかつて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八年前に謝源がこの沖合で難破した蘭人の二人を家来の救ふて来たのを、世話してやつたことがあつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源は絶えずニコ／＼してそれを聞いて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に両人ともまだ琉球のことばを忘れて居ないで、たやすく思ふまゝに言ふことが出来て居たといふことは謝源をムシヤウに嬉しがらせた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源は二人の言葉の終るのを待ち遠しそうにして「アヽよし／＼両人とも大儀であつたナ」と言つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう五十の齢にも及ばうとして居る謝源も前後を忘れて「アヽ愉快だ※」と叫びたくなつた程であつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "郭光はこれを介して謝源に渡した。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "偉いと言はれてもいくらか原始的な人種である琉球人たる謝源はその品を受け取つてしまつてからは、それを見たくてたまらなかつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源はその時は全く子供のやうにハシヤギながら、急いでそれを開いて見たのであつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源は全くそれを珍らしがつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源はその地図を蘭人に示して「もそつと、前に進んでこれを説明して呉れぬか」と言つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源は地図を下に置いて蘭人の説明を待つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地図は上の方は北で、下の方は南……」謝源はそんなことはどうでもよかつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
