          "literary": [
            {
              "text": "斯んな場所に不似合な程、見優りのするベッシェール夫人がその踊り場の一つのブウスカ・バルへ傘をつぼめてつか／＼と入って行くと彼等は話声を止めて振返った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜はしんしんと更けて、いよいよ深みまさり、粘り濃く潤う闇。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君こふる夢のたましひ行かへり、夢路をだにもわれに教へよ　といい、また、つらさのみまさり行く幾おもひやる夢のたましひいかゞ行くらん　などという歌があるが、これは睡眠中の心理的動作を指すもので、今日の学者といえども捨てがたい面白い詞章であると思う。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            }
          ]
        }
