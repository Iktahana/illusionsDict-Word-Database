    "definitions": [
      {
        "index": 1,
        "gloss": "cold brew (coffee, tea, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
