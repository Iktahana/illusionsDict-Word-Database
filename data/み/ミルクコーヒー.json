        "examples": {
          "standard": [
            {
              "text": "朝食には、温かいミルクコーヒーが欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "喫茶店で、彼は砂糖なしのミルクコーヒーを注文した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "凍える冬の日に飲むミルクコーヒーは格別だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "柾生はペプシ、慶一は「ミルクコーヒー」をたのんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミルクコーヒーという飲み物は、ミルクもコーヒーも入っていないのだそうだが、コーヒー牛乳とは異なる独特の味があり、映画館の売店以外ではあまり見かけない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハトヤは、公園劇場前金龍館寄りにあるコーヒー屋で、一日にコーヒー何千杯売るといふ、小さい店だが、此処のミルクコーヒーなど、浅草の何年間に何千杯のんだか分らない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーヒー五銭ミルクコーヒー十銭で、一と月の払ひが三十円を越えた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一回終って、卵をかけて飯を食ひ、コブ茶をのみ、ミルクコーヒーをのんで、吸入をかける。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "外出せず、中西のビフカツとオムライスで食事すませ、ミルクコーヒーなどのみ、ねころんで揉ませる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "座へ出る、涼しいので、あったかいミルクコーヒーの味よろし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の終りが四時半、やれ小一時間休めると思ったら、土屋伍一が身の上相談に来ちまひ、ふた葉の親子を食ひ、ミルクコーヒーのむともう夜の部。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
