    "definitions": [
      {
        "index": 1,
        "gloss": "judging from appearances",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは、ひどい搾取下にある島民たちで生活されているが、見たところは、パラダイスであった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程あのガラ／＼の音ぐらゐでは三百六十五日浚つて見たところで梓川がたゞの一ト雨に押し流してくる砂泥をすくひ上げるにも足りないのではないかといふ気がするのであつた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその夫人がビフテキを食っていたのが、少なくも見たところ平然と肉片を口に運んでいたのがハッキリ印象に残っている。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "曙町へはいると、ちょっと見たところではほとんど何事も起らなかったかのように森閑として、春のように朗らかな日光が門並を照らしている。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸こっちを見たところには栗鼠の軽さもある。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと見たところでは別に堂々とした様子などはない。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の見たところでは、梶井君は三好君に對してのみ、一切の純情性を捧げて、娘が母に對するやうに甘つたれて居た。",
              "citation": {
                "source": "本質的な文學者",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の根がたのかしこここに背の低い松が小杜を作っているばかりで、見たところ畑もなく家らしいものも見えない。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "シモツケの繖形花も肉眼で見たところでは、あの一つ一つの花冠はさっぱりつまらないものであるが、二十倍にして見るとこれも驚くべき立派な花である。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼女が見たところでは、その女はどうも跣足であったらしいというのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "案外に年を食っているかも知れねえが、見たところは十七か十八ぐらいの美しい女で、何かいろいろの祈祷のようなことをするのだそうだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七八というのは彼女の美に惑わされた報告で、どうしても二十歳か、あるいは二十歳を一つ二つぐらいは越えているらしいが、見たところは如何にも若々しかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "見たところ、彼は、日本の兵タイなど面倒くさい、大砲で皆殺しにしてしまいたいと思っているらしかった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきほどの客のように抓って見たところで、ごく稀にしか悲鳴を発しないのである。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」十六「なるほど見たところ、衣服を着た時の姿とは違うて肉つきの豊な、ふっくりとした膚。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか細かい線で描いてある横物で、打見たところはモヤモヤと煙っているようなばかりだ。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪口をいえば骨董は死人の手垢の附いた物ということで、余り心持の好いわけの物でもなく、大博物館だって盗賊の手柄くらべを見るようなものだが、そんな阿房げた論をして見たところで、野暮な談で世間に通用しない。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "原名は「人生の歌」というのであるが、自分の見たところではどうも人生を謳歌したものとは思われない。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰐が虎をねじっているのか、虎が鰐をねじっているのか見たところではどっちだかわからない。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "袴をはいているが見たところ左の足が無いらしい。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと見たところでは、ベーアのほうは負けかかって逃げ回っているようにも見られた。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭園は、ほんたうは二百坪にも足りないひろさなのであるが、見たところ千坪ほどのひろさなのだ。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭園は、ほんとうは二百坪にも足りないひろさなのであるが、見たところ千坪ほどのひろさなのだ。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も申します通り、その聖書は、ちょっと見たところ、古い木版みたいな字の恰好ですからね。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階建、格子戸、見たところは小官吏の住宅らしく。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『そら、あの森のところサ御料地の、あそこから向こうの畑と林とを見たところサ。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまさか引き出して見たところで何がわかろう。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうです、安宅さん、みたところお元気で、御景気も好いやうですが……」　彼が茫然して直ぐに返事をしないと、親爺は急に笑顔をやめた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな素晴らしい雑誌を出してみたところで、世の中は僕たちにうまく恰好をつけては呉れません。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それに顔をみたところで何処を風が吹いたやらつて顔ぢやないかね。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
