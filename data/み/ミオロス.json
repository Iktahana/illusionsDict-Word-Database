    "definitions": [
      {
        "index": 1,
        "gloss": "to overlook",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「此の頃は、よく勉強してゐますか」　頭の低い人間だけれど、やつぱりブルヂョアなのだ、見下ろすやうに奥さんは彼に言つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "北側の胸壁にもたれて見下ろす。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右を見ると伊豆の国というものの大きさがぼんやり分かるようであり、左を見下ろすと箱根山の高さのおおよその概念が確定するような気がする。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その姿見下ろす大吉の顔に一種残酷な、所謂悪魔的な微笑と云う奴が浮んだ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の三階から見下ろす一町くらい先のある家で、夜更けるまで大声で歌い騒ぎ怒鳴り散らすのが聞こえた。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見下ろすような眺望はけっしてできない。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼人だってどんな具合でここへ漂って来まいものでもない、』など思いつづけて坂の上まで来て下町の方を見下ろすと、夜は暗く霧は重く、ちょうどはてのない沼のようでところどころに光る燈火が燐の燃えるように怪しい光を放ちて明滅していた。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし若い僧は国太郎がじろじろ見上げ見下ろす眼ざしには一向｜無頓着になお進んで訊ねる。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼に金の勢が添はつて居る計りに、自分からしてが、いくらか彼を上に見ると云ふ卑屈な心にもなり、彼からは大に低く見下ろすと云ふ高慢な心にもなるんだ。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "説教者もちよつと詞を切つて、上座の方から見下ろす様にして戸口の人を呼びかけた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……橋の上、大通りの辻……高台の見霽と、一々数えないでも、城下一帯、この銅像の見えることは、ここから、町を見下ろすとおんなじで……またその位置を撰んで据えたのだそうだから、土地の人は御来迎、御来迎と云うんだね。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の背に立つ巌、狭く鋭く、踵から、爪先から、ずかり中窪に削った断崖の、見下ろす麓の白浪に、揺落さるる思がある。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、それがどういうつもりか井深君の前に危くヒョイと踏み止まったが、井深君の中山帽子の頂からスパッツをつけた靴の尖まで、ジロリと一っぺんに見上げ見下ろすと、さて身を転じて颯々と肩をゆすり乍ら歩いて行ったのである。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに立つて南を見下ろすと、穂のでかかつた麦のだんだん畑がうちつづき、丘のすそと平野がつらなるところに、白壁の塀をめぐらした大きい館が見えました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　異人館の丘の崖端から川を見下ろすと、昼間見る川は賑かだつた。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、ぐっと見下ろす。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その緩い坂を登りつめてしまえば、大震災の当時の市区改正のため築山のうしろは断ち切られた俄崖になり、見下ろす崖の肌にも寒竹の根や灌木の根が瓦石と混って赭土の断面にむくじり出ています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手品というものが、本来、背後から見下ろす人のためにできた芸当ではないのだから。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すがすがしい好晴の日で食卓から見下ろす銀座方面のながめははればれと明るくいきいきと美しいものであった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は炭坑の入口を見下ろすことの出来る位置に待っていた。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "見下ろす先には、くすんだ中間色のロンドン市街、私もホームズの肩越しに覗いてみると、向かいの舗道に大柄の女が、ふっくらした毛皮の襟巻きを首に廻して、鍔広の帽子に大きな曲線を描いた赤い羽根をつけ、それを艶なデヴォンシア公爵夫人流に、片耳隠しで斜にかぶって立っている。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて庭園の最端谷を直下に見下ろす場所に来た時谷を見下ろして居た僕はふと一つの真紅の燈火が向ひの山の中腹の辺に点つて居るのを見つけた。",
              "citation": {
                "source": "殺人行者",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なぜというに、男は肝より丈まさり、応対をするのにも、見上げるのと、見下ろすのでは、見識が違う。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "セコチャンは、自分をのみ殺した湖の、蒼黒い湖面を見下ろす墓地に、永劫に眠った。",
              "citation": {
                "source": "死屍を食う男",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "見上ぐるも恐ろしく、見下ろすも恐ろしき處、一町以上もつゞく。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと気が附くと、私達は茅葺屋根の寺を後にして、崖に臨んだ小さな亭見たやうな処に腰をかけて、見下ろすやうにして下を瞰てゐた。",
              "citation": {
                "source": "百日紅",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間のことは判らないが、不図下の部屋がカタカタする音に気がついて例の覗き穴から見下ろすと、この前に来たように一隊の警官隊が集っていた。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらには坊が二つも三つもつゞいて、その一つは崖の上から谷を見下ろすやうな位置にあつた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の流人たちは、海を見下ろす砂丘の上で、日向ぼっこをしていた。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもその日の夕方には、三本のボイラーをうまく無事に積みおろすことができた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
