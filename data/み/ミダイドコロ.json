[
  {
    "uuid": "a5824222-46b6-54ee-8bb0-518a34791a64",
    "entry": "御台所",
    "reading": {
      "primary": "みだいどころ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
