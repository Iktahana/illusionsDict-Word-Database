    "definitions": [
      {
        "index": 1,
        "gloss": "failed attempt (at a crime, suicide, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その翌日、朝鮮の青年が「天界ホテル」の寝室にいた白痴のマリを殺害しようとした未遂事件。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八　近年の統計によると警視庁管内における自殺者の数が著しく増加し、大正十一年と昭和八年とでは管内人口の増加が約六割であるのに対して自殺既遂者の数は二十割、未遂者の数は四十割に増加しているとの事である。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　彼等が決闘を未遂に終らせたことはとりも直さずわたしに決闘を仕遂げさすことであつた。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に商店の番頭のＹは、非常にセンチメンタルな調子で、ある娼婦と心中未遂に到るまでの捨て鉢な戀の告白をしました。",
              "citation": {
                "source": "Ｓ中尉の話",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれまで既に、四度も自殺未遂を行っていた。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "未遂で人に見とがめられ、縄目の恥辱を受けたくなかった。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その最初の冒険が（或いは冒険未遂が）どうして洩れたものか、三造には分らなかった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或ときイギリスのシェフィールドといふ町の警察へ、一人の泥棒未遂の犯人があげられました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために彼は泥棒未遂罪としてつかまつて、九回も牢屋にたゝきこまれたものでした。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはもちろん、シャーロック・ホームズ氏謀殺未遂事件でしょう、――」「いやいや、レストレード君、僕はこの事件の中には、一切関わりを持ちたくないんだがね。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「殺人だ、ネヴィル・シン――ああ、うむ、その罪を問うとしたら自殺未遂で立件せねばならんのか。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "「付け加えてもいい、シャーロック・ホームズ殺害未遂、と。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "本日午後、中心区で凶悪な強盗未遂が発生、結果一名が死亡するも犯人は逮捕された。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "強盗殺人犯の脱監密通した令夫人鉄道線路の飛び込自殺××氏の毒物嚥下山林中の強姦未遂。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、この監にいる者の中には、恐喝取財未遂の弁護士、詐欺取財の陸軍大佐、官吏侮辱の二六新報の署名人、犬姦事件の万朝報署名人、恐喝取財の日出新聞記者、自殺幇助（情死未遂）の少年、官文書偽造の中学校書記、教科書事件の師範学校長、同上高等女学校長、元警部某、馬蹄銀事件の某々らであった。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、殺人未遂の犯人があるから、直ぐ来て呉れと。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その弱々しい少年が、この恐喝取財未遂の犯人に相違ありませんでした。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "若杉さんを襲った賊、それは罪名からいえば、窃盗未遂でした。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかが、いや、わたしが “たかが” などといってはいけないが、でも、たかが女子寮への侵入、それも未遂にすぎないものを、それだけのことで、いったいどこのだれが、だいじな生徒を退学させるっていうんだ！",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――とぎれとぎれの話の間に、太田は男の名を村井源吉といひ、犯罪は殺人未遂らしく、五年の刑期だといふことだけを知ることができた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――とぎれとぎれの話の間に、太田は男の名を村井源吉といい、犯罪は殺人未遂らしく、五年の刑期だということだけを知ることができた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、もちろん、君を毒殺し得たと思って、すぐ自殺を計ったのだが、それが、どういう因果か未遂に終って、こうして病院へ連られて来て、今では自殺する能力をさえ奪われてしまったのだ。",
              "citation": {
                "source": "卑怯な毒殺",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "正しくいへば、卒倒でなくして自殺未遂であつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "謀殺未遂というやつですねえ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自殺未遂の者は、病院に運ばれて手厚く看病されたが、回復後数ヶ月して、殺人罪で裁判にかけられた。",
              "citation": {
                "source": "死生に関するいくつかの断想",
                "author": "BITS OF LIFE AND DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "みすみすいまだ売出し前の若手二人。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
