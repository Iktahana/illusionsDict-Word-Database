        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ベッドは右奥の壁に――。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "右奥に階段の昇り口。",
              "citation": {
                "source": "疵だらけのお秋（四幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右奥に見えてゐる階段に音がして四十四五の小役人風の男が降りて来る。",
              "citation": {
                "source": "疵だらけのお秋（四幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右奥にスタンド、その横から奥の居間に行ける。",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右奥の少し離れた所でガーン、ベリベリと大きな物音。",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（右奥へ消える。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実あ本宿手前の土橋をさ……たしか此処からも見える筈……（右奥へ行き遠くを指して）ほら、あれだ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（トタンに右奥遠くでドドドと土橋が水へ落ちる音。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙太　（右奥を眺めやりつつ）ウーム。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右奥からザザッと音を立てて走り出て来る博徒甲。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早田、柵門内へいきなり走り込んで行きかけるが、チョイと立ち停って右奥屯所の方へ向って）水戸、岡田先生よりの使い早田隼人通るぞっ！",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（本舞台へ、ビクビクしながら歩いて行き、柵門の辺まで行きウロウロしていたが思い切って右奥の方へ向けてビクビクもので小腰を屈めながら）へい、お願え申しまするお願えいたします。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉村不意を打たれて、トッサに刀のツカでガッと受けは受けても、どこかを少しかすられたらしい）吉村　（パッパッパッと六、七歩右奥へ畳を飛びさがって抜刀）卑怯っ！",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と右奥下方を眺める。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村道は本舞台にかかるとすぐ二つに分れて、一方は左袖へ消え、一方は右に曲って、水田の中を斜に断って、右奥へ曲って消えている。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥水田は岩瀬町から柿岡町へかけての低い山脈にくぎられ、右奥遠く高く肩を見せているのは加波山と足尾山である。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（その声につれて同勢は一言も発せずにバラバラッと右奥へ向って、稲田の中に飛込んで行こうとする）仙太　やい、待てっ！",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（滝三も右奥を気にしいしい田に入る）段六　滝、お咲坊のことが心配かの？",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右奥遠くで微かに人々の罵り騒ぐ声々。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲の中から立ち上る滝三）滝三　（右奥遠くを眺めながら）……お父う、何だか変だ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『はあああ……腰のう、痛さあよう、……五反田のう、長さあああ……』突然右奥遠くで何かが爆発する、えらい響。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右奥角の暗い影の中に黒く拱道が見え、明らかに上の階に向かっていた。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "実ぁ本宿手前の土橋をさ……たしかここからも見えるはず……（右奥へ行き遠くを指して）ほら、あれだ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トタンに右奥遠くでドドドと土橋が水へ落ちる音。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早田、柵門内へいきなり走り込んで行きかけるが、チョイと立停って、右奥屯所の方へ向って）水戸、岡田先生よりの使い早田隼人が通るぞっ！",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（本舞台へ、ビクビクしながら歩いて行き、柵門の辺まで行き、ウロウロしていたが思い切って右奥の方へ向けてビクビク物で小腰を屈めながら）へい、お願い申しまする！",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉村　（パッパッパッと六、七歩右奥へ畳を飛びさがって抜刀）卑怯っ！",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
