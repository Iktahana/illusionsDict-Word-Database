        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "東トルキスタンのヤルカンドにミッション付きの歯医者がいた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは書画骨董の鑑定を学んで、それ等の仲介のコンミッションを取ったり、自分でも売買する方面へ職業を転出して行った。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食後、使が来て、負傷者等がミッション・ハウスへ運ばれて来ている旨を告げた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「え、駄目なの――切符を、十枚も売って上げたのに、少しコミッションよこしてもいいわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果、九州・畿内の各地に、教会・ミッションスクールが出来、ラテン語、ポルトガル語、地理、文学、西洋音楽などが伝へられた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この木を伐らせ、コミッションを得んとする役人ら、毎度合祀を勧めしも、その地に豪傑あり、おもえらく、政府真に合祀を行なわんとならば、兵卒また警吏を派して一切人民の苦情を払い去り、一挙して片端から気に入らぬ神社を潰して可なり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんでもＳ先生の細君の取持だそうだ――」同級生はミッション・スクウル風の男女交際にも、今までの習慣に無い婚約ということにも一切反対の語気で言った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "菅の多くの従姉妹の中には東京や横浜のミッション・スクウルを既に卒業したものもあり、まだ寄宿舎の方で学んでいるものもある。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の奥さんはミッション・スクウルを出た婦人で、先生とは大分年は違うが、取廻しよく皆なを款待した。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカにミッションがあるが日本にはそれがないというばかりではあるまい。",
              "citation": {
                "source": "若い婦人のための書棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳麗玉――ミッション上りの同志で安重根の情婦。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓際の硝子蓋の裡に天正十五年の禁教令出島和蘭屋敷の絵巻物、対支貿易に使用された信牌、航海図、切支丹ころびに関する書類、有名なフェートン号の航海日誌、ミッション・プレス等。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミッション・プレス、その他切支丹関係の書類は、歴史的に興味深いばかりでなく、芥川氏が数篇の小説中に巧に活用し、その芸術的効果を高めているような一種独特な用語、文体で書かれているため、文学的な面白さも充分ある。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミッションの活動は活溌となり経済的、人的に国際的援助がめざましくなってきた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "書庫には、出島｜和蘭屋敷の絵巻物、対支貿易に使用された信牌、航海図、きりしたんころびに関する書つけ、シーボルトの遺物、フェートン号の航海日誌、羅馬綴の日本語にラテン語を混えた独特な趣味あるミッション・プレス等々価値あるものが沢山ある。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら何か秘密な政治上のミッションでも持っているかと云うに、そうでもないらしい。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉は地方のミッション・スクウルからの習慣でずっと礼拝に出ていたのだが、三週間ばかり前からそれをやめた。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、末起は、郊外の邸町で育ち、黒襟の、母や祖母とはそぐわぬ、ミッションスクールに入れられた。",
              "citation": {
                "source": "方子と末起",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、父の勤めの都合で、香港や廣東で幼時をすごし、それからぽんと東京のミッションスクールの寄宿舍に入れられてしまつてゐたのだから……　もう足かけ九年、こんな信州の山のなかにこもつて、何ひとつ厭な顏をせず、寢たつきりの、めんだうな私のおつきあひをして貰つてゐるのは、なんとしてもありがたいことだ。",
              "citation": {
                "source": "わぎもこ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏ですから政治家になりますって言い出して、今度のコンミッション事件の攻撃をやりはじめましてな」「そうですか。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミッションの学校にしばらくいたことがあるからそう言うのではありません。",
              "citation": {
                "source": "男ぎらい",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで母は私の行末を案じて、その頃流行のミッション・スクールに私を入れてくれた。",
              "citation": {
                "source": "楡の家",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのミッション・スクールを出ると、私は程なくこの三村家の人となった。",
              "citation": {
                "source": "楡の家",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時私はひょっくりミッション・スクール時代のお友達で、今は知名のピアニストになっていられる安宅さんにお会いした。",
              "citation": {
                "source": "楡の家",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧亡しても、コンミッションで喜ばれるよりええと云って、空元気をつける栄蔵も、お節の心が今となって、しみじみ味わわれた。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コムミッションの天引は殆不文律になって居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の妻は妹とあるミッションスクールの同級生であったのであるが、卒業後、妹の勧めで私はそれを嫁に迎えることにしたのである。",
              "citation": {
                "source": "盗難",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
