    "definitions": [
      {
        "index": 1,
        "gloss": "to exchange glances",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "側の門弟の一人が、さては、と意味あり気な顔で見合わす。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次も五郎蔵も「可笑しな具合」と顔見合わす。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "進藤等も「何で厶ろうな」と顔見合わす。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時いずこともなく遠雷のとどろくごとき音す、人々顔と顔見合わす隙もなく俄然として家振るい、童子部屋の方にて積み重ねし皿の類の床に落ちし響きすさまじく聞こえぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘二人顔を見合わす。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（胸に縋って、顔を見合わす。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "両方おもてを見合わす。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "侯爵は、かたわらより、「ともかく、今日はまあ見合わすとしたらどうじゃの。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍女等目と目を見合わす。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして正面の饒舌家の女性群と眼を見合わすと、止むを得ぬはずみのように言った。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ名前も知らず、どこに住まっている人か知らぬうちに、度々顔を見合わすので、お玉はいつか自然に親しい心持になった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "対手の男は伴れと顔を見合わすようにした。",
              "citation": {
                "source": "山寺の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十人と集まりて顔見合わすことなしという。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝夕顔を見合わす間柄はそんなに追従いうことの出来ないのは当然である。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "空想で木村を描く事は、木村と顔を見合わす時ほどの厭わしい思いを葉子に起こさせなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務長の後ろには、食堂で葉子と一目顔を見合わすと、震えんばかりに興奮して顔を得上げないでいた上品なかの青年が、まっさおな顔をして物におじたようにつつましく立っていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ忙しいで行きますよ」　とぶっきらぼうにいって事務長が部屋を出て行ってしまうと、残った二人は妙にてれて、しばらくは互いに顔を見合わすのもはばかって黙ったままでいた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、僕たちは遺憾ながらあの作品を『×××』に載せることは見合わすことにした。",
              "citation": {
                "source": "無名作家の日記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "サムとぼくは、顔を見合わすと、うれしくなって、その場に踊り出した。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし今後年｜毎に貢進するに於ては、出征を見合わすも可なり」という意味の文書であった。",
              "citation": {
                "source": "秀吉・家康二英雄の対南洋外交",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一座、顔を見合わすのみ。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "成経　（康頼と顔を見合わす）基康　つつしんでおうけなされい。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "院も互いにただ一目だけ見合わす瞬間が与えられたい、最後の時に見合わせることのできなかった残念さ悲しさから長く救われたいと言ってお歎きになる御様子を見ては、とうていこの夫人のあとにお生き残りになることはむずかしかろうと思われて、そのことをまた人々の歎くことも想像するにかたくない。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は顔を見合わすと、腫ぼったい瞼を上げて、『なんだかぼんやりして来た、一と寝入りして、ゆっくり考えよう……』　と呟くようにいった春生の言葉に、黙って頷いた。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、もしその允許が出ない時には、結局実行を見合わすということになっていた。",
              "citation": {
                "source": "ソクラテス",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は目と目を見合わするのみ。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの点に関してはむしろ学生に述ぶべきことゆえ、今はここにこれを見合わす。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳独秀は阿片を加えた強烈な混合酒の杯を米良の杯に噛みあわすと云った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳独秀は阿片を加えた強烈な混合酒の杯に噛みあわすと云った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
