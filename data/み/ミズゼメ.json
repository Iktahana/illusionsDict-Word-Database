[
  {
    "uuid": "9a54db11-8937-5d0c-b5db-6ebc397f267e",
    "entry": "水責め",
    "reading": {
      "primary": "みずぜめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
