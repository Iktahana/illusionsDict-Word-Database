    "definitions": [
      {
        "index": 1,
        "gloss": "liquid face-whitening makeup",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "香水、クリイム、ピン、水白粉、油、ヘアネット、摺り硝子の扇形の壜、ヘチマ形の壜。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お恵は日焼けのした首に水白粉を塗っていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪を直して、顔へ水白粉なぞ塗って、しばらくそこにうっとりしていた。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨はませた小娘のやうに水白粉をなすりつけて父に見つかり、父は下司といふ言葉を遣つて叱つた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　小皺がよってカサッとしたところに水白粉をつけた顔を信江にむけ、「むかしものやから、この頃の唄はちっともわからんわねえ。",
              "citation": {
                "source": "だるまや百貨店",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうですわね」時子はクリームを伸ばしたあとへ、水白粉を顔へなすりこんでいた手を止めてお幸の方を向いた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女も同じ店で買物をして居たと見え、手に小さい水白粉か何かの瓶を持って居る。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "化粧水と水白粉とだけを薄すらと刷いた横顔が、神々しいほど淋しく見えた。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩型で、折襟のカラーをつけて、こがたい官僚風な大臣であるその政治家の顔を思い出すと、伸子は、おばさまである夫人の敏捷で悧溌な凹み眼と、うすく水白粉のはかれている顔や沈んだ色の紅をさした唇で、軽く、やや口早にげびない蓮葉さでものを云うときの表情を思いおこした。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は沢山な子持ちになってからも、早朝に起きて台所へいくと、引窓の明りの下で、すぐに掌に水白粉を溶いて手早く顔になすっていた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分で結ったらしい、油けなしのじみな髷で、さっと水白粉を刷いただけの薄化粧が、こまかくなにかの花を染めだした紫色の単衣と、涼しげな、いい調和をみせていた。",
              "citation": {
                "source": "滝口",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其頃彼は月に五六度ずつ美顔術師の許に通って、頻りと化粧に浮身を窶し、外出する時は常に水白粉をほんのり着けて、唇に薄紅さえさして居ましたが、もともと容貌が美しかったので、そんな真似をして居ようとは、誰も気が着きませんでした。",
              "citation": {
                "source": "金色の死",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つなさんになんて仰しゃって」　水白粉を手につけながら、かよは横目で万三郎を見た。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「過酸化水素キュカンバー、緑の水白粉、練白粉、花椿香油、過酸化水素クリーム……みんな平凡だな、和製の余りお高くない品ばかりだ。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらの水白粉の同じ指のと比較しますと、不思議によく似てはいますけれど、ですから肉眼で見たのでは区別がつかぬ程ですが、レンズで見ればまるで別人の指紋であることが分ります。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから色白粉ですが、青白い人は薔薇色のを用いるのが普通であるにも拘らず、ここにある水白粉は赤ら顔に適当な緑色のものです。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
