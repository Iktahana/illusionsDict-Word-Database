  {
    "uuid": "e7f37380-639f-5208-acfb-292c7c2ce5e0",
    "entry": "不見転",
    "reading": {
      "primary": "みずてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
