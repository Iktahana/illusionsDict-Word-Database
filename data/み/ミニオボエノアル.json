    "definitions": [
      {
        "index": 1,
        "gloss": "having the memory of having done something oneself",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
