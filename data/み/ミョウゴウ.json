[
  {
    "uuid": "d2712832-0cbd-5ca1-acbf-cafb807a00ae",
    "entry": "名号",
    "reading": {
      "primary": "みょうごう",
      "alternatives": [
        "めいごう"
      ],
      "is_heteronym": false
    },
    "grammar": {
