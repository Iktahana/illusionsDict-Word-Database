        "examples": {
          "standard": [
            {
              "text": "京都にある耳塚を訪れ、戦乱の犠牲となった人々の供養と平和への祈りを捧げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「歴史の教科書で読んだ耳塚の実物を目の当たりにして、当時の凄惨な状況に思いを馳せる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "遠い異国の地から運ばれた数多の耳が埋まっているという耳塚は、静かに悲しみを湛えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "耳塚を経て寺門前茶店に至て撫院を待。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
