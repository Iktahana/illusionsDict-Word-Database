    "definitions": [
      {
        "index": 1,
        "gloss": "to loiter (on the way)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
