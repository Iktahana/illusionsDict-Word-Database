        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……大方眠りつこうとしていると、不意に土間の隅に設けてある鶏舎のミノルカがコツコツコと騒ぎだした。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊「――俺家の鶏ども、白色レグホンだって、ミノルカだって、アンダラシャだって、どいつもこいつも、みんなはあ、黒鶏みてえになってるから。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは実際黒い羽根に青い光沢を持つてゐるミノルカ種の庭鳥にそつくりだつた。",
              "citation": {
                "source": "素描三題",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "真黒いミノルカとレグホンが六七羽のんきにブラついて居る。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰る時にミノルカが生んだのだと云う七面鳥の卵ほど大きい卵を二つくれた。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして翌年の春には、どの鶏舎にも白色レグホンやミノルカがさわがしく走りまわるようになり、生まれる卵の数も日に日に多少ずつ殖えて行った。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　―――――　南と北から家屋が建てこめているため、常に日光に遮られている薄暗い道路の行当りに、芥溜が見える、そこにミノルカではないが大きな黒い一羽の鶏が餌をあさっている。",
              "citation": {
                "source": "あめんちあ",
                "author": "富ノ沢麟太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
