      {
        "index": 1,
        "gloss": "Democratic Liberal Party (1948-1950)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
