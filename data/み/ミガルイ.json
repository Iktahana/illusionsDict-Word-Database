          "literary": [
            {
              "text": "東宮は眼ざとくそれを見つけて、枝移りするその身軽い動作に心を奪われているらしかった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからはもう身軽いそちの身体じゃ。",
              "citation": {
                "source": "くろがね天狗",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――見ると、その又市は、いつの間にか、身軽い武装をして、足拵えも、そのまま、戦場へ出るように固めていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
