        "examples": {
          "standard": [
            {
              "text": "夏の暑い日には、冷たいミルクセーキが最高のご褒美だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは、テーマパークでキャラクター入りのミルクセーキをねだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はバニラ味のミルクセーキを飲みながら、読書を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "小林はミルクセーキをストローでかき回しながら、「計算の手順は頭の中にある。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パイ缶を一つとミルクセーキ一ぱい、早いところ頼むぜ」　と、食堂の空中を泳ぎながら、みんな註文をだす。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスクリームよりも、もうちょっと安いのが、ミルクセーキ。",
              "citation": {
                "source": "氷屋ぞめき",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスクリームも、ミルクセーキも、その名は、そのまま今も残っているが、味は全く違ったものになった。",
              "citation": {
                "source": "氷屋ぞめき",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪屋のランチですませ、ミルクセーキを飲む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
