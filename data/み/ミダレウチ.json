          "literary": [
            {
              "text": "また小銃が、乱れ打ちに聞こえてきた、「ヒ、人殺し」。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒革張りに真鍮の鋲を乱れ打ちに打った、津賀閑山が騒ぎまわっている、あの鎧櫃だ！",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、私の必死の努力を裏切って、指は鍵盤の上を雨の如く乱れ打ちます。",
              "citation": {
                "source": "死の舞踏",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とふり込んでくる脇差の乱れ打ち、閃々、たばしる氷雨か、石火の稲妻。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
