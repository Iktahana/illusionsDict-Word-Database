    "definitions": [
      {
        "index": 1,
        "gloss": "to try and draw someone out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "赤い涎掛を荷の正面へ出して、小児の捌口へ水を向ける。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して姐さんの為にゃなるめえぜ」「姐さんもちっとは浮気をするがいいのさ」「などと傍から水を向けるんだからおそろしい。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "見えるようですわね」　と水を向けると、木村は始めて話の領分が自分のほうに移って来たように、顔色をなおしながら、事務長をそっちのけにした態度で、葉子に対しては自分が第一の発言権を持っているといわんばかりに、いろいろと話し出した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹ごなしに出かけようか」　すると、右門が、まさかと思っていたのに、妙なひとりごとを漏らしながら、ふいと立ち上がりましたものでしたから、水を向けるには向けましたが、案外な気のりのしかたに、かえって伝六があわててしまいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ水を向けると一も二もなく承知して、「オヤまあ」と思う間もなく、ノコノコサイサイ永田秀次郎氏があと釜に座ったのが、丁度十月の初旬のことであった。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」などと水を向けると、「藤田さん――でしたわね、昨夜の人？",
              "citation": {
                "source": "日本橋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう相手に対し、われわれ少人数でぶつかって行くんだから、本当に骨が折れる」「なんかその辺で、差支えない話でも出てきそうなものじゃないか」　と僕がすかさず水を向けると、彼は新しい莨に火をつけながら、「うん、一つだけ話をきかせようかな。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも貴嬢は浦山敷思わないかとか、何とか、ヒョイと軽く戯談を言って水を向けるのだ。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "有線をベースとした「伝送ではどうだ」と水を向ける小林にも、あくまで無線の「極超短波」と答えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と東野は、誘いの水を向ける無意味な声を出した。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて僕も富士見町ばかりでは所詮山の手の土臭く井戸の蛙の譏もうしろめたしと思へる折から、神田連雀町金清楼の宴会にて、講武所｜駒の家の抱小みつといへるが水を向けるをこれ幸ひと、一人先に金清楼を出で小みつが教ゆる外神田佐久間町河岸の船宿小松家といふに行き土蔵づくりの小座敷に女の来るを待ちたりけり。",
              "citation": {
                "source": "桑中喜語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったん緒口さえ見出せば、あとはこっちで水を向ける必要も何もなかった。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん津田の方でも水を向ける用意もなかった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は、まあ、そう急ぐなと言い、たゞなにかしたいというだけなら、自分の関係している製粉会社へ入れてもよいのだからと水を向けるのだが、彼は、それだけは真平であつた。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊豆屋さんに何にか變つたことでも」　平次は誘ひの水を向けるやうに聲を掛けました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "橋場の人魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お駒さん、昨夜は驚いたろう」　ガラッ八が水を向けると、「驚いたよ、お神さんがおっ死んだんだもの」　何を当り前な事を――と言わぬばかりの面構えは、すっかり我が名御用聞の八五郎を憂鬱にしてしまいます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の精",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊豆屋さんに何か変ったことでも」　平次は誘いの水を向けるように声を掛けました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "橋場の人魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "「相変らず集めてますな」　と、水を向けると、骨太の手で、頬のあたりを、さすりながら、「忙しいので遠出は駄目です。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生の三オンスは、天下に有名になりましたね」　と、水を向けると、「は、は、は。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたを驚かせにやって来ます」「ホホウ、そんなに美しい人ですか」　とわしが水を向けると、川村はもう有頂天になって、弁じ出すのだ。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
