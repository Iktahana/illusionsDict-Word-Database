[
  {
    "uuid": "33ce9ea1-42e0-5c48-986d-9ef702914a29",
    "entry": "見通す",
    "reading": {
      "primary": "みとおす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
