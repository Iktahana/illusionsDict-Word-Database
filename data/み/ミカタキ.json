          "literary": [
            {
              "text": "◯眼疾あるために、空を見れば一面に水玉があらわれ、また視力も落ちていて（おまけにややミストあり）今日ははっきり味方機の活動を見る事が出来なくて残念だった。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝方の味方機の消息を調べに来たのであろう。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "味方機だよ」と誰やらが呟く。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "全都は今や敵の投弾と、味方の高射砲と、敵機味方機入り乱れての爆音と、名状しがたき大音響につつまれていた。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝都の防空監視員たちは、照空燈の大光芒集中する白熱の焦点において、巨大なる敵機の周囲を燕のように縦横無尽に飛びまわる味方機の果敢な姿をながめ、手に汗をにぎったのである。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
