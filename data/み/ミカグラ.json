    "definitions": [
      {
        "index": 1,
        "gloss": "kagura (esp. when performed at the imperial palace)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
