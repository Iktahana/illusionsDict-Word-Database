    "definitions": [
      {
        "index": 1,
        "gloss": "to (happen to) see",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "因に、こうした景趣の村は関西地方に多く、奈良、京都の近畿でよく見かける。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主婦や娘は台所で立働いているのを裏口の方から見かける事があるが、一体に何処となく陰気なこの家内のさまは、日を経るに従うて自分の眼に映る。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹木の幹に「登山記念、何月何日、何某」とナイフで彫つてある文字を見かけることさへあるが、私には笑へない。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "市中の堀などでよく見かけるやうな、船を家として渡つて行く家族の一つである。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は真昼の百貨店でよく彼女を見かける。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃は日本人の顔がだんだんに西洋人に似てくるようで、銀座などを歩いているとあちらの映画スターに似たような顔つきをした男女を見かけることも珍しくないがただ髪の毛だけは、当り前のことだが皆申し合せたように真黒である。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "町には平凡な商家が並び、どこの田舎にも見かけるような、疲れた埃っぽい人たちが、白昼の乾いた街を歩いていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那や御領ンさんに顔を合すのがおっかなくって、向うから来るのを見かけると、わざと道を外らした。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで注意して見ると、近ごろ特に欧州大戦が始まって後に、三越などで見かける染物の色彩が妙に変わって来たような気がする。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし大通りでないその裏通りの呉服屋などの店先には、時たま純日本的に涼しい品を見かけることがある。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山梨県は、もともと甲斐犬の産地として知られているようであるが、街頭で見かける犬の姿は、けっしてそんな純血種のものではない。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこんな場合を見かけるとなんだか可笑しくもありまた気の毒な気がした。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "市中の堀などでよく見かけるような、船を家として渡って行く家族の一つである。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、彼女は屡彼の姿を気にとめて見かけるようになった。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "アレキサンダー君は、その自ら名告るところに依れば、旧露国帝室付舞踏師で、革命後上海から日本へ渡って来たのだが、踊を以て生業とすることが出来なくなって、今では銀座裏の、西洋料理店某でセロを弾いていると云う、つまり街頭で、よく見かける羅紗売りより僅かばかり上等な類のコーカサス人である。",
              "citation": {
                "source": "ああ華族様だよ　と私は嘘を吐くのであった",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ彼は、時折り若い女の姿を見かけると、思い出したように立ち止って、ジット眼を据えた。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りかけたのは午後の一時頃であったが、お宮の裏の近道に新しく出来たお湯屋を見かけると、お米はチョット這入ってみたくなったので、誰も居ない番台の上に十銭玉を一つ投げ出して板の間に上った。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは見当がむずかしくてなかなかうまく行かなかったのであるが、しだいに三島のまちで破れた舌をだらりとさげたまま休んでいる水車を見かけることが多くなった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の姿を見かけると、食もの屋の家の中から声がかけられるのであった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のその姿を度々見かける村の者は、長年、彼の豪勢へ持つてゐた反感を、この頃、幾何の同情に変へて来た。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎でよく見かける風景だが、麦畑で若いお百姓が、サトやああい、と呼ぶと、はるか向うでそのお里さんが、はああい、と実になんともうれしそうな恥ずかしそうな返事をするね。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、葛岡の姿を園芸場で見かけることはあるけれども、何だか彼からわたくしを避けるようにして横道へ切れたり、廻れ右をしてまた元へ引返してしまう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは町への出入りに二人の姿を見かけると、知らず／＼和やかな眼ざしを差向け、少しの距離を置いて同じ方向に歩み進んで行くのでございました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうときわたくしを見かける場合には、いつか地蔵堂へ襲って来てわたくしの眼の前で演じたと同様な破れかぶれの捨鉢な所作を繰返します。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文吉はわたくしの姿を見かけると、「やあ、ぼんやりのお蝶」　と呼びかけます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い娘を見かけると常司は、「昼から粘土打ち出てくれろよ」　と怒鳴ります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々出猟する彼らの或る者の姿さえ見かけることがあるともいう話であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そのかごのふたをあけて見かけるはずみに、中からふいにピエロがとび出して、片方の手にとッつかまりました。",
              "citation": {
                "source": "小犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の数こそちがっているが、それは彼が毎日見かける趣であった。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかげでおいしい朝の煙草が一服吸える」　父はそこで私に珍らしく微笑みかけるのであった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
