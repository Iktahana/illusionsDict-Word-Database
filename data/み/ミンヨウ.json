[
  {
    "uuid": "76107ac5-7b2a-5c61-9ac2-c636469bbfa1",
    "entry": "民謡",
    "reading": {
      "primary": "みんよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
