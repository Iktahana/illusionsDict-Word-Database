          "standard": [
            {
              "text": "初めて聴く曲なのに、どこか耳馴染みがあるメロディで、すぐに口ずさむことができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このブランドの名前は耳馴染みがいいので、一度聞いただけで覚えてしまった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幼い頃に母が歌ってくれた子守唄は、私にとって世界で一番耳馴染みのある音だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "寿女も耳馴染みで「奥住の嬢さん」と呼ぶ。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
