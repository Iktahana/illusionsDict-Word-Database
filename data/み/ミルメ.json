[
  {
    "uuid": "5f0fbe53-c490-5700-bc21-154f852360ae",
    "entry": "見る目",
    "reading": {
      "primary": "みるめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
