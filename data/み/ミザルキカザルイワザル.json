        "examples": {
          "standard": [
            {
              "text": "「見ざる聞かざる言わざる」の精神で、余計なことに口出ししないようにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はトラブルを避けるために、「見ざる聞かざる言わざる」を貫いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "上司に言われた「見ざる聞かざる言わざる」という言葉の意味を深く考えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "猿が三疋、見ざる聞かざる言わざるの正反対をやっている。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにお母さんは文一君の好いところ丈け知っていて悉く謹直な片山さんの感化だと思い込むから、例の見ざる聞かざる言わざるの反対を行く三猿亭主人がお気に召さない。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
