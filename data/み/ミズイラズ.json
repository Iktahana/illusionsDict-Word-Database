    "definitions": [
      {
        "index": 1,
        "gloss": "(being) by oneself",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
