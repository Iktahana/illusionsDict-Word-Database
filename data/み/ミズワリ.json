          "literary": [
            {
              "text": "水割りウィスキィは？",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "グレグソンなどは椅子から立ち上がった拍子に、水割りの残りをひっくり返してしまった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "担当のＭ島ノンダクレＹ子に「それこそ問題意識と結論だけあって、論旨の展開という中身がありませんネ」と水割り片手に突き返されるのが落ちである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとした口実があっても、強い｜水割りラムが振舞われたりした。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は吐き出したが、増さんはうまそうに、頭だの骨だの尻尾だの、一つ一つ丹念に噛み味わいながら、私以上にゆっくりと時間をかけて、燗をした水割り焼酎を啜るのであった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウイを出して、水割りで飲み出す。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
