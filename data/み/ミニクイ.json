[
  {
    "uuid": "92874bc8-eff4-56df-a15a-1af7d9f1065a",
    "entry": "醜い",
    "reading": {
      "primary": "みにくい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
