  {
    "uuid": "34a6a370-fe5a-502d-b187-44bdcca445ab",
    "entry": "三貴",
    "reading": {
      "primary": "みき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Miki Corporation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "嘉三貴様血迷ったな！",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん、すでにお察しの如くにこの三貴人を動かした者が実際に君が知りたい人名であろうが、それはたぶん誰にも知られていないだろう。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十四　ロッテナム美人術",
                "note": "青空文庫"
              }
            },
            {
              "text": "三貴人を動かして開店と同時に名流婦人が法外の値を物ともせずに飛びつくような効果的な後援を貴人直々してくれるには相当の運動資金が必要であろう。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十四　ロッテナム美人術",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、高価きわまる手術費と香水の値段だから、ロッテナム夫人のモウケは一ヶ月でも少なからぬ額であったと想像しうるが、三貴人を動かした人がこれによっていかに益するところがあったか、これが我々の大いなる謎なのさ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十四　ロッテナム美人術",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵の目的がスパイと分れば我々が蔭の人物をつきとめる目安もつくかも知れないが、ロッテナム夫人を使い、三貴人をうごかして、たった一ヶ月足らずでたちまち馬脚を現したといういろいろの事実の組み合せからは、我々外交官にはどうしても事を謀った人間の目的を知ることができないのだ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十四　ロッテナム美人術",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬を待つひと萩原朔太郎こほれる利根のみなかみに、ひねもす銀の針を垂れ、しづかに水に針を垂れ、さしぐみきたる冬を待つ。",
              "citation": {
                "source": "冬を待つひと",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "開墾宮沢賢治落ちしのばらの芽はひかり樹液はしづにかはたれぬあゝこの夕つゝましくきみと祈らばよからんをきみきたらずばわが成さんこの園つひにむなしけん西天黄ばみにごれるに雲の黒闇の見もあへず",
              "citation": {
                "source": "開墾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃此の国の詩壇は傷ましくも荒みきつて居た。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして尚さらいけないことには、そのときの太宰の服装がそっくり、馬場のかねがね最もいみきらっているたちのものだったではないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで例へば欧羅巴の如きレリジョンの確立してゐる所では、それに批評の発達した所では、批評家は個人的に言葉を使用しないで社交的圏を相手に話すので、言葉は専ら比較によつて成立つ品性についての言葉が人の頭に滲みきつて、そのため驚きはその滲みきつた言葉で片附られ勝になるといふことは想像出来るでせう。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "木曾川は底まで澄みきつて、両岸の紅葉を映してゐる。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩秋の陽光は澄みきつた高山性の空気を透して暑く、一同を汗ばませた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気は澄みきって、まるで水のやうに通りや店の中を流れましたし、街燈はみなまっ青なもみや楢の枝で包まれ、電気会社の前の六本のプラタヌスの木などは、中に沢山の豆電燈がついて、ほんたうにそこらは人魚の都のやうに見えるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがどうも仕方ないことは、私たちのイギリス海岸では、川の水からよほどはなれた処に、半分｜石炭に変った大きな木の根株が、その根を泥岩の中に張り、そのみきと枝を軽石の火山礫層に圧し潰されて、ぞろっとならんでいました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつにそのかすかな音が丘の上の一｜本いちょうの木に聞こえるくらいすみきった明け方です。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの記事がもし半分でも事実とすると、東京市の公共機関の内部には、ゆるみきりにゆるんでしまって、そうして生命を亡って腐れてしまった部分がいくらかはあると見える。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日は華厳の滝壺に下りんとて長塚も我もいさみきおう。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "水のように澄みきった秋の空、日は一間半ばかりの辺に傾いて、僕等二人が立って居る茄子畑を正面に照り返して居る。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉露水は、今の氷水よりもずつとつめたく、清水のやうに澄みきつてゐる。",
              "citation": {
                "source": "ラムネ・他四編",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るのちにそれぞれ澄みきるのである。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、瞳にもみえざる、このかすかな卵のかたちは楕円形にして、それがいたるところに押しあひへしあひ、空気中いつぱいにひろがり、ふくらみきつたごむまりのやうに固くなつてゐるのだ、よくよく指のさきでつついてみたまへ、春といふものの実体がおよそこのへんにある。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兼ねてより心に恋い焦れし男、前にして雪枝の面は嬉しさ包みきれぬ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、母が包みきれない嬉しさを顏に表しながら武井さんに長い看護の禮詞を述べてゐるのや、武井さんがしみじみした聲で母に祝ひ詞を返してゐるのにぢつと耳を傾けてゐた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は思はずぎよつとして、深い紺青に澄みきつた星空を見上げた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」嫁はおかしさを包みきれぬらしく笑った。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "用材出しを手伝ったお祝いのしるしに、おみき（酒）を振る舞うのは一つの習慣だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜はたらきまたはいたつきて、　　もろ手ほてりに耐へざるは、おほかた黒の硅板岩礫を、　　　にぎりてこそはまどろみき。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気は澄みきって、まるで水のように通りや店の中を流れましたし、街燈はみなまっ青なもみや楢の枝で包まれ、電気会社の前の六本のプラタヌスの木などは、中に沢山の豆電燈がついて、ほんとうにそこらは人魚の都のように見えるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちど沈めば、ぐうとそれきり沈みきりに沈んで、まさに、それっきりのぱあ、浮ぶお姿、ひとりでもあったなら、拝みたいものだよ。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、この、しっぽの動きも、注意して見ているとなかなかに複雑で、容易に読みきれるものではない。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            }
          ]
        }
