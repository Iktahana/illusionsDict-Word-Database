    "definitions": [
      {
        "index": 1,
        "gloss": "to come within sight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "フランシスとその伴侶との礼拝所なるポルチウンクウラの小龕の灯が遙か下の方に見え始める坂の突角に炬火を持った四人の教友がクララを待ち受けていた。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千鶴子は樹の間から道が少しでも見え始めると、すぐまた自動車の音のしない反対の奥の方へ自分から進んだ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　写真を芸術だと思わぬ久慈の口吻に、塩野はきっと対抗した気構えを見せたが、ノートル・ダムの尖塔が見え始めるとそれもすぐ忘れたらしく、サン・ミシェルの坂の方へ出ていった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯の消えている千鶴子の部屋の窓が五階の上に見え始めると、胸がそわそわして来て胸を一寸揺ってみた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の明けるのは琵琶湖の見え始めるころだとすると、少くとも石山あたりで起きていなければ、すぐ逢坂山にさしかかる。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この崩れかかった男の内部は、我々と全然異なった組織ででき上がっているのであろうか、尾田には少しずつ佐柄木の姿が大きく見え始めるのだった。",
              "citation": {
                "source": "いのちの初夜",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "女といふものは、美しいと見える時にはどこまでも美しく、むしやぶりつきたいやうな欲望を男に起させるが、しかし一たび不潔に見え始めると、もう胸が悪くなるほど不潔に見えて来るものである。",
              "citation": {
                "source": "道化芝居",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右の山は次第に相迫つて前面に聳る比叡山はいよ／＼近くいよ／＼險しく見え始める。",
              "citation": {
                "source": "十年振",
                "author": "一名京都紀行",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それまで見えなかったものが見え始める。",
              "citation": {
                "source": "かき",
                "author": "УСТРИЦЫ",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑の芝生の中に、白いパラソルの列がそろそろ見え始めると、もう夏休みになったという気がしたものである。",
              "citation": {
                "source": "楡の花",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの核は見え始めるとどんどん生長して、間もなく顕微鏡下でその形と構造とがよく見える位に発達する。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月に入って、日記に初めて宗教という文字が見え始める。",
              "citation": {
                "source": "『団栗』のことなど",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次は急に声を掛けもならず、暫らく部屋の隅、ガラクタの蔭に控えておりましたが、やがて日向を歩いて来た仁助老人の眼が馴れて、家の様子が見え始めると、「おや、銭形の親分じゃありませんか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々、痩せたブスのフィッチ嬢を見ると、カーターが見るのと同じ奇跡的な美貌がちらと見え始める。",
              "citation": {
                "source": "観点",
                "author": "THE POINT OF VIEW",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑いなくそんな雰囲気のせいで、山脈に接近するに従い、また折り重なって起伏する麓の丘が見え始めるのに従い、次第に乳白色の輝きを増す絶頂から噴出してくる奇怪な蜃気楼に対する私の反応は悪化したのだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台右手奥の方にも遠い連山が見え始める。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "五駅走ると海が見え始める。",
              "citation": {
                "source": "田園情調あり",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は兵隊さんが若く見え始めるほど自分の年が寄って来る。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その町への道路が見え始める少し手前で、カメハメハ・ハイウエイを降りる。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣いているようにも見え始める頃、笑いは少しずつおさまった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく他人の拘束によるのでも、また突発的な気分の興奮によるのでもなく、むしろその信仰箇条の明記するところによって、彼らは或る年齢に近づくにしたがい、また何かの病気のきざしが見え始めると、自ら自分のために火あぶり台をしつらえさせ、その上にきれいに飾った床を作らせる。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊吹山らしい山影がうっすら遠くに見え始める。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "断がいの上から、はるかに水平線がみえはじめる。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは田園と化した平城京｜址を過ぎて行くと、まず薬師寺の東塔がみえはじめる。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "供の弥九郎はそれまでものも云えず、足も地に着かぬようすだった、然し明り障子に灯影のさしている家などがみえはじめると、ようやく生気をとり戻したとみえ、急にわっはっはと笑いだした。",
              "citation": {
                "source": "山だち問答",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
