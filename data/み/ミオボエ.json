    "definitions": [
      {
        "index": 1,
        "gloss": "memory (of having seen something or someone before)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つまり思念だけでは足りない、思念と物質とが一緒になつて働いてゐるところとか、その結果を見覚えるとかすることが勘甚なのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛川と云えば佐夜の中山はと見廻せど僅かに九歳の冬｜此処を過ぎしなればあたりの景色さらに見覚えなく、島田｜藤枝など云う名のみ耳に残れるくらいなれば覚束なし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の御院殿坂を捜して墓地の中を歩いているうちに鉄道線路へ出たがどもう見覚えがない。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上根岸百何番とあるからこの辺かと思うが何一つ昔の見覚えのあるものはない。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺へ引き取られたこどもの時分から、魚に餌をやりつけているので、魚の主なものは見覚えてしまい、友だちか兄弟のように馴染んでしまっていました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に逢った場合と同じように無帽で、同じような五、六歳くらいと思われる男の子を背負っているが、どうも男の顔形にははっきりした見覚えはないので、前に自分の逢ったのと同人であるかどうか、何しろ暗いのでよくは分からない。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その男になにか見覚えになる特徴はなかったか」と裁判長が夕刊売りに尋ねる。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "千住大橋まで行って降りてはみたが、道端の古物市場の外に見るものはないので、すぐに「転向」してまた上野行に乗込み、さて車内の乗客を見渡すと、先刻行きに同乗した見覚えの顔がいくつも見つかったそうである。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が八度の近視眼鏡を二つ掛ける吾輩は、とう／＼其顔を能く見覚える事も出来なくて終つた。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "指頭の渦紋　人間の指の渦紋の形は生れ落ちてから死ぬるまで変らないもの故、人間の見覚えをするには最もよい目印しである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『僕は全くの旅客でこの土地には縁もゆかりもない身だから、知る顔もなければ見覚えの禿げ頭もない。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔明治音楽界などの演奏会で見覚えのある楽人達の顔を認める事が出来たが、服装があまりにちがっているので不思議な気がするのであった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんまり、さい／＼持って来さすせに、税関で顔を見覚えられとったんだよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっか顔に見覚えのある巡警だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、同村の、見覚えのある、顔の輪郭だけは残っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、以前見覚えた、両眼真黄色な絵具の光る、巨大な蜈※が、赤黒い雲の如く渦を巻いた真中に、俵藤太が、弓矢を挟んで身構えた暖簾が、ただ、男、女と上へ割って、柳湯、と白抜きのに懸替って、門の目印の柳と共に、枝垂れたようになって、折から森閑と風もない。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一足先へ駈出して、見覚えた、古本屋の戸へ附着いたが、店も大戸も閉っていた。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見覚えある板塀のあたりに来て、日のややくれかかる時、老夫はわれを抱き下して、溝のふちに立たせ、ほくほく打えみつつ、慇懃に会釈したり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "問われて室内を※しながら、「さよう、どこか見覚えているような気持もするです。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づくと帽子を脱いで、その黒い鼻のヴェールを取りはずしはしたが、いっこう見覚えのない顔である。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女将は、笠井さんを見覚えていない様子であった。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の両側に立っている二人の美男子に、見覚えがあるでしょう？",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、前にしゃがんでいる二人の婦人にも、見覚えがあるでしょう？",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして須利耶さまは、たしかにその子供に見覚えがございました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "農家の門を外に出てみるとはたして見覚えある往来、なるほどこれが近路だなと君は思わず微笑をもらす、その時初めて教えてくれた道のありがたさが解るだろう。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには僕が考えていたとおり雑記帳や鉛筆箱とまじって見覚えのある絵具箱がしまってありました。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足音はやや斜め後ろから間近になると突然私の眼の前に、野花をうざうざするほど摘み集めた見覚えのある経木の手籃が放り出された。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にあの三｜間間口一杯の布袋が小山のような腹を据えて、仕掛けだろう、福相な柔和な目も、人形が大きいからこの皿ぐらいあるのを、ぱくりと遣っちゃ、手に持った団扇をばさりばさり、往来を煽いで招くが、道幅の狭い処へ、道中双六で見覚えの旅の人の姿が小さいから、吹飛ばされそうです。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お忘れ下さるのが功徳でござりますよ、はい、でも私はざっとお見覚え申しております、たしか……滝の家さんのお妹御……」「ええ、小女い方よ、お爺さん、こんなになって……お可懐いのね。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "却って宿屋で酒を飲みおぼえたり女にからかったりする事を知り初める位が結局です。",
              "citation": {
                "source": "旅行の今昔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
