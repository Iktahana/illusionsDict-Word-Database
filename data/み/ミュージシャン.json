        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "正装をしたセッション・ミュージシャンたちが、テナーサックス、トランペット、トロンボーン、ヴァイオリン、チェロをかかえて、準備をしている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人から離れて、セッション・ミュージシャンのむこうにリンゴが見える。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミュージシャンか物書きか、なにかそうした仕事で食っていきたいと考えていた藤井は、大学の軽音楽部でバンドを組み、放送作家の見習いとしても働きはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は此の塔の訪問者の案内役であり、エレベーターのコンダクターであり、正午と六時のチャイムのミュージシャンでもあるのだ。",
              "citation": {
                "source": "バークレーより",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "云うまでもなく、此のチャイムのミュージシャンは、チャールス・ビ・ワイカーと云う誠実な高塔守である。",
              "citation": {
                "source": "バークレーより",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミュージシャンの宝達奈巳（http://astromedia.cocolog-nifty.com/）さん（微分音とコブシを使いまくる民族音楽的なヴォーカルをエレクトロに乗せる（ぶつける？",
              "citation": {
                "source": "怪奇小説の執筆についての覚書",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村は若い頃ハードロックのギタリストで鳴らした男で引退後はもっぱら裏方に回り、新人バンドの発掘と育成、レコーディングのプロデュース、ツアーのプロモーター関係を主な仕事としていたが、元ミュージシャンだったキャリアを生かしコンサートの音楽監督や曲のアレンジなども担当することがあった。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上一流ミュージシャンの演奏による数億種類ものＢＧＭの中から、コンピュータがその場にふさわしい曲を適宜に選択するので、気分はもうファンタジーランドの主人公！",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルに出演しているミュージシャンたちのディレクターをやってますし、地元でときどきまだ演奏もしてるようです。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイケルをサポートする地元のミュージシャンたちが、バックの演奏部分の練習をしていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミュージシャンたちの調子は、やがて完璧に仕上がった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミュージシャンたちが位置についた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "コントロール・ルームのディレクターが、マイクをとおしてミュージシャンひとりひとりに呼びかけた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "古くからの友人であるミュージシャンたちの絶妙のサポートを得て、マイケルは夢のように歌った。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタジオのなかでミュージシャンたちがマイケルを囲み、肩を叩き抱き合い、祝福した。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もがマイケルとミュージシャンたちを讃えた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミュージシャンたちが、たくさん来ていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "若いミュージシャンも大勢いた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "全員が歌い、ミュージシャンが思い思いにソロをとった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミュージシャンたちがステージにあがった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れがたきアイランド・ボーイズのために、これから海に出て黙祷します」　ミュージシャンたちが歌い始めた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カウボーイであると同時に、パニオロはミュージシャンでもある。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "スティール・ギター、十二弦ギター、ウクレレ、ハワイアン・パーカッション、普通のギター、ベースと、手近な楽器はなんでもこなす、練達のミュージシャンだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "パニオロの家のテラスで、パニオロや息子たち、そして近くに住むミュージシャンの友人たちが、今夜も音楽を作っている。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの人たちとおなじく彼もハワイ屈指のミュージシャンであり、硬い張りのあるバリトンで歌うカントリー・ソングは、この二十年、地元のジュークボックスで人気を保ち続けている。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラインハートは有名な白人のミュージシャンだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "マニュエルの仲間のミュージシャンたちが、昔の歌をいくつも演奏した。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人のミュージシャンたちを総動員したオリジナル・スコアが、抜群の効果をあげていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このレイモンドは、ハワイ屈指の伝統音楽のミュージシャン、マーカス・カアイラウの次男だ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタジオ・ミュージシャンとして、ピアノを中心とする鍵盤楽器を演奏するのが仕事だが、彼女自身としては歌人であることが拠りどころになっている。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
