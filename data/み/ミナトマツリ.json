        "examples": {
          "standard": [
            {
              "text": "今年の港まつりは、海上からダイナミックに打ち上げられる数千発の大輪の花火が最大の目玉だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "港まつりのパレードには、地元の小中学生や伝統的なお囃子のチームが趣向を凝らした山車で参加する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "屋台がずらりと立ち並ぶ港まつりのメイン会場は、浴衣姿の若者や家族連れで埋め尽くされていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "神戸は今港まつり、ワイ／＼さわぎである。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "船と陸とには、おしげもなく灯火がてんぜられ、まるでみなとまつりの予行演習であるかのようにおもわれた。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
