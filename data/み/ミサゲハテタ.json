        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いよいよ見下げ果てたやつだ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "侯爵伯爵を罵る口から能くもそんな言葉が出る、矢張人物よりも人爵の方が先生には難有いのだろう、見下げ果てた方だと口を衝いて出ようとする一語を彼はじっと怺えている。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "途方もない、乱暴な小僧ッ児の癖に、失礼な、末恐しい、見下げ果てた、何の生意気なことをいったって私が家に今でもある、アノ籐で編んだ茶台はどうだい、嬰児が這ってあるいて玩弄にして、チュッチュッ噛んで吸った歯形がついて残ッてら。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何といふ自分は見下げ果てた心の持主だらう、と先刻から密かに苛責の念に苛まれてゐた心が頼りなく流れ滾れたのだつた。",
              "citation": {
                "source": "鞭撻",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたが、そんな見下げ果てた了見だからあたし独りが家中の者から馬鹿にされるんです。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを何ぞや天主ともあろうに、たとい磔木にかけられたにせよ、かごとがましい声を出すとは見下げ果てたやつでございます。",
              "citation": {
                "source": "おしの",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "心気粗暴、眼光恐ろしく、動もすれば人に向て怒を発し、言語粗野にして能く罵り、人の上に立たんとして人を恨み又嫉み、自から誇りて他を譏り、人に笑われながら自から悟らずして得々たるが如き、実に見下げ果てたる挙動にして、男女に拘わらず斯る不徳は許す可らず。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は範実や義輔よりも、見下げ果てた意気地なしだ。",
              "citation": {
                "source": "好色",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼時妾｜目前り、雄が横死を見ながらに、これを救けんともせざりしは、見下げ果てたる不貞の犬よと、思ひし獣もありつらんが。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合になってかくのごとく限りなき母の愛情の前に坐っていながら、四拾や五拾の金額を少なく申出る事によって幾分なりともなお自分の面目なさを軽くしようなどとは実に何という見下げ果てた根性だ！",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "見下げ果てた心事であるが、十九の娘にそこまでは見抜かれまいと心得て、とりすましてゐる。",
              "citation": {
                "source": "破門",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "）静かに鼻の頭をこすって、　――尊公は見下げ果てたる愚人じゃよ。",
              "citation": {
                "source": "木枯の酒倉から",
                "author": "聖なる酔っ払いは神々の魔手に誘惑された話",
                "note": "青空文庫"
              }
            },
            {
              "text": "）静かに鼻の頭をこすつて　――尊公は見下げ果てたる愚人ぢやよ。",
              "citation": {
                "source": "木枯の酒倉から",
                "author": "――聖なる酔つ払ひは神々の魔手に誘惑された話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "見下げ果てた奴め、何と云ふ恐しい目にあふものぢや。",
              "citation": {
                "source": "クラリモンド",
                "author": "LA MORTE AMOUREUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人は見下げ果てた人種だつて云つたさうだ。",
              "citation": {
                "source": "昨今横浜異聞（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら僕は時どき自分が憎らしくなり、われながら見下げ果てた奴だと思うからだ。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "降伏の引出物に、敵将の妻を一夜貸せなどと、見下げ果てた犬侍だ。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "見下げ果てた……」　源三郎、懐中の右手がおどり出て、左の腰際へ走ったのは、いつものくせで、刀の柄に、手をかける心。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ瞬間にしろ、あんな妄念にこころをゆだねるとは、俺は何たる見下げ果てた男であろう。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは嘸ぞ私を見下げ果てた女だとお蔑みになっていらっしゃるでしょうね、でもそうするより仕方がなかったんですのよ』『あなたは御自分が金庫から持ち出して秘しておいて、それを探し出させ、私の手で御主人に返させようとお思いになって、私をここにお呼び寄せになったのですね』『すみません。",
              "citation": {
                "source": "機密の魅惑",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見下げ果てた男だと思つた婿の伊勢屋新兵衞が、私などよりは餘つ程良い男と判つて、私は穴へでも入り度い心持で御座いました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "佛喜三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見下げ果てた男だと思った婿の伊勢屋新兵衛が、私などよりはよっぽど良い男と判って、私は穴へでも入りたい心持でございました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "仏喜三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、それが人の子の道か、見下げ果てた奴！",
              "citation": {
                "source": "女記者の役割",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に下劣きわまる――なんという見下げ果てた気持だ！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩さん会へ行く伊達男が、通りすがりの馬車から泥をワイシャツの胸にかけられ、これ以上惨めで無力で見下げ果てた姿と、トリガーセンは同じだ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という見下げ果てた！",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見下げ果てた、意気地なし！",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかいうて、それほど綿貫恋しいのんかいうたら、精神的にはええ思うとこ一つもない、顔見るのんさいムカムカするような気イして、卑しい奴ッちゃ、見下げ果てた奴ッちゃ、いう風に、お腹の中では常時激しいに軽蔑してる。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお、おまえ、どうしてここへ」「や、山根のために、他国へ連れて行かれるところでございました」「そうか」　蝙也は手早く女の縛めを解放つや、「武太夫の手引をする者が仙台にあると聞いたが、それでは山根のやつだったのか、――それにしても俺を斬ろうなどとは見下げ果てたやつだ。",
              "citation": {
                "source": "松林蝙也",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇津木さんよりも、お前さんの根性が見下げ果てた、さもしさ、あさましさなんだ」　木ベエは蒼ざめて目を怒らせたが、反撃の言葉に窮した様子であった。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
