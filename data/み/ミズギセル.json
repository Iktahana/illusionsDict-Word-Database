        "examples": {
          "standard": [
            {
              "text": "異国情緒あふれるカフェで水ぎせるを体験した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "水ぎせるの煙がゆったりと立ち上る様子は、とても幻想的だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人が持っているアンティークの水ぎせるは、見事な彫刻が施されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "つまさき立ちで背のびして、キノコのへりからのぞきこむと、目にとびこんできたのが、こっちを向いた大きな青虫、すわりこんでうでを組み、ひそやかに水ぎせるをふかして、こちらにも何にも気にとめるそぶりさえない。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくだまったまま目を合わせていたんだけど、とうとう青虫が口から水ぎせるを外して、けだるそうに声をかけてきた。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくのあいだ、もの言わず水ぎせるをぷかぷかさせてたんだけど、やがてうでをほどいて、ふたたび口からきせるを外して、ひとこと。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と青虫は口に水ぎせるをくわえて、またふかし始める。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度もアリスは、相手がまた話す気になるまでじっと待ってね、数分すると青虫は口から水ぎせるを外して、キノコから下りて、草むらへとくねくねと立ち入り、去りぎわのすて言葉。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまさき立ちで背のびして、キノコのへりからのぞきこむと、目にとびこんできたのが、こっちを向いた大きな青虫、てっぺんにすわりこんでうでを組み、ひそやかに水ぎせるをふかして、こちらにも何にも気にとめるそぶりがちっともない。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　青虫の教え　青虫とアリスはしばらくだまったまま目を合わせていたんだけど、とうとう青虫が口から水ぎせるを外して、うつらうつらけだるそうに声をかけてきた。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくのあいだ、もの言わずぷかぷかやってたんだけど、やがてうでをほどいて、ふたたび口から水ぎせるを外して、ひとこと。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものの数分すると青虫は口から水ぎせるを外して、数度あくびもして身をゆすぶって。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            }
          ]
        }
