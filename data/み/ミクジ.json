    "definitions": [
      {
        "index": 1,
        "gloss": "fortune slip (usu. bought at a shrine)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
