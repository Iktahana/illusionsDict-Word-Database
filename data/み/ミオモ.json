[
  {
    "uuid": "15ef7da3-f019-564f-879d-8f326a5b4955",
    "entry": "身重",
    "reading": {
      "primary": "みおも",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pregnant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "妻はそのころもう身重になっていたので、この五月には初産という女の大難をひかえている。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた身重になるつもり！",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "行一も水道や瓦斯のない不便さに身重の妻を痛ましく思っていた矢先で、市内に家を捜し始めた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と海野は少しく色｜解てどかと身重げに椅子に凭れり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は其の節、身重なんでございましたの……ですから、淺ましい處を、お目に掛けますのが情なくつて、つい、引籠つてばかり居ました所、何ですか、あの晩は心持が、多時庭へも出られなからうと思はれましたので、密と露の中を、花に觸つて歩行いて見たんでございます。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と海野は少し色解てどかと身重げに椅子に凭れり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "身重で、時には面やつれがして見えるが、そのせいか何かコケチッシュにも感じられる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　そのうちに、火遠理命が海のお宮へ残しておかえりになった、お嫁さまの豊玉媛が、ある日ふいに海の中から出ていらしって、「私はかねて身重になっておりましたが、もうお産をいたしますときがまいりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇后は、そのときちょうどお身重でいらっしゃいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『上皇のお側に仕へてゐた上臈がおあとを慕うて島へ渡つて參り、程なく身重になつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女は以前両国辺のある町人の大家に奉公しているうちに、そこの主人の手が付いて、身重になって宿へ下がって、そこで女の子を生んだのです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "少年少女の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜をかかる愚鈍なものとしたのは、主として上述の川に落ちて死ぬほど、身重く動作緩慢なりなどいう方面から起っただろう。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし共に交会せば、身重罪を犯し人の善法を滅す。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その赤い山襞のあちこちに遥々都から御あとを追うて来た御側の女がやがて身重になって籠ったあとの森だとか、同じくおあとを慕われた姫宮がどうなされたとかいう様な伝説のあとを幾箇所も見てすぎた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊寛は、身重くなった妻を嘗めるように、いたわるのであった。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "診察をすると、夫人はやはり妊娠九ヶ月の身重でしたが、それと同時に夫人は肺結核に罹って居たのであります。",
              "citation": {
                "source": "印象",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、身重な病人に何が出来ましょう。",
              "citation": {
                "source": "印象",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　　　＊　　　　　＊「開業三周年を祝して……」と新吉の店に菰冠りが積み上げられた、その秋の末、お作はまた身重になった。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時身重であったその女が、作を産おとしてから程なく、子供を弟の家に置去に、どこともなく旅へ出て行った。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　不屈な闘志――ロンドン時代――　身重なイエニーは肉体と精神との苦痛をこらえてロンドンにたどり着いた。",
              "citation": {
                "source": "カール・マルクスとその夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "名もない、一人の貧しい、身重の女が全身から滲み出しているものは、生活に苦しんでいる人間の無限の訴えと、その苦悩の偽りなさと、そのような苦しみは軽蔑することが不可能であるという強い感銘とである。",
              "citation": {
                "source": "ケーテ・コルヴィッツの画業",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍には、身重な母親が張り板をよせかけ、指先を真赤にしながら、古い裏地を張っている。",
              "citation": {
                "source": "光のない朝",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はしかれ女は身重なると綿入れ着たるとはいとど惨めに浅ましく、袷より単衣のころ最も美しく懐かしきものだ。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "目がさめて後お妃は、喉の中に何か固くしこるような、玉でもくくんでいるような、妙なお気持ちでしたが、やがてお身重におなりになりました。",
              "citation": {
                "source": "夢殿",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、身重になつてしまつたといふ落度があつたので、私の家にゐても姉の私の母へは遠慮がちだつた。",
              "citation": {
                "source": "日本橋あたり",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、嫁はあの通り体が弱い上に身重だし、肝腎のきよ（女中の名）はぐずで間に合わないし、おまけに私の手はこんなのだからねえ……」　そう言われると私も困ったが、同時にまた、河田さんにすまないと思った。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、安蔵は病の床に伏し、妻の清子は身重だった。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三階級にのみおもに役立っていた教養の所産を、第四階級が採用しようとも破棄しおわろうともそれは第四階級の任意である。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、じぶんがみんなからすてられて、神さまの天使からはのろいをうけていることを、しみじみおもいました。",
              "citation": {
                "source": "赤いくつ",
                "author": "DE RODE SKO",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのふは此酒店にて、樂しき事のみおもひつゝ、花を編み、母上の腕を枕にして眠りしものを。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
