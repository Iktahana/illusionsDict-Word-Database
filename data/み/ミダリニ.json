[
  {
    "uuid": "d954d649-2e75-5e5c-ab65-7460694d56cc",
    "entry": "妄りに",
    "reading": {
      "primary": "みだりに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
