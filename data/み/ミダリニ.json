      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "without authority",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしながらすでに妄りに人の居ない座敷の中に出現して、箒の音を発した為に、その音に愕ろいて一寸のぞいて見た子供が気絶をしたとなれば、これは明らかな出現罪である。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今後はばけもの世界長の許可なくして、妄りに向う側に出現することはならん。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今後ばけものの世界長の許可なくして、妄りに向側に出現いたしてはならんぞ。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "国と国とも同じ事で、単に勝つ見込があるからと云つて、妄りに干戈を動かされては近所が迷惑する丈である。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に人の惡しからざる思想や言語や行爲に對して、妄りに剋殺的の思想や言語や行爲をなさずして、助長を意とせざる可からずと思ふからである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "末造は妄りに語って、相手に材料を供給するような男ではない。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのリンゴの果実を妄りに多産にしないで、樹の堅実と健全繁栄とを保たせるのは即ち惜福である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "妄りに大望野心を懐くことを勧めるのではない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "形式ということを、悪いこと、取るに足りないことのように思って、妄りに私見に拠り私意を立て、折角聖賢が民人の為に設け説かれた形式に外れようとするのは、真に危なく殆いことで、一時の愉快はあっても終生の悔いがここに萌さないとも限らない、浅薄で愚かな事である。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の人は妄りに形式を斥けて、手本に就くことを嫌うけれども、手本を取ることは卑しいことでも悪いことでもない。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "また今の人、一方の教を奉じ、一家の言を信ずることを喜ばず、某々に囚われると云って、妄りに之を憎むこと甚だしい。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "度朔山上の章桃樹下に百鬼を簡閲し、道理なく妄りに人の禍害を為す鬼を、荼と鬱と、葦縄で縛りて虎に食わす。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ずしも妄りに選擇するを要せず。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "止みなむ／＼、妄りに人を咎むべきに非ず。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "就いては又しても陣触れなど仰せ出さりょうも知れぬが、師冬が沙汰するまでは一人たりとも妄りに動くな。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻とおなじ闘いが再びここで繰り返されることになったが、何分にも小坂部という邪魔者があるので、かれらは妄りに踏み込んで撃つことを躊躇しなければならなかった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽柴筑前守が縄張りの城中へ女子の身として妄りにまいらるること無用でござる。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "妄りに先を爭ふべきにもあらざるが、若し人に後れざらむとならば、なぜ自から仕立てざるぞ。",
              "citation": {
                "source": "千葉夜行記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "又一説に曰く、此地行徳の入會地にて、八幡村民妄りに入るべかざるを以て、八幡不知と名づけたりと。",
              "citation": {
                "source": "千葉夜行記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『そは知らじ、然れどもかのわかき下婢にすら母上は妄りにゆくを許したまはず。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは一番大切なものであって、しかも妄りに吹くことは出来ぬものである。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんにもせよ、夜陰に及んで妄りに貝をふきたてゝ城下をさわがす曲者は、すぐ召捕れという下知があったところへ、家老のなにがしが俄に殿の御前へ出て、容易ならぬことを言上しました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを知りつゝ妄りに木刀をふりまわした以上、その罪は武家の子供等にあるから、わたしは彼等に折檻を加えたので、決して町人の子どもの贔屓をしたのではない。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿舎は隊の方から指定してくれた所に宿泊することになっていて、妄りに宿所を更えることは出来ません。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "当人がしいて行きたいと望めば格別、さもなければ妄りにこれから先へは案内するなと、警察から案内者に云い渡してあるのだそうです。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "われに思ふ所あり、なんぞ妄りに汝の渦中に落ち入らんや。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に対しては誰のことでも妄りに誹らないのが居士の美徳ではあったが、一年ばかりでその門に足を絶ってしまった一個の青年を長く記憶していてくれたのは、わたしとして有難い事だと感謝している。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "康有爲が近代で最も感服して居るのは完白の書は篆隷に於て一種の得る所があるけれども、楷行其外の書に於ては、篆隷の法を以て妄りに應用するに過ぎぬ。",
              "citation": {
                "source": "北派の書論",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "王道をもって、新政の要義としている朝廷が、妄りに陪臣の命を取るようなことは、万に一つもないと考えようとした。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、俳聖芭蕉は、みだりに作らないといふ覚悟を非常に持つてゐたさうであるが、その事は、私には此の場合特に重要な事と考へられる。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
