    "definitions": [
      {
        "index": 1,
        "gloss": "Southern Cross (asterism formed with the brightest four stars of the constellation Crux)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "南十字へ着きますのは、次の第三時ころになります。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "南十字へ着きますのは、次の第三時ころになります」車掌は紙をジョバンニに渡して向こうへ行きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "送るのは水平線上の南十字星、迎えるのは久恋の佳人。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、渡欧の船中、印度洋で眺めた南十字星の美しさは、いつまでも忘れ難い。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔も今も変りなく燦然と輝くあの南十字星がそんな役割を勤めたかと思ふと、ただ単に美しいと鑑賞するだけでは済まないやうにさへ思ふ。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しずかにプラネタリュウムの機械の動く音がすると、星空が移り、もう大阪の空をはなれて、星の旅がはじまり、やがて南十字星が美しい光芒にきらめいて現われた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "流星が南十字星を横切る。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あえかな美しさにうっとりしていると、解説者は南十字星へ矢印の青い光を向けて、「――さて、皆さん、ここに南十字星が現われて、わたし達はいよいよ南方の空までやって来ました。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しんと寝しずまったマニラの町を野を山を椰子の葉を、この美しい南十字星がしずかに見おろしているのです」　マニラときいて、君枝は睡気からさめた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋食とちがう、星の名や」　君枝は肩をくねくねさせて笑い、「――ほな、南十字星は……？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "他吉は余程疲れていたのか、〆団治が、「こうーっと、南十字星てどの方角に出てる星やろか？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "南十字星が内地で見えてたまるかい。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「向うへ行ったらな、イの一番に南十字星見てこましたろ思てるねん」　と、〆団治は言った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――もう、南十字星てどの方角に出てる星やねんちゅうような、ぼけたことは言わへんぞ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はな、向うへ行て、空を見て、どれが南十字星か判らんかったら恥やさかいな、昨日うちの会社の文芸部の男に案内してもろて、四ツ橋の電気科学館へ行て、プラ、プラ、プラチナ……」「プラネタリュウム」　君枝は言って、赧くなった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ、それ、そのプラネタリで、南十字星言うもん見せて貰て来てん」　〆団治が言うと、他吉の眼は輝いた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "四ツ橋で南十字星を見たという〆団治の話を聴いて、君枝が〆団治らの慰問隊を見送りに行った留守中に寝床を這いだして来ていたのか、それは他吉だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "南十字星見ながら死にはったんやもん。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "見たい見たい思てはった南十字星見ながら、行きたい行きたい言うたはったマニラへ到頭行かはったんや。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しずかにプラネタリウムの機械の動く音がすると、星空が移り、もう大阪の空をはなれて、星の旅がはじまり、やがて南十字星が美しい光芒にきらめいて、現れた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "説明者は南十字星へ矢印の光を向けて、「――さて、皆さん、ここに南十字星が現れて、いよいよ南方の空、今は丁度マニラの真夜中です。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しんと寝しずまったマニラの町を山を野を、あの美しい南十字星がしずかに見おろしているのです。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほな、南十字星は……！",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "他吉は余程疲れていたのか、〆団治が「南十字星てどの方角に出てる星やねん？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四ツ橋のプラネタリウムへ行けば、南十字星が見られる」という〆団治の話を聴いて、いつの間に君枝や次郎の眼をぬすんで寝床を這いだして来ていたのか、それは他吉だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
