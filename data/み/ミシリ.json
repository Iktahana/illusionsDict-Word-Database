      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "recognition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "富米野と云う男熊本にて見知りたるも来れり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の二階建の方では見知りの町の人たちや富沢先生だ富沢先生だとか云って囁き合ってゐる村の人たち、南の診察室や手術室のある棟には十三才の聖女テレジアといった風の見習ひの看護婦たちが行ったり来たりしてゐたし、それにおれはおれの創造力に充分な自信があった。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前、清水の次郎長、御見知り置かれて幾久しく御別懇に願います」　「ああお前さんか、次郎長と云うのは？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "番頭と鉄五郎は見知りらしく立ち話し。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか、ブラゴウエシチェンスクにも、顔見知りが多くなっていた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "倶楽部で顔見知りの男が二人いた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾きし月の光にすかし見ればかねて見知りし大入島の百合という小娘にぞありける。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔見知りの一等卒が、蛸をゆでたように、真赤になって、似指を振りだしのまゝとび出してきた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見知りたる女にあらねど、うつくしき顔の笑をば含みたる、よき人と思いたれば、怪しまで、隠れたる児のありかを教うるとさとりたれば、いそいそと従いぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は煮えくりかえる程腹がたって、どうしてくれようかと思い思いその時計屋に行ったら、見知り越しの番頭が出て来て、「いらっしゃいまし。",
              "citation": {
                "source": "ざんげの塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "客同志見知り越しのものもある。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　破廂　泰助は昼来て要害を見知りたれば、その足にて直ぐと赤城家の裏手に行き、垣の破目を潜りて庭に入りぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、めりはりが判然して、人見知りはせず、愛々しい。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけにまた娘の、世馴れて、人見知りをしない様子は、以下の挙動で追々に知れようと思う。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その向の方なら、大概私が顔見知りよ。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "高綱　　申しおくれたれど、それがしは佐々木四郎高綱、なにとぞ御見知り置きくだされい。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は前から顔見知りですから、『やあ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいつて来たのは、顔見知りの百姓であつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段を上り下りする人間は、大概顔見知りの店員たちで、それは確に、三階の寝泊りの大部屋へ通うものであって、昼は店に行っていてそこには誰もいない。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ昼前なので遠くの街から集まって来た人達より踊り手には近所の見知り越しの人が多かった。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "園子も、懸念していたほど人見知りはせず、誰にでも笑いかけていた。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また頭が悪いせいか、人見知りをしないたちなので、おかみさんにも笑いかけたりして、私がおかみさんのかわりに、おかみさんの家の配給物をとりに行ってあげている留守にも、おかみさんからアメリカの罐詰の殻を、おもちゃ代りにもらって、それを叩いたりころがしたりしておとなしく六畳間の隅で遊んでいたようでした。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御無礼、御叱りには測り兼ねまするが、今後御熟懇、永く御為に相成るべき者と御見知り願い度、猶不日了休禅坊同道相伺い、御礼に罷出ます、重々御恩に被ますることでござりまする。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "見知りたる女にあらねど、うつくしき顔の笑をば含みたる、よき人と思ひたれば、怪しまで、隠れたる児のありかを教ふるとさとりたれば、いそいそと従ひぬ。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねて、顔見知りの間柄である。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）――悉しくはなくても、向う前だから、様子は知ってる、行来、出入りに、顔見知りだから、声を掛けて、（いつ見ても、好容色なや、ははは。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　拙者生れてより、今この年配で、人見知りはしないというのに、さらさら三方をカーテンで囲って、「覗いちゃ不可ません。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、この店は場所柄先斗町あたりの芸者の常連が多く、それを見ていることが、彼にとっては目の正月であり、顔見知りの芸者を相手にいやがらせを言っておれば、お茶屋散財しているような気がするからである。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大穴の時は配当を取りに来る人もまばらで、すぐ顔見知りになる。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、締切日の關係やら、私のせつかちやら、人みしりやらで、たうとうその禮を盡さぬままにて、發表しました。",
              "citation": {
                "source": "文盲自嘲",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
