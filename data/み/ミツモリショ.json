          "literary": [
            {
              "text": "過般見積書も作つて見たんだがね、六頁にして、帶廣のアノ新聞を買つて了つて、釧路十勝二ケ國を勢力範圍にしようと云ふんだ。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "過般見積書も作つて見たんだがね。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "実を云えば、見積書をもって行って手金を受取るまで、石川は大して当にしていなかった。",
              "citation": {
                "source": "牡丹",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇なる哉、安価の見積書は六月十九日に提出せられ太田に稽留せられて三十日に至りしに、値上げの案は、七月二日に提出せられて翌三日に可決せられたり。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨日のお話の見積書を出させるように、象牙店へいって来ました。",
              "citation": {
                "source": "秘められたる挿話",
                "author": "松本泰",
                "note": "青空文庫"
              }
            }
          ]
        }
