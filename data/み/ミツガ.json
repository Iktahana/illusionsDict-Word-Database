[
  {
    "uuid": "1b6b723d-35eb-5326-a7fd-50258f64e96c",
    "entry": "密画",
    "reading": {
      "primary": "みつが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
