        "examples": {
          "standard": [
            {
              "text": "このガラスコップは安価なためか、表面にわずかな脈理が見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "高品質なレンズを作るには、ガラス内部の脈理を極限まで排除しなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鉱石の断面を研磨すると、美しい脈理が模様となって現れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「脈理を以て予め死を知り、天命の及ばざるを知」ると云ふのであつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大理石の様模をあたうるには、随意ところの一色を塗り、これに脈理を施して天然のものに擬し、後に落古を被せて艶出しするを善とす――。",
              "citation": {
                "source": "元禄十三年",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
