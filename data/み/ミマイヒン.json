    "definitions": [
      {
        "index": 1,
        "gloss": "goods offered to a person in distress",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "友人の退院祝いに、フルーツの盛り合わせを見舞い品として持っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "病気で寝込んでいる彼のために、栄養ドリンクを見舞い品に選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "災害で家を失った人々に、毛布や食料などの見舞い品が届けられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "六条院の各夫人から産室への見舞い品、祝品はさまざまに意匠の凝らされたものであった。",
              "citation": {
                "source": "源氏物語",
                "author": "柏木",
                "note": "青空文庫"
              }
            },
            {
              "text": "津山からの見舞い品を捧げ、一文字の短刀を戴いて、この感動的な対面が終ったとき、若さまは静かに「母上の御｜位牌へ御挨拶を致したい」と云った。",
              "citation": {
                "source": "若殿女難記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "門前で自動車を乗り捨てたのは病人への遠慮、見舞い品を運転手に持たせて表玄関へ近づくと、内から障子が明いて松浦さん自らが現れた。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
