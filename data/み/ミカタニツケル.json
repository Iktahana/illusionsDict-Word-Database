    "definitions": [
      {
        "index": 1,
        "gloss": "to enlist as a supporter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
