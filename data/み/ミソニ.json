    "definitions": [
      {
        "index": 1,
        "gloss": "food cooked in miso",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "胡瓜の味噌煮、茄子の浅漬うまし。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカモ鰍の味噌煮というような下宿屋料理を小言｜云い云い奇麗に平らげた。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "味噌煮だから、酒と莨に荒れぎみの咽喉や胃袋には、味噌汁と同様の効果がある。",
              "citation": {
                "source": "或る夜の武田麟太郎",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛の煮込み……といっても、おもに豚の腸や胃や食道、特別には肝臓と心臓、そのこま切れを竹串にさして、鉄鍋でぐらぐら味噌煮にしたものだが、その鍋をかこんでアルコールを飲むという、この頃たいへんはやっている安直な飲み屋が、近くの街角に一つあった。",
              "citation": {
                "source": "早春",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○鰯を味噌煮にて食すれば中毒せずという。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、十数年前上州花咲峠の奥の、武尊山の峭壁に住んでいた野猿を猟師から買い受け、その唇を味噌煮にこしらえて食べたことがあるが、軽い土臭と酸味を持っていて口では言い表わせぬ魔味を感じたのであった。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンボウという直径一間もあるまんまるい大きな魚があるが、あの肉と骨と皮をしぼって汁をとり臓物を味噌煮にして食うとアンコウ以上にうまいかも知れぬ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、十数年前上州花咲峠の奥の、武尊山の峭壁に住んでゐた野猿を猟師から買ひ受け、その唇を味噌煮にこしらへて食べたことがあるが、軽い土臭と酸味を持つてゐて、口では言ひ現せぬ魔味を感じたのであつた。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の傍に円火鉢引寄せ書を読みながら柚味噌煮る楽しみも十二月である。",
              "citation": {
                "source": "写況雑記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊田屋、坊主しやも、緑町の鶏肉を味噌煮にしてたべさせるかどや――あのへんのたべものやはみんな懐しいおもひで許りだけれど。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食には「長」の釣った鮒を味噌煮にして喰べた。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この子四ツじゃに糠より軽い軽いはずだよ稗糧と夫婦の坊子じゃもの坊子にゃ出ぬ乳も運上にゃしぼる藁で髪ゆい、縄帯しめて――　痩せた畑を、小作の子が、聞き覚えの味噌煮唄をどなって通った。",
              "citation": {
                "source": "脚",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、騒いだ後は、いつも、千曲川が赤くなるほど、首謀者の首が、並べて斬られ、結局、百姓は又、何も得るところはなく、坊子にゃ出ぬ乳も運上にゃしぼる　と、味噌煮唄でもうたって、欝憤をやるだけのものになってしまう。",
              "citation": {
                "source": "脚",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋の中では鮒の味噌煮がことこと音を立ててい、味噌と川魚との入り混ったうまそうな匂いが、蓋の隙間から漂いながれていた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその鮒を味噌煮にした。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんガスなどはないので、火鉢に粉炭を入れ、味噌煮の鍋を掛けたりおろしたり、また煮つまると水を加えたりしながら、煮あがるのをたのしみに待つのであった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいさ」と私はかれらの去ったあとで自分に云い聞かせた、「味噌煮にしておけば保つからな、当分おかずに困らないで済むわけだ」　私はまえの味噌煮を丼へ移して、それらの鮒を新しく味噌煮にしかけた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "喰べたくないときにやる弁当の礼で、このあいだは鯖の味噌煮と煎り豆腐と、菜の胡麻よごしだったけれど、あんなにうまい物を喰べたのは生れて初めてで、喰べながら涙が出てしようがなかった。",
              "citation": {
                "source": "へちまの木",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "味噌煮であったが、そして、豚そのものは見たこともないけれど、あとでそう聞いて、ひどく胸の悪い思いをしたことがあった。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おやじ、酒だ、それから味噌煮を一つ」「こっちは濁ったのをくれ」と勇吉が云った。",
              "citation": {
                "source": "夜の蝶",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、ネギマのマグロの如く、牛肉をブツ切りにしたのと、葱も五分に切ったのを、味噌煮で食うのである。",
              "citation": {
                "source": "牛鍋からすき焼へ",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れつきか、ややともすると、すぐ下痢をやりますので」「味噌煮だろ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで祖父はくそみそに悪魔を罵つたから、さぞかし、悪魔の奴、地獄で何度も嚔めをしたことだらう。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "脳みそに、さわっちゃった。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、よみかきそろばん、という口調のよい言葉を大層嫌っていたので、その言葉をくそみそにやっつけたように思う。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は脳みそに、釘をぶちこまれたような気持だ。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしほどの芸人が、手前みそに狂言の功能をならべたり、一座の役者のちょうちん持ちをして、自分から品を下げるようなことはいたしませぬ。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちのぬかみそには人参、ジャガイモが入って居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は今、家にいる連中をくそみそに罵倒したけれど、でもあの連中を一人残らず尊敬していますよ。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "一しょになって、くそみそにやっつけるべきだったのだろうか。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
