    "definitions": [
      {
        "index": 1,
        "gloss": "Salsola komarovii (species of saltwort)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
