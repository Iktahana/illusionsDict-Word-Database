        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "陳列品の中に獅子舞の獅子の面が二点あったが、その面に附いている水色に白く水玉を染出した布片に多分｜鬣を表わすためであろう、麻糸の束が一列に縫いつけてある。",
              "citation": {
                "source": "夢判断",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、傾きかけた赤い西日が樹木の水玉にきらきらと光つた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "盥の水が躍り出して水玉の虹がたつ。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まあ、ここに葉のまわりの針の尖に、一ツずつ、小さな水玉のような露を持っててね。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちはそれがみんな水玉だと考えるだろう。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "呆気に取られて、ああ、綺麗だ、綺麗だ、と思ううちに、水玉を投げて、紅の※を揚げると、どうでしょう、引いている川添の家ごとの軒より高く、とさかの燃えるように、水柱を、颯と揃って挙げました。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、のろまな妻は列車の横壁にかかってある青い鉄札の、水玉が一杯ついた文字を此頃習いたてのたどたどしい智識でもって、FOR A-O-MO-RI とひくく読んでいたのである。",
              "citation": {
                "source": "列車",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、のろまな妻は列車の横壁にかかつてある青い鐵札の、水玉が一杯ついた文字を此頃習ひたてのたどたどしい智識でもつて、FOR A-O-MO-RI とひくく讀んでゐたのである。",
              "citation": {
                "source": "列車",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝の姿は見えねど、滝壺の裾の流れの一筋として白絹の帯上げの結び目は、水沫の如く奔騰して、そのみなかみの※々の音を忍ばせ、そこに大小三つほどの水玉模様が撥ねて、物憎さを感ぜしむるほど気の利いた図案である。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓外の雨は急に降りまさつて來たらしく、窓硝子を傳つて流れ落ちる水玉が玉簾のやうに動いて行く。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い水玉をちらした仕立ておろしの黄いろいドレスが、夕闇を透して男の眼にしみた。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水玉草を賣る、涼し。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「姉が夢中に叫んだうわ言かとも思い、またそれは敷地にいるロマのことではないかとも思い……多くの者が頭に水玉の模様があるハンカチーフを巻いておりますが、それが姉の使った言葉に関係があるのかは、ちょっと。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "水玉のスカートの長い洋服を着て、鍔広の帽子を冠つてゐたが、こつちを見たのか見ないのか、面を伏せて、彼の視線を擦りぬけるやうに、足を速めて奥の方のブウスのなかへ消えてしまつた。",
              "citation": {
                "source": "二つの失敗",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "覆面の小がらなそれなる怪人は、岸へ泳ぎつくと、ぐっしょりぬれた着物からぽたぽたと水玉をおとしながら、まるで何かの物の化につかれてでもいるかのごとく、ひょうひょうふらふらと歩きだしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉やヒゲから、凍つたのがとけて、水玉を作つて頬を流れ落ちた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧雨が降つてる、づぶ濡の木立にかけた蜘蛛の網は、水玉の重みに弛んで毀れて了つた。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな波のうねりになって押しよせて行く自分の心が浜の方で微妙な響と形で居る小波の様な両親の心とぶつかって水玉をとばしらせてそれと一緒になった時の気持はほんとうに口なんかじゃあ云えませんねえ。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻はわざと帽子をとって、水玉模様のスカアフと一しょに短い断髪が風に流れるのに任せた。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生、先生は、月夜に立ちのぼる水の、不思議に蠱惑的な薫りを御存じでございますか、扁平な櫂に当って転げる水玉の、水晶を打つ繊細な妙音を御存じでございますか。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コップの水に浸って居る葉にこまかいむく毛がある故か、小さい水玉が見える。",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い蓮の葉の上でコロコロ転んでいる水銀の玉、蜘蛛の巣をつたって走る一滴の水玉、そんな優しい小さなものに、そんな美しい小さなものに、わたしはなれないのかしら。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い蓮の葉の上でコロコロ転んでゐる水銀の玉、蜘蛛の巣をつたつて走る一滴の水玉、そんな優しい小さなものに、そんな美しい小さなものに、わたしはなれないのかしら。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "震えて居る木の葉でも水玉でもあらゆるものが躍って居る様に見える。",
              "citation": {
                "source": "無題（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "細い葉先に漸々とまって居る小さい水玉の光り。",
              "citation": {
                "source": "雨が降って居る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "サラサラした水は快く彼等の軟い胸毛を濡して、鯱鉾立ちをする様にして、川床の塵の間を漁る背中にたまった水玉が、キラキラと月の光りを照り返した。",
              "citation": {
                "source": "一条の繩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の主ダニーロは、じつと物思ひに沈み、その緋色のジュパーンの袖が独木舟の縁から下へ垂れて水をしやくつてをり、また彼等の女主人カテリーナは静かにわが児を揺ぶりながら、良人の顔からじつと眼を放さずにゐるが、彼女の、表布をきせぬ粋な羅紗服には灰色の塵のやうに水玉が跳ねかかつてゐる。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時あたしのおたばこぼんが出来上ると、中に赤や青や金色の小さな瓢箪か、役者の写真の浮いている水玉のかんざしを、そこの姉妹が買ってさしてくれたり、腰にギヤマンの瓢箪をさげさせたりした。",
              "citation": {
                "source": "西洋の唐茄子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "水玉という草に水をうって、涼しくかけたものだが、みんな一時のもので、赤くひからびるまではかけていない。",
              "citation": {
                "source": "大門通り界隈一束",
                "author": "続旧聞日本橋・その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、できればこれまでのものも含めて、明確化させた新しいルールに従って使ってもらえないかと考え、すべての作業者にメールで連絡を取り、「みずたまり」＊で論議して、合意の形成を目指した。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            }
          ]
        }
