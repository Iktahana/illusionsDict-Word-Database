        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ギャンブルにのめり込み、彼はついに身を落としてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一度身を落とすと、再び元の地位に戻るのは並大抵のことではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その物語は、栄華を極めた貴族が戦乱によって身を落とす悲劇を描いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "伊達の素足に、意地と張りを立て通す深川名物羽織芸者……とはいえ、この境涯へお艶が身を落とすにいたるまでには、じつはつぎのようないきさつがあったのだった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま一分も遅ければ、その水夫は疲れ切って絶望し、深淵のうちに身を落とすところだった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんとした家庭を持たぬのがはじまりで、しまいには賤しい稼ぎに身を落とすような不幸な者どもではございません。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョージ卿のような立場の人間がこのように身を落とすとは、信じられない。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になると家鳴震動して土を落しごみをおとす。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
