[
  {
    "uuid": "88d07c09-b32d-55b8-86d8-b94a35d57f62",
    "entry": "御霊",
    "reading": {
      "primary": "みたま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
