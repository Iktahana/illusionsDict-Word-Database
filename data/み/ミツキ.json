    },
    "definitions": [
      {
        "index": 1,
        "gloss": "three months",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（新生三月号をよみて）",
              "citation": {
                "source": "書信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリスタン・コルビエールは、千八百四十五年、七月十九日、午前八時、モルレーに於て汽船会社の社長の息子として生れ、千八百七十五年、三月一日午後十時同所で死んでゐるから三十年に足らぬ生涯であつた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく寒い朝だつたよ、三月になつてはゐたが、来る途中、日の当らない所は凍つてゐた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月、四月、五月、そうです。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその年の三月に、女と二人で、Ｋ市から上京したのだつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、私はその三月、東京で高等学校を受験して、ハネられてゐたのであつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月程前まで、彼女は祖母と二人で暮してゐたのだが、三月前その最後の一人の祖母も死んで行つたので彼女は友のすゝめるまゝに女優となつたのだつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "編暦をつかさどる人々は、たとえば東京における三月の平均温度が摂氏何度であるかを知らなくても職務上少しもさしつかえはない。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬は言うまでもないとして、三月四月頃、試みに郊外に出て見給え、遠くに碧い山か、斑らな雪の縞を入れて、菜の花の末、または青葉若葉の上に、浮ぶように横たわっている。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この三月にはまた次のような端書が来た。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十一年三月『朝の光』）",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十二年三月『朝の光』）",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、昭和四年三月以後に建てられた小学校は皆この規準に従って建てられたものであるが、それらのうちで倒潰はおろか傾斜したものさえ一校もなかった。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治三十三年三月『ほととぎす』）",
              "citation": {
                "source": "神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　夏の初から――六月の半頃から三月以上もかけ續けてやうやく古びた竹の簾。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水無瀬はその弟妹の中の上の弟を語って、三月の行糧を、山の窟に蓄えた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正五年三月『現代之科学』）",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正二年三月『理学界』）",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十年三月『電気と文芸』）",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　アルベルト・アインシュタインは一八七九年三月の出生である。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月九日帰朝早々から風邪を引き、軽い肺気腫の兆候があるというので大事を取って休養していたが、一度快くなって、四月五日の工学大会に顔を出したが、その翌日の六日の早朝から急性肺炎の症状を発して療養効なく九日の夕方に永眠した。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長塚へ梅の歌を詠めと云うてやったら三月上旬に出京して実際を見てから作ると云うてきた。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十六年二月校訂の時しるす）本書は昭和十二年五月内務省主催第二回神職講習会における講義を速記したものであって、昨年三月｜神祇院で印刷に附して関係者に頒布せられたが、今回｜書肆の請により同院の許しを得て新たに刊行したものである。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十七年三月橋本進吉刊行委員附記　この昭和十七年のはしがきは、明世堂刊行の際、巻首に掲げられたものである。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の一昨年うせたる時も、母の去年うせたる時も、心からの介抱に夜るも帯を解き給はず、咳き入るとては背を撫で、寐がへるとては抱起しつ、三月にあまる看病を人手にかけじと思し召の嬉しさ、それのみにても我れは生涯大事にかけねばなるまじき人に、不足らしき素振のありしか。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京虫や蚤蚊に攻められながら、野羊の乳を飲み、アラビア人のコックの料理を食って、一八七二年の十二月十二日から翌年三月中旬にわたる単調な船住いをつづけた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八一年三月に Trinity の Honorary Fellow になった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一例を挙げると、三月十六日パレスタインで強風が砂塵を立てているに乗じてトルコの駱駝隊を襲撃し全滅させたという記事もある。",
              "citation": {
                "source": "戦争と気象学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年三月六日『東京朝日新聞』）　　　　　　　　　六十五　　　　　　過失より起る火災　放火や悪戯より起る火災は人の不注意から起る火災に比すればほとんど云うに足らぬ少数であるそうな。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後を祖母が耕二の顔に向つて「フンフンフン」といふ咬みつきたいやうな、肉親仲間以外では決してされることのない笑ひを一つかけた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
