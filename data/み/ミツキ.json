[
  {
    "uuid": "49b67cde-229e-5f91-b8a1-be0a0b93f677",
    "entry": "三月",
    "reading": {
      "primary": "みつき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
