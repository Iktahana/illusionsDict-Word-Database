        "examples": {
          "standard": [
            {
              "text": "動画配信サービスに加入すれば、月額料金だけで映画が見放題になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "週末は家でアニメの見放題を楽しんで、リフレッシュするつもりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「全試合が見放題！」というキャッチコピーに惹かれて、スポーツ専門チャンネルを契約した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "淋しいことは淋しかったが、誰も特別にかまってくれず、しかも新しいものは見放題。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「清い水は飲みほうだい、ぴちぴちした魚はたくさんとれる、ぼくらはここに住まいを定めることにした、伝馬船は浜辺づたいにひいてきて、川口につないだ。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ大変な仕送りだと見えて、一本卅円もする三鞭酒たらいうものを飲みほうだいに飲み散らし、冬の真ッさなかに鮎が食いてえのポンカンないかのと、それはもう」　悦子は憎々しく舌打ちをし、「まア、生意気ねェ、大した器量でもないくせに。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
