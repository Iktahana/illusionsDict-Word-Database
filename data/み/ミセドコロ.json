          "literary": [
            {
              "text": "そこが何より、この場面仕掛の見せ所だったのである。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ急げ、男の見せ所だ」　マーシが踵を返して、テントを去った。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは五か一〇くらいで、それは集金の操作でうまくまじくなったが、一〇が一五となり一八となるうち、ますます栄子に熱があがり、ここが男のみせどころだと、すっかり太っ腹になってしまった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにがさて御本城の御奉行閣下の臨席裁判だ、兼尾殿はこれぞわが腕のみせどころと、能力いっぱいぎりぎりの意気込みで主訟状を読み上げた。",
              "citation": {
                "source": "艶妖記",
                "author": "忍術千一夜　第一話",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓と矢を持って戻ってきた三之丞、「五年来修行の腕のみせどころだぞ、ぬかるなよ」伯父が念を押すのをうしろに聞きながら、足場を計って弓を構えた。",
              "citation": {
                "source": "備前名弓伝",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
