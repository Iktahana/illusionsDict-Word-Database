[
  {
    "uuid": "882a3e7e-cabb-5ccc-baa5-087f91c83182",
    "entry": "漲る",
    "reading": {
      "primary": "みなぎる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
