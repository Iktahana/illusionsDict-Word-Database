    "definitions": [
      {
        "index": 1,
        "gloss": "power (of the Emperor)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大御稜威い照らすと御船出成りぬ、日の皇子や、御鉾とり、かく起ちましぬ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四章大いなり、今にして現人神、かく坐せば、かぎりなき大御稜威かくあらせば。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大君は神にし坐す、大御稜威神とし坐す。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "現神今にし坐す、　大御稜威日のごと坐す。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "げにや隈なく御稜威は光被する。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "九州、瀬戸内海、大和地方にかけて、既に御稜威の下に、欣んで帰順する者も多かつたが、事理を解せぬ蛮民も多く、途中に於ても、それらに対する警戒平定に、多くの日時を費されたことと思ふ。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "室は紙障子引きたてしのみにて雨戸ひくということもせず戸の後鎖することもせざる、さすがに御神の御稜威ありがたしと心に浸みて嬉しくおぼえ、胸の海浪おだやかに夢の湊に入る。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達が今見渡すこの広い河の向ふまでを、必ずともに父君の御稜威の下に、統べ終ほすことを誓つて置かう。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが日本は、幸いにして、御稜威のもとに、建国二千六百余年の光輝ある国史をもち、軍人は忠勇無双、銃後国民も亦すこぶるりっぱです。",
              "citation": {
                "source": "『火星兵団』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の如く景行の朝より成務の朝に亙りて、九州の北部が容易に王化に靡きしは、固より列聖御稜威の然らしむる所なるべしと雖も、而もまた此處に據れる女王國の勢力が衰頽に赴きしこと、その原因たらずんばあらず。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……きっと、陛下の御稜威に謝しまつり、戦死者の霊をとむらっているのだろう。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "○おほきみの御稜威かがやく日の本に狂業するな癡の漢人　（平賀元義）　これに、『からふね』の題があるけれども、題詠ではなく、そのころ外國の軍艦どもが、しきりに我國にむかつてこけ威しを敢てした時の事實が念中にあつてこの歌が咏まれたものに相違ない。",
              "citation": {
                "source": "愛國歌小觀",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇の御稜威のかがやく皇國にむかつて、何のふざけた眞似をするか、承知をせぬぞ、癡呆の外國人どもよ、といふ意味である。",
              "citation": {
                "source": "愛國歌小觀",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝廷というものが中央においでになる、その朝廷の御稜威を借りて事をなさなければ、為すべき名分も、手段も立たぬ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これすなわち、山海共に皇室の御稜威に服し、ここに既に同化融合の実を挙げ給うた事実を、語り伝えたものではあるまいか。",
              "citation": {
                "source": "「日本民族」とは何ぞや",
                "author": "日本民族の概念を論ず",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして上に万世一系の皇室を戴き、歴代天皇の御稜威はいやが上にも輝いて、以て今日の隆昌なる国運を成すに至ったのでありますが、またそれと同じ様に私ども日本民族も、この国運の進展に伴って、終始一貫した成立発展の歴史を続けているのであります。",
              "citation": {
                "source": "本州における蝦夷の末路",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "セイレエン等御身はさゝやかなれど御稜威は大いなり。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "逆はむよしなき御稜威もて、舟人を救ひませば。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "神々の御稜威を厳めしき人の形には、われ等始て造り出だしつ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」四、「天皇の御ために身命を捧げることは自己犠牲ではなく、小我を捨てて大いなる御稜威に生き国民としての真生命を発揮する所以である。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "チベットの高野に光る初日影　　　　あづまの君の御稜威とぞ思ふ　其村で一月五日まで経を読み、その翌日｜出立してオーミという村まで三里ばかり進んで其村に泊りました。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛鳥白鳳天平三代にわたる宗教と芸術の未曽有の開顕は、ひとへに歴代天皇の　大御稜威の然らしめ給ふところであつて、　推古天皇ならびに上宮太子　天武天皇　聖武天皇悉く御一身を賭し紿ひて、あの危機の深淵の上に絶妙の花華を開かせ給うたのである。",
              "citation": {
                "source": "帰依と復活",
                "author": "龜井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御稜威とは「撫」であり、こゝに国体の深い源泉がある。",
              "citation": {
                "source": "君臣相念",
                "author": "龜井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大君の国の御稜威をおとさじと家をも身をも捨てにしものを」。",
              "citation": {
                "source": "風蕭々",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文武百官式の陣坐をめぐって、朝廷の御稜威と、彼の栄光を祝して、万歳をとなえた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまに忠顕は一帖の“簿”を取り上げて、「すべては大御稜威だな。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに御稜威というものか。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士は、武士大衆の自力を信じ、公卿は公卿で、御稜威に帰した天下であるとし、それはわが世の春だと思っている。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの善戦をなしえたのは、時の御稜威、また時の人心が支えたもの。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に妹はこんなことを云ふものの、この事件の底にはまだ他になにかこみいつた事情が潜んでゐないとも限らない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
