[
  {
    "uuid": "9c12f260-c10d-58ac-b2e6-fee55a016238",
    "entry": "未来",
    "reading": {
      "primary": "みらい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
