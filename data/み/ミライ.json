      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(distant) future",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然しまあ未来があつたのだが、それも諦めて、父親のためには田舎へ引籠らなければならなかつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "純粋持続の、人に於ける心理的状態は、強ひて言へば、未来を思ふとしては神を、現在を思ふとしては自己を、過去を思ふとしては運命を信じてゐるのだ。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "実以て茲には目覚ましい精神があるし、未来派発生当時のアポリネールの態度をでも想ひ出させる底の気慨が見られる。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "新楽天主義（それは未来を支配する）の輝やかしい黎明の光がうかがはれる。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これも未来の立派な政治家ですな」　校長は背ろ手を組んで、同意の笑を満面に湛えてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは千九百二十七年に小林に送る手紙です私には過去と未来が分らなくなつた。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに神人の子に未来を知るの力を与へ給はず。",
              "citation": {
                "source": "地上組織",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちジヤツク・ウオーキイ等によつて映画で紹介されてゐるやうな、歌詞を本位として簡単な音楽を伴奏的につけ、専ら歌詞の滑稽味やエロチシズムやで、大衆を興がらすやうに出来てる「音楽入西洋万才」が、近い未来に於て日本に現れることを予感させる。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に詩を作る人々は、過去においても未来においても、新しい詩においても古い詩においても、必須的に先ず俳句や和歌を学び、すべての技術の第一規範を、それから取り入れねばならないのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "未来の如何なる「新しい詩」においても、和歌や俳句のレトリックする規範を離れて、日本語の詩があり得るとは考えられない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本にはかつて決して、ボードレエルの如き真の絶望的な悲劇詩人は生れなかったし、今後の近い未来にもまた、容易に生れそうに思われない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時と空間に関する吾人の狭いとらわれたごまかしの考えを改造し、過去未来を通ずる大千世界の万象を四元の座標軸の内に整然と排列し刻み込んだ事でなければならない。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてこの哀れなる垂死の人の生涯を夢みた時、あたかもこの人の今の境遇が余の未来を現わしていて、余自身がこの翁の前身であるような感じがした。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何者とも知れぬ権威の命令で、自分は未来｜永劫この闇の中に封じ込められてしまったのだと思う。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その数々の線の一つずつには、線の両端に居る人間の過去現在未来の喜怒哀楽、義理人情の電流が脈々と流れている。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去を定めるものは現在であって、現在を定めるものが未来ではあるまいか。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それともまた現在で未来を支配する事が出来るものだろうか。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその上に未来の足場を建ててみよう。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の地震学上から判断される限り、同じ事は未来においても何度となく繰返されるであろうということである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、昆虫はおそらく明日に関する知識はもっていないであろうと思われるのに、人間の科学は人間に未来の知識を授ける。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎の為に未来のずつと未来までも、美くしいマヽであり度いお仕度の為にせつせとお化粧のお稽古です。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは自分の一生も案外小ぢんまりした平凡に規定されてしまう寂寞の感じはあったが、しかし、また何かそうなってみての上のことでなければ判らない不明な珍らしい未来の想像が、現在の自分の心情を牽きつけた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夢もなお及ばない遠い未来のかなた、彫刻家たちのかつて夢みたよりも更に熱い南のかなた、神々が踊りながら一切の衣裳を恥ずる彼地へ｛１｝」の憧憬、ニイチェのいわゆる 〔flu:gelbrausende Sehnsucht〕 はドイツ国民の斉しく懐くものである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」は過去を擁して未来に生きている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり各部門においては現在既知の知識の終点を究め、同時に未来の進路に対して適当の指針を与え得るものが先ず理想的の権威と称すべきものではあるまいか。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、「ああ、王子さまのおそばに来たいばかりに、あたしは、みらいえいごう、声をひとにやってしまったのです。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれを呼んでいるのであろうと、目をみらいてみると、眩しい懐中電灯が、彼のかおをてらしていた。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの道理がわからぬようではみらい｜えいごう妻とはおもわぬ、夫とも思ってもらわぬぞ」と、するどくお叱りになりました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
