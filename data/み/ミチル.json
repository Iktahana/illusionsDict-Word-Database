    "definitions": [
      {
        "index": 1,
        "gloss": "to fill",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この、それ自身にははなはだ平凡な光景を思い出すと、いつでも涼風が胸に満ちるような気がするのである。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし此のこころみに依って、王さまに何のうしろ暗いところも無かったという事が、わかったら、わしたちは申す迄も無くデンマークの国民ひとしく、ほっと安堵の吐息をもらし、幸福な笑顔が城中に満ちるでしょう。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "潮ぐもりの燻しがさむざむと満ちる、これから、蜆いろの沖にも。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "明軍の大将軍砲、仏郎機砲、霹靂砲、子母砲、火箭等、城門を射撃する爆発の音は絶間もなく、焔烟は城内に満ちる有様であった。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちた花は朽ち腐れて一種甘いような強い香気が小庭に満ちる。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仇討ちは気持ちいいものだとわかっていたつもりでしたが、これほど魂に安らぎが充ち満ちるとは今まで思ってもみなかったのです。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして更に無数の囁が騒然として空間に満ちる。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて潮が刻々に進み満ちるように、春の温度が日々に進み高まるように、精神の力量が身体状態の為に段々と増加する場合には、気も自然と張るものである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてその進潮は、進潮になった初めから終りまで、五時間ほどの間を刻々分々に進み満ちるのであるが、満ち尽せば即ち潮止りとなって、それから引き返えして退潮となるのであるから、つまりは五時間だけを持続するに過ぎないのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてまた春は即ち張るであって、木の芽も草の芽もみな張り膨らんで、万物｜尽く内より外に張り水も四沢に満ちる程である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府は、何故に　　ルンペン各位に、　　わざわざ、御武装を願つたか、　　失業者、山野に満ちる時、　　何故に諸君が、　　特に選ばれて、　　生命線に乗出すか、　　それが、所謂、　　所謂、それが、　　それが、つまり、　　政府の真意のあるところで　　あるのであります――。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくしてそれがしずまると、風の生み出す音の高い不思議な沈黙がまた天と地とにみなぎり満ちる。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして其詞を声に出して言ふと同時に、曾てそれを聴いた時に感じた不思議な感じ、今言ひあらはさうとする不思議な感じが胸に満ちるのである。",
              "citation": {
                "source": "クサンチス",
                "author": "XANTHIS",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『あの水雷庫の傍に、工場があつて、此方に職工の長屋、それから奥に、水雷に勤める官吏の住宅があつて、その前に、綺麗な吹井があつて、それに、夕日が当つてゐた……そこで、あの時、お前は手桶に水の満ちるのをじつと立つて見てゐたぢやないか……あの時分はまだ若かつたな！",
              "citation": {
                "source": "ある日",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯気が満ちると、彼らの顔は赤くなって伸縮した。",
              "citation": {
                "source": "街の底",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺憾なく延び満ちる姿の恐怖というものも、あのスフィンクスの笑いの中には火を見るごとく無気味な表情で漂っている。",
              "citation": {
                "source": "スフィンクス（覚書）",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の日の光が屋内まで輝き満ちるようなことは三年の旅の間なかったことだ。",
              "citation": {
                "source": "三人の訪問者",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寂しい月日が長かっただけ、心を苦めることが多かっただけ、それだけ胸に満ちる歓喜も大きなもののように思って来た。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢こくなった人間、豊富になった筈の人間精神の明確なるべき今日の人の多くがそれなら、果してひたすら発育して自己の肉体、精神の内感のみによって、宇宙に満ちる時の推移を直感するほど、深刻であるでしょうか。",
              "citation": {
                "source": "われを省みる",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活の意味に対する明るい知と愛とを抜いて、人は真に勇気に満ちることも堅忍であることも不可能である。",
              "citation": {
                "source": "世代の価値",
                "author": "――世界と日本の文化史の知識――",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い生きる力は、そういう我知らぬエゴイズムに満ちるときもあるのだ。",
              "citation": {
                "source": "青春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の日は光が屋内まで輝き満ちるようなことは過ぐる三年の間はなかったことだ。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "心を引緊め智を働かせて仕遂ぐべき大事があると、却って心が落付き、静かな勇気が内に満ちる。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりでなく、ぴったりと生活が落付かず、何だか借りもののようで、不満が裡に満ちる。",
              "citation": {
                "source": "小さき家の生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我心に満ちる愛やまごころを思えばそれの与えられぬのが不思議に思う。",
              "citation": {
                "source": "初夏（一九二二年）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒が甘かろうと、苦かろうと、盃は満ちる。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "四辺に満ちる声は一つになった歎いである。",
              "citation": {
                "source": "小鳥の如き我は",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "春になると、庭へ、ヒアシンスや馨水仙が不断に咲き満ちると云うことであった。",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "種々の思いが胸に満ちる。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｃ　醋の甕蒼ざめし汝が面饐えよどむ瞳のにごり、薄暮に熟視めつつ撓みちる髪の香きけば――醋の甕のふたならび人もなき室に沈みて、ほの暗き玻璃の窓ひややかに愁ひわななく。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
