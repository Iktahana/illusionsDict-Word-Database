    "definitions": [
      {
        "index": 1,
        "gloss": "secret order of the Emperor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "待設けたる斉泰は、たゞちに符を発し使を遣わし、往いて燕府の官属を逮捕せしめ、密に謝貴張※をして、燕府に在りて内応を約せる長史葛誠、指揮盧振と気脈を通ぜしめ、北平｜都指揮張信というものゝ、燕王の信任するところとなるを利し、密勅を下して、急に燕王を執えしむ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずくんぞ知らん、その日は薩長二藩に対し、討幕の密勅が、下された日である。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の一派は、岩倉を中心とする排幕派で、既に討幕の密勅も下っている所へ、大政奉還を申し出でたので、勝手が違ったが、たとえ武力で圧倒できなくなったにしろ、他の手段で、幕府の勢力を蹂躙しようと云うのである。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "足利尊氏は途中｜近江鏡ノ宿にて、密勅を蒙るや、之を秘して、何気なく京都を通り、丹波に入つて、足利氏の所領たる篠村八幡宮祠前に於て、勤皇の旗を挙げ、山陰道を上つてゐた千種忠顕の官軍と合して、六波羅を攻めて、之を滅した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、其の前後、徳川征討の密勅が薩長二藩に下つた。",
              "citation": {
                "source": "兵馬倥偬の人",
                "author": "塚原蓼洲",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に左内の手足となつて、密勅事件の裏に活躍した歌弟子、野邨恒見に、愚にも　まどへるものか。",
              "citation": {
                "source": "橘曙覧",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "恒見（淵蔵）は、左内の手足となつて、密勅事件の裏に活躍した人である（永井環其他）。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方には王政復古を急いで国家の革新を改行しようとする岩倉公以下の人たちがあり、一方には天皇の密勅を奏請して大事を挙げようとする会津藩主以下の人たちがある。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶喜公が大政奉還の上表を出したとほとんど同じ日に、薩長二藩へ討幕の密勅が下ったということを確かな筋から聞き込んだが、君らはあれをどう思うか、その密勅がまた間もなくお取りやめとなったというが、あれをもどう思うかとありました。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、信州｜伊那の谷あたりだけでも、過ぐる年の密勅事件に関係して自ら毒薬を仰いだもの、元治年代の長州志士らと運命を共にしたもの、京都六角通りの牢屋に囚われの身となっていたものなぞは数え切れないほどある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはともかく、井伊内閣による通商条約締結とともに朝廷の攘夷はもはや祈願たることをやめて、まず前出の示命（安政五年正月）となり、ついで条約不許可勅令（三月）、さらに八月八日の水藩以下への「密勅」となった。",
              "citation": {
                "source": "尊攘戦略史",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに密勅そのものの範囲が水戸継嗣ブロック以上に出て雄藩おしなべて十三藩にわたり、その内容もたんなる「攘夷」だけでなく「内憂」に言及され、内政改革の手段として「群議評定」「公武合体」が強調されている。",
              "citation": {
                "source": "尊攘戦略史",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月、密勅水戸に下る。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "その薩摩が討幕の密勅を奉ずるに至りたるが如きは、これ西郷、大久保の意にして、三郎の意に非ざるやまた疑うを須いず。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "○同八月八日、密勅水戸に下る（大獄の近因）。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十六　最後　井伊直弼は、密勅の水戸に降りしを奇貨とし、これを中心として、その打撃を始めたり、史家称して安政の大獄という。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の揚言する所に依れば、彼等は皆宮中より賜はれる馬牌、鍮尺を有し、皇帝の密勅を奉じて協約の實行を妨ぐるの同盟を爲せりといふに在り。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の揚言する所に依れば、彼等は皆宮中より賜はれる馬牌、鍮尺を有し、皇帝の密勅を奉じて協約の実行を妨ぐるの同盟を為せりといふに在り。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "癸亥の年の密勅の件からはじまったこんどの事でも、杉永がつねに私の意見を支持したため、われわれ同志の者の行動はよく一致し、離反者などは一人も出さずに済みました。",
              "citation": {
                "source": "失蝶記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手記を続けるに当って、密勅をめぐる家中の論争は省略します。",
              "citation": {
                "source": "失蝶記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "密勅があって以来、禁裡付きの下房どのと、国許にあるわれら同志とのあいだで、絶えず情報の交換があり、それについての急を要する合議が繰り返されていたのです。",
              "citation": {
                "source": "失蝶記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治天皇は、「討幕の密勅」を、薩長二藩にくだしたといわれている。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして岩倉は、わずか十六歳の、すこぶる気の弱い明治天皇を立てて、思うままにあやつり、薩長の策士らと連絡して、この「討幕の密勅」と称する偽勅を出したのである。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "「討幕の密勅」といわれるものも、公卿と雄藩の策士とが、作りあげたものである。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "公卿の一人である岩倉具視は、さきにも述べたように、ついに孝明天皇を殺害し、明治天皇を手玉にとつて、「討幕の密勅」をひそかに書き、そのほかにも、かず多くの不法がおこなわれた。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと前後して、さきにも述べたように、岩倉の手でつくられた、偽の、「討幕の密勅」なるものが、薩長の二藩に出された。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならば、彼の手許には、後白河法皇の密勅が、それより幾日か前に人知れず届いていた筈であるから。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「密勅です」　一学の声は、低いが、おごそかである。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
