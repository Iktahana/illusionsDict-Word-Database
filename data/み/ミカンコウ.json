        "examples": {
          "standard": [
            {
              "text": "その重要な歴史資料は、現在も学術機関によって未刊行のまま厳重に保管されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "未刊行の詩集に収録される予定だった作品が、ファンの有志によってウェブ上に公開された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は自分の半生を綴った未刊行の自叙伝を、そっと金庫の中に隠した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "此書の下巻は未刊行のものださうで、頃日箕山さんは蘭軒の伝を稿本中より抄出してわたくしに寄示してくれたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでそういう本とか、外にも未刊行のものがあることが想像されるので、一度ぜひ拝見したいものと思っている。",
              "citation": {
                "source": "『雪華図説』の研究後日譚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボドレアン図書館にある彼の未刊行の草稿は大学出版会のクラレンドン・プレスで出版されることになっている。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "未刊行の医学著作も含まれることを希望している。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            }
          ]
        }
