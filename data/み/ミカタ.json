    },
    "definitions": [
      {
        "index": 1,
        "gloss": "viewpoint",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "芸術不振の原因を社会の事情に在りとする見方は、常に十分なものではない。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで特に「主観的」と言ったのは、新詩人としての僕の見方が、一般俳壇人のそれに比して、多少新しく変ったところがあるかも知れないと思ったからだ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天の一方に」は、「天一方望美人」というような漢詩から、解釈の聯想を引き出して来る人があるけれども、むしろ漠然たる心象の幻覚として、天の一方に何物かの幻像が実在するという風に解するのが、句の構想を大きくする見方であろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした見方からして、この句は蕪村俳句のモチーヴを表出した哲学的標句として、芭蕉の有名な「古池や」と対立すべきものであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんこれは自分等の年輩のものの自分勝手な見方ではあろうが、こうした見方もあるいは現代の俳人に多少の参考にはなるかもしれないと思ったので思い出話のついでに拙ない世迷言を並べてみた次第である。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが私の富士の見方である。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから私は思う、外国の山を見るには、二つの見方が、経験されはしまいか、即ち自分の国の自然に似ている方面と、似ていない方面との二つである。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村であったか誰だったか、「花茨故郷の路に似たるかな」は、似た方からの見方だ。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般に上品に或るものを加えて「いき」となり、更に加えて或る程度を越えると下品になるという見方がある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は子供の見方をするように人々はまた思い思いの見方をしているであろう。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この所説を見ても西鶴の態度を科学的と見るという見方はおそらく多くの人に共通な見方であって自分が今ここに事新しく述べるまでもないことかも知れないであろうが、ただ自分が近頃彼の作品を乱読しているうちに特に心付いた若干の点を後日の参考また備忘のために簡単に誌しておきたいと思った次第である。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくそういう見方から西鶴の探偵趣味とその方法を観察するのも一興であろう。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳密なる意味において「物理的孤立系」なるものが存せず、すなわち「万物相関」という見方よりすれば、一つの現象を限定すべき原因条件の数はほとんど無限なるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとき見解と期待との相違より生ずる物議は世人一般の科学的知識の向上とともに減ずるは勿論なれども、一方学者の側においても、科学者の自然に対する見方が必ずしも自明的、先験的ならざる事を十分に自覚して、しかる後世人に対する必要もあるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう風に考えて来ると、方則というものの見方が色々あるように思われる。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの見方は、この方程式の後尾へそれ自身に小さくまた沢山の場合の平均が零に漸進するような無限級数を附加して考えるのである。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にその対象の見方および取扱いの上に如何なる特徴があるかと考えてみると、その対象の形態的ないし心理的の現象の中である特別な部分を抽象してその部分を誇大しあるいは挙揚して表示するというのが一つの顕著な点である。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三に地質学上の現象として地震を見るのもまた一つの見方である。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乍併さういふ意味に於て歌の価値を認めるのは、吾輩の考へでは、歌といふものを余りに侮蔑した見方であると思ふのである。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はまた見方によれば一種のディレッタントであったようにも見える。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点がどこか吾々科学者の心掛けるものの見方に類するところがあるように思われるのである。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学の場合には方則の普遍性とか思考の節約とかいう事が標準となって科学者の自然に対する見方を指導しその価値を定めて行くのである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに比べて芸術家が自然に対する見方は非常に多様であり得る事は勿論である。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術家としてどうすれば新しい見方をする事が出来るかという事は一概に云えない。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも多様な見方の上に組立てた科学的系統が相併立しているような観がある。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏みかためられ、凍てついた道から外れると、馬の細長い脚は深く雪の中へ没した。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風のない夜で涼みかたがた見物に来る町の人びとで城跡は賑わっていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話の番号じゃあるまいし、ちゃんと正しい読みかたをしてもらいたいものだ。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう百年あとには、しちひゃくでもないし、ななひゃくでもないし、全く別な読みかたも出来ているかも知れない。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何んです」　相島は意味の分らないほゝゑみかたをした。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
