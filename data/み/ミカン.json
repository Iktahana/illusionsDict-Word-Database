        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "incomplete",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「君の詩は未完成の藝術だ」と。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "未完成であると思う。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹園宮沢賢治髪白き山田博士が書いだき帰り往くころかはたれはしづに這ひ来てふくよかに木の芽ほごるゝ鳥飛びて気圧を高み守衛長〔以下未完〕ぎごちなき独乙冠詞を青々となげく窓あり",
              "citation": {
                "source": "樹園",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに僕は――君の聰明な友人芥川龍之介氏が評した通り――藝術上にも未完成の人物なのだ。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「邪宗門」が未完成、又は生硬な象徴詩だといふ非難はあつても、同氏の歌集「雲母集」が象徴詩でないといふことは何人にも言へません。",
              "citation": {
                "source": "ふつくりとした人柄",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくは未完成の下図であつたらう。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは作者と私との趣味の相違や、私の讀み方の不足や、作者の技巧の未完成が混り合つて原因してゐるのであらうが、そんな個所は末梢的であつて、何よりも私はこの作品を貫いてゐる作者のまともな精神に觸れて心強く思つた。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大部の未完原稿が此の間屆き、私は驚いた。",
              "citation": {
                "source": "青空同人印象記（大正十五年六月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "その少女の未完成と無垢とが彼女の墓の戸を開いたままにさせてをり、そのためその少女は死んでゐても、一方では生の半分をいきいきと保ち、もう一方では他の大きな傷口をひらいてゐる半分の方へ開いてゐるといつた、一種の能力をもつてゐるのです。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "このおそらく永遠に未完成であるべき物理的科学の殿堂の基礎はだれが置いたか。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、このトーキー器械の科学的機構は未完成である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃腸の弱い瀬川はたまに猪口を手にするだけで、盃洗のなかへ滾し滾しして、呑んだふりをしていたが、お茶もたて花も活け、庖丁もちょっと腕が利くところから、一廉の食通であり、（未完）",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "未完成の草稿を焼き捨てるとか、湖中へ沈めるとかいう考えも浮ばないではなかったが、それほど華やかな芝居気さえなくなっていて、ただ反古より、多少惜しいぐらいの気持ちで、草稿は鞄の中へ入れて持ち帰った。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼈四郎は病友の屍体の肩尖に大きく覗いている未完成の顔をつくづく見瞠り「よし」と独りいって、屍体を棺に納め、共に焼いてしまったことであった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "未完成のまゝ花器の根元を持つてそつと桂子が押しやつたずんどうの花活へ、水を差しながらせん子がいつた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間は戸惑つて、彼を将来ある未完成の画家の範疇にあつさり片付けた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてこの世で未完成だつた人間に、自然は一人の子供でも残させなけりや……」　小布施は疲れ切つて、またベツドへ横になり、爪先を立て、寝ながらいくらか反身になつた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十四年に書いた私の「火の鳥」という未完の長編小説に、次のような一節がある。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の文華が小さく完成して行きづまつてゐる時、この津軽地方の大きい未完成が、どれだけ日本の希望になつてゐるか、一夜しづかに考へて、などといふとすぐ、それそれそんなに不自然に肩を張る。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（未完）〔生前未発表・明治四十一年七月稿〕",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（未完）（四）　落人ごゝろ　（つゞき）　燈光燦として眩ゆき所、地中海の汐風に吹かれ来しこの友の美髯、如何に栄々しくも嬉しげに輝やきしか、我は実になつかしき詩人なりと思ひぬ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（未完）（八）　権威は勝利者の手にあり　（続）　而して今茲に有生十五億を眩目せしむるの巨光、而して又、世界第二の文明を経営すべき参天の巨柱は建設せられたる也。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（未完）（九）　権威は勝利者の手にあり　（続）　斯くの如きは、吾人が一歳有半の間、上下一致、民族的和協の実をあげて遂行したる猛烈の健闘によりて、漸やく贏得するに至れる帝国現下の状勢也。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（未完）（二十一）　十一夜会の記　陰暦｜水無月の十一夜、月いと美しき夜なりき。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘さえ言えぬ未完成な生命なのだ。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遂に終りということを知らない人間の歴史は、未完成は完成の始まりで完成は未完成の発足点であるという連鎖の不分明を教えているようでございます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "未解決や未完成を恐れて何で解決や完成に旅立たれましょうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、肉附きも骨格も好くて、内部に力が籠っている未完成らしい娘だった。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月に二人は本家に呼ばれて行ってみんながみかんをたべたとき楢夫がすばやく一つたべてしまっても一つを取ったので一郎はいけないといふやうにひどく目で叱ったのでした、そのときの楢夫の霜やけの小さな赤い手などがはっきり一郎に見えて来ました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みかんの木もあれば竹もあります。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
