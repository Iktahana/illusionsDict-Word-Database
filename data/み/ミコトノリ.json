    "definitions": [
      {
        "index": 1,
        "gloss": "imperial decree",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "マレー半島に奇襲上陸、香港攻撃、宣戦の大詔、園子を抱きながら、涙が出て困った。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち詔して明年を建文元年としたまいぬ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其歳閏九月、たま／＼天文の変ありて、詔を下し直言を求められにければ、山西の葉居升というもの、上書して第一には分封の太だ侈れること、第二には刑を用いる太だ繁きこと、第三には治を求むる太だ速やかなることの三条を言えり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其遺詔こそは感ずべく考うべきこと多けれ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "太祖の遺詔感ず可く考う可きもの無からんや。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺詔に曰く、朕皇天の命を受けて、大任に世に膺ること、三十有一年なり、憂危心に積み、日に勤めて怠らず、専ら民に益あらんことを志しき。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "秦王｜｜宜しく大位に登るべしとは詔を遺されたるなるべし。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "太祖の遺詔、嗚呼、何ぞ人を感ぜしむるの多きや。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然りと雖も、太祖の遺詔、考う可きも亦多し。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚呼、これ罪斉泰にあるか、建文帝にあるか、抑又遺詔にあるか、諸王にあるか、之を知らざる也。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "又｜飜って思うに、太祖の遺詔に、果して諸王の入臨を止むるの語ありしや否や。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は疑う、太祖の人情に通じ、世故に熟せる、まさに是の如きの詔を遺さゞるべし。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "太祖の智にして事｜此に出でず、詔を遺して諸王の情を屈するは解す可からず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に曰く、太祖の遺詔に、諸王の入臨を止むる者は、太祖の為すところにあらず、疑うらくは斉泰｜黄子澄の輩の仮託するところならんと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "斉泰の輩、もとより諸王の帝に利あらざらんことを恐る、詔を矯むるの事も、世其例に乏しからず、是の如きの事、未だ必ずしも無きを保せず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "真耶、偽耶、太祖の失か、失にあらざるか、斉泰の為か、為にあらざる耶、将又斉泰、遺詔に托して諸王の入京会葬を遏めざる能わざるの勢の存せしか、非｜耶。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸王の入京会葬を遏めたる時の如き、諸王は皆｜謂えらく、泰皇考の詔を矯めて骨肉を間つと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "臣又願わくは陛下｜益々親親の礼を隆んにし、歳時伏臘、使問絶えず、賢者は詔を下して褒賞し、不法者は初犯は之を宥し、再犯は之を赦し、三｜犯改めざれば、則ち太廟に告げて、地を削り、之を廃処せんに、豈服順せざる者あらんやと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "建文元年二月、諸王に詔りして、文武の吏士を節制し、官制を更定するを得ざらしむ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに於て事燕王に及ばざる能わず、詔ありて燕王を責む。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝廷よりは燕王の爵を削るの詔、及び王府の官属を逮うべきの詔至りぬ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "臣｜伏して祖訓を覩るに云えることあり、朝に正臣無く、内に奸悪あらば、則ち親王兵を訓して命を待ち、天子｜密かに諸王に詔し、鎮兵を統領して之を討平せしむと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "君側の奸を掃わんとすと云うと雖も、詔無くして兵を起し、威を恣にして地を掠む。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此役や、燕王｜数々危し、諸将帝の詔を奉ずるを以て、刃を加えず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝｜大理少卿薛」］を遣りて、燕王及び諸将士の罪を赦して、本国に帰らしむることを詔し、燕軍を散ぜしめて、而して大軍を以て其後に躡かしめんとす。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王、指揮武勝を遣りて、朝廷兵を罷むるを許したまいて、而して糧を絶ち北を攻めしめたもうは、前詔と背馳すと奏す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "誓書および遺詔を出して授けたまい、敢て天に違う者あらば、朕が為に之を伐て、と言い訖りて崩れたまえるなり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王兵を挙ぐるに及び、日に召されて謀議に参し、詔檄皆孝孺の手に出づ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "是の如きの論を為せるの後二十余年にして、一朝｜簒奪の君に面し、其の天下に誥ぐるの詔を草せんことを逼らる。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学らしい言葉で云われている林房雄のみことのりに、だまって肯く英文学者を前において、彼は更に首相の息子吉田健一の「英国の文学」を、推薦している。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
