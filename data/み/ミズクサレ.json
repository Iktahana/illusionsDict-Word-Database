        "examples": {
          "standard": [
            {
              "text": "長雨のせいで、畑の野菜が水腐れを起こしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "水腐れを防ぐためには、適切な水はけが必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今年の稲は水腐れがひどく、収穫量が大幅に減った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これこそは、今日この頃のまだ小雪のちらちらする寒さにも、早くも春の動きを感じて、塩と淡水との境、水底の砂子まじりに、また水腐れがした蘆の葉などにそれみづからを生みつけようとの衝動から、いたいたしいまでに弱さうな、痩形のお前をして冒険にも長い寒水の旅に上らせたものなのだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭でつかちのどんこは、餌をもとめて水腐れのした塵つ葉か何かをぱくりと銜へ込み、それと気づいてしぶしぶ吐き出しはしたものの、思ひ切れないで未練がましくまたその後を追い縋らうとする愚しさ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
        }
