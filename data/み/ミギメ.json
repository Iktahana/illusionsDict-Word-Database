        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "次にこれが三度目をパチクリさせたあと、右目でウインク。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "べこ右目にものもらいが出来て痛い。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "右目の奥に光電子セル幕があって、画像がはいると機械が動くようになっている。",
              "citation": {
                "source": "理想",
                "author": "THE IDEAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィレット医師は往診の後よくその絵の前に立ち止まっては、生き写しともいうべき類似性に驚きながら、今や絵の顔の右目の上にある小さな窪みだけが、大昔に死んだ魔法使いといま生きている青年とを区別できる点になってしまったと考えたものだった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも変な髭で、黒眼鏡を掛けた右目の上にわずかな瘢痕があると彼らは思った。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく五分と五分の戦いが続いたが、遂に黄金の剣が大魔王ミノスの右目を潰す。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "右目から青い鮮血をとめどなく流しながら、ミノスはガラス窓を突き破って外に逃げた。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大魔王ミノスは右目にドクロマークのついた眼帯をしている。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺の右目をよくも潰してくれたな。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "右目にはドクロマークのついた眼帯をしている。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその輪を右目に当て、湖を見渡した。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば小太り、小さな口ひげをワックスで固め、右目に片眼鏡をはめた中年の伊達男だ。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は囚人ということですか」　小男が片眼鏡を右目にしっかと押し込んだ。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "右目の上に真新しい傷があり、血が垂れている。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
