[
  {
    "uuid": "0c3f76a6-3703-5bb9-bca3-ea37ff4b30d9",
    "entry": "身につまされる",
    "reading": {
      "primary": "みにつまされる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-一段"
      ],
      "ctype": null,
