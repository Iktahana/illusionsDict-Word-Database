        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "右上に斜に鉄道線路が二本引いてある。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島はやがて遙か右上方に幽かな、一握りの灰を撒いたくらゐの汚點を認めて、「あれは何だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "目はまぶたによって任意に開閉され、また頭を動かすことなしにある程度までは自由に左右上下に動かされる。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島はやがて遥か右上方に幽かな、一握りの灰を撒いたくらゐの汚点を認めて、「あれは何だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときには、私の家の人たちは、その記念写真の右上に白い花環で囲んだ私の笑顔を写し込む。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "右上肢及右下肢のあらゆる骨は多少挫折せられたり。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてすこし下っては、左右上下の天井を懐中電灯で照らし注意深い観察をしては、またすこし身体を後退させていった。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、全体として見ると右上から斜めに左下に向かった方向が多いということだけは明らかに認められる。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその右上の隅には、戦略的な意味を持つ「Window manager」という書き込みがあり、同書はその写真を転載している。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "右上りの、力を入れて書くのが癖だったので、慣れないうちはよくガラスペンを折った。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "身動きの出来ない中で、ふと自分の肩つきの右上りな、癇で突っ張っているような姿に気づいて妙な心地がした。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋は石室でちょっとわからぬが目印に小屋の右上の尾根へ柱が立ててある。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ん坊はくにやくにやと首や體を左右上下に動かしながら、無心に早苗の方を見てにつと笑つた。",
              "citation": {
                "source": "風媒",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "象牙の篦を結び付けた暗褐色の紐を解いて巻物をすこしばかり開くと、紫黒色の紙に金絵具で、右上から左下へ波紋を作って流れて行く水が描いてあるが、非常に優雅な筆致に見えた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "珈琲の汚染は殆んど全部に亘っていて、汚れていない処は右上の角の一部分しかない。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなものを一渡り見まわした私は、最後に、右上の端の珈琲の汚染の附いていない処に眼を注いだ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、四つの創形を云うと、そのうちの二つは左右上膊部の外側、即ち肩口から二寸ほど下方にあって、残り二つは、左右腰骨の突起部、即ち大臀筋の三角部だった。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その正方形の窓――それがどうして窓でないと云へよう――の右上から左下へかけて、對角線を引いて、下半分が青黒い蔭になつてゐた。",
              "citation": {
                "source": "桂離宮",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近々に見ますと、その額の、時々寄りあう眉の右上に、厚化粧では隠れそうに思われるほどの淡さで、拇指の先ほどの大きさの痣がありました。",
              "citation": {
                "source": "乾杯",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす桃色の大きな波が、その空間をうずめて、左右上下にさかんに動いていた。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うそをつくと――」　と、ケレンコがいいかけると、「正面、舳のわずか右上に、うす黒く、ぼんやりしたものがあるでしょう」「あああれか。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "見えなければならない筈のものが見えないといふ一種の視力変調をいふのであつて、求心性は一定距離に於ける左右上下の視野が交互にその一方中心に向つて狭められること、円筒状は、遠くはなれても視野の幅がおなじだといふもの、螺旋状は一定距離に於ける視野が視力試験中だんだん狭まつていくもの、である。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑散とした本屋で、雑誌をぱらぱらめくりよみしていた時、私はある一頁の右上にある写真をみて、自分がひきずられてゆくような感じを抱いた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（同上右上中）形は大體前のものに似てゐるけれども、製法が細かくなり、だいぶ美しく出來てをります。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "棒を刀のように振り廻すものとでも考えたら大マチガイで、まるで棒が手中に吸いこまれて、前後左右上下の諸方から無際限に目にもとまらぬ早さでとびだし襲いかかってくるものと思い知っておかねばならぬ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿皮の爪磨きで爪を磨きながら、ゆうゆうと十三世の動作を観察していたタヌは、そこで、いきなり立ちあがって窓のそばまでゆき、せっかくの自由画を掌で拭い取ってから、その右上へ、　と、書きつけて、軽蔑したように肩をぴくんとさせた。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "謝肉祭の支那服　――地中海避寒地の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおその上、右上の糸切歯に金が被さっていた。",
              "citation": {
                "source": "理想の女",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからは急に岩質が変って、角々した岩場になるが、すぐ正面は小さいながらも壁をなし水が滴っていてちょっと厄介に見えたので、左に割込む細いリンネの方へ廻り、それから右上へと登路をとる。",
              "citation": {
                "source": "一ノ倉沢正面の登攀",
                "author": "小川登喜男",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンタの　おじさんは　このおねがいに　こころ　うたれたのですが　……　※あんないで　わかったこと：　おおきな　おへやが、　ふだん　サンタさんの　いるところで、　みぎうえに　みえる　あなから　ババールは　ここへ　おっこちてきた。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
