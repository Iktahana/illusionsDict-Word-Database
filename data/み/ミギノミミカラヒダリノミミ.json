        "examples": {
          "standard": [
            {
              "text": "彼にいくら忠告しても、いつも右の耳から左の耳へと抜けていってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "母のお説教を右の耳から左の耳へ聞き流しながら、夕飯のメニューを考えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大事な説明をしているのに、彼は退屈そうに右の耳から左の耳へ流しているようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "さて、手ぬぐいで顔をふこうとしますと、とめ針がすうっと顔をこすって、おかげで右の耳から左の耳まで、赤いミミズばれができてしまいました。",
              "citation": {
                "source": "ならずもの",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは真理をありのままに聞くと、早合点をしてすぐにわかってしまったように思い、聞いた真理の言が心の底に届かないで、右の耳から左の耳に抜けてしまいやすい。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            }
          ]
        }
