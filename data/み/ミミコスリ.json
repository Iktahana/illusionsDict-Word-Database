    },
    "definitions": [
      {
        "index": 1,
        "gloss": "whispering into someone's ear",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なんだかみんな耳こすりでもしているようだと思いながら一時間がたちました。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふもこの家で、」と、彼はイワン・フョードロ※ッチを傍へ引つぱつて行つて耳こすりをした。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴らは君を贋金づくりだろうと言って、しつこくおれに耳こすりをしやがるのさ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は耳こすりした。",
              "citation": {
                "source": "展望",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は暫く默つてゐた、そして再び彼等も耳こすりした。",
              "citation": {
                "source": "展望",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はて、何をしているんだろう、誰かクレヴァースへ落ちたのか知らん、声をかけたものか……それとも……耳がかっと鳴って、頭は火のように熱い、そして襟から背筋へかけて、氷でも注がれたようにぞくぞく寒気がする、考えながら見なおすと、どうも耳こすりでもしているのか、どれとは無しに動くらしい。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、耳こすりという段取りになりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっぱりと溜飲をさげて、どう出るだろうと思って高見の見物をしていると、志貴子はいきなりあたしのそばへ来て、わざと木津さんに聞えるような高ッ調子で、「そこにいやはりますのン、木津さんじゃありませんの」と耳こすりをするじゃありませんか。",
              "citation": {
                "source": "猪鹿蝶",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "巧みに英支事情を捕えて日本開国を先取した米国からも同様な耳こすりがあって、英国はますます幕府から袖にされた。",
              "citation": {
                "source": "尊攘戦略史",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことによると――愚楽老人が八代公との相談から、そっと大岡様へ耳こすりした、その方面から来た侍か……？",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっぱりと溜飲をさげて、どう出るだろうと思って高見の見物をしていると、志貴子がいきなりあたしのそばへ来て、わざと木津さんに聞えるような高ッ調子で、「そこにいやはりますのン、木津さんやありませんの」と耳こすりをするじゃありませんか。",
              "citation": {
                "source": "姦（かしまし）",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房はチョッと舌打をして、男に耳こすりをした。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」お徳は新らしいお銚子を持つて來てお若に何か耳こすりをする。",
              "citation": {
                "source": "俳諧師",
                "author": "高濱虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉は、太閤殿下ともなられながら、昔の小才がぬけないで人に耳こすりをする癖があると時人に眉をひそめられた。",
              "citation": {
                "source": "くせ",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、それからまる一か月、当地ではこの事件であられもない噂が町中に広がり、はては皆がさげすむような目つきで人を見たり、ひそひそ耳こすりをしたりするので、わたしやドゥーニャは教会へも行けなくなったくらい、中にはわたしたちを目の前に据えて、聞こえよがしに話し合う人もあるのです。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "まわりを見ると同じ年ごろの娘たちはたいていつれがあって、おかしそうに耳こすりをしたり、ささやいたり※ぜをしあったりしている、慎ましくとりつくろっているだけ余計に楽しそうである。",
              "citation": {
                "source": "合歓木の蔭",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、もう学校も始まる時分やし、早く帰らないとルミーさんもマニラへ立ってしまうし、………と、悦子はぽつぽつ母に耳こすりをする始末であった。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ妙子の帰りしなに、こいさんもっといててやったらええやないかと、傍へ寄って来て親切めかしく耳こすりしたのが、皮肉と取れば取れなくもなかった。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしはあの人の女房ですよ、世間の者がどんな眼で見、どんなふうに耳こすりをするか、知らないとでも思ってるの、女房のあたしを見る眼が、娘のおまえを見るより棘がないとでもいうの、とおみきは思ったが、口には出さなかった。",
              "citation": {
                "source": "枡落し",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蔭でこそこそ耳こすりをするほうが、木剣を使うより身についたらしいな」「なんですって」「もういちど云おうか」　兵庫介は立った。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんそれらは幾たびも洗濯し、縫い直されたものだったし、色も柄もじみな品で、袷から単衣に着替えても、さして人の注意をひくようなことはなかったが、中に眼のするどいかみさんなどがいて、はら立たしげに耳こすりをすることがないでもなかった。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ、それじゃあ、たった今、黒谷の尼と、物蔭で耳こすりしていたのは、その取引だったのか」「童の着けている狩衣と太刀だけでも、物代以上の値はふめる」「ふてえ奴。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……が、そうした心の機微へつけ入って、ある事、ない事、努めてご兄弟が離反してゆくように、耳こすりする讒者もあるから薪に油です」「讒者。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、すぐにゴロリと横になって、手枕をかいながら、生意気そうな鼻の穴を宮内のほうにむけ、「おじさん、いまおめえは、この向こうにはいっている竹童のところで、なにかコソコソ耳こすりをやっていたろう」　といった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう人の耳こすりや潮笑にも、めったには怒らないぞと、顔に錠前をかけたような無口に変った。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日旅の寝小屋で枕につくと、耳こすりで騒めき始めた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　妓と妓は、顔見合わせて、まるで耳こすりでもするように、宋江へ囁いた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するうちに、弟子のひとりが、彼に何か耳こすりしていた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かまわんというに」「そ、そんなことを、遊ばしてはいけません」「大事ない」「……あれ」「何を躁ぐ、耳こすりじゃ、そっと申そうものを、はて、心ない声を出すものかな」「いけません」　そこへ半兵衛が退って来た。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、そのところを、チョッピリ耳こすり致しますが、蜂須賀様じゃ、また近頃、だいぶ精を出して、火薬を買い込むって話じゃございませんか――あの天下｜御法度の戦薬をね。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "木曾の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
