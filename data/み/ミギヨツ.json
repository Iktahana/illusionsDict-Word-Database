          "literary": [
            {
              "text": "高さ四尺幅三尺程の大幅の中には、画面一杯に羽を拡げた印度孔雀に、駕し左右四つの手に、各宝珠を捧げ説法の印を結んだ異形の女身仏が、背上の蓮台の上に趺座しているのだ。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右四つの伝記はおのおのに特色があります。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "右四つに組んだ巨躰は千斤の鉄塊のように重く、じりじりと引く双腕の膂力はまんりきのように強靱であった。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
