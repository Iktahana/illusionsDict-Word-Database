        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ちょうど『美しいシャボン玉』を壊さないように、注意に注意して気をつけましたと、未亡人となった夫人が後で言っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく人の途絶えたときに、仏になった老人の未亡人が椅子に腰かけて看護に疲れたからだを休めていた。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その背後に立っていたのは、この未亡人の二人の娘で、とうに他家に嫁いで二人ともに数人の子供の母となっているのであるが、その二人が何か小声で話しながら前に腰かけている老母の鬢の毛のほつれをかわるがわるとりあげて繕ってやっている。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジァンペートロというバリートンが当時異常な人気を呼んでいて、なんでもある貴族の未亡人から、自分の願いを容れてくれなければ自殺するという脅迫を受けて困っているというような噂が新聞で持て囃されたが、しかしそれは単に宣伝のための空ごとだというゴシップもあった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一族はこれからイレエネ・ホルンと云ふ未亡人の邸へ食事に行くのである。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルリンの下宿はノーレンドルフの辻に近いガイスベルク街にあって、年老いた主婦は陸軍将官の未亡人であった。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの「先生」は、青木さんといって三十歳前後の、いわゆる戦争未亡人である。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……南堂未亡人の執念……？",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "南堂伯爵未亡人の死と、私とを結び付けて考え得る者は、今逃がしてやった一匹のお女郎蜘蛛以外に絶無である。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "南堂伯爵未亡人との約束を果したいからだ。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今朝の零時半キッカリに、南堂伯爵未亡人を、その自宅に訪問した。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "南堂伯爵未亡人は、その尤なる者であった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨万の財産を死蔵して、珍書画の蒐集に没頭していた故伯爵が四五年前に肺病で死ぬと間もなく未亡人は、旧邸宅の大部分を取毀して貸家を建てて、元銀行員の差配を置いた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "未亡人の美しさが見る見る年月を逆行し始めたのは、その頃からの事であった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……事実……私が南堂伯爵未亡人の素行調査にアンナにまで夢中になり始めた、そのソモソモの動機というのは、アノ粗末な、赤煉瓦の煙突に外ならなかったのだ。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その番号から運転手の名前を探り出して、鼻薬を使いながら未亡人の行先を尋ねてみると、私の着眼が一々的中している事が裏書きされて来た。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家政婦の自宅と名前は可哀相な筋合いがあるからここには書かないが、××戦争で死んだ勇士の未亡人であったことは間違いない。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一方に伯爵未亡人が案外に手剛いらしいのにも驚いた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おわかりになりまして……今夜の十二時半……わたくしの家の裏門……」　という未亡人自身の声がした。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "指定された通りに裏門の潜り戸から這入ると、そこいらのベンチに待っていたらしい訪問着姿の未亡人が出迎えた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私の手を離した未亡人が、室の真中まで行って電燈の紐をコチンと引っぱった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして伯爵の死後、未亡人が秘密の享楽場としていたものに相違なかった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何もかも御存じの事ですから、ズットお負けしまして半額の五千円ぐらいでは如何でしょうか」「それでおよろしいですの」「結構です」　未亡人は卓子の下からハンドバックを取出して札を勘定し始めた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに未亡人は札を数え終った。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更に伯爵未亡人の名声が高大な理由を認めない訳に行かなかった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分でも気付かないうちに未亡人の魔力に毒されていたのであろうか。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に未亡人は紅茶を入れて来た。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなものが妾と何の関係が……」　そう云ううちに未亡人は何となく気味わるそうな表情になった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなにシラをお切りになっちゃ困りますね」　未亡人は私の顔を正視した。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の顔を穴のあく程みつめていた未亡人の頬に見る見るポーッと紅がさして、眼がこの上もなく美しくキラキラと輝やき初めた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
