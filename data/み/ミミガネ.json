        "examples": {
          "standard": [
            {
              "text": "この大きな土鍋には、持ち運びしやすいように頑丈な耳金が取り付けられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い吊り鐘の耳金が腐食しており、落下の危険があるため修理が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「鍋の耳金のところに布巾を引っ掛けておくと、熱くてもすぐ持ち上げられるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "高木敏雄君また前年この譚の類話を求められた時、予が答えた二、三の話を挙ぐると、まず蒙古の譚に、ある王の耳金色で驢耳のごとく長きを世間へ知れぬように腐心し、毎夜一青年にその頭を梳らしめ終ってすなわち殺した。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
