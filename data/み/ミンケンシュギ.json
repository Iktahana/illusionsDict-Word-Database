    "definitions": [
      {
        "index": 1,
        "gloss": "democracy (as propounded by Sun Yat-sen)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
