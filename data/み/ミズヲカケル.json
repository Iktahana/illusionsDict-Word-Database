          "literary": [
            {
              "text": "けがれた心を洗いまひょと、彼女たちは不動明王の尊像に水をかける。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（※）　水をかけると、××ふきかへした。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "山のやうに嵩くなると、熊手で掻きなして上から肥桶に何荷もの水をかける。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時になると彼一人また煙草の方へ行つて、苗床に水をかける。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷もつに火がつくので水をかける、そのあまりをかい出すもの、舟をこぐもの分業で命からがらにげ出したのだ。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間なるものにどんなに絶望したとしても、この本を読みなおせば、少なくとも私は希望の芽に水をかけることができると思う。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さあさあ水をかけるがいい」「承わる」　と小次郎は、傍の土瓶を取り上げた。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして井戸端へ来て、黒い足に水をかけると、タワシでゴシ／＼とこすりました。",
              "citation": {
                "source": "黒んぼ会",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私らは外からチョボ／＼水をかけるぐらゐのものだが、この少年は無我夢中まつたゞ中へとびこんで突く蹴る倒す阿修羅の如く火勢の中心をゆるめてくれたので、四五人でともかくこゝを処理した。",
              "citation": {
                "source": "模範少年に疑義あり",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "水がかかるよ」「なあに、水をかけることはないよ。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "此も元は、水をかける若者が、神の資格に於てしたことゝ思はれる。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "浄めのお水をかけることを稼業にしている老人は、可哀そうに、死んでしまった。",
              "citation": {
                "source": "親ごころ",
                "author": "モオパッサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男は、浄めのお水をかける道具に指を触れた。",
              "citation": {
                "source": "親ごころ",
                "author": "モオパッサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "火でも消すように暖炉へ水をかける。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そなたはお船頭の扱いで、栄耀をしているから気がつかなかったろうが、この船の水夫どもは、わしらが乗ったのを縁起悪がり、ちょっと甲板に出れば、後から蹴る、棒切を投げつける、突っころばすやら水をかけるやら、この間などは、控綱に触ったというばかりに、猫吊しにして海へ投げそうにした。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しは楽になるかと筧の水をかけると、焼けた石や鉄のように水がはね返ってじゅうじゅうと音をたてる。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第六巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾いた砂山に水をかけると、水は滲み込んで失くなつて了ふだらう。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と、しゃがんで、金吾の足に手で水をかける音）金吾　どうも。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（涙声）……さ、一郎、あんたも水をかけるの。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（幼児の手に持ち添えて水をかける。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（墓に水をかける）お母さん！",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――縮緬は濡れると縮むから、力一杯締め、固く結んだ上、水をかけると締つて容易と解けない、水差しが引くり返つて、疊も床も濡れて居たのは、自分の首を締めて、後の始末が出來なかつた爲だ」　平次の解説の鮮やかさ、あまりの事に一座の者は顏を見合せるばかりです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "華魁崩れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "醫者が來る前に、呼び掛ける者、泣き叫ぶもの、水をかける者、背中を叩くもの、滅茶々々な介抱をしましたが、お百合はもう息を吹き返しさうもありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "禁制の賦",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者が来る前に、呼び掛ける者、泣き叫ぶ者、水をかける者、背中を叩く者、滅茶滅茶な介抱をしましたが、お百合はもう息を吹き返しそうもありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "禁制の賦",
                "note": "青空文庫"
              }
            },
            {
              "text": "立って焼石に水をかける。",
              "citation": {
                "source": "モスクワ印象記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「海綿の大きなのを集めて、海水をかけ、天日にかわかしては、また海水をかける。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして火事の進行を阻止するために風下の家を取りこわし、機械は焔に水をかけるのでなく、この仕事をする消防夫達に水をかけ、かくの如き小さな迸水装置は、迅速に取り上げて火事の現場へ持って行くことが出来る。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛火に水をかけるといっても決して勇しい姿ではなく、ただバケツをぶらさげているだけで、たまに水をかけてみたり、ぼんやり立ったり歩いてみたり変に痴鈍な動きで、その男の心理の解釈に苦しむような間の抜けた姿なのだった。",
              "citation": {
                "source": "白痴",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "このヤロー」　燃える火の前へ引きずり下されて、カメはさすがにポカンとしているのを、また打ちのめして、水をかける。",
              "citation": {
                "source": "淪落の青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "このカントリー・アンド・ウエスタンに対して、水をかける役を持ちつつ結合したのがリズム・アンド・ブルースのブルース性と現代性だった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
