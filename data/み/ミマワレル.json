      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be hit (by a typhoon, earthquake, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それでたぶん、年じゅう胃が悪くて時々神経衰弱に見舞われる自分のような人間には楽焼きの明るさも恋しいがまた同時に青磁にも自然の同情があるのかもしれない。",
              "citation": {
                "source": "青磁のモンタージュ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえは一週間以内に、どろぼうに見舞われるぞ。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついつい、わがままも出て、それだから、こんどのように、こんな気味わるい吹出物に見舞われるのです。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "刃向かう場合は死に見舞われるのが常で、その方法は奇怪かつ予期不可能なるが通例。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今の花江と結婚するとすれば、――花江が夢殿村に勤めている以上、いずれ遅かれ早かれ、その村の患者と同様な病いに見舞われることは覚悟していなければならぬのだ。",
              "citation": {
                "source": "馬車",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだからというて別に彼らを慰めてやる方法もないので困って居た所が、この正月に碧梧桐が近所へ転居して来たので、その妻君や姉君が時々見舞われるのは、内の女どもにとりてはこの上もない慰みになるようになった。",
              "citation": {
                "source": "病牀苦語",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "前途有為な壮年の人が、中途で死に見舞われるのは悲惨だと思うのも、大なる間違である。",
              "citation": {
                "source": "生活について",
                "author": "――地方の青年へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも苦痛なのは、暴風雨に見舞われることだ。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "標高千米突内外の筑波や箱根では、麓で天候を予想して登っても、大なる失策はなかろう、が三千米突以上の高山となると、山麓で晴天の予想も、頂上へ行くとがらりかわり、折々雲霧に見舞われる、これによると、今回のように度々御幕がかかるのが、かえって嵩高に感ぜられる。",
              "citation": {
                "source": "穂高岳槍ヶ岳縦走記",
                "author": "鵜殿正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち一八八四年からのち、彼は毎年の春から夏にかけて、救われがたい憂欝症――数ヵ月にわたって持続する無興味と無気力と不眠症――に定期的に見舞われるに至り、ようやく創作時における精神の緊張にたえず、作品の数は目に見えて減って行った。",
              "citation": {
                "source": "「あかい花　他四篇」あとがき",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "セエラはいつ行っても屋根裏にいるというわけではありませんし、抜け出たあとをアメリア嬢に見舞われる惧れもないではありませんでした。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「苗字を知らずに、どうして親類が見舞われるのだよ。",
              "citation": {
                "source": "嬰寧",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、労働の維持のための基金が季節の不順に見舞われるごとに大きな急激な変動を蒙る国の繁栄は、決して安全なものでないと考えて間違いないのである。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "振動が止んでやれ安心という時に再び大地震に見舞われるのだから誠に始末がわるい。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ一度大地震のあった地域は、二度も三度も繰り返して大地震に見舞われる可能性があると言う方が真実である。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この問題については、筆者は遺憾ながら将来いつかは大地震に見舞われるであろうと答えざるを得ないのである。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし将来もこの順序で大地震が起こるとすれば、東京が安政程度の激震に見舞われるのは遠い将来のこととなって、きわめて望ましいことではあるが、何しろ十七世紀以後という比較的短い期間について調べた結果であるから、今後長い期間における地震活動の経過を見なければ確かなことは言われないのである。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョア新聞が断片的に与える報道を見ると、世界の資本主義が概して、再び好況に見舞われるのではないかという希望を、人々は持つかもしれない。",
              "citation": {
                "source": "技術の哲学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都帝大に招かれて文化史か精々美学の講座でも持てば好いものを、どう間違ったか、事もあろうに倫理学の助教授になった氏は、御多聞にもれず「洋行」の運命に見舞われる。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "この風土的類型にぞくする日本は、さらに、突発的な季節風に見舞われるという意味に於て特に台風的風土をもつ。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "警視庁などでは、応援団を金網に入れることを研究しているそうだから、スポーツマンシップを出来るだけ早く、こういう具合に純化して了わないと、応援団は気の毒にも金網に入れられて了う運命に見舞われるだろう。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ等の禁を犯すと、不幸か悪運かに見舞われる。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん相手が国老だし、忠言でもしようものならすぐ癇癪を起して、地錦抄だの、草木育種だの、石植譜だのというたね本を持ちだして来て懸河の弁を見舞われる、それで敬遠して、みんなみごとだおみごとと褒めるばかりだから、だから老人すっかり天狗になっているというわけだった。",
              "citation": {
                "source": "明暗嫁問答",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "洪水に見舞われるのは天災で普通のことだとしていたし、ただ洪水のあとで足の指の股が爛れるのや、洪水のおいていった土には草が生えぬのが不思議だと語り合う程度であった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の現実は昔のようなすさまじいそれではないが――いや、もうすこしすると、俺も異常な運命に見舞われる。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼はテオドロスの無神論にかぶれて久しく信心家連中を笑っていたが、自ら死に見舞われると忽ちにして最も極端な迷信に堕した。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからわたしは発作に見舞われると、それをそのままお薬と心得る。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこの忠告を用いずして、事件の渦中に飛び込むようなことがあれば、君は悔いても及ばぬ一大不幸に見舞われるであろう。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいう半｜狂人にはのべつ見舞われるでな、わしは馴れているのじゃ。",
              "citation": {
                "source": "剣の四君子",
                "author": "小野忠明",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、麓をぐるりと取巻かれて持久戦と出られたら、たちまち干乾しに見舞われる」「いまは捨てるときでしょう」宋江の説である。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
