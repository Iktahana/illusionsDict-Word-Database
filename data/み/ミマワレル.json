[
  {
    "uuid": "d0d4084f-bb21-547d-81bc-1cf185526a85",
    "entry": "見舞われる",
    "reading": {
      "primary": "みまわれる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
