[
  {
    "uuid": "4bcf48be-7216-5553-a878-a95781f79546",
    "entry": "皆",
    "reading": {
      "primary": "みな",
      "alternatives": [
        "みんな"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "代名詞",
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "everyone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕は彼の詩集、「春と修羅」を十年来愛読してゐますが、自分が無名のために、此の地方で印刷された驚くべき詩集を、皆さんにお知らせする術を持ちませんでした。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "月蝕皆既萩原朔太郎みなそこに魚の哀傷、われに涙のいちじるく、きみはきみとて、ましろき乳房をぬらさむとする。",
              "citation": {
                "source": "月蝕皆既",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさて、人が皆その幼時に、欣怡の情を有することは確かである。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああこの曠野に戰ふものちかつて皆生歸を期せず鐵兜きて日に燒けたり。",
              "citation": {
                "source": "南京陷落の日に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆あなたのためです』と、さすがにヘルンも夫人に愚痴をこぼしている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人もよくその良人の心を知り、『ヘルンの一生は、皆私や子供のために尽してくれた犠牲でした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカシ朝、海デ泳グカラ、皆、夜ノ心配ヲ忘レマス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼津　八月十七日パパカラ可愛イ子ニ、ソレカラ皆ノ人ニヨロシク。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカシモウ皆スマセマシタ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府が盆踊を禁ずるのも、国民が欧米人の真似をするのも、固有の日本文化が亡びるのも、すべて皆基督教の宣教師が宣伝するためであり、一切の悪は耶蘇教の罪に帰せられた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『皆、耶蘇がさせるのです。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "耶蘇が皆悪くするのです。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故にヘルンもまた、自分の著作は皆妻の功績によるものだといって、深く夫人の労に感謝し、ある著述のごときは、実際に夫人の名で出版しようとしたほどであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆妻のお前のお蔭で、お前の話を聞いて書いたのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで学校に式のある時など、他の教師は皆礼服で列席するのに、ヘルンは一張羅の背広で押し通していた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしヘルンが仕事をしている時は、家人が皆神経質に注意しているので、家中がひッそりとして閑寂に静まり返っていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議に私は、その時の話を皆おぼえてゐる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが自殺しない厭世論者の言ふことなんか、皆ウソにきまつてゐるよ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るものは默し、うなづき、そして皆行き去るだらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その泣菫氏の自選詩集には、僕が昔愛讀した詩が殆んど皆オミツトされ、僕の嫌ひだつた詩ばかりがしかも多くの斧鉞を加へて集めてある。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆が口をそろへて言つてることは、百貨店の繁榮が小賣商人を餓死させると言ふことだつた。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから最後の結論として、皆が一緒に歎息したことは、昔の馬グソ臭い新宿情趣が、近代文明の爲に次第に廢滅して行くといふことだつた。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩いてゐる人たちも、一樣に皆黒いトンビを着て、田舍者の煤ぼけた樣子をして居る。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん皆にわかってもらいたくて出来るだけ、ていねいに書いた筈である。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説家ってのは、皆あんな工合いのものかねえ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学を卒業して雑誌社に勤務するようになってからも同じ事で、大隅君は皆に敬遠せられ、意地の悪い二、三の同僚は、大隅君の博識を全く無視して、ほとんど筋肉労働に類した仕事などを押しつける始末なので、大隅君は憤然、職を辞した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりゃもう、皆さまが、もったいないほど、――」口ごもった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこの家で生れた日の事を、ちゃんと皆が知っているのである。",
              "citation": {
                "source": "六月十九日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つにはだいたい私がそれまでに殆んど読書らしい読書をしてゐず、術語だの伝統だのまた慣用形象などに就いて知る所殆んど皆無であつたのでその口惜しさに遇つて自己を失つたのでもあつたゞらう。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は皆卑屈になつてもう卑屈が卑屈とみえないで、寧ろ思慮あることのやうに考へられるといふふうにまでなつてゐる。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
