          "literary": [
            {
              "text": "未丁年で煙草を喫っていて巡査に年をきかれた。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "未丁年者、被保護者、官公務に服するもの、此等の人々以外の者の疾病は、自ら招致せるも亦多いことで有らうと思はれる。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに書いておくが女囚は八王子におかれ、未丁年囚は川越におかれる。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱衣場では、同志の村木というまだ未丁年の男が一人、蒼い顔をして着物を着かけていた。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般の読者を未丁年者として見る目で、そう認めたのは致し方がない。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」でつぷりして、少し蒼白めた顔の人物　これはエカテリーナ朝に於て劇作者として活躍したフォンウィージン（1745―1792）のことで、彼は純然たる露西亜喜劇、『旅団長』及び『未丁年者』の両作に依つて文学史上不朽の名を残してゐる。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「啓蒙とは理性が自業自得で陥っている未丁年状態から解放されることだ」と。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "理性が自分自身成熟する自由を持っているに拘らず、なお未丁年状態に止まっているのは全く理性自身の責任だというのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ資本主義の後れた発育が理性を未丁年状態に引き留めた責任者などとは決して考えられていない。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "英一　さあ――谷　　そこまで行くと、我々は未丁年ですね。",
              "citation": {
                "source": "火のついた踵",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あ、だが、おまえは未丁年者だからだめだ」「馬券を買わなければいいでしょう」「駄目駄目、観客としてもはいる資格がない。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
