[
  {
    "uuid": "186a6a7b-11e0-52d1-b7bf-13e531ddbefe",
    "entry": "見取り",
    "reading": {
      "primary": "みとり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
