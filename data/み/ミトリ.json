    "definitions": [
      {
        "index": 1,
        "gloss": "perception",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "書物の記載も、見取り図も至極簡単であるからやむを得ない。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時によると僕も日記中に君の見取り図くらいなところを書きとめたこともあるが、それは真の粗雑としたものだ。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然科学の研究なども、プレパラートと見取り図とを作ることに彼は不器用だったが、それさえ除けば、あまり分りきった事実の排列にすぎなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、天主閣の見取り図の写しに取りかかつてゐたのであるが、長い勤労の疲れが凝つて稍ともすれば、唸り声をあげるのであつた。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "半紙いっぱいに書いた見取り図の要所要所へそういう文字を書き入れて、ここ加州家裏門としるしたその門の横の道に、長々と寝そべっている人の姿が見えました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "見取りの図面はめっぽうまずいが、ところどころへ書き込んである字は、このとおりめっぽううまいお家流の女文字だ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと以前に如雲社という会が京都であって、確か毎月裏寺町で開かれていたが、ここには京中の各派の社中の方々が思い思いの出品もされ、私もそのいいのをよく見取りもさせて貰った。",
              "citation": {
                "source": "随想",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "都合よいのを選り取り見取りで。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、刀と短銃とを左右に持って、二人へ突きつけながら、微笑して「こういうものもある――選り取り、見取りに取りゃしゃんせ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、それによって、ふたたび見取り図を描いて説明しながら、「まずこういったあんばいでございます」と、話しを結んだ。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは次郎と三郎とでくわしい見取り図まで取って来た家で、二人ともひどく気に入ったと言っていた。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "今回の数次にわたる測量に際しては、損壊を恐れて敢て発掘的な作業を行わず、単に形状の見取りに止めて、すべてを後に行わるべき学術的調査研究に残すことにした。",
              "citation": {
                "source": "あの世の入口",
                "author": "――いわゆる地獄穴について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いゝわね、どんな美人でも選り取り見取りつてわけね。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番の先口さんですから、択り取り見取りでございますわ」　と安子夫人は又頻りにくれたがる。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "拍子木ともいうが恰も拍子木二本を併べ食いちがい三分の二程度に置いた見取りでゆけばいいのである。",
              "citation": {
                "source": "庭をつくる人",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "すてはまず袴野の顔に激昂のあとのないのを見取り、ついで貝ノ馬介が手綱を取っている手の平の汗までわかるような焦りを、眉の間に見附けた。",
              "citation": {
                "source": "舌を噛み切った女",
                "author": "またはすて姫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが氏が要求している処の、即ち又やがて氏自身が造り上げるだろう処の、体系の見取り図は、ある一点に於て、決定的に決っているようだ。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "あ、それから、川波さんのうちの見取り図をここへ書いておいてください」　影男の速水は、テーブルに紙をひろげて、千代に鉛筆を渡した。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が考え考え、見取り図を書き終わると、速水は要所要所の質問をして、屋敷のもようをすっかり頭に入れてしまった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三の紙草の上に描かれたものは、当地付近の見取り図であります。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "明くる朝も、同じ時刻に小屋へ帰り、見取り図へ必要な条項を、詳しく書き加えた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり太く線を引きすぎて、墨を滲ませたり、ぼとっと墨汁を落したり、幾たびか失敗したあとで、どうやら升屋の見取り図ができあがった。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん基礎的な見取り図のような知識を得るための本。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "完全なよそ者なのに邸内の見取りは完璧ですね。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、家の見取り図を知らないか。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏法の信者たちとつきあっておれば、幾らでも選り取り見取りだが、小さな島ではこんな資財でも限りがあった。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいぜん、ここへ伺う前、まだ夕明りのまま、あちこち駒を遊ばせて、ざっと懐紙に写しとってまいった、兵庫の地の見取り図ですが」「ほ？",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "つみとりてそぞろ心や　　　　　　くちづけさはに　願ふは君が髮ぐさ飾るやさし七草。",
              "citation": {
                "source": "絶句四章",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が姉を見上げた時に、姉の後に襷を掛けた守りのお松が、草箒とごみとりとを両手に持ったまま、立ってて姉の肩先から自分を見下して居た。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "本社のいちはやく探知するところによればツェ氏は数日前よりはりがねせい、ねずみとり氏と交際を結びおりしが一昨夜に至りて両氏の間に多少感情の衝突ありたるもののごとし。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
