    "definitions": [
      {
        "index": 1,
        "gloss": "to hurry on one's way",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "頼む」　　　　　　　　　　　　　　　　　　（Ｆ・Ｏ）７４＝（Ｆ・Ｉ）街道　右門暗殺十人組が道を急ぐ。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼む」（Ｆ・Ｏ）74＝（Ｆ・Ｉ）街道　右門暗殺十人組が道を急ぐ。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "己が業が兒戲に類するかどうか、兎にも角にも早く其の人に會つて腕を比べたいとあせりつつ、彼は只管に道を急ぐ。",
              "citation": {
                "source": "名人傳",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "己が業が児戯に類するかどうか、とにもかくにも早くその人に会って腕を比べたいとあせりつつ、彼はひたすらに道を急ぐ。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "埃の立つ道を急ぐともなく急いで、漸く豐川の岸に出た。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がいま人間ひとりの生死を気づかいつつ道を急ぐように、人もおのおの自己の重要な事件で走っているのであろう。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹濃は道を急ぐといふところから家に去り戻つて馬の用意する。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳原ならそれほど道を急ぐ必要はないはずなのに、右門はもよりのつじ待ち駕籠屋へやっていくと、黙ってあごでしゃくりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いた喜平次は又もや夢中になって駈け出し、幸いに彼等の追跡を免れて、ホッとしながら、ある里にはいると、鶏の声がしたので、やれ嬉しやと思って道を急ぐと、傍の木蔭から、鬼の形相をした白髪の老婆が、珍しや喜平次といって抱きつき、ウンといって彼は気絶するという、怪談としては、ありふれた筋であった。",
              "citation": {
                "source": "暴風雨の夜",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかしてこの自分の家出が、単なる忘恩の行為でなしに、父母から背き去り墨染の衣に身をやつしても一向道を急ぐあの憐むべき発心者のように見られたいと願った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、夢見の通り重態で有っては成らぬと、何につけても道を急ぐので有った。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも背に男の子を一人背負うて、ほかに全く連れとてもなく、この山道を急ぐのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥し桶を肩に掛けて、威勢よく向うの畠道を急ぐ壮年も有った。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "半蔵らのように福島から立って来たものでも、あるいは西の方面からやって来るものでも、昼食の時を寝覚に送ろうとして道を急ぐことは、木曾路を踏んで見るもののひとしく経験するところである。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく目がさめた時分には、もういつしか日が暮れかかっているので、驚いて起ち上がって道を急ぐのでありました。",
              "citation": {
                "source": "眠い町",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "うさぎ追いしかの山　小ぶな釣りしかの川夢は今もめぐりて　忘れがたき故郷　道を急ぐ人々の中には、立ち止まって、じっと耳をすます青年がありました。",
              "citation": {
                "source": "青い草",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩方の道を急ぐ人たちは、ちょっと見たばかりで、「このこいは値もいいにちがいない。",
              "citation": {
                "source": "千代紙の春",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく部落へ行って見たら万事｜明瞭りするだろうと歩きにくい道を急ぐのであった。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とお銀は悲鳴を上げ、粂太郎の胸へ取り縋る、それを背後へ囲いながら、「何かご用でございますか、少し道を急ぐ者、お通しなされてくださりませ」　顫えながら粂太郎は云った。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅行者は、いっ時はっとしたが、気を取り直して道を急ぐ。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもし我々にして心に欲することを直ちに実現し得る無限の力を持ち得るとしたら、我々はいたずらに同情に苦しむよりも、この力量への道を急ぐべきではないか。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途中、義経たちの一行は、手紙を持って山道を急ぐ男に出逢った。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、平氏敗北の後を追い、都への道を急ぐに当り、山門諸兄の思惑いかがかと思い候。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第七巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "道を急ぐお豊の下駄の音。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "行つて見よう」　平次は行詰つた事件に點じた、新しい光を發見したらしく、八五郎を促すやうに道を急ぐのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "隱し念佛",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次は早速支度をして、神田から目黒まで、近からぬ道を急ぐことになりました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "江戸の夜光石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして兵馬が、長持を追いぬけて、有明道を急ぐことしばし。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしは道を急ぐから、川あ越して来たまでのこんじゃ、それがどうした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "道を急ぐわしの後には、洛中洛外の騒動が、目に見えるようなここちがした。",
              "citation": {
                "source": "茶漬三略",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
