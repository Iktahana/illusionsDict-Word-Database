    "definitions": [
      {
        "index": 1,
        "gloss": "to see through (a lie, scheme, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
