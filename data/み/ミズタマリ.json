        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれどもやがて月が頭の上に出て月見草の花がほのかな夢をたゞよはしフィーマスの土の水たまりにも象牙細工の紫がかった月がうつりどこかで小さな羽虫がふるふ。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの河原のあちこちの大きな水たまりからいっこう魚が釣れなくなって時々は死んで腐ったものも浮いていました。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はまた地下に「川」や「水たまり」を考えている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "目と髪の黒い女が水たまりのまわりに集まってせんたくをしているそばには鶏が群れ遊び、豚が路傍で鳴いています。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "来てみると運動場には誰もいず、一パイに水たまりが出来ています。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の不完全な救助網や不潔な腰掛け、倒れそうな石垣やくずれそうな崖、病菌や害虫を培養する水たまりやごみため、亀裂が入りかかって地震があり次第断水を起こすような水道溝渠、こわれて役に立たぬ自働電話や危険な電線工事、こういう種類のものを報道して一般の用心と当局の注意を喚起したい。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、寒さは寒し、こたつの穴の水たまりを見て、胴震ひをして、小くなつて畏まつた。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺と白たびで、ばしや／＼とはねを上げながら、「それ又水たまりでござる。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水たまりに落ちていた。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "渾身のちからで、起き直り、木の幹に結びつけた兵古帯をほどいて首からはずし、水たまりの中にあぐらをかいて、あたりをそっと見廻した。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に捨てられた孤独の水たまりである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よいしょ、と小さい声で言ってみて、路のまんなかの水たまりを飛び越す。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "水たまりには秋の青空が写って、白い雲がゆるやかに流れている。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "水たまり、きれいだなあと思う。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほっと重荷がおりて笑いたくなり、この小さい水たまりの在るうちは、私の芸術も拠りどころが在る。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "この水たまりを忘れずに置こう。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "よいしょと、水たまりを飛び越して、ほっとする。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "水たまりには秋の空が写って、雲が流れる。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさの水たまりを思い出す。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの水たまりの在るうちは、――と思う。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "また引きかえし、荒むしろを掻きわけて小屋へはいり、見た、小屋の中央に一｜坪ほどの水たまりがあって、その水たまりは赤く濁って、時々水がだぶりと動く。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一坪くらいの小さい水たまりに一丈の霊物がいるというのは、ちょっと不審であったが、併し霊物も身をねじ曲げて、旅の空の不自由を忍んでいるのかも知れない。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨あがりの道の、ところどころに残っている水たまりを避けて、木挽町の河岸を、逓信省の方へ行きながら、たしかこの辺の曲がり角に看板のあるのを見たはずだがと思いながら行く。",
              "citation": {
                "source": "普請中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "路次の水たまり、黒い小猫がぴょんぴょんと水溜をさけて、隣の生垣の下をくぐった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜通しで降った雨のため、水たまりだらけだった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど庭の歩道にあった水たまりの大きさになるが、男はどうも跨いでいる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "足もとの水たまりに、雨上りの空の遠さを見るかなしさに、うち沈んだ。",
              "citation": {
                "source": "幸福への道",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、できればこれまでのものも含めて、明確化させた新しいルールに従って使ってもらえないかと考え、すべての作業者にメールで連絡を取り、「みずたまり」＊で論議して、合意の形成を目指した。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "掲示板〔みずたまり〕は、かすかな記憶を書き込むことによって、書名を忘れた本に再会できる“お尋ね本コーナー”となることもある。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌一一月には、掲示板〔みずたまり〕ができた。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
