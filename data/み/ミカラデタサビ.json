    "definitions": [
      {
        "index": 1,
        "gloss": "paying for one's mistakes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
