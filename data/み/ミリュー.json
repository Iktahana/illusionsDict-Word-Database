        "examples": {
          "standard": [
            {
              "text": "彼は芸術家として、独自のミリューの中で創作活動を続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その作家の作品には、彼が育った社会的なミリューが色濃く反映されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい文化を生み出すためには、多様なミリューが交錯する場が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし映画が単なる複製の技術としてのただの活動写真というだけの境界から脱却して、それ自身の独自な領域を自覚するようになり、創作の新しいミリューとして発見されると同時に行なわれはじめた映画制作の方法がすなわちこのモンタージュである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミリュー理論的批評が社会学的批判としてもすでに不充分なことは今日では誰にも徹底しているが、社会的批判（実は社会学的批判）になると、まだ仲々信用があるのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
