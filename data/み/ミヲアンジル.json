        "examples": {
          "standard": [
            {
              "text": "遠く離れて暮らす両親は、いつも私の身を案じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "病気の妻の身を案じ、彼は毎日看病に励んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は、旅立つ友人の身を案じて、様々な忠告をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "が、そのままお前の身を案じるやうに消毒室の方へ出て行つた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、従来も度々言ひましたし、又今日こんなに言ふのも、皆｜阿父さんの身を案じるからで、これに就いては陰でどれほど私が始終苦心してゐるか知つてお在は無からうけれど、考出すと勉強するのも何も可厭になつて、吁、いつそ山の中へでも引籠んで了はうかと思ひます。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それほど右近の身を案じるなら、いま信長がいいつける命を奉じて、高槻城へ行くがよい。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
