        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "娘が六人、人妻が三人、若後家が二人とな、いずれもみめよい者共をえりすぐって捕りあげたのは言うまでもないことじゃが、憎いはそれから先じゃ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "みめよい娘じゃとて、ほんに女は仕合せともかぎりませんわいな。",
              "citation": {
                "source": "九条武子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、領内からみめよい女を二、三人捜し出し、それを殿様に献上すれば免黜どころの話ではない。",
              "citation": {
                "source": "純情狸",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女達は、伊万里赤絵町から、かわるがわる四、五人ずつ呼んでおく港の遊女で、朱塗の駕が山峡を通る日は、飽いた女が返されて、次ぎのみめよい女が撰ばれてくる日だ。",
              "citation": {
                "source": "増長天王",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
