        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蜜蜂の羽音かも知れない。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々の見た蟻や蜜蜂のやうに個體の甲と乙との見分けが付かなくならなければ其の「集團」はまだ本物になつて居ないと思ふ。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜜蜂の巣の所在を人に知らせるからこういう名が付いているのだそうな。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日庭に角砂糖をいくつか出しておいたら、やがて一群の蜜蜂がこれにとまってしきりに骨折っていたが、堅くて喰い欠く事が出来ぬと見えて一時飛び去ってしもうた。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早春の蜜蜂　（尾崎一雄氏）　全篇清新な筆觸で書かれてゐる。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に蜜蜂の描寫、八年前の或る朝の記憶は秀れてゐる。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年前の短篇に於ても蜜蜂と妹の死との間にはつながりの必然性がない。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し最後にＫ子の死を敍したあと不吉な二月、それに關聯して再び蜜蜂のことへかへつて來たのは首尾照應してさきの蜜蜂を生かしてはゐる。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は「見えざるもの」の蜜蜂です。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の天候異常で七月中晴天が少なかったために、何か特殊な、蜜蜂の採蜜資料になるべき花のできが悪かったか、あるいは開花がおくれたといったような理由があるのではないかとも想像される。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ見た書物に、蜜蜂が花野の中で、つぼみと、咲いた花とを識別するのは、彼らにものの形状を弁別する能力のあるためだということが書いてあった。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この蜜蜂の話は人間社会の経済問題にも実にいろいろな痛切な問題を投げるようである。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南半球の納豆屋さんには日本から飛んで来る蜜蜂が恐ろしいのである。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面に陳列された商品がさき盛った野の花のように見え、天井に回るファンの羽ばたきとうなりが蜜蜂を思わせ、行交う人々が鹿のように鳥のようにまたニンフのように思われてくるのである。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜜蜂やかまきりの雄の運命ともよく似たところがあるのである。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜜蜂の雄虫は生殖の役目を果たすと同時に空中から石のごとく墜ちて死ぬ。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜜蜂が蜜を集めている。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ一つの蜜蜂にはそれぞれの哲学があるのかもしれない。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルキシズムその他いろいろなイズムの立場から蜜蜂に注文をつけるのは随意であるが、蜜蜂はそんな注文を超越してやっぱり同じように蜜を集めるであろう。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして忙しい蜜蜂はおそらくそういう注文者を笑ったりそしったりする暇すらないであろうと思われる。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの見た蟻や蜜蜂のように個体の甲と乙との見分けがつかなくならなければその「集団」はまだ本物になっていないと思う。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀器の光、ガラス器のきらめき、一輪ざしの草花、それに蜜蜂のうなりに似たファンの楽音、ちょうどそれは「フォーヌの午後」に表わされた心持ちである。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして蜜蜂に体のめぐりをわんわん飛び廻らせながら一人一人やってきて大きな手で私の手を堅く握ってくれた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そばへ寄って見ると、その桃いろなのには、いちめんにせいの低い花が咲いていて、蜜蜂がいそがしく花から花をわたってあるいていましたし、緑いろなのには小さな穂を出して草がぎっしりはえ、灰いろなのは浅い泥の沼でした。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お庭の蜜蜂にやる」　と玉子さんが言いました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった今まで、草原の中をよろめきながら飛んでいる野の蜜蜂が止まったら、羽を焦してしまっただろうと思われる程、赤く燃えていた女房の顳※が、大理石のように冷たくなった。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは、白いミツバチが、むらがっているんだよ」と、年とったおばあさんが言いました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの中には、ミツバチの女王もいる？",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この子は、ほんとうのミツバチの中には女王がいることを、ちゃんと知っていたのです。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女王バチはね、ミツバチが、いちばんたくさんむらがっているところを、とんでいるんだよ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
