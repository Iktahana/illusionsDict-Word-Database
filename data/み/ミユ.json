    "definitions": [
      {
        "index": 1,
        "gloss": "to be seen",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "爪萩原朔太郎青くしなへる我が指のリキユールグラスにふるるとき生れつきとは思へども侘しく見ゆる爪形をさしも憎しと思ふなり",
              "citation": {
                "source": "爪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、表現は、経験によつて、叫びの当の対象と見ゆるものを、より叫びに似るやうに描いたのである。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "行く春や白き花見ゆ垣の隙　この句もまた、蕪村らしく明るい青春性に富んでいる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑居鳥寺見ゆ麦林寺とやいふ　夏の日の田舎道、遠く麦畑の続いた向うに、寺の塔が小さく見える。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗憺として錨をおろしみな重砲の城の如く無言に沈鬱して見ゆるかな。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川口に当りて海面鏡のごとく帆船の大き小さきも見ゆ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右には未だ青き稲田を距てて白砂青松の中に白堊の高楼｜蜑の塩屋に交じり、その上に一抹の海青く汽船の往復する見ゆ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と何の事やら、わけのわからんやうな事を悟り澄ましたみたいな口調で言ひ、兩腕をうしろに組み、ひとり家を出て、あちらこちら海岸を逍遙し、苅薦の亂れ出づ見ゆ海人の釣船　などと、れいの風流めいた詩句の斷片を口ずさみ、「人は、なぜお互ひ批評し合はなければ、生きて行けないのだらう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁はきょうこそ見ゆれと旅路の草の衾から起上がった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白波の立つ伊豆の海が見ゆる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "形よりも影、体よりも光り、姿よりも匂いで、人の見ゆる方が多くなった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地図と鳥瞰図の合の子のようなもので、平面的に書き込んである里程や距離を胸に入れながら、自分の立つ位置から右に左に見ゆる見当のまま、山や神社仏閣や城が、およそその見ゆる形に側面の略図を描いてある。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのいきざしは、夏の池に、くれなゐのはちす、始めて開けたるにやと見ゆ」という場合の「意気ざし」は、「息ざしもせず窺へば」の「息差」から来たものに相違ない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "利根の鉄橋を越えて行くに夏｜蕎麦をつくる畑｜干瓢をつくる畑などあれば埼玉や古河のあたりの夏蕎麥のなつみこめやもおほに思はゞ麥わらをしける廣畑瓜の畑葉かげに瓜のこゝたく見ゆるなど口ずさむ。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国の婦人のまだうら若きと見ゆるが靴の上に草鞋をはき、一人は橋の上に立ち、一人は岩に腰うちかけて絵など写すめり。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "屏風巌をめぐりて般若方等二つの滝の見ゆる処に出ず。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "中禅寺の湖をながめて天雲のいはひもとほる湖の上に眞白片帆の舟歸る見ゆ歌袋歌滿ちあふるなめ革のかはり袋のありこせぬかも歌袋の歌は文して格堂にからかいやりしなり。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中あかねさす西日は照れどひぐらしの鳴き蟲山に雨かゝる見ゆゆくゆく一人の少女のいと艶なるに逢う。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛籠の底に納めたりける一二枚の衣を打かへして、浅黄ちりめんの帯揚のうちより、五｜通六通、数ふれば十二｜通の文を出して旧の座へ戻れば、蘭燈のかげ少し暗きを、捻ぢ出す手もとに見ゆるは殿の名。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さゝやかなる庭の池水にゆられて見ゆるかげ物いふやうにて、手すりめきたる所に寄りて久しう見入るれば、はじめは浮きたるやうなりしも次第に底ふかく、この池の深さいくばくとも量られぬ心地になりて、月はそのそこの底のいと深くに住らん物のやうに思はれぬ。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年九月三十日『東京朝日新聞』）　　　　　　　　　七　　　　　　霧の海　野原に下りた霧の渺々として海のごとく見ゆるをいう。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いはば私にとつては實に好々｜敵手だつたのだが、先生今や東北青｜葉城下に去つて久しく相見ゆる機を得ない。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――」と彼の暗記しおる公報の一つ、常に朗読というより朗吟する一つを始めた、「敵艦見ゆとの警報に接し、連合艦隊は直ちに出動これを撃滅せんとす、本日天候晴朗なれども波高し――ここを願います、僕はこの号外を読むとたまらなくうれしくなるのだから――ぜひここをやってくださいな。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オヤ好い月だね、田川さんお上がんなさいよ」という女は今年十九、歳には少し老けて見ゆる方なるがすらりとした姿の、気高い顔つき、髪は束髪に結んで身には洗曝の浴衣を着けて居る。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "火影及ぶかぎりは雪片きらめきて降つるが見ゆ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕日影あざやかに照り四国地遠く波の上に浮かびて見ゆ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔たそがれ思量惑くして〕たそがれ思量惑くして、　　銀屏流沙とも見ゆるころ、堂は別時の供養とて、　　盤鉦木鼓しめやかなり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――記憶も、去るにあらずや……湧き起る歓喜のためには　人の情けも、小さきものとみゆるにあらずやああ、神様、これがすべてでございます、　尽すなく尽さるるなく、心のままにうたへる心こそ　これがすべてでございます！",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "山｜虔しき木工のみ、　　夢の裡なる隊商のその足竝もほのみゆれ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍には可愛き兒の寐姿みゆ、膝の上には無情の君よ我れを打捨て給ふかと、殿の御聲あり／＼聞えて、外面には良人や戻らん更けたる月に霜さむし、たとへば我が良人今此處に戻らせ給ふとも、我れは恥かしさに面あかみて此膝なる文を取かくすべきか、恥づるは心の疚しければなり、何かは隱さん。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            }
          ]
        }
