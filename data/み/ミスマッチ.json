        "examples": {
          "standard": [
            {
              "text": "チームの経験と彼の若さがミスマッチで、なかなかうまくいかなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "理想と現実のミスマッチに、彼は深く悩んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この服と靴、完全にミスマッチだよ。変えようよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "まるっきりミスマッチ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい夫婦は愛し合ってると言ってたけど、てんでミスマッチなのね。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "恵子さんよりもっとミスマッチで、長くは続かないと思うよ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちもいっしょにいるのが恥ずかしいタイプの人だから、ミスマッチだというのは私がそう思ってるだけで、本当はいい組み合わせなのかもしれない。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
