        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その線路の右端の下方、すなわち紙の右下隅に鶯横町の彎曲した道があって、その片側にいびつな長方形のかいてあるのがすなわち子規庵の所在を示すらしい。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが反対に画面の右端を左へ向いて駆けって行くのでは迫った感じが出ないであろう。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台の右端から流れだす義太夫音楽の呼気がかからなければ決してあれだけの効果を生ずることはできないのはもちろんである。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふさがっているのは表通りの右端の二区切りだけで、あとは古障子やら藁やら一ぱい散らかったまま空いている。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "元就は斯くて十月五日に二十日市の桜尾城に於て凱旋式を挙行しているが、彼は敵将晴賢の首級に対してもこれを白布にて掩い、首実検の時も、僅かに其白布の右端を取っただけで、敵将をみだりに恥かしめぬだけの雅量を示している。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "最右端は、ゆるぎ岩也。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "契約したのは右端にある一棟の一部を成した五坪ばかりの洋室であつた。",
              "citation": {
                "source": "老苦",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "とすると、右端が弥七郎の作だな」「さようでござります」「おかしなこともあればあるものだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで、キャンパスの左端から右端へとカメラをパーンしたショットも、やはり十二秒だった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その楽屋／特等席の、三つならんだテーブルの右端に、部員ではない高志と令子が陣どっていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎の住居は、丸太材を適度に配したヒュッテ風の小粋な住居で、同じように三軒並んだ右端の家であった。",
              "citation": {
                "source": "寒の夜晴れ",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには自分の前の十七｜憧を、皆がとりやすいように斜めにしてすこし前へ出してやるとみせかけ、例えば右手の中に、不用の持牌二個を隠し持ち、前へ押すときにそれを十七憧の右端へ加え、前へ押して手を引くとき、左手の中に左端の二枚を隠し取って手牌の中に入れてしまう。",
              "citation": {
                "source": "麻雀インチキ物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "１□９２　　２９□１　　９７１□＋　２□１７――――――　１７５９２　まづ右端の縱列の□から考へて行く。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうでないと第三段目の右端の數字は０とならない。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（上から五段目の右端）つまり、３に或數（除數の一位）をかけて、答の一位に９が出てくるためには、その或數は３の外にないのだ。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "１３　　＿＿＿＿□３）９４９　　　□３　　――――　　　□１９　　　□１９　　――――　　　　　０　これでみるとほり、答の十位が１と決まれば、第三段目の右端は當然３である。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三段目の右端のＳが曲者である。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは七段目の右端の數字も、同じく０であることだ。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "１□９２　　２９□１　　９７１□＋　２□１７――――――　１７５９２　まず右端の縦列の□から考えて行く。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでないと第三段目の右端の数字は０とならない。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "除数に答の一位の数である３をかけたとき、その計算の一位の数は９となっている（上から五段目の右端）。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "１３　　＿＿＿＿□３）９４９　　　□３　　――――　　　□１９　　　□１９　　――――　　　　　０　これでみるとおり、答の十位が１と決まれば、第三段目の右端は当然３である。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは七段目の右端の数字も、同じく０であることだ。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "左端のタンホルンから、右端のドルデンホルンにいたるまで、ベルグリストックが、フィンステルアルが、アイガアが、モンクが、ユングフラウが、ブリュムリフオルブの群巒が、さらにブルュンヂンが、續々として屹立ち、こゝに人間界とは別の天地を形成してゐるのである。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "左が玄関で右端が女中部屋である。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族は最も貧乏なるものを最右端に置き、それより順次左に富める者を排列す。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "余と望蜀生とは右端から掘り進み、中央を東皐文海二｜子の初陣に委せた。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "嶺の千鳥窪",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年は新道ができていて美女平を通らず尾根の右端を巻いて小谷にいで、それを渡ったりなどしてしばらくは道もわかったが、すぐ道を失いあとは藪をくぐりながらほぼ旧道に沿って登って行った。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "監房の外の一間幅に四間の板廊下の右端にトタン張の流しがあり、そこに水道の蛇口が一つ出ている。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
