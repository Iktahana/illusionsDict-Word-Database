    "definitions": [
      {
        "index": 1,
        "gloss": "to risk one's life (to do)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
