    "definitions": [
      {
        "index": 1,
        "gloss": "Water Dragon (29th term of the sexagenary cycle, e.g. 1952, 2012, 2072)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
