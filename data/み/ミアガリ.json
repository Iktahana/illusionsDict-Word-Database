    "definitions": [
      {
        "index": 1,
        "gloss": "taking a day off by paying one's own fee to one's master (of a prostitute; often in order to see her lover)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やみあがりの目にこゝろよき　雨の明るさ！",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "やみあがりの目にこころよき　雨の明るさ！",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "病みあがりの、しかして快く熱したるわが頬に、雨をふくめる夜風の爽かなりしかな。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時私は母の看病に働いたり、故郷へ帰ったうれしさで友達などとも誘い合って、病みあがりの身も忘れて山を歩いたりしましたの」　話がこうして今年の最近にまで亘ってきた時には、とよ子はまた激しく泣いた。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私は堪らぬ義憤に駆られて、夢中で後を追ひはじめたが忽ち両脚は氷柱の感で竦みあがり、空しくこの残酷なる所刑の有様を見逃さねばならなかつた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして再び腕の台に転落すると、またもや激流にのった小舟の威勢で見る影もなく、拉し去られた、――私は堪らぬ義憤に駆られて、夢中で後を追いはじめたが忽ち両脚は氷柱の感で竦みあがり、空しくこの残酷なる処刑の有様を見逃さねばならなかった。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はまだ病みあがりの蒼い顔をして、枯枝を杖にして草履をひきずりながら辿って来た。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「病みあがりに朝晩出あるいて、叔母御がなんにも叱らぬかよ」と、婆はけむそうな眼をして言った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯父さんは歳を老つてゐるし、もともと貧乏な家ですから、どうすることも出来なくなつて、病みあがりのおきいちやんは、湖の向ふの村の機場へ機織工女に売られることになつたのです。",
              "citation": {
                "source": "虹の橋",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "病みあがりのお前にはなんとしても無理なこつちや、寺田ン家の源次でも頼んだらとおら思ふとるんやが。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "御免下さいとおとなえば、若い病みあがりらしい妻君が、蒼い顔をして出て来ました。",
              "citation": {
                "source": "職業の苦痛",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月の末に、病みあがりの、あと養生もしないで邸へ帰った。",
              "citation": {
                "source": "渡りきらぬ橋",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "怨恨つみあがり、鬱情す走る十重、二十重の心根の複雑さを、機械の食い破ってゆく日が来たようであった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして畸型の醜女の代りにアキの美貌に思ひついた満足で私の好色はふくらみあがり、私は新たな目的のために期待だけが全部であつた。",
              "citation": {
                "source": "いづこへ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がはじめてこの村に来た当時のことだが、或日、昔の屋敷跡らしい大きな石崖のうえに立って、秋らしい日ざしを浴びながら、病みあがりらしくぼんやり蓼科山の方をながめていた。",
              "citation": {
                "source": "雪の上の足跡",
                "author": "高原の古駅における、二月の夕方の対話",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして畸型の醜女の代りにアキの美貌に思いついた満足で私の好色はふくらみあがり、私は新たな目的のために期待だけが全部であった。",
              "citation": {
                "source": "いずこへ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちらと視線が流れたばかりにすぎないはずが、まるで眼の中へ焼きこまれたと思はなければならないやうな強烈な印画で、××××××××××××××視野いつぱいにひろがり、部屋いつぱいの大きさにふくらみあがり、安川の顔へめがけてわッとおしつけてくるやうだつた。",
              "citation": {
                "source": "老嫗面",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "病みあがりの蟷螂のやうなあの痩せこけた老耄親父にうまうま騙られてしまつたぞと、親友を侮辱したのも偽りのない事実であつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ふりかえると、ローレンス老人が立っていたので、ジョウはちぢみあがりました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男の顔は、日にやけて黒く、目が光って、ひげは、やみあがりのようにのびていました。",
              "citation": {
                "source": "新しい町",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "病みあがりのような、げっそりした疲労だけがのこっていた。",
              "citation": {
                "source": "白い道",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベンジャミンは　かみぶくろに　かくれて　ちぢみあがりました。",
              "citation": {
                "source": "ばにばにきょうだいのはなし",
                "author": "THE TALE OF THE FLOPSY BUNNIES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ」　久美子は悚みあがり、われともなく鋭い叫声をあげた。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆さん衆の荒みあがり、それもホン一晩のところ、あっしに下すったと思わねえで、其奴等に恵んでやったと思って、今日のところあお見逃し下せえ、貸元衆、真壁村の仙太郎、恩に着ますでござんす。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
