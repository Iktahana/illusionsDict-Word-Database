    "definitions": [
      {
        "index": 1,
        "gloss": "to remain in memory (of sounds and words)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
