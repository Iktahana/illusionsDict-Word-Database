    "definitions": [
      {
        "index": 1,
        "gloss": "Mito Kōmon (televised period drama; 1969-2011)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
