        "examples": {
          "standard": [
            {
              "text": "皇子の尊は、父である天皇の意向を受けて各地を視察された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "次代の君主として期待される皇子の尊の周囲には、多くの側近が集まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "物語の中で、皇子の尊は試練を乗り越えて真の英雄へと成長していく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "後次第に、ひつぎのみこ・皇子の尊など言ふ名で、半成人の資格を認めて来る様になつた。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "○日並の皇子の尊の馬並めて御猟立たしし時は来向ふ　〔巻一・四九〕　柿本人麿　これも四首中の一つで、その最後のものである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、皇太子様の事をば、みこのみことと申し上げたのである。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
