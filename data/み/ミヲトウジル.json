    "definitions": [
      {
        "index": 1,
        "gloss": "to throw oneself (into an activity)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
