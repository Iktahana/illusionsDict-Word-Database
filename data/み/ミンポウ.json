    },
    "definitions": [
      {
        "index": 1,
        "gloss": "commercial broadcast",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「昨日午後八時頃から十時頃にかけて東京周辺地域のテレビにＮＨＫ民放合わせて七局に海賊放送が流れた事件で、警視庁は逆探知の結果海賊放送の電波の発信源は板橋区周辺と考えられることを明らかにしました。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオの仕事が好きで、民放でアルバイトをしていました。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつての高村恵子は民放のラジオ局に勤め、アナウンサーをしていた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
