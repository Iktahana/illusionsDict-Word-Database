[
  {
    "uuid": "b03d3874-4391-54f7-b583-f9f3bdf005b8",
    "entry": "民法",
    "reading": {
      "primary": "みんぽう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
