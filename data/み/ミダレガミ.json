    "definitions": [
      {
        "index": 1,
        "gloss": "disheveled hair",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "紅葉の秋木も、一合五勺位から皆無になったが、虎杖は二つ塚側火山の側面まで生えている、それも乱れ髪のように、蓬々としている。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　乱れ髪　亭主の叫びし声を怪しみ、慌しく来る旅店の内儀、「まあ何事でござんすの、と洋燈を点けて据え置きながら、床の間の方を見るや否や、「ン、と反返るを抱き止めて、泰助｜屹と振返れば、柱隠しの姿絵という風情にて、床柱に凭れて立つ、あら怪しき婦人ありけり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お葉に掴み毀された前髪の庇は頽れたままで、掻上げもせぬ乱れ髪は黒幕のように彼女の蒼い顔を鎖していた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは角力の乱れ髪と言って粋なものなんです。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そが中には家を理するの良妻もあるべく、業に励むの良工もあるべし、恋のもつれに乱れ髪の少女もあらむ、逆想に凝りて世を忘れたる小ハムレットもあらむ。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は何条猶予すべき、直ぐに偉容を張って謡い了ったが、我れながら会心の出来で、殊に、「乱れ髪乱れ笠、思いはいつか忘れむと」　のあたり、即座に天関地軸を撲落して、唯一人の美人を天の一方に仰ぐような心地がした。",
              "citation": {
                "source": "謡曲黒白談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛ぶ時に乱れ髪になっていた女の頭髪も見えなくなった。",
              "citation": {
                "source": "水魔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒髪を乱した妖艶な女の頭、矢で貫かれた心臓、その心臓からぽたぽた落ちる血のしたたりがおのずから字になったように図案された「乱れ髪」という標題――文字に親しむ事の大きらいな葉子もうわさで聞いていた有名な鳳晶子の詩集だった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやッと思う中に、その女はスルスルと枕辺へ這って来て、どうぞお助け下さい、ご免なすッて下さいと、乱れ髪を畳に摺付けて潜然と泣く。",
              "citation": {
                "source": "お住の霊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "本堂の机の上には乱れ髪、落梅集、むさし野、和尚さんが早稲田に通うころよんだというエノックアーデンの薄い本がのせられてあった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱れ髪が額から頬に掛っていた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "判者が外の人であったら、初から、かぐや姫とつれだって月宮に昇るとか、あるいは人も家もなき深山の絶頂に突っ立って、乱れ髪を風に吹かせながら月を眺めて居たというような、凄い趣向を考えたかもしれぬが、判者が碧梧桐というのだから先ず空想を斥けて、なるべく写実にやろうと考えた。",
              "citation": {
                "source": "句合の月",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "――丸々と肥えた頸筋に、血に塗れた乱れ髪が数本｜蛇のように匍っている、見るからに惨酷な犯行を思わせずにはおかなかった。",
              "citation": {
                "source": "電気風呂の怪死事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は敷布をはずして、水色の服に着更えると、乱れ髪を繕った。",
              "citation": {
                "source": "苦力頭の表情",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "俯向けて歩いていた、廂の乱れ髪を、一寸横に傾けて、稲妻のように早い、鋭い一瞥の下に、二人の容貌、態度、性格をまで見たかと思われる位であった。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、涼しさや頬に女船頭の乱れ髪。",
              "citation": {
                "source": "悪因縁の怨",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時にラムプの向う側からバタバタと走り出て来たお作が、殆んど福太郎に打っ突かるようにピッタリ縋り付いたと思うと、酔いも何も醒め果てた乱れ髪を撫で上げながら、半泣きの声を振り絞った。",
              "citation": {
                "source": "斜坑",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "服の着方、釦のはめ方、ネクタイの結び方、片手で乱れ髪をかきあげる癖まで……そして和服の時には、襟を合せる様子から、帯を結ぶ手付まで……其他無数の細かい事柄。",
              "citation": {
                "source": "女人禁制",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "のち之を年代順に春夏秋冬二巻に分ち、その前にプレリウドとして「乱れ髪」、「源氏振」の二小巻を付けて之を作つた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒髪の千筋の髪の乱れ髪かつ思ひ乱れ思ひ乱るる　明治三十四年七月、作者二十四歳の時出た第一集「乱れ髪」は一躍著者の文名を高からしめ、その自由奔放、大胆率直な内容と稍唐突奇矯な表現とを以て一世を驚倒させ毀誉相半ばしたものであるが、作者に取つては一生後悔の種ともなつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして「乱れ髪」はその混沌たる発酵時代を代表してゐるのである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「乱れ髪」の中にも相当調つた歌が少しはある。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱れ髪といふ本の名がどこから来たものか、つひ質さずにしまつたが、或はこの歌などから採られたのではないかとも思はれる。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はさう思つて秀歌選ではその「乱れ髪」の巻のはじめに置いて見たのである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者は岩波文庫本を自ら選ぶに当つて「乱れ髪」から十四首を採つたが、この歌は這入つてゐない。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆあみして泉を出でしわが肌に触るるは苦し人の世の衣「乱れ髪」の五十八首目にあり、裸体讃美の歌であるから、同集の持つ華麗な彩色の一つに数へられる。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒髪は王者を呼ぶに力わびず竜馬来たると春の風聴く　これは第二集「小扇」（明治三十七年一月出版）の巻尾の歌で、調子の出来上つた後の作であるが、内容は「乱れ髪」を特色づける凛々たる勇気を誇示して恥ぢない歌だ。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大切な黒髪を少女心のこよなくいたはる心持を詠んだ歌であるが、情景相応した気持のよい出来栄えで乱れ髪の中では最も無難な歌の一つに数へられる。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
