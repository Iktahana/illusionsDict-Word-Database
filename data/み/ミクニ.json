    "definitions": [
      {
        "index": 1,
        "gloss": "country",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "貴下の御健康と御国の未来を祝福して！",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでないと、あれでも御国のためには、生命も惜まない徒だから、どんなことをしようも知れない。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもが、吾々父母妻子をうっちゃって、御国のために尽そうという愛国の志士が承知せん。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "正義の戦とか、御国のためとか、陛下の御ためとか、あるいは自分の奉ずる正しい主義のためとか、そういう確信を以て奮う勇気は、常に正々堂々として世の亀鑑となり、しかもその勇気は、撓まず滅せず、いやさらに燃えさかるのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし国民性の本質が、内奥に於て如何にその外観とちがっているかは、かの日清・日露等の役に於ける兵士の軍歌（雪の進軍と、此処は御国を何百里）が、歌曲共に、哀調悲傷を極めているに見ても解る。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御国の来らむことを。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じやうな切ない夢を、幾度となく続けて見て、半死半生の躰で漸つと我に返つた時、亭主が、『御国許へ電報をお掛け被成りましては如何でござりませう。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうでないと、あれでも御国のためには、生命も惜まない徒だから、どんなことをしやうも知れない。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもが、われわれ父母妻子をうつちやつて、御国のために尽さうといふ愛国の志士が承知せん。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後某は御先代妙解院殿よりも出格の御引立を蒙り、寛永九年｜御国替の砌には、三斎公の御居城｜八代に相詰め候事と相成り、あまつさえ殿御上京の御供にさえ召具せられ候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじ押借りのたぐいでも、攘夷のためとか御国の為とか云えば、これに勿体らしい口実が出来るので、小利口な五右衛門も定九郎もみんな攘夷家に早変りしてしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕ノ親愛ナル新吉ヨ、僕ハイヨイヨ希ヒガカナツテ勇マシイ水雷艇ノ乗組員ニナツタ、ダガ僕ハ御国ノ士官ニナリ損ツタコトガザンネンダ。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の盲ひたお婆さんは、車に乗ると眼が眩ると言ふので、昔｜御国替への時乗つて来たやうな軽尻馬をわざわざ仕立てゝ、町の通をほつくり／＼と遣つて来た。",
              "citation": {
                "source": "朝",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは日本海を向こうへ越えた国境附近で、御国のために生命を投げだして働いている、わが陸海軍将兵のために敬意を表していたのかと思ったんだが、そうじゃなかったのかね」「ええ、敬礼は太陽にしていたんです。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく御国のために、ぜひ完全に防護してみせなきゃならない。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……おじさんも仕事をはげむから、どうか御国のために、帝都の防衛のことはみなさんによく頼んだよ。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "『仕置』の結尾の所には、右之仕置大方に候而御国元より国之下知未断之故国俗壊行候儀役人之曲事と被仰付候はゞ我々可及迷惑候間前以申出候若恨に可被存人は羽地合手に可成候少も一身惜不申候国中の恥辱には替間敷候如何様返答可承候と書いてあります。",
              "citation": {
                "source": "琉球史の趨勢",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝ませ和子よ　水色絹の　帳の裡に　夢まどらかに　バラの香りと　小鳩の声の　夢の御国を　おとのうまで　ねませ和子よ　夢まどらかに……　とのう。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これですべての事の方はついて仕舞う、とは云えこの徳も力もないわしが、やがての時、見事にすこやかに生い立つべき種を消ゆる事なく眼にはよう見えぬ土に蒔いたと申す事はわしを安らかに、御国へ行かせる――息がきれた様に言葉の末をただほそく残す。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「広岡先生の御国はどちらなんですか」と高瀬が聞いた。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾は御国魂を主とす。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "御国の来らんことを。",
              "citation": {
                "source": "反逆",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "定而御国下御静謐恐悦至極と奉存候。",
              "citation": {
                "source": "手紙",
                "author": "安政三年九月二十九日　相良屋源之助あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "私しかへりは今月の末より来初めにて候得共、御国へかへり候はひまどり可申と奉存候。",
              "citation": {
                "source": "手紙",
                "author": "安政五年七月頃　坂本乙女あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "御国より出しものゝ内一人西洋イギリス学問所ニいりおり候。",
              "citation": {
                "source": "手紙",
                "author": "慶応元年九月九日　坂本乙女、おやべあて",
                "note": "青空文庫"
              }
            },
            {
              "text": "然ニ私ニ非レバたれか上関迄出し候心積ニ候所、此頃御国より相廻り候船、下の関ニ参候時節、人なく幸ニ黒田了介殿御出ニ候得共、今少し御留りの儀故ニ無是非候。",
              "citation": {
                "source": "手紙",
                "author": "慶応元年十二月十四日　岩下佐次右衛門、吉井友実あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人　（なだめるように）まあ、あなたなどは御年若なのですから、一先御父様の御国へお帰りなさい。",
              "citation": {
                "source": "三つの宝",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後蒸気船の将武藤早馬に行逢候得ども、是ハ重役の事又ハ御国に帰れなど云ハれん事を恐れ、しらぬ顔して通行しに、広之丞再三参り、私之存念を尋候ものから認め送り候処、内々武藤にも見セシ様子。",
              "citation": {
                "source": "手紙",
                "author": "慶応二年十二月四日　坂本権平、一同あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫男児を育るハ誠ニ心得あるべし、とても御国の育方にてハ参り兼候べしと、実ニ残念ニ存候。",
              "citation": {
                "source": "手紙",
                "author": "慶応二年十二月四日　坂本権平、一同あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　――これは、もちっと後のことで、九女八はこの大阪から帰ってから後、大正二年の七月に、浅草公園の活動｜劇場みくに座で、一日三回興業に、山姥や保名を踊り、楽屋で衣裳を脱ごうとしかけて卒倒し、そのままになってしまったのだった。",
              "citation": {
                "source": "市川九女八",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
