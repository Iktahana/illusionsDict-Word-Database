        "examples": {
          "standard": [
            {
              "text": "理髪店で髪を切ってもらうついでに、伸びてきた耳毛も綺麗に剃ってもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「最近、父が鏡を見ながら一生懸命に耳毛を抜いている姿をよく見かける。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "加齢とともに耳毛が濃くなるのは、毛の周期が長くなることが原因の一つらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "かたわらには年寄りの栗毛までがたたずんで、ねずみ色の耳毛が中から勢いよくはえている大きな片耳を、一座の方へそばだてながら、連中の演説をじっと聞いておりました。",
              "citation": {
                "source": "夢がたり",
                "author": "TO, CHEVO NE BYLO",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳毛添緑、字は山松であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
