    "definitions": [
      {
        "index": 1,
        "gloss": "miniature-shrine maker",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だからお前、ただの大工や宮師なんかとは訳が違って素晴らしいんだよ。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "安床の「安さん」の事",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は素人のくせに、和歌宮師の手術の手際にけちをつけるなんてよろしくないよ。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも和歌宮師の手術は、この点では当代に並ぶものがない。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ位なら和歌宮師の助手が勤まるだろう」　と鳴海は皮肉をいう。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが和歌宮先生の特技と称せらるるものも実は先生が把握した真理を大胆率直に機械的技術に移し、これを駆使するのに外ならない」「そういっちまえば、君の崇拝する和歌宮師は、魔術師の一種だてぇことになる。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の調べたところでは、多くの人々が迎春館という名を知っており、和歌宮鈍千木師の名前も聞いて知っているが、さて迎春館のはっきりした所在も知らず、また和歌宮師に会った者もないのだ。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事も忙しいし、それに更に深い研究を続けておられるものだからねえ」「じゃ、君は僕を和歌宮師のところへ連れていって会わせて呉れ」「駄目だよ、君はそういう手術を希望していないんだから、やっぱり駄目だよ」「とにかく僕は大きな疑惑を持っている。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "門を入って左へ観音さまの堂脇から淡島の付近一帯、宮師、注連飾り、桶類、金物類そのほかの店が隙間なく、高張や長提灯の数を列ねて、耳も聾するばかりの呼び声、ことに明治の中頃の景気は格別、江戸時代に輪をかけてすばらしい人出、山と買い込んだ品物を両手に高くさし上げてやっと通るほどの大骨折り。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩は固より此集の歌を好まないけれど、此集の如き歌が明治の詞壇に存在する事を苟にも拒みやしない。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へん他人の家へ垂込みやしめえし、何のこれ往来だ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうとつくにながい間だれもこんな波止場を思つてみやしない。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「済みやしないよ、七皿のあとが、一銚子、玉子に海苔と来て、おひけとなると可いんだけれど、やっぱり一人で寝るんだから、大きに足が突張るです。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんた自分で、先生のところへでも訪ねて行ってみやしなかった」　すると葛岡は、もう臆病な眼の屡叩かせ方で、正直にも、これは偽りですと言わんばかりの表情をしたのち、「訪ねてなんか行ってみやしないさ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄干橋をみやしやんせ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その位ならこんなに訳を云って頼みやしないじゃないか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もあなたに余計な世話を焼いて下さいと頼みやしませんよ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでは日本本国からの輸出品と、こちらの日本会社の製品とが衝突するだけじゃすみやしません。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今年の煙草も、どうやらまア今日で無事にすみやした。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「滅相もない、ちよつとお休みやしたのに、こないたんと載いては済みまへんどす。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいッたってもなあ」「叔母さん、宮様を拝まッしたか」「私はなあ、橋の傍で拝みやした」　母親は源の横顔を熟視って、「源、お前も握飯はどうだい。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお信さんは恨めしさうに啜り泣きを始めた「お父つあん等、自分の子お産みやしたことおへんよつてお知りんのどす。",
              "citation": {
                "source": "乳の匂ひ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早や、お読みやしたの？",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一君を殺るつもりならワザワザこんな処まで引張り込みやしないよ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "不平が云いたい位なら最初からコンナ仕事に頭を突込みやしないよ。",
              "citation": {
                "source": "無系統虎列剌",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう笑わないよ、笑わないよ」漸くのことで笑いを抑えた若い水夫のガブリエルは、老人の側へ返って来たが、「ちょっとばかり爺さんに訊たいがね、お前は屹度若い頃、うつ、買う、飲む、の三拍子揃った道楽者でその上に阿片を飲みやしなかったかな！",
              "citation": {
                "source": "死の航海",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本格のソプラノなんか、一度も唄ってみやしない。",
              "citation": {
                "source": "ニューフェイス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうラムなんか決してあんなにたくさん飲みやしねえ。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "空子　　仲直りなんかさせてくれつて頼みやしないわ。",
              "citation": {
                "source": "五月晴れ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あんたはん、昨日こちらのお婆さんにお頼みやしたやおへんか。",
              "citation": {
                "source": "霜凍る宵",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ帰ってお寝みやしとくれやす。",
              "citation": {
                "source": "霜凍る宵",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
