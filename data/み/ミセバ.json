    "definitions": [
      {
        "index": 1,
        "gloss": "highlight (scene)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
