        "examples": {
          "standard": [
            {
              "text": "体調が悪かったのか、前日の夕食が未消化のまま胃に残っている感じがする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "赤ちゃんの便に未消化のニンジンが混じっていたが、特に機嫌は悪くなさそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "胃腸を休めるために、当分は未消化になりやすい脂っこい食事は避けよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "参考書も、必要に迫って、すぐ作品に役だたせようとすると、どうしても未消化なナマが目につくものである。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
