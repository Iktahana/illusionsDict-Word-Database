    "definitions": [
      {
        "index": 1,
        "gloss": "vain person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は見栄っ張りなので、いつも高級品ばかり買いたがる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "見栄っ張りな性格が災いして、彼女は友人から距離を置かれるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は見栄っ張りだが、根は優しい人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ぐうたら、見栄っ張り、遊び女だなんて。",
              "citation": {
                "source": "四風の街",
                "author": "The Street of Four Winds",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　見栄っ張りな小次郎も、酔うとひとりでに、常の容態や端麗も構えから忘れてしまう。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、それも彼女のみえっぱりの罪のない嘘だろうと、私はなにもいわなかった。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなちょうしで、ちょっとうたぐりぶかく、みえっぱりだったから、その花はすぐに、その子をこまらせるようになった。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "11　ふたつめの星は、みえっぱりのすまいだった。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」王子くんが見えるなり、みえっぱりはとおくから大ごえをあげた。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのも、みえっぱりにかかれば、だれもかれもみんなファンなんだ。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、みえっぱりはいう。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、みえっぱりはその子にすすめた。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "みえっぱりは、ぼうしをちょっともち上げて、そっとあいさつをした。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "みえっぱりも、ぼうしをちょっともち上げて、もういちどあいさつをした。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、みえっぱりはきいてなかった。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "みえっぱりは、ほめことばにしか、ぜったい耳をかさない。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、王さま、みえっぱり、しごとにんげんやのんだくれなんかよりは、ばかばかしくない。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "王さま、みえっぱり、のんだくれ、しごとにんげんから。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かぞえてみると、王さまが（もちろん黒いかおの王さまも入れて）111にん、ちりのはかせが7000にん、しごとにんげんが90まんにん、のんだくれが750まんにん、みえっぱりが３おく1100まんにんで、あわせてだいたい20おくのおとなのひとがいる。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
