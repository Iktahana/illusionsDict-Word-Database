        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "叛軍に対する所罰としては、銃五十｜梃の没収、未納の税金徴収、二十｜哩の道路工事等が課せられたに過ぎなかった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七の歳、お蒼前樣の祭禮に馬から落ちて、右の脚を折り左の眼を潰した豐吉は、村役場の小使になつてゐて、私が訪ねて行つた時は、第一期地租附加税の未納督促状を、額の汗を拭き／＼謄寫版で刷つてゐた。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七の歳、お蒼前様の祭礼に馬から落ちて、右の脚を折り左の眼を潰した豊吉は、村役場の小使になつてゐて、私が訪ねて行つた時は、第一期地租附加税の未納督促状を、額の汗を拭き／＼謄写版で刷つてゐた。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "部落の小作料はもう五年間も未納だ。",
              "citation": {
                "source": "飛行機の下の村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいだけの配付の中で、未納が三分一はあるやろな。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "須貝、未納、二人共軽装。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　だって、勝とうと思ったら、誰だって……難しい球打つわよ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　（窓の傍で）御覧なさい。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　そんなところで、何か言ってないでさァ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　用心深いのね。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　お洗濯の連中よ、また引っ張られてくらしい。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　珍らしいものなんて、言ってやしないわ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　ああ言うのは、仕方がないのね。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　直ぐ還して貰えるもんで、馴れっこになってるんだわ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　連れてかれてよ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　洗濯どころじゃない。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　グロテスク……。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　暑いなあ、今日は……。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　如何、もう、ワン・ゲエム。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　折角の日曜日だのに……ぼんやりしてちゃ、つまんないわ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　負けるからね。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　子供じゃないわ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　昨日も約束したでしょう。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　何時でも思い出すのね。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　言った後からは、今度から……。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　出鱈目言ってないで、行きましょう。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　少し堅めるといいんだわ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　撮影所の裏に、ローラーがあるのよ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　お手伝いしてよ、妾。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　妾、ずっと前だけど、バスケットの選手だったことがあるのよ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
