          "literary": [
            {
              "text": "マン幕をはりめぐらし、正面に三柱の神が祭られている。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "此三柱の神は、皆｜独り神成りまして、御身を隠し給いきと。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この三柱の神は、みな獨神三に成りまして、身を隱したまひき四。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "その底筒の男の命、中筒の男の命、上筒の男の命三柱の神は、墨の江の三前の大神一四なり。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            }
          ]
