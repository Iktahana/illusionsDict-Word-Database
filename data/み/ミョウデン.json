    "definitions": [
      {
        "index": 1,
        "gloss": "rice field in the charge of a nominal holder (ritsuryō system)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
