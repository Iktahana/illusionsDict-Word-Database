    "definitions": [
      {
        "index": 1,
        "gloss": "Mikawa (former province located in the east of present-day Aichi Prefecture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三河と美濃の国境だという境橋を渡って、道はだんだん丘陵の間に入り、この辺が桶狭間の古戦場だという田圃みちを通った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい電車に飛び乗ってうれしくなってしばらく進行していると「三河島の屋根の上」に出る。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高架線路から見おろした三河島は不思議な世界である。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、三河島にあった建物会社というところへ這入って働いた。",
              "citation": {
                "source": "自伝",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三「どうもその猫ばばあの死に様がちっと変じゃありませんかね」　湯屋熊の熊蔵はその晩すぐに神田の三河町へ行って、親分の半七のまえできょう聞き出して来た猫婆の一件を報告した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "手先の松吉が神田三河町の半七の家へ威勢よく駈け込んで来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、三河町の親分さん」と、女は立ち停まって愛想のいい笑顔をみせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "四「おや、三河町の親分さん。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきからどうも唯の人でないらしいと思っていましたが、おまえさんは三河町の親分さんでございましたね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬道の庄太という子分が神田三河町の半七の家へ駈け込んで来たのは、文久元年七月二十日の朝であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっとわけがあってな、三河の親類へきのう、あずけただがな。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかのよかった恭一君が、海のむこうの三河のある村に、もらわれてしまったというのです。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三河にもらわれていったって、いつかまた帰ってくることもあるでしょう。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その物語に題は通えど、これは東の銭なしが、一年思いたつよしして、参宮を志し、霞とともに立出でて、いそじあまりを三河国、そのから衣、ささおりの、安弁当の鰯の名に、紫はありながら、杜若には似もつかぬ、三等の赤切符。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……何とかや――いと呼んでさがして、漸く竹の臺でめぐり合ひ、そこも火に追はれて、三河島へ遁げのびてゐるのだといふ。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もつづいて這入ろうかと思ったが、ビラをみると、一流うかれ節三河屋何某一座、これには少しく恐れをなして躊躇していると、雨がはらはらと降って来た。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "四谷の大木戸手前に三河屋といふ小さい両替店があつて、主人新兵衛夫婦と、せがれの善吉、小僧の市蔵、下女のお松の五人暮らしであつた。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三河屋からは直ぐに訴へ出でがあつたので、犯人の探索が行はれた。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し相手が武士であるから、迂闊に召捕るわけにも行かないので、手先ふたりは三河屋のせがれ善吉を同道して、次郎の屋敷の近所に網を張つてゐると、彼は湯屋へ行くらしく、手拭をさげて表へ出た。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三河屋で一分の銀を両替へしたのは次郎である。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "御迷惑でございましょう」　神田三河町の半七が子分の松吉をつれて、押上村の甚右衛門の店さきに立った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、三河町、めずらしいな。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "元八も道楽者であるだけに、この二人を唯の客ではないらしいと鑑定して、女中にそっとたずねると、彼らは三河町の半七とその子分であるという。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、三河町の親分さんでしたか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「や、三河町か」四　あくる朝、半七は八丁堀の槇原の屋敷へゆくと、けさも杉野の用人の角右衛門が来ていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちよつとわけがあつてな、三河の親類へ昨日、あづけただがな。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかのよかつた恭一君が、海の向かふの三河の或る村にもらはれてしまつたといふのです。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三河にもらはれていつたつて、いつかまた帰つて来ることもあるでせう。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の四つ辻には必ず一かたまりの塵埃が積み捨られてある三河島たんぼを兄と妹は歩いて居たやうに覚えます――。",
              "citation": {
                "source": "処女時代の追憶",
                "author": "断片三種",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒の自由に飲めない彼らは、かかる映画の上に自分を投射して、そこに酌みかわされる美禄に酔うのである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
