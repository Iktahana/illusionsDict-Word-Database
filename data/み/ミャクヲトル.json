          "literary": [
            {
              "text": "脈をとる手のふるひこそかなしけれ――　医者に叱られし若き看護婦！",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "医師　　（老婦人の脈をとる）老婦人　　お前は、その時、収のことを思ひ出してゐた。",
              "citation": {
                "source": "落葉日記（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "医師　　（老婦人の脈をとる）長い沈黙。",
              "citation": {
                "source": "落葉日記（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "脈をとることになると忠実なもので、商売柄、健斎老を啓発することも少なくはありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体も精神も霊性も活発であるかどうかは、人を診察する医者が、まずわれわれの脈をとることをなによりも先にすると同じように、いつでも幼児を見守るものの第一条件として、たえず気がついていなくてはならないことである。",
              "citation": {
                "source": "たましいの教育",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "早見が煙に代つて、病人の脈をとる。",
              "citation": {
                "source": "カライ博士の臨終",
                "author": "人生の最も厳粛であるべき瞬間に、わたくしがもし笑ひの衝動をおさへることができぬとしたら、いつたいどんな罪に問はれるであらう？",
                "note": "青空文庫"
              }
            },
            {
              "text": "早見博士と煙医師が、交※、患者の脈をとる。",
              "citation": {
                "source": "カライ博士の臨終",
                "author": "人生の最も厳粛であるべき瞬間に、わたくしがもし笑ひの衝動をおさへることができぬとしたら、いつたいどんな罪に問はれるであらう？",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙医師は、慌てて、脈をとる。",
              "citation": {
                "source": "カライ博士の臨終",
                "author": "人生の最も厳粛であるべき瞬間に、わたくしがもし笑ひの衝動をおさへることができぬとしたら、いつたいどんな罪に問はれるであらう？",
