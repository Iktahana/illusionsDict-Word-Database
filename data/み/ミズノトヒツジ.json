        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十六年（癸未）　一八八三○四月、春木座にて「菅原実記」を上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日、癸未、晴、寅剋御不例御減、御夢想の告厳重と云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿二日、癸未、霽、丑剋大地震。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「折たく柴の記」によると、白石は元禄癸未の年十一月二十二日の夜大地震に逢ったので藩邸へ伺候した。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六年癸未、三十七歳。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "実文政癸未八月十七日。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "徙り来つた年の翌年壬午が僅に事なく過ぎて、癸未の八月十七日に霞亭は四十四歳で歿した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは渋江抽斎伝に枳園が癸未の年に始て蘭軒に従学したことを言つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "署して「文政癸未孟春廿二日伊沢信恬識」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此年癸未に蘭軒は関定能と云ふものをして装釘せしめて、自らこれに跋した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その百三十四　屋代｜弘賢は此年癸未の武鑑に「奥祐筆所詰、勘定格、百五十俵高、神田明神下、屋代太郎」と記してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文政六年癸未三月歿。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「癸未以病辞相、短述※懐」として七律一首、又「同前七絶八首」として聯作の絶句がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "末には「文政六年歳次癸未秋九月下澣、阿正精藁」と署してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓表に「居丸山邸舎三年、罹疾不起、実文政癸未八月十七日、享年四十四、葬巣鴨真性寺」と書してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その百三十七　北条霞亭と其妻敬とが辛巳の歳に江戸に来てから、此年癸未に至るまで、足掛三年の間、蘭軒の家と往来してゐたことは明である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "前年備後に来て、茶山と親善であつたことは、後者の癸未以後の詩に徴して知られる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "其奥附には「文政六年歳次癸未冬十一月刻成」と記してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "校閲は庚辰に終り、序文は辛巳に成り、剞※は癸未に終つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に癸未に霞亭の歿したことを言つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　当時世間に行はれてゐた千金翼方は、乾隆癸未｜重梓本、王宇泰本等である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "按ずるに蘭軒の女は文化乙丑に長女｜天津が夭し、壬申に二女智貌童女が夭し、文政癸未に四女順が夭し、今又五女万知が夭した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩田楊庵は出羽国山形の七日町から、文政癸未に江戸に出て長泉寺に寓し、尋で蘭軒の門に入つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "六年癸未　平八郎三十一歳。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "末に「文政六年｜癸未四月眞志屋五郎作｜新發意壽阿彌陀佛」と署して、邦字の華押がしてある。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "雅談の成った年は其序によって按ずれば癸未暮春明治十六年である。",
              "citation": {
                "source": "上野",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞けば昔京師の伶人、富士と浅間というものが、喧嘩をしたということだが、今は天保｜癸未ここ一年か半年のうちには、どうでも敵を討たなければならぬ」　いよいよ復讐の一念を、益※ここで強めたのであった。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梨の花青し　圓朝の墓どころ昭和癸未睦月下浣於　巣鴨烟花街龍安居　　　作者第一話　初一念　　　　　一「……」　クリッとした利巧そうな目で小圓太の次郎吉は、縹いろに暮れようとしている十一月の夕空の一角を悲し気に見つめていた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときはこれ昭和癸未のとし春のひと日、おのれまたこのひとまきの境をさりてながくかへりきたる日なきを知りをはんぬ。",
              "citation": {
                "source": "朝菜集",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと気の毒なのは、自ら折角国家社会主義者をもって任じている（尤もその概念規定などは何でもいいので要するに国家という字が大切なのだが）早大の林癸未夫教授が、私有財産制の否定者であるとして某代議士から議会の問題にされたことだ。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
