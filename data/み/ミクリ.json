    "definitions": [
      {
        "index": 1,
        "gloss": "branched bur-reed (Sparganium erectum)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
