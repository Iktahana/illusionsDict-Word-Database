    "definitions": [
      {
        "index": 1,
        "gloss": "to sink deeply into one's mind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんな時だから、どんな映画でも、骨身にしみる。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの王の運命の末路のはかなさがなんとなしに身にしみるようであった。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして病人は臨終の間ぎわまで隣人の親切を身にしみるまで味わわされるのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "光の反射屈折に関する基礎法則を本当によく呑込ませることに全力を集注し、そうしてそれを解説するに最適切な二、三の実例を身にしみるように理解させれば、その余の複雑な光学器械などは、興味さえあらば手近な本や雑誌を見てひとりで分かることである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり身にしみるような宣伝はわりに少ない。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女たちは更に香炉を持って来て机のそばへ置くと、うす紫の煙がゆらゆらと軽く流れて、身にしみるような匂いにお蝶はいよいよ酔わされた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこでもうどの鳥も、なんとか工夫をしなくてはとてもいけない、こんな工合ぢゃ鳥の文明は大ていこゝらでとまってしまふと、口に出しては云ひませんでしたが、心の中では身にしみる位さう思ひつゞけてゐたのでございます。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その月をあおいで、要次郎は夜の寒さが身にしみるように肩をすくめた。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "良いところだとはきいてはいたが夜逃げ同然にはるばる東京から流れて来れば、やはり裏通の暗さは身にしみるのだった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろ／＼と庵のまはりをあるく、雑草のうつくしさがあたらしく身にしみる。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "……四日ぶりに御飯を炊く、四日ぶりにぬく飯をたべる、あたゝかい飯のうまさが今更のやうに身にしみる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙つて聞いてゐると、身にしみるものがあつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日、一日、僕には、いまのこの世の中の苛烈が、身にしみる。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋のゆふ風が身にしみるわ。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　若い者と付合っているだけに、梶田さんは弥三郎の最期を怪談らしく話さなかったが、聴いている私たちは夜風が身にしみるように覚えた。",
              "citation": {
                "source": "鯉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＳ―ＤＯＳや戦争といった本当にばかばかしいものの下らなさが身にしみるとのことなので注釈を頼りに再度挑戦したが、この注釈がとんでもない難物でまたも見事に挫折した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜のかたき討は又近日と約束して、仙助と一緒にここを出ると、秋の夜の寒さが俄かに身にしみるように覚えた。",
              "citation": {
                "source": "真鬼偽鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋風はやっぱり身にしみるな。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵は、そなたの心づくしの肴で、酒も一入身にしみるわ。",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――俊二郎とやら、陸奥の秋風はまたひとしお身にしみる喃」　そこへのっしのっしと来合わしたのは英膳です。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　しめやかに降る雨も、もういかにも秋のものらしい、まだ早いではないかと心細く呟き眺められるけれど、病後の身にしみる何とないつめたさは、やつぱり默つてそれを是認してしまふ。",
              "citation": {
                "source": "道",
                "author": "――ある妻の手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫の声、それを村園や郊外の庭に聴く時、たしかに幽寂の感をひくが、それが一つならず、二つならず、無数の秋虫一度にみだれ咽んで、いわゆる「虫声満地」とか「虫声如雨」とかいう境に至ると、身にしみるような涼しさは掻き消されてしまう憾みがある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に荒涼｜索莫、わたしは遠い昔にさまよい歩いた満洲の冬を思い出して、今年の春の寒さがひとしお身にしみるように感じた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その月を仰いで、要次郎は夜の寒さが身にしみるやうに肩をすくめた。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "――「近代異妖編」",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋のゆう風が身にしみるわ。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "師走の夜の寒さが身にしみるのか、なにか深い物思いに沈んでいるのか、お鉄は両袖をしっかりとかき合わせて、肩をすくめながらおとなしく付いて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "押し詰まるといよいよ寒さが身にしみるようだ」　云いかけて半七は不図このあいだの晩のことを思い出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "お妙　　（身にしみるやうに。",
              "citation": {
                "source": "俳諧師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
