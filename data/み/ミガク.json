    "definitions": [
      {
        "index": 1,
        "gloss": "to polish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は真面目に、ペコペコ頭を下げ、靴を磨くことが、阿呆らしくなった。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又山は上代にあつては所謂｜※歌や歌垣で、若い男女の縁結の役目を勤めて居たものだが、末代になつては博徒のために男を磨く戦場の役目を務めて居る。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその作法というものは、身を慎しみ心を磨く修業である。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小利口にきび／＼と立※る、朝は六つ前から起きて、氣輕身輕は足輕相應、くる／＼とよく働く上、早く江戸の水に染みて早速に情婦を一つと云ふ了簡から、些と高い鼻柱から手足の爪まで、磨くこと洗ふこと、一｜日十｜度に及んだと云ふ。",
              "citation": {
                "source": "片しぐれ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小利口にきび／＼と立※はつて、朝は六つ前から起きて、氣輕身輕は足輕相應、くる／＼とよく働く上、早く江戸の水に染みて、早速情婦を一つと云ふ了簡から、些と高い鼻柱から手足の先まで磨くこと洗ふこと、一日十度に及ぶ。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所詮、句を磨くことは人を磨くことであり、人のかがやきは句のかがやきとなる。",
              "citation": {
                "source": "道〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "隔日位に、お湯に入って皮膚を清潔な健康色に磨くのがよろしいでしょう。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『光』は感傷に發す、眞實の核を磨くことにより。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして君なぞ既にいい腕になっているのだもの、いよいよ腕を磨くべしだネ。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イヤ腕を磨くべきはもとよりだが、腕で芸術が出来るものではない。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "麝香入の匂袋ででもある事か――坊は知るまい、女の膚身を湯で磨く……気取ったのは鶯のふんが入る、糠袋が、それでも、殊勝に、思わせぶりに、びしょびしょぶよぶよと濡れて出た。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋民の小学校にありし頃よく用ひし事あり、丁子と云ふ名はよけれど、之を硯に擦るに、恰も軽石に踵の垢を磨く時の如き異様の音す。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭の捉われは芸を磨くのに邪魔であるからと。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一々に検して、その磨くべきは改めて磨き直した。",
              "citation": {
                "source": "黒檜",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗練に洗練を経るほど、磨けば磨くほど私は厳粛になつた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "※の濃染手拭、酒の名の「潮」の盃、引出よと祝ふとわけて、我が老舗酒はよろしと、新の桝酒に磨くと、春や春、造酒よ造酒よと、酒はかり、朱塗の樽の栓ぬき、神もきかせと箍たたき、たたきめぐれば、ほのぼの明けぬ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のシバルリイは「我」を重んじて、軽々しく死し軽々しく生きず、我がシバルリイは生命を先づ献じて、然る後にシバルリイを成さんとするものゝ如かりし、己れの品性は磨くこと多からずして、他の儀式礼法多き武門に対敵して、反動的に放縦素朴に走りたり。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな忙しい暮らしをしていても、本能のように、肌に垢の附くような事はしていなかった娘ではあるが、意識して体を磨くようになっているきのうきょうに比べて見れば、爺いさんの記憶にあるお玉の姿は、まだ璞のままであった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄苑は、たかくさきほこり、せむのうの花朱を流す、たをりの草に朗かに、白銅磨く湖の水。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、公演もあり、放送もあり、技を磨くには絶好の職業であった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "習慣で、どんなに遅くっても、就床前に必ず歯を磨く前川が、室内の奥についている洗面所の方へ歩いて行く後姿に、「ねえ、冗談は冗談として、ちょっとご相談したいことがあるの家庭教師のことで……」と、云いさして、夫人は、良人の背中でちょっと舌を出してから、追いかけて行った。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時まで経っても研究のための実験であり技術を磨くための練習であった。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は例の古語を引きて、客人心地はいかなるにか、クピド（愛の神）の磨く箭にや中り給ひしなどいひつゝ、われ等に酒を勸めたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧嘩といえば穏かならぬようにも聞えまするが、それも太平の世に武を磨く一つの方便、斬取り強盗とは筋合が違うて、お上でもむずかしゅういわるる筈がござりませぬ」　家風がおのずと染みたのか、但しは主人の口真似か、お菊は淀みもなしにすらすらといい開いて、母の惑いを解こうとした。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、矢張技巧を磨くことは必要だ。",
              "citation": {
                "source": "不思議な鳥",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己を批評する心は自己を磨く心である。",
              "citation": {
                "source": "須磨子の死",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "この姿を一目でも奴が垣間見たならば、忽ち魂を蕩かせて、鋭い毒爪を磨くことであらう、部屋へ入らう。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には靴を磨くブラッシに靴墨を塗って置いて、暗やみで摺れ違いながら人の顔を撫でたりしたそうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "妖狐伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに僕毎日百ずつ息をかけてみがくんですもの」　「実際そうだといいがな」とお父さんが申しました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、いちばん大事な仕事は、空の星をみんな下ろして、みがくことだよ。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
