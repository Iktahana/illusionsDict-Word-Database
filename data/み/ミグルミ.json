        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「へい、」「苞からポンと出た処勝負、ものは何でも構わねえ、身ぐるみ賭けると、おじいが丁で、私が半。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「身ぐるみ脱ぎます――あなたの前でございますが。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「坊主、身ぐるみ脱いで失せおろう」　怪量はちらりと対手を身ながら衣を脱いでさしだした。",
              "citation": {
                "source": "轆轤首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いい相談があると瞞されて、掃溜のような穢い長屋の奥へ引っ張り込まれて、三日のあいだ、腹さんざん慰み物にされて、身ぐるみ剥がれて古浴衣一枚にされて……。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "素ツ裸になつて身ぐるみ大地へ叩きつけたかつた。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるべくならば血ぬらさないで、身ぐるみ丸取りにしようと思いましたものでしたから、仙次の腕やいかにと静かにその体へ目を配りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つは、その辺に悪旗本の屋敷があって、往来の者をむやみに引摺り込んでいかさま博奕をして、身ぐるみ脱いで置いて行かせるので、自然に置いてけ堀という名が出来たというのです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "用心のいゝのは、身ぐるみ着かえてしまって、双子の半纏などを引っかけて、手拭を米屋かぶりなどにして土間の隅の方で竊と見物しているものもある。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "本因坊が台湾に出かけていつた時、何処かの宿屋で盗賊に逢つて、身ぐるみ持つていかれてしまつたんだ。",
              "citation": {
                "source": "本因坊と私",
                "author": "関根金次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かに身ぐるみ剥がれて、絞め殺されたんでしょう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "筆屋の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺らから身ぐるみ剥ぎとって行ぐ奴からさかしまに剥ぎとってやるまでよ！",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "題材から云えば、そのまま一層ひろく、ひろくと拡がってゆき、拡りかたは如何にも惶しかったが、程なくその奔走の姿も新しい看察を伴ってみられるようになり、現在ではあれこれ表面的な題材に拘泥せず、今日の荒い現実のなかへ作家は身ぐるみとびこんで描けという気風にあると思う。",
              "citation": {
                "source": "人生の共感",
                "author": "――求められる文学について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかな罠にはかからない銀狐でも、こんな手紙を読んだなら、身ぐるみ脱いで早速毛皮を送つてやらうといふ気になつたに違ひない！",
              "citation": {
                "source": "金談にからまる詩的要素の神秘性に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は割り部屋がなくなったし、割り部屋があったら、いつ洋服など身ぐるみ盗んでドロンされるか見当もつかず、それだけ世間が平和じゃないんだ、と石川淳が、彼らしい述懐によって世相をガイタンしていたのを妙にハッキリ記憶している。",
              "citation": {
                "source": "精神病覚え書",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーケットというところは元々売買取引するところだが、終戦後は、ここで女を買うことも間に合うし、顔を貸りられて身ぐるみまきあげる取引もあり、一つとして足りない取引がなく、みんなここで間に合うこととなった。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は同じ地点で二度スリにやられたが、身ぐるみはがれたことはない。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "介抱窃盗というのは、介抱するフリをして身ぐるみ持ってくのを云うのだそうで、新宿のマーケットでは酔っ払いが主としてこの被害を蒙るのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "安達ヶ原を承知の上で乗りこむのだから、身ぐるみはがれたってテメエが悪いんだ、なるほど、そうか。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さっきの旅人、しみったれだったな、身ぐるみ剥いでわずか二両さ」「世のセチ辛さがこれで解る、ちょっと外見は立派でも、内へはいると文なしだ」「何さ内みが文なしだから、それで外見を飾るのさ」　穿ったことを話している。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな奴はオレの方が身ぐるみはいでやると、ふだんからそんな強がりを言っていた方です」「そう、そう。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十五　赤罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の常連に至っては身ぐるみ剥いでも浴衣一枚だ。",
              "citation": {
                "source": "朝起の人達",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その月二十九日には、蒲原の酒屋に押込が入つて、賣溜を奪つて逃げ、七月二十八日は小夜の中山で追剥が旅人を脅かし、九月十七日には飛んで鈴鹿峠で大阪の町人夫妻が殺されて大金を取られ、十月七日は、箱根で一人旅の女が身ぐるみ剥がれて居ります」「それは大變だ」　と笹野新三郎。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り、すばらしい冒険をやっちゃったワ」「何うなすったの」「日比谷公園へおびき出されて、身ぐるみ剥がれちゃったの。",
              "citation": {
                "source": "踊る美人像",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「怪我なんかしないけれど、公園の真中で身ぐるみ剥がれちゃったんだから、そりゃ口惜しかったワ。",
              "citation": {
                "source": "踊る美人像",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し今晩はどうかしてるワよ」「そうだろうとも、日比谷公園へ引っ張り出されて、身ぐるみ剥がれて御覧、誰だって少しはどうかするから」　智恵子は同じ長椅子に腰を下して、そっと糸子の短銃の手の上へ自分の手を持って行きました。",
              "citation": {
                "source": "踊る美人像",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の新聞には、三段抜かなんかで頼むよ、『女優柳糸子、日比谷公園で身ぐるみ剥がる』なんていうのは。",
              "citation": {
                "source": "踊る美人像",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その月二十九日には、蒲原の酒屋に押込が入って、売溜を奪って逃げ、七月二十八日は小夜の中山で追剥が旅人を脅かし、九月十七日には飛んで鈴鹿峠で大坂の町人夫妻が殺されて大金を取られ、十月七日は、箱根で一人旅の女が身ぐるみ剥がれております」「それは大変だ」　と笹野新三郎。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、さすがに殿様らしい自尊心を持ち続け乍ら、風呂場でお腰元にお召換をさせて貰う時のように、いとも鷹揚に、一糸も残さず身ぐるみ脱いでしまったのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "大名の倅",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏見の町で古着屋を捜して、トランクを中みぐるみ売った。",
              "citation": {
                "source": "酒徒漂泊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さささっと　ねこぬこタムに　かけよって　何が何だか　わからないうちに　――　みぐるみ　はがされ　まるめられて、　ひもで　ぎゅうぎゅう　ぐるぐるまきに　しばられて。",
              "citation": {
                "source": "ちょびひげサミュエルのはなし",
                "author": "まきまきパンのまき",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
