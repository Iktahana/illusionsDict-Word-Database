    "definitions": [
      {
        "index": 1,
        "gloss": "cardboard box for mandarin oranges",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
