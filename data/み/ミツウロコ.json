        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "北条時政が江の島の窟で弁財天から授かったという、かの三つ鱗のたぐいらしい。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "春陽堂から出たくろうす表紙に三つ鱗の紋所を押したあの本の扉かどこかに、此脚本は、実朝・義時の事を書くつもりの、追つて出る、二篇と相俟つて、三部作に纏ることになるのだ、と言つた添へ書きのあつたことを思ひ出して、更に博士の執念深さ・ねつさに驚歎します。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つ鱗の周囲に擦れ擦れの大きさに円を描く。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "退屈の刻を、数十の線に劃して、行儀よく三つ鱗の外部を塗り潰す子と、尋常に手を膝の上に重ねて、一劃ごとに黒くなる円の中を、端然と打ち守る母とは、咸雍の母子である。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸に三つ鱗はとくに出来上った。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その紋尽しを書いている時だ」「そりゃ……」「ちょうどその丸に三つ鱗を描いてる時だ。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "団十郎の扮した高時の頭は円く、薄玉子色の衣裳には、黒と白との三つ鱗の模様が、熨斗目のように附いていました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "重ねた黒羽二重の袖、紋は三つ鱗。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "辻斬",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩井銀之助の近い親類か、無二の友達で、三つ鱗を定紋にしてゐる家を搜してくれ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "辻斬",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳しく言へば三つ鱗の紋と、旗本武鑑と、あの妹の萩野の顏色さ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "辻斬",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩井銀之助の近い親類か、無二の友達で、三つ鱗を定紋にしている家を捜してくれ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "辻斬",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳しく言えば三つ鱗の紋と、旗本武鑑と、あの妹の萩野の顔色さ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "辻斬",
                "note": "青空文庫"
              }
            }
          ]
        }
