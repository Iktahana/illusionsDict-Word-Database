    "definitions": [
      {
        "index": 1,
        "gloss": "to throw away one's life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
