        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山の中で、雪を売るということが、一方の室で、シトロンやミルクキャラメルを売っているのに対して、いかにも原始的で、室でやりそうな商いではないか。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "成田山のお守り袋のなかに、森永ミルクキャラメルの箱が入っているすがたが浮かんでくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ううん、ミルクキャラメル。",
              "citation": {
                "source": "真坊と和尚さま",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、いって、ミルクキャラメルを下さって、真坊の頭をくるくるとなでられました。",
              "citation": {
                "source": "真坊と和尚さま",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、男と女というものは妙な融合性があるものと見えて、監視に来た吏員の中には娘子軍に降伏して、サイダーを持って来たり、ミルクキャラメルをご馳走したりする人間が出来た。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
