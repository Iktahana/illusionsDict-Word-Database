    "definitions": [
      {
        "index": 1,
        "gloss": "Mimasaka (former province located in the northeast of present-day Okayama Prefecture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "毎年二月半ばから四月五月にかけて但馬、美作、備前、讃岐あたりから多くの遍路がくる。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日、乙巳、天霽、義盛、時兼以下の謀叛の輩の所領美作淡路等の国の守護職、横山庄以下の宗たるの所々、先づ以て之を収公し、勲功の賞に充てらる可しと云々、相州、大官令之を沙汰し申さる、次に侍別当の事、義盛の闕を以て相州に仰せらると云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長政の忠臣遠藤喜右衛門、赤尾｜美作などは、信長も昔の信長とは違う、今では畿内五州、美濃、尾張、三河、伊勢等十二ヶ国の領主である。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥平美作守｜貞能一番乗であったが、陣中に貞勝、貞能、貞昌、父子無事の対面は涙ながらであったと伝える。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の長居は無用、伜美作守勝俊も大阪陣大和口にて、後藤又兵衛出張の時名を挙げた者だ。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "井上、小河の二人は次へ出て、利章方へ一人たりとも參つてはならぬと觸れ、利章の邸の前に往つてゐた者共を、利章の姉婿で、當時｜睡鴎と名告つてゐた黒田｜美作が邸と、其向側の評定所とへ引き上げさせた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "早乙女主水之介、約束通り土産一匹つかわすとこのように申し伝えて、今ただちに南町御番所の水島宇右衛門なる与力の許へ引立てて参れ」　言いおくと、通り合わせた町駕籠を急ぎに急いで仕立てながら、京弥いち人のみを引き随えて、ただちに黒住団七の禄を喰む、宇都宮九万石の主、奥平美作守昌章の上屋敷に行き向いました。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし仮りに、奥平美作守が、九万石封主の力を借りて、これを庇い立てすることあるも、われわれにはまた直参旗本の威権あり！",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "篠崎流奥義の腕にかけても、やわか許すまじと、真に颯爽としながら打ち乗って、一路、美作守上屋敷なる麻布六本木へ急がせました。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀之助様と称えていた若者で、穉くて美作国西北条郡津山の城主｜松平家へ壻入した人であったそうである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "九年には美作守に転じて小普請支配になつてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳さんは嘗て「正弘公懐旧紀事」を閲して、安政元年に米使との談判に成つた条約の連署中に、伊沢美作守の名があるのを見たと云ふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文書に拠れば、政義の職は下田奉行で、安政元年十二月十八日の談判中に、「美作守｜抔は当春より取扱居、馴染之儀にも有之」云々と自ら語つてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "十世助三郎は慶応武鑑の寄合の部に、「伊沢力之助、父美作守、三千二百五十石、三河だい」と記してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」是に由つて観れば、波響広年は美作守道広の弟であつたと見える。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿詞を贈つたものには讚岐の後藤｜漆谷、美作の茂誥大輔、徳島の僧玉澗等があつたことが集に見えてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "正弘等の浦賀に派した応接掛の中には、蘭軒等の総本家の当主、此稿の首に載せた伊沢｜美作守政義が加はつてゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "正弘は彼に於て概ね開国論に左袒し、伊沢｜美作守政義の洋行の議をさへ容れた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯耆美作では大猿を祭り、河内では河伯を崇めると云う。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長江｜美作が気の毒にも、癩を病んで命｜旦夕、そこで一粒を投じてやった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから美作国まで行くのでは、たっぷり二日の道のりだから。",
              "citation": {
                "source": "しっぺい太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "六部は大そうよろこんで、しっぺい太郎を連れて、もう痛い足のこともわすれて、どんどん美作国に向かって急いで行きました。",
              "citation": {
                "source": "しっぺい太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……されば九州で危いのはまず黒田と細川（熊本）であろう……と備後殿（栗山）も美作殿（黒田）も吾儕に仰せ聞けられたでのう。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵の父は十手の名人で無二斎と称し、主人、新免氏の姓を名乗る事を許されて、新免無二斎とも称していたが、この人夫妻の墓は美作の国｜英田郡字宮本と云う所に有る。",
              "citation": {
                "source": "巌流島",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "いけどりと云えば、あさい石見守、赤尾みまさかのかみ、おなじく新兵衛、この三人のかた／″＼は武運つたなく縄目のはじをおうけになって御前へひきすえられました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
