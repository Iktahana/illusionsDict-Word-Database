    },
    "definitions": [
      {
        "index": 1,
        "gloss": "three-year-old",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし鳥獣を羨んだ原始人の三つ子の心はいつまでも生き延びて現代の文明人の社会にも活動している。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし鳥獣をうらやんだ原始人の三つ子の心はいつまでも生き延びて現代の文明人の社会にも活動している。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つ子が百度も聞いた桃太郎の話をあきもしないで、いくどでもきく様な気持の人達はあきもしないで同じ様な事を書いたのをよみます。",
              "citation": {
                "source": "現今の少女小説について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは教育でもなければ、また時代の影響でもない、三つ子の魂そのものです。",
              "citation": {
                "source": "今日の女流作家と時代との交渉を論ず",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つ子の魂百までだと思ふとあさましい。",
              "citation": {
                "source": "十歳以前に読んだ本",
                "author": "――明治四十五年六月『少年世界』の為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "明け暮れお葬式の真似をしていたのでは、三つ子の魂百までもの譬えで、将来に良い影響は及ぼさぬと考えた。",
              "citation": {
                "source": "孟母断機",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお、よう来た、いい子だ、いい子だ」　こう言って祖母は天ぷらを二つ三つ子供の手に握らせた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい「三つ子の魂百までも」というがごとく、何人にも幼少の折、漠然とした職業選定の傾きが心に備われるものである。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三つ子の心は百までも」「老馬｜路を忘れず」という。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "お願だ、どうぞ忘れさせて御呉れ、あの気高い姿とあのかがやく様な顔を」と云って三つ子の様に乳母の肩にかおをうずめて泣いて居る。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い切った事をお主は御云いなされた――コレ若い人、お主はそれをほんの心で聞いては大した事が出来ぬともかぎらぬ、じょうだんだと聞き流され、三つ子の云うた事だと思って居なされナ？",
              "citation": {
                "source": "葦笛（一幕）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私今ネ、フッとやたらに貴方が可哀そうになったんですの、そしたらすぐ涙が出ちゃったんですの、ただそれだけ……」　千世子は三つ子の様に声に出して泣きたいほどやたらむしょうにＨが可哀そうになって来た。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居町の噂などに耳を立てるだけでも紳士らしくない恥しさを感じるが――菊五郎が、三つ子の兄弟を一人でして見ようといふ考へを起したといふだけでも、芝居全体に無人になつた感が深い。",
              "citation": {
                "source": "手習鑑雑談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此が手習鑑では松王・梅王・桜丸の三つ子になつてゐるといふことは、誰でも言ふとほりであらう。",
              "citation": {
                "source": "手習鑑雑談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此三つ子に就いては、当時大阪天満の天神の氏子に、三つ子が生れて恩賞に預つた事があつたのを、取りこんだと言はれてゐるが、如何にも適切で、さうあるべきことであらう。",
              "citation": {
                "source": "手習鑑雑談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒藤太の性格は、そのまゝ松王には行つてゐないが、梅松桜の三つ子の兄弟の順に就いて、池田弥三郎君が、梅王が長男であると言ふ様な気がすると言つてゐるのは面白い。",
              "citation": {
                "source": "手習鑑雑談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人ならば双生児だし、三人ならばどうしても三つ子といわなければならない。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら三つ子が生れたからといって、父が三つ子を双生児と書き誤る筈はないと思う。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり仮りに真一にシャム兄弟的なもう一人の人間があって、それと妾とが同じ日に同じ母から分娩されたとしたら、これは常識からいっても所謂三つ子である。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺は、その大きな、私の頭なんかは一つかみらしい変に太くて曲った指のある手で私の手をひっぱり、三つ子を歩かせる様に私を家へつれ込んだ。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い世の中にはふたごと言って、いっしょに生まれてくる子供たちもありますが、これはふたごでなくて三つ子でした。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "デカルトは「余は思考す、故に余は存在す」という三つ子にでも分るような真理を考え出すのに十何年か懸ったそうだ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「公園に出れば金になる位、このごろじゃァ、おい、三つ子だって知ってるんだよ。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して三つ子の魂百までとも称し、三つ子の時に打ち込んだる魂は、いわゆる習慣は第二の天性であって、牢乎として抜くべからざるものであるから、教育の必要は最もこの際に在る。",
              "citation": {
                "source": "現代の婦人に告ぐ",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つ子の魂百まで、つまりハマ族のままだ。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッハヽヽヽ」「明後日祝言だってのに笑いごとじゃないよ」「聊か困りました」「矢っ張り三つ子の魂って奴で、いつまでたっても直らない」「仕方がなかったんです」　と堀尾君は喧嘩の経緯を話した。",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人などは、立つことが出来ず、可哀想に三つ子の様に畳の上を這っていた。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも、人のかしらといわれるほどのそのほうがいたしたことじゃから、ただの盗みではあるまいと存じおったが、では、雪舟を盗みとって金にでも引き換え、ないしょにみつごうというつもりじゃったのじゃな」「めっそうもござんせんや。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせい様が、人もあろうに磯五に、金をみつごうとしているばっかりにである。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうも朝からじとじとと、こやみもなく時雨がしょぼふって、病床にふしていた老母がふとトロトロと、まどろみにおちたのは、もはや夜も子の刻どき、あるいは草木も眠るうしみつごろであったかもしれません。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
