[
  {
    "uuid": "44ec23d1-8173-5cac-9957-04da6652fb8f",
    "entry": "三つ子",
    "reading": {
      "primary": "みつご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
