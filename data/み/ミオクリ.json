[
  {
    "uuid": "2efd0fc3-8074-5d65-83fa-3c5a28d2b038",
    "entry": "見送り",
    "reading": {
      "primary": "みおくり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "seeing (someone) off",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私はいぶかしく思いながらその後姿をそれとなく見送り縁台に腰をおろすと、馬場はにやにやうす笑いして言いだした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の間の光を肩にうけて、女だけが、私を見送りに出てゐた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所に杯盤の音、戸口に見送りの人声、はや出立たんと吸物の前にすわれば床の間の三宝に枳殻飾りし親の情先ず有難く、この枳殻誤って足にかけたれば取りかえてよと云う人の情もうれし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄下の溜池に海蟹の鋏動かす様がおかしくて見ておれば人を呼ぶ汽笛の声に何となく心｜急き立ちて端艇出させ、道中はことさら気を付けてと父上一句、さらば御無事でと子供等の声々、後に聞いて梯子駆け上れば艫に水白く泡立ってあたりの景色廻り舞台のようにくる／＼と廻ってハンケチ帽子をふる見送りの人々。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船にのるのだか見送りだか二十前後の蝶々髷が大勢居る。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙姫は、龍宮の階段まで見送りに出て、默つて小さい貝殼を差し出す。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私や、どうも、お迎へはいいけれど、このお見送りつてやつは苦手だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも、このお見送りつてやつは、氣のはずまねえものだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月見草の花が白い、カケス畑を知らぬ間に過ぎて、自動車はスケッチ帳入りの小嚢を手に下げた茨木君と私と長男隼太郎外、強力一人を大野原に吐き出して、見送りのため同乗せられた大山さんと、梅月の主人をさらって、影を没してしまう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはだまってそれを見送りました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中の駅でもまた函館の波止場でも到る処で見送りが盛んであった。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は今、室生君の告別を見送りながら、一人あとに殘された自分の道を眺めてゐる。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見送りの百姓達で家の表、賑々しい。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "見送りの人々もみな苦々しい顔をしていたなかにその寂しい老人と彼女は重いため息をついていた。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出発半時間前、中央ステイションのプラット・ホームには、ミサコの夫と彼女の女弟子たち、カリタ夫妻が彼女を見送りにきていた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミサコは、小さなワニ皮の旅行鞄に少時の憂愁をかくして、皮手袋を脱ると見送りの人々と握手をかわした。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぎりで客へは何の挨拶もしない、その後ろ姿を見送りもしなかった。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまきの棺が寺へゆき着くと、そこにはほかにも貧しい葬式があって、その見送り人は徐々に帰りかかるところであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまきの葬式は丁度それと入れ違いに本堂に繰り込むと、前に来ていた見送り人はやはり芝辺の人達が多かったので、あとから来たおまきの見送り人と顔馴染みも少なくなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、おまえさんもお見送りですか」「御苦労さまです」　こんな挨拶が方々で交換された。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんから評判のよくない母子ではあったが、それでも近所の義理があるのと、もう一つにはお作の横死が人々の同情をひいたとみえて、見送り人は案外に多いらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰一人の見送りとてない出発であった。",
              "citation": {
                "source": "過古",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何台もの電車を私達は見送りました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おしまいまで見ていないですぐお帰りになるといいわ」家内は玄関の式台に立って見送り、落ち着いていた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　兄さんはそう言って屈託なく笑って帰りましたけれど、私は勝手口に立ったままぼんやり見送り、それからお部屋へ引返して、母の物問いたげな顔にも気づかぬふりして、静かに坐り、縫いかけの袖を二針三針すすめました。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人をお見送りしてから、目刺を焼いて簡単な昼食をすませて、それから園子をおんぶして駅へ買い物に出かけた。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柏の木はみんな踊のままの形で残念そうに横眼で清作を見送りました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もういまはけっこんをすませた森のからすも、三マイルさきまで、みおくりについてきました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯彼猿はそのむかしを忘れずして、猶亜米利加の山に栖める妻の許へふみおくりしなどいと殊勝に見ゆる節もありしが、この男はおなじ郷の人をも夷の如くいいなして嘲るぞかたはら痛き。",
              "citation": {
                "source": "みちの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "物和らかな豆腐屋の隠居、義理固い炭薪屋の大将といったような公民級をはじめとして、子分のデモ倉、プロ亀に至るまでがはしゃぎまわってみおくりに来ました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
